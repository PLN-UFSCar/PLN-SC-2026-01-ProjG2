  <rst>
    <segment id="1">Desorganização cancela concurso em Lauro</segment>
    <segment id="2">O tumulto fez o governo municipal suspender o certame</segment>
    <segment id="3">, com 36 mil inscritos</segment>
    <segment id="4">O concurso da Prefeitura de Lauro de Freitas para cargos que exigem ensino médio</segment>
    <segment id="5">, previsto para acontecer neste domingo</segment>
    <segment id="6">, 4, acabou cancelado após candidatos protestarem contra a mudança</segment>
    <segment id="7">, em cima da hora</segment>
    <segment id="8">, do local de provas.</segment>
    <segment id="9">O tumulto fez o governo municipal suspender o certame</segment>
    <segment id="10">, com 36 mil inscritos</segment>
    <segment id="11">, para apurar o porquê das mudanças repentinas.</segment>
    <segment id="12">O concurso oferece mais de 600 vagas para os níveis fundamental</segment>
    <segment id="13">, médio e superior.</segment>
    <segment id="14">Os cargos oferecidos são de geólogo</segment>
    <segment id="15">, biólogo</segment>
    <segment id="16">, odontólogo</segment>
    <segment id="17">, técnico em radiologia</segment>
    <segment id="18">, motorista</segment>
    <segment id="19">, sociólogo</segment>
    <segment id="20">, psicólogo</segment>
    <segment id="21">, professor (do Ensino Fundamental ao 9º ano)</segment>
    <segment id="22">, coordenador Pedagógico</segment>
    <segment id="23">, farmacêutico</segment>
    <segment id="24">, enfermeiro e médico</segment>
    <segment id="25">, dentre outros.</segment>
    <segment id="26">Segundo a prefeita Moema Gramacho</segment>
    <segment id="27">, o concurso com vagas para candidatos que têm curso superior</segment>
    <segment id="28">, previsto para o próximo domingo</segment>
    <segment id="29">, 11, está temporariamente cancelado</segment>
    <segment id="30">, até que as falhas sejam investigadas.</segment>
    <segment id="31">“Estamos apurando.</segment>
    <segment id="32">Uma reunião com a empresa já está marcada.</segment>
    <segment id="33">Todas as denúncias e provas devem ser apresentadas na prefeitura ou no Ministério Público (MP)</segment>
    <segment id="34">", disse Moema.</segment>
    <segment id="35">Ainda de acordo com ela</segment>
    <segment id="36">, a empresa responsável pelo concurso</segment>
    <segment id="37">, a Libri</segment>
    <segment id="38">, alegou que a mudança</segment>
    <segment id="39">sese deveu às escolas escolhidas para locais de prova não terem</segment>
    <segment id="40">sese disponibilizado  no prazo.</segment>
    <segment id="41">“</segment>
    <segment id="42">A Libri tem um histórico de  várias suspensões.</segment>
    <segment id="43">Um dos cancelamentos ocorreu no concurso da cidade de Simões Filho"</segment>
    <segment id="44">, denunciou a candidata Vanesca Brito</segment>
    <segment id="45">, de 36 anos.</segment>
    <segment id="46">Canditatos fazem abaixo-assinado

Alguns candidatos insatisfeitos com o cancelamento protestaram em frente à Unime</segment>
    <segment id="47">, em Lauro de Freitas – local com maior número de inscritos.</segment>
    <segment id="48">A prova deles estava prevista para ter início às 13h30.</segment>
    <segment id="49">O motorista Luciano Abreu</segment>
    <segment id="50">, 40, junto com outros candidatos</segment>
    <segment id="51">, organizaram um abaixo-assinado que deve ser protocolado</segment>
    <segment id="52">, nesta segunda-feira</segment>
    <segment id="53">, 5, na prefeitura e no MP.</segment>
    <segment id="54">Os inscritos</segment>
    <segment id="55">sese queixaram</segment>
    <segment id="56">, sobretudo</segment>
    <segment id="57">, da falta de organização dos locais indicados para realizar o concurso.</segment>
    <segment id="58">Marinalda Santos olhou o site da Libri no dia do certame e descobriu  que o local de prova havia mudado.</segment>
    <segment id="59">"</segment>
    <segment id="60">Fomos avisados sobre as mudanças com menos de 72 horas"</segment>
    <segment id="61">, disse um candidato</segment>
    <segment id="62">, que preferiu não</segment>
    <segment id="63">sese identificar.</segment>
    <segment id="64">Alguns inscritos vieram de longe e lamentaram os prejuízos.</segment>
    <segment id="65">É o caso</segment>
    <segment id="66">caso das amigas Edneide Ferreira da Silva</segment>
    <segment id="67">, 37, e de Meriele Souza</segment>
    <segment id="68">, 28.</segment>
    <segment id="69">As duas vieram de Barra</segment>
    <segment id="70">, a 650 km de Salvador</segment>
    <segment id="71">, para realizar o concurso e tiveram que gastar com transporte e hospedagem.</segment>
    <segment id="72">A reportagem tentou contato com a Libri</segment>
    <segment id="73">, masmas ninguém atendeu os telefones.</segment>
    <segment id="74">Confira nota na íntegra:

"</segment>
    <segment id="75">A Prefeitura de Lauro de Freitas informa que suspendeu o Concurso Público 001 2011</segment>
    <segment id="76">, que seria realizado neste domingo (4) a partir das 13h30</segment>
    <segment id="77">, depois de constatar falhas na organização da empresa licitada para executar o concurso</segment>
    <segment id="78">, principalmente quanto à identificação dos locais de realização das provas</segment>
    <segment id="79">, o que resultou em tumulto em duas das maiores instituições de ensino</segment>
    <segment id="80">, onde</segment>
    <segment id="81">sese concentrava maior número de candidatos.</segment>
    <segment id="82">Para garantir igualdade de direitos</segment>
    <segment id="83">, a Prefeitura preferiu suspender as provas e remarcar uma nova data que será divulgada com a antecedência necessária.</segment>
    <segment id="84">A Prefeitura lamenta o ocorrido</segment>
    <segment id="85">, informa que vai apurar com rigor os fatos e</segment>
    <segment id="86">sese coloca à disposição dos candidatos para outros esclarecimentos".</segment>
  </rst>
</analysis>