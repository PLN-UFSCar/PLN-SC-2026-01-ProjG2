  <rst>
    <segment id="1">Forrozeiros fazem pé-de-meia</segment>
    <segment id="2">A Prefeitura de Senhor do Bonfim vai pagar R$ 80 mil para ter Adelmário Coelho</segment>
    <segment id="3">A Bahia tem 417 municípios</segment>
    <segment id="4">, ou seja</segment>
    <segment id="5">, centenas de festas juninas acontecendo entre os dias 23 e 26 de junho.</segment>
    <segment id="6">E entre os municípios mais bombados está Senhor do Bonfim</segment>
    <segment id="7">, que fica a 376 quilômetros de Salvador.</segment>
    <segment id="8">A prefeitura da cidade</segment>
    <segment id="9">, que espera receber no período junino 50 mil pessoas</segment>
    <segment id="10">, resolveu divulgar os cachês dos artistas que vão tocar este ano</segment>
    <segment id="11">, ao contrário do que fez em 2010.</segment>
    <segment id="12">Serão gastos R$ 798 mil com 16 artistas</segment>
    <segment id="13">, entre eles</segment>
    <segment id="14">, Zé Ramalho</segment>
    <segment id="15">, que vai embolsar R$ 120 mil</segment>
    <segment id="16">, e a banda estourada Garota Safada</segment>
    <segment id="17">, que vai levar R$ 110 mil.</segment>
    <segment id="18">Outra banda de peso nesse pacote é a Magníficos</segment>
    <segment id="19">, que vai apresentar uma superestrutura.</segment>
    <segment id="20">“</segment>
    <segment id="21">São duas carretas para levar equipamento de som</segment>
    <segment id="22">,  iluminação e telões de LED.</segment>
    <segment id="23">Só a dupla Bruno e Marrone tem um arsenal parecido</segment>
    <segment id="24">, masmas o nosso é melhor”</segment>
    <segment id="25">, diz o produtor da Magníficos</segment>
    <segment id="26">, Rapahel Acioli.</segment>
    <segment id="27">A turma não faz mais que dois shows por dia para não prejudicar a qualidade.</segment>
    <segment id="28">O mesmo pensamento tem o cantor Adelmário Coelho</segment>
    <segment id="29">, que já tem 25 shows marcados só em junho.</segment>
    <segment id="30">“</segment>
    <segment id="31">A nossa equipe tem 36 pessoas”</segment>
    <segment id="32">, diz.</segment>
    <segment id="33">Outro forrozeiro que está vibrando com o São João é Zelito Miranda</segment>
    <segment id="34">, que vai abocanhar R$ 45 mil.</segment>
    <segment id="35">“Nosso show é completo.</segment>
    <segment id="36">Os dançarinos têm 13 figurinos diferentes”</segment>
    <segment id="37">, diz Zelito.</segment>
    <segment id="38">A cidade também traz os filhos da terra para a festa.</segment>
    <segment id="39">Cicinho de Assis</segment>
    <segment id="40">, que vai faturar  R$ 27 mil</segment>
    <segment id="41">, e Zaca</segment>
    <segment id="42">, do Trio Bahia</segment>
    <segment id="43">, com cachê de R$ 20 mil</segment>
    <segment id="44">, são bonfinenses e</segment>
    <segment id="45">, além de rever os amigos</segment>
    <segment id="46">, vão ajudar a cidade a gerar mais renda.</segment>
    <segment id="47">Veja quem toca este ano em senhor do Bonfim e o valor que será pago por show</segment>
  </rst>
</analysis>