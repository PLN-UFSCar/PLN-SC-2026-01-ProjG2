  <rst>
    <segment id="1">Corno trocado não dói</segment>
    <segment id="2">Após ser traído em rede nacional por Nicole</segment>
    <segment id="3">, Victor Ramos já é visto com outra
Como já sentenciou a cantora Alcione na  música  “Loba”: “Chumbo trocado não dói!</segment>
    <segment id="4">” (Não gosto nem de ouvir</segment>
    <segment id="5">, minha gente</segment>
    <segment id="6">, os olhos enchem de lágrimas!</segment>
    <segment id="7">Respirando fundo!).</segment>
    <segment id="8">Pois bem</segment>
    <segment id="9">, Victor Ramos</segment>
    <segment id="10">, após ser traído por Nicole  em rede nacional</segment>
    <segment id="11">, resolveu correr atrás do prejuízo (ou de outra costela para amenizar a dor).</segment>
    <segment id="12">Na internet</segment>
    <segment id="13">, os fofoqueiros de plantão</segment>
    <segment id="14">, como</segment>
    <segment id="15">como Gominho do programa Muito+</segment>
    <segment id="16">, afirmam que o jogador do Vitória tem frequentado bares chiques acompanhado por uma gata misteriosa (quem será  a moça?).</segment>
    <segment id="17">Além disso</segment>
    <segment id="18">, neste São João</segment>
    <segment id="19">, o zagueiro pegou a estrada e</segment>
    <segment id="20">sese deslocou para a cidade do Senhor do Bonfim</segment>
    <segment id="21">, onde foi flagrado no forró do Sfrega.</segment>
    <segment id="22">E no maior arrasta-pé com amigos  (Que energia!</segment>
    <segment id="23">Ele foi  após o jogo).</segment>
    <segment id="24">Enquanto isso</segment>
    <segment id="25">, dentro do reality</segment>
    <segment id="26">, a ex-panicat nem imagina a decepção que causou ao seu amado depois de ter beijado Théo Becker.</segment>
    <segment id="27">Ela, para quem não lembra</segment>
    <segment id="28">, já teve um rolo com o ator quando o moço participou da primeira vez de “A Fazenda”.</segment>
    <segment id="29">Nicole já perdoou uma traição de Victor.</segment>
    <segment id="30">Ele, por sua vez</segment>
    <segment id="31">, não sabemos</segment>
    <segment id="32">sese perdoou a moça.</segment>
    <segment id="33">O certo é que ela</segment>
    <segment id="34">, quando sair do reality</segment>
    <segment id="35">, vai  ficar ‘p’ da vida.</segment>
  </rst>
