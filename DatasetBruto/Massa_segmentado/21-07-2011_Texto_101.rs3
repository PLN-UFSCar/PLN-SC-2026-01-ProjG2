  <rst>
    <segment id="1">Caio Júnior já sente a sombra de Cuca no Botafogo
RIO - O coro por Cuca</segment>
    <segment id="2">, que teve o nome gritado após a derrota do Botafogo para o Corinthians por 2 a 0</segment>
    <segment id="3">, na noite de quarta-feira</segment>
    <segment id="4">, em São Januário</segment>
    <segment id="5">, deve ter causado pesadelos no técnico</segment>
    <segment id="6">Caio Júnior.</segment>
    <segment id="7">O treinador alvinegro sabe que a sua situação não é das mais confortáveis.</segment>
    <segment id="8">A vitória sobre o Atlético-PR</segment>
    <segment id="9">, sábado</segment>
    <segment id="10">, em Curitiba</segment>
    <segment id="11">, é fundamental</segment>
    <segment id="12">para que</segment>
    <segment id="13">para que a diretoria não dê ouvidos aos apelos da torcida.</segment>
    <segment id="14">BLOG: 'É Por Ti Fogo'</segment>
    <segment id="15">Cuca ganha força com parte dos alvinegros</segment>
    <segment id="16">, que estão insatisfeitos com o trabalho de Caio Júnior</segment>
    <segment id="17">, apesar dos números bastante razoáveis.</segment>
    <segment id="18">São 17 jogos</segment>
    <segment id="19">, com sete vitórias</segment>
    <segment id="20">, sete empates e apenas três derrotas.</segment>
    <segment id="21">Mas o time não vence no Brasileiro há três partidas.</segment>
    <segment id="22">Vencer fora de casa é mais do que garantir o emprego do técnico.</segment>
    <segment id="23">Significa não</segment>
    <segment id="24">sese afastar da parte de cima da tabela.</segment>
    <segment id="25">O goleiro Jéfferson acredita que a solução para o Botafogo está na Argentina e vai disputar a final da Copa América pelo Uruguai</segment>
    <segment id="26">, no domingo</segment>
    <segment id="27">, contra o Paraguai.

-</segment>
    <segment id="28">A gente sabe da qualidade do Loco.</segment>
    <segment id="29">Quando ele está em campo</segment>
    <segment id="30">, o time adversário respeita.</segment>
    <segment id="31">É frio</segment>
    <segment id="32">, sabe fazer gols</segment>
    <segment id="33">, tem técnica tanto com a perna esquerda quanto com a direita.</segment>
    <segment id="34">Quando ele voltar</segment>
    <segment id="35">, vai nos ajudar muito.</segment>
    <segment id="36">Não vejo ninguém no grupo com as características dele.</segment>
    <segment id="37">Ele é único aqui - afirmou o goleiro.</segment>
  </rst>
