    <segment id="31">Pane na telefonia</segment>
    <segment id="32">Clientes de telefonia fixa</segment>
    <segment id="33">, mГѓВіvel e banda larga da Oi</segment>
    <segment id="34">, em 14 municГѓВ­pios do oeste baiano</segment>
    <segment id="35">, tiveram os serviГѓВ§os suspensos na tarde de domingo</segment>
    <segment id="36">, apГѓВіs um raio causar curto-circuito em um retransmissor do povoado de Lagoa Clara</segment>
    <segment id="37">, municГѓВ­pio de Santana</segment>
    <segment id="38">, a 812 km de Salvador.</segment>
    <segment id="39">Гўв‚¬Е“Tive um prejuГѓВ­zo que nem consigo calcular</segment>
    <segment id="40">, pois</segment>
    <segment id="41">pois enquanto estava sem sinal</segment>
    <segment id="42">, deixei de vender muita mercadoria.</segment>
    <segment id="43">Hoje, ninguГѓВ©m anda mais com dinheiro no bolsoГўв‚¬</segment>
    <segment id="44">, afirmou a dona de mercado e aГѓВ§ougue em LuГѓВ­s Eduardo MagalhГѓВЈes</segment>
