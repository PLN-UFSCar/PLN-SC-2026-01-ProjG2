  <rst>
    <segment id="1">Jovem é sequestrada e torturada a mando de ex-namorado preso
RIO - Dos fios negros quase na cintura</segment>
    <segment id="2">, a jovem Silvia Regina</segment>
    <segment id="3">, de 21 anos</segment>
    <segment id="4">, tem agora só a lembrança da foto de quando estava grávida.</segment>
    <segment id="5">Desde o início dos tempos</segment>
    <segment id="6">, os cabelos são símbolo de força</segment>
    <segment id="7">, saúde</segment>
    <segment id="8">, rebeldia.</segment>
    <segment id="9">Nas mulheres</segment>
    <segment id="10">, também feminilidade</segment>
    <segment id="11">, e muito mais.</segment>
    <segment id="12">Em São Gonçalo</segment>
    <segment id="13">, a história retrocedeu séculos.</segment>
    <segment id="14">Ela foi sequestrada na segunda-feira e teve a cabeça raspada pela ex-sogra</segment>
    <segment id="15">, a mando do pai de sua filha</segment>
    <segment id="16">, que está preso por tráfico em Bangu.</segment>
    <segment id="17">A "lição" lhe custou as madeixas longas em duas horas de espancamento.
- Foram horas de horror.</segment>
    <segment id="18">Eles me bateram com pedaços de pau e depois rasparam meus cabelos.</segment>
    <segment id="19">Minha ex-sogra ameaçava me matar com uma faca e dizia que era para eu ter vergonha e ir visitar o filho dela no presídio.</segment>
    <segment id="20">Tudo isso</segment>
    <segment id="21">porque</segment>
    <segment id="22">porque terminei o relacionamento.</segment>
    <segment id="23">Eu não queria essa vida de mulher de presidiário - disse Silvia Regina Evangelista</segment>
    <segment id="24">, ao começar a contar</segment>
    <segment id="25">comocomo foram os momentos em que esteve nas mãos dos sequestradores.</segment>
    <segment id="26">Silvia foi levada à força por Regina Célia dos Santos Nicolau</segment>
    <segment id="27">, de 39 anos.</segment>
    <segment id="28">Ela é mãe do traficante Carlos Renato Nicolau da Conceição</segment>
    <segment id="29">, de 19 anos.</segment>
    <segment id="30">Os vizinhos viram</segment>
    <segment id="31">Silvia ser arrastada pelos cabelos.</segment>
    <segment id="32">Era só o início do suplício que deixou seu corpo cheio de hematomas.</segment>
    <segment id="33">A ex-sogra cortou seus cabelos.</segment>
    <segment id="34">E a ex-cunhada arrancou os tufos restantes à máquina.</segment>
    <segment id="35">Agora, Silvia usa uma bandana na cabeça</segment>
    <segment id="36">, sob o capuz de um casaco.</segment>
    <segment id="37">A ex-sogra não agiu sozinha.</segment>
    <segment id="38">Com ela estavam a ex-cunhada</segment>
    <segment id="39">, uma menor de 16 anos</segment>
    <segment id="40">, e Antônio Eudivan de Moura Pereira</segment>
    <segment id="41">, de 22 anos</segment>
    <segment id="42">, e Luiz Fernando Rodrigues da Silva</segment>
    <segment id="43">, de 28 anos.</segment>
    <segment id="44">O grupo arrombou a porta da casa da jovem que estava com filha</segment>
    <segment id="45">, no bairro Maria Paula</segment>
    <segment id="46">, e a levaram para um matagal na favela do Arrastão.</segment>
    <segment id="47">A ordem teria partido de dentro do Presídio Muniz Sodré</segment>
    <segment id="48">, onde está Carlos Renato.</segment>
    <segment id="49">Nesta terça-feira era aniversário de 1 ano da filha de Silvia</segment>
    <segment id="50">, provavelmente com Carlos Renato.</segment>
    <segment id="51">Eles tinham combinado que seria feito um teste de DNA.</segment>
    <segment id="52">Inconformado com o fim do relacionamento</segment>
    <segment id="53">, ele já não recebia visitas de Silva</segment>
    <segment id="54">, que tem outro namorado.

- Ele não aceitava o fim do relacionamento.</segment>
    <segment id="55">Eu só queria levar minha vida em paz - resumiu Silvia.</segment>
    <segment id="56">Silvia foi resgatada por volta das 13h</segment>
    <segment id="57">, quando seria levada para outro cativeiro</segment>
    <segment id="58">, num Corsa que acabou sendo interceptado por policiais militares.</segment>
    <segment id="59">De acordo com o delegado titular da 74 DP (Alcântara)</segment>
    <segment id="60">, Jorge Veloso</segment>
    <segment id="61">, eles responderão a inquérito por sequestro e tortura.</segment>
    <segment id="62">Autora do "</segment>
    <segment id="63">Livro do Cabelo"</segment>
    <segment id="64">, Leusa Araújo observa que o episódio é gravíssimo:

- Há rituais religiosos</segment>
    <segment id="65">, masmas esse</segment>
    <segment id="66">casocaso está no universo do castigo.</segment>
    <segment id="67">A forma mais rápida de tirar a identidade de uma pessoa e puni-la é raspar seu cabelo.</segment>
    <segment id="68">No caso</segment>
    <segment id="69">caso da mulher</segment>
    <segment id="70">, você tira dela o feminino.</segment>
    <segment id="71">É uma coisa horrorosa que degrada e humilha.</segment>
    <segment id="72">Na França</segment>
    <segment id="73">, depois da Segunda Guerra</segment>
    <segment id="74">, as mulheres que dormiram com soldados alemães tiveram a cabeça raspada e foram expostas na rua.</segment>
    <segment id="75">De acordo com levantamento de dados do cadastro da polícia</segment>
    <segment id="76">, Carlos Renato foi condenado por tráfico de drogas a oito anos de reclusão.</segment>
    <segment id="77">Ele está preso há um ano e meio no Muniz Sodré.</segment>
    <segment id="78">De acordo com a polícia ele é acusado de chefiar e gerenciar uma das bocas de fumo do Morro do Preventório</segment>
    <segment id="79">, em Charitas</segment>
    <segment id="80">, Niterói.</segment>
    <segment id="81">Já na sua ficha na Polícia Civil</segment>
    <segment id="82">, segundo o delegado Jorge Veloso</segment>
    <segment id="83">, consta que Carlos Renato foi preso em no bairro Jóquei</segment>
    <segment id="84">, em São Gonçalo</segment>
    <segment id="85">, no dia 29 de outubro de 2010.</segment>
    <segment id="86">Na ocasião</segment>
    <segment id="87">, ele estava com drogas e uma arma.</segment>
  </rst>
</analysis>