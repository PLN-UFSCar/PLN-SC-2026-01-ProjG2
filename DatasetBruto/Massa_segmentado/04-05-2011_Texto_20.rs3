  <rst>
    <segment id="1">Fluminense perde para o Libertad por 3 a 0 e está fora da Libertadores

RIO - Nem parecia o time de guerreiros.</segment>
    <segment id="2">O Fluminense tentou jogar amparado pela vantagem de dois gols conseguida no Rio</segment>
    <segment id="3">, masmas acabou castigado pelo excesso de cautela.</segment>
    <segment id="4">Praticamente sem atacar durante os 90 minutos</segment>
    <segment id="5">, o time carioca perdeu por 3 a 0 para o Libertad no Defensores del Chaco</segment>
    <segment id="6">, e foi eliminado nas oitavas de final da Taça Libertadores.</segment>
    <segment id="7">TEMPO REAL:</segment>
    <segment id="8">Como foi o jogo</segment>
    <segment id="9">, lance a lance 
Mesmo depois de levar o primeiro gol</segment>
    <segment id="10">, marcado por Rojas no início do segundo tempo</segment>
    <segment id="11">, o Fluminense preferiu segurar o resultado.</segment>
    <segment id="12">Aos 40 minutos</segment>
    <segment id="13">, porém</segment>
    <segment id="14">porém, Samudio fez o gol que colocou a equipe paraguaia com a vaga na mão.</segment>
    <segment id="15">Já nos acréscimos</segment>
    <segment id="16">, Nuñes fechou o placar.</segment>
    <segment id="17">O Fluminense quase pagou caro por sua postura defensiva no início do jogo.</segment>
    <segment id="18">Precisando de gols</segment>
    <segment id="19">, o Libertad encurralou o time carioca em seu campo e deu trabalho para Ricardo Berna</segment>
    <segment id="20">, que fez boas defesas em cabeçada perigosa</segment>
    <segment id="21">, aos 19 minutos</segment>
    <segment id="22">, e em chuta de longe de Gamarra</segment>
    <segment id="23">, aos 21.</segment>
    <segment id="24">Logo depois</segment>
    <segment id="25">, Diguinho recuou perigosamente e Berna foi obrigado em chutar em cima de Gamarra.</segment>
    <segment id="26">A bola ainda bateu na trave direita antes de sair.</segment>
    <segment id="27">Aos poucos o Fluminense conseguiu equilibrar o jogo</segment>
    <segment id="28">, masmas pouco ameaça o gol de Vargas.</segment>
    <segment id="29">Em seu melhor ataque</segment>
    <segment id="30">, aos 42</segment>
    <segment id="31">, Conca cruzou e Diego cabeceou no travessão paraguaio.</segment>
    <segment id="32">O início do segundo tempo repetiu o roteiro da etapa inicial</segment>
    <segment id="33">, com os donos da casa pressionando em busca do primeiro gol.</segment>
    <segment id="34">E de tanto insistir o Libertad abriu o placar aos 13: Rojas</segment>
    <segment id="35">, que havia entrado quatro minutos antes</segment>
    <segment id="36">, arriscou de longe</segment>
    <segment id="37">, no canto direito de Berna.</segment>
    <segment id="38">Ao contrário do que</segment>
    <segment id="39">sese poderia imaginar</segment>
    <segment id="40">, no entanto</segment>
    <segment id="41">, o time paraguaio não aproveitou o bom momento para aumentar a pressão.</segment>
    <segment id="42">Pelo contrário</segment>
    <segment id="43">, foi o Fluminense quem teve sua melhor chance</segment>
    <segment id="44">, com Fred</segment>
    <segment id="45">, que recebeu ótimo passe de Marquinho na área</segment>
    <segment id="46">masmas bateu muito mal</segment>
    <segment id="47">, por cima</segment>
    <segment id="48">, aos 27 minutos.
Mas</segment>
    <segment id="49">comocomo o tricolor carioca</segment>
    <segment id="50">sese recusava a atacar</segment>
    <segment id="51">, acabou atraindo o adversário para o seu campo.</segment>
    <segment id="52">Nuñes assustou com um chute cruzado</segment>
    <segment id="53">, aos 35.</segment>
    <segment id="54">Na oportunidade seguinte</segment>
    <segment id="55">, o Libertad não desperdiçou:</segment>
    <segment id="56">Samudio acertou um belo chute da meia-lua</segment>
    <segment id="57">, no canto esquerdo de Berna</segment>
    <segment id="58">, e fez o gol que mudou a situação do jogo.</segment>
    <segment id="59">Agora desclassificado</segment>
    <segment id="60">, o tricolor tentou sufocar nos minutos finais</segment>
    <segment id="61">, masmas acabou sofrendo o terceiro aos 46:</segment>
    <segment id="62">Nuñes recebeu cruzamento da direita e completou de primeira.</segment>
    <segment id="63">Logo depois</segment>
    <segment id="64">, Mariano ainda foi expulso pouco depois. 

LIBERTAD 3</segment>
    <segment id="65">X 0 FLUMINENSE
Libertad: Vargas</segment>
    <segment id="66">, Bonet</segment>
    <segment id="67">, Portocarrero</segment>
    <segment id="68">, Canuto e Samudio</segment>
    <segment id="69">; Ayala (Rojas)</segment>
    <segment id="70">, Cáceres</segment>
    <segment id="71">, Aquino e Gamarra (Nuñez)</segment>
    <segment id="72">;</segment>
    <segment id="73">Maciel (Orue) e Pavlovich.</segment>
    <segment id="74">Fluminense:</segment>
    <segment id="75">Ricardo Berna</segment>
    <segment id="76">, Mariano</segment>
    <segment id="77">, Gum, Edinho e Julio Cesar</segment>
    <segment id="78">; Valencia (Diogo)</segment>
    <segment id="79">, Diguinho (Rodriguinho)</segment>
    <segment id="80">, Marquinho e Conca</segment>
    <segment id="81">; Fred e Rafael Moura (Araújo).</segment>
    <segment id="82">Juiz: Roberto Silvera (Fifa-URU).
Cartões amarelos: Pavlovich</segment>
    <segment id="83">, Marquinho</segment>
    <segment id="84">, Ricardo Berna</segment>
    <segment id="85">, Ayala</segment>
    <segment id="86">, Diguinho.</segment>
    <segment id="87">Cartão vermelho: Mariano.</segment>
  </rst>
