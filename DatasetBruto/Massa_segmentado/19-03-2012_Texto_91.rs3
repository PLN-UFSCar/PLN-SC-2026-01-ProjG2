  <rst>
    <segment id="1">Filho de Eike Batista mata ciclista
Wanderson Pereira dos Santos foi vítima do acidente na rodovia Washington Luís</segment>
    <segment id="2">O empresário Thor Batista</segment>
    <segment id="3">, 24 anos</segment>
    <segment id="4">, filho mais velho do bilionário Eike Batista</segment>
    <segment id="5">, atropelou e matou</segment>
    <segment id="6">, no último sábado</segment>
    <segment id="7">, o ciclista e ajudante de caminhão Wanderson Pereira dos Santos</segment>
    <segment id="8">, 30, na Rodovia Washington Luís (BR-040)</segment>
    <segment id="9">, em Duque de Caxias</segment>
    <segment id="10">, no Rio de Janeiro.</segment>
    <segment id="11">O caso</segment>
    <segment id="12">caso foi registrado na 61ª Delegacia de Polícia</segment>
    <segment id="13">, em Xerém</segment>
    <segment id="14">, como</segment>
    <segment id="15">como homicídio culposo</segment>
    <segment id="16">, provocado por atropelamento.</segment>
    <segment id="17">Thor terá de depor na próxima quinta</segment>
    <segment id="18">, e pode ser indiciado.</segment>
    <segment id="19">Além do filho de Eike</segment>
    <segment id="20">, Maria Vicentina Pereira</segment>
    <segment id="21">, tia da vítima</segment>
    <segment id="22">, também deve ser ouvida nos próximos dias.</segment>
    <segment id="23">A família da vítima deve pedir indenização na justiça por danos morais e materiais.</segment>
    <segment id="24">Eles acham que a perícia após o acidente foi irregular.</segment>
    <segment id="25">“Ele foi atingido no acostamento</segment>
    <segment id="26">, atropelado de frente”</segment>
    <segment id="27">, contou a tia de Wanderson.</segment>
    <segment id="28">Porém,  a única testemunha que prestou depoimento disse que  a vítima foi atropelada quando atravessava a via.</segment>
    <segment id="29">Wanderson foi enterrado ontem à tarde.</segment>
    <segment id="30">Bilionário sai em defesa de Thor</segment>
    <segment id="31">O Grupo EBX</segment>
    <segment id="32">, de Eike Batista</segment>
    <segment id="33">, defendeu Thor:</segment>
    <segment id="34">“</segment>
    <segment id="35">Ele lamenta profundamente o ocorrido e diz que prestou socorro à vitima</segment>
    <segment id="36">, que atravessava</segment>
    <segment id="37">, inadvertidamente</segment>
    <segment id="38">, a rodovia.</segment>
    <segment id="39">Thor estava na velocidade permitida e fez o teste do bafômetro.</segment>
    <segment id="40">Ele prestará toda a assitência à família de Wanderson e comparecerá no curso da semana para prestar depoimento na 61ª DP”</segment>
    <segment id="41">, informou em nota.</segment>
  </rst>
</analysis>