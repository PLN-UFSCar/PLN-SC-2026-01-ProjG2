  <rst>
    <segment id="1">Lula relaxa antes da quimioterapia</segment>
    <segment id="2">Hoje ele começa o tratamento da laringe</segment>
    <segment id="3">Um dia após receber a notícia sobre um tumor na laringe</segment>
    <segment id="4">, o ex-presidente Luiz Inácio da Silva passou o dia de ontem descansando em seu apartamento em São Bernardo e hoje começa a quimioterapia.</segment>
    <segment id="5">No meio da tarde</segment>
    <segment id="6">, Lula pareceu na janela da sacada do apartamento com um bebê no colo.</segment>
    <segment id="7">Segundo a assessoria do ex-presidente</segment>
    <segment id="8">, foi recomendado que Lula não usasse a voz</segment>
    <segment id="9">, devido ao exame em que foi submetido no sábado.</segment>
    <segment id="10">O médico de Lula</segment>
    <segment id="11">, Roberto Kalil Filho</segment>
    <segment id="12">, visitou o ex-presidente.</segment>
    <segment id="13">Segundo ele</segment>
    <segment id="14">, Lula está bem humorado e tranquilo.</segment>
    <segment id="15">“Ele está extremamente bem humorado e confiante e isso é fundamental para o sucesso de qualquer tratamento”</segment>
    <segment id="16">, disse.</segment>
    <segment id="17">Segundo Kalil Filho</segment>
    <segment id="18">, Lula quer total transparência sobre sua doença.</segment>
    <segment id="19">“Ele determinou aos médicos que fossem bem transparentes</segment>
    <segment id="20">, Lula sabe o que foi diagnosticado</segment>
    <segment id="21">, tudo foi bem discutido”</segment>
    <segment id="22">, afirmou.</segment>
    <segment id="23">O presidente venezuelano Hugo Chávez manifestou esperança pela recuperação de Lula
 
Lula passou por exames sábado</segment>
    <segment id="24">, no Hospital Sírio-Libanês</segment>
    <segment id="25">, em São Paulo</segment>
    <segment id="26">, que detectaram a doença.</segment>
    <segment id="27">Os médicos optaram por fazer a quimioterapia para preservar o órgão.</segment>
    <segment id="28">Ex-fumante</segment>
    <segment id="29">, Lula gosta de cigarrilhas</segment>
    <segment id="30">, hábito que dividia com o seu vice</segment>
    <segment id="31">, José Alencar</segment>
    <segment id="32">, morto em março deste ano.</segment>
    <segment id="33">Os dois também costumavam tomar “uns goles”</segment>
    <segment id="34">, como</segment>
    <segment id="35">como dizia Alencar.</segment>
    <segment id="36">Doutor MASSA!</segment>
    <segment id="37">O câncer de laringe ocorre predominantemente em homens e é um dos mais comuns entre os que atingem a região da cabeça e pescoço.</segment>
    <segment id="38">Representa cerca de 25% dos tumores malignos que acometem essa área e 2% de todas as doenças malignas.</segment>
    <segment id="39">A ocorrência pode</segment>
    <segment id="40">sese dar em uma das três porções em que</segment>
    <segment id="41">sese divide o órgão: laringe supraglótica</segment>
    <segment id="42">, glote e subglote.</segment>
    <segment id="43">O álcool é um fator de risco a mais para a evolução da doença</segment>
    <segment id="44">, masmas também existem causas virais.</segment>
    <segment id="45">No caso</segment>
    <segment id="46">caso de Lula</segment>
    <segment id="47">, ainda não foi possível afirmar o que levou ao desenvolvimento do tumor.</segment>
  </rst>
</analysis>