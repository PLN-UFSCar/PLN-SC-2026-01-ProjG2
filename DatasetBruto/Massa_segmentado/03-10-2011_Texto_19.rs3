  <rst>
    <segment id="1">Há 50 anos:</segment>
    <segment id="2">Otelo escala scratch parlamentar...</segment>
    <segment id="3">Otelo Caçador escreve hoje na sua coluna "Penalty":
"</segment>
    <segment id="4">O scratch dos pernas de pau</segment>
    <segment id="5">, esta semana</segment>
    <segment id="6">, deveria ser formado por êstes senhores (que representam tôda a Assembleia dos Deputados da Guanabara)</segment>
    <segment id="7">; Gérson Bergher</segment>
    <segment id="8">, Paulo Alberto e Levi Neves</segment>
    <segment id="9">; Átila Nunes</segment>
    <segment id="10">, Silbert Sobrinho e Valdemar Viana</segment>
    <segment id="11">; Amaral Neto</segment>
    <segment id="12">, Saldanha Coelho</segment>
    <segment id="13">, Roland Corbisier</segment>
    <segment id="14">, Lopo Coelho e Gama Filho.</segment>
    <segment id="15">Foram nomes escolhidos ao acaso</segment>
    <segment id="16">, sem nenhuma intenção política.</segment>
    <segment id="17">Só êles fingem não compreender que não é possível serem realizadas partidas de futebol com entrada a nove cruzeiros.</segment>
    <segment id="18">Com esta quantia</segment>
    <segment id="19">, não se</segment>
    <segment id="20">se engraxa sapato</segment>
    <segment id="21">, não se</segment>
    <segment id="22">se compra um bom jornal</segment>
    <segment id="23">, não se</segment>
    <segment id="24">se toma uma cachaça nem um sorvete.</segment>
    <segment id="25">E nem se</segment>
    <segment id="26">se compra uma mariola (que custa dez cruzeiros no próprio Maracanã).</segment>
    <segment id="27">E ficam os nobres deputados cozinhando o projeto do aumento dos preços dos ingressos das entradas de futebol.</segment>
    <segment id="28">Enquanto isso</segment>
    <segment id="29">, o futebol carioca vai entrando pelo cano.</segment>
    <segment id="30">"

...que não veste camisa dos clubes</segment>
    <segment id="31">O presidente da FCF</segment>
    <segment id="32">, Antônio do Passo</segment>
    <segment id="33">, encaminhou ontem ao deputado Gonzaga da Gama Filho</segment>
    <segment id="34">, as propostas da entidade em número de 7</segment>
    <segment id="35">, apresentadas às TVs em 18 de julho do corrente ano.</segment>
    <segment id="36">Ontem mesmo o referido parlamentar falou sôbre o assunto da tribuna da Câmara</segment>
    <segment id="37">, lendo tôdas as propostas e fazendo referência principalmente à última</segment>
    <segment id="38">, pela qual a FCF permitiria o televisamento absolutamente grátis desde que antes</segment>
    <segment id="39">, durante e depois das transmissões não fôsse feito nenhum anúncio</segment>
    <segment id="40">, o que as emissoras não aceitaram.</segment>
  </rst>
</analysis>