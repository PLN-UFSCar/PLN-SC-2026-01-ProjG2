  <rst>
    <segment id="1">Dimas tem chance de mostrar valor</segment>
    <segment id="2">O técnico Toninho Cerezo vai colocar o lateral Sub - 20 contra o Juazeiro</segment>
    <segment id="3">Em 2009 quando levou o Vitória às semifinais do Campeonato Brasileiro da Série A</segment>
    <segment id="4">, Toninho Cerezo apostou em jovens valores</segment>
    <segment id="5">comocomo Leandrinho</segment>
    <segment id="6">, Tácio</segment>
    <segment id="7">, Baiano</segment>
    <segment id="8">, Fernando e Cláudio.</segment>
    <segment id="9">E não se</segment>
    <segment id="10">se arrependeu.</segment>
    <segment id="11">De volta ao Leão</segment>
    <segment id="12">, ele parece que não perdeu a confiança na divisão de base e</segment>
    <segment id="13">, sem poder contar com Nino Paraíba</segment>
    <segment id="14">, Léo e Romário</segment>
    <segment id="15">, todos contundidos</segment>
    <segment id="16">, vai lançar o garoto Dimas na lateral direita para o jogo de amanhã</segment>
    <segment id="17">, no Barradão</segment>
    <segment id="18">, contra o Juazeiro</segment>
    <segment id="19">, pela segunda rodada do Campeonato Baiano.</segment>
    <segment id="20">E a data não poderia ser melhor para Dimas</segment>
    <segment id="21">, que completa 20 anos neste domingo.</segment>
    <segment id="22">Ele  terá sua primeira oportunidade no time principal do Vitória.</segment>
    <segment id="23">“Vai ser um grande presente.</segment>
    <segment id="24">Espero retribuir a confiança depositada pelo professor Cerezo”</segment>
    <segment id="25">, falou .</segment>
    <segment id="26">Regularizados</segment>
    <segment id="27">, o goleiro Renan e o volante Michel vão para o banco de reservas.</segment>
    <segment id="28">Toninho Cerezo relacionou 19 jogadores.</segment>
    <segment id="29">O volante Rodrigo Mancha também está regularizado</segment>
    <segment id="30">, masmas não foi relacionado.</segment>
    <segment id="31">Michel sofreu um ferimento na canela durante o coletivo de ontem em campo reduzido e iniciou tratamento.</segment>
    <segment id="32">Os titulares venceram por 2 a 1</segment>
    <segment id="33">, gols de Lúcio Flávio e Neto</segment>
    <segment id="34">, descontando Michel.</segment>
  </rst>
