  <rst>
    <segment id="1">Caixa paralelo do PT seria de R$ 350 milh횄쨉es</segment>
    <segment id="2">, segundo Val횄짤rio
BRAS횄LIA</segment>
    <segment id="3">A revista Veja diz que as afirma횄짠횄쨉es foram feitas a diversos interlocutores.</segment>
    <segment id="4">Procurado pela publica횄짠횄짙o</segment>
    <segment id="5">, Val횄짤rio teria evitado dar entrevista</segment>
    <segment id="6">, masmas n횄짙o desmentiu nada.</segment>
    <segment id="7">O motivo para o operador ter come횄짠ado a detalhar o funcionamento do mensal횄짙o seriam as sucessivas condena횄짠횄쨉es no STF.</segment>
    <segment id="8">Val횄짤rio teria acertado com o PT que receberia uma puni횄짠횄짙o branda em troca de seu sil횄짧ncio.
- Prometeram n횄짙o exatamente absolver</segment>
    <segment id="9">, masmas diziam "</segment>
    <segment id="10">Vamos segurar</segment>
    <segment id="11">, vamos isso</segment>
    <segment id="12">, vamos aquilo"...</segment>
    <segment id="13">Amenizar - teria contado o mensaleiro.</segment>
    <segment id="14">Outra revela횄짠횄짙o feita por Val횄짤rio</segment>
    <segment id="15">, segundo a revista</segment>
    <segment id="16">, 횄짤 de que o caixa do mensal횄짙o seria muito maior do que o descoberto at횄짤 agora.</segment>
    <segment id="17">Val횄짤rio teria contado a interlocutores que o valor seria tr횄짧s vezes maior que os R$ 129 milh횄쨉es revelados:
- Da SMP&amp;B</segment>
    <segment id="18">, v횄짙o achar s횄쨀 os R$ 55 milh횄쨉es</segment>
    <segment id="19">, masmas o caixa era muito maior.</segment>
    <segment id="20">O caixa do PT foi de R$ 350 milh횄쨉es</segment>
    <segment id="21">, com dinheiro de outras empresas que nada tinham a ver com a SMP&amp;B nem com a DNA - teria dito o operador.</segment>
    <segment id="22">Esse dinheiro teria sido obtido com empr횄짤stimos fict횄짯cios tomados por suas empresas e doa횄짠횄쨉es diretas de interessados em obter facilidades no governo: - Muitas empresas davam empr횄짤stimos</segment>
    <segment id="23">, outras n횄짙o.</segment>
    <segment id="24">Segundo a revista</segment>
    <segment id="25">, o ex-presidente Lula teria</segment>
    <segment id="26">sese empenhado pessoalmente na coleta de dinheiro para essa engrenagem.</segment>
    <segment id="27">Val횄짤rio teria afirmado que muitos empres횄징rios reuniam-</segment>
    <segment id="28">sese com o presidente</segment>
    <segment id="29">, acertavam a contribui횄짠횄짙o e despejavam o dinheiro no cofre do PT.</segment>
    <segment id="30">A distribui횄짠횄짙o desses recursos ficaria a cargo do ex-tesoureiro Del횄쨘bio Soares</segment>
    <segment id="31">, que teria registrado detalhadamente a entrada e a sa횄짯da desses recursos em um livro guardado a sete chaves.</segment>
    <segment id="32">O destino final seria o mesmo dos recursos j횄징</segment>
    <segment id="33">descobertos: a remunera횄짠횄짙o de petistas e aliados.</segment>
    <segment id="34">O tesoureiro do PT</segment>
    <segment id="35">, segundo Val횄짤rio</segment>
    <segment id="36">, tinha uma rela횄짠횄짙o pr횄쨀xima com Lula:
- O Del횄쨘bio dormia no Alvorada.</segment>
    <segment id="37">Ele e a mulher dele iam jogar baralho com Lula</segment>
    <segment id="38">횄혻 noite.</segment>
    <segment id="39">Alguma vez isso ficou registrado l횄징 dentro?</segment>
    <segment id="40">Quando voc횄짧 quer encontrar (algu횄짤m)</segment>
    <segment id="41">, voc횄짧 encontra</segment>
    <segment id="42">, e sem registro.</segment>
    <segment id="43">Agora, Val횄짤rio estaria profundamente magoado com os antigos companheiros:
- Eu detesto esse pessoal.</segment>
    <segment id="44">Esse povo acabou com a minha vida</segment>
    <segment id="45">, me fez de um tamanho que eu n횄짙o sou.</segment>
    <segment id="46">O PT me fez de escudo</segment>
    <segment id="47">, me usou</segment>
    <segment id="48">comocomo um boy de luxo.</segment>
    <segment id="49">Mas eles</segment>
    <segment id="50">sese ferraram</segment>
    <segment id="51">porque</segment>
    <segment id="52">porque agora vai todo mundo para o ralo.</segment>
    <segment id="53">Segundo a revista</segment>
    <segment id="54">, o temor de Val횄짤rio em revelar publicamente o que sabe seria por uma quest횄짙o de sobreviv횄짧ncia.
- V횄짙o me matar.</segment>
    <segment id="55">Tenho de agradecer por estar vivo at횄짤 hoje - teria dito.</segment>
