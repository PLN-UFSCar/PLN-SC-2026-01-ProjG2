  <rst>
    <segment id="1">Dor de mãe e ombro amigo do delegado</segment>
    <segment id="2">Jovem tentou sair do mundo das drogas</segment>
    <segment id="3">, masmas acabou morto pelos inimigos</segment>
    <segment id="4">“</segment>
    <segment id="5">Meu filho estava trabalhando</segment>
    <segment id="6">, não era vagabundo</segment>
    <segment id="7">, não estava bagunçando</segment>
    <segment id="8">, gente!</segment>
    <segment id="9">Na hora que ele vai almoçar...</segment>
    <segment id="10">Oh Jesus!</segment>
    <segment id="11">Ele não estava roubando...</segment>
    <segment id="12">Ai, meu Deus!</segment>
    <segment id="13">”.</segment>
    <segment id="14">Aos prantos</segment>
    <segment id="15">, os gritos de dor e desespero eram desabafados por Crispiniana</segment>
    <segment id="16">, mãe do jovem Sílvio Pires Santana</segment>
    <segment id="17">, 20 anos.</segment>
    <segment id="18">Ele foi assassinado a tiros</segment>
    <segment id="19">, por volta das 14h30 de ontem</segment>
    <segment id="20">, na Rua Stella Maris</segment>
    <segment id="21">, perto do campo de futebol na localidade conhecida</segment>
    <segment id="22">comocomo Yolanda Pires</segment>
    <segment id="23">, no bairro de São Cristóvão.</segment>
    <segment id="24">Funcionário de uma oficina mecânica e lava a jato na região</segment>
    <segment id="25">,  Sílvio estava indo almoçar quando foi abordado pelos criminosos</segment>
    <segment id="26">, que o colocaram em um carro.</segment>
    <segment id="27">Ele levou bala no pescoço</segment>
    <segment id="28">, ombro e nádegas.</segment>
    <segment id="29">Segundo o delegado Alex Gabriel Chehade</segment>
    <segment id="30">, do Departamento de Homicídios</segment>
    <segment id="31">, a polícia recebeu a informação de que  Sílvio era traficante de drogas na região do Barro Duro</segment>
    <segment id="32">, em Simões Filho</segment>
    <segment id="33">, e há dois anos teria expulsado de lá dois homens que praticavam roubos contra a comunidade.</segment>
    <segment id="34">Decidido a sair do mundo do tráfico</segment>
    <segment id="35">, Sílvio</segment>
    <segment id="36">sese mudou para São Cristóvão</segment>
    <segment id="37">, há cerca de um ano</segment>
    <segment id="38">, e estava morando na mesma rua onde residem os antigos rivais.</segment>
    <segment id="39">O delegado acredita que essa rixa pode ter motivado o crime.</segment>
    <segment id="40">Para a polícia</segment>
    <segment id="41">,  Sílvio não sabia que os antigos inimigos agora eram vizinhos dele.</segment>
    <segment id="42">Sensibilizado com o drama da mãe</segment>
    <segment id="43">, delegado faz alerta aos jovens

Sensibilizado com o drama da mãe da vítima</segment>
    <segment id="44">, o delegado tentou dar apoio à moça.</segment>
    <segment id="45">“Tenho uma prática espiritual forte</segment>
    <segment id="46">, que me dá equilíbrio nessas situações.</segment>
    <segment id="47">Além de cumprir minha obrigação profissional</segment>
    <segment id="48">, tentei levar um pouco de conforto a um ser humano”</segment>
    <segment id="49">, diz Chehade</segment>
    <segment id="50">, há 17 anos na polícia.</segment>
    <segment id="51">“Isso serve de lição aos jovens.</segment>
    <segment id="52">Toda promessa do mundo das drogas é uma fuga por um caminho onde a rota sempre leva à morte”.

Usava cocaína</segment>
    <segment id="53">Segundo o delegado</segment>
    <segment id="54">, no local do crime surgiu a versão de que Sílvio estaria devendo a traficantes</segment>
    <segment id="55">, pois</segment>
    <segment id="56">pois não havia recebido o salário na data certa</segment>
    <segment id="57">, no último dia 5.</segment>
    <segment id="58">A vítima usava cocaína</segment>
    <segment id="59">, conforme a polícia.</segment>
    <segment id="60">Quando era adolescente</segment>
    <segment id="61">, ele foi detido acusado de furto e em 2012 foi preso por briga.</segment>
  </rst>
