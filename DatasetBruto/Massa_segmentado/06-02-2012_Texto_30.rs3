  <rst>
    <segment id="1">Delegacia pede socorro ao Exército
Unidade de Tancredo Neves recebeu denúncia de que seria atacada</segment>
    <segment id="2">Diante do cenário de insegurança na cidade devido à greve da PM</segment>
    <segment id="3">, até a 11ª Delegacia Territorial (Tancredo Neves)</segment>
    <segment id="4">sese sentiu ameaçada e pediu apoio ao exército para reforçar a segurança da unidade.</segment>
    <segment id="5">Por meio de um telefonema anônimo</segment>
    <segment id="6">, uma pessoa informou que 12 homens armados iriam invadir a delegacia para roubar armas e liberar os presos custodiados no local.</segment>
    <segment id="7">“Chegou um boato e nós temos que estar de prontidão.</segment>
    <segment id="8">Como o Exército estava próximo</segment>
    <segment id="9">, pedimos para incluir a delegacia na área de patrulhamento”</segment>
    <segment id="10">, explicou o titular da 11ª DT</segment>
    <segment id="11">, Guilherme Machado.</segment>
    <segment id="12">Apenas cinco policiais</segment>
    <segment id="13">, entre eles duas mulheres</segment>
    <segment id="14">, estavam de plantão na 11ª DT ontem.</segment>
    <segment id="15">Dois homicídios e um atentado a  tiros a um ônibus</segment>
    <segment id="16">, próximos à 11ª DT</segment>
    <segment id="17">, aumentaram a  apreensão sobre a segurança da delegacia</segment>
    <segment id="18">, devido à ameça de invasão recebida no sábado.</segment>
    <segment id="19">Por volta das três horas da tarde</segment>
    <segment id="20">, os homens do Exército chegaram para guarnecer a unidade e as ruas próximas.</segment>
    <segment id="21">“</segment>
    <segment id="22">A presença do Exército é por cautela.</segment>
    <segment id="23">Estamos em uma área complexa</segment>
    <segment id="24">, com histórico de altos índices de criminalidade”</segment>
    <segment id="25">, declarou Machado.</segment>
    <segment id="26">Em alguns pontos situados fora do centro da cidade foi possível verificar a presença dos homens do Exército.</segment>
    <segment id="27">Na Calçada</segment>
    <segment id="28">, Cidade Baixa</segment>
    <segment id="29">, Largo do Tanque</segment>
    <segment id="30">, Jaqueira do Carneiro (na BR-324) e Arraial do Retiro</segment>
    <segment id="31">, os militares das forças armadas tentavam passar segurança à população.</segment>
    <segment id="32">Saques e furtos continuam.</segment>
    <segment id="33">Até sorveteria sobrou</segment>
    <segment id="34">Os saques continuaram na madrugada de ontem.</segment>
    <segment id="35">Só no bairro da Fazenda Grande do Retiro</segment>
    <segment id="36">, três estabelecimentos comerciais foram saqueados.</segment>
    <segment id="37">“Quebraram as vitrines e levaram praticamente tudo”</segment>
    <segment id="38">, contou um funcionário da Borges Calçados que acompanhava o conserto da porta violada.</segment>
    <segment id="39">O Supermercado</segment>
    <segment id="40">Todo Dia abriu no início da tarde após o saque.</segment>
    <segment id="41">Na Liberdade</segment>
    <segment id="42">, a loja da Cesta do Povo da Feira do Japão foi saqueada também.</segment>
    <segment id="43">A tradicional sorveteria Cubana do Pelourinho foi roubada por um homem que escalou o casarão e entrou por uma janela do 1º andar.</segment>
    <segment id="44">Ele levou R$ 800.</segment>
    <segment id="45">A PM chegou uma hora depois do chamado e não encontrou o ladrão.</segment>
    <segment id="46">Assassinatos dobram</segment>
    <segment id="47">O número de assassinatos e roubos a carros dobraram nos últimos seis dias de greve em comparação com o mesmo período da semana anterior à paralisação.</segment>
    <segment id="48">Da noite do dia 31 de janeiro (quando a greve foi deflagrada) até as oito horas da noite de ontem</segment>
    <segment id="49">, 84 pessoas foram assassinadas e 211 veículos foram subtraídos na Grande Salvador.</segment>
    <segment id="50">Nos seis dias que antecederam a greve</segment>
    <segment id="51">, houve 42 homicídios e 101 carros roubados ou furtados.</segment>
    <segment id="52">Os dados são da Secretaria de Segurança Pública.</segment>
    <segment id="53">Até às oito horas da noite de ontem</segment>
    <segment id="54">, foram registrados 13 homicídios.</segment>
    <segment id="55">Um deles foi o de Adeilton Santos de Jesus</segment>
    <segment id="56">, 29 anos</segment>
    <segment id="57">, assassinado no final de linha da Engomadeira.</segment>
    <segment id="58">Ele foi retirado do ônibus</segment>
    <segment id="59">, que transportava pessoas que voltavam do enterro de um traficante do bairro assassinado na última sexta-feira.</segment>
    <segment id="60">Por volta das 23h de ontem</segment>
    <segment id="61">, chegou à redação a notícia de mais três mortes e um ferido no final de linha de Santa Cruz.</segment>
  </rst>
</analysis>