  <rst>
    <segment id="1">Grevistas enterram educação no CAB
Alunos da rede estadual estão há 18 dias sem aula e os pais estão preocupados</segment>
    <segment id="2">Ao completar</segment>
    <segment id="3">, ontem</segment>
    <segment id="4">, 17 dias em greve</segment>
    <segment id="5">, os professores da rede pública estadual decidiram em assembleia continuar de braços cruzados.</segment>
    <segment id="6">Os servidores</segment>
    <segment id="7">sese reuniram</segment>
    <segment id="8">, durante  toda a  manhã</segment>
    <segment id="9">, no Anexo Barbosa Romeu</segment>
    <segment id="10">, no CAB</segment>
    <segment id="11">, e,  após votação</segment>
    <segment id="12">, resolveram  seguir parados até  a próxima  quarta-feira</segment>
    <segment id="13">, quando acontecerá uma nova reunião.</segment>
    <segment id="14">Ao protestar com apitos</segment>
    <segment id="15">, eles seguiram rumo à governadoria</segment>
    <segment id="16">, levando um caixão para simbolizar o  enterro da educação.</segment>
    <segment id="17">Além disso</segment>
    <segment id="18">, puseram em cruzes os nomes dos deputados que votaram a favor do reajuste do piso salarial da categoria em 7</segment>
    <segment id="19">,5%, -os professores pedem 22</segment>
    <segment id="20">,22%.</segment>
    <segment id="21">Em meio a esse impasse estão os cerca de 1</segment>
    <segment id="22">,5 milhão de alunos da rede pública estadual que enfrentam uma rotina diária diferente da ideal</segment>
    <segment id="23">, sem aulas.</segment>
    <segment id="24">O tempo ocioso dos alunos  preocupa os pais.</segment>
    <segment id="25">“Moro em São Caetano e  achei melhor  mandar meu sobrinho Pablo</segment>
    <segment id="26">, que está na 8° série</segment>
    <segment id="27">, para o interior até a greve acabar.</segment>
    <segment id="28">Vai evitar que ele fique o dia todo na rua”</segment>
    <segment id="29">, revela o varredor  Antônio Cezar</segment>
    <segment id="30">, 32.  Já  o estudante Jamir  Gomes</segment>
    <segment id="31">, 17, optou por montar um grupo de estudo.</segment>
    <segment id="32">“Montei um grupo com colegas.</segment>
    <segment id="33">Estou no 2° ano e não posso perder tempo”</segment>
    <segment id="34">, diz</segment>
    <segment id="35">Segundo presidente do APLB-Sindicato dos Trabalhadores em Educação do Estado</segment>
    <segment id="36">, Rui Oliveira</segment>
    <segment id="37">, a greve continua</segment>
    <segment id="38">, masmas a categoria está aberta ao dialogo.</segment>
    <segment id="39">“Pedimos audiência com o governador Wagner para nova rodada de negociação.</segment>
    <segment id="40">Aguardamos resposta”</segment>
    <segment id="41">, diz Rui.</segment>
    <segment id="42">Há quem fique de boa</segment>
    <segment id="43">Apesar da preocupação de  parte dos estudantes</segment>
    <segment id="44">, tem uma galerinha que está  achando “maaaraaa” as “férias forçadas” e querem mais é</segment>
    <segment id="45">sese divertir.</segment>
    <segment id="46">“Gostei da greve</segment>
    <segment id="47">, acordo mais tarde</segment>
    <segment id="48">,  fico no computador conversando com amigos”</segment>
    <segment id="49">,  confessa  o estudante do Colégio Modelo Luís Eduardo Magalhães</segment>
    <segment id="50">, Alberto Conceição</segment>
    <segment id="51">, 16.</segment>
    <segment id="52">Já  a aluna Carla Santos</segment>
    <segment id="53">, 16 do Colégio Estadual Raphael Serravalle  prefere ficar na casa das amigas e assistir à televisão.</segment>
    <segment id="54">“Colocamos  as conversas em dia.</segment>
    <segment id="55">Minha mãe não gosta da greve</segment>
    <segment id="56">, masmas eu tô  adorando”</segment>
    <segment id="57">,</segment>
    <segment id="58">admite.</segment>
  </rst>
</analysis>