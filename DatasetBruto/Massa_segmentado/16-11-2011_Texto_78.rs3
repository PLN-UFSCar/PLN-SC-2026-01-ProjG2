  <rst>
    <segment id="1">Lei Seca: 42 veículos removidos das ruas
Foram recolhidas 35 carteiras de habilitação e autuados 74 motoristas</segment>
    <segment id="2">A operação Lei Seca</segment>
    <segment id="3">, no feriado prolongado entre os dias 11 e 15 de novembro</segment>
    <segment id="4">, resultou na remoção de 42 veículos por agentes da Superintendência de Trânsito e Transporte de Salvador.</segment>
    <segment id="5">Foram recolhidas 35 carteiras de habilitação por irregularidades e autuados 74 motoristas por problemas diversos.</segment>
    <segment id="6">Outras 24 autuações foram baseadas na Lei Seca.</segment>
    <segment id="7">Durante a operação</segment>
    <segment id="8">, 493 motoristas foram abordados.</segment>
    <segment id="9">Destes</segment>
    <segment id="10">, dois foram flagrados com até 0</segment>
    <segment id="11">,29 mg de álcool por litro de ar expelido</segment>
    <segment id="12">, o que</segment>
    <segment id="13">sese configura</segment>
    <segment id="14">comocomo infração gravíssima de trânsito</segment>
    <segment id="15">, passível de penalidade na carteira e multa</segment>
    <segment id="16">, suspensão do direito de dirigir por 12 meses e apreensão do veículo.</segment>
    <segment id="17">Outro condutor foi flagrado com mais de 0</segment>
    <segment id="18">,29 mg de álcool</segment>
    <segment id="19">, o que</segment>
    <segment id="20">, de acordo com a Lei Federal 11.705/2008</segment>
    <segment id="21">, sese caracteriza</segment>
    <segment id="22">comocomo crime de trânsito</segment>
    <segment id="23">, infração do artigo 306 do Código de Trânsito Brasileiro (CTB)</segment>
    <segment id="24">, que prevê penas de detenção de seis meses a três anos</segment>
    <segment id="25">, multa e suspensão ou proibição do direito de dirigir.</segment>
    <segment id="26">De acordo com a Transalvador</segment>
    <segment id="27">, a operação contou</segment>
    <segment id="28">, durante os cinco dias</segment>
    <segment id="29">, com 47 agentes de trânsito</segment>
    <segment id="30">, 17 policiais militares</segment>
    <segment id="31">, 12 prepostos do Detran</segment>
    <segment id="32">, seis advogados</segment>
    <segment id="33">, além de 26 viaturas e 15 reboques.</segment>
  </rst>
</analysis>