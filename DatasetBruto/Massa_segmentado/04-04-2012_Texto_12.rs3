  <rst>
    <segment id="1">Vitória do bom-senso</segment>
    <segment id="2">Diante do impasse</segment>
    <segment id="3">, o Ministério Público decide que clássicos terão as duas torcidas</segment>
    <segment id="4">Até os personagens Jair e Vicentino</segment>
    <segment id="5">, do quadro do Globo Esporte</segment>
    <segment id="6">, fizeram campanha contra a ideia de que os próximos Ba-Vis fossem disputados com torcida única.</segment>
    <segment id="7">E ontem à tarde</segment>
    <segment id="8">, na sede do Ministério Público</segment>
    <segment id="9">, no CAB</segment>
    <segment id="10">, ficou definido que tricolores e rubro-negros continuarão marcando presença juntos no maior clássico do Norte-Nordeste.</segment>
    <segment id="11">A decisão é favorável ao Vitória</segment>
    <segment id="12">, FBF e organizadas do rubro-negro  que não concordavam com a proposta do Ministério Público – que contava com o apoio da Polícia Militar</segment>
    <segment id="13">, do Bahia e das organizadas do tricolor.</segment>
    <segment id="14">Enquetes feitas pelo Grupo A TARDE e outros órgãos de imprensa mostraram que a maioria dos torcedores rejeitava a torcida única.</segment>
    <segment id="15">Segundo o vice-diretor Jurídico do Bahia</segment>
    <segment id="16">, Ademir Ismerim</segment>
    <segment id="17">, o MP irá agir com mais rigor contra os  torcedores que criarem confusão nos dias dos clássicos.</segment>
    <segment id="18">“</segment>
    <segment id="19">O Ministério Público advertiu que não pode impor a torcida única nos Ba-Vis</segment>
    <segment id="20">, masmas</segment>
    <segment id="21">sese reserva o direito de propor medida judicial</segment>
    <segment id="22">sese houver motivos”</segment>
    <segment id="23">, alertou Ademir Ismerin.</segment>
  </rst>
</analysis>