  <rst>
    <segment id="1">Severino quebra-galho assume time</segment>
    <segment id="2">Geninho é demitido e Ricardo Silva vai dirigir um Vitória cheio de trocas amanhã
Cheio de novidades</segment>
    <segment id="3">, o  interino Ricardo Siva assume o comando do Vitória pela segunda vez este ano e  terá o desafio de armar o time às pressas para enfrentar o Naútico</segment>
    <segment id="4">, amanhã</segment>
    <segment id="5">, nos Aflitos.</segment>
    <segment id="6">A primeira dúvida é no meio.</segment>
    <segment id="7">“ Gostei muito de Geraldo</segment>
    <segment id="8">, masmas ele disputa vaga com Lúcio Flávio e Geovanni”</segment>
    <segment id="9">, disse.</segment>
    <segment id="10">No ataque</segment>
    <segment id="11">, ele não sabe</segment>
    <segment id="12">sese mantem Marcelo ou promove o retorno de Marquinhos.</segment>
    <segment id="13">“Marquinhos estava parado e preciso conversar com ele”.</segment>
    <segment id="14">Sem Fernandinho</segment>
    <segment id="15">, suspenso</segment>
    <segment id="16">, Ricardo Silva já definiu a entrada do recém-contratado Chiquinho.</segment>
    <segment id="17">Na zaga</segment>
    <segment id="18">, Alison retorna de suspensão.</segment>
    <segment id="19">O elenco viaja hoje mesmo sem escalação definida.</segment>
    <segment id="20">O ex-comandante Geninho soube da sua demissão assim que chegou ao Barradão para o treino de ontem pela manhã</segment>
    <segment id="21">, após perder para a Portuguesa em Pituaçu.</segment>
    <segment id="22">“Fiquei surpreso com a decisão.</segment>
    <segment id="23">O time ainda estava em formação e muitas peças estavam</segment>
    <segment id="24">sese recuperando de contusão.</segment>
    <segment id="25">Coloquei o Geraldo no jogo com 70% de condição.</segment>
    <segment id="26">O Lucio Flavio também.</segment>
    <segment id="27">Não tinha Marquinhos</segment>
    <segment id="28">, Rildo...</segment>
    <segment id="29">Bem, deixa pra lá.</segment>
    <segment id="30">É o natural do futebol e não guardo rancor com estas coisas”</segment>
    <segment id="31">, disse Geninho</segment>
    <segment id="32">, que nos 10 jogos que comandou teve 46% de aproveitamento.</segment>
    <segment id="33">Segundo a diretoria</segment>
    <segment id="34">, nenhum nome foi cogitado para substituí-lo</segment>
    <segment id="35">, masmas Carpeggiani está na lista.</segment>
    <segment id="36">Reforço: Leão fecha com  novo atacante

Novo concorrente de Neto Baiano no ataque</segment>
    <segment id="37">, Fábio Santos deve ser apresentado</segment>
    <segment id="38">, de forma oficial</segment>
    <segment id="39">, apenas na quarta-feira.</segment>
    <segment id="40">Porém, o atleta de 24 anos já treina a partir de hoje no Barradão.</segment>
    <segment id="41">O namoro do Leão é antigo.</segment>
    <segment id="42">O atacante chegou a conversar com o Vitória no término do Paulistão</segment>
    <segment id="43">, quando defendia o Oeste e foi vice-artilheiro da competição.</segment>
    <segment id="44">Porém,  optou pelo Avaí.</segment>
  </rst>
