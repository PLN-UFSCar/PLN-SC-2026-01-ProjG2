  <rst>
    <segment id="1">O último programa de Soraia
Homem em liberdade condicional mata prostituta em hotel no Pelô</segment>
    <segment id="2">Era</segment>
    <segment id="3">para ser apenas uma noite de prazer</segment>
    <segment id="4">, masmas acabou em tragédia: Manuel Santos Silva</segment>
    <segment id="5">, 32 anos</segment>
    <segment id="6">, foi preso em flagrante por policiais militares</segment>
    <segment id="7">, após assassinar Soraia da Silva</segment>
    <segment id="8">, 39 anos</segment>
    <segment id="9">, conhecida na área</segment>
    <segment id="10">comocomo Carioca.</segment>
    <segment id="11">O crime aconteceu às 6h da manhã de ontem</segment>
    <segment id="12">, quando ele tentava deixar o Hotel Ibiza</segment>
    <segment id="13">, situado na Rua do Bispo</segment>
    <segment id="14">, no Pelourinho</segment>
    <segment id="15">, onde passara a noite com Soraia.</segment>
    <segment id="16">Sem dó nem piedade</segment>
    <segment id="17">, Manuel estrangulou a garota de programa que havia conhecido na noite anterior</segment>
    <segment id="18">, no Pelô.</segment>
    <segment id="19">Em depoimento à delegada</segment>
    <segment id="20">Joana Angélica Santos</segment>
    <segment id="21">, do Departamento de Homicídios (DHPP)</segment>
    <segment id="22">, Manuel disse que matou Soraia</segment>
    <segment id="23">porque</segment>
    <segment id="24">porque ela tentou roubá-lo</segment>
    <segment id="25">, usando uma lâmina de barbear.</segment>
    <segment id="26">“Ele disse que deu um soco nela e depois a estrangulou com uma toalha”</segment>
    <segment id="27">, conta a delegada Joana Angélica</segment>
    <segment id="28">, que não acredita na versão apresentada pelo acusado.</segment>
    <segment id="29">“</segment>
    <segment id="30">A perícia não encontrou nem lâmina de barbear e nem dinheiro com ele”.</segment>
    <segment id="31">Manuel disse ainda que ele e a vítima estavam 'travados' de cerveja e cocaína.</segment>
    <segment id="32">O corpo de Soraia foi encontrado sem roupa</segment>
    <segment id="33">, no banheiro de um dos quartos do hotel.</segment>
    <segment id="34">Ele pagou R$ 34 pelo pernoite.</segment>
    <segment id="35">Manuel já foi condenado por roubo e estava em liberdade condicional</segment>
    <segment id="36">, desde o ano passado</segment>
    <segment id="37">, depois de ficar preso um ano e seis meses.</segment>
    <segment id="38">Agora, ele voltará ao presídio para cumprir o restante da pena e será indiciado por homicídio qualificado.</segment>
    <segment id="39">“Ele matou a vítima de forma cruel</segment>
    <segment id="40">, sem possibilidade de defesa”</segment>
    <segment id="41">, ressalta Joana Angélica.</segment>
    <segment id="42">Ela era querida</segment>
    <segment id="43">Soraia nasceu no Rio de Janeiro</segment>
    <segment id="44">, masmas morava em Salvador há 10 anos.</segment>
    <segment id="45">Ela fazia ponto na Praça da Sé</segment>
    <segment id="46">, Pelourinho.</segment>
    <segment id="47">“Era uma boa mãe.</segment>
    <segment id="48">Me ajudava a criar o meu filho de 1 ano</segment>
    <segment id="49">, que sofre de crise convulsiva.</segment>
    <segment id="50">Eu também tenho ataque de epilepsia”</segment>
    <segment id="51">, relata M.S.S.</segment>
    <segment id="52">, 17 anos</segment>
    <segment id="53">, filha de Soraia.</segment>
    <segment id="54">A jovem diz estar sem lugar para morar.</segment>
    <segment id="55">A garota de programa deixou outros quatro filhos</segment>
    <segment id="56">, que não moram em Salvador.</segment>
    <segment id="57">“Soraia trabalhava</segment>
    <segment id="58">comocomo cabeleireira e fazia faxina.</segment>
    <segment id="59">Se dava bem com todo mundo”</segment>
    <segment id="60">, conta a amiga</segment>
    <segment id="61">, Maria Auxiliadora.</segment>
    <segment id="62">O vendedor ambulante Valmir Almeida fala da conduta da amiga.</segment>
    <segment id="63">“Soraia não fazia mal a ninguém e não andava com gente errada”</segment>
    <segment id="64">, afirma.</segment>
  </rst>
</analysis>