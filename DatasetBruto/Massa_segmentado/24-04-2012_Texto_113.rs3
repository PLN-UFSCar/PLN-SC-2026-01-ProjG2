  <rst>
    <segment id="1">Os sucessores de Bruno</segment>
    <segment id="2">, o Bruxo</segment>
    <segment id="3">Com o líder preso</segment>
    <segment id="4">, comparsas</segment>
    <segment id="5">sese organizam para comandar o tráfico na Avenida Peixe</segment>
    <segment id="6">Faz parte da cadeia do tráfico de drogas  a reorganização da quadrilha após a prisão do líder.</segment>
    <segment id="7">Na Avenida Peixe</segment>
    <segment id="8">, no bairro da Liberdade</segment>
    <segment id="9">, não foi diferente após a prisão de Bruno Ramos Figueiredo</segment>
    <segment id="10">,  22 anos</segment>
    <segment id="11">, o Bruxo</segment>
    <segment id="12">, na última quinta-feira.</segment>
    <segment id="13">De acordo com o coordenador do Serviço de Investigação da 2ª Delegacia Territorial (Lapinha)</segment>
    <segment id="14">, Leonidas Cafezeiro</segment>
    <segment id="15">, Fábio Luis dos Santos Soares</segment>
    <segment id="16">, 24, o Luizinho</segment>
    <segment id="17">, deve assumir a liderança.</segment>
    <segment id="18">“Ele estava entre os três fugitivos”</segment>
    <segment id="19">, diz Cafezeiro sobre a fuga do último dia 25 de janeiro na carceragem da 2ª DT.</segment>
    <segment id="20">Luzinho responde a um processo por porte ilegal de arma</segment>
    <segment id="21">, um por tráfico de drogas e três por roubo.</segment>
    <segment id="22">“Esses caras são organizados.</segment>
    <segment id="23">No sábado</segment>
    <segment id="24">, os traficantes do Beco do Sabão tentaram invadir a Peixe e foram recebidos a tiros”</segment>
    <segment id="25">, afirma um morador que não</segment>
    <segment id="26">sese identificou por questões de segurança.</segment>
    <segment id="27">Janderson Santos Ferreira</segment>
    <segment id="28">, 19, o Ralado</segment>
    <segment id="29">, e Raimundo Welington dos Santos</segment>
    <segment id="30">, o Netinho</segment>
    <segment id="31">, são outros dois comparsas de Bruno.</segment>
    <segment id="32">A dupla já foi presa em 2010</segment>
    <segment id="33">, sob a suspeita de ter matado uma idosa no Pero Vaz.</segment>
    <segment id="34">Ralado também é acusado de participar do assalto à Empresa de ônibus Barramar</segment>
    <segment id="35">, em março passado.</segment>
    <segment id="36">“</segment>
    <segment id="37">Para a Avenida Peixe ficar em paz tem que prender também Ralado</segment>
    <segment id="38">, Netinho</segment>
    <segment id="39">, Luizinho e os outros comparsas de Bruno.</segment>
    <segment id="40">Eles ainda estão armados”</segment>
    <segment id="41">, conta</segment>
    <segment id="42">, preocupado</segment>
    <segment id="43">, um morador.</segment>
    <segment id="44">Dois traficantes mortos</segment>
    <segment id="45">Na noite do último domingo</segment>
    <segment id="46">, dois homens envolvidos com o tráfico de drogas foram assassinados no intervalo de uma hora em locais diferentes na Liberdade.</segment>
    <segment id="47">A polícia ainda não sabe dizer</segment>
    <segment id="48">sese há relação entre os crimes ou</segment>
    <segment id="49">sese as vítimas são ligadas ou rivais do traficante Bruno.</segment>
    <segment id="50">Anderson Santos  de Oliveira</segment>
    <segment id="51">, 25, foi morto a tiros por volta das 19h dentro de um casarão na Ladeira da Soledade.</segment>
    <segment id="52">William Cerqueira Pinheiro</segment>
    <segment id="53">, 26, foi assassinado a tiros na Rua do Céu por volta das 19h30.</segment>
    <segment id="54">Na tarde de sábado</segment>
    <segment id="55">, um homem de identidade ignorada foi assinado na Rua Sacramento Pio.

Disque Denúncia.</segment>
    <segment id="56">Ajude a polícia

Quem souber informações sobre os comparsas de Bruno pode ligar para o Disque Denúncia (3235-0000).</segment>
    <segment id="57">Não precisa</segment>
    <segment id="58">sese identificar.</segment>
    <segment id="59">Bruno era o líder do tráfico de drogas na Avenida Peixe</segment>
    <segment id="60">, Liberdade</segment>
    <segment id="61">, e acusado de assassinar 18 pessoas.</segment>
  </rst>
</analysis>