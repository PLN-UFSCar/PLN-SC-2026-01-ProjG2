  <rst>
    <segment id="1">Dia Internacional contra o Tráfico</segment>
    <segment id="2">Foi divulgado a quantidade de drogas apreendida nesse ano</segment>
    <segment id="3">O Departamento de Narcóticos (Denarc) da Bahia divulgou</segment>
    <segment id="4">, ontem</segment>
    <segment id="5">, no Dia Internacional contra o Abuso e Tráfico Ilícito de Drogas</segment>
    <segment id="6">, que em 2012 já foram apreendidos mais de 17 toneladas de maconha</segment>
    <segment id="7">, 14, 6 quilos de cocaína</segment>
    <segment id="8">, 16 quilos de crack e 4 mil 468 pedras da mesma droga</segment>
    <segment id="9">, em todo o Estado.</segment>
  </rst>
