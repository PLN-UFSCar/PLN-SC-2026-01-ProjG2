  <rst>
    <segment id="1">Vit횄쨀ria est횄징 na UTI do Brasileir횄짙o
Cantor com nome de arrocha faz dois gols e mant횄짤m vit횄쨀ria na sofr횄짧ncia</segment>
    <segment id="2">Ele n횄짙o</segment>
    <segment id="3">횄짤 cantor de arrocha</segment>
    <segment id="4">, masmas deixou o Vit횄쨀ria na maior sofr횄짧ncia.</segment>
    <segment id="5">Pablo, atacante do Figueirense</segment>
    <segment id="6">, foi o carrasco do rubro-negro baiano</segment>
    <segment id="7">, marcando os dois gols da partida de ontem no Orlando Scarpelli</segment>
    <segment id="8">, livrando o Figueira do rebaixamento e empurrando o Le횄짙o para a degola.</segment>
    <segment id="9">Em um jogo dif횄짯cil de</segment>
    <segment id="10">sese ver</segment>
    <segment id="11">, o Vit횄쨀ria at횄짤 come횄짠ou bem.</segment>
    <segment id="12">Logo aos 10 segundos</segment>
    <segment id="13">, Dinei chutou com perigo e quase marcou.</segment>
    <segment id="14">Mas o banho de 횄징gua fria veio cedo.</segment>
    <segment id="15">Aos 17 minutos</segment>
    <segment id="16">, ap횄쨀s cobran횄짠a de falta</segment>
    <segment id="17">, o goleiro Gatito Fernandez</segment>
    <segment id="18">, mal colocado</segment>
    <segment id="19">, falhou feio e foi encoberto pela cabe횄짠ada de Pablo: 1 a 0 Figueirense.</segment>
    <segment id="20">O Le횄짙o at횄짤 que tentou</segment>
    <segment id="21">, melhorou</segment>
    <segment id="22">, masmas n횄짙o conseguiu chegar ao empate.</segment>
    <segment id="23">No segundo tempo as coisas mudaram.</segment>
    <segment id="24">Para pior.</segment>
    <segment id="25">Com o time perdido em campo</segment>
    <segment id="26">, o rubro-negro pouco criou e viu sua desvantagem aumentar aos 13 minutos</segment>
    <segment id="27">, novamente com o camisa 11</segment>
    <segment id="28">, depois de aproveitar o rebote do chute de Marc횄짙o (ex-Bahia)</segment>
    <segment id="29">, em cima de Gatito Fernandez.</segment>
    <segment id="30">O Figueira alcan횄짠ou os 46 pontos e</segment>
    <segment id="31">sese garantiu na S횄짤rie</segment>
    <segment id="32">A do Brasileir횄짙o do ano que vem.</segment>
    <segment id="33">O Vit횄쨀ria</segment>
    <segment id="34">, com 38</segment>
    <segment id="35">, voltou 횄혻 zona de degola e</segment>
    <segment id="36">, no s횄징bado</segment>
    <segment id="37">, 횄혻s 20h (de Salvador)</segment>
    <segment id="38">, joga contra o Flamengo na Arena Amaz횄쨈nia.</segment>
    <segment id="39">Para se</segment>
    <segment id="40">se livrar da S횄짤rie B</segment>
    <segment id="41">, o Le횄짙o n횄짙o depende s횄쨀 dele.</segment>
    <segment id="42">Tem que vencer as duas partidas e secar Coritiba</segment>
    <segment id="43">, Chapecoense e Palmeiras.</segment>
  </rst>
