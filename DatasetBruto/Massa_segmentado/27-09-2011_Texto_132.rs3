  <rst>
    <segment id="1">Sofrimento após cair do trio</segment>
    <segment id="2">Ela reclama do descaso da produção do evento</segment>
    <segment id="3">, que não estaria dando assistência</segment>
    <segment id="4">A ajudante de cozinha Tatiane Jesus Costa</segment>
    <segment id="5">, 20 anos</segment>
    <segment id="6">, saiu de casa  no último domingo com a saúde em perfeito estado e com total animação para curtir a Parada Gay realizada no bairro da Ribeira.</segment>
    <segment id="7">Menos de doze horas depois</segment>
    <segment id="8">, ela voltou à sua residência</segment>
    <segment id="9">, na Estrada das Barreiras</segment>
    <segment id="10">, com a bacia deslocada</segment>
    <segment id="11">, vários ferimentos nos braços e costas</segment>
    <segment id="12">, dores pelo corpo todo e sem conseguir mexer a perna esquerda.</segment>
    <segment id="13">Tatiane foi uma das seis vítimas que caíram de cima do trio elétrico Ciclone</segment>
    <segment id="14">, que animou a Parada Gay da Ribeira.</segment>
    <segment id="15">O acidente ocorreu por volta das 18h</segment>
    <segment id="16">, no final de linha do bairro.</segment>
    <segment id="17">“</segment>
    <segment id="18">Durante todo o percurso</segment>
    <segment id="19">, sempre tinha uma pessoa que levantava os fios de telefone ou de energia quando o trio passava.</segment>
    <segment id="20">No final do trajeto</segment>
    <segment id="21">, essa pessoa não estava mais.</segment>
    <segment id="22">Aí, quando o trio passou por cinco fios de telefone</segment>
    <segment id="23">, os cabos ficaram presos e derrubaram a grade de proteção que fica no fundo do trio.</segment>
    <segment id="24">Foi nessa hora que eu caí.</segment>
    <segment id="25">A grade de proteção já estava solta antes”</segment>
    <segment id="26">, relembra Tatiane.</segment>
    <segment id="27">“</segment>
    <segment id="28">Eu caí por cima de outras pessoas.</segment>
    <segment id="29">Se caísse direto no asfalto eu estaria morta.</segment>
    <segment id="30">Faltou o que para eu morrer?</segment>
    <segment id="31">Tenho uma filha de dois anos para criar</segment>
    <segment id="32">, estou desempregada e agora com essas dores vai ser mais difícil ainda conseguir emprego”</segment>
    <segment id="33">, lamenta a jovem.</segment>
    <segment id="34">“</segment>
    <segment id="35">Os organizadores do evento disseram que iam prestar toda a assistência e que iam entrar em contato comigo hoje (ontem)</segment>
    <segment id="36">, masmas até agora nada”</segment>
    <segment id="37">, reclama.


Amigo de Tatiane que está na parada gay</segment>
    <segment id="38">, Ubiraci confirma que seis pessoas caíram do trio

 
Tatiane recebeu alta de madrugada

Tatiane foi levada ao Hospital Geral do Estado (HGE) e teve alta médica por volta da 1h da madrugada de ontem.</segment>
    <segment id="39">Sem dinheiro</segment>
    <segment id="40">, sentindo fortes dores e com imensas dificuldades até para ficar em pé</segment>
    <segment id="41">, Tatiane contou com a ajuda de um amigo</segment>
    <segment id="42">, que pagou o táxi de volta para casa.</segment>
    <segment id="43">“</segment>
    <segment id="44">Os organizadores disseram que iam dar assistência a ela e até agora ninguém ligou”</segment>
    <segment id="45">, cobrou Ubiraci Damasceno</segment>
    <segment id="46">, 35, amigo de Tatiane</segment>
    <segment id="47">, que também estava na festa.</segment>
    <segment id="48">Lucas Souza</segment>
    <segment id="49">, 16, outro amigo dela</segment>
    <segment id="50">, opina que</segment>
    <segment id="51">sese a grade de proteção não estivesse quebrada</segment>
    <segment id="52">, dificilmente os fios a teriam derrubado.</segment>
    <segment id="53">Não teve queda?</segment>
    <segment id="54">Produtores têm outra versão</segment>
    <segment id="55">O organizador da Parada Gay da Ribeira</segment>
    <segment id="56">, Fábio Santana dos Santos</segment>
    <segment id="57">, insistiu em negar a queda de pessoas de cima do trio.</segment>
    <segment id="58">“</segment>
    <segment id="59">O fio prendeu e derrubou a gaiola (grade de proteção</segment>
    <segment id="60">, também chamada de guarda-corpo) que caiu em cima de três pessoas que estavam no chão.</segment>
    <segment id="61">Provavelmente</segment>
    <segment id="62">, por causa de uma desatenção do operador que segura o fio”</segment>
    <segment id="63">, contou ele.</segment>
    <segment id="64">Fábio garantiu ter todos os documentos em mãos com autorização dos órgãos públicos para a realização do evento.</segment>
    <segment id="65">A Transalvador</segment>
    <segment id="66">, Sucom e a Sesp (todos órgãos da prefeitura) confirmaram a liberação.</segment>
    <segment id="67">Sem vistoria:</segment>
    <segment id="68">Os erros da produção

O trio não passou pela vistoria do Detran.</segment>
    <segment id="69">Em nota</segment>
    <segment id="70">, o órgão informou que  a organização do evento deveria ter pedido a inspeção</segment>
    <segment id="71">, via ofício</segment>
    <segment id="72">, “visto que a última vistoria</segment>
    <segment id="73">, com validade de 30 dias</segment>
    <segment id="74">, feita nesses veículos</segment>
    <segment id="75">, foi em fevereiro</segment>
    <segment id="76">, por conta do Carnaval”.</segment>
    <segment id="77">A vistoria do Detran observa o sistema elétrico</segment>
    <segment id="78">, mecânico</segment>
    <segment id="79">, estrutural</segment>
    <segment id="80">, de freios e contra incêndio.</segment>
    <segment id="81">A Defesa Civil  também não foi comunicada sobre a Parada.</segment>
    <segment id="82">A delegada titular do Bonfim</segment>
    <segment id="83">, Vânia Matos</segment>
    <segment id="84">, disse que só poderá solicitar a perícia técnica para apurar as causas do acidente</segment>
    <segment id="85">sese houver o registro de queixa na delegacia</segment>
    <segment id="86">, o que ainda não ocorreu.</segment>
  </rst>
</analysis>