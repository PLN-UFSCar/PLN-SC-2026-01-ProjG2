Quem for convocado ou</segment>
    <segment id="3">sese inscreveu receberﾃδ｡ o chamado do TRE atﾃδｩ 22 de setembro</segment>
    <segment id="4">Quem foi convocado pelo Tribunal Regional Eleitoral da Bahia ou atﾃδｩ mesmo</segment>
    <segment id="5">sese inscreveu no projeto Mesﾃδ｡rio Voluntﾃδ｡rio tem atﾃδｩ o dia 22 de setembro para receber</segment>
    <segment id="6">, em casa</segment>
    <segment id="7">, a carta de convocaﾃδｧﾃδ｣o indicado o local</segment>
    <segment id="8">, data e hora onde serﾃδ｡ realizado o treinamento.</segment>
    <segment id="9">Existe tambﾃδｩm a opﾃδｧﾃδ｣o de fazer todo o processo pela internet</segment>
    <segment id="10">, acessando o site mesarios.tre-ba.gov.br e serﾃδ｣o dispensados do treinamento presencial.</segment>
    <segment id="11">Depois de</segment>
    <segment id="12">sese inscrever no programa Mesﾃδ｡rio Volutnﾃδ｡rio</segment>
    <segment id="13">, devido ﾃδ parceria que o TRE tem com sua faculdade</segment>
    <segment id="14">, a estudante Jamile Assis estﾃδ｡ ansiosa para assumir o posto de dirigente de zona eleitoral</segment>
    <segment id="15">, masmas ainda nﾃδ｣o decidiu</segment>
    <segment id="16">sese farﾃδ｡ o treinamento on line ou presencial.</segment>
    <segment id="17">ﾃ｢竄ｬﾅ鄭cho uma ideia interessante</segment>
    <segment id="18">, ﾃδｩ minha contribuiﾃδｧﾃδ｣o cidadﾃδ｣ e eu ainda vou ganhar horas para completar a carga horﾃδ｡ria do meu cursoﾃ｢竄ｬ</segment>
    <segment id="19">, diz a futura mesﾃδ｡ria.</segment>
    <segment id="20">Mesmo sendo uma obrigaﾃδｧﾃδ｣o eleitoral</segment>
    <segment id="21">, assim</segment>
    <segment id="22">comocomo o voto</segment>
    <segment id="23">, o nﾃδ｣o comparecimento na zona ﾃδｩ considerado uma infraﾃδｧﾃδ｣o administrativa</segment>
    <segment id="24">, podendo atﾃδｩ gerar multa.</segment>
    <segment id="25">Mas tem quem goste e ache atﾃδｩ um privilﾃδｩgio ser mesﾃδ｡rio.</segment>
    <segment id="26">ﾃ｢竄ｬﾅ泥esde 2002 que eu sou convocado.</segment>
    <segment id="27">Quando recebi a carta achei que ia ser um porre</segment>
    <segment id="28">, masmas ao chegar lﾃδ｡ fiz o meu trabalho</segment>
    <segment id="29">, ganhei meu ticket e ainda tive direito a dois dias de folga no meu empregoﾃ｢竄ｬ</segment>
    <segment id="30">, explica Tadeu Paz.</segment>
    <segment id="31">Nﾃδ｣o existe remuneraﾃδｧﾃδ｣o para quem assume a tarefa de mesﾃδ｡rio</segment>
    <segment id="32">, masmas hﾃδ｡ alguns benefﾃδｭcios</segment>
    <segment id="33">, como</segment>
    <segment id="34">como dois dias de folga no trabalho para cada dia de serviﾃδｧo nas eleiﾃδｧﾃδｵes e a possibilidade de desempate em concurso pﾃδｺblico</segment>
    <segment id="35">, caso</segment>
    <segment id="36">caso a regra esteja prevista no edital.</segment>
    <segment id="37">Alﾃδｩm das vantagens determinadas em lei</segment>
    <segment id="38">, os alunos das faculdades conveniadas ao Mesﾃδ｡rio Voluntﾃδ｡rio poderﾃδ｣o ter as horas de</segment>
    <segment id="39">serviﾃδｧo</segment>
    <segment id="40">nas mesas receptoras de votos computadas</segment>
    <segment id="41">comocomo atividade complementar ou extracurricular</segment>
    <segment id="42">.</segment>
    <segment id="43">Tﾃδｭtulo de eleitor atﾃδｩ dia 27/09
Quem perdeu o tﾃδｭtulo de eleitor tem atﾃδｩ o dia 27 de setembro para solicitar a 2ﾃつｪ via do documen to.</segment>
    <segment id="44">O requerimento pode ser feito em  qualquer unidade  do Serviﾃδｧo de Atendimento ao Consumidor (SAC).</segment>
    <segment id="45">Mas, mesmo quem nﾃδ｣o consiga tirar a 2ﾃつｺ via</segment>
    <segment id="46">, poderﾃδ｡ votar.</segment>
    <segment id="47">De acordo com o site do TRE-Ba</segment>
