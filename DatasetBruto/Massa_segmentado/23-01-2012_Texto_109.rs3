  <rst>
    <segment id="1">Princesinha de Cajacity arrasa</segment>
    <segment id="2">A gata garante que nunca malhou.</segment>
    <segment id="3">É ter muita sorte</segment>
    <segment id="4">, não?</segment>
    <segment id="5">Com seus caixinhos de ouro</segment>
    <segment id="6">, Patrícia Carvalho</segment>
    <segment id="7">, 22 anos</segment>
    <segment id="8">, arrasa os corações dos marmanjos de Fazenda Grande 2</segment>
    <segment id="9">, em Cajazeiras.</segment>
    <segment id="10">A gata é carinhosamente chamada de Paty - a princezinha de Cajazeiras</segment>
    <segment id="11">, pela galera do bairro onde mora.</segment>
    <segment id="12">Com uma mãe coruja e incentivadora</segment>
    <segment id="13">, a loirinha resolveu sair na capa do Massa!</segment>
    <segment id="14">para mostrar a beleza e</segment>
    <segment id="15">, quem sabe</segment>
    <segment id="16">, conseguir oportunidades de trabalho neste verão em Salvador.</segment>
    <segment id="17">“Minha mãe me apoiou para sair no jornal.</segment>
    <segment id="18">Acho que é uma boa maneira de eu ser vista e até conquistar novas oportunidades”</segment>
    <segment id="19">, aposta Paty.</segment>
    <segment id="20">Ela faz curso de técnico de enfermagem e é dona de um corpão bonito por natureza.</segment>
    <segment id="21">A gata garante que nunca malhou.</segment>
    <segment id="22">É ter muita sorte</segment>
    <segment id="23">, não?</segment>
    <segment id="24">Nas horas de folga</segment>
    <segment id="25">, Paty não dispensa as redes sociais e procura aproveitar o escurinho do cinema e um bom banho de mar nos finais de semana.</segment>
  </rst>
