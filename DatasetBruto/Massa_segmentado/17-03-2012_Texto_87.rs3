  <rst>
    <segment id="1">O céu é o limite para quem nasce baiano</segment>
    <segment id="2">Músicos da terra mostram que são talentosos também para atuar
Que os artistas baianos são talentosos</segment>
    <segment id="3">, ninguém duvida.</segment>
    <segment id="4">Ultimamente</segment>
    <segment id="5">, eles resolveram provar que são multifacetados também!</segment>
    <segment id="6">Primeiro</segment>
    <segment id="7">, foi Alinne Rosa</segment>
    <segment id="8">, vocalista da Cheiro de Amor conquistar seu espaço na telinha ao interpretar a fogosa Alessandra em “</segment>
    <segment id="9">O Brado Retumbante”.</segment>
    <segment id="10">E fez bonito!</segment>
    <segment id="11">“Fiquei ansiosa com o resultado e me surpreendi com os elogios.</segment>
    <segment id="12">Minha vida é cantar</segment>
    <segment id="13">, masmas nunca fecho portas.</segment>
    <segment id="14">Se me convidarem novamente</segment>
    <segment id="15">, eu topo!</segment>
    <segment id="16">”, declarou à época do lançamento da minisérie global.</segment>
    <segment id="17">O cantor Adelmo Casé também mostrou seus dotes de ator</segment>
    <segment id="18">comocomo o Soldado Maia</segment>
    <segment id="19">,  no filme “Gonzaga</segment>
    <segment id="20">, de Pai Para Filho”</segment>
    <segment id="21">, que estreia nas telonas em 26 de outubro.</segment>
    <segment id="22">“Gostei demais</segment>
    <segment id="23">, masmas a minha vida é cantar.</segment>
    <segment id="24">Só continuarei atuando</segment>
    <segment id="25">sese der para conciliar com a música”</segment>
    <segment id="26">, afirma o vocalista da Negra Cor.</segment>
    <segment id="27">A garota bombril da vez é Ivete Sangalo.</segment>
    <segment id="28">A musa já fez bonito na telona e</segment>
    <segment id="29">, agora</segment>
    <segment id="30">, joga duro na telinha

 

Ivete: garota mil e uma utilidades

Depois de uma participaçãono filme “Xuxas Gêmeas” (2006)</segment>
    <segment id="31">, Ivete Sangalo tem sido assediada por grandes autores de TV.</segment>
    <segment id="32">A começar pelo poderoso Daniel Filho</segment>
    <segment id="33">, que a convidou para ser “</segment>
    <segment id="34">A Desastrada de Salvador”</segment>
    <segment id="35">, de “As Brasileiras”.</segment>
    <segment id="36">Arrasou.</segment>
    <segment id="37">Ontem, a musa confirmou pelo Twitter que será a dona do bordel Bataclan na nova versão de “Gabriela”.</segment>
    <segment id="38">“Amado Walcir</segment>
    <segment id="39">, será uma grande hora ser a sua Maria Machadão.</segment>
    <segment id="40">Que lindo presente!!!</segment>
    <segment id="41">Bju”, tuitou.</segment>
    <segment id="42">O autor não</segment>
    <segment id="43">sese deu:</segment>
    <segment id="44">"Estou felicíssimo.</segment>
    <segment id="45">A Ivete Sangalo vai arrasar</segment>
    <segment id="46">comocomo Maria Machadão!”</segment>
    <segment id="47">, devolveu.</segment>
    <segment id="48">Dá-lhe</segment>
    <segment id="49">Veveta!</segment>
    <segment id="50">!</segment>
  </rst>
