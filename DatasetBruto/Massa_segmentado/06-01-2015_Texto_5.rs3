  <rst>
    <segment id="1">Catraca liberada para os idosos
DeterminaГѓВ§ГѓВЈo visa resolver transtornos pela limitaГѓВ§ГѓВЈo de assentos preferenciais</segment>
    <segment id="2">A prefeitura de Salvador publicou hoje</segment>
    <segment id="3">, no DiГѓВЎrio Oficial do MunicГѓВ­pio (DOM)</segment>
    <segment id="4">, um decreto que autoriza os cobradores dos novos ГѓВґnibus da cidade a liberar a passagem dos idosos pelas catracas</segment>
    <segment id="5">, caso</segment>
    <segment id="6">caso as trГѓВЄs cadeiras reservadas para esse pГѓВєblico na frente dos veГѓВ­culos jГѓВЎ estejam ocupadas.</segment>
    <segment id="7">A aГѓВ§ГѓВЈo</segment>
    <segment id="8">, anunciada ontem pelo secretГѓВЎrio de Mobilidade da capital baiana</segment>
    <segment id="9">, FГѓВЎbio Mota</segment>
    <segment id="10">, tem o objetivo de tentar resolver os problemas causados pela reduГѓВ§ГѓВЈo do nГѓВєmero de assentos prioritГѓВЎrios para idosos nos coletivos.</segment>
    <segment id="11">Como a entrada nos novos veГѓВ­culos acontece pela porta da frente e apenas trГѓВЄs cadeiras estГѓВЈo localizadas antes da catraca</segment>
    <segment id="12">, o acesso dos idosos aos outros seis assentos preferenciais</segment>
    <segment id="13">, situados no meio do ГѓВґnibus</segment>
    <segment id="14">, sГѓВі estava acontecendo mediante pagamento da tarifa reajustada de R$ 3.</segment>
    <segment id="15">Isso porque</segment>
    <segment id="16">porque</segment>
    <segment id="17">, segundo motoristas e cobradores ouvidos pela equipe de reportagem</segment>
    <segment id="18">, as empresas proibiram a abertura das portas do meio e do fundo para o acesso dos idosos.</segment>
    <segment id="19">Quem descumprisse a determinaГѓВ§ГѓВЈo dos patrГѓВµes seria advertido</segment>
    <segment id="20">, suspenso ou atГѓ</segment>
    <segment id="21">В© demitido por justa causa</segment>
    <segment id="22">, em casos de reincidГѓВЄncia</segment>
    <segment id="23">, de acordo com os relatos dos rodoviГѓВЎrios entrevistados.</segment>
    <segment id="24">Ontem, na EstaГѓВ§ГѓВЈo da Lapa</segment>
    <segment id="25">, a reportagem flagrou casos em que o direito do idoso ГѓВ  gratuidade foi desrespeitado.  (Leia a baixo)</segment>
    <segment id="26">Dureza!</segment>
    <segment id="27">Idosos passam por perrengue</segment>
    <segment id="28">Ontem ГѓВ  tarde</segment>
    <segment id="29">, durante aproximadamente 30 minutos</segment>
    <segment id="30">, pelo menos cinco usuГѓВЎrios da terceira idade deixaram de pegar o ГѓВґnibus por falta de assento livre antes da catraca.</segment>
    <segment id="31">Nesses casos</segment>
    <segment id="32">, porГѓВ©m</segment>
    <segment id="33">, o problema era a demanda alta Гўв‚¬вЂњ e nГѓВЈo a ocupaГѓВ§ГѓВЈo irregular das cadeiras por pessoas jovens.</segment>
    <segment id="34">Quem teve paciГѓВЄncia para esperar</segment>
    <segment id="35">, sese espremeu no pequeno espaГѓВ§o entre o motorista</segment>
    <segment id="36">, o cobrador e a catraca.</segment>
    <segment id="37">Гўв‚¬Е“O motorista nГѓВЈo abriu as portas do meio e do fundo</segment>
    <segment id="38">, entГѓВЈo prefiro esperar outro ГѓВґnibus do que ir em pГѓВ©Гўв‚¬</segment>
    <segment id="39">, afirmou o aposentado JosГѓВ© da Cruz</segment>
    <segment id="40">, 80 anos.</segment>
