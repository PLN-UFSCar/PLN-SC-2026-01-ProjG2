  <rst>
    <segment id="1">Bob é o cara no ‘tiro de defesa’
Coordenador de investigação da DTE foi o melhor no Torneio de Tiros da Polícia Civil</segment>
    <segment id="2">O rei da mira entre os coordenadores de investigação das delegacias de Salvador e Região Metropolitana foi conhecido na tarde de ontem durante a terceira e última etapa do 1° Torneio de Tiro da Polícia Civil</segment>
    <segment id="3">, realizado  no estande de tiro da Coordenação de Operações Especiais (COE)</segment>
    <segment id="4">, em São Cristóvão.</segment>
    <segment id="5">Carlos Rogério de Souza Oliveira</segment>
    <segment id="6">, da Delegacia de Tóxicos e Entorpecentes (DTE)</segment>
    <segment id="7">, marcou 78 pontos e ficou em primeiro lugar.</segment>
    <segment id="8">Bob, como</segment>
    <segment id="9">como é conhecido na corporação</segment>
    <segment id="10">,  desbancou  os coordenadores Ubirajara Ferreira Braga</segment>
    <segment id="11">, da 23ª DT (Lauro de Freitas)</segment>
    <segment id="12">, que liderava a 1ª etapa com 68 pontos</segment>
    <segment id="13">, e Luís  Castro</segment>
    <segment id="14">, da 20ª DT (Candeias)</segment>
    <segment id="15">,  líder da 2ª etapa com 74 pontos.</segment>
    <segment id="16">Luís e Ubirajara ficaram com o segundo e terceiro lugares</segment>
    <segment id="17">, respectivamente.</segment>
    <segment id="18">Orientados pelo organizador da competição e instrutor de tiro da Acadepol e da COE</segment>
    <segment id="19">, Álvaro Moraes de Castro</segment>
    <segment id="20">, o Mestre Álvaro</segment>
    <segment id="21">, disputaram na modalidade</segment>
    <segment id="22">“</segment>
    <segment id="23">Tiro de Defesa”</segment>
    <segment id="24">, usando pistolas modelo 2/7 da Tauros de calibre ponto 40 (10 milímetros).</segment>
    <segment id="25">Os vencedores ganharam medalhas</segment>
    <segment id="26">, sendo que o primeiro lugar recebeu uma lavadora de alta pressão  entregue pelo Delegado-chefe da Polícia Civil</segment>
    <segment id="27">, Hélio Jorge.</segment>
    <segment id="28">“</segment>
    <segment id="29">Eles marcaram de 68% a 78% dos 100 pontos</segment>
    <segment id="30">, o que é uma média considerada boa”</segment>
    <segment id="31">, avaliou o delegado-chefe.</segment>
    <segment id="32">Na cola de criminosos: Vale até usar fantasias</segment>
    <segment id="33">A competição revelou histórias antigas.</segment>
    <segment id="34">Quem diria que o delegado-geral</segment>
    <segment id="35">, Hélio Jorge</segment>
    <segment id="36">, e o coordenador de investigação da DREOF</segment>
    <segment id="37">, Otto Francisco</segment>
    <segment id="38">, já se</segment>
    <segment id="39">se fantasiaram de mendigos para investigar um empresário acusado de aliciar  menores.</segment>
    <segment id="40">Foi em 1997</segment>
    <segment id="41">, quando Hélio Jorge era delegado e Otto investigador da Derca.</segment>
    <segment id="42">Eles ficaram em  frente ao motel onde o acusado estava e</segment>
    <segment id="43">, quando o viram saindo</segment>
    <segment id="44">, simularam um acidente com seus próprios carros para impedir que o cara fugisse.</segment>
    <segment id="45">O empresário</segment>
    <segment id="46">, que  estava com duas menores e uma câmera fotográfica</segment>
    <segment id="47">, foi preso em flagrante.</segment>
    <segment id="48">“Não tínhamos celular</segment>
    <segment id="49">, só  viatura padronizada.</segment>
    <segment id="50">Utilizamos as técnicas de investigação e o que tínhamos para criar situações legais”</segment>
    <segment id="51">, disse Hélio Jorge.</segment>
  </rst>
</analysis>