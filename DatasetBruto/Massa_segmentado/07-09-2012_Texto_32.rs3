  <rst>
    <segment id="1">Delegado diz que casal sequestrado em Cruzeiro seria morto em Niter횄쨀i
RIO - O delegado titular da 94횂짧 DP (Pira횄짯)</segment>
    <segment id="2">, Marcelo Haddad</segment>
    <segment id="3">, disse</segment>
    <segment id="4">, nesta sexta-feira</segment>
    <segment id="5">, que o aposentado Celso Ernesto dos Santos</segment>
    <segment id="6">, de 53 anos</segment>
    <segment id="7">, e sua mulher</segment>
    <segment id="8">, Dalva Ribeiro Leite dos Santos</segment>
    <segment id="9">, de 52</segment>
    <segment id="10">, que foram sequestrados em Cruzeiro</segment>
    <segment id="11">, no interior de S횄짙o Paulo</segment>
    <segment id="12">, seriam mortos em Niter횄쨀i</segment>
    <segment id="13">, na Regi횄짙o Metropolitana do Rio.</segment>
    <segment id="14">O delegado Marcelo Haddad disse que o t횄짤cnico em inform횄징tica Gabriel Gustavo Pereira confessou que ele e dois comparsas pretendiam matar o casal</segment>
    <segment id="15">porque</segment>
    <segment id="16">porque eram conhecidos das v횄짯timas e moravam na mesma cidade.</segment>
    <segment id="17">Segundo o pol횄짯cia</segment>
    <segment id="18">, Gabriel disse que escolheu Niter횄쨀i para matar o casal</segment>
    <segment id="19">porque</segment>
    <segment id="20">porque foi a primeira cidade que veio em sua cabe횄짠a.</segment>
    <segment id="21">O trio foi preso por policiais do 10횂쨘 BPM (Barra do Pira횄짯)</segment>
    <segment id="22">, ap횄쨀s capotar com o Palio</segment>
    <segment id="23">, placa EIM-4877</segment>
    <segment id="24">, no quil횄쨈metro 228 da Rodovia Presidente Dutra</segment>
    <segment id="25">, na pista de descida da Serra das Araras</segment>
    <segment id="26">, em Pira횄짯</segment>
    <segment id="27">, no Sul Fluminense.</segment>
    <segment id="28">O carro 횄짤 de propriedade do filho do casal</segment>
    <segment id="29">, Emerson J횄쨘nior dos Santos</segment>
    <segment id="30">, de 25 anos</segment>
    <segment id="31">, que tamb횄짤m foi rendido pelos cinco integrantes da quadrilha que invadiram a casa dos pais dele por volta das 15h de quinta-feira</segment>
    <segment id="32">, na Vila Paulo Romeu</segment>
    <segment id="33">, em Cruzeiro (SP).</segment>
    <segment id="34">Os assaltantes amarraram e amorda횄짠aram a fam횄짯lia</segment>
    <segment id="35">, al횄짤m de espancarem as v횄짯timas e revirarem todo o im횄쨀vel.</segment>
    <segment id="36">Segundo Haddad</segment>
    <segment id="37">, todos os membros do bando tinham cheirado coca횄짯na e estavam embriagados.</segment>
    <segment id="38">Segundo Celso</segment>
    <segment id="39">, os bandidos estavam armados com tr횄짧s pistolas e uma faca.</segment>
    <segment id="40">Dois dos assaltantes chegaram a sacar dinheiro ap횄쨀s pegarem os cart횄쨉es e senhas do aposentado e do filho dele.</segment>
    <segment id="41">Nos primeiros minutos desta sexta-feira</segment>
    <segment id="42">, o casal foi colocado no porta-malas do Palio.</segment>
    <segment id="43">Gabriel assumiu a dire횄짠횄짙o do carro.</segment>
    <segment id="44">No ve횄짯culo</segment>
    <segment id="45">, estavam ainda Gleison J횄쨘nior de Oliveira</segment>
    <segment id="46">, de 26 anos</segment>
    <segment id="47">, e o soldado-atirador Eduardo Silva Juli횄짙o Paiva</segment>
    <segment id="48">, de 19 anos.</segment>
    <segment id="49">Todos moradores tamb횄짤m em Cruzeiro.
- O Palio capotou em alta velocidade na descida da Serra das Araras.</segment>
    <segment id="50">Mesmo com as duas m횄짙os amarradas e amorda횄짠ado</segment>
    <segment id="51">, consegui quebrar o vidro lateral do Palio e pedir ajuda a policiais do Batalh횄짙o de Pol횄짯cia Rodovi횄징ria (BPRV)</segment>
    <segment id="52">, que, por acaso</segment>
    <segment id="53">, estavam indo para Niter횄쨀i e pararam na pista para ver o acidente - disse Celso.</segment>
    <segment id="54">Os policiais encontraram uma garrafa de u횄짯sque e energ횄짤ticos dentro do Palio.</segment>
    <segment id="55">Mesmo feridos no acidente</segment>
    <segment id="56">, os tr횄짧s assaltantes conseguiram fugir a p횄짤.</segment>
    <segment id="57">Gabriel foi o primeiro a ser preso</segment>
    <segment id="58">, quando caminhava 횄혻s margens da Via Dutra</segment>
    <segment id="59">, ap횄쨀s o fim da descida da Serra das Araras</segment>
    <segment id="60">, pr횄쨀ximo ao bairro de Cacaria</segment>
    <segment id="61">, ainda em Pira횄짯.
Por volta das 6h30m</segment>
    <segment id="62">, Eduardo e Gleison foram presos no bairro Estrada Floresta</segment>
    <segment id="63">, em Pira횄짯.</segment>
    <segment id="64">Com eles</segment>
    <segment id="65">, os policiais apreenderam R$ 480</segment>
    <segment id="66">, rel횄쨀gios e celulares que pertenciam 횄혻s v횄짯timas.</segment>
    <segment id="67">Emerson ficou na casa junto com os assaltantes Wellinton Eduardo Quitana de Souza</segment>
    <segment id="68">, de 19 anos</segment>
    <segment id="69">, e Rafael Laviola.</segment>
    <segment id="70">Ap횄쨀s encontrarem a pol횄짯cia</segment>
    <segment id="71">, seus pais contaram que o jovem era mantido ref횄짤m em casa.</segment>
    <segment id="72">A pol횄짯cia de Cruzeiro foi at횄짤 l횄징 e o libertou.</segment>
    <segment id="73">Wellington foi preso</segment>
    <segment id="74">, masmas Rafael continua foragido.</segment>
    <segment id="75">O chefe do Setor de Investiga횄짠횄짙o da 94횂짧 DP</segment>
    <segment id="76">, S횄짤rgio Costa</segment>
    <segment id="77">, afirmou que a inten횄짠횄짙o inicial dos cinco bandidos era apenas furtar objetos de valor da casa do aposentado.</segment>
    <segment id="78">Como encontraram Celso e Dalva no im횄쨀vel</segment>
    <segment id="79">, resolveram anunciar o assalto.
- A inten횄짠횄짙o era apenas furtar os objetos de valor</segment>
    <segment id="80">para que</segment>
    <segment id="81">para que pudessem comprar drogas - disse S횄짤rgio Costa.</segment>
    <segment id="82">Haddad indiciou os acusados nos crimes de roubo com restri횄짠횄짙o de v횄짯timas e forma횄짠횄짙o de quadrilha.</segment>
    <segment id="83">J횄징 o delegado de Cruzeiro</segment>
    <segment id="84">, Cirilo dos Santos Neto</segment>
    <segment id="85">, autuou o bando por extors횄짙o qualificada pela reten횄짠횄짙o das v횄짯timas.</segment>
    <segment id="86">Os tr횄짧s que foram presos em Pira횄짯 ser횄짙o transferidos para Cruzeiro.</segment>
  </rst>
