  <rst>
    <segment id="1">Se pegou com Deus!</segment>
    <segment id="2">Luan Santana escapa da morte após pane em avião</segment>
    <segment id="3">Pela segunda vez</segment>
    <segment id="4">, o cantor viu a vida passar em sua frente</segment>
    <segment id="5">comocomo</segment>
    <segment id="6">sese fosse a última vez.</segment>
    <segment id="7">Isso porque</segment>
    <segment id="8">porque</segment>
    <segment id="9">, na noite de sábado</segment>
    <segment id="10">, o avião que levava o cantor de Londrina (PR) para Macaé (RJ) teve que fazer um pouso de emergência em São José do Rio Preto (SP).</segment>
    <segment id="11">Por sorte</segment>
    <segment id="12">, não passou de susto.</segment>
    <segment id="13">“</segment>
    <segment id="14">O que a gente passou hoje (sábado) serve para darmos mais valor ainda às pessoas que estão à nossa volta”</segment>
    <segment id="15">, escreveu ele ontem no Twitter</segment>
    <segment id="16">, afirmando que “só Deus sabe o que sentimos...</segment>
    <segment id="17">Mas o importante é que a força do bem é muito maior do que a do mal”.</segment>
    <segment id="18">Luan nunca escondeu que teme morrer em um acidente aéreo.</segment>
    <segment id="19">“</segment>
    <segment id="20">Tenho medo de morrer</segment>
    <segment id="21">comocomo os Mamonas Assassinas”</segment>
    <segment id="22">, revelou em entrevista à revista Ti-ti-ti de setembro.</segment>
    <segment id="23">Na ocasião</segment>
    <segment id="24">, ele contou sobre um outro susto que levou:</segment>
    <segment id="25">“</segment>
    <segment id="26">Em um voo para Colatina (ES) chovia demais.</segment>
    <segment id="27">O piloto fez várias tentativas de pouso.</segment>
    <segment id="28">Naquele dia</segment>
    <segment id="29">, pensei que o avião ia</segment>
    <segment id="30">sese espatifar”

Entenda o</segment>
    <segment id="31">casocaso</segment>
    <segment id="32">Uma pane no radar da aeronave onde estava o cantor provocou o pouso de emergência</segment>
    <segment id="33">, segundo informou o empresário de Luan</segment>
    <segment id="34">,  Anderson Ricardo.</segment>
    <segment id="35">Ainda segundo ele</segment>
    <segment id="36">, que não estava no avião</segment>
    <segment id="37">, uma forte turbulência também contribuiu</segment>
    <segment id="38">para que</segment>
    <segment id="39">para que a aeronave perdesse a instabilidade durante o voo.</segment>
    <segment id="40">Aeronave era alugada</segment>
    <segment id="41">O avião que sofreu uma pane não foi o de propriedade do cantor.</segment>
    <segment id="42">Ele pertence a uma empresa de táxi aéreo.</segment>
    <segment id="43">Já o jatinho de Luan</segment>
    <segment id="44">, avaliado em R$ 3 milhões</segment>
    <segment id="45">, não foi usado nem mesmo após o acidente.</segment>
    <segment id="46">Ídolo teen nas telonas

Luan Santana  fará o papel do cantor Leandro no filme “Não aprendi a dizer adeus”</segment>
    <segment id="47">, que contará a história da dupla Leandro e Leonardo.</segment>
    <segment id="48">Esse último será interpretado pelo ator Bruno Gagliasso.</segment>
  </rst>
</analysis>