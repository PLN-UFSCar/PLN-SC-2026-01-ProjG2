  <rst>
    <segment id="1">O vício deles é roubar mansão de ricos</segment>
    <segment id="2">Quarteto alugava carro</segment>
    <segment id="3">, escolhia a casa e fazia a limpa</segment>
    <segment id="4">Quatro membros de uma quadrilha especializada em assaltar mansões</segment>
    <segment id="5">, em bairros nobres de Salvador e Região Metropolitana</segment>
    <segment id="6">, foram apresentados à imprensa</segment>
    <segment id="7">, ontem.</segment>
    <segment id="8">Fábio Jesus dos Reis</segment>
    <segment id="9">, 30 anos</segment>
    <segment id="10">, o Fabinho (líder do bando)</segment>
    <segment id="11">, Tiago Rocha Barreto</segment>
    <segment id="12">, 22, Cleber Sacramento Silva Trindade</segment>
    <segment id="13">, 27, e Roque dos Santos Filho</segment>
    <segment id="14">, 54, foram detidos por policiais da Delegacia da Pituba.</segment>
    <segment id="15">Os acusados rendiam os moradores enquanto eles chegavam no imóvel ou invadiam com os donos já dentro.</segment>
    <segment id="16">Uma das casas assaltadas foi a de um coronel da reserva da PM</segment>
    <segment id="17">, no bairro Portão</segment>
    <segment id="18">, Lauro de Freitas.</segment>
    <segment id="19">Durante o roubo a uma casa</segment>
    <segment id="20">, no Caminho das Árvores</segment>
    <segment id="21">, em 12 de abril</segment>
    <segment id="22">, Tiago obrigou uma das moradoras a ficar nua e passou as mãos nos seios e na vagina da moça</segment>
    <segment id="23">, uma universitária de 23 anos.</segment>
    <segment id="24">Só não houve penetração</segment>
    <segment id="25">porque</segment>
    <segment id="26">porque ele foi impedido por Fábio.</segment>
    <segment id="27">Segundo o delegado Nilton Tormes</segment>
    <segment id="28">, o bando tinha receptadores específicos tanto para vender as joias quanto os eletrônicos.</segment>
    <segment id="29">Sapato italiano de R$ 1</segment>
    <segment id="30">,8 mil</segment>
    <segment id="31">Com a quadrilha foram apreendidas seis TVs de plasma</segment>
    <segment id="32">, dois notebooks</segment>
    <segment id="33">, um video game</segment>
    <segment id="34">, um home theater</segment>
    <segment id="35">, um micro-ondas</segment>
    <segment id="36">, perfumes</segment>
    <segment id="37">, seis celulares</segment>
    <segment id="38">, três relógios</segment>
    <segment id="39">, um sapato italiano avaliado em cerca de R$ 1</segment>
    <segment id="40">,8 mil e um revólver calibre 38.</segment>
    <segment id="41">Segundo a polícia</segment>
    <segment id="42">, os criminosos também roubavam joias e dinheiro encontrados nas residências.</segment>
    <segment id="43">A polícia investiga agora os outros quatro membros da quadrilha que estão foragidos</segment>
    <segment id="44">, inclusive uma mulher.</segment>
    <segment id="45">Eles agiam nos bairros Itaigara</segment>
    <segment id="46">, Itapuã</segment>
    <segment id="47">, Pituba</segment>
    <segment id="48">, Caminho das Árvores</segment>
    <segment id="49">, Patamares</segment>
    <segment id="50">, Piatã</segment>
    <segment id="51">, Stella Maris e Vilas do Atlântico.</segment>
  </rst>
</analysis>