  <rst>
    <segment id="1">Samba de viola tipo exportação</segment>
    <segment id="2">Galera fez parte da ação Tocar para Trocar</segment>
    <segment id="3">, gravado na Ponta de Humaitá</segment>
    <segment id="4">Cinco homens e uma mulher.</segment>
    <segment id="5">“É ela quem dá o toque delicado</segment>
    <segment id="6">, o que é muito bom  em uma banda com tantos homens”</segment>
    <segment id="7">, declara Reinaldo Popó</segment>
    <segment id="8">, vocalista da Sangue Brasil.</segment>
    <segment id="9">Ele se</segment>
    <segment id="10">se refere à percussionista Márcia Bebê que</segment>
    <segment id="11">, ao lado do irmão de nome bem parecido</segment>
    <segment id="12">, Márcio Bebê</segment>
    <segment id="13">, faz a marcação do bom samba executado pelo grupo.</segment>
    <segment id="14">Para completar o time de bambas e manter o sucesso conquistado em seis anos de estrada</segment>
    <segment id="15">, Ed Pereira assume o violão</segment>
    <segment id="16">, Léo Brandão apronta no reco-reco</segment>
    <segment id="17">, e André Sacode arrasa no pandeiro e nos vocais.</segment>
    <segment id="18">Inspirados em cantores de peso</segment>
    <segment id="19">, como</segment>
    <segment id="20">como Zeca Pagodinho e Jorge Aragão</segment>
    <segment id="21">, a galera está com o segundo CD saindo do forno em abril.</segment>
    <segment id="22">São 14 faixas</segment>
    <segment id="23">, 13  delas autorais</segment>
    <segment id="24">, incluindo a música de trabalho</segment>
    <segment id="25">, “Buraco Quente”.</segment>
    <segment id="26">A experiência desses músicos vai além dos palcos.</segment>
    <segment id="27">Em 2011</segment>
    <segment id="28">, o grupo participou do projeto Playing for Change</segment>
    <segment id="29">, organizado por dois norte-americanos com o objetivo de reunir sons provenientes da cultura de cada país.</segment>
    <segment id="30">“Foi uma experiência maravilhosa para todos nós fazer parte desse projeto</segment>
    <segment id="31">, que foi criado para inspirar</segment>
    <segment id="32">, conectar e trazer paz ao mundo através da música”</segment>
    <segment id="33">, afirma o vocalista.</segment>
    <segment id="34">No blog do projeto</segment>
    <segment id="35">, não faltaram elogios à   banda e ao nosso rico repertório musical .</segment>
    <segment id="36">“Na Bahia</segment>
    <segment id="37">, quando você agita uma árvore</segment>
    <segment id="38">, os músicos saem de lá”</segment>
    <segment id="39">, escreveram os idealizadores.</segment>
    <segment id="40">A banda fez o seu papel: mostrar para o mundo o que é que os baianos têm!</segment>
    <segment id="41">Agenda de shows

Conferir essa galera do samba não é difícil.</segment>
    <segment id="42">No domingo</segment>
    <segment id="43">, 4, terá apresentação no bar Água de Pote</segment>
    <segment id="44">, em Itapuã</segment>
    <segment id="45">, a partir das 17h30.</segment>
    <segment id="46">Ingresso: R$ 15.</segment>
    <segment id="47">E não</segment>
    <segment id="48">para por aí.</segment>
    <segment id="49">Toda quinta eles fazem ensaio no Chuleta Bar</segment>
    <segment id="50">, no Politeama</segment>
    <segment id="51">, às 18h30.</segment>
    <segment id="52">Ingresso R$ 5.</segment>
    <segment id="53">Tem também o show que promete bombar na Chácara Bela Cintra</segment>
    <segment id="54">, dia 9</segment>
    <segment id="55">, em Cajazeiras</segment>
    <segment id="56">, com participação das bandas Opção 3 e K entre Nós</segment>
    <segment id="57">, entre outras atrações</segment>
    <segment id="58">, a partir das 19h.</segment>
    <segment id="59">A casadinha custa R$ 30.</segment>
  </rst>
</analysis>