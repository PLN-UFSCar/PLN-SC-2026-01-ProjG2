  </header>
  <rst>
    <segment id="1">Mãe guerreira luta para salvar o filho</segment>
    <segment id="2">Eliene já não aguenta mais ver o caçula Vítor</segment>
    <segment id="3">, 18, envolvido com o mundo das drogas</segment>
    <segment id="4">Mesmo amando o caçula incondicionalmente</segment>
    <segment id="5">, Eliene Sousa de Jesus</segment>
    <segment id="6">, 44 anos</segment>
    <segment id="7">, não tolera mais a vida errada que Vítor de Jesus Silva</segment>
    <segment id="8">, 18, está levando e quer a ajuda de uma clínica.</segment>
    <segment id="9">Dona Eliene recebeu a reportagem em casa</segment>
    <segment id="10">, na Liberdade</segment>
    <segment id="11">, para contar seu drama.</segment>
    <segment id="12">Há cerca de um ano</segment>
    <segment id="13">, Vítor começou a ficar viciado em maconha</segment>
    <segment id="14">, cocaína e até mesmo crack.</segment>
    <segment id="15">A paciência da mãe parece que</segment>
    <segment id="16">sese esgotou completamente na última quarta-feira</segment>
    <segment id="17">, dia 25</segment>
    <segment id="18">, quando dois amigos do filho foram até a casa dela cobrar de Vítor a divisão do dinheiro arrecadado com a venda de um celular roubado no dia anterior</segment>
    <segment id="19">, no Plano Inclinado.</segment>
    <segment id="20">Indiganada</segment>
    <segment id="21">, Eliene achou o chip do aparelho escondido na tubulação do banheiro.</segment>
    <segment id="22">Com o chip nas mãos</segment>
    <segment id="23">, Eliene conseguiu telefonar para a mulher que teve o celular roubado.</segment>
    <segment id="24">Pouco tempo depois</segment>
    <segment id="25">, policiais militares foram até a casa dela e colocaram Vítor na viatura</segment>
    <segment id="26">, com a intenção de localizar o receptador que comprou o aparelho.</segment>
    <segment id="27">Os PMs não tiveram sucesso e Vítor só não ficou preso</segment>
    <segment id="28">porque</segment>
    <segment id="29">porque a vítima ficou com medo de registrar queixa.</segment>
    <segment id="30">“</segment>
    <segment id="31">Eu estou tão desesperada que</segment>
    <segment id="32">, às vezes</segment>
    <segment id="33">, eu penso que</segment>
    <segment id="34">sese ele fosse preso</segment>
    <segment id="35">, iria ver</segment>
    <segment id="36">comocomo é o sofrimento na prisão e tentaria sair dessa vida</segment>
    <segment id="37">, para nunca mais voltar lá”</segment>
    <segment id="38">, desabafa a mãe.</segment>
    <segment id="39">Eliene afirma que é obrigada a esconder qualquer dinheiro do filho</segment>
    <segment id="40">, pois</segment>
    <segment id="41">pois senão ele pega tudo para comprar tóxicos.</segment>
    <segment id="42">Vítor esconde drogas e produtos roubados na tubulação do banheiro</segment>
    <segment id="43">, conforme a mãe.</segment>
    <segment id="44">Sumiço na greve da PM</segment>
    <segment id="45">No período da greve da Polícia Militar</segment>
    <segment id="46">, no último mês de fevereiro</segment>
    <segment id="47">, Eliene lembra que Vítor sumiu de casa durante 10 dias.</segment>
    <segment id="48">Desesperada</segment>
    <segment id="49">, ela confeccionou 12 cartazes com a foto do filho e um telefone de contato</segment>
    <segment id="50">, pedindo ajuda para localizar o caçula que estava desaparecido.</segment>
    <segment id="51">A mãe colou os papéis em vários postes</segment>
    <segment id="52">, no bairro Liberdade.</segment>
    <segment id="53">Na época</segment>
    <segment id="54">, Eliene recebeu a informação de que o filho estava traficando drogas em uma boca de fumo do bairro onde moram.</segment>
    <segment id="55">Segundo a mãe</segment>
    <segment id="56">, Vítor mentiu que estava na casa do pai</segment>
    <segment id="57">, que mora em Simões Filho.</segment>
    <segment id="58">Eliene diz que criou os três filhos praticamente sozinha.</segment>
    <segment id="59">Irmãos são gente boa

Eliene é funcionária terceirizada de um posto de saúde da prefeitura de Salvador</segment>
    <segment id="60">, atuando no setor administrativo.</segment>
    <segment id="61">Ela diz que os dois irmãos de Vítor</segment>
    <segment id="62">, uma jovem de 20 anos e um rapaz de 21</segment>
    <segment id="63">, nunca deram trabalho.</segment>
    <segment id="64">A garota é estudante do ensino médio.</segment>
    <segment id="65">Já o jovem de 21 anos está na faculdade de farmácia e já trabalha na área.</segment>
    <segment id="66">“</segment>
    <segment id="67">Eles já estão com vergonha de Vítor”</segment>
    <segment id="68">, lamenta Eliene.</segment>
    <segment id="69">A mãe recorda que Vítor sempre foi “muito amoroso e prestativo</segment>
    <segment id="70">, ajudando os vizinhos a carregar água</segment>
    <segment id="71">, botijão de gás e outros favores”.</segment>
    <segment id="72">Ela opina que “amizades erradas” o fizeram mudar.</segment>
    <segment id="73">“Acho um absurdo a mãe dizer que não sabe dos erros dos filho.</segment>
    <segment id="74">Mãe que é mãe sempre sabe de tudo.</segment>
    <segment id="75">Ele está errando demais.</segment>
    <segment id="76">Não vou tolerar ninguém indo em minha casa partilhar produto de roubo.</segment>
    <segment id="77">Estou aqui para colaborar com a polícia</segment>
    <segment id="78">, no que for preciso.</segment>
    <segment id="79">Não passo a mão na cabeça”</segment>
    <segment id="80">, garante ela.</segment>
    <segment id="81">Salvação para o rapaz

Católica</segment>
    <segment id="82">, Eliene faz um apelo.</segment>
    <segment id="83">Ela quer que o filho seja internado em uma clínica de recuperação para usuários de drogas.</segment>
    <segment id="84">Porém,</segment>
    <segment id="85">comocomo Vítor não aceita</segment>
    <segment id="86">sese internar de forma espontânea</segment>
    <segment id="87">, a mãe dele pede a ajuda de uma clínica que faça o resgate do jovem mesmo contra a vontade dele.</segment>
    <segment id="88">“</segment>
    <segment id="89">Já fiz tudo o que estava ao meu alcance.</segment>
    <segment id="90">Não tenho mais recursos.</segment>
    <segment id="91">Os vizinhos e os colegas de trabalho sabem da minha luta e torcem por mim.</segment>
    <segment id="92">Sempre acompanhei a vida dos meus filhos</segment>
    <segment id="93">, na escola</segment>
    <segment id="94">, em tudo.</segment>
    <segment id="95">Peço que não tenham pena de mim</segment>
    <segment id="96">, pois</segment>
    <segment id="97">pois é o último dos sentimentos.</segment>
    <segment id="98">Somente peço uma ajuda para interná-lo.</segment>
    <segment id="99">Ele vai</segment>
    <segment id="100">sese recuperar.</segment>
    <segment id="101">Gostei que vocês vieram aqui.</segment>
    <segment id="102">Até em emissoras de TV eu já pensei em ir.</segment>
    <segment id="103">Espero que alguém me ajude”</segment>
    <segment id="104">, pede Eliene.</segment>
  </rst>
</analysis>