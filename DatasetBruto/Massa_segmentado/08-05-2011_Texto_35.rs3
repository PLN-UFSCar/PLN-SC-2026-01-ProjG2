  <rst>
    <segment id="1">Em Cuba</segment>
    <segment id="2">, dissidente morre após ser preso</segment>
    <segment id="3">, diz oposição</segment>
    <segment id="4">Um dissidente cubano teria morrido após ser espancado por policiais logo depois de um protesto na cidade de Santa Clara na semana passada.</segment>
    <segment id="5">A denúncia</segment>
    <segment id="6">, não confirmada</segment>
    <segment id="7">, foi feita ontem ao governo por opositores</segment>
    <segment id="8">, que já definem o episódio</segment>
    <segment id="9">comocomo um "assassinato".</segment>
    <segment id="10">Segundo eles</segment>
    <segment id="11">, o ex-prisioneiro político Juan Wilfredo Soto García</segment>
    <segment id="12">, de 46 anos</segment>
    <segment id="13">, foi levado a um hospital na quinta-feira pelos próprios policiais</segment>
    <segment id="14">, após ser espancado diante de várias testemunhas.</segment>
    <segment id="15">Soto, que tinha outros problemas de saúde</segment>
    <segment id="16">, não teria resistido aos ferimentos</segment>
    <segment id="17">, morrendo no sábado.</segment>
    <segment id="18">A notícia</segment>
    <segment id="19">, no entanto</segment>
    <segment id="20">, só foi divulgada ontem.</segment>
    <segment id="21">O governo ainda não</segment>
    <segment id="22">sese pronunciou sobre o</segment>
    <segment id="23">casocaso.</segment>
    <segment id="24">Segundo o hospital</segment>
    <segment id="25">, a causa da morte foi pancreatite.</segment>
    <segment id="26">O atestado de óbito</segment>
    <segment id="27">, no entanto</segment>
    <segment id="28">, só estará disponível daqui a 15 dias.</segment>
    <segment id="29">Comissão independente exige investigação</segment>
    <segment id="30">Soto era integrante do Polo Antitotalitário Unido</segment>
    <segment id="31">, um grupo de oposição de Santa Clara do qual faz parte o dissidente Guillermo Fariñas</segment>
    <segment id="32">, e havia cumprido 12 anos de prisão por motivos políticos</segment>
    <segment id="33">, segundo mensagem no Twitter da blogueira Yoani Sanchez.</segment>
    <segment id="34">O ex-preso político tinha um problema cardíaco.</segment>
    <segment id="35">Mas, de acordo com Elizardo Sanchez</segment>
    <segment id="36">, da Comissão de Direitos Humanos de Cuba</segment>
    <segment id="37">, um órgão independente</segment>
    <segment id="38">, o espancamento teria sido o motivo da morte.</segment>
    <segment id="39">Elizardo exigiu uma investigação aberta.</segment>
    <segment id="40">Segundo ele</segment>
    <segment id="41">, a polícia tem agido com brutalidade crescente contra dissidentes.</segment>
    <segment id="42">A morte de Soto seguiu a do dissidente preso</segment>
    <segment id="43">Orlando Zapata Tamayo</segment>
    <segment id="44">, ocorrida no ano passado</segment>
    <segment id="45">, que desencadeou uma avalanche de críticas internacionais à repressão contra os presos políticos de Cuba.
Zapata</segment>
    <segment id="46">, que tinha 42 anos e cumpria uma pena de 36 por várias condenações</segment>
    <segment id="47">, morreu no dia 23 de fevereiro de 2010 após uma greve de fome de 85 dias.</segment>
    <segment id="48">Três meses depois</segment>
    <segment id="49">, o presidente Raúl Castro reuniu-</segment>
    <segment id="50">sese com o cardeal cubano Jaime Ortega e aceitou libertar 52 presos políticos</segment>
    <segment id="51">, em um acordo que começou a sair do papel em julho.</segment>
    <segment id="52">Desde então</segment>
    <segment id="53">, mais de 100 pessoas já deixaram a cadeia - a maioria vive no exílio político na Espanha.</segment>
    <segment id="54">Para o governo</segment>
    <segment id="55">, eles são mercenários organizados.</segment>
  </rst>
</analysis>