  <rst>
    <segment id="1">GLOBO e EXTRA realizam Fórum Rio Cidade Sede</segment>
    <segment id="2">Com tantos projetos</segment>
    <segment id="3">, obras e mudanças na cidade</segment>
    <segment id="4">, uma grande discussão ainda cerca os Jogos de 2016: quanto vai custar a realização do evento.</segment>
    <segment id="5">Esse assunto será o tema do seminário do Fórum Rio Cidade Sede</segment>
    <segment id="6">, que O GLOBO e o EXTRA promovem nesta segunda-feira.</segment>
    <segment id="7">O início do encontro está marcado para as 9h no auditório da Bolsa de Valores</segment>
    <segment id="8">, na Praça Quinze.</segment>
    <segment id="9">O diretor de Sustentabilidade dos Jogos de Londres 2012</segment>
    <segment id="10">, Dan Epstein</segment>
    <segment id="11">, é um dos convidados do seminário "</segment>
    <segment id="12">O planejamento orçamentário dos Jogos Olímpicos Rio 2016".</segment>
    <segment id="13">Ele vai tratar das ações sustentáveis no planejamento do evento na capital do Reino Unido.</segment>
    <segment id="14">Em seguida</segment>
    <segment id="15">, será o painel "</segment>
    <segment id="16">Responsabilidades na construção e na gestão do planejamento orçamentário"</segment>
    <segment id="17">, a cargo do presidente da Autoridade Pública Olímpica (APO)</segment>
    <segment id="18">, Márcio Fortes.</segment>
    <segment id="19">Ex-ministro das Cidades</segment>
    <segment id="20">, Fortes promete um orçamento enxuto.</segment>
    <segment id="21">Segundo ele</segment>
    <segment id="22">, o número final ainda foi fechado.</segment>
    <segment id="23">A presidente da Autoridade Olímpica Municipal</segment>
    <segment id="24">, a economista Maria Silvia Bastos Marques</segment>
    <segment id="25">, também vai participar do encontro</segment>
    <segment id="26">, que está previsto para terminar às 12h30</segment>
    <segment id="27">m.</segment>
    <segment id="28">Ela vai falar sobre os projetos da prefeitura para os grandes eventos.</segment>
    <segment id="29">O seminário será mediado pela colunista do GLOBO Flávia Oliveira.</segment>
  </rst>
