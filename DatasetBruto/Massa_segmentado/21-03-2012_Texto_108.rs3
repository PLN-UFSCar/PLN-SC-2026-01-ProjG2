  <rst>
    <segment id="1">Rocinha passa por fase de estabilização</segment>
    <segment id="2">, diz especialista
RIO - Comércio fechado e moradores dentro de casa</segment>
    <segment id="3">, enquanto traficantes disputam em confrontos armados o controle de bocas de fumo.</segment>
    <segment id="4">Quatro meses depois de ser ocupada pela Polícia Militar</segment>
    <segment id="5">, esse é o cenário da Favela da Rocinha desde o último domingo</segment>
    <segment id="6">, quando dois grupos de criminosos intensificaram a disputa pelo comando do tráfico local.</segment>
    <segment id="7">O tempo em que esteve sob o domínio do crime e as características geográficas da comunidade podem explicar a resistência de criminosos na favela.</segment>
    <segment id="8">A antropóloga Jacqueline Muniz</segment>
    <segment id="9">, especialista em segurança pública da Universidade Cândido Mendes</segment>
    <segment id="10">, explica que a comunidade está em fase de estabilização do processo de pacificação.
- Assim</segment>
    <segment id="11">comocomo o Complexo do Alemão</segment>
    <segment id="12">, a Rocinha tem uma área grande e características topográficas específicas.</segment>
    <segment id="13">Além disso</segment>
    <segment id="14">, viveu durante 40 anos sob o domínio do tráfico.</segment>
    <segment id="15">Esses fatores explicam que ainda ocorram conflitos.</segment>
    <segment id="16">Agora é importante a ação de inteligência da polícia</segment>
    <segment id="17">, assim</segment>
    <segment id="18">comocomo a aproximação dela com os moradores</segment>
    <segment id="19">, que devem ter confiança para denunciar.</segment>
    <segment id="20">O estofador José Paulo de Araújo</segment>
    <segment id="21">, há 37 anos na Rocinha</segment>
    <segment id="22">, demonstra insatisfação com a ocupação policial.

- Não vemos mais homens armados</segment>
    <segment id="23">, e os bailes funk terminam cedo</segment>
    <segment id="24">, masmas ficamos apavorados com um toque de recolher</segment>
    <segment id="25">, como</segment>
    <segment id="26">como o de ontem (terça-feira).</segment>
    <segment id="27">Às 22h</segment>
    <segment id="28">, ouvi tiros e vi moleques fugindo.</segment>
    <segment id="29">Para mim</segment>
    <segment id="30">, nada mudou.</segment>
    <segment id="31">Foi tudo maquiagem.</segment>
    <segment id="32">Uma facção rival à da quadrilha de Antônio Bonfim</segment>
    <segment id="33">, o Nem da Rocinha</segment>
    <segment id="34">, teria assumido o controle da maior parte da favela.</segment>
    <segment id="35">A presença policial não impede os tiroteios</segment>
    <segment id="36">, que desde a última segunda-feira deixaram três mortos e amedrontam quem vive na comunidade.</segment>
    <segment id="37">Na quarta-feira</segment>
    <segment id="38">, dois suspeitos foram presos.</segment>
    <segment id="39">Ocupado em novembro de 2010 pelo Exército</segment>
    <segment id="40">, o Complexo do Alemão também sofre com a ação de traficantes</segment>
    <segment id="41">, que desafiam os militares.

- Desde domingo</segment>
    <segment id="42">, depois que escurece</segment>
    <segment id="43">, começam os tiros.</segment>
    <segment id="44">Também ouvimos explosões de granadas.</segment>
    <segment id="45">Homens armados de fuzis</segment>
    <segment id="46">, vestidos de preto</segment>
    <segment id="47">, estão circulando pelas travessas.</segment>
    <segment id="48">Eles gritam nomes de traficantes.</segment>
    <segment id="49">Ninguém sai de casa</segment>
    <segment id="50">, os moradores estão em pânico - conta uma moradora da localidade da Cachopa</segment>
    <segment id="51">, na parte alta da Rocinha</segment>
    <segment id="52">, que pede para não ser identificada.</segment>
    <segment id="53">Concentrados na área que faz divisa com a Favela do Vidigal</segment>
    <segment id="54">, os confrontos são travados entre o bando chefiado pelo traficante Amaro Pereira da Silva</segment>
    <segment id="55">, o Neto</segment>
    <segment id="56">, ligado a Nem</segment>
    <segment id="57">, e a quadrilha comandada por Inácio de Castro e Silva</segment>
    <segment id="58">, o Canelão.</segment>
    <segment id="59">O bandido foi expulso da Rocinha por Nem em 2008.</segment>
    <segment id="60">A disputa teria</segment>
    <segment id="61">sese intensificado depois que parte das bocas de fumo da favela deixou de repassar o faturamento para os remanescentes da quadrilha de Nem.</segment>
    <segment id="62">Segundo o porta-voz da PM</segment>
    <segment id="63">, capitão Ivan Blaz</segment>
    <segment id="64">, o patrulhamento noturno na Rocinha está reforçado por homens do Bope desde segunda-feira.

- Temos conhecimento da presença de traficantes na Rocinha e estamos fazendo todos os esforços para capturá-los.</segment>
    <segment id="65">Configuração do tráfico em áreas ocupadas não é clara</segment>
    <segment id="66">A PM informou que</segment>
    <segment id="67">, nos quatro meses de ocupação</segment>
    <segment id="68">, foram presas 59 pessoas e apreendidos 59 fuzis e 36 pistolas</segment>
    <segment id="69">, além de 15 quilos de maconha</segment>
    <segment id="70">, 500 quilos de cocaína e outras drogas.</segment>
    <segment id="71">Na tarde de quarta</segment>
    <segment id="72">, policiais prenderam Leandro Soares dos Santos</segment>
    <segment id="73">, de 31 anos</segment>
    <segment id="74">, traficante que estaria envolvido no confronto da madrugada de domingo.</segment>
    <segment id="75">Segundo o Disque Denúncia</segment>
    <segment id="76">, os chamados com informações sobre a Rocinha no primeiro trimestre deste ano aumentaram 66% em relação a 2011</segment>
    <segment id="77">, passando de 159 para 265.</segment>
    <segment id="78">O sociólogo e coordenador do Núcleo de Estudos da Cidadania</segment>
    <segment id="79">, Conflito e Violência Urbana da UFRJ</segment>
    <segment id="80">, Michel Misse</segment>
    <segment id="81">, aponta três possíveis cenários para o tráfico ter permanecido nas favelas com UPPs.

- Um é voltar tudo</segment>
    <segment id="82">comocomo era antes</segment>
    <segment id="83">, a derrota do projeto.</segment>
    <segment id="84">Este eu acho pouco provável.</segment>
    <segment id="85">O segundo é a volta do "arrego" (suborno dado por traficantes a policiais)</segment>
    <segment id="86">, masmas sem ostensividade.</segment>
    <segment id="87">No terceiro</segment>
    <segment id="88">, os traficantes</segment>
    <segment id="89">, com dificuldade de manter os pontos de venda</segment>
    <segment id="90">, vão para outra região até que consigam voltar para o segundo cenário (o do "arrego").</segment>
  </rst>
</analysis>