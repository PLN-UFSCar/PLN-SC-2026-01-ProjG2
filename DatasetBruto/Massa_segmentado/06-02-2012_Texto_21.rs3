  <rst>
    <segment id="1">Wando continua internado e manda bilhete</segment>
    <segment id="2">O cantor está acordado e</segment>
    <segment id="3">sese comunica por gestos.</segment>
    <segment id="4">Os cuidados intensivos continuam</segment>
    <segment id="5">O cantor Wando</segment>
    <segment id="6">, de 66 anos</segment>
    <segment id="7">, vem apresentando melhora em seu quadro de saúde</segment>
    <segment id="8">, de acordo com boletim médico divulgado nesta segunda-feira</segment>
    <segment id="9">, 6, pelo Biocor Instituto</segment>
    <segment id="10">, em Nova Lima</segment>
    <segment id="11">, na Região Metropolitana de Belo Horizonte.</segment>
    <segment id="12">O cantor está acordado e</segment>
    <segment id="13">sese comunica por gestos</segment>
    <segment id="14">, tolerando bem a retirada gradual do respirador.</segment>
    <segment id="15">Os cuidados intensivos continuam.</segment>
    <segment id="16">Wando foi internado com dores no peito na sexta-feira (27) e</segment>
    <segment id="17">, quando</segment>
    <segment id="18">sese preparava para um cateterismo</segment>
    <segment id="19">, seu quadro</segment>
    <segment id="20">sese agravou e evoluiu para um enfarte.</segment>
    <segment id="21">Os médicos o submeteram a uma angioplastia de urgência para desobstruir as artérias do coração.</segment>
    <segment id="22">Desde então</segment>
    <segment id="23">, o cantor vinha sendo mantido sedado no CTI</segment>
    <segment id="24">, respirando com auxílio de aparelhos.</segment>
    <segment id="25">Bilhete

No domingo</segment>
    <segment id="26">, o cantor divulgou um bilhete</segment>
    <segment id="27">, apresentado no Fantástico</segment>
    <segment id="28">, da TV Globo</segment>
    <segment id="29">, onde estava escrito "</segment>
    <segment id="30">Eu estou na oficina de Deus arrumando a turbina.</segment>
    <segment id="31">Me aguardem!</segment>
    <segment id="32">".</segment>
