  <rst>
    <segment id="1">Cruzeiro garante tetra antecipadamente</segment>
    <segment id="2">Pelo segundo ano consecutivo</segment>
    <segment id="3">, time vence BrasileirГѓВӘo sem precisar do ГѓВғltimo jog</segment>
    <segment id="4">O Cruzeiro ГѓВ©</segment>
    <segment id="5">, mais uma vez</segment>
    <segment id="6">, o melhor time do Campeonato Brasileiro.</segment>
    <segment id="7">A hegemonia celeste foi matematicamente oficializada ontem</segment>
    <segment id="8">, no MineirГѓВӘo</segment>
    <segment id="9">, diante de mais de 50 mil torcedores.</segment>
    <segment id="10">Гѓв‚¬ vontade dentro de casa e com todos os principais jogadores em campo</segment>
    <segment id="11">, o Cruzeiro venceu o GoiГѓВҰs por 2 a 1</segment>
    <segment id="12">, pela 36Г‚ВҒ rodada</segment>
    <segment id="13">, e garantiu o tГѓВ­tulo com duas rodadas de antecipaГѓВ§ГѓВӘo.</segment>
    <segment id="14">Os gols foram marcados por Ricardo Goulart e Everton Ribeiro</segment>
    <segment id="15">, descontando Samuel.</segment>
    <segment id="16">Um forte temporal caiu sobre Belo Horizonte durante todo o dia e comprometeu a qualidade do espetГѓВҰculo dentro de campo.</segment>
    <segment id="17">Apesar disso</segment>
    <segment id="18">, nas arquibancadas ninguГѓВ©m pareceu</segment>
    <segment id="19">sese importar.</segment>
    <segment id="20">A chuva foi apenas mais um dos muitos combustГѓВ­veis que embalaram a festa daqueles que gritaram Гұв‚¬Е“ГѓВ© campeГѓВӘoГұв‚¬ (do Brasil) pela segunda vez seguida.</segment>
    <segment id="21">Foi igualando as 23 vitГѓВіrias do campeonato de 2013 que o time do tГѓВ©cnico</segment>
    <segment id="22">Marcelo Oliveira comemorou o quarto tГѓВ­tulo nacional (1966</segment>
    <segment id="23">, 2003</segment>
    <segment id="24">, 2013 e agora 2014) e fez a alegria da parte azul da capital mineira e de milhГѓВµes de torcedores espalhados por todo o PaГѓВ­s.</segment>
    <segment id="25">MissГѓВӘo cumprida?</segment>
    <segment id="26">Sim, claro.</segment>
    <segment id="27">ГѓвЂ° hora de comemorar!</segment>
    <segment id="28">No entanto</segment>
    <segment id="29">, a sensaГѓВ§ГѓВӘo de levantar duas taГѓВ§as em quatro dias</segment>
    <segment id="30">ГѓВ© ainda mais tentadora.</segment>
    <segment id="31">Nesta quarta</segment>
    <segment id="32">, o Cruzeiro tentarГѓВҰ reverter a boa vantagem de 2 a 0 do maior rival AtlГѓВ©tico para</segment>
    <segment id="33">sese tornar tambГѓВ©m campeГѓВӘo da Copa do Brasil.</segment>
    <segment id="34">ГѓвЂ° o bГѓВөnus que pode trazer a perfeiГѓВ§ГѓВӘo para o ano de 2014 ao torcedor cruzeirense - faturou o Campeonato Mineiro e</segment>
    <segment id="35">, assim</segment>
    <segment id="36">comocomo em 2003</segment>
    <segment id="37">, completaria a Гұв‚¬Е“TrГѓВ­plice CoroaГұв‚¬.</segment>
