  <rst>
    <segment id="1">Vídeo de Kelly em investigação</segment>
    <segment id="2">Departamento de polícia técnica promete punir o funcionário que gravou imagem</segment>
    <segment id="3">A veiculação de um vídeo no YouTube (site de compartilhamento de vídeos) com imagens da dançarina Kelly Sales Silva</segment>
    <segment id="4">, 23, conhecida</segment>
    <segment id="5">comocomo Kelly Cyclone</segment>
    <segment id="6">, no necrotério do Instituto Médico Legal Nina Rodrigues</segment>
    <segment id="7">, está sendo investigado pelo Departamento de Polícia Técnica.</segment>
    <segment id="8">O site retirou o vídeo do ar</segment>
    <segment id="9">, masmas as pessoas continuam publicando e</segment>
    <segment id="10">, inclusive</segment>
    <segment id="11">, postando no Orkut.</segment>
    <segment id="12">No  vídeo</segment>
    <segment id="13">,  gravado dentro do IML</segment>
    <segment id="14">, o corpo de Kelly aparece deitado em uma gaveta metálica  ainda sujo e com o short jeans e blusa da Seleção Argentina</segment>
    <segment id="15">, que   ela usava quando foi assassinada</segment>
    <segment id="16">, no último dia 18.</segment>
    <segment id="17">O filme inicia mostrando o rosto de Cyclone com os olhos ainda abertos e segue com closes em algumas  tatuagens</segment>
    <segment id="18">comocomo a do nome Tony (suposto namorado que está preso na 23ª DT por tráfico de drogas) na perna esquerda.</segment>
    <segment id="19">“Olha o nome de Tony”</segment>
    <segment id="20">, diz uma voz masculina que parece ser de quem fez as imagens.</segment>
    <segment id="21">“</segment>
    <segment id="22">Já foi”</segment>
    <segment id="23">, fala  novamente a pessoa tirando a câmera do corpo de Kelly e direcionando para outros corpos.</segment>
    <segment id="24">“Equipe</segment>
    <segment id="25">Jonh</segment>
    <segment id="26">”</segment>
    <segment id="27">é outra expressão dita no vídeo</segment>
    <segment id="28">, bem como</segment>
    <segment id="29">como “Tchau</segment>
    <segment id="30">, gordinha.</segment>
    <segment id="31">A gordinha já foi”</segment>
    <segment id="32">, sese referindo ao corpo de outra mulher morta.</segment>
    <segment id="33">Em nota</segment>
    <segment id="34">, o DPT afirmou que o local onde as perícias são feitas é  restrito a funcionários e que  “as imagens estão sendo analisadas pela Corregedoria da Instituição</segment>
    <segment id="35">para que</segment>
    <segment id="36">para que sejam tomadas</segment>
    <segment id="37">, com extremo rigor</segment>
    <segment id="38">, as medidas correcionais que a situação exige”.</segment>
    <segment id="39">O órgão informou ainda que encaminhará as imagens para a  perícia com o objetivo de identificar a autoria e abrirá sindicância para apurar o fato.</segment>
    <segment id="40">O  resultado</segment>
    <segment id="41">, conforme a nota</segment>
    <segment id="42">,  deve sair em 30 dias aproximadamente.</segment>
    <segment id="43">Família está revoltada:</segment>
    <segment id="44">Vão botar na Justiça</segment>
    <segment id="45">“</segment>
    <segment id="46">É uma falta de respeito com os sentimentos dos outros.</segment>
    <segment id="47">A pessoa que fez isso não tem mãe.</segment>
    <segment id="48">Eu quero justiça.</segment>
    <segment id="49">Espero que quem fez isso pague.</segment>
    <segment id="50">Já conversei com meu advogado e vou entrar com um processo.</segment>
    <segment id="51">O Estado vai ter que arcar com isso.</segment>
    <segment id="52">Eu não permiti que ninguém explorasse minha filha depois de morta”</segment>
    <segment id="53">, disse emocionada a  comerciante Maria Aparecida Sales</segment>
    <segment id="54">, mãe de Kelly Cyclone.</segment>
    <segment id="55">“Que ousadia é essa?</segment>
    <segment id="56">Colocaram o vídeo de minha irmã morta na internet?</segment>
    <segment id="57">”, afirmou incrédula a irmã</segment>
    <segment id="58">, a dançarina  Carla Sales</segment>
    <segment id="59">, que  não sabia do vídeo até ser procurada pela reportagem do MASSA!.</segment>
  </rst>
</analysis>