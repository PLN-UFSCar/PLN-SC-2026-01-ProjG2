  <rst>
    <segment id="1">Porta-voz de Nossa Senhora</segment>
    <segment id="2">O advogado Pedro Siqueira diz que fala com a santa</segment>
    <segment id="3">Ser chamado de “maluco” não causa mais estranheza para o advogado Pedro Siqueira</segment>
    <segment id="4">, 40 anos.</segment>
    <segment id="5">O que importa para ele é a fé.</segment>
    <segment id="6">Segundo Siqueira</segment>
    <segment id="7">, sua devoção é tamanha que o fez  ser “eleito” o porta-voz de Nossa Senhora no Brasil.</segment>
    <segment id="8">Há cerca de 20 anos</segment>
    <segment id="9">, o advogado vem reunindo mais de duas mil pessoas durante a reza de um  terço em reverência à santa na Paróquia</segment>
    <segment id="10">Nossa Senhora da Conceição da Gávea</segment>
    <segment id="11">, no Rio de Janeiro.</segment>
    <segment id="12">Nessas sessões</segment>
    <segment id="13">, o homem</segment>
    <segment id="14">, que também é professor universitário</segment>
    <segment id="15">, diz transmitir mensagens enviadas diretamente por Nossa Senhora aos fiéis.</segment>
    <segment id="16">Nem todos os recados</segment>
    <segment id="17">, no entanto</segment>
    <segment id="18">, são passados aos presentes.</segment>
    <segment id="19">“</segment>
    <segment id="20">Eu não tenho tempo suficiente para dar todos os recados dela...</segment>
    <segment id="21">São cerca de 20 mensagens que ela vai me passando”</segment>
    <segment id="22">, diz Pedro</segment>
    <segment id="23">,  explicando que as mensagens são passadas a ele durante  o terço.</segment>
    <segment id="24">“Eu recebo uma voz que fala dentro do coração.</segment>
    <segment id="25">Essa voz é a de Nossa Senhora”</segment>
    <segment id="26">, diz.</segment>
    <segment id="27">A quem  contesta a veracidade do fato</segment>
    <segment id="28">, o advogado informa que quem está no local</segment>
    <segment id="29">, nas últimas terças-feiras do mês</segment>
    <segment id="30">, pode sentir a presença da santa.</segment>
    <segment id="31">“</segment>
    <segment id="32">Se forma uma luz muito grande</segment>
    <segment id="33">, dourada e brilhante</segment>
    <segment id="34">, que vem do teto da igreja.</segment>
    <segment id="35">A pessoa entra no templo para rezar e vai sentir na pele que ali tem uma força”</segment>
    <segment id="36">, garante.

 

Dom desde criança</segment>
    <segment id="37">De família de católicos praticantes</segment>
    <segment id="38">, Pedro Siqueira não sabe explicar quando</segment>
    <segment id="39">, de fato</segment>
    <segment id="40">, começou a receber as mensagens de Nossa Senhora.</segment>
    <segment id="41">A única coisa de que</segment>
    <segment id="42">sese recorda é que os recados começaram a ser mandados ainda quando ele era criança.</segment>
    <segment id="43">No início</segment>
    <segment id="44">, o advogado e lutador de artes marciais não sabia lidar muito bem com as mensagens tristes que a santa transmitia.</segment>
    <segment id="45">Ele diz que “antigamente eu falava</segment>
    <segment id="46">, hoje eu não falo mais.</segment>
    <segment id="47">Só sese eu sentir que a pessoa está muito preparada para ouvir aquilo.</segment>
    <segment id="48">As pessoas pedem para eu falar</segment>
    <segment id="49">, masmas no fundo elas não querem ouvir a verdade”.</segment>
    <segment id="50">Para difundir esses recados</segment>
    <segment id="51">, Pedro lançou em abril o livro “Senhora das Águas”</segment>
    <segment id="52">, com narrativa ficcional</segment>
    <segment id="53">, para contar suas experiências e as dos amigos  que frequentam o terço no Rio.</segment>
  </rst>
</analysis>