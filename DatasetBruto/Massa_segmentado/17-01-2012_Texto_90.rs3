  <rst>
    <segment id="1">Gatas Ba-Vi esquentam campeonato baiano</segment>
    <segment id="2">As gatas do BA-VI deixam os torcedores de boca aberta</segment>
    <segment id="3">O campeonato baiano começou ontem</segment>
    <segment id="4">, masmas as gatas fanáticas há muito tempo mantém o coração acelerado por seus times.</segment>
    <segment id="5">Prova disso é que a loira Aline Aquino</segment>
    <segment id="6">, de Plataforma</segment>
    <segment id="7">, é chamada pelos amigos de ‘rubro-linda’</segment>
    <segment id="8">, apelido perfeito para quem mata e morre pelo Vitória.</segment>
    <segment id="9">Sobrinha de Rosecleide</segment>
    <segment id="10">, torcedora-símbolo do time</segment>
    <segment id="11">, tem a tia</segment>
    <segment id="12">comocomo referência.</segment>
    <segment id="13">“Ela me levava ao Barradão quando eu era de colo.</segment>
    <segment id="14">Desde então</segment>
    <segment id="15">, meu amor pelo Vitória só aumentou”</segment>
    <segment id="16">, revela.</segment>
    <segment id="17">O Bahia também tem torcida forte.</segment>
    <segment id="18">A morena Acácia Leite</segment>
    <segment id="19">, de Cosme de Farias</segment>
    <segment id="20">, sese encanta com os tricolores.</segment>
    <segment id="21">“Tenho muito orgulho do meu time e da torcida do Bahia.</segment>
    <segment id="22">Aconteça o que acontecer</segment>
    <segment id="23">, estamos torcendo juntos”</segment>
    <segment id="24">, diz apaixonada.</segment>
  </rst>
</analysis>