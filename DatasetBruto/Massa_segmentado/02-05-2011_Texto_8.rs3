  <rst>
    <segment id="1">Há 50 anos: Brasil e Paraguai voltam a cancha</segment>
    <segment id="2">Como estava programado</segment>
    <segment id="3">, a seleção brasileira - preparando-</segment>
    <segment id="4">sese para a segunda partida contra o Paraguai</segment>
    <segment id="5">, hoje à noite - treinou ontem pela manhã</segment>
    <segment id="6">, no Estádio Sajonia</segment>
    <segment id="7">, fazendo 20 minutos de individual dirigido por Paulo Amaral</segment>
    <segment id="8">, cabendo a Aimoré comandar a meia hora seguinte de dois toques.</segment>
    <segment id="9">Carona brasileira para guaranis</segment>
    <segment id="10">O desportista Alfonso Capurro recepcionou com um jantar</segment>
    <segment id="11">, anteontem</segment>
    <segment id="12">, os dirigentes brasileiros que</segment>
    <segment id="13">sese encontram nesta capital</segment>
    <segment id="14">, à frente o presidente João Havelange.</segment>
    <segment id="15">Este ficou ali sabendo das dificuldades que enfrentam os guaranis em relação à Copa do Mundo de 1962.</segment>
    <segment id="16">Tomando conhecimento de que o govêrno do país vizinho não poderia despender muita verba para a viagem a Santiago</segment>
    <segment id="17">, o presidente da CBD afirmou que</segment>
    <segment id="18">, caso</segment>
    <segment id="19">caso os paraguaios</segment>
    <segment id="20">sese classifiquem para a Copa</segment>
    <segment id="21">, não terão problemas para o transporte</segment>
    <segment id="22">, seguindo a seleção guarani</segment>
    <segment id="23">comocomo convidada da seleção brasileira</segment>
    <segment id="24">, no mesmo avião especial que levará os campeões mundiais até Santiago.</segment>
    <segment id="25">Vôo Lima-Rio nas asas da FAB</segment>
    <segment id="26">As equipes brasileiras de volibol</segment>
    <segment id="27">, tetracampeãs sul-americanas invictas</segment>
    <segment id="28">, tiveram mais uma vez adiada sua chegada ao Rio.</segment>
    <segment id="29">Os aviões da FAB em que viajarão nossos jogadores sòmente deveriam deixar Lima esta manhã</segment>
    <segment id="30">, com escalas em Arica e Campo Grande</segment>
    <segment id="31">, onde possìvelmente haverá pernoite.</segment>
  </rst>
