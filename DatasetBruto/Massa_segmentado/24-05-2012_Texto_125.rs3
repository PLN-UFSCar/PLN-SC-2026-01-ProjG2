  <rst>
    <segment id="1">Grupo de moradores do Vidigal recupera parque ecológico que estava degradado
RIO - Há sete anos</segment>
    <segment id="2">, o Parque Ecológico do Vidigal só tinha de bonito a vista para o mar.</segment>
    <segment id="3">A área</segment>
    <segment id="4">, localizada logo depois do famoso Biroscão (um grande bar que serve de referência na comunidade)</segment>
    <segment id="5">, era usada</segment>
    <segment id="6">comocomo lixeira por moradores da favela</segment>
    <segment id="7">, que ali jogavam de tudo: resíduos domésticos</segment>
    <segment id="8">, eletrodomésticos e móveis velhos</segment>
    <segment id="9">, pneus</segment>
    <segment id="10">, vasos sanitários</segment>
    <segment id="11">, garrafas PET e potinhos de plástico.</segment>
    <segment id="12">Incomodado com o cenário</segment>
    <segment id="13">, um grupo de dez vizinhos</segment>
    <segment id="14">, por iniciativa própria</segment>
    <segment id="15">, decidiu arregaçar as mangas e fazer dali um pequeno paraíso verde.</segment>
    <segment id="16">A "lipoaspiração</segment>
    <segment id="17">" do lugar</segment>
    <segment id="18">, como</segment>
    <segment id="19">como dizem por lá</segment>
    <segment id="20">,</segment>
    <segment id="21">durou seis anos.</segment>
    <segment id="22">E o resultado hoje é de admirar.
- Esse lugar é bonito à beça - avisa um mototaxista na entrada do Vidigal</segment>
    <segment id="23">, após explicar à equipe</segment>
    <segment id="24">comocomo chegar ao parque.</segment>
    <segment id="25">Nesse tempo</segment>
    <segment id="26">, o entulho foi retirado</segment>
    <segment id="27">, assim</segment>
    <segment id="28">comocomo o chorume.</segment>
    <segment id="29">Árvores da Mata Atlântica foram plantadas</segment>
    <segment id="30">, e os voluntários criaram um "berçário" de mudas.</segment>
    <segment id="31">Parte do lixo foi reciclado</segment>
    <segment id="32">, ganhando utilidade no próprio parque</segment>
    <segment id="33">, que também recebeu tratamento paisagístico.</segment>
    <segment id="34">Tucanos</segment>
    <segment id="35">, macacos</segment>
    <segment id="36">, gambás e o pássaro Tiê-sangue - que inspirou o nome do espaço</segment>
    <segment id="37">, batizado de Sitiê - são agora frequentadores assíduos.</segment>
    <segment id="38">O interessante é que nenhum dos voluntários que promoveram a transformação desse cantinho do Vidigal</segment>
    <segment id="39">, com cerca de 300 metros quadrados</segment>
    <segment id="40">, tem formação em jardinagem</segment>
    <segment id="41">, paisagismo ou arquitetura.</segment>
    <segment id="42">O que move a turma são a criatividade e a dedicação.</segment>
    <segment id="43">Para chegar ao Sitiê</segment>
    <segment id="44">, basta passar pelo portal assinado pelo artista plástico Damião Pereira da Silva e seguir a trilha feita com centenas de pneus do antigo lixão</segment>
    <segment id="45">, transformados em escadas pelos pioneiros do projeto (cerca de dez</segment>
    <segment id="46">, que vão de artistas ao chefe dos garis comunitários).</segment>
    <segment id="47">Garrafas PETs e potes de plásticos jogados fora são usados</segment>
    <segment id="48">comocomo recipientes para mudas.</segment>
    <segment id="49">Sanitários são agora vasos de planta.</segment>
    <segment id="50">As ruínas de três casas desapropriadas no passado pela prefeitura viraram jardim suspenso e oficina de reciclagem.</segment>
    <segment id="51">O grupo também aplica o material PET na decoração do que restou das construções</segment>
    <segment id="52">, que já não enfeiam a paisagem.</segment>
    <segment id="53">A experiência</segment>
    <segment id="54">, visitada por turistas estrangeiros</segment>
    <segment id="55">, masmas pouco conhecida dos cariocas</segment>
    <segment id="56">, entrará na rota da Rio+20: dia 18 de junho</segment>
    <segment id="57">, haverá um tour pela área</segment>
    <segment id="58">, que passará pelo parque ecológico.</segment>
    <segment id="59">Na ocasião</segment>
    <segment id="60">, os criadores do Sitiê darão uma palestra sobre "Lixo Urbano".</segment>
  </rst>
</analysis>