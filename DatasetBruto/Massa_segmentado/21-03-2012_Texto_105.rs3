  <rst>
    <segment id="1">Typo</segment>
    <segment id="2">A é revelação do pagode romântico</segment>
    <segment id="3">Projeto social</segment>
    <segment id="4">Nordeste Eu Sou apoia a galera no lançamento do hit Coisas do Coração</segment>
    <segment id="5">Com apenas sete meses de estrada</segment>
    <segment id="6">, a banda de pagode romântico Typo</segment>
    <segment id="7">A,   nascida no Nordeste de Amaralina</segment>
    <segment id="8">, sese prepara para lançar o primeiro CD.</segment>
    <segment id="9">O talento dos meninos pode ser confirmado nas sete faixas autorais.</segment>
    <segment id="10">Fãs de carteirinha do cantor Thiaguinho</segment>
    <segment id="11">, ex-Exaltasamba</segment>
    <segment id="12">, a galera conta que a escolha do nome para a banda surgiu  do  comentário que o amigo famoso fez no Twitter.</segment>
    <segment id="13">“Ele (Thiaguinho) disse que é pretinho tipo A. Gostamos e resolvemos colocar o nome do grupo por causa disso.</segment>
    <segment id="14">Typo</segment>
    <segment id="15">A é qualidade”</segment>
    <segment id="16">, garante o vocalista Rodrigo Grohe.</segment>
    <segment id="17">Composto por músicos bem jovens</segment>
    <segment id="18">, todos entre 16 e 20 anos</segment>
    <segment id="19">, o grupo foi formado na escola em que todos estudavam.</segment>
    <segment id="20">“Somos todos marinheiros de primeira viagem.</segment>
    <segment id="21">Mas estamos estudando e nosso som é muito bom”</segment>
    <segment id="22">, garante o violonista Jairo Junnyor.</segment>
    <segment id="23">George Mota</segment>
    <segment id="24">, na segunda voz</segment>
    <segment id="25">;  Jailton Santos</segment>
    <segment id="26">, no baixo</segment>
    <segment id="27">;</segment>
    <segment id="28">Ricardo Libório</segment>
    <segment id="29">, no cavaquinho</segment>
    <segment id="30">; Rafael Viana</segment>
    <segment id="31">, no tantan</segment>
    <segment id="32">; Brunno Santos</segment>
    <segment id="33">, no surdo</segment>
    <segment id="34">; e Lucas Lobo</segment>
    <segment id="35">, no violão</segment>
    <segment id="36">, completam a trupe.</segment>
    <segment id="37">Mesmo com as cabeças e forças voltadas para tocar</segment>
    <segment id="38">,  a galera não descuidou dos estudos e terminou o segundo grau para poder investir pesado na carreira.</segment>
    <segment id="39">“Agora</segment>
    <segment id="40">, queremos viver da música”</segment>
    <segment id="41">, afirma Rodrigo.</segment>
    <segment id="42">Com tanto gás</segment>
    <segment id="43">, esses meninos prometem realmente chegar longe.</segment>
    <segment id="44">Bem longe!</segment>
    <segment id="45">Programação

Typo</segment>
    <segment id="46">A vai lançar o primeiro CD no começo de abril</segment>
    <segment id="47">, no Nordeste de Amaralina.</segment>
    <segment id="48">Eles também vão fazer um som no espaço de shows do Engenho Velho da Federação</segment>
    <segment id="49">, no domingo</segment>
    <segment id="50">, a partir das 18h.</segment>
    <segment id="51">Entrada gratuita.</segment>
    <segment id="52">Os rapazes recém-chegados no mercado já tocaram com Fantasmão e Guig Ghetto.</segment>
  </rst>
