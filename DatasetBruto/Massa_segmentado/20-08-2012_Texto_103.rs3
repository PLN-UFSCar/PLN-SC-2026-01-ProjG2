  <rst>
    <segment id="1">Posto vive no toque de recolher
Turma diz que PSF funciona de acordo com a vontade dos chefes do trГѓВЎfico</segment>
    <segment id="2">Os moradores de Paripe jГѓВЎ nГѓВЈo</segment>
    <segment id="3">sese chocam mais quando chegam na Unidade de SaГѓВєde da FamГѓВ­lia de Bate CoraГѓВ§ГѓВЈo e encontram as portas fechadas.</segment>
    <segment id="4">Mas o problema</segment>
    <segment id="5">, que se</segment>
    <segment id="6">se repete</segment>
    <segment id="7">, nГѓВЈo ГѓВ© por falta de mГѓВ©dicos ou funcionГѓВЎrios.</segment>
    <segment id="8">O posto de saГѓВєde</segment>
    <segment id="9">,  localizado na Гўв‚¬Е“Faixa de GazaГўв‚¬ do trГѓВЎfico de drogas</segment>
    <segment id="10">, sese vГѓВЄ obrigado a encerrar o atendimento sempre que existe algum tipo de conflito entre traficantes de Fazenda Coutos 3 e os rivais  do Bate coraГѓВ§ГѓВЈo.</segment>
    <segment id="11">Гўв‚¬Е“JГѓВЎ aconteceu de chegar aqui e ter que voltar</segment>
    <segment id="12">porque</segment>
    <segment id="13">porque os traficantes tinham mandado fechar.</segment>
    <segment id="14">Se tiver tiroteio</segment>
    <segment id="15">, nГѓВЈo tem</segment>
    <segment id="16">comocomo funcionar.</segment>
    <segment id="17">Aqui fica no fundo de Fazenda CoutosГўв‚¬</segment>
    <segment id="18">, diz  BГѓВЎrbara Lorena</segment>
    <segment id="19">, paciente da unidade de saГѓВєde.</segment>
    <segment id="20">A disputa pelo comando do trГѓВЎfico de drogas na regiГѓВЈo ГѓВ© intenso.</segment>
    <segment id="21">Tanto que existe uma norma informal que proГѓВ­be que os postos realizem atendimentos para moradores de localidades rivais.</segment>
    <segment id="22">Гўв‚¬Е“A guerra</segment>
    <segment id="23">ГѓВ© intensa.</segment>
    <segment id="24">Se chegar por aqui um morador de Fazenda Coutos 3</segment>
    <segment id="25">, a gente ГѓВ© quase impedido de realizar qualquer tipo de procedimento.</segment>
    <segment id="26">Ficamos no meio da guerra.</segment>
    <segment id="27">Se a gente nГѓВЈo atende</segment>
    <segment id="28">, ficamos jurados</segment>
    <segment id="29">, sese atende os daqui pedem nossa cabeГѓВ§a.</segment>
    <segment id="30">E aГѓВ­, no desespero</segment>
    <segment id="31">, a gente faz o quГѓВЄ?Гўв‚¬</segment>
    <segment id="32">, questiona uma funcionГѓВЎria do posto</segment>
    <segment id="33">, que nГѓВЈo quis</segment>
    <segment id="34">sese identificar por medo.</segment>
    <segment id="35">Olhe que estГѓВЎ melhor!</segment>
    <segment id="36">Gerente da unidade</segment>
    <segment id="37">, Ricardo Miranda afirma que  a realidade ГѓВ© outra.</segment>
    <segment id="38">Гўв‚¬Е“JГѓВЎ existiu isso</segment>
    <segment id="39">, masmas hoje ГѓВ© tudo mais tranquiloГўв‚¬</segment>
    <segment id="40">, garante.</segment>
    <segment id="41">A assessoria da Secretaria Municipal de SaГѓВєde informou que desconhece a situaГѓВ§ГѓВЈo:</segment>
    <segment id="42">Гўв‚¬Е“Sei que tudo funciona direitinho por lГѓВЎГўв‚¬.  JГѓВЎ o delegado ACM dos Santos</segment>
    <segment id="43">, da 5Г‚Вє DT</segment>
    <segment id="44">, informa que apГѓВіs a prisГѓВЈo do traficante Гѓndio e do desaparecimento de Neguinho do Bate</segment>
    <segment id="45">, a situaГѓВ§ГѓВЈo estГѓВЎ mais tranquila.</segment>
    <segment id="46">Гўв‚¬Е“NГѓВЈo tenho conhecimento dessas aГѓВ§ГѓВµesГўв‚¬</segment>
    <segment id="47">, afirma o delegado.</segment>
    <segment id="48">Lei do crime</segment>
    <segment id="49">Em Paripe</segment>
    <segment id="50">, a rixa entre os traficantes suprime o direito de ir e vir.</segment>
    <segment id="51">A Гўв‚¬ЛњleiГўв‚¬в„ў ГѓВ© clara: quem mora em Bate CoraГѓВ§ГѓВЈo nГѓВЈo pode nem passar por Fazenda Coutos 3 e os dessa localidade nГѓВЈo podem ir na Cocisa</segment>
    <segment id="52">, por exemplo.</segment>
