  <rst>
    <segment id="1">Será que vai rolar?</segment>
    <segment id="2">Durante a festa</segment>
    <segment id="3">, na madrugada de ontem</segment>
    <segment id="4">, pintou um clima entre Yuri e Renata</segment>
    <segment id="5">O troca-troca de casais no Big Brother Brasil 12 promete deixar o clima da casa ainda mais picante nos próximos dias.</segment>
    <segment id="6">Agora, a dupla Yuri e Renata anda dando sinal de que poderá rolar algo mais entre eles.</segment>
    <segment id="7">Os indícios surgiram na Festa Amarelinha</segment>
    <segment id="8">, quando a gata trocou vários elogios com Yuri e os dois quase</segment>
    <segment id="9">sese beijaram na piscina.</segment>
    <segment id="10">A loira parece não gostar de ficar sozinha e investe pesado nos rapazes da casa.</segment>
    <segment id="11">Primeiro foi o ‘rala e rola’ com o brother Jonas.</segment>
    <segment id="12">Depois</segment>
    <segment id="13">, vieram beijinhos e sabe-</segment>
    <segment id="14">sese lá mais o quê em baixo do edredom com Ronaldo.</segment>
    <segment id="15">Agora, joga todas as sua fichas em Yuri.</segment>
    <segment id="16">O brother</segment>
    <segment id="17">, no entanto</segment>
    <segment id="18">, continua babando pela sister Laisa</segment>
    <segment id="19">, mesmo já tendo levado um grande´’pé-na-bunda’.</segment>
    <segment id="20">Nem por isso perdeu a chance de jogar charme e</segment>
    <segment id="21">, quem sabe</segment>
    <segment id="22">, provocar ciuminho na gaúcha.</segment>
    <segment id="23">“</segment>
    <segment id="24">A gente tem afinidade em várias coisas”</segment>
    <segment id="25">, disse o rapaz</segment>
    <segment id="26">, empolgado</segment>
    <segment id="27">, para a mineira.</segment>
  </rst>
</analysis>