  <rst>
    <segment id="1">Jovem de 17 anos matou cadeirante
Leleco</segment>
    <segment id="2">, assustado com o bafafá em torno do crime</segment>
    <segment id="3">, levou a mãe para a delegacia</segment>
    <segment id="4">Um adolescente de 17 anos conhecido</segment>
    <segment id="5">comocomo Leleco confessou à polícia que disparou um dos nove tiros que mataram o cadeirante Waldir Santos</segment>
    <segment id="6">, 48 anos</segment>
    <segment id="7">, o Gordo</segment>
    <segment id="8">, no último domingo</segment>
    <segment id="9">, em Fazenda Coutos 3.</segment>
    <segment id="10">Ao perceber as proporções que o assassinato  tomou</segment>
    <segment id="11">, o adolescente pediu à mãe para levá-lo à 5ª DT (Periperi).</segment>
    <segment id="12">“</segment>
    <segment id="13">A mãe o trouxe sem saber de nada.</segment>
    <segment id="14">Inicialmente</segment>
    <segment id="15">, ele negou o tempo todo e chegou a dizer que era amigo da vítima</segment>
    <segment id="16">, masmas nós tinhamos informações sobre o crime e ele acabou confessando”</segment>
    <segment id="17">, afirmou o titular da 5ª DT</segment>
    <segment id="18">, delegado Antônio Carlos Magalhães Santos.</segment>
    <segment id="19">Os oito primeiros tiros</segment>
    <segment id="20">, segundo Leleco</segment>
    <segment id="21">, foram disparados por Rodrigo Santos Silva</segment>
    <segment id="22">, o Galego.</segment>
    <segment id="23">“</segment>
    <segment id="24">Matamos</segment>
    <segment id="25">porque</segment>
    <segment id="26">porque Gordo ligava para os caras do Santo Antônio (uma das ruas da localidade do Iraque)</segment>
    <segment id="27">e dizia para virem matar a gente.</segment>
    <segment id="28">Galego ouviu ele falar ao telefone”</segment>
    <segment id="29">, contou Leleco</segment>
    <segment id="30">, que é traficante da localidade do Iraque</segment>
    <segment id="31">, em Fazenda Coutos 3</segment>
    <segment id="32">, segundo a polícia.</segment>
    <segment id="33">Ele e Galego haviam  combinado de matar</segment>
    <segment id="34">, masmas não chegaram a programar o crime.</segment>
    <segment id="35">“</segment>
    <segment id="36">A gente</segment>
    <segment id="37">sese bateu com ele na rua e resolvemos matar.</segment>
    <segment id="38">Galego deu oito tiros e passou arma para eu dar o último”</segment>
    <segment id="39">, narrou Leleco.</segment>
    <segment id="40">Após o assassinato</segment>
    <segment id="41">, ele foi para uma igreja em Vista Alegre de Baixo.</segment>
    <segment id="42">“Não rezei e não pedi perdão.</segment>
    <segment id="43">Fui apenas me proteger”</segment>
    <segment id="44">, explicou.</segment>
    <segment id="45">O adolescente  disse  que só sentiu arrependimento pelo que fez quando viu o desespero da  mãe ao saber do envolvimento dele no crime.</segment>
    <segment id="46">“Me arrependi pelo sofrimento que estou vendo minha mãe passar.</segment>
    <segment id="47">Por ter ouvido ela dizer que vai ter que</segment>
    <segment id="48">sese mudar às pressas por minha causa.</segment>
    <segment id="49">Agora vou ter que ir à igreja pelos resto da vida”</segment>
    <segment id="50">, disse.</segment>
    <segment id="51">Fruto do roubo
TVs</segment>
    <segment id="52">, botijões de gás e aparelho de som foram recuperados</segment>
    <segment id="53">A arma usada para matar Waldir</segment>
    <segment id="54">, um revólver calibre 38</segment>
    <segment id="55">, pertence a Alberto dos Santos Souza</segment>
    <segment id="56">, 18 anos</segment>
    <segment id="57">, o Zé</segment>
    <segment id="58">, que foi preso na última quarta</segment>
    <segment id="59">, juntamente com Caveirinha e Emerson</segment>
    <segment id="60">, por policiais da 5ª DT.</segment>
    <segment id="61">Moradores apontaram os três</segment>
    <segment id="62">comocomo autores do assassinato</segment>
    <segment id="63">, masmas eles nada têm a ver com o crime.</segment>
    <segment id="64">Galego e Leleco pegaram a arma emprestada e teriam informado a Zé</segment>
    <segment id="65">para que</segment>
    <segment id="66">para que iriam usá-la.</segment>
    <segment id="67">A polícia procura agora Galego</segment>
    <segment id="68">, que está foragido.</segment>
    <segment id="69">Por ser menor de idade</segment>
    <segment id="70">, Leleco será submetido a medidas socioeducativas.</segment>
    <segment id="71">Só queriam</segment>
    <segment id="72">sese dar bem!</segment>
    <segment id="73">Dois comparsas no roubo

Leleco também confessou participação no furto à casa do cadeirante na última segunda.</segment>
    <segment id="74">Ele disse que furtou</segment>
    <segment id="75">porque</segment>
    <segment id="76">porque precisava de dinheiro para comprar roupas.</segment>
    <segment id="77">Além dele</segment>
    <segment id="78">, Joel dos Santos</segment>
    <segment id="79">, 22 anos</segment>
    <segment id="80">, e Maicon Santos de Jesus</segment>
    <segment id="81">, 19, também participaram do furto.</segment>
    <segment id="82">Joel e Maicon foram presos na quinta-feira passada</segment>
    <segment id="83">, durante operação dos policiais da 5ª DT.</segment>
    <segment id="84">“Participei</segment>
    <segment id="85">porque</segment>
    <segment id="86">porque queria  comprar um som e estava sem dinheiro”</segment>
    <segment id="87">, explicou Joel.</segment>
    <segment id="88">Ao ser abordado pelos policiais</segment>
    <segment id="89">, ele  disse que havia comprado as mercadorias por R$ 250.</segment>
    <segment id="90">No entanto</segment>
    <segment id="91">, ao saber que seria preso em flagrante e indiciado por receptação</segment>
    <segment id="92">, confessou ter participado do furto.</segment>
    <segment id="93">Já Maicon disse que ajudou os colegas a carregar os produtos</segment>
    <segment id="94">, masmas não ficou com nada.</segment>
    <segment id="95">“</segment>
    <segment id="96">Fiz um favor para  Joel.</segment>
    <segment id="97">Ele insistiu muito”</segment>
    <segment id="98">, alegou.</segment>
  </rst>
</analysis>