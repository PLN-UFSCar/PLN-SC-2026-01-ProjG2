  <rst>
    <segment id="1">Carro preto toca terror</segment>
    <segment id="2">Atentado na Mouraria acaba com uma mulher morta e mais dois baleados
ﾃ｢竄ｬﾅ哲ﾃδ｣o corre ninguﾃδｩmﾃ｢竄ｬ</segment>
    <segment id="3">, essas foram as palavras dos atiradores que balearam trﾃδｪs pessoas na noite do ﾃδｺltimo sﾃδ｡bado na Rua Castanheda</segment>
    <segment id="4">, na Mouraria.</segment>
    <segment id="5">O local do crime fica a cerca de 100 metros do Quartel General da 6ﾃつｪ Regiﾃδ｣o Militar do Exﾃδｩrcito.</segment>
    <segment id="6">A ajudante de cozinha Dulce Isaﾃδｭas Franﾃδｧa Monteiro</segment>
    <segment id="7">, 22 anos</segment>
    <segment id="8">, nﾃδ｣o resistiu ao ser atingida nas costas</segment>
    <segment id="9">, no rosto</segment>
    <segment id="10">, no abdﾃδｴmen e no pescoﾃδｧo.</segment>
    <segment id="11">Segundo informaﾃδｧﾃδｵes do Departamento de Homicﾃδｭdios e Proteﾃδｧﾃδ｣o ﾃδ Pessoa (DHPP)</segment>
    <segment id="12">, quatro homens chegaram em um Vectra preto e realizaram os disparos.</segment>
    <segment id="13">Tiago Santos de Araﾃδｺjo</segment>
    <segment id="14">, 26, e um adolescente de 13 anos tambﾃδｩm foram atingidos.</segment>
    <segment id="15">Ambos foram atendidos no Hospital Geral do Estado (HGE) e jﾃδ｡ receberam alta.</segment>
    <segment id="16">Dulce tambﾃδｩm foi levada ao HGE</segment>
    <segment id="17">, masmas jﾃδ｡ chegou morta.</segment>
    <segment id="18">A mﾃδ｣e de Dulce</segment>
    <segment id="19">, Leoneide Franﾃδｧa</segment>
    <segment id="20">, contou que a filha ﾃδｩ trabalhadora</segment>
    <segment id="21">, masmas que jﾃδ｡ namorou com um rapaz envolvido com o trﾃδ｡fico de drogas.</segment>
    <segment id="22">ﾃ｢竄ｬﾅ滴ﾃδ｡ nove meses mataram esse namorado dela.</segment>
    <segment id="23">Nﾃδ｣o sei</segment>
    <segment id="24">sese a morte dela tem alguma coisa a verﾃ｢竄ｬ</segment>
    <segment id="25">, revela.</segment>
    <segment id="26">De acordo com testemunhas</segment>
    <segment id="27">, os homens pararam o carro na entrada da rua e desceram atirando.
Cadﾃδｪ a seguranﾃδｧa?
Moradores da Rua Castanheda reclamam da seguranﾃδｧa no local.</segment>
    <segment id="28">ﾃ｢竄ｬﾅ滴ﾃδ｡ trﾃδｪs meses passaram aqui na rua e atiraram tambﾃδｩm</segment>
    <segment id="29">, masmas ninguﾃδｩm foi atingido.</segment>
    <segment id="30">Moro aqui hﾃδ｡ 16 anos e nunca tinha visto issoﾃ｢竄ｬ</segment>
    <segment id="31">, conta um morador que preferiu nﾃδ｣o</segment>
    <segment id="32">sese identificar.</segment>
    <segment id="33">ﾃ｢竄ｬﾅ鄭 gente tﾃδ｡ precisando de seguranﾃδｧa.</segment>
    <segment id="34">Tinha muita gente na rua na hora</segment>
    <segment id="35">, inclusive</segment>
    <segment id="36">, crianﾃδｧas.</segment>
    <segment id="37">Nﾃδ｣o temos mais liberdade de ficar na ruaﾃ｢竄ｬ</segment>
    <segment id="38">, desabafa outra moradora.</segment>
    <segment id="39">A mﾃδ｣e da vﾃδｭtima espera que a polﾃδｭcia dﾃδｪ uma resposta ao crime.</segment>
    <segment id="40">ﾃ｢竄ｬﾅ擢oi uma brutalidade.</segment>
    <segment id="41">A polﾃδｭcia tem que dar uma resposta.</segment>
    <segment id="42">Tenho nove filhos e ﾃδｩ a primeira que eu perco um.</segment>
    <segment id="43">Conto com a forﾃδｧa de Deus e de amigos para suportar a dorﾃ｢竄ｬ</segment>
    <segment id="44">, desabafa Leoneide.</segment>
  </rst>
