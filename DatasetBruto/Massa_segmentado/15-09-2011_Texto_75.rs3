  <rst>
    <segment id="1">Caso Jobson
Atacante fica de “férias” até 6 de março de 2012</segment>
    <segment id="2">A Corte Arbitral Superior da Fifa decidiu ontem que o ex-atacante  do Bahia</segment>
    <segment id="3">, Jobson</segment>
    <segment id="4">, cumprirá mais  seis meses de suspensão por  uso de crack e cocaína.</segment>
    <segment id="5">A sentença de 42 páginas  foi informada aos advogados do jogador</segment>
    <segment id="6">, que estava em Conceição do Araguai</segment>
    <segment id="7">, no Pará</segment>
    <segment id="8">, a sua terra natal.</segment>
    <segment id="9">“Estou aliviado</segment>
    <segment id="10">porque</segment>
    <segment id="11">porque dos males esse foi o menor.</segment>
    <segment id="12">Seis meses foi uma vitória.</segment>
    <segment id="13">Estou bem tranquilo”</segment>
    <segment id="14">, disse.</segment>
    <segment id="15">Jobson foi flagrado no exame antidoping em 2009</segment>
    <segment id="16">, quando atuava pelo Botafogo.</segment>
    <segment id="17">Na ocasião</segment>
    <segment id="18">, o jogador admitiu ter usado crack</segment>
    <segment id="19">, e foi punido com dois anos de suspensão pelo Superior Tribunal de Justiça Desportiva (STJD)</segment>
    <segment id="20">, que posteriormente reduziu a pena para  seis meses.</segment>
    <segment id="21">A Wada (Agência Mundial Antidoping) discordou da decisão e levou o</segment>
    <segment id="22">casocaso para a CAS</segment>
    <segment id="23">, onde foi julgado no dia 21 de junho deste ano.</segment>
    <segment id="24">Jobson tem vínculo com o clube da estrela solitária</segment>
    <segment id="25">, masmas atualmente está sem clube</segment>
    <segment id="26">, desde que foi dispensado do Bahia</segment>
    <segment id="27">, por problemas disciplinares.</segment>
    <segment id="28">Ele afirmou que iria revelar as causas de sua saída do time baiano</segment>
    <segment id="29">, depois do resultado do julgamento</segment>
    <segment id="30">, masmas até agora não</segment>
    <segment id="31">sese pronunciou.</segment>
    <segment id="32">“Foi uma grande vitória.</segment>
    <segment id="33">Participei do julgamento com o dr. Carlos Portinho e meu sócio Bichara Neto</segment>
    <segment id="34">, e consideramos uma jurisprudência importante.</segment>
    <segment id="35">É um voto de confiança no Jobson”</segment>
    <segment id="36">, disse o advogado do jogador</segment>
    <segment id="37">, Marcos Motta.</segment>
  </rst>
</analysis>