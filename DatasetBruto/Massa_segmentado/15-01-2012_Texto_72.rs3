  <rst>
    <segment id="1">Botafogo está fora da Copa</segment>
    <segment id="2">São Paulo de Juniores
RIO - O Botafogo está fora da Copa</segment>
    <segment id="3">São Paulo de Juniores.</segment>
    <segment id="4">Após conseguir o empate em 2 a 2 com o Vitória com um gol aos 49 minutos do segundo tempo</segment>
    <segment id="5">, o alvinegro carioca decepcionou na disputa de pênaltis:</segment>
    <segment id="6">desperdiçou três cobranças e acabou derrotado por 3 a 1 na briga pela última vaga em jogo nas oitavas de final.</segment>
    <segment id="7">O Fluminense</segment>
    <segment id="8">, que derrotou o Bahia pela manhã</segment>
    <segment id="9">, é o único time do Rio ainda na competição.</segment>
    <segment id="10">O Vitória abriu o placar aos seis minutos de jogo</segment>
    <segment id="11">, com um gol de Givanildo</segment>
    <segment id="12">, masmas o Botafogo chegou ao empate antes do intervalo</segment>
    <segment id="13">, em cabeçada de Dória.</segment>
    <segment id="14">Novamente foi o time baiano quem passou à frente no placar: aos 17 minutos</segment>
    <segment id="15">, Agdon</segment>
    <segment id="16">, de cabeça</segment>
    <segment id="17">, mandou a bola na trave</segment>
    <segment id="18">, e Willie completou no rebote.</segment>
    <segment id="19">Nos acréscimos</segment>
    <segment id="20">, após escanteio da direita</segment>
    <segment id="21">, Dória fez o gol que manteve o Botafogo na briga.</segment>
    <segment id="22">Só que</segment>
    <segment id="23">, nos pênaltis</segment>
    <segment id="24">, quem brilhou foi o goleiro Ruan</segment>
    <segment id="25">, do Vitória</segment>
    <segment id="26">, que pegou dois chutes - de Jadson e Sassá - e ainda viu outra penalidade sair pela linha de fundo.</segment>
    <segment id="27">Do lado baiano</segment>
    <segment id="28">, apenas Gabriel perdeu seu pênalti.</segment>
    <segment id="29">Agdon, Josué e Givanildo marcaram e garantiram a classificação.</segment>
  </rst>
