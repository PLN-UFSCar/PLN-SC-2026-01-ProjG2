  <rst>
    <segment id="1">Menina desaforada
Dedo para o alto é o gesto predileto de Rihanna.</segment>
    <segment id="2">Especialmente quando irritada</segment>
    <segment id="3">Vida de artista é isso aí.</segment>
    <segment id="4">Que dirá de pop stars</segment>
    <segment id="5">, como</segment>
    <segment id="6">como Rihanna.</segment>
    <segment id="7">A cantora foi clicada saindo de um restaurante em Santa Mônica</segment>
    <segment id="8">, nos Estados Unidos.</segment>
    <segment id="9">Não gostou do assédio dos fotógrafos e deu dedo para todos.</segment>
    <segment id="10">O gesto</segment>
    <segment id="11">, aliás</segment>
    <segment id="12">, é frequente nos modos da moça</segment>
    <segment id="13">, que recentemente postou no Twitter uma foto em que aparece de ‘gueixa’</segment>
    <segment id="14">, também com o dedo para o alto.</segment>
  </rst>
