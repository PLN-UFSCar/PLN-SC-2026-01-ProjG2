  <rst>
    <segment id="1">Obama ganha versão Seal em boneco</segment>
    <segment id="2">Uma empresa de brinquedos lançou uma linha de bonecos em que o presidente americano aparece</segment>
    <segment id="3">comocomo um Seal</segment>
    <segment id="4">, como</segment>
    <segment id="5">como são chamados os membros da equipe especial da Marinha responsável pela morte de Osama Bin Laden.</segment>
    <segment id="6">A americana Herobuilders</segment>
    <segment id="7">, acostumada a brincar com a figura de políticos</segment>
    <segment id="8">, chama o boneco de "Rambama"</segment>
    <segment id="9">, em referência ao personagem Rambo dos cinemas.</segment>
    <segment id="10">No site da empresa</segment>
    <segment id="11">, o boneco é descrito nos comentários dos visitantes</segment>
    <segment id="12">comocomo horrível e de mau gosto.</segment>
    <segment id="13">O brinquedo é anunciado por US$ 35.</segment>
  </rst>
