  <rst>
    <segment id="1">Que belezura</segment>
    <segment id="2">Ex de Diogo é uma delícia</segment>
    <segment id="3">Um colírio para os olhos!</segment>
    <segment id="4">Coral Vieira</segment>
    <segment id="5">, dançarina do programa Domingão do Faustão</segment>
    <segment id="6">, mostra toda sua sensualidade em um ensaio provocante para o site Paparazzo.</segment>
    <segment id="7">Solteira</segment>
    <segment id="8">, a gata avisa aos marmanjos que pensam em dar em cima dela que gosta de homens românticos e que pensem nela</segment>
    <segment id="9">, principalmente na cama.</segment>
    <segment id="10">“</segment>
    <segment id="11">Gosto de cara que</segment>
    <segment id="12">sese preocupa comigo e não pensa só nele”</segment>
    <segment id="13">, disse ela</segment>
    <segment id="14">, que tem</segment>
    <segment id="15">comocomo parte favorita do seu corpo as pernas.</segment>
  </rst>
