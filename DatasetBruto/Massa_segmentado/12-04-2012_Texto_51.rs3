  <rst>
    <segment id="1">Amigas unidas na criminalidade</segment>
    <segment id="2">Uma foi presa em flagrante por receptação de objetos roubados e a outra tráfico</segment>
    <segment id="3">Em uma das salas da Delegacia da Boca do Rio</segment>
    <segment id="4">,  o abraço demorado entre Kátia Vanessa Nery Vicente</segment>
    <segment id="5">, 23 anos</segment>
    <segment id="6">, e Tamires José de Moura</segment>
    <segment id="7">, 19, conhecida</segment>
    <segment id="8">comocomo Sequita</segment>
    <segment id="9">, refletiu a amizade entre as duas e o apoio mútuo em um momento bastante complicado para elas.</segment>
    <segment id="10">As duas jovens foram presas</segment>
    <segment id="11">, ontem</segment>
    <segment id="12">, por motivos diferentes</segment>
    <segment id="13">, na comunidade Irmã Dulce</segment>
    <segment id="14">, no bairro</segment>
    <segment id="15">Boca do Rio</segment>
    <segment id="16">, onde elas  moram.</segment>
    <segment id="17">De acordo com os policiais do Serviço de Investigação da Delegacia da Boca do Rio</segment>
    <segment id="18">, Tamires foi autuada em flagrante por tráfico de drogas depois de os agentes encontrarem 73 pedras de crack escondidas no terreno onde está localizada a casa dela.</segment>
    <segment id="19">Os policiais também apreenderam dois irmãos adolescentes de Tamires</segment>
    <segment id="20">, um de 16 e outro de 17 anos.</segment>
    <segment id="21">“</segment>
    <segment id="22">Quando os policiais chegaram</segment>
    <segment id="23">, eu estava dormindo.</segment>
    <segment id="24">O filho de Katinha</segment>
    <segment id="25">, que é uma criança</segment>
    <segment id="26">, dormia ao meu lado.</segment>
    <segment id="27">Acordei com o barulho deles conversando com os meus irmãos.</segment>
    <segment id="28">A droga não é minha</segment>
    <segment id="29">, não foi encontrada comigo”</segment>
    <segment id="30">, defende-</segment>
    <segment id="31">sese Tamires</segment>
    <segment id="32">, que está sem emprego e cursa a 7ª série no Imeja.</segment>
    <segment id="33">Segundo os policiais civis</segment>
    <segment id="34">, a prisão da jovem ocorreu após uma denúncia anônima.</segment>
    <segment id="35">Quando tinha 17 anos</segment>
    <segment id="36">, Sequita foi detida com um pacote de maconha</segment>
    <segment id="37">, na cidade de Lauro de Freitas.</segment>
    <segment id="38">Com Tamires</segment>
    <segment id="39">, os policiais apreenderam R$ 373 em dinheiro.</segment>
    <segment id="40">Já Kátia</segment>
    <segment id="41">Vicente foi autuada em flagrante por receptação de produtos roubados.</segment>
    <segment id="42">Ela pagou fiança de R$ 2</segment>
    <segment id="43">,5 mil e foi liberada ainda na tarde de ontem.</segment>
    <segment id="44">Denúncias de tráfico</segment>
    <segment id="45">De acordo com os policiais da Delegacia da Boca do Rio</segment>
    <segment id="46">, na casa de Kátia foram apreendidas ferramentas elétricas</segment>
    <segment id="47">, três celulares e três câmeras digitais.</segment>
    <segment id="48">Para a polícia</segment>
    <segment id="49">, as ferramentas elétricas teriam sido roubadas da empresa Conslox</segment>
    <segment id="50">, localizada na Avenida Jorge Amado</segment>
    <segment id="51">, no bairro Boca do Rio.</segment>
    <segment id="52">Criminosos arrombaram a janela da loja</segment>
    <segment id="53">, no último dia 6 de abril</segment>
    <segment id="54">, e levaram 
R$ 4</segment>
    <segment id="55">,5 mil do caixa</segment>
    <segment id="56">, além das ferramentas.</segment>
    <segment id="57">Segundo os policiais do Serviço de Investigação da Delegacia da Boca do Rio</segment>
    <segment id="58">, a unidade já recebeu denúncias relatando que Kátia também seria traficante de drogas na região da comunidade Irmã Dulce.</segment>
    <segment id="59">As acusações estão sob investigação.</segment>
    <segment id="60">Ficha suja.</segment>
    <segment id="61">Já tem passagem</segment>
    <segment id="62">A polícia irá investigar agora quem seria o chefão do tráfico</segment>
    <segment id="63">, na região da Boca do Rio</segment>
    <segment id="64">, que estaria fornecendo drogas para Tamires</segment>
    <segment id="65">, a amiga de Kátia.</segment>
    <segment id="66">No dia 11 de setembro de 2008</segment>
    <segment id="67">, Kátia Vanessa foi detida juntamente com outras quatro pessoas.</segment>
    <segment id="68">Em poder desse grupo</segment>
    <segment id="69">, foi apreendida uma espingarda calibre 32.</segment>
    <segment id="70">Segundo a polícia</segment>
    <segment id="71">, Kátia é dona de um bar</segment>
    <segment id="72">, localizado na comunidade Irmã Dulce.</segment>
    <segment id="73">No mesmo local</segment>
    <segment id="74">, durante o dia</segment>
    <segment id="75">, funciona uma creche</segment>
    <segment id="76">, da qual Kátia Vanessa também seria a dona.</segment>
    <segment id="77">Tamires</segment>
    <segment id="78">, que foi presa com os dois irmãos</segment>
    <segment id="79">, garante que não sabe</segment>
    <segment id="80">sese os adolescentes são envolvidos com o tráfico de drogas.</segment>
    <segment id="81">“Eu não sei.</segment>
    <segment id="82">Eu fico em casa</segment>
    <segment id="83">, enquanto eles (os dois irmãos) ficam na rua”</segment>
    <segment id="84">, afirma Sequita.</segment>
    <segment id="85">Na Delegacia da Boca do Rio</segment>
    <segment id="86">, Kátia preferiu não conversar com a reportagem do MASSA!</segment>
  </rst>
</analysis>