  <rst>
    <segment id="1">‘</segment>
    <segment id="2">Os carros de Belo são todos rolo’</segment>
    <segment id="3">A musa do Carnaval afirmou que os veículos do ex são de cambalacho</segment>
    <segment id="4">Feche a fazenda que Belo quer entrar</segment>
    <segment id="5">, minha gente!</segment>
    <segment id="6">Tudo isso</segment>
    <segment id="7">porque</segment>
    <segment id="8">porque Viviane Araújo abriu o bico no reality  e deu a seguinte declaração: "</segment>
    <segment id="9">Eu podia ter carrão</segment>
    <segment id="10">, masmas não tinha nada no meu nome.</segment>
    <segment id="11">Era tudo rolo.</segment>
    <segment id="12">Aliás, até hoje os carros dele são todos rolo” (Olha a polícia na porta!</segment>
    <segment id="13">Já tô  correndo).</segment>
    <segment id="14">Agora está explicado o medo que o cantor  tinha das revelações da musa do Carnaval</segment>
    <segment id="15">, que afirmou ainda que o fim do relacionamento lhe fez bem – e bota bem nisso</segment>
    <segment id="16">, né, Ramadés?.</segment>
    <segment id="17">"É muito ruim não ter paz de espírito.</segment>
    <segment id="18">Hoje, eu trabalho muito mais</segment>
    <segment id="19">, as pessoas têm outra visão do que eu sou.</segment>
    <segment id="20">Tenho as coisas por meu merecimento e não</segment>
    <segment id="21">porque</segment>
    <segment id="22">porque alguém fez para mim"</segment>
    <segment id="23">, disse  (e eu apoio).</segment>
    <segment id="24">A gata contou ainda que sua mãe chegou a alertá-la sobre o caráter de seu ex-marido</segment>
    <segment id="25">, masmas que ela não deu ouvidos.</segment>
    <segment id="26">Os dois</segment>
    <segment id="27">sese separaram em 2007</segment>
    <segment id="28">, após 9 anos juntos.</segment>
    <segment id="29">Assim que a morena entrou no reality</segment>
    <segment id="30">, o cantor tentou proibir que ela falasse seu nome enquanto</segment>
    <segment id="31">estivesse em “</segment>
    <segment id="32">A Fazenda”.</segment>
    <segment id="33">A Justiça</segment>
    <segment id="34">, no entanto</segment>
    <segment id="35">,  negou o pedido.</segment>
    <segment id="36">Em 2011</segment>
    <segment id="37">, o Ministério Público Federal pediu o indiciamento de Belo</segment>
    <segment id="38">, Latino e alguns jogadores por contrabando de carros  importados</segment>
    <segment id="39">, apreendidos pela Polícia Federal.</segment>
    <segment id="40">Ele disse</segment>
    <segment id="41">, na época</segment>
    <segment id="42">,  que a documentação  estava toda em ordem.</segment>
  </rst>
</analysis>