  <rst>
    <segment id="1">Deco domina premiação do Carioca</segment>
    <segment id="2">, masmas é desfalque no Flu
RIO - Em festa promovida na noite desta segunda-feira</segment>
    <segment id="3">, a Ferj elegeu os onze melhores jogadores do Campeonato Carioca 2012.</segment>
    <segment id="4">O time de melhores da competição ficou com Diego Cavalieri</segment>
    <segment id="5">, Fágner</segment>
    <segment id="6">, Dedé</segment>
    <segment id="7">, Thiago Medeiros e Carlinhos</segment>
    <segment id="8">, Rômulo</segment>
    <segment id="9">, Kléberson</segment>
    <segment id="10">, Deco e Felipe</segment>
    <segment id="11">; Vágner Love e Alecsandro.</segment>
    <segment id="12">Além disso</segment>
    <segment id="13">, o Flumienense recebeu oficialmente o troféu de campeão Carioca.</segment>
    <segment id="14">O melhor técnico do campeonato foi considerado Abel Braga</segment>
    <segment id="15">, que, descumprindo ordens do diretor executivo do clube</segment>
    <segment id="16">, Rodrigo Caetano</segment>
    <segment id="17">, revelou os exames de imagem feitos por Deco.</segment>
    <segment id="18">O meia</segment>
    <segment id="19">, que saiu ainda no primeiro tempo no segundo jogo da final</segment>
    <segment id="20">, contra o Botafogo</segment>
    <segment id="21">, deve ficar pelo menos três semanas fora e é descartado para as duas partidas contra o Boca Juniors</segment>
    <segment id="22">, pelas quartas de final da Libertadores.</segment>
    <segment id="23">De acordo com Abel</segment>
    <segment id="24">, o meia só volta a atuar</segment>
    <segment id="25">sese o Fluminense passar para as semifinais da competição.

- Sabemos que é um missão muito difícil</segment>
    <segment id="26">, complicada.</segment>
    <segment id="27">Foi assim lá na Bombonera</segment>
    <segment id="28">, foi assim no Engenhão.</segment>
    <segment id="29">Mas uma coisa a gente tem certeza: hoje o Fluminense vai para a Bombonera e</segment>
    <segment id="30">sese faz respeitar.</segment>
    <segment id="31">Eles sabem que não estão enfrentando uma equipe qualquer - afirmou Abel Braga.</segment>
    <segment id="32">O gol de Deco na final da Taça Guanabara contra o Vasco foi eleito o mais bonito do Estadual.</segment>
    <segment id="33">O meia foi o jogador mais premiado da noite.</segment>
    <segment id="34">Além do título de campeão estadual</segment>
    <segment id="35">, que recebeu com os demais companheiros</segment>
    <segment id="36">, ele levou ainda o prêmio de melhor meia 1</segment>
    <segment id="37">, desbancando Fellype Gabriel e Juninho Pernambucano</segment>
    <segment id="38">, e o principal troféu individual da noite</segment>
    <segment id="39">, de craque da competição.</segment>
    <segment id="40">Juiz devolve bola</segment>
    <segment id="41">No momento mais curioso da premiação</segment>
    <segment id="42">, logo após receber o prêmio de melhor juiz do campeonato</segment>
    <segment id="43">, o árbitro Marcelo de Lima Henrique devolveu a bola da partida final para o atacante Rafael Moura</segment>
    <segment id="44">, que marcou o gol da vitória do Fluminense sobre o Botafogo por 1 a 0.

- Já fiz cerca de quinze finais pelo Brasil</segment>
    <segment id="45">, sete no Rio</segment>
    <segment id="46">, e pela primeira vez vi um atleta querer a bola do jogo.</segment>
    <segment id="47">Talvez seja nosso jeito militarizado de dizer que a bola é minha (dos árbitros).</segment>
    <segment id="48">Mas o Rafael Moura pediu a bola e me comoveu.</segment>
    <segment id="49">Ele merece a bola - afirmou o juiz</segment>
    <segment id="50">, que entregou a bola para Peter Siemsen</segment>
    <segment id="51">, presidende do Fluminense</segment>
    <segment id="52">, que representou o jogador</segment>
    <segment id="53">, ausente na cerimônia.</segment>
