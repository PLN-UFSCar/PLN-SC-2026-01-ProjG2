  <rst>
    <segment id="1">Encaixe mineiro no Leão</segment>
    <segment id="2">Professor Cerezo está sorrindo à toa com o desempenho do time</segment>
    <segment id="3">O deslize no empate da estreia fora de casa contra o Feirense já foi esquecido.</segment>
    <segment id="4">As duas goleadas sobre Juazeiro (6x1) e Vitória da Conquista (5x0) deixaram o técnico Toninho</segment>
    <segment id="5">Cerezo de sorriso largo com seu grupo.</segment>
    <segment id="6">E olha que ainda tem gente de peso</segment>
    <segment id="7">, como</segment>
    <segment id="8">como Marquinhos</segment>
    <segment id="9">, Geovani</segment>
    <segment id="10">, Rodrigo</segment>
    <segment id="11">, Robston</segment>
    <segment id="12">, Pedro Ken</segment>
    <segment id="13">,  Tartá e Dinei.</segment>
    <segment id="14">“</segment>
    <segment id="15">À medida que  forem sendo liberados</segment>
    <segment id="16">, eles vão jogando.</segment>
    <segment id="17">E tem a questão também dos jogos serem quarta e domingo</segment>
    <segment id="18">, sem um período maior de descanso para os jogadores.</segment>
    <segment id="19">Jogamos quarta-feira em Conquista e chegamos hoje (ontem) às 10h da manhã e já vamos treinar à tarde para a partida de domingo.</segment>
    <segment id="20">Isso arrebenta com o jogador</segment>
    <segment id="21">, masmas faz parte do jogo”</segment>
    <segment id="22">, falou  Cerezo.</segment>
    <segment id="23">Parece que o bom mineiro não é adepto da máxima de que em time que está ganhando não</segment>
    <segment id="24">sese mexe.</segment>
    <segment id="25">“</segment>
    <segment id="26">A ideia não é sempre ficar mexendo.</segment>
    <segment id="27">Como a gente joga quarta e domingo</segment>
    <segment id="28">, você não tem nem tempo para treinar.</segment>
    <segment id="29">Sempre uma ou duas mexidas eu vou procurar fazer para dar um descanso”</segment>
    <segment id="30">, explicou.</segment>
    <segment id="31">Mas o que está agradando mesmo ao Toninho Cerezo é o futebol solidário do Leão.</segment>
    <segment id="32">“Está todo mundo correndo</segment>
    <segment id="33">, lutando</segment>
    <segment id="34">, dentro daquela filosofia do futebol de que oito correm pra dois</segment>
    <segment id="35">, masmas sete não correm pra três.</segment>
    <segment id="36">O time todo está</segment>
    <segment id="37">sese posicionando</segment>
    <segment id="38">, perde a bola</segment>
    <segment id="39">, encaixa</segment>
    <segment id="40">, isso é um bom sinal”</segment>
    <segment id="41">, disse o técnico que ontem trabalhou forte com os reservas.</segment>
  </rst>
</analysis>