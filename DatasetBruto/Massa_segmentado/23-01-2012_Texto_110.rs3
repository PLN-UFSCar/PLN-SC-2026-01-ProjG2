  <rst>
    <segment id="1">Leão dá surra no Juazeiro</segment>
    <segment id="2">Diante do Juazeiro</segment>
    <segment id="3">, o Leão aplicou um belo 6 a 1</segment>
    <segment id="4">No primeiro jogo do ano no Barradão</segment>
    <segment id="5">, o Vitória mostrou que está com tudo para buscar o título baiano.</segment>
    <segment id="6">Diante do Juazeiro</segment>
    <segment id="7">, o Leão aplicou um belo 6 a 1</segment>
    <segment id="8">, com gols de Uelliton (dois)</segment>
    <segment id="9">, Lúcio Flávio e Neto Baiano</segment>
    <segment id="10">, que marcou três e foi um dos destaques.</segment>
    <segment id="11">Nino Guerreiro descontou para os visitantes.</segment>
    <segment id="12">Com quatro pontos</segment>
    <segment id="13">, o rubro-negro está em segundo.</segment>
    <segment id="14">A chuva de gols começou com Neto Baiano em chute cruzado.</segment>
    <segment id="15">Nino Guerreiro empatou pouco tempo depois</segment>
    <segment id="16">, masmas o Vitória garantiu o triunfo ainda na etapa inicial: 4 a 1</segment>
    <segment id="17">, com dois de Uelliton de fora da área e um de pênalti de Neto Baiano.</segment>
    <segment id="18">Na etapa final</segment>
    <segment id="19">, o camisa 9 teve outra penalidade</segment>
    <segment id="20">, masmas isolou.</segment>
    <segment id="21">“</segment>
    <segment id="22">O gramado atrapalhou e eu escorreguei”</segment>
    <segment id="23">, justificou.</segment>
    <segment id="24">Porém, depois de um belo gol de Lúcio Flávio de fora da área</segment>
    <segment id="25">,

Neto fechou a goleada e</segment>
    <segment id="26">sese tornou artilheiro do Estadual</segment>
    <segment id="27">, ao lado de João Neto e Clodoaldo</segment>
    <segment id="28">, com três gols.</segment>
    <segment id="29">“Quero ser artilheiro e ajudar o Vitória a ser campeão”</segment>
    <segment id="30">, prometeu o atacante.</segment>
    <segment id="31">Torcida pegou no pé de Uelliton

Boa parte da torcida pegou no pé de Uelliton.</segment>
    <segment id="32">O volante foi xingado antes de a bola rolar.</segment>
    <segment id="33">Depois de marcar dois gols</segment>
    <segment id="34">, ele recebeu aplausos</segment>
    <segment id="35">, masmas as vaias foram maiores.</segment>
    <segment id="36">“Tenho que dar satisfação ao Vitória</segment>
    <segment id="37">, que paga meu salário”</segment>
    <segment id="38">, desabafou.</segment>
    <segment id="39">Goleiro era Bruno ou Michel Teló?</segment>
    <segment id="40">Bruno foi um dos principais destaques do primeiro tempo de Vitória e Juazeiro</segment>
    <segment id="41">, masmas não por qualidade técnica.</segment>
    <segment id="42">O goleiro visitante foi alvo de brincadeiras por parte da torcida do Leão.</segment>
    <segment id="43">Da arquibancada</segment>
    <segment id="44">, uma garota chegou a gritar:</segment>
    <segment id="45">“Vai, Michel Teló!</segment>
    <segment id="46">”.</segment>
    <segment id="47">E parece que a pressão fez efeito.

Bruno</segment>
    <segment id="48">, que parecia estar machucado</segment>
    <segment id="49">, mostrou-</segment>
    <segment id="50">sese inseguro em vários lances.</segment>
    <segment id="51">Além dos vacilos</segment>
    <segment id="52">, o arqueiro levou quatro gols ainda na primeira etapa</segment>
    <segment id="53">, apesar de quase defender a cobrança de pênalti de Neto Baiano.</segment>
    <segment id="54">O resultado da atuação veio no intervalo:</segment>
    <segment id="55">ele terminou substituído por Esaúl</segment>
    <segment id="56">, que fez belas defesas.</segment>
  </rst>
</analysis>