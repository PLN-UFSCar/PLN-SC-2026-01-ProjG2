  <rst>
    <segment id="1">Esse cara sou eu!</segment>
    <segment id="2">Fﾃδ｣ disputa ingresso para show do Rei</segment>
    <segment id="3">Com apenas 17 anos</segment>
    <segment id="4">, o estudante Vinﾃδｭcius Azevedo ﾃδｩ fﾃδ｣ do Rei Roberto Carlos.</segment>
    <segment id="5">Estranho?</segment>
    <segment id="6">Para ele</segment>
    <segment id="7">, nﾃδ｣o.</segment>
    <segment id="8">ﾃ｢竄ｬﾅ哲o geral</segment>
    <segment id="9">, as pessoas estranham por causa da idade</segment>
    <segment id="10">, masmas nﾃδ｣o chega a ser um preconceitoﾃ｢竄ｬ</segment>
    <segment id="11">, conta.</segment>
    <segment id="12">Os prﾃδｳprios amigos avisam quando Roberto aparece na televisﾃδ｣o.</segment>
    <segment id="13">Segundo Vinﾃδｭcius</segment>
    <segment id="14">, o amor - ou melhor</segment>
    <segment id="15">, a grande admiraﾃδｧﾃδ｣o</segment>
    <segment id="16">, como</segment>
    <segment id="17">como o jovem gosta de classificar - pelo cantor teve lﾃδ｡</segment>
    <segment id="18">suas influﾃδｪncias do pai e da avﾃδｳ</segment>
    <segment id="19">, masmas foi algo que surgiu a partir dele mesmo.</segment>
    <segment id="20">ﾃ｢竄ｬﾅ敵osto de MPB</segment>
    <segment id="21">, e Roberto ﾃδｩ o rei da MPB.</segment>
    <segment id="22">Vocﾃδｪ tem que gostar do que ﾃδｩ bomﾃ｢竄ｬ</segment>
    <segment id="23">, diz.</segment>
    <segment id="24">A admiraﾃδｧﾃδ｣o floresceu a partir de um show na Concha Acﾃδｺstica</segment>
    <segment id="25">, em 2011.</segment>
    <segment id="26">ﾃ｢竄ｬﾅ擢oi aﾃδｭ que comecei a colecionar coisas deleﾃ｢竄ｬ</segment>
    <segment id="27">, explica.</segment>
    <segment id="28">Da coleﾃδｧﾃδ｣o</segment>
    <segment id="29">, Vinﾃδｭcius destaca a rosa que ganhou do Rei nesse primeiro e ﾃδｺnico show em que esteve.</segment>
    <segment id="30">ﾃ｢竄ｬﾅ摘u nﾃδ｣o esperava!</segment>
    <segment id="31">Foi uma emoﾃδｧﾃδ｣o da zorraﾃ｢竄ｬ</segment>
    <segment id="32">, lembra.</segment>
    <segment id="33">Para ele</segment>
    <segment id="34">, Roberto Carlos marca sua vida nﾃδ｣o</segment>
    <segment id="35">sﾃδｳ pelas canﾃδｧﾃδｵes</segment>
    <segment id="36">, masmas tambﾃδｩm pelas amizades</segment>
    <segment id="37">, conquistadas graﾃδｧas</segment>
    <segment id="38">ﾃδ admiraﾃδｧﾃδ｣o e</segment>
    <segment id="39">, principalmente</segment>
    <segment id="40">, por sua paixﾃδ｣o pela mﾃδｺsica.</segment>
    <segment id="41">ﾃ｢竄ｬﾅ鄭prendi a tocar violﾃδ｣o para tocar Roberto.</segment>
    <segment id="42">Tenho mﾃδｺsicas minhas que foram inspiradas por versos dele.</segment>
    <segment id="43">Para mim</segment>
    <segment id="44">, ele ﾃδｩ um artista completoﾃ｢竄ｬ</segment>
    <segment id="45">, revela.</segment>
    <segment id="46">Momento de fﾃδ｣</segment>
    <segment id="47">Como todo fﾃδ｣</segment>
    <segment id="48">, Vinﾃδｭcius tambﾃδｩm jﾃδ｡ fez ﾃ｢竄ｬﾅ斗oucurasﾃ｢竄ｬ pelo ﾃδｭdolo.</segment>
    <segment id="49">Uma delas foi o display (ao fundo da foto) do cantor que ele foi buscar em uma loja no Shopping Iguatemi.</segment>
    <segment id="50">O jovem conta que um amigo o avisou sobre o objeto e ele tomou suas prﾃδｳprias providﾃδｪncias.</segment>
    <segment id="51">ﾃ｢竄ｬﾅ擢ui no Iguatemi sﾃδｳ para isso.</segment>
    <segment id="52">Conversei com funcionﾃδ｡rios</segment>
    <segment id="53">, gerentes</segment>
    <segment id="54">, atﾃδｩ que consegui levar para casaﾃ｢竄ｬ</segment>
    <segment id="55">, relembra.</segment>
    <segment id="56">Com 8 DVDs</segment>
    <segment id="57">, 9 CDs e vﾃδ｡rios vinis do cantor</segment>
    <segment id="58">, Vinﾃδｭcius</segment>
    <segment id="59">ﾃδｩ bem modesto:</segment>
    <segment id="60">ﾃ｢竄ｬﾅ典udo o que vejo e ﾃδｩ possﾃδｭvel comprar</segment>
    <segment id="61">, eu comproﾃ｢竄ｬ. Para realizar o sonho de tirar a foto com o Rei</segment>
    <segment id="62">, o rapaz estﾃδ｡ concorrendo ﾃδ promoﾃδｧﾃδ｣o do MASSA!</segment>
    <segment id="63">, que vai levar um fﾃδ｣ ao show do dia 29.</segment>
    <segment id="64">O vencedor serﾃδ｡ escolhido pelos leitores em enquete no site do jornal</segment>
    <segment id="65">, a partir de hoje (15).</segment>
    <segment id="66">Vote atﾃδｩ o dia 27/11.</segment>
    <segment id="67">ﾃ｢竄ｬﾅ鼎ada show</segment>
    <segment id="68">ﾃδｩ uma emoﾃδｧﾃδ｣o diferente para quem ﾃδｩ fﾃδ｣ﾃ｢竄ｬ</segment>
    <segment id="69">, completa.</segment>
  </rst>
