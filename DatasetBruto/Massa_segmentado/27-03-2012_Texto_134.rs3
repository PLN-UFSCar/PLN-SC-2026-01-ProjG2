  <rst>
    <segment id="1">Telefonista dá aquele alô</segment>
    <segment id="2">A morena conta que malha muito todos os dias para dar um grau caprichado ao visual</segment>
    <segment id="3">A gata Érica Pacheco</segment>
    <segment id="4">, 28, nasceu em Nazaré de Jacuípe</segment>
    <segment id="5">, interior baiano</segment>
    <segment id="6">, masmas é em Salvador que atende várias ligações ao dia.</segment>
    <segment id="7">A moça faz faculdade de Educação Física e trabalha</segment>
    <segment id="8">comocomo teleoperadora para pagar os estudos.</segment>
    <segment id="9">Esbanjando um corpão de dar inveja a qualquer uma</segment>
    <segment id="10">, a morena conta que malha muito todos os dias para dar um grau caprichado ao visual.</segment>
    <segment id="11">Para os marmanjões de plantão</segment>
    <segment id="12">, a gata</segment>
    <segment id="13">, que é fã de carteirinha da banda sertaneja de Sapeaçu Los Primos de Chico</segment>
    <segment id="14">, é casadíssima e apaixonada.</segment>
    <segment id="15">“</segment>
    <segment id="16">Eu e meu marido vivemos felizes e não rola ciúmes”</segment>
    <segment id="17">, garante a moça.</segment>
