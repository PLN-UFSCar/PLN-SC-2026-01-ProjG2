  <rst>
    <segment id="1">Sair de casa só</segment>
    <segment id="2">sese for de canoa!</segment>
    <segment id="3">Em Novo Horizonte</segment>
    <segment id="4">, a terra correu e assustou moradores</segment>
    <segment id="5">Sofá boiando</segment>
    <segment id="6">, cachorro ilhado</segment>
    <segment id="7">, sobrou até para o altar do santo que teve que ficar suspenso por blocos para não ser levado pelas águas de esgoto.</segment>
    <segment id="8">O caos tomou conta  do local</segment>
    <segment id="9">, na madrugada de ontem.</segment>
    <segment id="10">Desesperados</segment>
    <segment id="11">, os moradores não sabiam o que fazer  com as casas tomadas por 1m20 de água de esgoto</segment>
    <segment id="12">, que trouxe ratos</segment>
    <segment id="13">, piolho de cobra e fezes.</segment>
    <segment id="14">“</segment>
    <segment id="15">Isso não é vida!</segment>
    <segment id="16">Perdi  guarda-roupa</segment>
    <segment id="17">, fogão e cama</segment>
    <segment id="18">, tudo que lutei meses para comprar em prestações.</segment>
    <segment id="19">Pagamos nossos impostos e quando chove ficamos desse jeito.</segment>
    <segment id="20">Nem trabalhar pude”</segment>
    <segment id="21">, desabafa  o motorista Antônio Santos</segment>
    <segment id="22">, 55.</segment>
    <segment id="23">A situação de calamidade</segment>
    <segment id="24">, segundo os moradores</segment>
    <segment id="25">, sese repete há cinco anos.</segment>
  </rst>
</analysis>