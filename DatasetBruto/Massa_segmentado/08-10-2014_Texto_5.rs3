  <rst>
    <segment id="1">Padre foi perfurado 18 vezes com ferro</segment>
    <segment id="2">Dois homens teriam participado do crime</segment>
    <segment id="3">, que, para a polﾃδｭcia</segment>
    <segment id="4">, nﾃδ｣o foi latrocﾃδｭnio</segment>
    <segment id="5">O padre Francisco Carlos Sousa</segment>
    <segment id="6">, 50, foi morto com 18 perfuraﾃδｧﾃδｵes provocadas por ferro de construﾃδｧﾃδ｣o civil</segment>
    <segment id="7">, segundo informaﾃδｧﾃδｵes da Polﾃδｭcia Civil.</segment>
    <segment id="8">De acordo com testemunhas</segment>
    <segment id="9">, o crime teria sido cometido por dois homens com idade aparente de 25 a 30 anos</segment>
    <segment id="10">, masmas</segment>
    <segment id="11">, o Departamento de Homicﾃδｭdio e Proteﾃδｧﾃδ｣o ﾃδ Pessoa (DHPP) ainda nﾃδ｣o os identificou.</segment>
    <segment id="12">Por causa da violﾃδｪncia do crime</segment>
    <segment id="13">, da arma utilizada e do local onde ele foi assassinado</segment>
    <segment id="14">, a polﾃδｭcia trabalha com a hipﾃδｳtese de homicﾃδｭdio e nﾃδ｣o de roubo tendo</segment>
    <segment id="15">comocomo resultado morte (latrocﾃδｭnio).</segment>
    <segment id="16">O padre estava desaparecido desde domingo</segment>
    <segment id="17">ﾃδ tarde</segment>
    <segment id="18">, quando iria ao santuﾃδ｡rio Mﾃδ｣e e Rainha</segment>
    <segment id="19">, no bairro do Stiep</segment>
    <segment id="20">, para celebrar a missa agendada para as 16h.</segment>
    <segment id="21">O delegado titular da 1ﾃつｪ Delegacia do DHPP</segment>
    <segment id="22">, Marcelo Sansﾃδ｣o</segment>
    <segment id="23">, conta que segundo testemunhas</segment>
    <segment id="24">, os homens perseguiram o padre no matagal</segment>
    <segment id="25">, prﾃδｳximo ao Hotel Catussaba</segment>
    <segment id="26">, em Itapuﾃδ｣</segment>
    <segment id="27">, enquanto ele gritava por socorro.</segment>
    <segment id="28">Um dos autores teria o alcanﾃδｧado e segurado</segment>
    <segment id="29">, enquanto o outro o golpeou.</segment>
    <segment id="30">Depois ele teria sido arrastado para o interior do terreno e nﾃδ｣o foi mais visto.</segment>
    <segment id="31">Arma ﾃδｩ de presﾃδｭdio</segment>
    <segment id="32">Os autores eram negros</segment>
    <segment id="33">, tinham estatura mediana.</segment>
    <segment id="34">Um era forte</segment>
    <segment id="35">, tinha o corpo atlﾃδｩtico</segment>
    <segment id="36">, e o outro era magroﾃ｢竄ｬ</segment>
    <segment id="37">, descreveu o delegado Sansﾃδ｣o a partir da informaﾃδｧﾃδ｣o de testemunhas.</segment>
    <segment id="38">A arma do crime</segment>
    <segment id="39">, encontrada ao lado do corpo</segment>
    <segment id="40">, foi amarrada com um tecido</segment>
    <segment id="41">, o que segundo o delegado</segment>
    <segment id="42">, pode sinalizar que o crime teria sido praticada por ex-detento</segment>
    <segment id="43">, jﾃδ｡ que a arma improvisada</segment>
    <segment id="44">ﾃδｩ utilizada em presﾃδｭdios.</segment>
    <segment id="45">Ainda conforme o delegado</segment>
    <segment id="46">, o celular nﾃδ｣o foi roubado.</segment>
    <segment id="47">O carro da vﾃδｭtima foi utilizado pela dupla para a fuga.</segment>
    <segment id="48">A carteira tambﾃδｩm foi levada.</segment>
    <segment id="49">A Polﾃδｭcia jﾃδ｡</segment>
    <segment id="50">fez o trajeto do religioso</segment>
    <segment id="51">, tentando resgatar imagens de estabelecimentos por onde ele passou.</segment>
    <segment id="52">Um dos empecilhos para a investigaﾃδｧﾃδ｣o</segment>
    <segment id="53">, segundo o delegado</segment>
    <segment id="54">, ﾃδｩ a ausﾃδｪncia de gravaﾃδｧﾃδ｣o no interior do condomﾃδｭnio.</segment>
