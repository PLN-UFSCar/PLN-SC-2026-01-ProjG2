  </header>
  <rst>
    <segment id="1">Conta de luz vai aumentar 6</segment>
    <segment id="2">,15%!</segment>
    <segment id="3">A partir do próximo domingo</segment>
    <segment id="4">, o consumidor deve maneirar no uso de eletrodomésticos</segment>
    <segment id="5">A partir do próximo domingo</segment>
    <segment id="6">, a energia elétrica ficará mais cara 6</segment>
    <segment id="7">,57% para os baianos.</segment>
    <segment id="8">O reajuste que atingirá os 5 milhões de clientes da Coelba</segment>
    <segment id="9">, espalhados por 415 municípios baianos</segment>
    <segment id="10">, foi aprovado ontem pela Agência Nacional de Energia Elétrica (Aneel).</segment>
    <segment id="11">Para os consumidores residenciais</segment>
    <segment id="12">, o reajuste será de 6</segment>
    <segment id="13">,15%.</segment>
    <segment id="14">Para os consumidores de alta-tensão</segment>
    <segment id="15">, como</segment>
    <segment id="16">como as indústrias</segment>
    <segment id="17">, será de 7</segment>
    <segment id="18">,36%.</segment>
    <segment id="19">Um cliente convencional</segment>
    <segment id="20">, que utiliza em média 80 kWh por mês</segment>
    <segment id="21">, que atualmente paga R$ 44</segment>
    <segment id="22">,43, passará a pagar R$ 46</segment>
    <segment id="23">,98, o que representará mais R$ 2</segment>
    <segment id="24">,56 por mês na conta.</segment>
    <segment id="25">De acordo com  a presidente da Associação das Donas de Casa da Bahia</segment>
    <segment id="26">, Selma Magnavita</segment>
    <segment id="27">, o reajuste  pesa no orçamento</segment>
    <segment id="28">, porque</segment>
    <segment id="29">porque vem com o da água e do telefone</segment>
    <segment id="30">, por exemplo e não adianta reclamar.</segment>
    <segment id="31">“</segment>
    <segment id="32">Todo mês de abril eles aumentam”</segment>
    <segment id="33">, lembra.</segment>
    <segment id="34">Para ela</segment>
    <segment id="35">, o mais importante para o consumidor neste momento é buscar alternativas para reduzir o consumo e economizar.</segment>
    <segment id="36">“Agora é um boa ocasião para o consumidor adotar uma postura mais consciente em relação ao consumo.</segment>
    <segment id="37">Se nós economizarmos</segment>
    <segment id="38">, vamos preservar os recursos necessários para gerar energia e cuidar dos nossos bolsos”</segment>
    <segment id="39">, analisa Selma Magnavita.</segment>
    <segment id="40">Atitudes</segment>
    <segment id="41">comocomo o uso consciente de aparelhos eletroeletrônicos</segment>
    <segment id="42">, como</segment>
    <segment id="43">como ar-condicionado</segment>
    <segment id="44">, ventilador</segment>
    <segment id="45">, chuveiro elétrico e ferro de passar</segment>
    <segment id="46">, podem fazer uma grande diferença neste momento</segment>
    <segment id="47">, acredita a dona de casa.</segment>
    <segment id="48">“Se não for suficiente para reduzir a conta</segment>
    <segment id="49">, pelo menos poderá impedir um aumento”</segment>
    <segment id="50">, acredita.</segment>
    <segment id="51">Segure o bolso!</segment>
    <segment id="52">Ferro elétrico - Evite ligar o ferro nos horários em que muitos outros aparelhos estejam ligados.</segment>
    <segment id="53">Ele sobrecarrega a rede elétrica.</segment>
    <segment id="54">Junte, sempre</segment>
    <segment id="55">, a maior quantidade de roupa possível e passe todas de uma vez.</segment>
    <segment id="56">Ambientes - Pinte os ambientes de cor clara</segment>
    <segment id="57">, especialmente os tetos</segment>
    <segment id="58">, que refletem e espalham a luz por todo o ambiente.</segment>
    <segment id="59">Selo - Compre equipamentos com o selo Procel de Economia de Energia.</segment>
    <segment id="60">Geladeiras - Não instale fogão e geladeira lado a lado</segment>
    <segment id="61">, pois</segment>
    <segment id="62">pois um atrapalha o desempenho do outro.</segment>
  </rst>
</analysis>