  <rst>
    <segment id="1">Vamos ajudar o bebê do acidente</segment>
    <segment id="2">Agora precisa de berço</segment>
    <segment id="3">, fraldas</segment>
    <segment id="4">, tudo...</segment>
    <segment id="5">Veja como</segment>
    <segment id="6">como colaborar</segment>
    <segment id="7">Ver a pequena Leandra dos Santos Oliveira</segment>
    <segment id="8">, de seis meses</segment>
    <segment id="9">, recuperando-</segment>
    <segment id="10">sese na enfermaria do Hospital do Subúrbio (HS)</segment>
    <segment id="11">, é acreditar na vida.</segment>
    <segment id="12">Ela foi a única sobrevivente do acidente na BR- 324 (próximo a Simões Filho) na última terça-feira</segment>
    <segment id="13">, que vitimou cinco pessoas.</segment>
    <segment id="14">Umas das vítimas foi a mãe dela</segment>
    <segment id="15">, Ana Paula Ramos de Oliveira</segment>
    <segment id="16">, 28 anos.</segment>
    <segment id="17">Segundo a médica pediatra Maria Betânia Pinto</segment>
    <segment id="18">, Leandra está bem.</segment>
    <segment id="19">“Ela não teve nenhum episódio de piora clínica.</segment>
    <segment id="20">Chora forte</segment>
    <segment id="21">, um sinal de bebê saudável</segment>
    <segment id="22">, e está corada”</segment>
    <segment id="23">, afirma.</segment>
    <segment id="24">Leandra está com um gesso na perna para tratar a fratura no fêmur esquerdo.</segment>
    <segment id="25">Depois de receber alta</segment>
    <segment id="26">, a criança voltará ao povoado de Tabua</segment>
    <segment id="27">, zona rural de Várzea Nova</segment>
    <segment id="28">,  a 326 quilômetros de Salvador.</segment>
    <segment id="29">A pequena heroína vai precisar  pegar a estrada novamente para continuar o tratamento de saúde</segment>
    <segment id="30">, devido à má-formação que tem nas mãos e nos pés.</segment>
    <segment id="31">Auxílio: HS recebe donativos</segment>
    <segment id="32">Enquanto estiver no Hospital do Subúrbio (HS)</segment>
    <segment id="33">, o bebê e a acompanhante terão toda a assistência.</segment>
    <segment id="34">Mas ao receber alta</segment>
    <segment id="35">, Leandra voltará à sua realidade</segment>
    <segment id="36">, uma casa simples de 2/4 e sala na zona rural.</segment>
    <segment id="37">“Ela não tem nem berço.</segment>
    <segment id="38">Dormia na cama com os pais”</segment>
    <segment id="39">, lembra Joselita.</segment>
    <segment id="40">A coordenadora do Serviço Social do HS</segment>
    <segment id="41">, Aline Grimaldi</segment>
    <segment id="42">, lembra que o bebê vai precisar de roupas</segment>
    <segment id="43">, fralda descartável</segment>
    <segment id="44">, leite e brinquedos quando receber alta.</segment>
    <segment id="45">“</segment>
    <segment id="46">O serviço social do Hospital do Subúrbio está recebendo doações para quando Leandra voltar para casa”</segment>
    <segment id="47">, ressalta.</segment>
    <segment id="48">Leandra tem mais três irmãos.</segment>
    <segment id="49">O pai é um lavrador de Várzea Nova.</segment>
    <segment id="50">Batalha da mãe</segment>
    <segment id="51">A cada 15 dias Ana Paula trazia a filha a Salvador para realizar o tratamento.</segment>
    <segment id="52">A rotina começou logo após o nascimento da criança.</segment>
    <segment id="53">“</segment>
    <segment id="54">A mãe queria tanto vê-la (Leandra) bem.</segment>
    <segment id="55">Foi uma guerreira nesses seis meses”</segment>
    <segment id="56">, declara a prima de Ana Paula</segment>
    <segment id="57">, Joselita Freire</segment>
    <segment id="58">, 46, que acompanha a recuperação de Leandra no HS.</segment>
  </rst>
</analysis>