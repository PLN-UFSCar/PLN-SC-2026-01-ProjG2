  <rst>
    <segment id="1">Um show de delícias em exposição nas vitrines para os amantes da boa mesa
RIO - Promessa de refeições saborosas e dicas de culinária</segment>
    <segment id="2">, entre outros prazeres</segment>
    <segment id="3">, o festival Rio Gastronomia não agrada apenas ao paladar.</segment>
    <segment id="4">Os olhos também podem ficar tentados em passeios bem longe das panelas.</segment>
    <segment id="5">A tentação passa pelas vitrines de várias lojas</segment>
    <segment id="6">, que vão expor artigos ligados ao universo gastronômico -</segment>
    <segment id="7">comocomo panelas e copos de cristal -</segment>
    <segment id="8">, com preços mais em conta</segment>
    <segment id="9">, graças ao evento.</segment>
    <segment id="10">Ao todo</segment>
    <segment id="11">, 22 empresas</segment>
    <segment id="12">, com mais de 50 pontos de venda espalhados pela cidade</segment>
    <segment id="13">, enfeitaram suas vitrines.</segment>
    <segment id="14">Criatividade não faltou.</segment>
    <segment id="15">No Centro</segment>
    <segment id="16">, a Prakasa Presentes vai exibir na vitrine uma espagueteira de aço inox com desconto de quase 20%.</segment>
    <segment id="17">Dela, sairá uma suculenta macarronada.</segment>
    <segment id="18">Mas a proprietária Renata Hubner faz um alerta aos mais gulosos:

- O que estará na espagueteira não é macarrão de verdade.</segment>
    <segment id="19">Nosso objetivo é despertar o paladar do cliente.</segment>
    <segment id="20">Afinal</segment>
    <segment id="21">, a gastronomia não</segment>
    <segment id="22">sese limita a um bom prato</segment>
    <segment id="23">, masmas também a artigos que possam complementar a refeição.</segment>
    <segment id="24">Por isso</segment>
    <segment id="25">, além da espagueteira</segment>
    <segment id="26">, estamos com promoções de jogos de copos de cristal</segment>
    <segment id="27">, queijeiras e aparelhos de fondue - conta Renata.</segment>
    <segment id="28">Livrarias exibirão publicações sobre culinária</segment>
    <segment id="29">Com filiais na Zona Sul e Barra</segment>
    <segment id="30">, a Tutto Per La Casa exibirá nas vitrines uma série de artigos essenciais para quem</segment>
    <segment id="31">sese aventura nas panelas com frequência ou somente de vez em quando.

- Nós selecionamos artigos que qualquer bom chefe de cozinha</segment>
    <segment id="32">sese sentiria privilegiado de ter - explicou Jarina Vasilcovsky</segment>
    <segment id="33">, uma das sócias.</segment>
    <segment id="34">O festival também inspirou a loja Daniele Dessin a criar uma linha de pingentes folheados a ródio ou a ouro 18 quilates.</segment>
    <segment id="35">Há cinco modelos: faca</segment>
    <segment id="36">, colher</segment>
    <segment id="37">, garfo</segment>
    <segment id="38">, rolos de macarrão e concha.</segment>
    <segment id="39">As livrarias Saraiva</segment>
    <segment id="40">, Leonardo da Vinci e Argumento separaram livros sobre a arte da cozinha.</segment>
    <segment id="41">A lista completa e os endereços dos participantes podem ser conferidos no site www.riogastronomia.com.</segment>
    <segment id="42">Na quinta-feira</segment>
    <segment id="43">, o presidente do Sindicato de Hotéis</segment>
    <segment id="44">, Bares e Restaurantes do Rio (SindRio)</segment>
    <segment id="45">, Pedro de Lamare</segment>
    <segment id="46">, destacou que o Rio Gastronomia tem tudo para</segment>
    <segment id="47">sese consolidar</segment>
    <segment id="48">comocomo uma das vocações turísticas da cidade:

- Queremos que a cidade nos próximos dez dias respire gastronomia.</segment>
    <segment id="49">Por isso</segment>
    <segment id="50">, o evento não</segment>
    <segment id="51">sese limita a bares e restaurantes</segment>
    <segment id="52">, estendendo-</segment>
    <segment id="53">sese também ao comércio ligado ao setor.</segment>
    <segment id="54">E agosto é um mês excelente para isso</segment>
    <segment id="55">, porque</segment>
    <segment id="56">porque oferece uma opção a mais para o turismo na cidade num mês que é considerado baixa temporada.</segment>
    <segment id="57">Uma iniciativa do GLOBO e da prefeitura do Rio</segment>
    <segment id="58">, através da Riotur</segment>
    <segment id="59">, o Rio Gastronomia tem o apoio do SindRio</segment>
    <segment id="60">, e é patrocinado por Bohemia</segment>
    <segment id="61">, Bradesco</segment>
    <segment id="62">, Sedex</segment>
    <segment id="63">, Sebrae-RJ e CEG.</segment>
    <segment id="64">Jantar reúne 250 convidados</segment>
    <segment id="65">Convidados participam do coquetel servido antes do jantar que abriu</segment>
    <segment id="66">, ontem à noite</segment>
    <segment id="67">, a principal atração do Rio Gastronomia: um cardápio de refeições especiais em 377 restaurantes.</segment>
    <segment id="68">Cerca de 250 convidados</segment>
    <segment id="69">sese reuniram no Palácio da Cidade</segment>
    <segment id="70">, entre eles</segment>
    <segment id="71">, o prefeito Eduardo Paes e personalidades</segment>
    <segment id="72">comocomo a bailarina Ana Botafogo e a cantora Fernanda Abreu.</segment>
    <segment id="73">O menu foi elaborado por quatro chefs renomados: Francesco Carli assinou a entrada</segment>
    <segment id="74">; Claude Troisgros e Roberta Sudbrack</segment>
    <segment id="75">, os pratos principais</segment>
    <segment id="76">; e Samantha Aquim</segment>
    <segment id="77">, a sobremesa.</segment>
  </rst>
</analysis>