    <segment id="62">PenГѓВ­nsula itapagipana</segment>
    <segment id="63">A praia da Ribeira faz parte da PenГѓВ­nsula Itapagipana.</segment>
    <segment id="64">Com um formato similar ao de uma vГѓВ­rgula</segment>
    <segment id="65">, a penГѓВ­nsula tem 42</segment>
    <segment id="66">,76 hectares e cerca de 166 mil habitantes.</segment>
    <segment id="67">A regiГѓВӘo ГѓВ© composta pelos seguintes bairros: Itapagipe</segment>
    <segment id="68">, Massaranduba</segment>
    <segment id="69">, Vila Rui Barbosa</segment>
