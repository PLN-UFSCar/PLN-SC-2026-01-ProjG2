  <rst>
    <segment id="1">Jards Macal횄짤 desafia UFRJ e faz show pelo Dia dos Pais em frente ao Canec횄짙o
RIO - Ocupada por estudantes da Universidade Federal do Rio de Janeiro (UFRJ) desde o dia 24 de julho</segment>
    <segment id="2">, a entrada do Canec횄짙o recebeu na tarde deste domingo o que pode ter sido o maior show desde o fechamento da casa de espet횄징culos</segment>
    <segment id="3">, em outubro de 2010.</segment>
    <segment id="4">Jards Macal횄짤 foi convidado pelo Diret횄쨀rio Central dos Estudantes para fazer uma homenagem ao Dia dos Pais em frente</segment>
    <segment id="5">횄혻 casa</segment>
    <segment id="6">, a partir das 18h</segment>
    <segment id="7">, com entrada franca.</segment>
    <segment id="8">O evento ocorreu sem incidentes.</segment>
    <segment id="9">O cantor disse ao p횄쨘blico que</segment>
    <segment id="10">sese sentia honrado em fazer o show</segment>
    <segment id="11">, j횄징 que ele nunca tinha tocado no Canec횄짙o.</segment>
    <segment id="12">No s횄징bado 횄혻 noite</segment>
    <segment id="13">, a reitoria da UFRJ</segment>
    <segment id="14">, propriet횄징ria do terreno</segment>
    <segment id="15">, havia divulgado uma nota alertando para os riscos 횄혻 seguran횄짠a do local e</segment>
    <segment id="16">sese eximindo de responsabilidade em</segment>
    <segment id="17">casocaso de problemas.</segment>
    <segment id="18">Mesmo assim</segment>
    <segment id="19">, Macal횄짤 havia confirmado a apresenta횄짠횄짙o e declarado apoio aos estudantes:
- Sempre estive ao lado dos estudantes e continuarei.</segment>
    <segment id="20">O que a universidade quer</segment>
    <segment id="21">, com atitudes</segment>
    <segment id="22">comocomo essa</segment>
    <segment id="23">, 횄짤 impedir os estudantes de</segment>
    <segment id="24">sese manifestarem livremente.</segment>
    <segment id="25">Se dizem de esquerda</segment>
    <segment id="26">, masmas s횄짙o sempre de direita.</segment>
    <segment id="27">Desde a ocupa횄짠횄짙o</segment>
    <segment id="28">, os estudantes v횄짧m promovendo reuni횄쨉es e atividades culturais no local.</segment>
    <segment id="29">Segundo a nota divulgada no s횄징bado</segment>
    <segment id="30">, a UFRJ tem "reiteradamente advertido o DCE para os riscos da ocupa횄짠횄짙o do antigo Canec횄짙o</segment>
    <segment id="31">, em virtude das prec횄징rias condi횄짠횄쨉es da rede el횄짤trica</segment>
    <segment id="32">, do telhado e dos extintores".</segment>
    <segment id="33">Macal횄짤 j횄징 teria sido avisado dos perigos e recebido a oferta para</segment>
    <segment id="34">sese apresentar em algum im횄쨀vel cont횄짯guo da universidade</segment>
    <segment id="35">, como</segment>
    <segment id="36">como o do antigo bingo ou a Casa da Ci횄짧ncia</segment>
    <segment id="37">, que fica na Rua Lauro Muller</segment>
    <segment id="38">, tamb횄짤m em Botafogo.</segment>
    <segment id="39">Ao final da nota</segment>
    <segment id="40">, a Reitoria atribui ao DCE e aos artistas envolvidos a responsabilidade por quaisquer acidentes.</segment>
    <segment id="41">Segundo os estudantes</segment>
    <segment id="42">, alunos da faculdade de Arquitetura e o professor Luiz Felipe Cunha fizeram visitas t횄짤cnicas ao local antes de sua ocupa횄짠횄짙o para atestar as condi횄짠횄쨉es de seguran횄짠a para a ocupa횄짠횄짙o e a realiza횄짠횄짙o de eventos.</segment>
    <segment id="43">Na semana passada</segment>
    <segment id="44">, o local abrigou a festa Maracangalha</segment>
    <segment id="45">, reunindo cerca de mil pessoas.</segment>
    <segment id="46">A ocupa횄짠횄짙o faz parte das a횄짠횄쨉es do Comando de Greve UFRJ</segment>
    <segment id="47">, que reivindica</segment>
    <segment id="48">, entre outros t횄쨀picos</segment>
    <segment id="49">, a destina횄짠횄짙o de 10% do PIB nacional 횄혻 educa횄짠횄짙o p횄쨘blica e a transforma횄짠횄짙o do Canec횄짙o num centro cultural de gest횄짙o p횄쨘blica.</segment>
    <segment id="50">Est횄징 marcada para a manh횄짙 da pr횄쨀xima ter횄짠a-feira uma nova reuni횄짙o entre os ocupantes do espa횄짠o e a coordenadoria do F횄쨀rum de Ci횄짧ncia e Cultura para discutir o destino da casa noturna.</segment>
    <segment id="51">Macal횄짤 foi convidado para tocar no Canec횄짙o h횄징 duas semanas.</segment>
    <segment id="52">Ao falar sobre o convite</segment>
    <segment id="53">, lembrou de epis횄쨀dios controversos dos quais participou nos anos 70</segment>
    <segment id="54">, durante o Regime Militar.
- N횄짙o tenho nenhuma preocupa횄짠횄짙o com rela횄짠횄짙o 횄혻 seguran횄짠a do evento.</segment>
    <segment id="55">Participei do 1횂쨘 Circuito Universit횄징rio em 1971</segment>
    <segment id="56">, ao lado do Gilberto Gil (o evento era uma alternativa para os m횄쨘sicos que tinham problemas com a censura).</segment>
    <segment id="57">J횄징 fiz show em 1973 no MAM</segment>
    <segment id="58">, perto de obras car횄짯ssimas</segment>
    <segment id="59">, de Picasso e outros grandes artistas</segment>
    <segment id="60">, e deu tudo certo.</segment>
    <segment id="61">Foi uma comemora횄짠횄짙o maravilhosa pelo 25횂쨘 anivers횄징rio da Carta de Declara횄짠횄짙o dos Direitos Humanos</segment>
    <segment id="62">, da ONU.</segment>
    <segment id="63">O que me preocupa 횄짤 ser convidado</segment>
    <segment id="64">, cantar e tocar - diz ele.</segment>
    <segment id="65">Para esta homenagem aos pais</segment>
    <segment id="66">, Macal횄짤 - que n횄짙o tem filhos - havia preparado um repert횄쨀rio de sucessos seus</segment>
    <segment id="67">comocomo "Gothan City" (Macal횄짤/Capinam)</segment>
    <segment id="68">, "Canalha" (Walter Franco)</segment>
    <segment id="69">, "</segment>
    <segment id="70">Mambo da cantareira" (Macal횄짤) e "</segment>
    <segment id="71">Juizo final" (Nelson Cavaquinho)</segment>
    <segment id="72">, em cerca de uma hora de show.</segment>
