  <rst>
    <segment id="1">Matança dentro de bar no Arenoso
Chacina teria ligação com briga entre gangues</segment>
    <segment id="2">Quatro homens foram mortos em uma chacina na Rua Reginaldo Praxedes</segment>
    <segment id="3">, no Arenoso</segment>
    <segment id="4">, sábado à noite.</segment>
    <segment id="5">Segundo moradores</segment>
    <segment id="6">, sete homens fortemente armados</segment>
    <segment id="7">, a bordo de um Fiat Uno (branco)</segment>
    <segment id="8">, dispararam contra pessoas sentadas a uma mesa da Barraca do Regi</segment>
    <segment id="9">, quando o dono apresentou a conta dos amigos.</segment>
    <segment id="10">Foram atingidos o dono do bar</segment>
    <segment id="11">, Reginaldo Santos da Silva</segment>
    <segment id="12">, 47 anos</segment>
    <segment id="13">, e três clientes: Gilson Alves Conceição</segment>
    <segment id="14">, 47, Vanderlei Alves Santos</segment>
    <segment id="15">, 20, e Israel Sales</segment>
    <segment id="16">, 25 anos.</segment>
    <segment id="17">Ao saber da morte do amigo Regi</segment>
    <segment id="18">, como</segment>
    <segment id="19">como Reginaldo era conhecido</segment>
    <segment id="20">, o comerciante “Larinho” teve um infarto e foi hospitalizado.</segment>
    <segment id="21">“</segment>
    <segment id="22">Agora, quatro famílias de trabalhadores estão de luto”</segment>
    <segment id="23">, lamentou uma prima do comerciante que não quis</segment>
    <segment id="24">sese identificar.</segment>
    <segment id="25">Na manhã de ontem</segment>
    <segment id="26">,  moradores bloquearam a rua</segment>
    <segment id="27">, em frente ao bar</segment>
    <segment id="28">, colocando fogo em pneus e restos de madeira em sinal de protesto.</segment>
    <segment id="29">“Esse crime vai marcar para sempre o bairro”</segment>
    <segment id="30">, lamentou um líder comunitário</segment>
    <segment id="31">, que não quis</segment>
    <segment id="32">sese identificar.</segment>
    <segment id="33">Ele contou que</segment>
    <segment id="34">, na 3ª feira</segment>
    <segment id="35">, os mesmos assassinos atiraram em crianças e mulheres numa praça do bairro.</segment>
    <segment id="36">Ponto de drogas</segment>
    <segment id="37">Segundo o delegado Márcio Allan de Oliveira Assunção</segment>
    <segment id="38">, do Departamento de Homicídios e Proteção à Pessoa (DHPP)</segment>
    <segment id="39">, responsável pelas investigações</segment>
    <segment id="40">, as vítimas não têm passagem pela polícia</segment>
    <segment id="41">, masmas segundo o Serviço de Investigação do Local do Crime (Silc)</segment>
    <segment id="42">, uma delas tem envolvimento com o tráfico de drogas.</segment>
    <segment id="43">A identidade não foi informada.</segment>
    <segment id="44">“</segment>
    <segment id="45">No bar onde ocorreu o crime havia intensa atividade de tráfico”</segment>
    <segment id="46">, destacou Márcio Allan.</segment>
    <segment id="47">Segundo o delegado</segment>
    <segment id="48">, a chacina tem relação com o duplo homicídio</segment>
    <segment id="49">, ocorrido na última quinta-feira em Arenoso.</segment>
    <segment id="50">“Trata-</segment>
    <segment id="51">sese de uma rivalidade entre traficantes dos bairros Tancredo Neves e Arenoso”.</segment>
    <segment id="52">Os suspeitos já foram identificados.</segment>
  </rst>
</analysis>