  <rst>
    <segment id="1">Na bola ou 'na marra'</segment>
    <segment id="2">, Flamengo só tem uma opção: vencer o Bahia
- Uma vitória pode ser imprescindível por causa de uma sequência de maus resultados</segment>
    <segment id="3">RIO  outras vezes</segment>
    <segment id="4">para que</segment>
    <segment id="5">para que um time retome confiança e o futebol perdido</segment>
    <segment id="6">; em outros jogos</segment>
    <segment id="7">porque</segment>
    <segment id="8">porque enfrenta-</segment>
    <segment id="9">sese um adversário mais fraco</segment>
    <segment id="10">, em casa</segment>
    <segment id="11">; ou ainda</segment>
    <segment id="12">porque</segment>
    <segment id="13">porque seus rivais na tabela estão ameaçando</segment>
    <segment id="14">sese distanciar.</segment>
    <segment id="15">Numa questão de múltipla escolha</segment>
    <segment id="16">, o Flamengo marcaria todas as opções acima para explicar sua obrigação de derrotar o Bahia</segment>
    <segment id="17">, neste domindo</segment>
    <segment id="18">, às 16h</segment>
    <segment id="19">, no Engenhão.</segment>
    <segment id="20">Numa rodada em que os adversários da parte de cima da tabela jogam todos fora de casa</segment>
    <segment id="21">, o Flamengo não pode nem pensar em tropeçar mais uma vez</segment>
    <segment id="22">, mesmo desfalcado de seu principal jogador</segment>
    <segment id="23">, Ronaldinho Gaúcho.</segment>
    <segment id="24">Precisando pontuar para</segment>
    <segment id="25">sese manter entre os líderes</segment>
    <segment id="26">, o time busca um resultado positivo que lhe dê tranquilidade para retomar o bom futebol</segment>
    <segment id="27">, no jogo que antecede o esperado clássico contra o líder Corinthians na quinta-feira.</segment>
    <segment id="28">O técnico Vanderlei Luxemburgo fez mistério em relação à escalação.</segment>
    <segment id="29">Jael, Negueba e Diego Maurício disputam a vaga de Ronaldinho.</segment>
    <segment id="30">No meio</segment>
    <segment id="31">, para o lugar do lesionado Luiz Antônio</segment>
    <segment id="32">, Muralha tem mais chances que Bottinelli.</segment>
    <segment id="33">A zaga é outro mistério.</segment>
    <segment id="34">Perseguido por grande parte da torcida</segment>
    <segment id="35">, Welinton cumpriu suspensão contra o Avaí</segment>
    <segment id="36">masmas as falhas defensivas estiveram presentes na Ressacada.</segment>
    <segment id="37">Perguntado sobre a volta do zagueiro à equipe</segment>
    <segment id="38">, Luxemburgo disse apenas que não baseará sua escolha movido à pressão:

- Meu time não é escalado de fora para dentro.</segment>
    <segment id="39">É de dentro para fora.</segment>
    <segment id="40">Cismaram com o Welinton</segment>
    <segment id="41">, ele não pode errar</segment>
    <segment id="42">, masmas eu tenho de ir pelas minhas convicções.</segment>
    <segment id="43">Assim será em relação a todo o time.</segment>
    <segment id="44">Num momento do campeonato em que muitos rubro-negros começam a</segment>
    <segment id="45">sese questionar sobre até onde</segment>
    <segment id="46">, realmente</segment>
    <segment id="47">, este time pode chegar</segment>
    <segment id="48">, o treinador usou uma gíria do futebol para dizer que vê potencial</segment>
    <segment id="49">, fôlego e força no elenco para disputar o título até o fim:

-</segment>
    <segment id="50">A equipe tem caixa para crescer de novo no campeonato.</segment>
    <segment id="51">Esta gangorra é para todos.</segment>
    <segment id="52">E vamos subir outra vez.</segment>
    <segment id="53">Maior representante de fôlego e força no time</segment>
    <segment id="54">, o volante Willians completa hoje 150 jogos pelo clube.

- Quando eu cheguei</segment>
    <segment id="55">, em 2009</segment>
    <segment id="56">, todo mundo pensou que seria apenas mais uma contratação.</segment>
    <segment id="57">Vim buscando meu espaço.</segment>
    <segment id="58">Nunca joguei tantas partidas por um mesmo time.</segment>
    <segment id="59">Acho que a camiseta do Flamengo</segment>
    <segment id="60">sese deu bem comigo e eu com ela - disse Willians.</segment>
    <segment id="61">Adversário desta tarde</segment>
    <segment id="62">, o Bahia demitiu o técnico Renê Simões na última sexta-feira e será dirigido pelo interino Eduardo Barroca.</segment>
    <segment id="63">Flamengo: Felipe</segment>
    <segment id="64">, Leonardo Moura</segment>
    <segment id="65">, Welinton</segment>
    <segment id="66">, Gustavo e Júnior César</segment>
    <segment id="67">; Muralha</segment>
    <segment id="68">, Willians</segment>
    <segment id="69">, Renato e Thiago Neves</segment>
    <segment id="70">; Deivid e Jael (Negueba).</segment>
    <segment id="71">Bahia: Tiago</segment>
    <segment id="72">; Marcos</segment>
    <segment id="73">, Paulo Miranda</segment>
    <segment id="74">, Titi</segment>
    <segment id="75">, Maranhão</segment>
    <segment id="76">; Fahel</segment>
    <segment id="77">, Marcones</segment>
    <segment id="78">, Carlos Alberto</segment>
    <segment id="79">, Ricardinho</segment>
    <segment id="80">; Jones e Souza.</segment>
    <segment id="81">Juiz: Alício Penna Júnior (MG).</segment>
  </rst>
