  <rst>
    <segment id="1">Giovanna Ewbank colocava meias no sutiã
"</segment>
    <segment id="2">Enquanto minhas amigas já tinham peito e bunda</segment>
    <segment id="3">, eu parecia uma tábua”</segment>
    <segment id="4">, disse</segment>
    <segment id="5">A mulher do ator Bruno Gagliasso revelou à revista Caras que</segment>
    <segment id="6">, durante a adolescência</segment>
