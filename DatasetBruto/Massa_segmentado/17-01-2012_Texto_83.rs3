  <rst>
    <segment id="1">Bandidões viram mulherzinha</segment>
    <segment id="2">Homens são flagrados ao tentar fugir do presídio vestidos de mulher</segment>
    <segment id="3">Os presidiários André Rosa da Silva</segment>
    <segment id="4">, 22, condenado por homicídio</segment>
    <segment id="5">, e Valdemir de Jesus</segment>
    <segment id="6">, 25, detido por tráfico</segment>
    <segment id="7">, foram flagrados quando tentavam fugir</segment>
    <segment id="8">, vestidos de mulher</segment>
    <segment id="9">, do Conjunto Penal de Teixeira de Freitas (a 813 km de Salvador).</segment>
    <segment id="10">Era dia de visita normal</segment>
    <segment id="11">, no último domingo</segment>
    <segment id="12">, quando agentes penitenciários acharam estranho as duas ‘mulheres’ desengonçadas</segment>
    <segment id="13">, com as costas muito largas e com andar e jeito de homem</segment>
    <segment id="14">, indo</segment>
    <segment id="15">embora</segment>
    <segment id="16">embora da unidade prisional</segment>
    <segment id="17">, juntamente com os familiares de outros detentos.</segment>
    <segment id="18">Após a fraude ser descoberta</segment>
    <segment id="19">, André e Valdemir ainda deram risada.</segment>
    <segment id="20">Os detentos utilizaram maquiagem e perucas</segment>
    <segment id="21">, para completar o golpe que armaram.</segment>
    <segment id="22">O diretor do presídio</segment>
    <segment id="23">, coronel Bartolomeu Calheiros</segment>
    <segment id="24">, desconfia que os disfarces dos detentos tenham entrado no presídio por cima do muro da área de banho de sol</segment>
    <segment id="25">, que não é protegida por tela.</segment>
    <segment id="26">Segundo o diretor</segment>
    <segment id="27">, cerca de 350 pessoas fizeram visita aos detentos da unidade</segment>
    <segment id="28">, no último domingo.</segment>
    <segment id="29">Devido à tentativa de fuga</segment>
    <segment id="30">, André e Valdemir foram colocados</segment>
    <segment id="31">, ontem</segment>
    <segment id="32">, no isolamento</segment>
    <segment id="33">, como</segment>
    <segment id="34">como pena administrativa.</segment>
    <segment id="35">Queixas do diretor</segment>
    <segment id="36">O diretor do presídio reclama do sistema frágil de vigilância na entrada da unidade.</segment>
    <segment id="37">Segundo ele</segment>
    <segment id="38">,  quatro policiais deveriam fazer a segurança</segment>
    <segment id="39">, masmas apenas dois ficam de vigia.</segment>
    <segment id="40">Por causa da ausência da tela e da vigilância frágil</segment>
    <segment id="41">, são feitas revistas constantes nos presos.</segment>
    <segment id="42">Nessas ações</segment>
    <segment id="43">, sempre são encontradas armas</segment>
    <segment id="44">, drogas</segment>
    <segment id="45">, objetos perfurantes e celulares.</segment>
    <segment id="46">“</segment>
    <segment id="47">Pelos lados do presídio</segment>
    <segment id="48">, sempre fica uma brecha para</segment>
    <segment id="49">sese jogar algo para dentro.</segment>
    <segment id="50">Entra tudo quanto é coisa</segment>
    <segment id="51">, droga</segment>
    <segment id="52">, arma.</segment>
    <segment id="53">Nós trabalhamos com a estrutura que nos dão.</segment>
    <segment id="54">Aqui, temos 670 presos</segment>
    <segment id="55">, para serem vigiados por 12 agentes</segment>
    <segment id="56">, diariamente</segment>
    <segment id="57">, e mais dois policiais militares”</segment>
    <segment id="58">, afirmou.</segment>
    <segment id="59">A capacidade do presídio é para 313 internos.</segment>
  </rst>
</analysis>