  <rst>
    <segment id="1">Mulher pariu em vaso sanitário</segment>
    <segment id="2">Bombeiros levaram cerca de 30 minutos para retirar a latrina do chão e salvar o bebê
Cai Qulin</segment>
    <segment id="3">, de 36 anos</segment>
    <segment id="4">, passou um sufoco no último sábado</segment>
    <segment id="5">, em Pequim</segment>
    <segment id="6">, na China.</segment>
    <segment id="7">Segundo informações do jornal “China Daily”</segment>
    <segment id="8">, a mulher entrou em trabalho de parto enquanto usava um banheiro público e viu seu bebê deslizar pela privada quando</segment>
    <segment id="9">sese agachou para urinar.</segment>
    <segment id="10">A chinesa</segment>
    <segment id="11">, que teve a filha nove dias antes do programado</segment>
    <segment id="12">, disse que precisava usar o banheiro com urgência antes de ir ao hospital.</segment>
    <segment id="13">Quando a criança despencou</segment>
    <segment id="14">, o marido de Cai</segment>
    <segment id="15">, Zhang Tao</segment>
    <segment id="16">, fez o certo e chamou o serviço de emergência.</segment>
    <segment id="17">Desmontar um dos banheiros e retirar a bacia turca (privada) do chão foi o primeiro passo dos bombeiros.</segment>
    <segment id="18">Em seguida</segment>
    <segment id="19">, eles resgataram o bebê.</segment>
    <segment id="20">O salvamento não foi fácil</segment>
    <segment id="21">, pois</segment>
    <segment id="22">pois demorou cerca de 30 minutos para ser concluído.</segment>
    <segment id="23">Apesar de todo o susto</segment>
    <segment id="24">, a menina</segment>
    <segment id="25">, que foi levada para o Hospital da Universidade de Tsinghua</segment>
    <segment id="26">, recupera-</segment>
    <segment id="27">sese bem.</segment>
    <segment id="28">Já a mãe Cai recebeu alta hospitalar no mesmo dia e espera pela filha em casa.</segment>
  </rst>
</analysis>