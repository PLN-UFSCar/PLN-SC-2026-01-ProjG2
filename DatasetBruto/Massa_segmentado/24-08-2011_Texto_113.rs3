  <rst>
    <segment id="1">E agora</segment>
    <segment id="2">, pai?</segment>
    <segment id="3">Bebeto vira “zagueiro” para vigiar a filha gata</segment>
    <segment id="4">Acostumado a infernizar a vida dos zagueiros adversários na época de jogador</segment>
    <segment id="5">, o tetracampeão Bebeto Gama agora vive situação diferente.</segment>
    <segment id="6">Pai da modelo Stephanie Oliveira</segment>
    <segment id="7">, 20 anos</segment>
    <segment id="8">, o baiano craque de bola faz marcação cerrada para a filha não sair debaixo de sua asa.</segment>
    <segment id="9">A tarefa é complicada e já faz sete anos que ele leva dribles desconcertantes de sua pequena.</segment>
    <segment id="10">Desde os 13</segment>
    <segment id="11">, Stephanie vive nas passarelas e</segment>
    <segment id="12">, para desespero de Bebeto</segment>
    <segment id="13">, já morou em outros países</segment>
    <segment id="14">comocomo Itália</segment>
    <segment id="15">, China e Estados Unidos.</segment>
    <segment id="16">"</segment>
    <segment id="17">Ele não gosta que eu viaje.</segment>
    <segment id="18">Prefere sempre que fique mais perto dele"</segment>
    <segment id="19">, revelou a garota em entrevista ao "Loucos por Futebol"</segment>
    <segment id="20">, da Rádio Bandeirantes.</segment>
    <segment id="21">Apesar do ciúme</segment>
    <segment id="22">, Bebeto apoia a carreira da filha e</segment>
    <segment id="23">sese orgulha em vê-la nas capas de revistas.</segment>
    <segment id="24">Mas para brilhar nas passarelas do Brasil e do exterior</segment>
    <segment id="25">, contou com a genética da mãe Denise</segment>
    <segment id="26">, que é ex-jogadora de vôlei.</segment>
    <segment id="27">“Tenho 1</segment>
    <segment id="28">,81 m e 54 kg.</segment>
    <segment id="29">Não sou esquelética.</segment>
    <segment id="30">Sou magra”</segment>
    <segment id="31">, informa.</segment>
    <segment id="32">A mãe influenciou também a menina a praticar vôlei.</segment>
    <segment id="33">Mas é o esporte do pai que ela gosta de jogar nas horas vagas.</segment>
    <segment id="34">“Gosto bastante de futebol.</segment>
    <segment id="35">Lá em casa todo mundo é atleta</segment>
    <segment id="36">, temos uma quadra de futebol.</segment>
    <segment id="37">Sempre joguei</segment>
    <segment id="38">, sou flamenguista doente.</segment>
    <segment id="39">Era até uma boa zagueira.</segment>
    <segment id="40">Mas só para brincar”</segment>
    <segment id="41">, falou.</segment>
    <segment id="42">Neste ano</segment>
    <segment id="43">, Stephanie mudou-</segment>
    <segment id="44">sese para São Paulo e agora tentará</segment>
    <segment id="45">sese tornar atriz.</segment>
    <segment id="46">Está na escola de teatro.</segment>
    <segment id="47">“</segment>
    <segment id="48">Meu pai ficou meio assim de vir morar aqui [a família é de Salvador]</segment>
    <segment id="49">, masmas sei que sempre posso contar com ele.</segment>
    <segment id="50">”</segment>
  </rst>
</analysis>