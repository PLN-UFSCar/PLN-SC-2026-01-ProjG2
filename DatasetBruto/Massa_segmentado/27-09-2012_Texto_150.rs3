  <rst>
    <segment id="1">Bancos pГѓВєblicos mantГѓВЄm greve</segment>
    <segment id="2">Para avaliar o 10Г‚Вє dia de greve nos bancos oficiais</segment>
    <segment id="3">, os bancГѓВЎrios farГѓВЈo assembleia</segment>
    <segment id="4">Em assembleia realizada  ontem ГѓВ  noite no GinГѓВЎsio de Esportes da Ladeira dos Aflitos</segment>
    <segment id="5">, os bancГѓВЎrios decidiram pelo fim da greve nas unidades privadas.</segment>
    <segment id="6">A decisГѓВЈo saiu depois de 9 dias de paralisaГѓВ§ГѓВµes na Bahia.</segment>
    <segment id="7">Na mesma convocaГѓВ§ГѓВЈo</segment>
    <segment id="8">, foi definida a continuidade do movimento nas unidade pГѓВєblicas</segment>
    <segment id="9">, Banco do Brasil</segment>
    <segment id="10">, Caixa EconГѓВґmica Federal e Banco do Nordeste.</segment>
    <segment id="11">Гўв‚¬Е“Isto devido as grandes perdas ao longo dos anosГўв‚¬</segment>
    <segment id="12">, analisa o presidente do Sindicato dos BancГѓВЎrios</segment>
    <segment id="13">, Euclides Fagundes.</segment>
    <segment id="14">Durante convocaГѓВ§ГѓВЈo</segment>
    <segment id="15">, o sindicato</segment>
    <segment id="16">sese manifestou favorГѓВЎvel ao fim da greve.</segment>
    <segment id="17">Гўв‚¬Е“Decidimos por acompanhar o movimento nacional.</segment>
    <segment id="18">NГѓВЈo faz sentido continuarmos</segment>
    <segment id="19">sozinhosГўв‚¬</segment>
    <segment id="20">, diz Euclides.</segment>
    <segment id="21">Nova assembleia acontece hoje</segment>
    <segment id="22">, no GinГѓВЎsio de Esporte</segment>
    <segment id="23">, ГѓВ s 6h30 da tarde.</segment>
    <segment id="24">Proposta</segment>
    <segment id="25">A FederaГѓВ§ГѓВЈo Nacional de Bancos (Fenaban) elevou a 7</segment>
    <segment id="26">,5% a proposta de reajuste dos salГѓВЎrios dos trabalhadores</segment>
    <segment id="27">, um aumento real de 2</segment>
    <segment id="28">,02%.</segment>
    <segment id="29">O piso da categoria que era R$ 1.405 passa a ser R$ 1.519.</segment>
    <segment id="30">A oferta tambГѓВ©m prevГѓВЄ aumento de 8</segment>
    <segment id="31">,5% no valor dos auxГѓВ­lios-refeiГѓВ§ГѓВЈo e alimentaГѓВ§ГѓВЈo (que passa a ser 472</segment>
    <segment id="32">,15); alГѓВ©m de contabilizar uma alta de 10% na parcela fixa da ParticipaГѓВ§ГѓВЈo nos Lucros e Resultados (PLR).</segment>
