  <rst>
    <segment id="1">Conheça o destino dos mineiros resgatados no Chile
RIO - Um ano depois</segment>
    <segment id="2">, mineiros chilenos que passaram 69 dias soterrados sofrem com desemprego e problemas de saúde</segment>
    <segment id="3">Conheça a seguir o destino de alguns deles:

Mário Sepúlveda:</segment>
    <segment id="4">Era o porta-voz do grupo durante o confinamento e foi o grande destaque do resgate.</segment>
    <segment id="5">Segundo a chegar à superfície</segment>
    <segment id="6">, puxou o famoso coro: "</segment>
    <segment id="7">Chi, chi</segment>
    <segment id="8">, chi!</segment>
    <segment id="9">Le, le</segment>
    <segment id="10">, le!</segment>
    <segment id="11">"</segment>
    <segment id="12">e distribuiu pedras do interior da mina</segment>
    <segment id="13">, abraçando o presidente Sebastian Piñera.</segment>
    <segment id="14">É o mais bem-sucedido dos 33: ganha a vida participando de eventos e dando palestras motivacionais</segment>
    <segment id="15">, tem inclusive agente no exterior</segment>
    <segment id="16">, e vai abrir um centro recreativo nos arredores de Santiago.</segment>
    <segment id="17">Jorge Galleguillos:</segment>
    <segment id="18">Ficou conhecido por</segment>
    <segment id="19">, num dos vídeos que os mineiros enviaram do confinamento</segment>
    <segment id="20">, cantar e dançar de cueca.</segment>
    <segment id="21">Superou uma forte depressão pós-confinamento e hoje dá palestras motivacionais</segment>
    <segment id="22">, inclusive nos EUA.</segment>
    <segment id="23">Carlos Mamani: Único estrangeiro do grupo</segment>
    <segment id="24">, o boliviano recusou uma oferta de trabalho em seu país e resolveu permanecer no Chile.</segment>
    <segment id="25">Está desempregado.

Omar Reygadas: Eletricista</segment>
    <segment id="26">, foi resgatado enrolado numa bandeira do Colo-Colo.</segment>
    <segment id="27">Vive de aparições na TV e palestras no Chile.</segment>
    <segment id="28">Chegou</segment>
    <segment id="29">, durante meses</segment>
    <segment id="30">, a administrar o recebimento de presentes e convites para eventos feitos aos mineiros - hoje cada vez mais escassos</segment>
    <segment id="31">, segundo ele.</segment>
    <segment id="32">Dario Segovia:</segment>
    <segment id="33">Aproveitou o dinheiro que recebeu do minerador Leonardo Farkas e comprou uma caminhonete</segment>
    <segment id="34">, com a ajuda da qual vende frutas e legumes em Copiapó.</segment>
    <segment id="35">Osman Araya</segment>
    <segment id="36">, outro mineiro</segment>
    <segment id="37">, trabalha com ele.</segment>
    <segment id="38">Florencio Ávalos:</segment>
    <segment id="39">Autor de boa parte dos vídeos gravados dentro da mina</segment>
    <segment id="40">, protagonizou uma das cenas mais emocionantes ao ser abraçado por seu filho aos prantos logo que saiu da cápsula.</segment>
    <segment id="41">Voltou a trabalhar</segment>
    <segment id="42">comocomo mineiro.

José Ojeda:</segment>
    <segment id="43">O autor da famosa mensagem "Estamos bem no refúgio</segment>
    <segment id="44">os 33" está de licença médica e é considerado o mais afetado psicologicamente do grupo</segment>
    <segment id="45">, tomando seis doses diárias de medicamentos.

Luis Urzúa:</segment>
    <segment id="46">Era o chefe do turno no momento do acidente e foi um dos líderes do grupo.</segment>
    <segment id="47">Dá palestras e organizou as comemorações do primeiro aniversário da tragédia

Edison Pena:</segment>
    <segment id="48">Corria durante o confinamento.</segment>
    <segment id="49">Desde então</segment>
    <segment id="50">, participou da maratona de Nova York e visitou o túmulo de seu ídolo</segment>
    <segment id="51">, Elvis Presley</segment>
    <segment id="52">, nos EUA.</segment>
    <segment id="53">Está desempregado.</segment>
    <segment id="54">"</segment>
    <segment id="55">Nossa vida está tão escura quanto na época da mina"</segment>
    <segment id="56">, disse sua mulher

Jimmy Sánchez:</segment>
    <segment id="57">É o mais jovem do grupo</segment>
    <segment id="58">, está com 20 anos e de licença médica.</segment>
    <segment id="59">Reconhece que nunca superou emocionalmente a tragédia.</segment>
    <segment id="60">"</segment>
    <segment id="61">Estou louco"</segment>
    <segment id="62">, declarou esta semana</segment>
    <segment id="63">, relatando que tem medo do escuro e da noite

Franklin Lobos:</segment>
    <segment id="64">Ex-jogador de futebol</segment>
    <segment id="65">, hoje treina divisões de base do time de futebol de Copiapó

Víctor Segovia:</segment>
    <segment id="66">Voltou à mineração e está prestes a publicar um livro com as notas que escrevia durante o confinamento</segment>
  </rst>
</analysis>