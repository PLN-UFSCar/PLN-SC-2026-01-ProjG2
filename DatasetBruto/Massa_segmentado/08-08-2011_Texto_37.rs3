  <rst>
    <segment id="1">PMs que atropelaram criança têm alta</segment>
    <segment id="2">Policiais envolvidos em acidente em Boa Vista de São Caetano não serão afastados</segment>
    <segment id="3">Os três policiais militares da 9ª CIPM/ Pirajá envolvidos no acidente de vitimou Vanessa dos Santos Cardoso Lima</segment>
    <segment id="4">, 5 anos</segment>
    <segment id="5">, já receberam alta médica na manhã desta segunda-feira.</segment>
    <segment id="6">Os policiais foram encaminhados – após o acidente que deixou a mãe da menina</segment>
    <segment id="7">,  Laildes dos Santos Lima</segment>
    <segment id="8">, 34, também ferida – para o Hospital Agenor Paiva "por estarem fortemente abalados com o acidente"</segment>
    <segment id="9">, segundo nota divulgada pela Secretaria de Segurança Pública (SSP-BA).</segment>
    <segment id="10">Após a alta médica</segment>
    <segment id="11">, os policiais</segment>
    <segment id="12">, que não tiveram os nomes informados</segment>
    <segment id="13">, serão ouvidos pela Corregedoria da Polícia Militar e também pelo delegado da 4ª CP (São Caetano).</segment>
    <segment id="14">A data dos depoimentos não foi informada.</segment>
    <segment id="15">Segundo o sargento Gutemberg</segment>
    <segment id="16">, do Departamento de Comunicação Social da Polícia Militar</segment>
    <segment id="17">, "não há nenhuma orientação para o afastamento dos policiais das suas funções</segment>
    <segment id="18">, uma vez que o acidente</segment>
    <segment id="19">, apesar de ter tido vítimas</segment>
    <segment id="20">, não se</segment>
    <segment id="21">se caracteriza</segment>
    <segment id="22">comocomo homicídio doloso (quando a intenção de matar).</segment>
    <segment id="23">E que entendemos é que houve um acidente de trânsito ".</segment>
    <segment id="24">O sargento afirma</segment>
    <segment id="25">, ainda</segment>
    <segment id="26">, que provavelmente os policiais não retornem para as funções anteriores e que sejam locados na área administrativa da PM.</segment>
    <segment id="27">"</segment>
    <segment id="28">De fato só emitiremos nota informando sobre a recolocação os três policiais quando a PM emitir um parecer oficial sobre essa posição"</segment>
    <segment id="29">, afirma Gutemberg.</segment>
  </rst>
</analysis>