  <rst>
    <segment id="1">Secretário volta a defender uso de pré-moldados para UPAs
RIO - O secretário estadual de Saúde</segment>
    <segment id="2">, Sérgio Côrtes</segment>
    <segment id="3">, voltou a defender no domingo o uso dos módulos pré-moldados de aço em vez de obras de alvenaria para erguer as Unidades de Pronto Atendimento (UPAs).</segment>
    <segment id="4">Segundo ele</segment>
    <segment id="5">, a agilidade na construção justificaria a escolha.</segment>
    <segment id="6">Com as estruturas de metal</segment>
    <segment id="7">, afirmou</segment>
    <segment id="8">, é possível erguer uma unidade em 90 dias.</segment>
    <segment id="9">Se a opção fosse por alvenaria</segment>
    <segment id="10">, de acordo com Côrtes</segment>
    <segment id="11">, seria preciso mais tempo.
- Não sou técnico</segment>
    <segment id="12">, masmas não</segment>
    <segment id="13">sese construiria uma UPA em três meses</segment>
    <segment id="14">sese fosse de alvenaria.</segment>
    <segment id="15">Temos exemplos disso nos hospitais que erguemos.</segment>
    <segment id="16">Tanto que o modelo está sendo copiado não só no Brasil</segment>
    <segment id="17">, como</segment>
    <segment id="18">como no exterior - afirmou ele</segment>
    <segment id="19">, embora</segment>
    <segment id="20">embora o Crea-RJ tenha dito</segment>
    <segment id="21">, anteontem</segment>
    <segment id="22">, que o prazo para erguer um prédio de alvenaria nos moldes da UPA também seria de três meses.

Sérgio Côrtes: faltam pediatras nas UPAs</segment>
    <segment id="23">O secretário</segment>
    <segment id="24">, porém</segment>
    <segment id="25">porém, admitiu que algumas UPAs apresentam problemas:

- Esses problemas dizem respeito</segment>
    <segment id="26">, sobretudo</segment>
    <segment id="27">, aos nossos recursos humanos.</segment>
    <segment id="28">Faltam principalmente pediatras</segment>
    <segment id="29">, o que é uma carência em todo o país.</segment>
    <segment id="30">Como mostrou O GLOBO no sábado</segment>
    <segment id="31">, a construção das UPAs com módulos de aço fica</segment>
    <segment id="32">, em média</segment>
    <segment id="33">, 25% mais cara que a de um hospital de alvenaria.</segment>
    <segment id="34">Com base em dados da prefeitura e do estado</segment>
    <segment id="35">, a reportagem revelou que os módulos saem a R$ 2.385 o metro quadrado.</segment>
    <segment id="36">Já em São Carlos (SP)</segment>
    <segment id="37">, a prefeitura está construindo o Hospital Escola Municipal</segment>
    <segment id="38">, de alvenaria</segment>
    <segment id="39">, por R$ 1.900 o metro quadrado.</segment>
    <segment id="40">A reportagem mostrou ainda que o metro quadrado das Clínicas da Família</segment>
    <segment id="41">, da prefeitura do Rio</segment>
    <segment id="42">, feitas em parte com módulos metálicos</segment>
    <segment id="43">, custa ainda mais caro: R$ 3 mil.</segment>
  </rst>
