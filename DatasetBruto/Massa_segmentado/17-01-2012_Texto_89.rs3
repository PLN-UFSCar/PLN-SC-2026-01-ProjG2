  <rst>
    <segment id="1">Matrícula na rede estadual
Começa nesta quarta.</segment>
    <segment id="2">Pela primeira vez</segment>
    <segment id="3">, o cadastro pode ser pela internet</segment>
    <segment id="4">Começa nesta quarta-feira (18) a matrícula nas escolas estaduais.</segment>
    <segment id="5">Pela primeira vez</segment>
    <segment id="6">, o cadastro pode ser pela internet no site da Secretaria de Educação do Estado (http://educar.sec.ba.gov.br/matricula2012/).</segment>
    <segment id="7">Essa opção só está disponível para quem era aluno da rede municipal de Salvador ou já estuda nos colégios estaduais e quer trocar de instituição.</segment>
    <segment id="8">Também é possível</segment>
    <segment id="9">sese matricular em qualquer unidade da rede estadual</segment>
    <segment id="10">, da 8 às 20 horas.</segment>
    <segment id="11">O procedimento pode ser feito até 27 de janeiro.</segment>
  </rst>
