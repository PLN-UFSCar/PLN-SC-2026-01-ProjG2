  <rst>
    <segment id="1">Ódio e mortes no pagodão do Bar do Amor</segment>
    <segment id="2">Dois homens são assassinados e três ficam feridos</segment>
    <segment id="3">, na Boca do Rio</segment>
    <segment id="4">O som dos tiros silenciou o pagode que ocorria na Rua José Felipe Venique</segment>
    <segment id="5">, no bairro</segment>
    <segment id="6">Boca do Rio</segment>
    <segment id="7">, na noite do último domingo.</segment>
    <segment id="8">A festa foi organizada pela mulher que comanda o Bar e Lanchonete do Amor.</segment>
    <segment id="9">Duas pessoas foram executadas e outras três</segment>
    <segment id="10">, feridas.</segment>
    <segment id="11">Edgar Oliveira da Silva</segment>
    <segment id="12">, 27 anos</segment>
    <segment id="13">, morreu com 13 tiros.</segment>
    <segment id="14">A outra vítima</segment>
    <segment id="15">, ainda sem identificação</segment>
    <segment id="16">, foi assassinada com 11 disparos.</segment>
    <segment id="17">Segundo a polícia</segment>
    <segment id="18">, os dois mortos  frequentavam o pagode</segment>
    <segment id="19">, masmas moravam no Nordeste de Amaralina.</segment>
    <segment id="20">Três homens realizaram os disparos.</segment>
    <segment id="21">De acordo com o delegado do Departamento de Homicídios</segment>
    <segment id="22">, Jesus Pablo Barbosa</segment>
    <segment id="23">,  há três suspeitos para o crime.</segment>
    <segment id="24">“</segment>
    <segment id="25">Os assassinos são  traficantes</segment>
    <segment id="26">, masmas ainda não dá para dizer</segment>
    <segment id="27">sese a motivação  tem relação com o tráfico”</segment>
    <segment id="28">, explica.</segment>
    <segment id="29">Segundo o mecânico Moisés Santos</segment>
    <segment id="30">, os assassinos chegaram a pé.</segment>
    <segment id="31">“Muita gente estava na rua.</segment>
    <segment id="32">Foram quase 40 tiros”</segment>
    <segment id="33">, lembra.</segment>
    <segment id="34">Rosinei Bernardo</segment>
    <segment id="35">, 37, Emanoel Barbosa dos Santos</segment>
    <segment id="36">, 24, e L.S.S</segment>
    <segment id="37">, 17, ficaram feridos.</segment>
    <segment id="38">Dona do comércio silencia</segment>
    <segment id="39">;</segment>
    <segment id="40">Moradores reclamam</segment>
    <segment id="41">Os moradores da Rua José Felipe Venique  contam que</segment>
    <segment id="42">, desde setembro do ano passado</segment>
    <segment id="43">, a cada 15 dias</segment>
    <segment id="44">, a locatária do Bar e Lanchonete do Amor organiza o pagode em plena rua.</segment>
    <segment id="45">A comerciante</segment>
    <segment id="46">, de prenome Daiane</segment>
    <segment id="47">,  não quis falar sobre o episódio.</segment>
    <segment id="48">“</segment>
    <segment id="49">A rua é tranquila.</segment>
    <segment id="50">Mas, quando tem esse pagode</segment>
    <segment id="51">, sempre acontece confusão.</segment>
    <segment id="52">É a primeira vez que tem morte”</segment>
    <segment id="53">, conta uma aposentada que</segment>
    <segment id="54">sese identificou apenas</segment>
    <segment id="55">comocomo Lurdes.</segment>
    <segment id="56">Outro morador</segment>
    <segment id="57">, que preferiu não</segment>
    <segment id="58">sese identificar</segment>
    <segment id="59">, reclama dos transtornos.</segment>
    <segment id="60">“</segment>
    <segment id="61">O pagode começa às 18 h e só termina à meia-noite.</segment>
    <segment id="62">Os moradores nem frequentam a festa</segment>
    <segment id="63">porque</segment>
    <segment id="64">porque aparece muito vagabundo.</segment>
    <segment id="65">Depois disso</segment>
    <segment id="66">, acredito que a bagunça deve acabar”</segment>
    <segment id="67">, declara.</segment>
  </rst>
</analysis>