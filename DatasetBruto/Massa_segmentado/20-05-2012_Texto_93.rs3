  <rst>
    <segment id="1">Internacional e Atlético-MG estreiam com vitória
RIO - O Internacional começou sem problemas no Campeonato Brasileiro.</segment>
    <segment id="2">O colorado não tomou conhecimento do Coritiba</segment>
    <segment id="3">, vencendo por 2 a 0</segment>
    <segment id="4">, neste domingo</segment>
    <segment id="5">, no Beira-Rio</segment>
    <segment id="6">, diante de 22 mil pessoas.</segment>
    <segment id="7">Sem correr muitos riscos</segment>
    <segment id="8">, o Inter começou a construir sua fácil vitória aos 9 minutos.</segment>
    <segment id="9">Oscar tocou para Damião</segment>
    <segment id="10">, que mostrou sua qualidade do goleador ao dar o drible da vaca num adversário e chutar forte</segment>
    <segment id="11">, no ângulo esquerdo do goleiro Vanderlei</segment>
    <segment id="12">, que nada pôde fazer.</segment>
    <segment id="13">O segundo gol do time gaúcho também foi feito no primeiro tempo e foi outra pintura.</segment>
    <segment id="14">O argentino Dátolo tabelou com Dagoberto</segment>
    <segment id="15">, que tocou para Damião e recebeu de volta</segment>
    <segment id="16">, na medida para o chute forte</segment>
    <segment id="17">, de direita</segment>
    <segment id="18">, rasteiro</segment>
    <segment id="19">, novamente sem chance de defesa para Vanderlei</segment>
    <segment id="20">, que reclamou da desatenção de sua zaga.</segment>
    <segment id="21">No segundo tempo</segment>
    <segment id="22">, administrando com tranquilidade a vantagem</segment>
    <segment id="23">, o Inter controlou as ações e ainda mandou uma bola no travessão</segment>
    <segment id="24">, num chute forte de Damião</segment>
    <segment id="25">, aos 39.</segment>
    <segment id="26">Em Campinas</segment>
    <segment id="27">, o Atlético-MG conseguiu uma vitória de 1 a 0</segment>
    <segment id="28">, quando o 0 a 0 já era considerado o resultado normal.</segment>
    <segment id="29">O time mineiro obteve seu gol aos 45 minutos do segundo tempo</segment>
    <segment id="30">, numa cabeçada de Escudero.</segment>
    <segment id="31">Além da estreia com vitória</segment>
    <segment id="32">, o Atlético-MG quebrou uma escrita no estádio Moisés Lucarelli: em nove jogos</segment>
    <segment id="33">, tinha empatado seis e perdido três.</segment>
    <segment id="34">Apesar da expectativa da torcida da Ponte Preta</segment>
    <segment id="35">, que esperava desde 2006 o retorno do time à elite do futebol brasileiro</segment>
    <segment id="36">, apenas 4.911 torcedores (renda de R$ 84.968</segment>
    <segment id="37">,00) foram ao estádio.</segment>
    <segment id="38">Empates decepcionantes</segment>
    <segment id="39">No Parque do Sabiá</segment>
    <segment id="40">, em Uberlândia</segment>
    <segment id="41">, o Cruzeiro irritou sua torcida.</segment>
    <segment id="42">Dominado</segment>
    <segment id="43">, não foi além de um empate em 0 a 0 com o Atlético-GO</segment>
    <segment id="44">, que criou chances e por pouco não deixou Minas com a vitória.</segment>
    <segment id="45">Principalmente no primeiro tempo</segment>
    <segment id="46">, o Cruzeiro contou com o goleiro Fábio</segment>
    <segment id="47">, que salvou o time em vários lances.</segment>
    <segment id="48">E também com a má pontaria dos atacantes rivais</segment>
    <segment id="49">, como</segment>
    <segment id="50">como Bida</segment>
    <segment id="51">, que perdeu um gol feito logo no começo do jogo</segment>
    <segment id="52">, mandando a bola para fora com o gol aberto à sua frente.</segment>
    <segment id="53">Em Salvador</segment>
    <segment id="54">, no Estádio Pituaçu</segment>
    <segment id="55">, debaixo de chuva</segment>
    <segment id="56">, Bahia e Santos também ficaram no 0 a 0.</segment>
    <segment id="57">O time baiano dominou</segment>
    <segment id="58">masmas não conseguiu superar o time reserva do Santos.</segment>
  </rst>
</analysis>