  <rst>
    <segment id="1">Mochila com granada é encontrada nas imediações da Escola Americana</segment>
    <segment id="2">, na Gávea
RIO - Após receberem denúncias com informações sobre uma mochila abandonada</segment>
    <segment id="3">, contendo material do tráfico da Rocinha</segment>
    <segment id="4">, policiais da delegacia do Tanque (41ªDP)</segment>
    <segment id="5">, realizaram diligências próximo a Escola Americana</segment>
    <segment id="6">, na Estrada da Gávea.</segment>
    <segment id="7">Quando chegaram ao local</segment>
    <segment id="8">, os policiais encontraram na mochila uma granada</segment>
    <segment id="9">, uma bóia de sinalização pertencente as Forças Armadas</segment>
    <segment id="10">, uma boia no Exército</segment>
    <segment id="11">, um carregador para rádio de comunicação</segment>
    <segment id="12">, um saco contendo fogos e rojões</segment>
    <segment id="13">, que poderiam ser usados para fabricar bombas caseiras e um coldre.</segment>
    <segment id="14">O material foi encaminhado à 15ªDP (Gávea).</segment>
  </rst>
