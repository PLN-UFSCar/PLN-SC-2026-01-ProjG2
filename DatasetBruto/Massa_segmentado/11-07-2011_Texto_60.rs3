  <rst>
    <segment id="1">Quissamã: Cana</segment>
    <segment id="2">, petróleo e futebol
QUISSAMÃ</segment>
    <segment id="3">, RJ - Descendente de escravos</segment>
    <segment id="4">, Pé Inchado ganhou o apelido nas jornadas de trabalho nos canaviais que perdem espaço na economia local.</segment>
    <segment id="5">Ele é um dos moradores da senzala da Machadinha</segment>
    <segment id="6">, antiga fazenda de cana-de-açúcar do século XIX</segment>
    <segment id="7">, recuperada pela Prefeitura e que ganhou um centro cultural.</segment>
    <segment id="8">O campo local</segment>
    <segment id="9">, entre a igreja e a Casa Grande</segment>
    <segment id="10">, é também usado para os treinamentos do Quissamã Futebol Clube.</segment>
    <segment id="11">O Quissamã é terceiro colocado da Série B (a Segundona) do Campeonato Carioca</segment>
    <segment id="12">, com 34 pontos</segment>
    <segment id="13">, logo atrás do líder Bonsucesso (36) e do Friburguense (35).</segment>
    <segment id="14">A cinco jogos do fim</segment>
    <segment id="15">, com 12 clubes na disputa em partidas de ida e volta</segment>
    <segment id="16">, o time do Norte Fluminense perdeu os dois últimos jogos e deixou escapar a liderança.</segment>
    <segment id="17">Mas os torcedores de Quissamã ainda acreditam que o Azulão</segment>
    <segment id="18">, apelido do time que leva o nome do município</segment>
    <segment id="19">, vai fazer história e será um dos dois que subirão para a Primeira Divisão do futebol carioca em 2012.

- Se Deus quiser e do jeito que está jogando</segment>
    <segment id="20">, vai mesmo.</segment>
    <segment id="21">Na comemoração</segment>
    <segment id="22">, vai ter que ter churrasco com bezerro inteiro</segment>
    <segment id="23">, não quero nem saber - garante Valdecir dos Santos</segment>
    <segment id="24">, conhecido</segment>
    <segment id="25">comocomo Cici ou Pé Inchado.</segment>
    <segment id="26">- Contra o Botafogo</segment>
    <segment id="27">, Fluminense</segment>
    <segment id="28">, Vasco e Flamengo</segment>
    <segment id="29">, vai ser enjoado.</segment>
    <segment id="30">Mas eles não conhecem o Quissamã e aí é que é melhor.</segment>
    <segment id="31">Com uma população de 20.244 habitantes</segment>
    <segment id="32">, pouco maior do que a capacidade atual de São Januário</segment>
    <segment id="33">, Quissamã</segment>
    <segment id="34">sese une no sonho de chegar à Primeira Divisão.</segment>
    <segment id="35">O sucesso vem a reboque dos royalties do petróleo</segment>
    <segment id="36">, que fizeram do município o quarto maior Produto Interno Bruto per Capita do país</segment>
    <segment id="37">, na última pesquisa do IBGE</segment>
    <segment id="38">, de 2008.</segment>
    <segment id="39">Fundado em 1919</segment>
    <segment id="40">, o Quissamã disputava apenas torneios regionais de Macaé - cidade da qual Quissamã era distrito até</segment>
    <segment id="41">sese emancipar em 1989 - e Campos.</segment>
    <segment id="42">Em 2006</segment>
    <segment id="43">, a prefeitura abraçou o clube</segment>
    <segment id="44">, que se</segment>
    <segment id="45">se tornou profissional</segment>
    <segment id="46">, vencendo a Terceira Divisão em 2008.</segment>
    <segment id="47">Desde então</segment>
    <segment id="48">, persegue o sonho de enfrentar os grandes.

- Sonhamos com a Primeira Divisão.</segment>
    <segment id="49">Temos tudo para crescer: torcida</segment>
    <segment id="50">, técnico de fora e apoio da Prefeitura.</segment>
    <segment id="51">E temos o exemplo da derrota do ano passado - conta José Cláudio Marinho</segment>
    <segment id="52">, o Dinho</segment>
    <segment id="53">, ex-presidente do clube na fase amadora</segment>
    <segment id="54">, revelando o trauma de 2010</segment>
    <segment id="55">, quando o time chegou em terceiro na Série B</segment>
    <segment id="56">, a quatro pontos do segundo colocado</segment>
    <segment id="57">, o Nova Iguaçu</segment>
    <segment id="58">, que subiu junto com a Cabofriense.</segment>
    <segment id="59">Para subir</segment>
    <segment id="60">, o prefeito Armando Carneiro da Silva não esconde a relação entre o governo municipal e o time de futebol.</segment>
    <segment id="61">Na oração do time antes de pisar no gramado do Estádio Antônio Carneiro da Silva contra o Friburguense</segment>
    <segment id="62">, na última quarta</segment>
    <segment id="63">, o prefeito pediu a palavra.</segment>
    <segment id="64">Ele explicou que</segment>
    <segment id="65">, na véspera</segment>
    <segment id="66">, tivera uma reunião com Rubens Lopes</segment>
    <segment id="67">, presidente da Federação do Rio</segment>
    <segment id="68">, que garantiu não haver má vontade com o pequeno clube do Norte Fluminense.</segment>
    <segment id="69">A semelhança entre o nome do prefeito e o do estádio não é mera coincidência.</segment>
    <segment id="70">Armando é de família tradicional da região.</segment>
    <segment id="71">A família</segment>
    <segment id="72">Carneiro da Silva tem grande influência política.</segment>
    <segment id="73">Octávio Carneiro da Silva</segment>
    <segment id="74">, antigo prefeito</segment>
    <segment id="75">, é o padrinho político que</segment>
    <segment id="76">sese tornou desafeto do atual.

Investimentos: R$ 850 mil

Apelidado de Carneirão</segment>
    <segment id="77">, o estádio tem dimensões acanhadas.</segment>
    <segment id="78">Em seu único bloco de arquibancada</segment>
    <segment id="79">, cabem entre 1.500 e 2 mil pessoas</segment>
    <segment id="80">, masmas os Bombeiros limitam a capacidade em 370 torcedores.</segment>
    <segment id="81">Contra o Friburguense</segment>
    <segment id="82">, a súmula registrou que todos os 350 ingressos postos à venda esgotaram.</segment>
    <segment id="83">Além do carro de som que convoca a torcida</segment>
    <segment id="84">, 100 camisas do Quissamã foram distribuídas para quem comprasse entrada.</segment>
    <segment id="85">Os jogos invariavelmente são deficitários.</segment>
    <segment id="86">Desde sua profissionalização</segment>
    <segment id="87">, em 2006</segment>
    <segment id="88">, o clube sobrevive com o dinheiro que jorra dos royalties.</segment>
    <segment id="89">Em 2011</segment>
    <segment id="90">, a participação do petróleo na economia da cidade é até agora de R$ 42 milhões</segment>
    <segment id="91">, inferior aos R$ 146 milhões de 2008.</segment>
    <segment id="92">É desse dinheiro que saem os R$ 815 mil que garantem a temporada do Quissamã.</segment>
    <segment id="93">O clube não tem outro patrocínio</segment>
    <segment id="94">, masmas o prefeito garante que empresários ajudarão a pagar um significativo prêmio pela promoção à Série A.

-</segment>
    <segment id="95">O futebol é a paixão nacional.</segment>
    <segment id="96">E de Quissamã também - afirma o prefeito.</segment>
    <segment id="97">- O município não tem grandes despesas do futebol.</segment>
    <segment id="98">Já teve participação maior</segment>
    <segment id="99">, masmas hoje é completamente absorvível pelo município.</segment>
    <segment id="100">A chegada à Primeira Divisão provocará um confronto de paixões.</segment>
    <segment id="101">O prefeito é rubro-negro</segment>
    <segment id="102">, o diretor de futebol é vascaíno</segment>
    <segment id="103">, o roupeiro é botafoguense e o dono do bar vizinho ao estádio é tricolor.

- Sou flamenguista</segment>
    <segment id="104">, masmas agora sou torcedor do Quissamã de "corazón" - afirma o aposentado Juan Alvarez Martins</segment>
    <segment id="105">, espanhol que morou 40 anos no Rio e há quatro está em Quissamã.</segment>
  </rst>
</analysis>