  <rst>
    <segment id="1">BMW desgovernado invade ciclovia de Copacabana e atropela mulher</segment>
    <segment id="2">RIO - O motorista de um BMW invadiu a ciclovia da Avenida Atlântica</segment>
    <segment id="3">, em Copacabana</segment>
    <segment id="4">, e atropelou Maria Regina Santos Ferreira</segment>
    <segment id="5">, de 58 anos</segment>
    <segment id="6">A mulher foi internada no Hospital Miguel Couto</segment>
    <segment id="7">, na Gávea</segment>
    <segment id="8">, onde está em observação.</segment>
    <segment id="9">De acordo com policiais da 12ª DP (Hilário de Gouveia)</segment>
    <segment id="10">, o motorista</segment>
    <segment id="11">, identificado</segment>
    <segment id="12">comocomo Francisco Jorge Pereira Ferreira</segment>
    <segment id="13">, responderá por lesão corporal culposa.</segment>
    <segment id="14">O motorista perdeu a direção</segment>
    <segment id="15">, na altura da Rua Siqueira Campos</segment>
    <segment id="16">, por volta das 14h40</segment>
    <segment id="17">m.</segment>
    <segment id="18">Praticamente no mesmo horário</segment>
    <segment id="19">, um engavetamento de seis veículos deixou 15 levemente feridos</segment>
    <segment id="20">, entre os quais 12 crianças</segment>
    <segment id="21">, na Rua Pereira da Silva</segment>
    <segment id="22">, em Laranjeiras.</segment>
    <segment id="23">Havia uma van escolar envolvida no acidente.</segment>
    <segment id="24">Carros de salvamento dos bombeiros dos quartéis do Humaitá e do Catete</segment>
    <segment id="25">sese deslocaram para o socorro</segment>
    <segment id="26">, o que deixou o trânsito complicado no local.</segment>
    <segment id="27">O último atropelamento numa ciclovia da cidade aconteceu no dia 18 junho</segment>
    <segment id="28">, quando o vigilante</segment>
    <segment id="29">William Eustáquio da Silva</segment>
    <segment id="30">, de 35 anos</segment>
    <segment id="31">, que andava de bicicleta do Aterro do Flamengo</segment>
    <segment id="32">, morreu após ser atropelado por um assaltante</segment>
    <segment id="33">, em frente 1º Grupamento Marítimo do Corpo de Bombeiros (G-Mar).</segment>
    <segment id="34">Já na ciclovia da Avenida Atlântica</segment>
    <segment id="35">, a última invasão por um carro aconteceu em 26 de fevereiro.</segment>
    <segment id="36">Na ocasião</segment>
    <segment id="37">, três pessoas foram atropeladas por uma picape desgovernada</segment>
    <segment id="38">, próximo ao Posto 5.</segment>
    <segment id="39">Uma delas</segment>
    <segment id="40">, um rapaz de 23 anos que estava numa bicicleta</segment>
    <segment id="41">, ficou gravemente ferido na perna.</segment>
  </rst>
</analysis>