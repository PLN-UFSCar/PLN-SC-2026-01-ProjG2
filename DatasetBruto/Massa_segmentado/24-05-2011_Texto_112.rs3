  <rst>
    <segment id="1">Farra do pó acaba em morte</segment>
    <segment id="2">Antônio afirma que o amigo Eduardo não usava drogas</segment>
    <segment id="3">No meio de uma noite de sexo regada a cocaína</segment>
    <segment id="4">, o eletricista Antônio Gonçalves de Oliveira</segment>
    <segment id="5">, 34, acordou assustado ao ouvir um som de tiro e viu caído no chão o amigo Eduardo Maia de Jesus</segment>
    <segment id="6">, 29, pedreiro.</segment>
    <segment id="7">Segundo Antônio</segment>
    <segment id="8">, a autora dos disparos foi Tatiana Oliveira Cruz</segment>
    <segment id="9">, 34, namorada de Eduardo.</segment>
    <segment id="10">Ela estava com um revólver 38 na mão.</segment>
    <segment id="11">Para defender o amigo</segment>
    <segment id="12">, Antônio lutou com Tatiana</segment>
    <segment id="13">, tomou a arma dela e acabou matando a mulher com tiros no tórax e ombro.</segment>
    <segment id="14">Antônio foi preso ontem por policiais da Delegacia de Periperi e deu essa versão para o duplo homicídio ocorrido no último sábado</segment>
    <segment id="15">, na casa de Tatiana</segment>
    <segment id="16">, no bairro Águas Claras.</segment>
    <segment id="17">Antônio diz que fez sexo com a enteada de Tatiana.</segment>
    <segment id="18">Ele não lembra o nome da jovem</segment>
    <segment id="19">, que conheceu naquele dia.</segment>
    <segment id="20">Após o crime</segment>
    <segment id="21">, disse que deu carona a ela até o bairro Valéria.</segment>
    <segment id="22">Investigação: Envolvidos sem ficha</segment>
    <segment id="23">De acordo com o delegado Sérgio Schlang Júnior</segment>
    <segment id="24">, familiares informaram que Eduardo atuava</segment>
    <segment id="25">comocomo matador</segment>
    <segment id="26">, assassinando pessoas por encomenda.</segment>
    <segment id="27">Nenhum dos envolvidos tem ficha na polícia.</segment>
    <segment id="28">O delegado destaca que</segment>
    <segment id="29">, inicialmente</segment>
    <segment id="30">, Antônio responderá a inquérito</segment>
    <segment id="31">comocomo suspeito pelos dois homicídios.</segment>
  </rst>
