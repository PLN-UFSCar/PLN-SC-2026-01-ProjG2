  <rst>
    <segment id="1">Juliana te empurra
Escolhida a musa para o concurso do BrasileirГѓВЈo</segment>
    <segment id="2">, a morena quer o time em cima</segment>
    <segment id="3">A torcida do Bahia estГѓВЎ triste com a qualidade da equipe</segment>
    <segment id="4">, forte candidata ao rebaixamento.</segment>
    <segment id="5">No entanto</segment>
    <segment id="6">, a vibraГѓВ§ГѓВЈo tricolor pode ser encontrada nas curvas de Juliana Cardoso</segment>
    <segment id="7">, que representarГѓВЎ o EsquadrГѓВЈo no Musa do BrasileirГѓВЈo</segment>
    <segment id="8">, do CaldeirГѓВЈo do Huck.</segment>
    <segment id="9">Pelo regulamento</segment>
    <segment id="10">, a gata nГѓВЈo pode falar com outro veГѓВ­culo de comunicaГѓВ§ГѓВЈo atГѓВ© o fim de concurso</segment>
    <segment id="11">, masmas pela entrevista concedida ao Globo Esporte</segment>
    <segment id="12">, mostrou que faz de tudo para levantar seu time do coraГѓВ§ГѓВЈo.</segment>
    <segment id="13">Гўв‚¬Е“Estou acompanhando todos os jogos e continuo acreditando que vamos sair dessa situaГѓВ§ГѓВЈo.</segment>
    <segment id="14">A esperanГѓВ§a ГѓВ© a ГѓВєltima que morre.</segment>
    <segment id="15">No ano passado eu fiquei entre as cinco</segment>
    <segment id="16">, masmas nГѓВЈo fui chamada.</segment>
    <segment id="17">E esse ano estou aqui.</segment>
    <segment id="18">NГѓВЈo me entreguei e espero que ninguГѓВ©m do time</segment>
    <segment id="19">sese entregueГўв‚¬</segment>
    <segment id="20">, justificou Juliana</segment>
    <segment id="21">, que nГѓВЈo desistiu do sonho mesmo apГѓВіs ser eliminada em 2011.</segment>
    <segment id="22">Ela transborda paixГѓВЈo ao falar do tricolor.</segment>
    <segment id="23">Гўв‚¬Е“Nasci Bahia.</segment>
    <segment id="24">Minha famГѓВ­lia</segment>
    <segment id="25">ГѓВ© toda Bahia.</segment>
    <segment id="26">NГѓВЈo tinha</segment>
    <segment id="27">comocomo eu torcer por outro time.</segment>
    <segment id="28">Meu sangue</segment>
    <segment id="29">ГѓВ© tricolor.</segment>
    <segment id="30">Para mim</segment>
    <segment id="31">, isso nГѓВЈo significa sГѓВі beleza.</segment>
    <segment id="32">ГѓвЂ° o orgulho de ser BahiaГўв‚¬.</segment>
    <segment id="33">A vitГѓВіria Гўв‚¬</segment>
    <segment id="34">вЂњ desbancou a concorrente e amiga Katiely Kathissumi Гўв‚¬вЂњ foi no limite.</segment>
    <segment id="35">Гўв‚¬Е“Ser escolhida foi uma surpresa.</segment>
    <segment id="36">Eu me inscrevi no ГѓВєltimo dia</segment>
    <segment id="37">, porque</segment>
    <segment id="38">porque estava esperando as fotos novas chegarem.</segment>
    <segment id="39">Contei com o apoio de minha famГѓВ­lia</segment>
    <segment id="40">, amigos e dos torcedores.</segment>
    <segment id="41">AlГѓВ©m disso</segment>
    <segment id="42">, contei tambГѓВ©m com o apoio da musa do Bahia do ano passado [Dani MangГѓВЎ]</segment>
    <segment id="43">, que ajudou na divulgaГѓВ§ГѓВЈo e me deu algumas dicas.</segment>
    <segment id="44">Esse apoio pode fazer a diferenГѓВ§a e o exemplo serve para o time.</segment>
    <segment id="45">Por isso</segment>
    <segment id="46">, a torcida tambГѓВ©m tem que ajudar".</segment>
    <segment id="47">Caio CГѓВ©sar de titular</segment>
    <segment id="48">O Bahia deve ter mais mobilidade no jogo deste domingo.</segment>
    <segment id="49">No treino de ontem</segment>
    <segment id="50">, o tГѓВ©cnico</segment>
    <segment id="51">Caio JГѓВєnior escalou o xarГѓВЎ</segment>
    <segment id="52">Caio CГѓВ©sar no lugar de Mancini</segment>
    <segment id="53">, suspenso pelo terceiro cartГѓВЈo.</segment>
    <segment id="54">AlГѓВ©m disso</segment>
    <segment id="55">, o tricolor contarГѓВЎ com dois laterais de ofГѓВ­cio</segment>
    <segment id="56">, o destro Neto e o canhoto Jussandro.</segment>
    <segment id="57">Гўв‚¬Е“Temos que ser mais agressivos no jogo</segment>
    <segment id="58">, para chamar o torcedor para o nosso ladoГўв‚¬</segment>
    <segment id="59">, explicou Caio JГѓВєnior.</segment>
