  <rst>
    <segment id="1">Ap횄쨀s relator e revisor</segment>
    <segment id="2">, demais ministros come횄짠am a votar
BRAS횄LIA -</segment>
    <segment id="3">O julgamento do mensal횄짙o entra nesta segunda-feira em nova fase</segment>
    <segment id="4">, mais veloz e reveladora.</segment>
    <segment id="5">Depois dos longos votos do relator</segment>
    <segment id="6">, Joaquim Barbosa</segment>
    <segment id="7">, e do revisor</segment>
    <segment id="8">, Ricardo Lewandowski</segment>
    <segment id="9">, pela primeira vez os outros nove ministros ter횄짙o a chance de</segment>
    <segment id="10">sese pronunciar</segment>
    <segment id="11">, trazendo 횄혻 luz suas tend횄짧ncias para condenar ou absolver os r횄짤us.</segment>
    <segment id="12">O primeiro deixou claro um vi횄짤s condenat횄쨀rio.</segment>
    <segment id="13">O segundo condenou alguns crimes e absolveu outros.</segment>
    <segment id="14">A partir da sess횄짙o desta segunda-feira</segment>
    <segment id="15">, ser횄징 poss횄짯vel saber</segment>
    <segment id="16">sese a Corte</segment>
    <segment id="17">sese dividir횄징 em dois times: o do relator e o do revisor.</segment>
    <segment id="18">Barbosa e Lewandowski levaram duas sess횄쨉es cada um para falar apenas do primeiro dos sete cap횄짯tulos</segment>
    <segment id="19">, masmas agora o tribunal deve apertar o passo para concluir ainda esta semana essa parte do julgamento.</segment>
    <segment id="20">O ministro Luiz Fux tem conversado com cada um dos colegas para convenc횄짧-los a votar em at횄짤 duas horas.</segment>
    <segment id="21">Se o plano der certo</segment>
    <segment id="22">, at횄짤 quinta-feira estar횄징 tra횄짠ado o destino de seis dos 37 r횄짤us.</segment>
    <segment id="23">Embora preze pela celeridade do julgamento</segment>
    <segment id="24">, o presidente da Corte</segment>
    <segment id="25">, Carlos Ayres Britto</segment>
    <segment id="26">, deixou a cargo dos colegas decidir por quanto tempo falar횄짙o.</segment>
    <segment id="27">Nesta segunda-feira</segment>
    <segment id="28">, o relator ainda falar횄징 por 20 minutos</segment>
    <segment id="29">, e o revisor ter횄징 o mesmo tempo.</segment>
    <segment id="30">Nessa primeira parte do julgamento</segment>
    <segment id="31">, decide-</segment>
    <segment id="32">sese o futuro de seis r횄짤us: o ex-presidente da C횄짖mara Jo횄짙o Paulo Cunha (PT-SP)</segment>
    <segment id="33">;</segment>
    <segment id="34">o ex-gerente de Marketing do Banco do Brasil Henrique Pizzolato</segment>
    <segment id="35">; o suposto operador do esquema</segment>
    <segment id="36">, Marcos Val횄짤rio</segment>
    <segment id="37">; e dois dos s횄쨀cios deste</segment>
    <segment id="38">, Cristiano Paz e Ramon Hollerbach.</segment>
    <segment id="39">O ex-ministro da Secretaria de Comunica횄짠횄짙o Luiz Gushiken dever횄징 ser absolvido</segment>
    <segment id="40">, como</segment>
    <segment id="41">como recomendou o Minist횄짤rio P횄쨘blico Federal.</segment>
    <segment id="42">Cezar Peluso na hora da despedida</segment>
    <segment id="43">O momento tamb횄짤m</segment>
    <segment id="44">횄짤 decisivo para o ministro Cezar Peluso</segment>
    <segment id="45">, que se</segment>
    <segment id="46">se aposenta em 3 de setembro</segment>
    <segment id="47">, quando completa 70 anos de idade.</segment>
    <segment id="48">Assim, ser횄징 a 횄쨘ltima semana dele no STF.</segment>
    <segment id="49">A inten횄짠횄짙o de Peluso de antecipar a 횄짯ntegra de seu voto</segment>
    <segment id="50">, antes mesmo de o relator fazer isso</segment>
    <segment id="51">, n횄짙o 횄짤 bem aceita por v횄징rios ministros</segment>
    <segment id="52">, como</segment>
    <segment id="53">como Marco Aur횄짤lio Mello e Lewandowski.</segment>
    <segment id="54">Outros colegas</segment>
    <segment id="55">, como</segment>
    <segment id="56">como Joaquim Barbosa</segment>
    <segment id="57">, Gilmar Mendes e Ayres Britto</segment>
    <segment id="58">, veem a ideia com bons olhos.</segment>
    <segment id="59">A quest횄짙o dever횄징 ser debatida em plen횄징rio esta semana.</segment>
    <segment id="60">Ap횄쨀s as falas desta segunda-feira do relator e do revisor</segment>
    <segment id="61">, deve haver um breve debate entre os demais integrantes da Corte.</segment>
    <segment id="62">Embora todos os ministros tenham votos escritos com cerca de 500 p횄징ginas</segment>
    <segment id="63">, boa parte deles</segment>
    <segment id="64">sese comprometeu a resumir suas vers횄쨉es</segment>
    <segment id="65">em plen횄징rio para acelerar o ritmo das decis횄쨉es.</segment>
    <segment id="66">Barbosa e Lewandowski tamb횄짤m prometeram votos mais curtos a partir de agora.</segment>
    <segment id="67">A vontade de dar mais agilidade 횄혻 vota횄짠횄짙o vem especialmente do presidente da Corte</segment>
    <segment id="68">, Ayres Britto</segment>
    <segment id="69">, auxiliado diretamente por Fux.</segment>
    <segment id="70">A primeira a votar nesta segunda-feira</segment>
    <segment id="71">횄짤 Rosa Weber.</segment>
    <segment id="72">Como de h횄징bito</segment>
    <segment id="73">, ser횄징 breve e atender횄징 ao apelo do colega.</segment>
    <segment id="74">Fux 횄짤 o seguinte e deve proceder da mesma forma.
N횄짙o</segment>
    <segment id="75">sese sabe</segment>
    <segment id="76">sese Dias Toffoli</segment>
    <segment id="77">, o terceiro na ordem de vota횄짠횄짙o</segment>
    <segment id="78">, vai se</segment>
    <segment id="79">se manifestar por muitas horas.</segment>
    <segment id="80">Ele pode usar mais tempo para justificar seu ponto de vista</segment>
    <segment id="81">, j횄징 que</segment>
    <segment id="82">, antes de come횄짠ar o julgamento</segment>
    <segment id="83">, pairavam d횄쨘vidas sobre seu eventual impedimento para participar da decis횄짙o.</segment>
    <segment id="84">O ministro foi advogado do PT</segment>
    <segment id="85">, 횄짤 amigo de um dos r횄짤us</segment>
    <segment id="86">, o ex-chefe da Casa Civil Jos횄짤 Dirceu</segment>
    <segment id="87">, e a namorada dele foi advogada de outro r횄짤u</segment>
    <segment id="88">, o ex-deputado Professor Luizinho (PT-SP).</segment>
    <segment id="89">Como est횄징 em jogo a condena횄짠횄짙o ou absolvi횄짠횄짙o do petista Jo횄짙o Paulo</segment>
    <segment id="90">, pode ser que Toffoli use mais tempo para explicar seu ponto de vista.</segment>
    <segment id="91">C횄징rmen L횄쨘cia</segment>
    <segment id="92">, tamb횄짤m conhecida por votos objetivos</segment>
    <segment id="93">, deve ser ainda mais r횄징pida que Rosa e Fux.</segment>
    <segment id="94">Ela costuma dar breves argumentos para sustentar sua posi횄짠횄짙o e dizer com qual colega concorda</segment>
    <segment id="95">, encaminhando em seguida a 횄짯ntegra de seu voto escrito.</segment>
    <segment id="96">Se n횄짙o pedir para antecipar o voto</segment>
    <segment id="97">, a depender do tempo usado em plen횄징rio pelos colegas</segment>
    <segment id="98">, a manifesta횄짠횄짙o de Cezar Peluso deve ocorrer na quarta ou na quinta-feira.</segment>
    <segment id="99">Na ocasi횄짙o</segment>
    <segment id="100">, o plen횄징rio poder횄징 decidir</segment>
    <segment id="101">sese o autoriza a antecipar o voto integral.</segment>
    <segment id="102">A expectativa de alguns ministros 횄짤 que Barbosa</segment>
    <segment id="103">, na condi횄짠횄짙o de relator</segment>
    <segment id="104">, abra a discuss횄짙o em plen횄징rio sobre a possibilidade de Peluso antecipar seu ponto de vista.</segment>
    <segment id="105">O voto de Peluso tem 400 p횄징ginas</segment>
    <segment id="106">, masmas o ministro</segment>
    <segment id="107">sese limitaria a verbalizar apenas um resumo do texto</segment>
    <segment id="108">, encaminhando a pe횄짠a integral aos colegas.</segment>
    <segment id="109">Depois de Peluso</segment>
    <segment id="110">, votam Gilmar Mendes e Marco Aur횄짤lio.</segment>
    <segment id="111">Ambos t횄짧m criticado os votos longos do relator e do revisor e</segment>
    <segment id="112">, por isso</segment>
    <segment id="113">, n횄짙o devem alongar muito suas manifesta횄짠횄쨉es.</segment>
    <segment id="114">Em seguida vem Celso de Mello</segment>
    <segment id="115">, considerado pelos colegas uma amea횄짠a 횄혻 celeridade do julgamento.</segment>
    <segment id="116">Tradicionalmente</segment>
    <segment id="117">, o decano do STF apresenta os votos mais longos</segment>
    <segment id="118">, levando em considera횄짠횄짙o aspectos hist횄쨀ricos e jurisprud횄짧ncias de outros pa횄짯ses.</segment>
    <segment id="119">O 횄쨘ltimo a votar 횄짤 o presidente</segment>
    <segment id="120">, que j횄징</segment>
    <segment id="121">sese comprometeu com a brevidade.</segment>
    <segment id="122">Quando os ministros conclu횄짯rem o julgamento sobre desvios de dinheiro p횄쨘blico na C횄짖mara dos Deputados e no Banco do Brasil</segment>
    <segment id="123">, entrar횄짙o em novo cap횄짯tulo: os crimes financeiros atribu횄짯dos aos dirigentes do Banco Rural.</segment>
    <segment id="124">Menos intrincada com o setor pol횄짯tico do esquema</segment>
    <segment id="125">, essa parte deve levar menos tempo para ser conclu횄짯da.</segment>
    <segment id="126">Estar횄짙o em jogo os destinos de Jos횄짤</segment>
    <segment id="127">Roberto Salgado</segment>
    <segment id="128">, Ayanna Ten횄쨀rio</segment>
    <segment id="129">, Vin횄짯cius Samarane e K횄징tia Rabello</segment>
    <segment id="130">, acusados de gest횄짙o fraudulenta.</segment>
    <segment id="131">Os advogados dos r횄짤us do mensal횄짙o mant횄짧m seus clientes informados em tempo real.</segment>
    <segment id="132">Durante as sess횄쨉es do STF</segment>
    <segment id="133">, a ferramenta mais utilizada 횄짤 o torpedo por celular.</segment>
    <segment id="134">Nos intervalos das sess횄쨉es</segment>
    <segment id="135">, ou mesmo durante a discuss횄짙o entre os ministros</segment>
    <segment id="136">, masmas fora do plen횄징rio</segment>
    <segment id="137">, as conversas nos celulares s횄짙o frequentes.</segment>
    <segment id="138">Luiz Francisco Barbosa</segment>
    <segment id="139">, defensor de Roberto Jefferson</segment>
    <segment id="140">, exibe para jornalistas a troca de mensagens com o delator do mensal횄짙o.</segment>
    <segment id="141">Os dois s횄짙o amigos h횄징 anos.
- N횄쨀s nos falamos com frequ횄짧ncia sobre o processo.</segment>
    <segment id="142">Geralmente</segment>
    <segment id="143">, conversamos antes e depois das sess횄쨉es.</segment>
    <segment id="144">Aguardo sempre uma mensagem.</segment>
    <segment id="145">Quando ele some</segment>
    <segment id="146">, vou ver o que ele escreve e est횄징 achando naquele diabo do blog dele - disse o defensor de Jefferson.</segment>
    <segment id="147">Essa rela횄짠횄짙o de proximidade entre r횄짤us e advogados prevalece em muitos casos.</segment>
    <segment id="148">Jo횄짙o Gomes</segment>
    <segment id="149">, advogado do ex-deputado federal Paulo Rocha (PT-PA)</segment>
    <segment id="150">, 횄짤 outro exemplo.
- Estou com o Paulo desde 2007</segment>
    <segment id="151">, e ele virou meu amigo.</segment>
    <segment id="152">Quando fiz sua defesa</segment>
    <segment id="153">, fomos jantar num restaurante aqui em Bras횄짯lia.</segment>
    <segment id="154">Ele gostou</segment>
    <segment id="155">, ficou contente</segment>
    <segment id="156">, me agradeceu.</segment>
    <segment id="157">A rela횄짠횄짙o 횄짤 assim.
Amizade 횄혻 parte</segment>
    <segment id="158">, Gomes diz que n횄짙o esconde de seu cliente a realidade do julgamento e a real perspectiva de ser absolvido ou condenado.
- N횄짙o vendo ilus횄쨉es.</segment>
    <segment id="159">Nenhum advogado faz isso num</segment>
    <segment id="160">casocaso</segment>
    <segment id="161">comocomo este.</segment>
    <segment id="162">Mas, honestamente</segment>
    <segment id="163">, e disse isso a ele</segment>
    <segment id="164">, tenho grande esperan횄짠a de que seja absolvido - disse Gomes</segment>
    <segment id="165">, que revelou ter admira횄짠횄짙o especial por alguns integrantes dos quadros do PT.</segment>
    <segment id="166">-</segment>
    <segment id="167">Admiro a hist횄쨀ria de alguns deles</segment>
    <segment id="168">, como</segment>
    <segment id="169">como as de Z횄짤 Dirceu e Genoino.</segment>
    <segment id="170">Gostaria de ter 횄징lbum de figurinha com as fotos deles.</segment>
    <segment id="171">Advogados mineiros chamam aten횄짠횄짙o.</segment>
    <segment id="172">Da defesa t횄짤cnica que Marcelo Leonardo fez de Marcos Val횄짤rio ao estilo irreverente de Paulo S횄짤rgio Abreu</segment>
    <segment id="173">, que chamou sua cliente</segment>
    <segment id="174">, Geiza Dias</segment>
    <segment id="175">, ex-secret횄징ria da SMP&amp;B</segment>
    <segment id="176">, de "mequetrefe"</segment>
    <segment id="177">, os mineiros conquistaram aplausos dos colegas.</segment>
