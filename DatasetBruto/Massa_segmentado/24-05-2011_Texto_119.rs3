  <rst>
    <segment id="1">Novos tornados voltam a causar destruição nos EUA

OKLAHOMA CITY - Enquanto as forças ainda</segment>
    <segment id="2">sese voltam para tentar reeguer Joplin</segment>
    <segment id="3">, no Missouri</segment>
    <segment id="4">, novos tornados atingiram nesta terça-feira a região central dos Estados Unidos.</segment>
    <segment id="5">Desta vez</segment>
    <segment id="6">, as vítimas foram os estado de Oklahoma e Kansas</segment>
    <segment id="7">, com saldo de pelo menos seis mortos.</segment>
    <segment id="8">Quatro das vítimas eram de Oklahoma City</segment>
    <segment id="9">, que teve ainda ao menos 60 feridos.</segment>
    <segment id="10">Já em Kansas</segment>
    <segment id="11">, duas pessoas morreram na pequena cidade de St.</segment>
    <segment id="12">John.</segment>
    <segment id="13">O número de mortos deve aumentar</segment>
    <segment id="14">, alertam as autoridades.</segment>
    <segment id="15">O maior dos tornados atingiu El Reno</segment>
    <segment id="16">, cidade de 15 mil habitantes a oeste de Oklahoma City</segment>
    <segment id="17">, e continuou em direção a nordeste.</segment>
    <segment id="18">Apesar de aparentemente não ter deixado vítimas</segment>
    <segment id="19">, a tempestade causou "danos extensos"</segment>
    <segment id="20">, segundo a Prefeitura.</segment>
    <segment id="21">Estados mais centrais dos EUA vêm</segment>
    <segment id="22">sese preparando durante todo o dia para o clima ruim</segment>
    <segment id="23">, depois que o Instituto de Meteorologia afirmou que as condições eram próprias para o surgimento de tornados.</segment>
    <segment id="24">O novo ciclo de tornados começou dois dias depois que um tornado gigantesco destruiu o coração da cidade de Joplin</segment>
    <segment id="25">, no Missouri</segment>
    <segment id="26">, matando pelo menos 122 pessoas.</segment>
    <segment id="27">A tempestade foi a mais mortal dos Estados Unidos em quase 60 anos.</segment>
  </rst>
</analysis>