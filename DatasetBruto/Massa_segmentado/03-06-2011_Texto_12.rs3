  <rst>
    <segment id="1">Vamo, vamo</segment>
    <segment id="2">, Negô!</segment>
    <segment id="3">Série B é carne de pescoço e no duelo com o Bugre</segment>
    <segment id="4">, o Leão pede a força da torcida</segment>
    <segment id="5">O Vitória vai soltar seus leões em cima do Bugre.</segment>
    <segment id="6">Em esquema bem ofensivo</segment>
    <segment id="7">, está na cara que Geninho quer “devorar” o Guarani no Barradão.</segment>
    <segment id="8">Para isso</segment>
    <segment id="9">, vai apostar somente em Uelliton</segment>
    <segment id="10">comocomo volante de origem</segment>
    <segment id="11">, enquanto Jerson</segment>
    <segment id="12">, Xuxa e Geovanni mandam brasa no meio-campo.</segment>
    <segment id="13">A tática é arriscada e o técnico admite que vai deixar a equipe mais vulnerável.</segment>
    <segment id="14">Isso porque</segment>
    <segment id="15">porque ele acha que ainda não tem os volantes ideais para a posição.</segment>
    <segment id="16">“</segment>
    <segment id="17">Em breve terei Zé Luís e Neto Coruja para usar</segment>
    <segment id="18">comocomo volantes.</segment>
    <segment id="19">Para este jogo não sei</segment>
    <segment id="20">sese posso colocar Zé Luís de início</segment>
    <segment id="21">, tenho que ver</segment>
    <segment id="22">sese ele aguenta”</segment>
    <segment id="23">, explicou Geninho.</segment>
    <segment id="24">O meia Jerson entra pela primeira vez</segment>
    <segment id="25">comocomo titular e vai tentar fazer a função de segundo volante.</segment>
    <segment id="26">“</segment>
    <segment id="27">Não tem riscos neste esquema.</segment>
    <segment id="28">Estou acostumado a trabalhar assim</segment>
    <segment id="29">, não tem mistério”</segment>
    <segment id="30">, opina Jerson.</segment>
    <segment id="31">No jogo contra o Icasa</segment>
    <segment id="32">, Geninho entrou com três zagueiros e saiu de lá com a derrota.</segment>
    <segment id="33">Desta vez</segment>
    <segment id="34">, apenas Léo Fortunato e Alison fazem esta função.</segment>
    <segment id="35">“</segment>
    <segment id="36">A característica deles [Jerson</segment>
    <segment id="37">, Xuxa e Geovanni] não é de marcação</segment>
    <segment id="38">, por isso vamos estar lá para ajudar também”</segment>
    <segment id="39">, disse Fortunato.</segment>
    <segment id="40">Enquanto isso</segment>
    <segment id="41">, o Guarani busca sua primeira vitória na Série B.</segment>
    <segment id="42">O time paulista empatou nas duas primeiras rodadas</segment>
    <segment id="43">, contra o Criciúma e o Sport.</segment>
  </rst>
</analysis>