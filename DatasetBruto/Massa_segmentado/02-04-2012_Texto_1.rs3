  <rst>
    <segment id="1">‘Patroa’</segment>
    <segment id="2">lidera o Harém do Funk</segment>
    <segment id="3">Ex-dançarina de pagode</segment>
    <segment id="4">, Flora Nascimento</segment>
    <segment id="5">sese lança</segment>
    <segment id="6">comocomo cantora ao lado de beldades
“Patroa”.</segment>
    <segment id="7">É assim que Flora Nascimento</segment>
    <segment id="8">, ex-dançarina de pagode</segment>
    <segment id="9">, quer ser conhecida pelos fãs a partir de agora</segment>
    <segment id="10">, quando dá o ponta-pé inicial na sua carreira de cantora com o Harém do Funk.</segment>
    <segment id="11">“</segment>
    <segment id="12">A ideia de criar um grupo nasceu depois que participei de um evento em um lava a jato.</segment>
    <segment id="13">Fui convidada para cantar e o povo gostou”</segment>
    <segment id="14">, recorda a moça.</segment>
    <segment id="15">O novo grupo faz jus ao nome escolhido</segment>
    <segment id="16">, já que o Harém de Flora é formado por dois casais de beldades que animam moças e rapazes com coreografias pra lá de ousadas.</segment>
    <segment id="17">O som que acompanha a vocalista é feito por MC Sheik e DJ Bolero.</segment>
    <segment id="18">“</segment>
    <segment id="19">Toco funk há muito tempo e a intenção de Flora com esse grupo me motivou bastante.</segment>
    <segment id="20">Ela quer mostrar para Salvador letras feitas para dançar</segment>
    <segment id="21">, masmas sem ridicularizar a mulher”</segment>
    <segment id="22">, comenta DJ Bolero</segment>
    <segment id="23">, já adequado à nova lei antibaixaria aprovada na semana passada.</segment>
    <segment id="24">Para incrementar o lançamento do Harém do Funk em Salvador</segment>
    <segment id="25">, a “Patroa” promete publicar na web o resultado das gravações do primeiro clipe da trupe.</segment>
    <segment id="26">Com a música de trabalho “Festa na Piscina”</segment>
    <segment id="27">, o vídeo vai invadir as redes sociais ainda esta semana.</segment>
    <segment id="28">Coreografias sensuais</segment>
    <segment id="29">, carrões de luxo e muita gente bonita estão garantidos.</segment>
    <segment id="30">“Aqui não esculachamos as mulheres.</segment>
    <segment id="31">Os homens é que merecem ser esculachados.</segment>
    <segment id="32">Esses não tem vez com a gente”</segment>
    <segment id="33">, diverte-</segment>
    <segment id="34">sese Flora.</segment>
    <segment id="35">CD à vista</segment>
    <segment id="36">O primeiro CD do Harém do Funk estará disponível para baixar da internet no final de abril.</segment>
    <segment id="37">Serão seis músicas autorais e várias outras conhecidas pelo público que curte o ritmo.</segment>
    <segment id="38">Para quem gostou do primeiro clipe</segment>
    <segment id="39">, pode aguardar que vem mais por aí: outros dois serão lançados ainda este mês.</segment>
  </rst>
</analysis>