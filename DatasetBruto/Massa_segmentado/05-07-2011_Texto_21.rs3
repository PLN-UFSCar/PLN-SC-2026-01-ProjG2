  <rst>
    <segment id="1">Bando ameaça com seringa de sangue</segment>
    <segment id="2">Bandidos levaram a grana da agência do Itaú do Garcia sem efetuar disparo</segment>
    <segment id="3">Os assaltantes levaram a melhor no roubo ao banco Itaú do bairro do Garcia.</segment>
    <segment id="4">Eles saíram com o dinheiro de um dos cofres da agência sem precisar disparar um tiro.</segment>
    <segment id="5">O Itaú não divulgou a quantia roubada.</segment>
    <segment id="6">Os bandidos renderam a gerente do estabelecimento quando ela chegava ao trabalho.</segment>
    <segment id="7">Em seguida renderam os seguranças e foram até o cofre.</segment>
    <segment id="8">Segundo informações de policiais da Delegacia de Repressão a Furtos e Roubos (DRFR)</segment>
    <segment id="9">, responsáveis pela investigação</segment>
    <segment id="10">, os funcionários relataram que quatro homens armados com fuzis entraram na agência usando a farda de uma empresa que faz a manutenção em aparelhos de ar-condicionado.</segment>
    <segment id="11">Um deles ameaçava a gerente com uma seringa cheia de sangue.</segment>
    <segment id="12">A tensão aumentou quando uma viatura da Polícia Civil parou na porta de um prédio em frente ao banco.</segment>
    <segment id="13">Os bandidos pensaram que os funcionários haviam chamado a polícia</segment>
    <segment id="14">, masmas em meio à agitação</segment>
    <segment id="15">, uma funcionária explicou que a viatura estava ali apenas para buscar um delegado</segment>
    <segment id="16">, que mora no prédio.</segment>
    <segment id="17">A viatura foi</segment>
    <segment id="18">embora</segment>
    <segment id="19">embora e os bandidos continuaram o assalto.</segment>
    <segment id="20">O grupo que estava dentro da agência</segment>
    <segment id="21">sese comunicava com o restante do bando pelo celular.</segment>
    <segment id="22">A ação  foi bastante discreta.</segment>
    <segment id="23">“Não percebi nada.</segment>
    <segment id="24">O carro desceu na garagem no horário em que os funcionários chegam e achei que fosse só mais um deles”</segment>
    <segment id="25">, disse um ambulante</segment>
    <segment id="26">, que trabalha em frente à agência.</segment>
    <segment id="27">Depois de rasparem o tacho</segment>
    <segment id="28">, o bandidos fugiram em um Fiat Strada preto.</segment>
    <segment id="29">Número um: Roubo foi o 1º na capital em 2011</segment>
    <segment id="30">O Banco Itaú</segment>
    <segment id="31">sese limitou a informar por meio de sua assessoria de imprensa que “está colaborando com as autoridades na investigação do</segment>
    <segment id="32">casocaso”.</segment>
    <segment id="33">A agência ficou fechada no resto do dia para a realização de perícia.</segment>
    <segment id="34">Pelo menos até as 11 horas da manhã</segment>
    <segment id="35">, não havia aviso na porta do banco para avisar aos clientes que não haveria atendimento.</segment>
    <segment id="36">Segundo a DRFR</segment>
    <segment id="37">, este foi o primeiro assalto a banco registrado em Salvador em 2011.</segment>
    <segment id="38">Ano passado</segment>
    <segment id="39">, foram catalogados oito roubos a banco na capital.</segment>
    <segment id="40">Até março deste ano</segment>
    <segment id="41">, 19 bancos foram roubados no interior do Estado.</segment>
    <segment id="42">Sem câmeras</segment>
    <segment id="43">O Banco Itaú do Garcia não possui câmeras de vigilância</segment>
    <segment id="44">, o que ajudaria na identificação dos bandidos.</segment>
    <segment id="45">Os 13 funcionários que estavam na agência no momento do assalto foram convocados para prestar depoimento na DRFR.</segment>
    <segment id="46">Os investigadores encontraram resistência para entrar na agência.</segment>
    <segment id="47">A entrada dos policiais só foi permitida depois de uma conversa com a gerente.</segment>
  </rst>
</analysis>