  <rst>
    <segment id="1">Fluminense atrás do brilho</segment>
    <segment id="2">, masmas sem suas principais estrelas
RIO - Um Fluminense sem estrelas vai a Madureira e Xerém.</segment>
    <segment id="3">Para o jogo desete sábado</segment>
    <segment id="4">, às 15h45m</segment>
    <segment id="5">, com o time da casa</segment>
    <segment id="6">, em Conselheiro Galvão</segment>
    <segment id="7">, Deco e Fred serão poupados.</segment>
    <segment id="8">Assim como</segment>
    <segment id="9">como do treino inuagural do reformado Centro de Treinamento</segment>
    <segment id="10">, em Xerém</segment>
    <segment id="11">, na próxima quinta-feira.</segment>
    <segment id="12">Em ambos</segment>
    <segment id="13">, o tricolor deseja reviver o brilho perdido dentro e fora de campo.</segment>
    <segment id="14">Para chegar à semifinal da Taça Rio</segment>
    <segment id="15">, menos de três pontos significam jogo perdido.</segment>
    <segment id="16">Ao mesmo tempo</segment>
    <segment id="17">, o Bangu enfrenta o Macaé hoje e o tricolor torcerá</segment>
    <segment id="18">para que</segment>
    <segment id="19">para que perca para poder ultrapassá-lo.</segment>
    <segment id="20">Antes de pensar em dar espetáculo</segment>
    <segment id="21">, o técnico Abel Braga quer vencer</segment>
    <segment id="22">, mesmo sem convencer.</segment>
    <segment id="23">E o palco</segment>
    <segment id="24">, segundo ele</segment>
    <segment id="25">, não ajuda mesmo...

- Não vamos conseguir jogar bonito naquele campo - declarou o treinador.</segment>
    <segment id="26">Mais críticas ao Estadual

Aconselhado pelos dirigentes a não falar da estrutura precária dos estádios do Campeonato Carioca</segment>
    <segment id="27">, Abel não</segment>
    <segment id="28">sese conteve.</segment>
    <segment id="29">Afinal</segment>
    <segment id="30">, um assunto está ligado ao outro.</segment>
    <segment id="31">Na reabertura do CT das categorias de base</segment>
    <segment id="32">, que no passado revelou dezenas de talentos</segment>
    <segment id="33">, apenas os reservas e jogadores que não entrarão em campo contra o Boca Juniors</segment>
    <segment id="34">, um dia antes</segment>
    <segment id="35">, no Engenhão</segment>
    <segment id="36">, foram escalados.</segment>
    <segment id="37">Mas, no futuro</segment>
    <segment id="38">, o treinador admite usar o CT e poupar o campo das Laranjeiras no momento em que o clube tenta mandar em seu estádio os jogos contra time pequenos no Estadual do próximo ano.

- Até pediram para eu não falar.</segment>
    <segment id="39">Mas não era para os times grandes não jogarem em Madureira?</segment>
    <segment id="40">Nosso campo aqui nas Laranjeiras dá um banho em muitos desses aí que temos jogado.</segment>
    <segment id="41">Agora, que vamos treinar em Xerém</segment>
    <segment id="42">, seria bom voltar a jogar aqui na nossa casa</segment>
    <segment id="43">, na qual eu comecei no futebol e tem mais estrutura que os campos que temos jogado.</segment>
    <segment id="44">Alheia ao palco</segment>
    <segment id="45">, a torcida quer show.</segment>
    <segment id="46">Mesmo classificado com duas rodadas de antecedência para as oitavas de final da Libertadores e já garantido na final do Carioca</segment>
    <segment id="47">, o Fluminense ainda não desencantou.</segment>
    <segment id="48">Melhor</segment>
    <segment id="49">, não encantou...

- O time está ganhando</segment>
    <segment id="50">, masmas não está jogando bonito?</segment>
    <segment id="51">Jogar bonito é fazer gol.</segment>
    <segment id="52">A gente sempre procura jogar melhor e</segment>
    <segment id="53">, sese ganhar jogando bonito</segment>
    <segment id="54">, tudo bem.</segment>
    <segment id="55">Eu não vejo</segment>
    <segment id="56">, no Brasil</segment>
    <segment id="57">, equipe mais ofensiva que a nossa</segment>
    <segment id="58">, com quatro jogadores de frente bem ofensivos.</segment>
    <segment id="59">Não vou mudar esta filosofia - explicou Abel.</segment>
    <segment id="60">Na tentativa de manter a vocação ofensiva</segment>
    <segment id="61">, Rafael Moura e Rafael Sóbis entram nos lugares de Fred e Wellington Nem.</segment>
    <segment id="62">Fazem quase a mesma função</segment>
    <segment id="63">, masmas sem o brilho dos titulares.</segment>
    <segment id="64">No meio-campo</segment>
    <segment id="65">, Wagner terá a tarefa de ocupar o lugar de Deco.</segment>
    <segment id="66">Diego Cavalieri</segment>
    <segment id="67">, com uma unha encravada</segment>
    <segment id="68">, inspira cuidados.

- O Fred já deu um aviso...</segment>
    <segment id="69">Deco está seguindo um planejamento.</segment>
    <segment id="70">Já perdemos o Valencia e não quero correr mais o risco de perder jogadores - declarou Abel.</segment>
    <segment id="71">Madureira: Márcio</segment>
    <segment id="72">, Wellington Júnior</segment>
    <segment id="73">, Zé Carlos</segment>
    <segment id="74">, Thiago e Zeca</segment>
    <segment id="75">; Gílson</segment>
    <segment id="76">, Caio Cezar</segment>
    <segment id="77">, Paulo Vitor e Alex</segment>
    <segment id="78">; Maciel e Jairo.</segment>
    <segment id="79">Fluminense:</segment>
    <segment id="80">Diego Cavalieri (Klever)</segment>
    <segment id="81">, Bruno</segment>
    <segment id="82">, Anderson</segment>
    <segment id="83">, Leandro Euzébio e Carlinhos</segment>
    <segment id="84">;</segment>
    <segment id="85">Edinho</segment>
    <segment id="86">, Diguinho</segment>
    <segment id="87">, Wagner e Thiago Neves</segment>
    <segment id="88">; Rafael Sóbis e Rafael Moura.</segment>
    <segment id="89">Juiz: William Nery.

TRANSMISSÃO: Premiere e Rádios Globo e CBN</segment>
  </rst>
</analysis>