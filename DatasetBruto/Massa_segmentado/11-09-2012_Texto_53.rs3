  <rst>
    <segment id="1">Chefona liderava ladrﾃδｵes de carro</segment>
    <segment id="2">Quadrilha faturou R$ 600 mil e catou 100 veﾃδｭculos</segment>
    <segment id="3">, de janeiro a junho deste ano
Mulher</segment>
    <segment id="4">, 39 anos</segment>
    <segment id="5">, mﾃδ｣e de trﾃδｪs filhos e lﾃδｭder de uma das principais quadrilhas de roubo</segment>
    <segment id="6">, adulteraﾃδｧﾃδ｣o e receptaﾃδｧﾃδ｣o de veﾃδｭculos da Bahia.</segment>
    <segment id="7">Jaﾃδｭra Fagundes Moreira de Araﾃδｺjo</segment>
    <segment id="8">, segundo a Polﾃδｭcia Civil</segment>
    <segment id="9">, comandava um grupo com ramificaﾃδｧﾃδｵes em Sergipe e Pernambuco e era acusada de ter roubado</segment>
    <segment id="10">, pelo menos</segment>
    <segment id="11">, 100 carros em Itapuﾃδ｣</segment>
    <segment id="12">, Brotas</segment>
    <segment id="13">, Boca do Rio e Pituba no primeiro semestre deste ano.</segment>
    <segment id="14">Ela e 11 comparsas</segment>
    <segment id="15">, dentre os quais sua filha (Jaiara Fagundes de Araﾃδｺjo)</segment>
    <segment id="16">, foram presos durante a ﾃ｢竄ｬﾅ徹peraﾃδｧﾃδ｣o Leoaﾃ｢竄ｬ</segment>
    <segment id="17">, da Polﾃδｭcia Civil</segment>
    <segment id="18">, deflagrada na ﾃδｺltima quinta-feira.</segment>
    <segment id="19">O diretor do Departamento de Crimes Contra o Patrimﾃδｴnio (DCCP)</segment>
    <segment id="20">, delegado Cleandro Pimenta</segment>
    <segment id="21">, explica que era Jaﾃδｭra quem solicitava o roubo dos veﾃδｭculos</segment>
    <segment id="22">, os documentos falsos e a adulteraﾃδｧﾃδ｣o do chassi dos carros.
ﾃ｢竄ｬﾅ摘 ela mesma</segment>
    <segment id="23">, apﾃδｳs o cumprimentos dessas etapas</segment>
    <segment id="24">, sese dirigia para a Juazeiro</segment>
    <segment id="25">, Petrolina (PE) e cidades de Sergipe para vender os carrosﾃ｢竄ｬ.</segment>
    <segment id="26">Segundo ele</segment>
    <segment id="27">, o bando tinha preferﾃδｪncia por veﾃδｭculos  novos no modelo utilitﾃδ｡rio</segment>
    <segment id="28">, principalmente</segment>
    <segment id="29">, Fiat Strada.</segment>
    <segment id="30">Os veﾃδｭculos eram vendidos por cerca de R$ 6.500 e o bando movimentou cerca de R$ 600 mil.</segment>
    <segment id="31">Pelo interior</segment>
    <segment id="32">A Polﾃδｭcia Civil (PC) investiga</segment>
    <segment id="33">comocomo a falsificaﾃδｧﾃδ｣o dos documentos e adulteraﾃδｧﾃδ｣o dos chassis eram feitas.</segment>
    <segment id="34">ﾃ｢竄ｬﾅ哲os documentos</segment>
    <segment id="35">, eles colocavam  que o veﾃδｭculo era financiado para justificar o valor baixo da vendaﾃ｢竄ｬ</segment>
    <segment id="36">, disse o delegado Augusto Eustﾃδ｡quio</segment>
    <segment id="37">, do DCCP.</segment>
    <segment id="38">Trﾃδｪs carros foram recuperados e 17 identificados durante a Operaﾃδｧﾃδ｣o Leoa.</segment>
    <segment id="39">ﾃ｢竄ｬﾅ迭ecebemos a informaﾃδｧﾃδ｣o de que alguns desses carros estﾃδ｣o sendo usados em campanhas polﾃδｭticas no interiorﾃ｢竄ｬ</segment>
    <segment id="40">, informa o delegado da Delegacia de Repressﾃδ｣o a Furtos e Roubos de Veﾃδｭculos (DRFRV)</segment>
    <segment id="41">, Nilton Borba.</segment>
    <segment id="42">Na tarde de ontem</segment>
    <segment id="43">, Valdeci Costa de Jesus</segment>
    <segment id="44">, Luﾃδｭs Claudio Santos da Silva</segment>
    <segment id="45">, Josﾃδｩ Rodrigues</segment>
    <segment id="46">, Edcarlos dos Santos e a filha de Jaﾃδｭra foram apresentados ﾃδ imprensa na sede da PC.</segment>
    <segment id="47">Eles negam envolvimento.</segment>
    <segment id="48">Tambﾃδｩm foram presos Josﾃδｩ Sandro</segment>
    <segment id="49">, Cleiton Correia Gomes</segment>
    <segment id="50">, Valteilton Alves Cruz</segment>
    <segment id="51">, Wellington dos Santos Silva e Edemir Cardoso dos Santos.</segment>
    <segment id="52">Loura dava um grau no salﾃδ｣o
Jaﾃδｭra foi presa quando entregava um carro roubado</segment>
    <segment id="53">, um Voyage</segment>
    <segment id="54">, a Edemir Cardoso dos Santos</segment>
    <segment id="55">, em Juazeiro (a 512 km da capital).</segment>
    <segment id="56">Segundo a polﾃδｭcia</segment>
    <segment id="57">, ela assumiu a lideranﾃδｧa do bando e disse que sempre passava no salﾃδ｣o de beleza antes de viajar para entregar os veﾃδｭculos roubados.</segment>
    <segment id="58">Isso para nﾃδ｣o levantar suspeitas</segment>
    <segment id="59">casocaso fosse parada em alguma blitz.</segment>
    <segment id="60">Alﾃδｩm de liderar o bando</segment>
    <segment id="61">, ela namorava com os bandidos.</segment>
    <segment id="62">Um deles era Ilmar Brito Tavares</segment>
    <segment id="63">, um dos responsﾃδ｡veis pelos roubos dos veﾃδｭculos.</segment>
    <segment id="64">Ilmar foi morto no sﾃδ｡bado</segment>
    <segment id="65">, em troca de tiros com a polﾃδｭcia.</segment>
    <segment id="66">Vai uma pizza</segment>
    <segment id="67">, aﾃδｭ?</segment>
    <segment id="68">Conforme a polﾃδｭcia</segment>
    <segment id="69">, a participaﾃδｧﾃδ｣o de Jaiara Fagundes de Araﾃδｺjo era anotar placas de veﾃδｭculos dos mesmo modelos roubados pelo bando.</segment>
    <segment id="70">ﾃ｢竄ｬﾅ摘la anotava a placa e informava ﾃδ mﾃδ｣e para a falsificaﾃδｧﾃδ｣o do documentoﾃ｢竄ｬ</segment>
    <segment id="71">, afirma o delegado do DCCP</segment>
    <segment id="72">, Cleandro Pimenta.</segment>
    <segment id="73">ﾃ｢竄ｬﾅ摘u</segment>
    <segment id="74">sﾃδｳ sou a filha dela.</segment>
    <segment id="75">Nﾃδ｣o tenho nada a ver com isso.</segment>
    <segment id="76">Eu faﾃδｧo faculdade de psicologiaﾃ｢竄ｬ</segment>
    <segment id="77">, insistia Jaiara.</segment>
    <segment id="78">Alﾃδｩm das atividades no bando</segment>
    <segment id="79">, Jaﾃδｭra mantinha um estabelecimento comercial: a Pizzaria Veritﾃδ｡</segment>
    <segment id="80">, no Nordeste de Amaralina</segment>
    <segment id="81">, que era administrada pela filha e o genro dela.</segment>
    <segment id="82">Inclusive</segment>
    <segment id="83">, parte do dinheiro proveniente da venda dos veﾃδｭculos era investido por Jaﾃδｭra no estabelecimento.</segment>
