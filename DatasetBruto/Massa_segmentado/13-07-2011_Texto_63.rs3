  <rst>
    <segment id="1">Dança estourada</segment>
    <segment id="2">Bonde do Serrote é febre na internet</segment>
    <segment id="3">O grupo investe agora na produção de novos clipes</segment>
    <segment id="4">, como</segment>
    <segment id="5">como o da dança do cemitério.</segment>
    <segment id="6">Confira!</segment>
    <segment id="7">Muitos bairros de Salvador fazem um “baba de saia”</segment>
    <segment id="8">, quando homens jogam futebol vestidos de mulher.</segment>
    <segment id="9">Mas uma partida de travestidos na quadra de Nova Brasília</segment>
    <segment id="10">, na Estrada Velha</segment>
    <segment id="11">, virou um clipe na internet que já tem 1 milhão de acessos no YouTube.</segment>
    <segment id="12">Ermínio Féliz</segment>
    <segment id="13">, 20 anos</segment>
    <segment id="14">, Diego Rodrigues</segment>
    <segment id="15">, 19, Bruno Roberto</segment>
    <segment id="16">, 16, e Rafael Costa</segment>
    <segment id="17">, 22, deixaram de ser colegas de baba para virarem o Bonde do Serrote.</segment>
    <segment id="18">Eles ficaram famosos com a coreografia da música “Passa o Serrote”</segment>
    <segment id="19">, da banda cearense Forró Balancear.</segment>
    <segment id="20">“Começou</segment>
    <segment id="21">comocomo uma brincadeira no baba e</segment>
    <segment id="22">, ao ver os vídeos</segment>
    <segment id="23">, percebi que podia rolar um clipe bacana”</segment>
    <segment id="24">, diz Ermínio</segment>
    <segment id="25">, editor e ator principal do vídeo</segment>
    <segment id="26">, que já rendeu participações do bonde em programas nacionais de TV</segment>
    <segment id="27">, como</segment>
    <segment id="28">como o de Eliana</segment>
    <segment id="29">, no SBT.</segment>
    <segment id="30">Os meninos viraram celebridade em Nova Brasília.</segment>
    <segment id="31">“</segment>
    <segment id="32">A gente começou a gravar mais vídeos e vender CDs pela vizinhança”</segment>
    <segment id="33">, conta Ermínio</segment>
    <segment id="34">, que quis imitar o clipe “Thriller”</segment>
    <segment id="35">, de  Michael Jackson</segment>
    <segment id="36">, e gravou o vídeo da música “Dança do Cemitério” no meio do cemitério Quinta dos Lázaros.</segment>
    <segment id="37">“</segment>
    <segment id="38">Quando o coveiro viu a gente dançando nos túmulos</segment>
    <segment id="39">, nos colocou para fora”</segment>
    <segment id="40">, diz.</segment>
    <segment id="41">Agora, o bonde aproveita o sucesso com a mulherada.</segment>
    <segment id="42">“Passamos o serrote em quem vier”</segment>
    <segment id="43">, brinca.</segment>
    <segment id="44">Turnê e DVD</segment>
    <segment id="45">A banda Bonde dos Playboys apostou no sucesso das coreografias dos garotos do serrote e</segment>
    <segment id="46">, agora</segment>
    <segment id="47">, eles fazem shows Brasil afora com o grupo.</segment>
    <segment id="48">“Vamos tocar em Tocantins</segment>
    <segment id="49">, no interior da Bahia e gravar um DVD dia 6 de agosto</segment>
    <segment id="50">, em São Paulo”</segment>
    <segment id="51">, conta o vocalista Lucimar.</segment>
    <segment id="52">OPINE:

O que você achou da dancinha criada pelos meninos do bairro de Nova Brasília?</segment>
    <segment id="53">Comente!</segment>
  </rst>
</analysis>