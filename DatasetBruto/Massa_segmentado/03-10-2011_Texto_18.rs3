  <rst>
    <segment id="1">Fluminense espera encerrar 11 meses sem vencer clássicos
RIO - O Fluminense venceu o clássico por 1 a 0 e continua líder do Brasileiro.</segment>
    <segment id="2">O gol de Tartá foi suficiente para superar o Vasco e os adversários na disputa pelo título.</segment>
    <segment id="3">Jornais</segment>
    <segment id="4">, sites</segment>
    <segment id="5">, rádios e TVs escreveram ou falaram algo parecido às primeiras linhas deste texto sobre o jogo entre Fluminense e Vasco em 7 de novembro de 2010</segment>
    <segment id="6">, no Engenhão.</segment>
    <segment id="7">Foi a última vitória do tricolor em clássicos regionais.</segment>
    <segment id="8">Desde aquele dia</segment>
    <segment id="9">, o time jogou mais sete vezes contra os três rivais cariocas: empatou quatro e perdeu três.</segment>
    <segment id="10">Domingo</segment>
    <segment id="11">, contra o Flamengo</segment>
    <segment id="12">, a derrota não é uma opção.</segment>
    <segment id="13">Se perder</segment>
    <segment id="14">, o time deixará a zona de classificação para a Libertadores e completará um ano sem saber o que é ganhar de Flamengo</segment>
    <segment id="15">, Vasco e Botafogo.

- Eu acho que isto não quer dizer nada.</segment>
    <segment id="16">Estas estatísticas existem para ser quebradas.</segment>
    <segment id="17">Vamos encarar mais este clássico com um jogo normal.</segment>
    <segment id="18">Mas posso dizer que o Fluminense vai entrar para ganhar - disse o técnico Abel Braga.</segment>
    <segment id="19">A vitória só será possível com gols.</segment>
    <segment id="20">Sem Fred</segment>
    <segment id="21">, convocado para os amistosos com a seleção</segment>
    <segment id="22">, Abel Braga confirmou a entrada de Rafael Moura.

- O Rafael Moura vai começar o jogo.</segment>
    <segment id="23">Disto eu não tenho dúvida.</segment>
    <segment id="24">Só não vou dar o time completo...</segment>
    <segment id="25">Ele é um jogador que tem nos ajudado bastante e já assimilou bem a parte tática - explicou o treinador.</segment>
    <segment id="26">Se o parceiro de ataque de Rafael Moura for diferente de Rafael Sobis</segment>
    <segment id="27">, a estratégia será a mesma de todas as partidas do Fluminense neste Campeonato Brasileiro.</segment>
    <segment id="28">Apesar de poder empatar para permanecer na quinta colocação</segment>
    <segment id="29">, porque</segment>
    <segment id="30">porque supera o Flamengo em vitórias</segment>
    <segment id="31">, três pontos colocariam o Fluminense mais perto do topo</segment>
    <segment id="32">, ainda mais</segment>
    <segment id="33">sese os resultados da rodada deixaram os líderes por baixo.

-</segment>
    <segment id="34">A gente não muda esquema e nem vou entrar para empatar.</segment>
    <segment id="35">Só empatamos duas vezes neste competição</segment>
    <segment id="36">, o que não é normal</segment>
    <segment id="37">, masmas prova que não temos esta preocupação com o empate - disse Abel.</segment>
    <segment id="38">Depois dos 90 minutos do Fla-Flu do primeiro turno</segment>
    <segment id="39">, com vitória rubro-negra por 1 a 0</segment>
    <segment id="40">, gol de Willians</segment>
    <segment id="41">, o sentimento era de frustração pelos pontos e tempo perdidos.</segment>
    <segment id="42">O fato de o time ter jogado bem</segment>
    <segment id="43">, criado a maioria das chances de perigo</segment>
    <segment id="44">, masmas não conseguir fazer o essencial no futebol fez Abel Braga lembrar que gol não pode ser detalhe.

- Fomos melhor que o Flamengo.</segment>
    <segment id="45">Mas o que vale é bola dentro... - declarou Abel.

Tartá</segment>
    <segment id="46">, Conca</segment>
    <segment id="47">, Muricy Ramalho...</segment>
    <segment id="48">Personagens de um passado recente que estiveram naquela última vitória em clássicos regionais nem fazem mais parte do clube.</segment>
    <segment id="49">Eles saíram</segment>
    <segment id="50">, masmas a escrita continua.</segment>
    <segment id="51">Sob o comando de Abel</segment>
    <segment id="52">, o time jogou três clássicos no Brasileiro.</segment>
    <segment id="53">Empatou em 1 a 1 com o Vasco</segment>
    <segment id="54">, e perdeu do Flamengo (1 a 0) e Botafogo (2 a 1).</segment>
    <segment id="55">No Campeonato Carioca</segment>
    <segment id="56">, uma derrota para o Botafogo e três empates.</segment>
    <segment id="57">No último deles</segment>
    <segment id="58">, na semifinal da Taça Rio contra o Flamengo</segment>
    <segment id="59">, o jogo terminou empatado em 1 a 1 no tempo normal</segment>
    <segment id="60">, masmas o tricolor perdeu nos pênaltis (5 a 4).</segment>
    <segment id="61">Quando olha a tabela do Brasileiro</segment>
    <segment id="62">, o técnico vê o passado</segment>
    <segment id="63">, masmas sabe que os pontos perdidos não podem voltar.

- Algumas derrotas</segment>
    <segment id="64">, ao meu ver</segment>
    <segment id="65">, foram injustas.</segment>
    <segment id="66">O próprio jogo com o Flamengo.</segment>
    <segment id="67">Santos</segment>
    <segment id="68">, no primeiro turno.</segment>
    <segment id="69">Grêmio</segment>
    <segment id="70">, Bahia</segment>
    <segment id="71">, Atlético-MG...</segment>
    <segment id="72">No esporte onde justiça pode não ter nada a ver com o resultado</segment>
    <segment id="73">, os jogos entram para a história pelo que termina escrito no placar.</segment>
    <segment id="74">Depois do Flamengo</segment>
    <segment id="75">, o Fluminense jogará com o Vasco na penúltima rodada (27 de novembro) e Botafogo</segment>
    <segment id="76">, na última (4 de dezembro).</segment>
    <segment id="77">Mais duas chances de relegar a estatística à fria análise do papel no</segment>
    <segment id="78">casocaso de algo dar errado domingo.</segment>
    <segment id="79">Sem Willians</segment>
    <segment id="80">, Ronaldinho Gaúcho e Aírton</segment>
    <segment id="81">, o Flamengo pode parecer mais frágil diante de um tricolor obstinado a zerar a contagem do tempo sem vencer clássicos antes de chegar aos 12 meses.</segment>
    <segment id="82">Abel não</segment>
    <segment id="83">sese engana:

- Eu tenho que me preocupar com o Fluminense.</segment>
    <segment id="84">Eu não tenho o Fred...</segment>
    <segment id="85">E não lamento.</segment>
    <segment id="86">É claro que eu gostaria de contar com o Fred</segment>
    <segment id="87">, quem não gostaria?</segment>
    <segment id="88">Mas eu confio sempre em quem vai entrar.</segment>
  </rst>
</analysis>