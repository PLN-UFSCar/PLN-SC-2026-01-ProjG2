  <rst>
    <segment id="1">Pizzaiolo morto ao defender a irmﾃδ｣
Vﾃδｭtima foi assassinada apﾃδｳs brigar com o cunhado</segment>
    <segment id="2">, que agredia a mulher</segment>
    <segment id="3">Uma briga entre marido e mulher teve um desfecho trﾃδ｡gico</segment>
    <segment id="4">, na madrugada de ontem</segment>
    <segment id="5">, na Rua dos Beneditinos</segment>
    <segment id="6">, no bairro de Dom Avelar - no Largo de Dom Avelar.</segment>
    <segment id="7">O pizzaiolo Alexandro Silva de Souza</segment>
    <segment id="8">, 39 anos</segment>
    <segment id="9">, foi assassinado pelo cunhado de prenome Ivenilson</segment>
    <segment id="10">, quando tentava evitar que a irmﾃδ｣ fosse agredida pelo marido.</segment>
    <segment id="11">Alexandro foi atingido cinco vezes no pescoﾃδｧo e nas costas por um objeto perfuro cortante</segment>
    <segment id="12">, semelhante a uma faca.</segment>
    <segment id="13">Contudo</segment>
    <segment id="14">, a delegada Marilene Lima</segment>
    <segment id="15">, do Departamento de Homicﾃδｭdios (DHPP)</segment>
    <segment id="16">, informou que os peritos do Departamento de Polﾃδｭcia Tﾃδｩcnica (DPT) nﾃδ｣o souberam precisar qual foi a arma usada no crime.</segment>
    <segment id="17">Segundo testemunhas</segment>
    <segment id="18">, Alexandro e a irmﾃδ｣ passaram a noite bebendo em alguns bares que ficam no local e</segment>
    <segment id="19">, por volta das 5h30</segment>
    <segment id="20">, Ivenilson foi atrﾃδ｡s da mulher e tentou levﾃδ｡-la ﾃδ forﾃδｧa para casa.</segment>
    <segment id="21">Ne entanto</segment>
    <segment id="22">, Alexandro nﾃδ｣o gostou das agressﾃδｵes contra a irmﾃδ｣ e agrediu o cunhado com  murros.</segment>
    <segment id="23">O irmﾃδ｣o deu soco nele com a chave da moto</segment>
    <segment id="24">, ele foi no carro</segment>
    <segment id="25">, pegou alguma coisa cortante e desferiu vﾃδ｡rios golpes na vﾃδｭtima</segment>
    <segment id="26">, diz a delegada.
'Parecia filme de terrorﾃ｢竄ｬ邃｢</segment>
    <segment id="27">Um comerciante que trabalha no local disse que</segment>
    <segment id="28">, apﾃδｳs matar o cunhado</segment>
    <segment id="29">, Ivenilson fugiu em um Fox preto.</segment>
    <segment id="30">Foi uma coisa feia</segment>
    <segment id="31">, parecia filme de terror.</segment>
    <segment id="32">O rapaz colocava a mﾃδ｣o no pescoﾃδｧo e o sangue espirrava</segment>
    <segment id="33">, relembra um testemunha</segment>
    <segment id="34">, sem se</segment>
    <segment id="35">se identificar.</segment>
    <segment id="36">De acordo com uma moradora da rua</segment>
    <segment id="37">, que pediu anonimanto</segment>
    <segment id="38">, este foi o segundo homicﾃδｭdio</segment>
    <segment id="39">, na mesma regiﾃδ｣o</segment>
    <segment id="40">, em dois meses.</segment>
    <segment id="41">Dom Avelar nﾃδ｣o aguenta.</segment>
    <segment id="42">Estes bares ficam atﾃδｩ de madrugada com o som nas alturas.</segment>
    <segment id="43">Rola atﾃδｩ trﾃδ｡fico de drogas</segment>
    <segment id="44">, declarou ela</segment>
    <segment id="45">, demonstrando indignaﾃδｧﾃδ｣o.</segment>
