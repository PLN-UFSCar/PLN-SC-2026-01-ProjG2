  <rst>
    <segment id="1">Tráfico tem baixa de uma tonelada</segment>
    <segment id="2">Polícia apreendeu maconha na Portelinha</segment>
    <segment id="3">, em Pau da Lima</segment>
    <segment id="4">Uma tonelada de maconha</segment>
    <segment id="5">, conforme estimativa da Polícia Civil</segment>
    <segment id="6">,  foi apreendida em Salvador</segment>
    <segment id="7">, na  manhã de ontem</segment>
    <segment id="8">, durante uma operação conjunta entre policiais da Delegacia de Repressão a Furtos e Roubos (DRFR)</segment>
    <segment id="9">, do Departamento de Narcóticos (Dnarc) e da Coordenação de Operações Especiais (COE) na Portelinha</segment>
    <segment id="10">, em Pau da Lima.</segment>
    <segment id="11">A operação resultou também na prisão de um homem de prenome Adriano</segment>
    <segment id="12">, que foi preso</segment>
    <segment id="13">, literalmente</segment>
    <segment id="14">, com a boca na botija.</segment>
    <segment id="15">Segundo um policial que participou da operação</segment>
    <segment id="16">, Adriano foi encontrado dentro de um buraco de cerca de três metros de profundidade</segment>
    <segment id="17">, quando retirava parte da maconha  que lá estava escondida.</segment>
    <segment id="18">“Ele contou que foi contratado só  para cavar o buraco para  guardar a droga e depois retirar.</segment>
    <segment id="19">E recebeu R$ 300 pelo serviço.</segment>
    <segment id="20">Quando foi preso</segment>
    <segment id="21">, ele estava retirando  a maconha por causa da chuva”</segment>
    <segment id="22">, contou o policial.</segment>
    <segment id="23">Um comparsa de Adriano conseguiu fugir.</segment>
    <segment id="24">Do Paraguai</segment>
    <segment id="25">A apreensão causou um prejuízo de</segment>
    <segment id="26">, pelo menos</segment>
    <segment id="27">, R$ 400 mil ao tráfico  (o preço mínimo do quilo da maconha custa R$ 400</segment>
    <segment id="28">, conforme o Denarc).</segment>
    <segment id="29">Parte da droga estava prensada em tabletes de</segment>
    <segment id="30">, aproximadamente</segment>
    <segment id="31">, 1kg.</segment>
    <segment id="32">De acordo com policiais que participaram da operação</segment>
    <segment id="33">, o tipo de prensa indica que a droga é de origem paraguaia.</segment>
    <segment id="34">Outra parte estava embalada em pequenas quantidades para venda.</segment>
    <segment id="35">“Fomos averiguar uma informação de roubo de carga e encontramos essa quantidade de maconha”</segment>
    <segment id="36">, afirmou o titular da DRFR</segment>
    <segment id="37">,  delegado  Marcos César.</segment>
  </rst>
</analysis>