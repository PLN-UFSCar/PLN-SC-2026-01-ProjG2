  <rst>
    <segment id="1">Quico já pegou Dona Florinda</segment>
    <segment id="2">Foi sem querer querendo</segment>
    <segment id="3">Uma revelação chocou os fãs do seriado mexicano Chaves</segment>
    <segment id="4">, que até hoje é exibido no SBT.</segment>
    <segment id="5">A relação entre Dona Florinda e Quico era bem mais que apenas de mãe e filho.</segment>
    <segment id="6">Carlos Villagrán</segment>
    <segment id="7">, que interpretava o Quico</segment>
    <segment id="8">, declarou no  programa da televisão peruana “La Noche</segment>
    <segment id="9">Es</segment>
    <segment id="10">Mia</segment>
    <segment id="11">”</segment>
    <segment id="12">, da emissora Latina</segment>
    <segment id="13">, que teve um</segment>
    <segment id="14">casocaso com a atriz Florinda Meza</segment>
    <segment id="15">, intérprete da personagem Dona Florinda</segment>
    <segment id="16">, na mesma série humorística.</segment>
    <segment id="17">"</segment>
    <segment id="18">Eu não vou negar</segment>
    <segment id="19">, foi há muito tempo e durante as gravações de Chaves</segment>
    <segment id="20">,” disse Villagrán.</segment>
    <segment id="21">A declaração causou espanto</segment>
    <segment id="22">porque</segment>
    <segment id="23">porque Florinda Meza é casada com Roberto Bolaños</segment>
    <segment id="24">, o criador do programa e o ator que interpretava o astro Chaves.</segment>
    <segment id="25">Ou seja</segment>
    <segment id="26">, além de ter um</segment>
    <segment id="27">casocaso com o filho da ficção</segment>
    <segment id="28">, Florinda ainda colocou um belo par de chifres na cabeça do Chaveco.</segment>
    <segment id="29">A verdade é que os intérpretes de Quico e Chaves não</segment>
    <segment id="30">sese falam há muito tempo e são inimigos declarados.</segment>
    <segment id="31">Tanto que Roberto Bolaños  demitiu Villagrán do seriado e tentou impedir que o ex-colega de elenco interpretasse Quico em outros programas de televisão e eventos</segment>
    <segment id="32">, masmas não conseguiu.</segment>
    <segment id="33">Na entrevista reveladora</segment>
    <segment id="34">, Villagrán anunciou que vai</segment>
    <segment id="35">sese aposentar.</segment>
    <segment id="36">O ator</segment>
    <segment id="37">, que tem 67 anos</segment>
    <segment id="38">, há mais de 40 encarna o personagem Quico e atua em circos na América Latina.</segment>
    <segment id="39">“Eu não sou o mesmo de antes e as pessoas merecem respeito”</segment>
    <segment id="40">, disse ele.</segment>
    <segment id="41">Chaves não teve capítulo final</segment>
    <segment id="42">O seriado Chaves começou em 1971</segment>
    <segment id="43">, no México</segment>
    <segment id="44">, um ano após a estreia do também famoso “Chapolim”.</segment>
    <segment id="45">Depois de algumas mudanças no elenco</segment>
    <segment id="46">, em 1983 as gravações foram encerradas e os fãs lamentam até hoje a falta de um episódio especial.</segment>
  </rst>
</analysis>