    <segment id="1">O bumbum baiano
Priscilla Santana representa a Bahia no Miss Bumbum Brasil</segment>
    <segment id="2">Com a promessa de encontrar o pandeiro mais bonito do Brasil</segment>
    <segment id="3">, o concurso Miss Bumbum Brasil 2011 elegeu Priscilla Santana</segment>
    <segment id="4">comocomo a representante da Bahia.</segment>
    <segment id="5">A bela fez por merecer: o bumbum dela merece até torcida organizada.</segment>
    <segment id="6">Não só o balaio</segment>
    <segment id="7">, pois</segment>
    <segment id="8">pois o conteúdo todo é de babar!</segment>
