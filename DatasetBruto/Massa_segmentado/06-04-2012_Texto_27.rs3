  <rst>
    <segment id="1">Novas unidades do Into e da Rede Sarah operam abaixo da capacidade
RIO - Dois centros de referência e até excelência</segment>
    <segment id="2">, com instalações acima dos padrões de outras unidades hospitalares da rede pública</segment>
    <segment id="3">, estão funcionando com índice abaixo da capacidade instalada.</segment>
    <segment id="4">Conforme noticiou Ancelmo Gois em sua coluna</segment>
    <segment id="5">, no GLOBO</segment>
    <segment id="6">, o novo Instituto Nacional de Traumato-Ortopedia (Into)</segment>
    <segment id="7">, na Avenida Brasil</segment>
    <segment id="8">, e a unidade Rio da Rede Sarah</segment>
    <segment id="9">, na Barra da Tijuca</segment>
    <segment id="10">, apresentam baixa produtividade.</segment>
    <segment id="11">Sarah poderia fazer 20 mil atendimentos ao mês

Inaugurado há quatro meses</segment>
    <segment id="12">, o Into realiza uma média de 550 cirurgias por mês</segment>
    <segment id="13">masmas tem capacidade para duplicar esse número.</segment>
    <segment id="14">Segundo Germana Bahr</segment>
    <segment id="15">, uma das coordenadoras da transição para as novas instalações</segment>
    <segment id="16">, a ampliação do atendimento está sendo gradual e dentro do prazo.</segment>
    <segment id="17">Ainda segundo ela</segment>
    <segment id="18">, uma consultoria foi contratada para fazer o estudo sobre a adaptação nas novas instalações.</segment>
    <segment id="19">O resultado é que</segment>
    <segment id="20">, no prazo de um ano</segment>
    <segment id="21">, o Into estará funcionando com 85% de sua capacidade.</segment>
    <segment id="22">Já a Rede Sarah</segment>
    <segment id="23">, inaugurada em 2009</segment>
    <segment id="24">, com um moderno modelo de gestão da unidade para atender gratuitamente 20 mil pacientes por mês</segment>
    <segment id="25">, realizou no ano passado 136.230 atendimentos</segment>
    <segment id="26">, uma média 11</segment>
    <segment id="27">,3 mil por mês.</segment>
    <segment id="28">A instituição informou que</segment>
    <segment id="29">, devido à amplitude da atenção dada a cada paciente</segment>
    <segment id="30">, o aumento do número de atendimentos é gradual.</segment>
    <segment id="31">O acolhimento é feito</segment>
    <segment id="32">, segundo a direção</segment>
    <segment id="33">, no sentido de respeitar os potenciais individuais de cada paciente e trabalhar a reabilitação de acordo com as afinidades</segment>
    <segment id="34">, perfil intelectual</segment>
    <segment id="35">, objetivos a serem perseguidos à partir da mudança provocada pela doença.</segment>
    <segment id="36">Into: 22 mil pacientes à espera por cirurgia</segment>
    <segment id="37">Enquanto as unidades</segment>
    <segment id="38">sese adaptam</segment>
    <segment id="39">, a fila de espera é cada vez maior.</segment>
    <segment id="40">No Into</segment>
    <segment id="41">, são 22 mil que aguardam por uma cirurgia</segment>
    <segment id="42">, alguns há mais de dois anos.</segment>
    <segment id="43">Segundo Germana</segment>
    <segment id="44">, essas pessoas começam a ser convocadas para uma reavaliação</segment>
    <segment id="45">, com o objetivo de agilizar a cirurgia quando chegar a vez delas.</segment>
    <segment id="46">Germana observa ainda que a mega estrutura do novo hospital exige readaptações e também a contratação de profissionais.</segment>
    <segment id="47">Segundo ela</segment>
    <segment id="48">, a direção da unidade tem conversado com o Ministério da Saúde e</segment>
    <segment id="49">, à medida que foram ativando os setores do hospital</segment>
    <segment id="50">, mais pessoas serão contratadas.</segment>
    <segment id="51">A acessibilidade ao novo prédio - que ocupa área de 70 mil metros quadrados</segment>
    <segment id="52">, com prédios construídos num terreno anexo</segment>
    <segment id="53">, de 15 mil metros quadrados - é outro problema.</segment>
    <segment id="54">O Into construiu uma passarela de acesso na Avenida Brasil - com rampas -</segment>
    <segment id="55">, masmas ainda há problemas.</segment>
    <segment id="56">Para facilitar o acesso dos pacientes</segment>
    <segment id="57">, a maioria tem problemas de locomoção</segment>
    <segment id="58">, foi instalado um elevador na rua.</segment>
    <segment id="59">No entanto</segment>
    <segment id="60">, apesar de não ter qualquer problema</segment>
    <segment id="61">, o elevador está fora de operação.</segment>
    <segment id="62">O Into já enviou um ofício a RioLuz para a instalação da fiação elétrica.</segment>
    <segment id="63">Um ascensorista vai operar o equipamento.</segment>
    <segment id="64">A coordenadora reconhece</segment>
    <segment id="65">, porém</segment>
    <segment id="66">porém, que ainda há problemas na área externa</segment>
    <segment id="67">, masmas disse que as conversas com o consórcio estão em andamento</segment>
    <segment id="68">para que</segment>
    <segment id="69">para que sejam realizadas melhorias.</segment>
  </rst>
</analysis>