  <rst>
    <segment id="1">Dirigente grevista é preso por seu major</segment>
    <segment id="2">O policial vai responder pelos crimes de formação de quadrilha e roubo de viaturas</segment>
    <segment id="3">O Soldado da Companhia de Polícia de Proteção Ambiental da Polícia Militar (Coppa)</segment>
    <segment id="4">Alvin dos Santos Silva</segment>
    <segment id="5">, apontado pela justiça federal</segment>
    <segment id="6">comocomo um dos integrantes do movimento grevista dos policiais militares</segment>
    <segment id="7">, foi preso na madrugada de ontem (5).</segment>
    <segment id="8">Acusado de formação de quadrilha e roubo de patrimônio público (viaturas)</segment>
    <segment id="9">, o policial é o primeiro a sofrer o cumprimento dos 12 mandados de prisão expedidos no estado da Bahia.</segment>
    <segment id="10">Segundo o tenente coronel Cunha</segment>
    <segment id="11">, da Assessoria de Comunicação do Exército</segment>
    <segment id="12">, o soldado foi informado sobre o mandado pelo Major Nilton Machado</segment>
    <segment id="13">, comandante da Coppa e de quem Alvin era motorista.</segment>
    <segment id="14">Machado o orientou e disse que ele seria encaminhado para a Corregedoria da PM e que teria direito a ampla defesa.</segment>
    <segment id="15">Depois de ter os seus direitos lidos</segment>
    <segment id="16">, o soldado foi detido e encaminhado ao Cartório da Polícia do Exército</segment>
    <segment id="17">, no Imbuí</segment>
    <segment id="18">, onde</segment>
    <segment id="19">sese encontra custodiado.</segment>
    <segment id="20">De acordo com o advogado Bruno Bahia</segment>
    <segment id="21">, da Associação de Policiais Militares da Bahia (APPM)</segment>
    <segment id="22">, que representa  Alvin</segment>
    <segment id="23">, a única relação do PM com a  Associação dos Policiais</segment>
    <segment id="24">, Bombeiros e dos seus Familiares do Estado Bahia (Aspra)</segment>
    <segment id="25">, foi a assinatura da ata de fundação da entidade</segment>
    <segment id="26">, há cerca de três anos.</segment>
    <segment id="27">Outra versão: Policial nega envolvimento</segment>
    <segment id="28">“</segment>
    <segment id="29">Foi um ato de incompetência do governo e do poder judiciário.</segment>
    <segment id="30">Ele estava trabalhando e não participou do movimento”</segment>
    <segment id="31">, defende o advogado Bruno Bahia.</segment>
    <segment id="32">O major Nilton Machado</segment>
    <segment id="33">, superior hierárquico do preso</segment>
    <segment id="34">, não quis falar sobre a conduta do policial e que informações sobre a prisão de seu comandado só por meio da Assessoria de Comunicação da PM.</segment>
    <segment id="35">O presidente da Aspra</segment>
    <segment id="36">, Marco Prisco</segment>
    <segment id="37">, confirma que Alvin já foi diretor da Aspra</segment>
    <segment id="38">, masmas não pertence mais à entidade.</segment>
    <segment id="39">Segundo Prisco</segment>
    <segment id="40">, o PM trabalhou todos os dias da greve com o comandante da Coppa.</segment>
    <segment id="41">Procurados no interior</segment>
    <segment id="42">O clima entre os grevistas concentrados em frente ao 1º Batalhão de PM de Feira de Santana na madrugada de ontem era de muita tensão</segment>
    <segment id="43">, em virtude dos boatos do possível cumprimento de mandato de prisão contra Edianari Márcio Almeida Santos e Josafá Ramos do Santos</segment>
    <segment id="44">, ambos  membros da diretoria da Aspra e que</segment>
    <segment id="45">sese encontram à frente do momvimento na cidade.</segment>
    <segment id="46">De acordo com o ministro da Justiça</segment>
    <segment id="47">, José Eduardo Cardozo</segment>
    <segment id="48">, já foram disponibilizadas vagas em presídios federais para abrigar os presos.</segment>
  </rst>
</analysis>