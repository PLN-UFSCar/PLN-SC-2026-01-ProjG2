  <rst>
    <segment id="1">Liberdade festeja prisão de Bruxo
Polícia Civil monta megaoperação e prende o homemque aterrorizava a Avenida Peixe</segment>
    <segment id="2">Um dia após o MASSA!</segment>
    <segment id="3">divulgar as barbaridades cometidas pelo traficante Bruno Ramos Figueiredo</segment>
    <segment id="4">, 22 anos</segment>
    <segment id="5">, o Bruxo</segment>
    <segment id="6">, contra a comunidade da Avenida Peixe</segment>
    <segment id="7">, no bairro Liberdade</segment>
    <segment id="8">, a Polícia Civil baiana mobilizou uma megaoperação e conseguiu prender o criminoso</segment>
    <segment id="9">, na madrugada de ontem.</segment>
    <segment id="10">Bruno foi detido no posto da Polícia Rodoviária Federal</segment>
    <segment id="11">, na BR-324</segment>
    <segment id="12">, ao tentar fugir para Alagoinhas.</segment>
    <segment id="13">Ele estava dentro do carro Celta</segment>
    <segment id="14">, cor prata (JQV-8576).</segment>
    <segment id="15">Junto com ele</segment>
    <segment id="16">, na BR-324</segment>
    <segment id="17">, também foram presos Ramon Almeida Campos</segment>
    <segment id="18">, 28, dono e piloto do Celta</segment>
    <segment id="19">, e a namorada de Bruno</segment>
    <segment id="20">, Roseane Barbosa Dates</segment>
    <segment id="21">, 28.</segment>
    <segment id="22">Titular da Delegacia de Repressão a Furtos e Roubos</segment>
    <segment id="23">, o delegado Marcos Cesar da Silva destaca que</segment>
    <segment id="24">, oficialmente</segment>
    <segment id="25">, Bruno já é acusado</segment>
    <segment id="26">comocomo o autor de 18 homicídios.</segment>
    <segment id="27">O delegado afirma que intensificou as investigações sobre Bruxo após o assalto contra a empresa de ônibus Barramar</segment>
    <segment id="28">, quando Bruno teria ajudado na fuga do comparsa Ralado.</segment>
    <segment id="29">“Já estávamos na cola dele.</segment>
    <segment id="30">Porém, estava sendo difícil conseguir prendê-lo.</segment>
    <segment id="31">Sempre que chegávamos na Avenida Peixe</segment>
    <segment id="32">, ele logo</segment>
    <segment id="33">sese escondia</segment>
    <segment id="34">, pois</segment>
    <segment id="35">pois tem muitos informantes do tráfico por ali.</segment>
    <segment id="36">Após a foto dele sair no jornal</segment>
    <segment id="37">, ele ficou com receio de ser preso e resolveu sair da toca para fugir.</segment>
    <segment id="38">Descobrimos que ele pretendia fugir e fizemos a operação na BR-324.</segment>
    <segment id="39">A reportagem do jornal foi boa por isso</segment>
    <segment id="40">, acabou ajudando</segment>
    <segment id="41">, porque</segment>
    <segment id="42">porque ele</segment>
    <segment id="43">sese movimentou</segment>
    <segment id="44">, saiu da toca”</segment>
    <segment id="45">, argumenta o delegado Marcos Cesar.</segment>
    <segment id="46">Bruxo nega ser matador.</segment>
    <segment id="47">“Eu trafico drogas para mim mesmo.</segment>
    <segment id="48">Não sou santo</segment>
    <segment id="49">, masmas 18 homicídios é demais.</segment>
    <segment id="50">Nunca matei ninguém.</segment>
    <segment id="51">Tem vários Bruno na Liberdade.</segment>
    <segment id="52">Tudo o que rola lá dizem que sou eu.</segment>
    <segment id="53">Entrego a Deus”</segment>
    <segment id="54">, diz o acusado.</segment>
    <segment id="55">Ordens vêm do presídio</segment>
    <segment id="56">Segundo o delegado Marcos Cesar</segment>
    <segment id="57">, a quadrilha liderada por Bruno recebe e executa as ordens dadas pelos chefões de uma organização criminosa que estão detidos nos presídios de Salvador.</segment>
    <segment id="58">“Esses líderes comandam ações criminosas de dentro das penitenciárias.</segment>
    <segment id="59">Eles dão ordens para os comparsas aqui fora cometerem assaltos</segment>
    <segment id="60">, assassinatos</segment>
    <segment id="61">, roubos de bancos e extorsão de comerciantes.</segment>
    <segment id="62">Temos denúncia de que Bruno cobrava pedágio aos comerciantes da Avenida Peixe”</segment>
    <segment id="63">, relata o delegado.</segment>
    <segment id="64">De acordo com ele</segment>
    <segment id="65">, os chefões dos presídios atuam em Salvador</segment>
    <segment id="66">, Região Metropolitana e várias outras cidades da Bahia.</segment>
    <segment id="67">Segundo o delegado</segment>
    <segment id="68">, o chefão da facção estabelecida dentro dos presídios é Kléber Nóbrega Pereira</segment>
    <segment id="69">, o Kekeu</segment>
    <segment id="70">, que está detido.</segment>
    <segment id="71">Os outros líderes presos são: José Henrique de Souza Conceição</segment>
    <segment id="72">, o Papa Capim</segment>
    <segment id="73">; José Carlos Ferreira dos Santos</segment>
    <segment id="74">, o Zói ou Olho de Gato</segment>
    <segment id="75">; e Tiago Ferreira da Silva</segment>
    <segment id="76">, o Xerex ou Tiago Delegado.</segment>
    <segment id="77">Todos executam ordens para os comparsas aqui fora tocarem o terror no Estado.</segment>
    <segment id="78">Transferência urgente</segment>
    <segment id="79">O delegado Marcos Cesar afirma que vai solicitar à Justiça a transferência dos chefes da facção criminosa (que estão detidos) para presídios federais de segurança máxima.</segment>
    <segment id="80">No carro onde Bruxo tentava fugir</segment>
    <segment id="81">, a polícia apreendeu cerca de dois quilos de maconha e três revólveres calibre 38.</segment>
    <segment id="82">Uma submetralhadora e um revólver 38 foram encontrados na casa de Márcia Conceição Nascimento</segment>
    <segment id="83">, 41, no Pero Vaz.</segment>
    <segment id="84">Segundo a polícia</segment>
    <segment id="85">, Márcia também integra a quadrilha de Bruno.</segment>
    <segment id="86">A megaoperação para prender Bruxo contou com policiais civis do COE</segment>
    <segment id="87">, do Gerrc</segment>
    <segment id="88">, da Furtos e Roubos e da Polícia Rodoviária Federal.</segment>
  </rst>
</analysis>