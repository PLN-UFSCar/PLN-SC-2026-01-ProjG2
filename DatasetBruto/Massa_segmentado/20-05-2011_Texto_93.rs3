  <rst>
    <segment id="1">Marido de Nem Gorda ainda não foi preso</segment>
    <segment id="2">Grilinho reagiu à operação que resultou na prisão de sua mulher 

Apontado pela polícia</segment>
    <segment id="3">comocomo um dos autores do assassinato da idosa Alaíde Queiroz</segment>
    <segment id="4">, 70 anos</segment>
    <segment id="5">, no último sábado</segment>
    <segment id="6">, Alex Brito das Neves</segment>
    <segment id="7">, 21, conhecido</segment>
    <segment id="8">comocomo Grilinho</segment>
    <segment id="9">, continua  sendo procurado.</segment>
    <segment id="10">Alex é marido de Maria Lúcia dos Santos Gomes</segment>
    <segment id="11">, 36, a Nem Gorda.</segment>
    <segment id="12">Testemunhas informaram à polícia que o carro (Fiat Stilo</segment>
    <segment id="13">, preto</segment>
    <segment id="14">, placa JRC-2757) de Nem Gorda foi utilizado pelos assassinos de Alaíde.</segment>
    <segment id="15">Segundo o boletim de ocorrência registrado na Delegacia de Periperi</segment>
    <segment id="16">, Grilinho reagiu à operação que resultou na prisão da mulher</segment>
    <segment id="17">, atirando contra os policiais.</segment>
    <segment id="18">Fique ligado</segment>
    <segment id="19">Denúncias devem ser feitas pelo telefone 3235-0000.</segment>
