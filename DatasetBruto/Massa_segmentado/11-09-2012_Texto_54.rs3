  <rst>
    <segment id="1">Capeta inferniza BR-324 e vai em cana</segment>
    <segment id="2">O coisa-ruim de mentira foi dedurado por motoristas escabriados
Quem trafegou pela BR-324 nas imedia횄짠횄쨉es do munic횄짯pio de Am횄짤lia Rodrigues (a 70 km de Salvador)</segment>
    <segment id="3">, no 횄쨘ltimo dia 7 de setembro</segment>
    <segment id="4">, e viu o diabo ao volante de um caminh횄짙o-cegonha n횄짙o estava sofrendo alucina횄짠횄쨉es.</segment>
    <segment id="5">Um motorista decidiu</segment>
    <segment id="6">sese disfar횄짠ar com uma m횄징scara do satan횄징s e foi preso por inspetores da Pol횄짯cia Rodovi횄징ria Federal (PRF)</segment>
    <segment id="7">, por dire횄짠횄짙o perigosa.</segment>
    <segment id="8">Segundo os agentes da PRF</segment>
    <segment id="9">, o chifrudo de araque</segment>
    <segment id="10">, al횄짤m de assustar com a cara feia</segment>
    <segment id="11">, dirigia jogando outros ve횄짯culos para fora da estrada.</segment>
    <segment id="12">O capet횄짙o foi abordado na altura do KM-550.</segment>
    <segment id="13">Questionado pelos agentes sobre o motivo que o levou a trafegar na rodovia com uma m횄징scara</segment>
    <segment id="14">, o condutor informou que estava querendo apenas assustar os motoristas.</segment>
    <segment id="15">Ele disse</segment>
    <segment id="16">, ainda</segment>
    <segment id="17">, que trafegavam na rodovia e que teria sa횄짯do da f횄징brica de ve횄짯culos em Cama횄짠ari e seguia com destino a S횄짙o Paulo.</segment>
    <segment id="18">Diante do fato inusitado</segment>
    <segment id="19">, o infrator foi preso em flagrante e encaminhado 횄혻 Pol횄짯cia Judici횄징ria de Am횄짤lia Rodrigues.</segment>
    <segment id="20">Amante ia malocada no caminh횄짙o</segment>
    <segment id="21">O motorista dos infernos acabou entregando o jogo.</segment>
    <segment id="22">De acordo com entrevista do programa BA-TV</segment>
    <segment id="23">, da Rede Globo</segment>
    <segment id="24">, na verdade</segment>
    <segment id="25">, ele usava uma m횄징scara</segment>
    <segment id="26">porque</segment>
    <segment id="27">porque 횄짤 casado e viajava com uma amante no caminh횄짙o</segment>
    <segment id="28">, e n횄짙o queria ser reconhecido.</segment>
    <segment id="29">Ele ficou preso em Am횄짤lia Rodrigues e no mesmo dia foi liberado.</segment>
    <segment id="30">No entanto</segment>
    <segment id="31">, o capetinha 횄짤 aguardado hoje na delegacia do munic횄짯pio para prestar esclarecimentos sobre o</segment>
    <segment id="32">casocaso.</segment>
