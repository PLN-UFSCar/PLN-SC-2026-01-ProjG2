  <rst>
    <segment id="1">Dia de violência e sangue no Curuzu
Lucas Costa</segment>
    <segment id="2">, 17 anos</segment>
    <segment id="3">, que usuário de drogas</segment>
    <segment id="4">, foi assassinado na Liberdade</segment>
    <segment id="5">O adolescente Lucas Costa de Souza</segment>
    <segment id="6">, 17 anos</segment>
    <segment id="7">, tomou banho</segment>
    <segment id="8">, almoçou e saiu para comprar cigarro em uma mercearia próximo de casa</segment>
    <segment id="9">, na Rua Direta do Curuzu</segment>
    <segment id="10">, na localidade do Curuzu</segment>
    <segment id="11">, na Liberdade.</segment>
    <segment id="12">Pegou o cigarro</segment>
    <segment id="13">, saiu do estabelecimento e</segment>
    <segment id="14">, após percorrer menos de 10 metros</segment>
    <segment id="15">, caiu baleado e morreu alí mesmo</segment>
    <segment id="16">, na calçada de outro estabelecimento.

Lucas</segment>
    <segment id="17">, que era filho adotivo</segment>
    <segment id="18">, não estudava</segment>
    <segment id="19">, não trabalhava e era usuário de cocaína e maconha</segment>
    <segment id="20">, conforme informou o irmão adotivo dele</segment>
    <segment id="21">, Roberto Costa de Souza</segment>
    <segment id="22">, à polícia.</segment>
    <segment id="23">Apesar da movimentação da rua</segment>
    <segment id="24">, ninguém entre as  dezenas de pessoas revelou ter visto quem atirou no menino.</segment>
    <segment id="25">Sabe-se</segment>
    <segment id="26">se apenas que</segment>
    <segment id="27">, quem quer que tenha sido</segment>
    <segment id="28">, levou o par de sandálias da marca Kenner</segment>
    <segment id="29">, o RG e dinheiro de Lucas.</segment>
    <segment id="30">Mãe fica desesperada</segment>
    <segment id="31">Ao perceber que  objetos do filho haviam sido roubados</segment>
    <segment id="32">, a mãe adotiva</segment>
    <segment id="33">, que não tinha condições nenhuma de falar com a imprensa</segment>
    <segment id="34">, tirou a bermuda que o jovem usava.</segment>
    <segment id="35">Enquanto aguardava a perícia</segment>
    <segment id="36">, o único limite entre ela e o filho era a fita de isolamento.</segment>
    <segment id="37">Desesperada</segment>
    <segment id="38">, ao perceber que o corpo do filho havia sido levado pelo rabecão</segment>
    <segment id="39">, a senhora</segment>
    <segment id="40">sese jogou sobre o sangue na calçada</segment>
    <segment id="41">, gritando o nome do jovem.</segment>
    <segment id="42">“</segment>
    <segment id="43">Com base no que foi dito pela família</segment>
    <segment id="44">, acreditamos que a motivação pode ter sido  dívida de drogas”</segment>
    <segment id="45">, afirmou o delegado do Departamento de Homicídios e Proteção à Pessoa (DHPP)</segment>
    <segment id="46">, Reinaldo Moreira.</segment>
    <segment id="47">A  câmera de um estabelecimento pode ter registrado o crime.</segment>
  </rst>
</analysis>