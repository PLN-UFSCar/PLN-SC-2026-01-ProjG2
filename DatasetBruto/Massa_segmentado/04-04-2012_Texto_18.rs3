  <rst>
    <segment id="1">Rodoviários ameaçam parar Estação Pirajá</segment>
    <segment id="2">O módulo policial que funcionava no local foi desativado e assalto rola solto</segment>
    <segment id="3">Os rodoviários ameaçam parar a Estação Pirajá na próxima semana por 24 horas.</segment>
    <segment id="4">O dia da manifestação não foi definido</segment>
    <segment id="5">, de acordo com Hélio Ferreira</segment>
    <segment id="6">, tesoureiro do Sindicato dos Rodoviários da Bahia.</segment>
    <segment id="7">Ele explica que o ato é contra a falta de estrutura do terminal.

"</segment>
    <segment id="8">A Estação Pirajá está inoperante.</segment>
    <segment id="9">Não tem banheiro</segment>
    <segment id="10">, bebedouro e segurança.</segment>
    <segment id="11">O módulo policial que funcionava no local foi desativado.</segment>
    <segment id="12">Há muitos assaltos e pessoas armadas circulando por lá.</segment>
    <segment id="13">À noite</segment>
    <segment id="14">, os rodoviários e a população ficam à mercê da sorte"</segment>
    <segment id="15">, critica o sindicalista.</segment>
    <segment id="16">De acordo com ele</segment>
    <segment id="17">, no dia do protesto</segment>
    <segment id="18">, os ônibus não vão entrar na Estação Pirajá.</segment>
    <segment id="19">"</segment>
    <segment id="20">Eles vão levar os passageiros direto dos bairros para o Centro da cidade</segment>
    <segment id="21">, sem parar na estação.</segment>
    <segment id="22">Quem quiser</segment>
    <segment id="23">, pode descer no ponto seguinte</segment>
    <segment id="24">, onde o ônibus vai parar".</segment>
    <segment id="25">Segundo Hélio</segment>
    <segment id="26">, os rodoviários encaminharam diversas reclamações para a Prefeitura</segment>
    <segment id="27">, masmas não houve solução sobre o que eles chamam de "abandono" da estação.</segment>
    <segment id="28">Diante disso</segment>
    <segment id="29">, eles decidiram protestar.</segment>
    <segment id="30">A Transalvador informou</segment>
    <segment id="31">, através de nota</segment>
    <segment id="32">, que tomou medidas emergenciais para resolver o problema</segment>
    <segment id="33">, contratando fiscais de fila</segment>
    <segment id="34">, que estão passando por treinamento</segment>
    <segment id="35">, além de ter contratado uma nova empresa para fazer a manutenção dos sanitários</segment>
    <segment id="36">, que também vão passar por reforma.</segment>
  </rst>
