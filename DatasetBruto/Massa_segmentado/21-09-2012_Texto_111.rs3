  <rst>
    <segment id="1">Turma se</segment>
    <segment id="2">se reГѓВєne pra retirar lixo da areia</segment>
    <segment id="3">Projeto</segment>
    <segment id="4">Nossa Coleta fez uma caminhada ecolГѓВіgica entre ItapuГѓВЈ e PiatГѓВЈ</segment>
    <segment id="5">As praias de ItapuГѓВЈ e PiatГѓВЈ foram tomadas por um arrastГѓВЈo na manhГѓВЈ de ontem.</segment>
    <segment id="6">Denominada</segment>
    <segment id="7">Caminhada EcolГѓВіgica de Limpeza da Praia</segment>
    <segment id="8">, a aГѓВ§ГѓВЈo incentivou o descarte consciente de lixo</segment>
    <segment id="9">, em comemoraГѓВ§ГѓВЈo ao Dia Internacional de Limpeza de Praia.</segment>
    <segment id="10">A iniciativa foi do projeto Nossa Coleta</segment>
    <segment id="11">, que  levou 60 pessoas</segment>
    <segment id="12">,  entre estudantes do ColГѓВ©gio Estadual Governador Lomanto JГѓВєnior</segment>
    <segment id="13">, funcionГѓВЎrios do Hotel Sol Express e integrantes da cooperativa Canore</segment>
    <segment id="14">, para recolher toda a lixarada que encontravam pelo percusso traГѓВ§ado.</segment>
    <segment id="15">A cada trecho percorrido os voluntГѓВЎrios</segment>
    <segment id="16">sese espantavam  com os trecos que encontravam.</segment>
    <segment id="17">Foram guarda-chuvas</segment>
    <segment id="18">, absorventes</segment>
    <segment id="19">, atГѓВ© saias de renda</segment>
    <segment id="20">, entre outros curiosos  itens.</segment>
    <segment id="21">Гўв‚¬Е“NГѓВЈo tinha noГѓВ§ГѓВЈo das porcarias que deixam na praiasГўв‚¬</segment>
    <segment id="22">, revelou Gabriel de Jesus</segment>
    <segment id="23">, de 24 anos</segment>
    <segment id="24">, depois de duas horas trabalho intenso de coleta.</segment>
    <segment id="25">Ao final do percurso</segment>
    <segment id="26">, em PiatГѓВЈ</segment>
    <segment id="27">, foram recolhidos 70 sacos cheios de trambolhos</segment>
    <segment id="28">, que foram destinados para a seleГѓВ§ГѓВЈo dos itens reciclГѓВЎveis</segment>
    <segment id="29">, na Coperativa Canore</segment>
    <segment id="30">, em Nordeste de Amaralina.</segment>
    <segment id="31">Se os sacos de  coleta ficaram cheios</segment>
    <segment id="32">, as mentes dos voluntГѓВЎrios mais ainda</segment>
    <segment id="33">, masmas de ideias de</segment>
    <segment id="34">comocomo colaborar com a manutenГѓВ§ГѓВЈo de limpeza das praias.</segment>
    <segment id="35">Гўв‚¬Е“Quando alguГѓВ©m jogar lixo na praia vou explicar</segment>
    <segment id="36">comocomo ГѓВ© prejudicial ou eu mesma irei recolher Гўв‚¬</segment>
    <segment id="37">,  fala a estudante Ghovana Hemell.</segment>
  </rst>
