  <rst>
    <segment id="1">Que presente é a cara da mamãe?</segment>
    <segment id="2">Em bairros</segment>
    <segment id="3">comocomo Liberdade e Cajazeiras</segment>
    <segment id="4">, é possível achar produtos com preços baixos

Quem quer economizar tem que bater perna por aí.</segment>
    <segment id="5">Faltando cinco dias para o Dia das Mães</segment>
    <segment id="6">, a reportagem do MASSA!</segment>
    <segment id="7">percorreu o comércio dos bairros da Liberdade e Cajazeira 10 e encontrou boas dicas para presentes.</segment>
    <segment id="8">As opções variam de R$ 4</segment>
    <segment id="9">,98 (metro do tecido malha) até R$ 269 (preço à vista do micro-ondas da Panasonic).</segment>
    <segment id="10">Além da possibilidade de dividir no cartão</segment>
    <segment id="11">, sem juros</segment>
    <segment id="12">, sempre há espaço para uma pechincha.</segment>
    <segment id="13">Quem garante é o sócio da loja Feirão dos Tecidos</segment>
    <segment id="14">, Lourival Gomes da Costa</segment>
    <segment id="15">, localizada na Rua Lima e Silva</segment>
    <segment id="16">, na Liberdade.</segment>
    <segment id="17">“Conversando</segment>
    <segment id="18">, a gente consegue dar um bom desconto”</segment>
    <segment id="19">, afirma.</segment>
    <segment id="20">Tanto na Liberdade</segment>
    <segment id="21">, quanto na rotatória de  Cajazeiras 10</segment>
    <segment id="22">, existe uma variedade de produtos</segment>
    <segment id="23">, em lojas e camelôs</segment>
    <segment id="24">, que podem agradar aos mais diversos tipos de mães.</segment>
    <segment id="25">Desde as mais tradicionais</segment>
    <segment id="26">, que adoram ganhar coisas para a casa</segment>
    <segment id="27">, passando pelas mais moderninhas e as que vivem preocupadas com o trabalho.</segment>
    <segment id="28">A mãe da doméstica Norma Santos Ferreira</segment>
    <segment id="29">, 48, dona Cremilda</segment>
    <segment id="30">, 76, faz o tipo tradicional e adora ganhar um utensílio novo para o lar.</segment>
    <segment id="31">“Todo ano compro coisas para a casa e ela adora.</segment>
    <segment id="32">Este ano</segment>
    <segment id="33">, vou dar um lençol para a cama”</segment>
    <segment id="34">, antecipa.</segment>
    <segment id="35">Mas, quem quiser inovar e presentar com algo diferente  pode confeccionar ou montar um presente.</segment>
    <segment id="36">Aí é só usar e abusar da imaginação.</segment>
    <segment id="37">Uma dica é montar uma cesta de café da manhã</segment>
    <segment id="38">, que custa</segment>
    <segment id="39">, em média</segment>
    <segment id="40">, R$ 50.</segment>
    <segment id="41">Indique você também um presente bom e barato para dar a mamãe no dia dela</segment>
    <segment id="42">, neste domingo (08-05).</segment>
  </rst>
</analysis>