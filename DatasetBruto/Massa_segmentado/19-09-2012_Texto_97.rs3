  <rst>
    <segment id="1">OperaГѓВ§ГѓВЈo passa o rodo</segment>
    <segment id="2">Policiais preparam o terreno para instalar Base ComunitГѓВЎria em Feira de Santana</segment>
    <segment id="3">Cerca de 130 policiais militares e civis ocuparam</segment>
    <segment id="4">, ontem</segment>
    <segment id="5">, o bairro George AmГѓВ©rico</segment>
    <segment id="6">, em Feira de Santana (a 108 km de Salvador)</segment>
    <segment id="7">, onde</segment>
    <segment id="8">, no prГѓВіximo dia 27</segment>
    <segment id="9">, serГѓВЎ inaugurada a 2Г‚ВЄ Base ComunitГѓВЎria de SeguranГѓВ§a (BCS) no interior do Estado Гўв‚¬</segment>
    <segment id="10">вЂњ a primeira serГѓВЎ instalada</segment>
    <segment id="11">, dia 21</segment>
    <segment id="12">, em Itabuna.</segment>
    <segment id="13">O objetivo ГѓВ© diminuir o ГѓВ­ndice de criminalidade</segment>
    <segment id="14">, tirando de circulaГѓВ§ГѓВЈo pessoas envolvidas com delitos na regiГѓВЈo.</segment>
    <segment id="15">Гўв‚¬Е“Estamos fazendo a limpeza da ГѓВЎrea</segment>
    <segment id="16">para que</segment>
    <segment id="17">para que a BCS seja implantada e os policiais trabalhem de forma pacГѓВ­fica no local.</segment>
    <segment id="18">A operaГѓВ§ГѓВЈo continua atГѓВ© o dia da implantaГѓВ§ГѓВЈoГўв‚¬</segment>
    <segment id="19">, frisou o  coronel AdelmГѓВЎrio Xavier</segment>
    <segment id="20">, do Comando de Policiamento Regional Leste.</segment>
    <segment id="21">Escolhido para sediar a primeira das quatro BCSs previstas para a cidade devido ao alto ГѓВ­ndice de violГѓВЄncia</segment>
    <segment id="22">, o bairro teve todas as ruas cercadas ontem por policiais em busca de drogas e suspeitos de crimes.</segment>
    <segment id="23">Todos os moradores</segment>
    <segment id="24">, alГѓВ©m de motoristas e motociclistas</segment>
    <segment id="25">, foram abordados.</segment>
    <segment id="26">Гўв‚¬Е“Estamos bloqueando as saГѓВ­das.</segment>
    <segment id="27">Os que teimam em estar  ГѓВ  margem da lei que saiam do bairro</segment>
    <segment id="28">, e evitaremos a entrada de outrosГўв‚¬</segment>
    <segment id="29">, disse Xavier.</segment>
    <segment id="30">Na operaГѓВ§ГѓВЈo</segment>
    <segment id="31">, foi preso em Lucas Silva Santos</segment>
    <segment id="32">, 19,  flagrado com um revГѓВіlver calibre 38</segment>
    <segment id="33">, muniГѓВ§ГѓВµes e crack.</segment>
    <segment id="34">Гўв‚¬Е“Ele foi encaminhado para o Complexo Policial Investigador Bandeira</segment>
    <segment id="35">, onde foi autuado em flagrante por trГѓВЎfico de drogas e porte ilegal de armas.</segment>
    <segment id="36">AlГѓВ©m dele</segment>
    <segment id="37">,  suspeitos foram encaminhados ГѓВ  delegacia e mais de 30 veГѓВ­culos</segment>
    <segment id="38">, entre carros e motocicletas</segment>
    <segment id="39">, foram apreendidos.</segment>
    <segment id="40">Bicho pega no bairro</segment>
    <segment id="41">George AmГѓВ©rico</segment>
    <segment id="42">, na verdade</segment>
    <segment id="43">, ГѓВ© o nome de um conjunto habitacional surgido na dГѓВ©cada de 80</segment>
    <segment id="44">, no bairro Campo Limpo</segment>
    <segment id="45">, a partir de uma invasГѓВЈo comandada por um lГѓВ­der comunitГѓВЎrio.</segment>
    <segment id="46">Com o passar do tempo</segment>
    <segment id="47">, o local cresceu e hoje</segment>
    <segment id="48">ГѓВ© considerado um sub-bairro.</segment>
    <segment id="49">Segundo o administrador  Carlos Santos</segment>
    <segment id="50">, atualmente cerca de 25 mil pessoas residem no local</segment>
    <segment id="51">, que carrega o tГѓВ­tulo de bairro mais violento nos ГѓВєltimos 4 anos.</segment>
    <segment id="52">Para a comerciante Roselita LourenГѓВ§o</segment>
    <segment id="53">, a implantaГѓВ§ГѓВЈo jГѓВЎ devia ter sido feita.</segment>
    <segment id="54">Гўв‚¬Е“A droga tomou conta daqui.</segment>
    <segment id="55">Tenho um bar e sofro</segment>
    <segment id="56">para que</segment>
    <segment id="57">para que nГѓВЈo o transformem em ponto de venda</segment>
    <segment id="58">, pois</segment>
    <segment id="59">pois os criminosos querem usar e vender drogas dentro de qualquer estabelecimentoГўв‚¬</segment>
    <segment id="60">, declarou. .</segment>
  </rst>
