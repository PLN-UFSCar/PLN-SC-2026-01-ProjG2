  <rst>
    <segment id="1">Briga passional na Praça XV deixa dois feridos
RIO - Uma história que poderia ter saído das peças de Nelson Rodrigues quase termina em tragédia</segment>
    <segment id="2">, na manhã desta quarta-feira</segment>
    <segment id="3">, no terminal de ônibus da Praça XV.</segment>
    <segment id="4">Por ciúmes da amante</segment>
    <segment id="5">, um vigia de 42 anos tentou atirar contra um motorista da linha Nova Iguaçu-Praça XV</segment>
    <segment id="6">, da empresa Evanil.</segment>
    <segment id="7">O vigia</segment>
    <segment id="8">, no entanto</segment>
    <segment id="9">, errou o alvo e acabou acertando de raspão o motorista e outras duas pessoas que passavam pelo terminal</segment>
    <segment id="10">, além da janela de um ônibus da Viação Rio Ita que seguiria para Manilha.</segment>
    <segment id="11">Um dos feridos</segment>
    <segment id="12">, o médico João Bosco Rego Perpétuo</segment>
    <segment id="13">sese salvou por pouco: um dos três tiros disparados só não o feriu no peito</segment>
    <segment id="14">porque</segment>
    <segment id="15">porque o celular no bolso de sua camisa serviu de escudo para a bala.</segment>
    <segment id="16">A discussão entre o vigia e o motorista começou em Nova Iguaçu</segment>
    <segment id="17">, onde o vigia entrou no ônibus com a amante.</segment>
    <segment id="18">Pelo depoimento do atirador na 1ª DP (Praça Mauá)</segment>
    <segment id="19">, o motorista teria entregue à mulher um panfleto com propaganda de uma empresa de turismo e pedido que ela o repassasse ao marido.</segment>
    <segment id="20">O amante entendeu a atitude</segment>
    <segment id="21">comocomo uma provocação</segment>
    <segment id="22">, já que a mulher é casada.

- Ele (o vigia) contou que</segment>
    <segment id="23">, há uns 15 dias</segment>
    <segment id="24">, o motorista já havia pedido o telefone dela.</segment>
    <segment id="25">Ela, então</segment>
    <segment id="26">, teria fingido que não entendeu.</segment>
    <segment id="27">A mulher é casada</segment>
    <segment id="28">, e o marido a leva ao ponto de ônibus em Nova Iguaçu todos os dias.</segment>
    <segment id="29">Hoje (quarta-feira)</segment>
    <segment id="30">, o motorista pediu que ela entregasse um panfleto ao marido.</segment>
    <segment id="31">E isso gerou a discussão - contou o delegado José Afonso Mota</segment>
    <segment id="32">, da 1ª DP.</segment>
    <segment id="33">Já o funcionário da Evanil disse à polícia que conhecia o casal de amantes apenas de vista e que acreditava que os dois fossem marido e mulher.</segment>
    <segment id="34">A propaganda</segment>
    <segment id="35">, segundo ele</segment>
    <segment id="36">, é da empresa de um amigo</segment>
    <segment id="37">, a quem estaria ajudando na divulgação.</segment>
    <segment id="38">Após o bate-boca ainda em Nova Iguaçu</segment>
    <segment id="39">, a viagem continuou até o ponto final da linha</segment>
    <segment id="40">, na Praça XV.</segment>
    <segment id="41">Depois que os passageiros desceram do coletivo</segment>
    <segment id="42">, por volta das 8h30m</segment>
    <segment id="43">, o motorista foi tirar satisfações com o vigia</segment>
    <segment id="44">, retomando a discussão.</segment>
    <segment id="45">No meio da briga</segment>
    <segment id="46">, fora do ônibus</segment>
    <segment id="47">, o vigia sacou um revólver calibre 38 e fez três disparos</segment>
    <segment id="48">, atingindo de raspão também a vendedora Lucinete Gomes de Oliveira</segment>
    <segment id="49">, que esperava ônibus para Nova Iguaçu.</segment>
    <segment id="50">Ela foi ferida no ombro esquerdo.

- Eu estava no ponto quando vi o homem descer do ônibus ofendendo o motorista</segment>
    <segment id="51">, que pediu calma - lembrou Lucinete</segment>
    <segment id="52">, que foi levada para o Hospital Souza Aguiar e liberada.</segment>
    <segment id="53">- Todo mundo ali teve sorte.</segment>
    <segment id="54">Poderia ter sido mais sério.

- O terminal estava cheio de gente e foi uma correria danada.</segment>
    <segment id="55">Me protegi atrás de uma pilastra - contou Éder Borges</segment>
    <segment id="56">, motorista do ônibus da Rio Ita que ia para Manilha.</segment>
    <segment id="57">O vigia ia para o trabalho no Centro e portava ilegalmente o revólver.</segment>
    <segment id="58">De acordo com o delegado da 1 DP</segment>
    <segment id="59">, ele já tinha passagem na polícia por homicídio culposo</segment>
    <segment id="60">, furto qualificado e maus-tratos - registrado na Delegacia Especial de Atendimento à Mulher (Deam).</segment>
    <segment id="61">Ele, no entanto</segment>
    <segment id="62">, não estava foragido.</segment>
    <segment id="63">O delegado informou que o vigia responderá por três tentativas de homicídio e por erro de execução (por ter atingido outras duas pessoas).</segment>
    <segment id="64">A pena</segment>
    <segment id="65">, neste</segment>
    <segment id="66">casocaso</segment>
    <segment id="67">, pode chegar a 20 anos de prisão.</segment>
  </rst>
</analysis>