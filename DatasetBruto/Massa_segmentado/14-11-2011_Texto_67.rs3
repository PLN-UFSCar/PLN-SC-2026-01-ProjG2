  <rst>
    <segment id="1">Bahia e Palmeiras
Ingressos para a partida já estão à venda</segment>
    <segment id="2">Teve início nesta segunda-feira</segment>
    <segment id="3">, 14, a venda de ingressos para o jogo entre Bahia e Palmeiras</segment>
    <segment id="4">, que acontece no domingo</segment>
    <segment id="5">, 20, às 19 horas</segment>
    <segment id="6">, no estádio de Pituaçu</segment>
    <segment id="7">, pela 36ª rodada da Série</segment>
    <segment id="8">A 2011.</segment>
    <segment id="9">A partida será o penúltima do Bahia em Salvador em 2011.</segment>
    <segment id="10">Depois deste jogo</segment>
    <segment id="11">, o Bahia só volta a campo em Pituaçu na última rodada do Brasileirão</segment>
    <segment id="12">, no dia 04 de dezembro</segment>
    <segment id="13">, contra o Ceará.</segment>
    <segment id="14">Os ingressos para a partida podem ser adquiridos</segment>
    <segment id="15">, das 09 às 17 horas</segment>
    <segment id="16">, nos seguintes pontos de venda: loja 88 (Pituba Parque Center)</segment>
    <segment id="17">, loja Bahia Esporte (Lauro de Freitas)</segment>
    <segment id="18">, loja Golaço (Comércio)</segment>
    <segment id="19">, Loja Viva Bahia ( Pituba)</segment>
    <segment id="20">, sede de praia (Boca do rio) e bilheterias do Estádio de Pituaçu.</segment>
    <segment id="21">O valor continua R$ 30 (arquibancada) e R$ 60 (cadeira)</segment>
    <segment id="22">, preço único.</segment>
    <segment id="23">Com 42 pontos</segment>
    <segment id="24">, 13ª posição da tabela e praticamente garantido na Série</segment>
    <segment id="25">A em 2012</segment>
    <segment id="26">, o Bahia agora disputa uma vaga na taça sul-americana.</segment>
    <segment id="27">O Palmeiras</segment>
    <segment id="28">, na 14ª posição</segment>
    <segment id="29">, com a mesma pontuação do Esquadrão</segment>
    <segment id="30">, é adversário direto do tricolor baiano na luta pela vaga no torneio.</segment>
  </rst>
</analysis>