  <rst>
    <segment id="1">Uma final de Copinha para fazer história</segment>
    <segment id="2">Corinthians pode ganhar o oitavo título da competição e o Fluminense tenta o sexto
Sonho de consumo dos dirigentes das divisões de base de Bahia e Vitória</segment>
    <segment id="3">, o título da Copa São Paulo de Futebol Júnior será decidido hoje</segment>
    <segment id="4">, em sua 43ª final</segment>
    <segment id="5">, entre os dois maiores bicho-papões da competição.</segment>
    <segment id="6">De um lado</segment>
    <segment id="7">, o todo-poderoso Corinthians</segment>
    <segment id="8">, com sete conquistas.</segment>
    <segment id="9">Do outro</segment>
    <segment id="10">, o tradicional Fluminense</segment>
    <segment id="11">, que já levantou cinco troféus do mais importante  torneio Sub-18 do Brasil.</segment>
    <segment id="12">A melhor campanha é do Timão</segment>
    <segment id="13">, com sete vitórias em sete jogos</segment>
    <segment id="14">, 28 gols marcados e apenas um sofrido.</segment>
    <segment id="15">O Pó de Arroz também venceu suas sete partidas</segment>
    <segment id="16">, masmas tem 23 gols assinalados e viu suas redes balançarem em seis oportunidades.</segment>
    <segment id="17">O artilheiro da Copinha é o meia Valdívia</segment>
    <segment id="18">, do Rondonópolis-MT</segment>
    <segment id="19">, que saiu nas oitavas de final.</segment>
    <segment id="20">O encorpado centroavante Douglas</segment>
    <segment id="21">, do Corinthians</segment>
    <segment id="22">, tem 6 gols</segment>
    <segment id="23">, e promete brigar pela artilharia.</segment>
    <segment id="24">Na semifinal ele  fez três na goleada por 6 a 0 diante do Atlético/PR.</segment>
    <segment id="25">"</segment>
    <segment id="26">Nada está ganho</segment>
    <segment id="27">, temos de estar prontos  para encarar o Fluminense</segment>
    <segment id="28">, que é uma grande equipe”</segment>
    <segment id="29">, falou.

Marcos Junior</segment>
    <segment id="30">, do Flu</segment>
    <segment id="31">, fez dois na semifinal e ajudou na vitória por 4 a 0 contra o Coritiba.</segment>
    <segment id="32">"</segment>
    <segment id="33">Espero</segment>
    <segment id="34">, na final</segment>
    <segment id="35">, também ter oportunidade de marcar”</segment>
    <segment id="36">, disse.</segment>
  </rst>
