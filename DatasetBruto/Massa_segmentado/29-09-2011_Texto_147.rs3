  <rst>
    <segment id="1">Esperança de dias</segment>
    <segment id="2">melhores
Policiais que atuam nas três bases do Nordeste de Amaralina comemoram a tranquilidade</segment>
    <segment id="3">O clima de tranquilidade marcou o segundo dia de trabalho dos policiais militares que atuam nas três bases comunitárias de segurança instaladas no bairro Nordeste de Amaralina.</segment>
    <segment id="4">De acordo com o delegado Marcelo Sansão</segment>
    <segment id="5">, titular da Delegacia do Nordeste de Amaralina</segment>
    <segment id="6">, foram registradas ontem na unidade apenas uma ocorrência de furto a uma casa comercial</segment>
    <segment id="7">; uma ameaça</segment>
    <segment id="8">; uma injúria</segment>
    <segment id="9">; além de duas pessoas conduzidas à delegacia: uma por dirigir veículo sem habilitação e outra por uso de maconha.</segment>
    <segment id="10">“</segment>
    <segment id="11">O dia foi muito tranquilo.</segment>
    <segment id="12">Espero que continue assim.</segment>
    <segment id="13">Nesse mês</segment>
    <segment id="14">, não tivemos nenhum homicídio”</segment>
    <segment id="15">, afirma o delegado.</segment>
    <segment id="16">O tenente Ricardo</segment>
    <segment id="17">, comandante da base da Chapada do Rio Vermelho</segment>
    <segment id="18">, fala sobre a receptividade dos moradores aos PMs.</segment>
    <segment id="19">“Só de andar pelas ruas você já sente a diferença.</segment>
    <segment id="20">Crianças falando com a gente</segment>
    <segment id="21">, o povo dando bom-dia.</segment>
    <segment id="22">O comércio movimentado.</segment>
    <segment id="23">Tem tudo para dar certo</segment>
    <segment id="24">, aliás</segment>
    <segment id="25">, já deu certo”</segment>
    <segment id="26">, opina.</segment>
    <segment id="27">Os policiais planejam agora visitar as casas dos moradores</segment>
    <segment id="28">, com o objetivo de conhecê-los e ouvir as reivindicações.</segment>
    <segment id="29">Também estão previstas palestras dos bombeiros sobre primeiros socorros e prevenção a acidentes domésticos e desabamentos.</segment>
    <segment id="30">Nos próximos dias</segment>
    <segment id="31">, será inaugurado o infocentro</segment>
    <segment id="32">, no Beco da Cultura</segment>
    <segment id="33">, que terá 10 computadores e cursos gratuitos de informática para o povo.</segment>
    <segment id="34">Cidadania chegando...</segment>
    <segment id="35">Junto à instalação das três bases comunitárias de segurança</segment>
    <segment id="36">, governos estadual e municipal anunciam projetos de requalificação urbana</segment>
    <segment id="37">, por parte da prefeitura</segment>
    <segment id="38">, e de desenvolvimento sociocultural</segment>
    <segment id="39">, por conta do estado.</segment>
    <segment id="40">O município divulgou ações de limpeza</segment>
    <segment id="41">, iluminação e recuperação de asfalto.</segment>
    <segment id="42">Segundo a prefeitura</segment>
    <segment id="43">, 19 ruas na área foram beneficiadas com a operação Tapa-Buraco</segment>
    <segment id="44">, 100 pontos de luz substituídos e 150 toneladas de entulho foram recolhidos.</segment>
    <segment id="45">Apresentando-</segment>
    <segment id="46">sese como</segment>
    <segment id="47">como líder comunitário de Santa Cruz</segment>
    <segment id="48">, Leo Brasil contestou.</segment>
    <segment id="49">“Só vi limpeza onde a comissão do governador ia passar ontem (terça)”.</segment>
    <segment id="50">Esportes na comunidade:</segment>
    <segment id="51">Natação é um dos esportes oferecidos pelo Centro Social Urbano</segment>
    <segment id="52">Cursos de graça:</segment>
    <segment id="53">Inscrições no dia 15</segment>
    <segment id="54">Na Rua da Alegria</segment>
    <segment id="55">, os buracos foram tapados e dois  postes de luz trocados.</segment>
    <segment id="56">Para o dia 15 de outubro</segment>
    <segment id="57">, está previsto o início de novas turmas dos cursos de manicure</segment>
    <segment id="58">, pedicure</segment>
    <segment id="59">, recepcionista e vigilante no Centro Social Urbano (CSU) do Nordeste.</segment>
    <segment id="60">A coordenadora do Centro</segment>
    <segment id="61">, Andreia Macedo</segment>
    <segment id="62">, informou que as primeiras turmas formaram um total de 120 alunos.</segment>
    <segment id="63">“Temos também aulas de futebol</segment>
    <segment id="64">, natação</segment>
    <segment id="65">, boxe</segment>
    <segment id="66">, ginástica</segment>
    <segment id="67">, karatê etc”</segment>
    <segment id="68">, disse.</segment>
    <segment id="69">As atividades têm o apoio da Secretaria Estadual de Desenvolvimento Social e Combate à Pobreza (Sedes).</segment>
  </rst>
</analysis>