  <rst>
    <segment id="1">Conflito entre mãe e filho marca o primeiro capítulo de 'Fina estampa'</segment>
    <segment id="2">, nova trama das 21h
RIO - Diferente de suas antecessoras</segment>
    <segment id="3">, que investiram em belas cenas gravadas em outros estados ou países</segment>
    <segment id="4">, "</segment>
    <segment id="5">Fina estampa" estreou na noite desta segunda-feira privilegiando o Rio de Janeiro</segment>
    <segment id="6">comocomo cenário.</segment>
    <segment id="7">O grande conflito da nova trama das 21h</segment>
    <segment id="8">, entre Griselda (Lilia Cabral)</segment>
    <segment id="9">, a mãe trabalhadora e masculinizada</segment>
    <segment id="10">, e Antenor (Caio Castro)</segment>
    <segment id="11">, o filho que tem vergonha dela</segment>
    <segment id="12">, foi o fio condutor do primeiro capítulo do folhetim de Aguinaldo Silva.</segment>
    <segment id="13">Conhecida no bairro</segment>
    <segment id="14">comocomo Pereirão</segment>
    <segment id="15">, a personagem de Lilia Cabral é mostrada</segment>
    <segment id="16">comocomo uma mulher dura</segment>
    <segment id="17">, capaz de ameaçar surrar um grupo de homens na praia ou de dar uma lição em Baltazar (Alexandre Nero)</segment>
    <segment id="18">, o marido que bate na mulher</segment>
    <segment id="19">, Celeste (Dira Paes).</segment>
    <segment id="20">Mas, ao mesmo tempo</segment>
    <segment id="21">, é sensível e chora após sofrer uma humilhação do filho.</segment>
    <segment id="22">Os dois brigam quando Griselda vai até a faculdade entregar um caderno que Antenor esqueceu em casa.</segment>
    <segment id="23">Ele expulsa a mãe com requintes de crueldade.</segment>
    <segment id="24">"</segment>
    <segment id="25">Você não está entendendo</segment>
    <segment id="26">porque</segment>
    <segment id="27">porque é ignorante.</segment>
    <segment id="28">Isso aqui não é lugar para você.</segment>
    <segment id="29">Aqui eu não sou seu filho</segment>
    <segment id="30">, sou Dr. Antenor.</segment>
    <segment id="31">E você não vai estragar isso"</segment>
    <segment id="32">, diz o estudante de Medicina.</segment>
    <segment id="33">Já a antagonista Tereza Cristina (Christiane Torloni) é mostrada</segment>
    <segment id="34">comocomo uma perua afetada que não mede esforços para ter as coisas do seu jeito.</segment>
    <segment id="35">Nem que precise encher a paciência do marido René (Dalton Vigh).</segment>
    <segment id="36">Os dois passam o dia planejando por telefone a comemoração do aniversário da filha Patrícia (Adriana Birolli).</segment>
    <segment id="37">Até que ele fure o pneu do carro comprado de presente para a menina e receba a ajuda de Pereirão na rua.</segment>
    <segment id="38">Apesar das roupas e da aparência descuidada</segment>
    <segment id="39">, o jeito confiante de Griselda logo desperta a atenção de René.</segment>
    <segment id="40">Noiva de Antenor</segment>
    <segment id="41">, Patrícia insiste para conhecer sua família e mal sabe das mentiras inventadas pelo estudante:</segment>
    <segment id="42">ele conta que a mãe está sempre trabalhando em suas fazendas de gado e chama-</segment>
    <segment id="43">sese Gisela.</segment>
    <segment id="44">O final do capítulo deixou um gancho: quando precisa consertar as luzes do jardim para a festa da filha</segment>
    <segment id="45">, Tereza Cristina acaba convocando Griselda.</segment>
    <segment id="46">É quando a protagonista reencontra René e fica prestes a descobrir a verdade sobre a namorada do filho.</segment>
    <segment id="47">Com apenas um intervalo comercial</segment>
    <segment id="48">, o capítulo fez um apanhado geral na trama e</segment>
    <segment id="49">, além da história central</segment>
    <segment id="50">, ainda apresentou o restante dos principais personagens</segment>
    <segment id="51">, como</segment>
    <segment id="52">como os outros filhos de Griselda</segment>
    <segment id="53">, Quinzé (Malvino Salvador) e Amália (Sophie Charlotte).</segment>
    <segment id="54">Ele, um homem que cuida do filho após ter sido abandonado pela mulher</segment>
    <segment id="55">; ela, uma moça trabalhadora que vive trocando olhares na rua com Rafa (Marco Pigossi)</segment>
    <segment id="56">, funcionário da oficina próxima à casa da família Pereira.</segment>
    <segment id="57">Amigo de Antenor</segment>
    <segment id="58">, ele empresta as motos que conserta para o rapaz ir para a faculdade e acaba descobrindo</segment>
    <segment id="59">, sem querer</segment>
    <segment id="60">, que ele e Amália são irmãos.</segment>
    <segment id="61">Outro personagem importante do núcleo do Jardim Oceânico é Guaracy (Paulo Rocha)</segment>
    <segment id="62">, o português dono de um bar na vizinhança.</segment>
    <segment id="63">Já neste início ele deixa claro seu interesse por Griselda: "</segment>
    <segment id="64">Tu ainda vai provar a água do meu bacalhau"</segment>
    <segment id="65">, diz a ela</segment>
    <segment id="66">, rindo.</segment>
    <segment id="67">A parte cômica fica por conta de Crô (Marcelo Serrado)</segment>
    <segment id="68">, o assistente que atura todas as humilhações de Tereza Cristina e a quem bajula chamando de "pitonisa de Tebas"</segment>
    <segment id="69">, "minha Cleópatra" ou "rainha do Nilo".</segment>
    <segment id="70">Para ver a patroa feliz</segment>
    <segment id="71">, ele chega a recusar o convite de Esther (Julia Lemmertz) para ocupar um lugar na primeira fila do desfile da grife Fio Carioca</segment>
    <segment id="72">, já que Tereza</segment>
    <segment id="73">sese sentiria ofendida de sentar-</segment>
    <segment id="74">sese no mesmo espaço.</segment>
    <segment id="75">Apareceram ainda Paulo (Dan Stubach)</segment>
    <segment id="76">, o marido de Esther</segment>
    <segment id="77">, além do casal Álvaro (Wolf Maia) e Zambeze (Totia Meirelles)</segment>
    <segment id="78">, donos de um quiosque na praia.</segment>
    <segment id="79">A taxista Vilma (Arlete Salles) é uma das amigas de Griselda</segment>
    <segment id="80">, e mora também no bairro com a filha Letícia (Tania Khallil) e a neta Carolina (Bianca Salgueiro).</segment>
  </rst>
</analysis>