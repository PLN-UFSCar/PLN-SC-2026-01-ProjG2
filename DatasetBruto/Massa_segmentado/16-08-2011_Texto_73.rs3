  <rst>
    <segment id="1">Cantor penou com infecção urinária</segment>
    <segment id="2">A doença de Igor Kanário é mais comum em mulheres</segment>
    <segment id="3">, masmas homens podem sofrer um bocado</segment>
    <segment id="4">O fãs da banda</segment>
    <segment id="5">A Bronkka tomaram um susto na última sexta-feira</segment>
    <segment id="6">, quando o vocalista Igor Kanário foi internado com fortes dores nos rins.</segment>
    <segment id="7">O cantor teve alta ontem do Hospital Espanhol</segment>
    <segment id="8">, em Salvador</segment>
    <segment id="9">, após receber o diagnóstico de infecção urinária.</segment>
    <segment id="10">Apesar de ser uma doença que atinge mais as mulheres</segment>
    <segment id="11">, os homens também estão expostos à ação de uma bactéria chamada</segment>
    <segment id="12">“escherichia coli”.</segment>
    <segment id="13">Ela sai do sistema digestivo por meio das fezes e entra em contato com a uretra - canal por onde sai a urina.</segment>
    <segment id="14">De acordo com o médico urologista Wagner Coêlho</segment>
    <segment id="15">, existem dois tipos de infecção urinária - a baixa e a alta.</segment>
    <segment id="16">“</segment>
    <segment id="17">A baixa atinge a região da bexiga.</segment>
    <segment id="18">A alta</segment>
    <segment id="19">, os rins”</segment>
    <segment id="20">, explica ele.</segment>
    <segment id="21">O paciente sente mal-estar</segment>
    <segment id="22">, dor na parte baixa da barriga e febre</segment>
    <segment id="23">, que é mais comum nas infecções dos rins.</segment>
    <segment id="24">Nas mulheres</segment>
    <segment id="25">, ainda há possibilidade de sangramento com a urina.</segment>
    <segment id="26">Segundo a assessoria de Igor Kanário</segment>
    <segment id="27">, o cantor também possui pedras nos rins.</segment>
    <segment id="28">O urologista Wagner Coêlho diz que neste</segment>
    <segment id="29">casocaso a situação complica.</segment>
    <segment id="30">“</segment>
    <segment id="31">A bactéria</segment>
    <segment id="32">sese instala no núcleo da pedra e muitas vezes é preciso fazer uma intervenção cirúrgica para conter a doença”</segment>
    <segment id="33">, diz.</segment>
    <segment id="34">O tratamento deve começar o mais rápido possível</segment>
    <segment id="35">, já que a bactéria pode</segment>
    <segment id="36">sese espalhar pelo corpo.</segment>
    <segment id="37">“Assim que os sintomas aparecerem o médico deve ser procurado.</segment>
    <segment id="38">O tratamento começa com uma série de exames</segment>
    <segment id="39">, como</segment>
    <segment id="40">como a urocultura</segment>
    <segment id="41">, que detecta qual é o tipo da bactéria que atinge o sistema urinário</segment>
    <segment id="42">, para que</segment>
    <segment id="43">para que a partir daí seja feito o uso do antibiótico correto”</segment>
    <segment id="44">, define o urologista</segment>
    <segment id="45">, que indica repouso e hidratação.</segment>
    <segment id="46">Pessoas com outras doenças</segment>
    <segment id="47">, como</segment>
    <segment id="48">como câncer</segment>
    <segment id="49">, diabetes e Aids</segment>
    <segment id="50">, podem estar mais sujeitas a contrair a bactéria.</segment>
    <segment id="51">“Qualquer doença que afete o sistema imunológico deixa o corpo mais propício para a doença”</segment>
    <segment id="52">, relata o doutor.</segment>
    <segment id="53">Kanário na gaiola:</segment>
    <segment id="54">Atingiu as ‘partes baixas’</segment>
    <segment id="55">O cantor da A Bronkka</segment>
    <segment id="56">, Igor Kanário</segment>
    <segment id="57">, ficou três dias de molho no hospital.</segment>
    <segment id="58">Em um programa de tevê o cantor reclamou que também sentiu dores nos testículos</segment>
    <segment id="59">, que ficaram inchados.</segment>
    <segment id="60">De acordo com o médico urologista Wagner Coêlho</segment>
    <segment id="61">,  isso não é comum</segment>
    <segment id="62">, masmas pode acontecer uma migração da bactéria causadora da infecção urinária para os testículos.</segment>
    <segment id="63">“Ela pode passar através do canal deferente</segment>
    <segment id="64">, que liga o testículo à uretra.</segment>
    <segment id="65">Mas aí passa a ser infecção testicular</segment>
    <segment id="66">, não mais urinária”</segment>
    <segment id="67">, diz.</segment>
    <segment id="68">Mantenha-</segment>
    <segment id="69">sese forte e hidratado!</segment>
    <segment id="70">A infecção urinária não está relacionada apenas à higiene íntima.</segment>
    <segment id="71">Ela ocorre também quando a bactéria consegue vencer as defesas do organismo.</segment>
    <segment id="72">Médicos orientam a ingestão de líquido para evitar a cistite.</segment>
    <segment id="73">Desta forma</segment>
    <segment id="74">, a pessoa consegue expelir as bactérias.</segment>
  </rst>
</analysis>