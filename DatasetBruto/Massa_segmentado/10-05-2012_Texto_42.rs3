  <rst>
    <segment id="1">Esta pizza o Bahia já traçou</segment>
    <segment id="2">Artilheiro está doidinho para pegar a Portuguesa de jeito hoje</segment>
    <segment id="3">, em Pituaço</segment>
    <segment id="4">Na cantina do Pituaço</segment>
    <segment id="5">, o Bahia encheu a pança  no dia 13 de novembro de 2010 e garantiu o tão sonhado retorno à Primeira Divisão do Campeonato Brasileiro</segment>
    <segment id="6">, com um triunfo por 3 a 0</segment>
    <segment id="7">, sobre a Portuguesa.</segment>
    <segment id="8">E o time paulista com nome de pizza volta a ser um obstáculo hoje</segment>
    <segment id="9">, à noite</segment>
    <segment id="10">, para o Esquadrão chegar às quartas de final da Copa do Brasil.</segment>
    <segment id="11">Empate por 0 a 0 leva a decisão da vaga para os pênaltis.</segment>
    <segment id="12">Qualquer outro empate classifica a Lusa e quem vencer carimba o passaporte.</segment>
    <segment id="13">E para matar a fome de gols da torcida</segment>
    <segment id="14">, nada</segment>
    <segment id="15">comocomo poder contar com seu principal artilheiro.</segment>
    <segment id="16">Souza participou normalmente do treino secreto de ontem e deve ir para o jogo</segment>
    <segment id="17">, o mesmo ocorrendo com o zagueiro e capitão Titi.</segment>
    <segment id="18">O técnico Falcão comandou um coletivo-tático e  depois realizou um trabalho de bolas paradas</segment>
    <segment id="19">, onde foram ensaiadas faltas laterais</segment>
    <segment id="20">, frontais e escanteios.</segment>
    <segment id="21">Logo depois</segment>
    <segment id="22">, os jogadores ainda treinaram cobranças de pênaltis.</segment>
  </rst>
</analysis>