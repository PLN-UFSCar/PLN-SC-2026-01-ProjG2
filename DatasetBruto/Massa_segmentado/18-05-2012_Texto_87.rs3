  <rst>
    <segment id="1">Botafogo dá a última cartada por Seedorf
RIO - O assunto é tratado com muita cautela no Botafogo.</segment>
    <segment id="2">Como Clarence Seedorf ainda é um nome capaz de mexer com o mercado</segment>
    <segment id="3">, apesar de seus 36 anos</segment>
    <segment id="4">, e ser dono de um futebol de alta técnica</segment>
    <segment id="5">, além de</segment>
    <segment id="6">sese cuidar fisicamente</segment>
    <segment id="7">, o holandês seria uma contratação capaz de renovar o ânimo do torcedor botafoguense neste começo de Brasileiro.</segment>
    <segment id="8">Algo semelhante ao que aconteceu com a chegada de Loco</segment>
    <segment id="9">Abreu ao clube</segment>
    <segment id="10">, em 2010.</segment>
    <segment id="11">Como no ano passado muita gente não acreditou que o clube tivesse apresentado uma proposta ao jogador</segment>
    <segment id="12">, que preferiu prosseguir sua carreira no Milan</segment>
    <segment id="13">, desta vez as conversas estão sendo feitas com muito cuidado.</segment>
    <segment id="14">Um alto dirigente do clube</segment>
    <segment id="15">, que pediu para não ter o seu nome revelado</segment>
    <segment id="16">, explicou</segment>
    <segment id="17">comocomo vê a negociação.

- No início</segment>
    <segment id="18">, achei que havia 20% de chances de a negociação andar.</segment>
    <segment id="19">Depois</segment>
    <segment id="20">, com novas conversas</segment>
    <segment id="21">, vi 40% de chances.</segment>
    <segment id="22">Hoje, eu diria que a negociação está adiantada entre 70 e 80%.</segment>
    <segment id="23">Devemos ter uma notícia definitiva ainda neste final de semana ou no início da próxima.</segment>
    <segment id="24">Também não queremos fazer nenhuma novela</segment>
    <segment id="25">, nem criar uma expectativa positiva e depois a negociação não acontecer.</segment>
    <segment id="26">Quando tivermos a palavra final</segment>
    <segment id="27">, vamos divulgar - disse o dirigente.</segment>
    <segment id="28">Em termos de impacto junto ao torcedor</segment>
    <segment id="29">, a vinda de Seedorf é comparada à chegada de Loco Abreu.</segment>
    <segment id="30">Ele mexeu com a torcida e o resultado final foi o melhor possível.</segment>
    <segment id="31">Na avaliação feita em uma reunião ocorrida na quinta-feira à noite</segment>
    <segment id="32">, entre os integrantes da cúpula do futebol e a comissão criada pelo presidente Maurício Assumpção para ajudar o setor</segment>
    <segment id="33">, foram discutidos alguns fatores que levaram o clube a não ter o desempenho esperado no primeiro semestre</segment>
    <segment id="34">, quando ficou com a segunda colocação no Campeonato Carioca e foi eliminado da Copa do Brasil pelo Vitória -BA.</segment>
    <segment id="35">Vitor Júnior</segment>
    <segment id="36">, nova aposta</segment>
    <segment id="37">Na avaliação</segment>
    <segment id="38">, chegou-</segment>
    <segment id="39">sese à conclusão de que o time é bom e necessita de alguns reforços.</segment>
    <segment id="40">Emocionalmente faltou uma resposta do grupo.</segment>
    <segment id="41">Ninguém contava com o exame de saúde do jogador Rojas</segment>
    <segment id="42">, que acusou problemas.</segment>
    <segment id="43">Ele era opção para a lateral esquerda e a zaga.</segment>
    <segment id="44">Além disso</segment>
    <segment id="45">, o clube</segment>
    <segment id="46">sese esforçou para ter o zagueiro Túlio Tanaka e acabou sem conseguir contratar o jogador.</segment>
    <segment id="47">Essas duas situações geraram problemas</segment>
    <segment id="48">, assim</segment>
    <segment id="49">comocomo a promoção do volante Jádson ter demorado a acontecer</segment>
    <segment id="50">, além da dispensa de alguns jogadores.</segment>
    <segment id="51">Para o segundo semestre</segment>
    <segment id="52">, o clube aguarda a chegada de um lateral-esquerdo.</segment>
    <segment id="53">Havia a aposta em Lennon</segment>
    <segment id="54">, que nesta sexta-feira deixou o campo de treino do Centro de Treinamento de Vôlei da CBV</segment>
    <segment id="55">, em Saquarema</segment>
    <segment id="56">, chorando com uma lesão no tornozelo direito.</segment>
    <segment id="57">Há expectativa de contratar um lateral-direito</segment>
    <segment id="58">, um zagueiro</segment>
    <segment id="59">, um volante e um meia-armador.</segment>
    <segment id="60">O meia canhoto Vitor Júnior</segment>
    <segment id="61">, contratado por empréstimo junto ao Corinthians</segment>
    <segment id="62">, começa a ganhar espaço no alvinegro.</segment>
    <segment id="63">Indicado pelo técnico Oswaldo de Oliveira</segment>
    <segment id="64">, já treinou esta semana no lugar de Elkeson.</segment>
  </rst>
</analysis>