  <rst>
    <segment id="1">Adeus a Cyclone reúne multidão
Parentes</segment>
    <segment id="2">, amigos</segment>
    <segment id="3">, conhecidos e muitos curiosos foram ao enterro para ver o corpo</segment>
    <segment id="4">O maior sonho da vida de Kelly Sales Silva</segment>
    <segment id="5">, de 23 anos</segment>
    <segment id="6">, a Kelly Cyclone</segment>
    <segment id="7">, era ingressar na vida política</segment>
    <segment id="8">comocomo vereadora.</segment>
    <segment id="9">Muitos podiam até torcer o nariz para Kelly Cyclone</segment>
    <segment id="10">, masmas o certo mesmo é que a garota tinha grandes chances de conquistar muitos votos</segment>
    <segment id="11">, pois</segment>
    <segment id="12">pois estava com a popularidade em alta</segment>
    <segment id="13">, como</segment>
    <segment id="14">como ficou constatado durante o enterro da jovem</segment>
    <segment id="15">, na tarde de ontem</segment>
    <segment id="16">, no Cemitério Municipal de Portão</segment>
    <segment id="17">, no município de Lauro de Freitas.</segment>
    <segment id="18">Por volta de 1 h da tarde</segment>
    <segment id="19">, cerca de 40 pessoas já</segment>
    <segment id="20">sese aglomeravam na porta do cemitério</segment>
    <segment id="21">, à espera da chegada do caixão com o corpo de Kelly.</segment>
    <segment id="22">A sala reservada para o velório de Kelly Cyclone ficou pequena para a quantidade de pessoas que tentavam</segment>
    <segment id="23">, a todo custo</segment>
    <segment id="24">, chegar perto do caixão.</segment>
    <segment id="25">Além dos familiares e amigos</segment>
    <segment id="26">, muitos curiosos marcaram presença no local</segment>
    <segment id="27">, em um total de quase 300 pessoas.</segment>
    <segment id="28">Policiais militares da Rondesp entraram na sala para tentar organizar o fluxo de gente</segment>
    <segment id="29">, masmas logo depois desistiram.</segment>
    <segment id="30">Júnior Back</segment>
    <segment id="31">, 27, e Valdenilson dos Santos</segment>
    <segment id="32">, 25, da banda Swing do P</segment>
    <segment id="33">, marcaram presença na cerimônia.</segment>
    <segment id="34">Música no enterro</segment>
    <segment id="35">Na maioria dos enterros</segment>
    <segment id="36">, a tampa do caixão é colocada logo após o velório e continua lacrada até  o corpo ser sepultado.</segment>
    <segment id="37">Com Kelly Cyclone</segment>
    <segment id="38">, quase aconteceu de modo diferente.</segment>
    <segment id="39">Os familiares iriam deixar o caixão sair do velório sem a tampa</segment>
    <segment id="40">, para que</segment>
    <segment id="41">para que as pessoas que não viram Kelly na pequena sala pudessem prestar uma última homenagem.</segment>
    <segment id="42">Por conta da chuva</segment>
    <segment id="43">, o caixão acabou saindo fechado.</segment>
    <segment id="44">O sepultamento acabou por volta das 5h da tarde</segment>
    <segment id="45">, ao som da música “Cyclone”</segment>
    <segment id="46">, da banda</segment>
    <segment id="47">A Bronkka.</segment>
    <segment id="48">Gleise Santos</segment>
    <segment id="49">, 25, amiga de Kelly</segment>
    <segment id="50">, escreveu “amor eterno” no cimento</segment>
    <segment id="51">, ainda fresco</segment>
    <segment id="52">, do local onde ficará a lápide.</segment>
  </rst>
</analysis>