  <rst>
    <segment id="1">Tiro dos capetas em PortГѓВЈo infernal
Vendedor de fГѓВЎbrica de sorvete leva bala de bandidos do PГѓВ© Preto</segment>
    <segment id="2">Era aniversГѓВЎrio da tia de Arielson dos Santos Sena</segment>
    <segment id="3">, 28 anos</segment>
    <segment id="4">, e ele fez questГѓВЈo de debulhar o feijГѓВЈo que seria cozinhado para a comemoraГѓВ§ГѓВЈo dos 53 anos da dona de casa.</segment>
    <segment id="5">Como de costume</segment>
    <segment id="6">, acordou cedo</segment>
    <segment id="7">, foi ГѓВ  casa dos tios</segment>
    <segment id="8">,  tomou um cafezinho fresco e foi para a frente da casa com o tio e o cunhado</segment>
    <segment id="9">, carregando o saco de feijГѓВЈo.</segment>
    <segment id="10">Instantes depois</segment>
    <segment id="11">, Arielson caiu da cadeira atingido por uma bala perdida.</segment>
    <segment id="12">O tiro foi disparado por dois traficantes da localidade do PГѓВ© Preto</segment>
    <segment id="13">, conforme testemunhas.</segment>
    <segment id="14">AtГѓВ© as 20h50</segment>
    <segment id="15">, Arielson</segment>
    <segment id="16">, que nГѓВЈo tem nada a ver com a guerra dos bandidos</segment>
    <segment id="17">, permanecia internado</segment>
    <segment id="18">, em estado grave</segment>
    <segment id="19">, no Hospital do SubГѓВєrbio.</segment>
    <segment id="20">O crime ocorreu por volta de 6h30 de ontem</segment>
    <segment id="21">, na Rua FГѓВ©lix de AraГѓВєjo</segment>
    <segment id="22">, conhecida</segment>
    <segment id="23">comocomo Rua Pequena</segment>
    <segment id="24">, no bairro de PortГѓВЈo</segment>
    <segment id="25">, em Lauro de Freitas</segment>
    <segment id="26">, onde a vГѓВ­tima mora com a mulher e a filha de quatro anos.</segment>
    <segment id="27">Em protesto</segment>
    <segment id="28">, moradores queimaram objetos e fecharam os dois sentidos da Estrada do Coco</segment>
    <segment id="29">, perto do Corpo de Bombeiros</segment>
    <segment id="30">, por  duas horas.</segment>
    <segment id="31">Na Delegacia de PortГѓВЈo</segment>
    <segment id="32">, consta que vГѓВЎrios homens em um Fiesta preto passaram atirando.</segment>
    <segment id="33">O registro aponta ainda</segment>
    <segment id="34">, segundo um policial de plantГѓВЈo</segment>
    <segment id="35">, que um dos homens</segment>
    <segment id="36">ГѓВ© conhecido</segment>
    <segment id="37">comocomo Kekel e mora no PГѓВ© Preto.</segment>
    <segment id="38">Гўв‚¬Е“Eu nГѓВЈo me conformo.</segment>
    <segment id="39">Ele ГѓВ©</segment>
    <segment id="40">comocomo</segment>
    <segment id="41">sese fosse um filho.</segment>
    <segment id="42">Nossa famГѓВ­lia ГѓВ© humilde e honestaГўв‚¬</segment>
    <segment id="43">, disse a tia.</segment>
    <segment id="44">VГѓВ­tima quer cair fora
Testemunhas contaram que quatro homens conhecidos</segment>
    <segment id="45">comocomo Lindole</segment>
    <segment id="46">, Kekel</segment>
    <segment id="47">, Alan e Chalalau participaram do atentado.</segment>
    <segment id="48">Este ГѓВєltimo</segment>
    <segment id="49">, foi apontado pela polГѓВ­cia</segment>
    <segment id="50">comocomo chefe do trГѓВЎfico e pivГѓВґ da chacina do PГѓВ© Preto</segment>
    <segment id="51">, em outubro de 2011.</segment>
    <segment id="52">Гўв‚¬Е“Eles chegaram de bicicleta.</segment>
    <segment id="53">Lindole e Kekel atiraram</segment>
    <segment id="54">, enquanto Alan e Chalalu vigiavamГўв‚¬</segment>
    <segment id="55">, diz testemunha.</segment>
    <segment id="56">Conforme os moradores</segment>
    <segment id="57">, esses atentados sГѓВЈo constantes na Rua Pequena</segment>
    <segment id="58">, principalmente nos finais de semana.</segment>
    <segment id="59">Por isso</segment>
    <segment id="60">, a famГѓВ­lia de Arielson jГѓВЎ alugou uma casa</segment>
    <segment id="61">, em JacuГѓВ­pe</segment>
    <segment id="62">, para passar os finais de semana.</segment>
    <segment id="63">Assustado com a violГѓВЄncia na rua</segment>
    <segment id="64">, Arielson sГѓВі aguarda a construГѓВ§ГѓВЈo da casa</segment>
    <segment id="65">, em Baixa Grande</segment>
    <segment id="66">, para voltar ГѓВ  cidade natal.</segment>
  </rst>
