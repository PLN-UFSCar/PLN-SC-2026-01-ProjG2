  <rst>
    <segment id="1">Manicure leva golpe pelo celular</segment>
    <segment id="2">Mulher recebe mensagem dizendo que foi premiada</segment>
    <segment id="3">, masmas leva preju de R$ 15 mil
"</segment>
    <segment id="4">Urgente!</segment>
    <segment id="5">Seu celular foi sorteado na recarga premiada na promoﾃδｧﾃδ｣o sorte na palma da mﾃδ｣o.</segment>
    <segment id="6">Mais informaﾃδｧﾃδｵes</segment>
    <segment id="7">,</segment>
    <segment id="8">ligue grﾃδ｡tis para 03185-0000-0000".</segment>
    <segment id="9">Quem nunca recebeu mensagem similar a esta e ficou feliz em saber que foi contemplado com prﾃδｪmio?</segment>
    <segment id="10">No entanto</segment>
    <segment id="11">, ﾃδｩ preciso cuidado</segment>
    <segment id="12">, pois</segment>
    <segment id="13">pois o sonho pode virar pesadelo.</segment>
    <segment id="14">Foi o que aconteceu com uma manicure de 24 anos</segment>
    <segment id="15">, que mora no bairro de Brotas.</segment>
    <segment id="16">Ela caiu no golpe e</segment>
    <segment id="17">, sem que percebesse</segment>
    <segment id="18">, foi orientada a transferir R$ 15 mil para uma conta bancﾃδ｡ria.</segment>
    <segment id="19">No sﾃδ｡bado</segment>
    <segment id="20">, 20 de dezembro de 2014</segment>
    <segment id="21">,</segment>
    <segment id="22">apﾃδｳs realizar uma recarga de R$ 7</segment>
    <segment id="23">, ela recebeu um SMS informando que havia ganhado R$ 30 mil e uma moto.</segment>
    <segment id="24">Para receber o prﾃδｪmio</segment>
    <segment id="25">, bastava ligar ou mandar mensagem para um determinado nﾃδｺmero.</segment>
    <segment id="26">Muito feliz</segment>
    <segment id="27">, ela mandou a mensagem e</segment>
    <segment id="28">, minutos depois</segment>
    <segment id="29">, recebeu ligaﾃδｧﾃδ｣o de um homem que</segment>
    <segment id="30">sese identificou</segment>
    <segment id="31">comocomo Douglas Fontineli de Lima.</segment>
    <segment id="32">Ele a orientou a ir atﾃδｩ um caixa eletrﾃδｴnico e fazer alguns procedimentos.</segment>
    <segment id="33">Nﾃδ｣o desconfiei</segment>
    <segment id="34">, parecia uma central de ligaﾃδｧﾃδ｣o.</segment>
    <segment id="35">Ele me ludibriou</segment>
    <segment id="36">, fiz uma transferﾃδｪncia para a conta dele achando que estava fazendo para a minha</segment>
    <segment id="37">, lamenta a manicure.</segment>
    <segment id="38">ﾃ｢竄ｬﾋ廨astei tudo com pﾃδｳﾃ｢竄ｬ邃｢</segment>
    <segment id="39">Segundo ela</segment>
    <segment id="40">, apﾃδｳs realizar a transaﾃδｧﾃδ｣o</segment>
    <segment id="41">, o golpista pediu que o comprovante fosse colocado em um envelope e depositado no caixa.</segment>
    <segment id="42">Ao perceber o golpe e sem saber o que fazer</segment>
    <segment id="43">, ela continuou ligando para o nﾃδｺmero atﾃδｩ o dia 25 de dezembro e foi informada pelo bandido sobre a fraude.</segment>
    <segment id="44">Ele me disse que tinha caﾃδｭdo no golpe.</segment>
    <segment id="45">Fiquei desesperada e disse: ﾃ｢竄ｬﾋ廴enino</segment>
    <segment id="46">, isso nﾃδ｣o</segment>
    <segment id="47">ﾃδｩ justo comigoﾃ｢竄ｬ邃｢.</segment>
    <segment id="48">Ele deu uma gargalhada e respondeu:</segment>
    <segment id="49">ﾃ｢竄ｬﾋ廨astei tudo com pﾃδｳ e maconhaﾃ｢竄ｬ邃｢ﾃ｢竄ｬ</segment>
    <segment id="50">, revela ela.</segment>
    <segment id="51">Com problemas renais e sem poder trabalhar</segment>
    <segment id="52">, ela estava juntando o dinheiro para abrir um salﾃδ｣o e cuidar da saﾃδｺde.</segment>
    <segment id="53">ﾃ｢竄ｬﾅ摘stou vivendo apenas com um salﾃδ｡rio mﾃδｭnimo.</segment>
    <segment id="54">Mas ﾃδｩ pouco</segment>
    <segment id="55">, pago aluguelﾃ｢竄ｬ. Apﾃδｳs tomar ciﾃδｪncia do fato</segment>
    <segment id="56">, ela foi atﾃδｩ a Delegacia da Lapinha (2ﾃつｪ DT) para registrar ocorrﾃδｪncia</segment>
    <segment id="57">, masmas foi informada por um policial que nada poderia ser feito</segment>
    <segment id="58">, jﾃδ｡ que ela mesma fez a transferﾃδｪncia.</segment>
    <segment id="59">Desconfie sempre</segment>
    <segment id="60">O delegado Charles Leﾃδ｣o</segment>
    <segment id="61">, coordenador do Grupo Especializado de Repressﾃδ｣o aos Crimes por Meios Eletrﾃδｴnicos (GME)</segment>
    <segment id="62">, da Polﾃδｭcia Civil</segment>
    <segment id="63">, orienta sobre</segment>
    <segment id="64">comocomo evitar esses golpes: ﾃ｢竄ｬﾅ泥esconfie sempre</segment>
    <segment id="65">, nunca deposite nada a tﾃδｭtulo de cadastro prﾃδｩvio.</segment>
    <segment id="66">Procure qualquer Delegacia Territorial</segment>
    <segment id="67">, os policiais estﾃδ｣o orientados a registrar a ocorrﾃδｪnciaﾃ｢竄ｬ邃｢ﾃ｢竄ｬ.</segment>
    <segment id="68">Segundo ele</segment>
    <segment id="69">, a identificaﾃδｧﾃδ｣o do criminoso nﾃδ｣o ﾃδｩ fﾃδ｡cil</segment>
    <segment id="70">, masmas nﾃδ｣o ﾃδｩ impossﾃδｭvel.</segment>
    <segment id="71">ﾃ｢竄ｬﾅ摘ssas quadrilhas sﾃδ｣o de outros estados</segment>
    <segment id="72">, o que dificulta a comunicaﾃδｧﾃδ｣o entre a polﾃδｭcia e as gerﾃδｪncias dos bancos.</segment>
    <segment id="73">Quando a polﾃδｭcia fica sabendo</segment>
    <segment id="74">, eles jﾃδ｡ sacaram o dinheiroﾃ｢竄ｬ</segment>
    <segment id="75">, diz Leﾃδ｣o.</segment>
  </rst>
