  <rst>
    <segment id="1">Novo site incentiva a pulada</segment>
    <segment id="2">de cerca
Chegou ao Brasil o Ohhtel</segment>
    <segment id="3">, um site de relacionamentos que promove encontros</segment>
    <segment id="4">Uma nova rede social tem causado polêmica entre os brasileiros.</segment>
    <segment id="5">Chegou ao País o The Ohhtel</segment>
    <segment id="6">, um site de relacionamentos parecido com o Orkut</segment>
    <segment id="7">, só que com o objetivo de os participantes serem muito mais que amigos.</segment>
    <segment id="8">Por meio dele</segment>
    <segment id="9">, os usuários podem marcar encontros para trair o seu parceiro ou</segment>
    <segment id="10">sese relacionar com pessoas casadas.</segment>
    <segment id="11">“</segment>
    <segment id="12">Uma maneira discreta de ter um</segment>
    <segment id="13">casocaso”</segment>
    <segment id="14">, é o que promete o The Ohhtel.</segment>
    <segment id="15">Já na  primeira semana em funcionamento no Brasil</segment>
    <segment id="16">,  mais de 400 homens soteropolitanos estavam inscritos.</segment>
    <segment id="17">Para as mulheres</segment>
    <segment id="18">, a inscrição é gratuita</segment>
    <segment id="19">, masmas para eles</segment>
    <segment id="20">, a brincadeira perigosa custa R$ 60.</segment>
    <segment id="21">O ideal transgressor do site</segment>
    <segment id="22">, ao propor ajudar pessoas a serem infiéis</segment>
    <segment id="23">, só vem confirmar uma característica do ser humano</segment>
    <segment id="24">, diz a psicóloga Kátia Queiroz.</segment>
    <segment id="25">Ela destaca que trair é um comportamento natural.</segment>
    <segment id="26">“</segment>
    <segment id="27">Em todas as culturas</segment>
    <segment id="28">, existem relações triangulares</segment>
    <segment id="29">, tanto do homem quanto da mulher.</segment>
    <segment id="30">Mas a sociedade</segment>
    <segment id="31">sese desenvolveu de forma que os homens são os que mais buscam prazer sexual fora do casamento”</segment>
    <segment id="32">, explica.</segment>
    <segment id="33">Homem ou mulher</segment>
    <segment id="34">, o perfil de quem procura trair pela internet é de um sedutor.</segment>
    <segment id="35">“</segment>
    <segment id="36">São pessoas que gostam de desafios</segment>
    <segment id="37">, de coisas novas</segment>
    <segment id="38">, de sair da rotina</segment>
    <segment id="39">, masmas sem nenhum comprometimento”</segment>
    <segment id="40">, destaca ela.</segment>
    <segment id="41">Culpa?</segment>
    <segment id="42">Nem um pouco.</segment>
    <segment id="43">“</segment>
    <segment id="44">Existem pessoas que não sentem a culpa de uma forma tão punitiva.</segment>
    <segment id="45">Quem opta por este tipo de site tem outra relação com a culpa”</segment>
    <segment id="46">, conclui a psicóloga.</segment>
    <segment id="47">Por causa desta matéria e também pela curiosidade</segment>
    <segment id="48">, eu me cadastrei no site The Ohhtel

Depois de criar um perfil com dados sobre idade e forma física</segment>
    <segment id="49">, comecei a olhar os tipos de homens que estavam cadastrados e logo de cara percebi qual é a ideia do site</segment>
    <segment id="50">, que em nada difere dos bate-papos de portais</segment>
    <segment id="51">comocomo Uol e IG</segment>
    <segment id="52">, em que</segment>
    <segment id="53">, no fim das contas</segment>
    <segment id="54">, todo mundo busca por sexo casual e secreto.</segment>
    <segment id="55">Não gostei</segment>
    <segment id="56">, achei forçado.</segment>
    <segment id="57">Em um dia</segment>
    <segment id="58">, recebi mensagens de dois caras que</segment>
    <segment id="59">, sem medo</segment>
    <segment id="60">, mandaram logo um link secreto para eu ter acesso às suas fotos.</segment>
    <segment id="61">Já pensou</segment>
    <segment id="62">sese eu fosse a namorada deles e os reconhecesse?</segment>
    <segment id="63">Achei muito arriscado!</segment>
    <segment id="64">Só sexo importa?</segment>
    <segment id="65">Por que as pessoas traem?</segment>
    <segment id="66">A psicóloga Kátia Queiroz diz que trair não significa que o casamento esteja ruim.</segment>
    <segment id="67">“Traição está ligada ao prazer sexual.</segment>
    <segment id="68">Muitas vezes o casamento pode ser bom em muitos aspectos</segment>
    <segment id="69">, como</segment>
    <segment id="70">como companheirismo</segment>
    <segment id="71">, masmas na cama não é tão empolgante e</segment>
    <segment id="72">, por isso</segment>
    <segment id="73">, os casais buscam fora”</segment>
    <segment id="74">, diz ela.</segment>
    <segment id="75">Assim como</segment>
    <segment id="76">como o contrário - somente um sexo de primeira não sustenta uma relação.</segment>
  </rst>
