  <rst>
    <segment id="1">Executados durante farra em Mussurunga</segment>
    <segment id="2">Na casa de um cômodo</segment>
    <segment id="3">, foram encontrados cachimbos de crack e bebidas alcoólicas</segment>
    <segment id="4">Três mulheres e um homem – cujos nomes não foram divulgados pela polícia –  foram executados com vários tiros dentro de casa</segment>
    <segment id="5">, por volta das 19h30 de quinta-feira</segment>
    <segment id="6">, 2, no Parque Recanto da Bela Vista</segment>
    <segment id="7">, localidade do bairro de Mussurunga.</segment>
    <segment id="8">Na casa de um cômodo</segment>
    <segment id="9">, foram encontrados cachimbos de crack e bebidas alcoólicas.</segment>
    <segment id="10">Segundo informações da Polícia Militar</segment>
    <segment id="11">, as vítimas</segment>
    <segment id="12">, que tinham entre 20 e 30 anos</segment>
    <segment id="13">, foram surpreendidas por dois homens armados com revólveres de calibre 32 e 38</segment>
    <segment id="14">, que chegaram e saíram do local a pé.</segment>
    <segment id="15">A suspeita é que o crime tenha sido motivado por dívidas de drogas.</segment>
    <segment id="16">De acordo com moradores da região</segment>
    <segment id="17">, o homem executado era do Bairro da Paz e há pouco tempo estava morando na casa.</segment>
    <segment id="18">Um morador que não quis</segment>
    <segment id="19">sese identificar contou que a jovem de prenome</segment>
    <segment id="20">Darci tinha envolvimento com drogas.</segment>
    <segment id="21">“</segment>
    <segment id="22">A história que sabemos é essa.</segment>
    <segment id="23">Parece</segment>
    <segment id="24">, também</segment>
    <segment id="25">, que ela estava hospedando uma mulher que já teve passagem pela polícia por porte de drogas”</segment>
    <segment id="26">, disse o morador.</segment>
    <segment id="27">Em frente à casa onde as vítimas foram executadas</segment>
    <segment id="28">, uma moradora</segment>
    <segment id="29">, que no momento do crime estava no quarto com mais quatro crianças e preferiu não dizer o nome</segment>
    <segment id="30">, disse que a jovem era  tranquila e não causava problemas.</segment>
    <segment id="31">“</segment>
    <segment id="32">Não conhecia ela de bater papo</segment>
    <segment id="33">, masmas de vez em quando ela vinha aqui pedir alguma coisa</segment>
    <segment id="34">, masmas nunca soube dela envolvida com drogas”</segment>
    <segment id="35">, conta.</segment>
    <segment id="36">O Departamento de Homicídios e Proteção à Pessoa (DHPP)</segment>
    <segment id="37">, que investiga o</segment>
    <segment id="38">casocaso</segment>
    <segment id="39">, informou que  a autoria dos homicídios ainda é ignorada.</segment>
    <segment id="40">Em junho de 2008</segment>
    <segment id="41">, outra chacina chocou os moradores de Mussurunga.</segment>
    <segment id="42">Sete pessoas</segment>
    <segment id="43">, todas elas sem ligação com o tráfico de drogas</segment>
    <segment id="44">, foram assassinadas na localidade do Baixinho de Mussurunga.</segment>
  </rst>
</analysis>