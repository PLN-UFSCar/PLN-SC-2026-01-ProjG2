  <rst>
    <segment id="1">Bebê sobrevive a acidente em Buerarema</segment>
    <segment id="2">Os pais da criança morreram no acidente</segment>
    <segment id="3">, além de mais três pessoas</segment>
    <segment id="4">Um bebê de aproximadamente dois meses de vida sobreviveu a um acidente que ocorreu na BR-101</segment>
    <segment id="5">, perto da cidade de Buerarema (a 450 km de Salvador)</segment>
    <segment id="6">, no sul da Bahia</segment>
    <segment id="7">, na noite da última quarta-feira.</segment>
    <segment id="8">Os pais da criança</segment>
    <segment id="9">, Adenildo Oliveira Amado</segment>
    <segment id="10">, 34, e Thamires Andréia C. Silva</segment>
    <segment id="11">, 38, morreram na tragédia</segment>
    <segment id="12">, além de mais três pessoas.</segment>
    <segment id="13">Adenildo e Thamires estavam dentro do GM Celta</segment>
    <segment id="14">, placa NZD-5609</segment>
    <segment id="15">, que bateu no VW Gol</segment>
    <segment id="16">, placa NTU-8054.</segment>
    <segment id="17">O bebê já teve alta médica.</segment>
    <segment id="18">Ele foi levado todo sujo de sangue para o Hospital Manuel Novais.</segment>
    <segment id="19">“Ele saiu sem nenhum arranhão</segment>
    <segment id="20">, graças à cadeirinha tipo bebê conforto</segment>
    <segment id="21">, onde ele estava sendo transportado”</segment>
    <segment id="22">, confirmou Pola Podanosqui</segment>
    <segment id="23">,  inspetora da Polícia Rodoviária Federal (PRF).</segment>
    <segment id="24">De acordo com a PRF</segment>
    <segment id="25">, o acidente aconteceu por volta das 20 horas</segment>
    <segment id="26">, no Km-529 da rodovia.</segment>
    <segment id="27">Segundo os policiais</segment>
    <segment id="28">, o Gol fazia uma ultrapassagem a uma carreta</segment>
    <segment id="29">, em local proibido</segment>
    <segment id="30">, e colidiu frontalmente com o Celta</segment>
    <segment id="31">, que seguia no sentido contrário.</segment>
    <segment id="32">Além das cinco mortes e do bebê que</segment>
    <segment id="33">sese salvou</segment>
    <segment id="34">, outras quatro pessoas ficaram feridas.</segment>
    <segment id="35">Elas foram levadas para hospitais de Itabuna.</segment>
    <segment id="36">O estado de saúde dos sobreviventes é estável.</segment>
    <segment id="37">Ocupantes do Gol morreram

Também morreram os ocupantes do Gol</segment>
    <segment id="38">, Lucas Dórea</segment>
    <segment id="39">, 38, motorista</segment>
    <segment id="40">, o filho Eduardo Oliveira Dórea</segment>
    <segment id="41">, 11 e Iliziária Ribeiro de Carvalho</segment>
    <segment id="42">, 25, que faleceu ao dar entrada no Hospital de Base.</segment>
    <segment id="43">Parentes das vítimas retiraram os corpos dos familiares</segment>
    <segment id="44">, na tarde de ontem</segment>
    <segment id="45">, no Departamento de Polícia Técnica (DPT) de Itabuna.</segment>
    <segment id="46">Adenildo e Thamires são de Arataca (a 500 km de Salvador).</segment>
    <segment id="47">Já os corpos de Lucas Dórea e o filho Eduardo Dórea foram levados para Buerarema.</segment>
    <segment id="48">O corpo de Iliziária foi levado para Eunápolis (a 644 km de Salvador).</segment>
  </rst>
</analysis>