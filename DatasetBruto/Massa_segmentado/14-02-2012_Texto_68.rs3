  <rst>
    <segment id="1">Berimbada arrasta multidão de foliões
Carnaval no bairro vai rolar todos os dias até terça-feira.</segment>
    <segment id="2">Se jogue mesmo!</segment>
    <segment id="3">O Carnaval já ganha as ruas.</segment>
    <segment id="4">No bairro do Nordeste de Amaralina</segment>
    <segment id="5">, a folia começou antes da abertura oficial do Rei Momo.</segment>
    <segment id="6">Em vez de trios elétricos</segment>
    <segment id="7">, pagode e axé</segment>
    <segment id="8">, quem deu o ritmo aos mais de 400 foliões que integraram o primeiro bloco a desfilar foram 50 berimbaus e atabaques dos inúmeros grupos de capoeira do Nordeste.</segment>
    <segment id="9">“Somos  a Berimbada</segment>
    <segment id="10">, o arrastão da capoeira.</segment>
    <segment id="11">Estamos abrindo oficialmente a folia no circuito Mestre Bimba.</segment>
    <segment id="12">Nosso bloco é gratuito e temos ala de baianas</segment>
    <segment id="13">, ala em homenagem a África</segment>
    <segment id="14">,  ala das crianças e dos mestres e professores de capoeira”</segment>
    <segment id="15">, afirma Paulo Lé</segment>
    <segment id="16">, coordenador da agremiação.</segment>
    <segment id="17">O contador Luís Eduardo Santos era um dos mais entusiasmados com a folia no bairro.</segment>
    <segment id="18">“</segment>
    <segment id="19">Esta festa ocorre há sete anos.</segment>
    <segment id="20">O Carnaval daqui é tudo de bom”.</segment>
    <segment id="21">Quem também demonstrava muito orgulho em percorrer as ruas do Nordeste era a professora de dança Gisélia Santos.</segment>
    <segment id="22">“Saber que nosso desfile é o primeiro a acontecer em 2012 é uma grande vitória.</segment>
    <segment id="23">Isso é bom para as pessoas verem que no Nordeste de Amaralina tem gente de bem</segment>
    <segment id="24">, que preza pela paz”</segment>
    <segment id="25">, afirmou.

 

 

Circuito Mestre Bimba</segment>
    <segment id="26">O circuito Mestre Bimba  não existe oficialmente</segment>
    <segment id="27">, apesar de o Carnaval do bairro acontecer há sete anos.</segment>
    <segment id="28">Antigamente</segment>
    <segment id="29">, não existia um nome para o circuito.</segment>
    <segment id="30">Mas este ano</segment>
    <segment id="31">, em uma eleição</segment>
    <segment id="32">, resolveram homenagear Mestre Bimba</segment>
    <segment id="33">, que foi morador do bairro e</segment>
    <segment id="34">sese tornou conhecido nacionalmente pela arte da capoeira.</segment>
  </rst>
