  <rst>
    <segment id="1">Polícia acaba festa de sexo e drogas</segment>
    <segment id="2">Foram presas 61 pessoas</segment>
    <segment id="3">, sendo 41 adolescentes convocados pelas redes sociais</segment>
    <segment id="4">A Polícia Civil prendeu 61 pessoas</segment>
    <segment id="5">, sendo 41 adolescentes</segment>
    <segment id="6">, em uma festa regada a sexo e drogas no município de Senhor do Bonfim</segment>
    <segment id="7">, a 375 km de Salvador.</segment>
    <segment id="8">Os organizadores da Erótiko’s Fest convocaram os jovens pelas redes sociais da internet para a balada</segment>
    <segment id="9">, que aconteceu na noite de anteontem.</segment>
    <segment id="10">A festa de horrores foi descoberta pelo Comissariado da Infância e Juventude</segment>
    <segment id="11">, que denunciou ao Ministério Público.</segment>
    <segment id="12">Com mandado de busca e apreensão expedido pelo juiz Tardelli Boaventura</segment>
    <segment id="13">, a polícia acabou com a festa   que</segment>
    <segment id="14">, em seu cartaz de divulgação</segment>
    <segment id="15">, anunciava bebida de graça.</segment>
    <segment id="16">Além disso</segment>
    <segment id="17">, estabelecia que mulheres deveriam obrigatoriamente usar biquínis para garantir entrada gratuita e que os homens pagariam entre R$ 15 e R$ 20.</segment>
    <segment id="18">A casa onde aconteceu o reggae fica na avenida Salvador</segment>
    <segment id="19">, no centro de Senhor do Bonfim.</segment>
    <segment id="20">É um sobrado com piscina e churrasqueira no terraço.</segment>
    <segment id="21">A casa estava desocupada e foi alugada apenas para este fim.</segment>
    <segment id="22">Lá, a polícia encontrou drogas e dinheiro</segment>
    <segment id="23">, possível  fruto da venda de ingressos.</segment>
    <segment id="24">Com 18 anos</segment>
    <segment id="25">, foram presos Rodrigo Emanuele Oliveira de Carvalho por tráfico e Vitor Alves</segment>
    <segment id="26">, por tráfico e por fornecer álcool a menores de idade</segment>
    <segment id="27">, prática proibida pelo Estatuto da Criança e do Adolescente.</segment>
    <segment id="28">Os demais foram ouvidos e liberados.</segment>
    <segment id="29">Os 41 adolescentes foram encaminhados ao Fórum acompanhados pelos comissários</segment>
    <segment id="30">, e aguardaram a presença dos pais que assinaram Termo de Compromisso.</segment>
    <segment id="31">Depois</segment>
    <segment id="32">, foram liberados.</segment>
    <segment id="33">Investigação continua</segment>
    <segment id="34">O delegado Felipe Nery disse que Vitor Alves foi quem organizou a festa e alugou a casa.</segment>
    <segment id="35">A polícia vai continuar as investigações e ouvir outras pessoas.</segment>
    <segment id="36">Os adolescentes podem ser novamente chamados.</segment>
    <segment id="37">A promotora da Infância e Juventude</segment>
    <segment id="38">, Ítala Suzana da Silva Carvalho Luz</segment>
    <segment id="39">, faz um alerta para os pais a fim de que “executem vigilância mais efetiva dos locais frequentados pelos filhos e das companhias que dizem ter”.</segment>
    <segment id="40">Além disso</segment>
    <segment id="41">, ela ressalta a importância de ficarem mais atentos aos acessos à internet</segment>
    <segment id="42">, meio utilizado para divulgar a festa.</segment>
    <segment id="43">Para a promotora</segment>
    <segment id="44">, é preciso haver mais campanhas de conscientização dos perigos das drogas e álcool</segment>
    <segment id="45">, com envolvimento maior dos pais.</segment>
    <segment id="46">“Precisamos ainda de políticas públicas de orientação aos pais</segment>
    <segment id="47">para que</segment>
    <segment id="48">para que retomem maior controle sobre os filhos”</segment>
    <segment id="49">, destaca.</segment>
  </rst>
</analysis>