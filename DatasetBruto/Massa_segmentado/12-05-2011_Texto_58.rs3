  <rst>
    <segment id="1">Marco Maia e outros deputados farão viagens internacionais no calor do debate do Código Florestal</segment>
    <segment id="2">Duas viagens internacionais vão afastar da Câmara</segment>
    <segment id="3">, na semana que vem</segment>
    <segment id="4">, o presidente da Casa</segment>
    <segment id="5">, Marco Maia (PT-RS)</segment>
    <segment id="6">, e os líderes das duas maiores bancadas - a do PT</segment>
    <segment id="7">, Paulo Teixeira (SP)</segment>
    <segment id="8">, e a do PMDB</segment>
    <segment id="9">, Henrique Eduardo Alves (RN) -</segment>
    <segment id="10">, esvaziando o debate do Código Florestal.</segment>
    <segment id="11">Estão nas duas missões pelo menos mais três deputados.</segment>
    <segment id="12">INFOGRÁFICO: Confira os principais pontos do Código Florestal
SEM PREVISÃO: Votação do novo Código Florestal não será na semana que vem
Marco Maia embarcou nesta quinta-feira para a Coreia do Sul</segment>
    <segment id="13">, acompanhado de quatro deputados: Paulo Teixeira</segment>
    <segment id="14">, Arlindo Chinaglia (PT-SP)</segment>
    <segment id="15">, Carlos Alberto Leréia (PSDB-GO) e Cláudio Cajado (DEM-BA)</segment>
    <segment id="16">, para participar da IIª Cúpula Parlamentar do G-20</segment>
    <segment id="17">, entre 18 e 20 de maio.</segment>
    <segment id="18">Henrique Eduardo Alves estará na comitiva do vice-presidente</segment>
    <segment id="19">, Michel Temer</segment>
    <segment id="20">, à Rússia.</segment>
    <segment id="21">Eles embarcam nesta sexta-feira e retornam terça-feira.</segment>
    <segment id="22">Temer preside um grupo bilateral de cooperação Brasil-Rússia.</segment>
    <segment id="23">Na comitiva estão ainda representantes dos ministérios de Ciência e Tecnologia e da Agricultura</segment>
    <segment id="24">, e da Eletrobrás</segment>
    <segment id="25">, entre outros.</segment>
    <segment id="26">A viagem até Seul dura dois dias</segment>
    <segment id="27">, e os cinco devem chegar lá no sábado.</segment>
    <segment id="28">Apesar de a cúpula só começar dia 18</segment>
    <segment id="29">, Maia terá</segment>
    <segment id="30">, entre os dias 16 e 18</segment>
    <segment id="31">, agendas bilaterais.</segment>
    <segment id="32">O primeiro compromisso de Maia está previsto para a noite de domingo</segment>
    <segment id="33">, um jantar na embaixada do Brasil com parlamentares e empresários.</segment>
    <segment id="34">A comitiva de Maia só retorna ao Brasil domingo</segment>
    <segment id="35">, dia 22.</segment>
    <segment id="36">Além da reunião do G-20 e encontros bilaterais</segment>
    <segment id="37">, Maia deverá visitar centros industriais da Coreia e fará uma viagem no Trem de Alta Velocidade.</segment>
    <segment id="38">A Câmara não informou o gasto com a viagem nem os voos e hotéis da comitiva.</segment>
    <segment id="39">O preço dos voos de ida e volta para Seul - cada trecho pode durar até 46 horas com uma ou duas paradas - varia de R$ 3</segment>
    <segment id="40">,5 mil a R$ 26 mil.</segment>
    <segment id="41">Em Seul</segment>
    <segment id="42">, a diária de hotéis quatro e cinco estrelas custa de R$ 300 a R$ 660.</segment>
    <segment id="43">A comitiva de Temer viajará à Rússia em avião da Força Aérea Brasileira.</segment>
  </rst>
</analysis>