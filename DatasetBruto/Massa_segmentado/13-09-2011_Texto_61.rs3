  <rst>
    <segment id="1">Um lar doce lar para o campeão</segment>
    <segment id="2">Galera faz campanha na internet</segment>
    <segment id="3">para que</segment>
    <segment id="4">para que Luciano Huck reforme a casa de Holyfield
Ver a casa do ex-pugilista Reginaldo Holyfield reformada pelo quadro Lar Doce Lar</segment>
    <segment id="5">, do programa Caldeirão do Huck.</segment>
    <segment id="6">Este é o objetivo da campanha que está sendo feita no site de relacionamento Facebook e no Twitter.</segment>
    <segment id="7">Com o tema</segment>
    <segment id="8">, “</segment>
    <segment id="9">A Bahia pede a Luciano</segment>
    <segment id="10">Huck o Lar Doce</segment>
    <segment id="11">Lar para nosso baiano Holyfield”</segment>
    <segment id="12">, a mensagem foi publicada nos murais de milhares de internautas  durante todo o dia  e ganhou destaque em  sites de notícias.</segment>
    <segment id="13">Holyfield está internado no Hospital Geral do Estado (HGE) desde a última quarta-feira</segment>
    <segment id="14">, quando teve 30% do corpo queimado depois de salvar dois sobrinhos de um incêndio na casa da irmã (que fica no 2º andar do sobrado onde a família mora</segment>
    <segment id="15">, no bairro de Massaranduba).</segment>
    <segment id="16">Por telefone</segment>
    <segment id="17">, ele disse que gostaria muito de ter a oportunidade  de participar do quadro.</segment>
    <segment id="18">“Cada dia mais as pessoas boas</segment>
    <segment id="19">sese aproximam de mim.</segment>
    <segment id="20">Fico muito feliz com esse carinho”</segment>
    <segment id="21">, disse o ex-lutador por telefone.</segment>
    <segment id="22">“</segment>
    <segment id="23">Fiz o possível e o impossível para honrar o nome da Bahia no boxe.</segment>
    <segment id="24">Essa campanha é o reconhecimento do meu esforço”</segment>
    <segment id="25">, completou.</segment>
    <segment id="26">Desde que</segment>
    <segment id="27">sese separou de sua mulher</segment>
    <segment id="28">, há 12 anos</segment>
    <segment id="29">, ele mora na casa da mãe (no térreo do sobrado) e</segment>
    <segment id="30">, quando o assunto é arrumar a casa</segment>
    <segment id="31">, ninguém tem dúvida sobre suas prioridades :</segment>
    <segment id="32">“</segment>
    <segment id="33">Ele sempre desejou ter dinheiro para arrumar a sala e a cozinha da mãe.</segment>
    <segment id="34">Queria deixar tudo organizado”</segment>
    <segment id="35">, disse a irmã Almerinda da Silva de Andrade</segment>
    <segment id="36">, 41, mãe dos meninos salvos no incêndio.</segment>
    <segment id="37">Desempregado há quase três anos</segment>
    <segment id="38">,  ele ainda não pôde realizar o desejo.</segment>
    <segment id="39">"</segment>
    <segment id="40">Para nós isso é novidade.</segment>
    <segment id="41">A gente não tem  internet</segment>
    <segment id="42">,

não sabemos nem mexer.</segment>
    <segment id="43">Se puder</segment>
    <segment id="44">, eu quero camas para mim e

meus dois filhos e um guarda-roupas novo".</segment>
    <segment id="45">Almerinda Andrade</segment>
    <segment id="46">, 41
Irmã

 

"Seria uma bênção</segment>
    <segment id="47">sese ele (Luciano Huck) viesse e

arrumasse todo o prédio.</segment>
    <segment id="48">Mas a prioridade é Reginaldo</segment>
    <segment id="49">,

é  ajeitar a casa de minha mãe</segment>
    <segment id="50">, onde ele mora". 
Telma de Andrade</segment>
    <segment id="51">, 49
Irmã

 

"</segment>
    <segment id="52">Estou torcendo</segment>
    <segment id="53">para que</segment>
    <segment id="54">para que dê certo.</segment>
    <segment id="55">Meu pai está precisando.</segment>
    <segment id="56">A casa de minha avó é muito mal-estruturada.</segment>
    <segment id="57">Ele é merecedor por tudo que já fez</segment>
    <segment id="58">, não só</segment>
    <segment id="59">comocomo lutador".</segment>
    <segment id="60">Pâmela de Andrade</segment>
    <segment id="61">, 17
Filha</segment>
    <segment id="62">Nove em uma casa:</segment>
    <segment id="63">Galera dorme junta</segment>
    <segment id="64">A mãe dele</segment>
    <segment id="65">, dona Maria de Lurdes da Silva</segment>
    <segment id="66">, 86, também gostaria de dar opinião na obra.</segment>
    <segment id="67">“Eu gostaria muito de ter um cantinho só meu”</segment>
    <segment id="68">, disse.</segment>
    <segment id="69">Isso porque</segment>
    <segment id="70">porque</segment>
    <segment id="71">, além do lutador e da mãe</segment>
    <segment id="72">,  outras 7 pessoas moram na casa (uma filha</segment>
    <segment id="73">, três netos e três bisnetos).</segment>
    <segment id="74">Desses</segment>
    <segment id="75">, quatro dormem no quarto com ela</segment>
    <segment id="76">, já que a residência possui apenas dois quartos e o lutador ocupa o outro.</segment>
    <segment id="77">Dona Maria fez questão de mostrar o estofado gasto e quebrado e as comidas armazenadas em panelas por falta de armários.</segment>
    <segment id="78">Mas diz que  só quer “uma cama e uma peça para colocar as ‘roupinhas’ de Reginaldo”.

 

Entenda o</segment>
    <segment id="79">casocaso</segment>
    <segment id="80">“</segment>
    <segment id="81">A ideia é fazer um movimento entre nossos contatos para colocar no mural este pedido a Luciano Huck e a produção do quadro Lar Doce Lar</segment>
    <segment id="82">, para que</segment>
    <segment id="83">para que eles possam ajudar”</segment>
    <segment id="84">, diz a mensagem da campanha na rede social Facebook.</segment>
    <segment id="85">Por enquanto</segment>
    <segment id="86">, ainda não houve resposta do apresentador nem da produção do programa.</segment>
    <segment id="87">Em seu Twitter</segment>
    <segment id="88">, Luciano informou que estava nos Estados Unidos a trabalho</segment>
    <segment id="89">, masmas que voltaria ao Brasil hoje.</segment>
  </rst>
