  <rst>
    <segment id="1">Gigante de Aço encara o ‘terror’</segment>
    <segment id="2">O zagueiro Rafael Donato ganha a vaga de Danny Morais na defesa e estreia no tricolor</segment>
    <segment id="3">A partida de hoje</segment>
    <segment id="4">, entre Bahia e Juazeirense</segment>
    <segment id="5">, às 8h30 da noite</segment>
    <segment id="6">, em Pituaçu</segment>
    <segment id="7">, pode ser comparada à conhecida história de Davi e Golias.</segment>
    <segment id="8">É que o grandalhão Rafael Donato</segment>
    <segment id="9">, 1,93 m</segment>
    <segment id="10">, que estreia com a camisa do Esquadrão</segment>
    <segment id="11">, deve ter pela frente o baixinho Clodoaldo</segment>
    <segment id="12">, 1,61 m.</segment>
    <segment id="13">Porém, o zagueiro quer um final diferente neste combate e está ligado para não perdê-lo.</segment>
    <segment id="14">“Estou  preparado</segment>
    <segment id="15">, independente de quem eu for marcar.</segment>
    <segment id="16">Vi muitos jogos do Clodoaldo.</segment>
    <segment id="17">Vou procurar dar o meu melhor e fazer o possível para pará-lo”</segment>
    <segment id="18">, prometeu Donato.</segment>
    <segment id="19">E todo cuidado é pouco na hora de marcar Clodoaldo</segment>
    <segment id="20">, um dos artilheiros do Estadual com três gols.</segment>
    <segment id="21">O atacante é famoso por aterrorizar as defesas adversárias e ganhou até música quando defendia o Fortaleza: “</segment>
    <segment id="22">Uh, terror!</segment>
    <segment id="23">Clodoaldo é matador!</segment>
    <segment id="24">”.</segment>
    <segment id="25">“</segment>
    <segment id="26">A gente</segment>
    <segment id="27">sese prepara justamente para essas horas</segment>
    <segment id="28">, onde vamos enfrentar um time qualificado.</segment>
    <segment id="29">O condicionamento físico está fazendo a diferença para o Juazeirense</segment>
    <segment id="30">, que vencerá o jogo”</segment>
    <segment id="31">, garantiu Clodoaldo.</segment>
    <segment id="32">Se o time do interior está bem preparado</segment>
    <segment id="33">, o Bahia fará de tudo para vencer a primeira no Baianão</segment>
    <segment id="34">, até colocar  em campo um zagueiro parecido com um jogador de basquete.</segment>
    <segment id="35">“</segment>
    <segment id="36">A brincadeira é normal.</segment>
    <segment id="37">Gosto de basquete</segment>
    <segment id="38">, masmas graças a Deus minhas qualidades servem mesmo para intimidar dentro de campo</segment>
    <segment id="39">, claro que dentro do respeito”</segment>
    <segment id="40">, contou Donato.</segment>
  </rst>
</analysis>