  <rst>
    <segment id="1">Construtora responsável por reforma do Planalto diz que ainda tem dinheiro para receber e pode ir à Justiça
BRASÍLIA - A reforma do Palácio do Planalto</segment>
    <segment id="2">, obra que já consumiu R$ 112 milhões e ainda não chegou ao fim</segment>
    <segment id="3">, pode acabar na Justiça.</segment>
    <segment id="4">O dono da construtora Porto Belo</segment>
    <segment id="5">, Celso de Paula</segment>
    <segment id="6">, diz que entrará com ação de cobrança judicial contra o governo</segment>
    <segment id="7">, por serviços adicionais que</segment>
    <segment id="8">, segundo ele</segment>
    <segment id="9">, foram feitos e nunca pagos.</segment>
    <segment id="10">O governo contesta os valores cobrados.</segment>
    <segment id="11">Celso nega que tenha havido superfaturamento e cita auditorias do Tribunal de Contas da União (TCU) que não constataram sobrepreço.</segment>
    <segment id="12">Em dois acórdãos</segment>
    <segment id="13">, o TCU diz que as irregularidades identificadas foram corrigidas.</segment>
    <segment id="14">A construtora foi contratada pelo Exército</segment>
    <segment id="15">, encarregado de gerir a obra.</segment>
    <segment id="16">Em resposta ao GLOBO</segment>
    <segment id="17">, o Exército admitiu que existe uma dívida de R$ 3</segment>
    <segment id="18">,5 milhões com a Porto Belo.</segment>
    <segment id="19">Isso elevará o custo final da reforma para R$ 115</segment>
    <segment id="20">,5 milhões.</segment>
    <segment id="21">Mas o dono da empresa quer mais R$ 8 milhões.</segment>
    <segment id="22">Ele ressalva que o valor até pode ser menor</segment>
    <segment id="23">, pois</segment>
    <segment id="24">pois está em discussão com o Exército.

- Não sou São Francisco.</segment>
    <segment id="25">Acredito que vá ter que ir para a Justiça</segment>
    <segment id="26">, não tem outro caminho.</segment>
    <segment id="27">O Exército não admite.</segment>
    <segment id="28">Eu não roubei</segment>
    <segment id="29">, eu fiz</segment>
    <segment id="30">, eu quero receber.</segment>
    <segment id="31">É justo.</segment>
    <segment id="32">Não vou ficar no prejuízo - disse Celso ao GLOBO nesta terça-feira</segment>
    <segment id="33">, por telefone.</segment>
    <segment id="34">O custo inicial da obra</segment>
    <segment id="35">, que deveria ter ficado pronta em abril de 2010</segment>
    <segment id="36">, por ocasião dos 50 anos de Brasília</segment>
    <segment id="37">, era de R$ 78 milhões.</segment>
    <segment id="38">O valor subiu e o palácio só voltou a ser ocupado pela Presidência da República em setembro do ano passado</segment>
    <segment id="39">, com mais de quatro meses de atraso.</segment>
    <segment id="40">Segundo Celso</segment>
    <segment id="41">, o motivo foram os constantes pedidos para acrescentar itens não contratados originalmente.</segment>
    <segment id="42">Ele cita o isolamento acústico do gabinete presidencial e a remoção de um tanque de óleo diesel.</segment>
    <segment id="43">Em relação aos R$ 8 milhões</segment>
    <segment id="44">, eles seriam referentes a despesas</segment>
    <segment id="45">comocomo o aluguel de geradores de energia elétrica para suprir a falta de luz da companhia de energia de Brasília</segment>
    <segment id="46">, durante a execução dos serviços.

- Não existiu obra com mais visibilidade no país.</segment>
    <segment id="47">Só maluco faria rolo ali - diz o construtor.</segment>
    <segment id="48">Em nota</segment>
    <segment id="49">, o Centro de Comunicação Social do Exército informou: "</segment>
    <segment id="50">Em relação ao pedido de reconhecimento de dívida realizado pela empresa Porto Belo</segment>
    <segment id="51">, além dos 290 mil reais que restam pagar</segment>
    <segment id="52">, em razão das pendências identificadas</segment>
    <segment id="53">, o Exército reconhece a dívida de 3</segment>
    <segment id="54">,5 milhões de reais</segment>
    <segment id="55">, por meio da fiscalização realizada na obra.</segment>
    <segment id="56">"</segment>
    <segment id="57">Celso reconhece que há pendências na reforma.</segment>
    <segment id="58">Ele diz que pediu prazo de seis meses para saná-las.</segment>
    <segment id="59">Segundo Celso</segment>
    <segment id="60">, o prazo é demasiadamente longo</segment>
    <segment id="61">, masmas foi solicitado</segment>
    <segment id="62">porque</segment>
    <segment id="63">porque</segment>
    <segment id="64">, segundo ele</segment>
    <segment id="65">, é comum a Presidência pedir o adiamento do início das obras</segment>
    <segment id="66">, para não atrapalhar a rotina do palácio.</segment>
    <segment id="67">Ele disse que</segment>
    <segment id="68">, a pedido da Casa Civil</segment>
    <segment id="69">, aceitou trocar parte da grama do palácio</segment>
    <segment id="70">, sem custo adicional.</segment>
  </rst>
</analysis>