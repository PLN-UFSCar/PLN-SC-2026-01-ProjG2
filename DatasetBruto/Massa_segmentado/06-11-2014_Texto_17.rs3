  <rst>
    <segment id="1">Amor supera qualquer barreira
Natalita</segment>
    <segment id="2">, 60 anos</segment>
    <segment id="3">, e Ramon</segment>
    <segment id="4">, 17, passaram o maior perrengue para casar</segment>
    <segment id="5">Minutos ap횄쨀s conhecer Natalina</segment>
    <segment id="6">, 60, Ramon</segment>
    <segment id="7">, 17, elogiou sua apar횄짧ncia</segment>
    <segment id="8">, sese ofereceu para levar seus pertences ao ponto de 횄쨈nibus</segment>
    <segment id="9">, pediu o n횄쨘mero do telefone e roubou-lhe um beijo.</segment>
    <segment id="10">O encontro ocorreu no dia 17 de novembro de 2013 na praia</segment>
    <segment id="11">, em Jardim de Alah.</segment>
    <segment id="12">No 횄쨘ltimo dia 25 de outubro</segment>
    <segment id="13">, a operadora de telecomunica횄짠횄짙o e o motoboy que cursa a 1횂짧 s횄짤rie do ensino m횄짤dio</segment>
    <segment id="14">sese casaram na Igreja Divino Esp횄짯rito Santo</segment>
    <segment id="15">, no Vale dos Lagos</segment>
    <segment id="16">, em cerim횄쨈nia coletiva.</segment>
    <segment id="17">Antes, enfrentarem o preconceito de parentes</segment>
    <segment id="18">, amigos e at횄짤 do padre da Igreja de S횄짙o Francisco</segment>
    <segment id="19">, na Boca do Rio</segment>
    <segment id="20">, onde moram.</segment>
    <segment id="21">O p횄징roco n횄짙o</segment>
    <segment id="22">sese contentou com o documento de emancipa횄짠횄짙o de Ramon e pediu uma declara횄짠횄짙o escrita 횄혻 m횄짙o pela m횄짙e do rapaz.</segment>
    <segment id="23">A diferen횄짠a de idade de 43 anos n횄짙o</segment>
    <segment id="24">횄짤 a 횄쨘nica coisa que chama aten횄짠횄짙o.</segment>
    <segment id="25">Diferentemente do que manda a tradi횄짠횄짙o</segment>
    <segment id="26">, foi ele quem recebeu o sobrenome dela.</segment>
    <segment id="27">Ou melhor</segment>
    <segment id="28">, ele pediu para usar o sobrenome da amada.</segment>
    <segment id="29">Sendo assim</segment>
    <segment id="30">, ela continuou a</segment>
    <segment id="31">sese chamar Natalina Miranda Barbosa e ele passou a</segment>
    <segment id="32">sese chamar Ramon de Jesus Santos Barbosa.</segment>
    <segment id="33">N횄짙o queria adotar o sobrenome dele para n횄짙o  perder o do meu pai.</segment>
    <segment id="34">Ele aceitou e pediu para usar o meu nome.</segment>
    <segment id="35">Me senti honrada com o pedido.</segment>
    <segment id="36">Para mim</segment>
    <segment id="37">, foi um presente que ele me deu</segment>
    <segment id="38">, disse Natalina.</segment>
    <segment id="39">Maratona em busca de aprova횄짠횄짙o</segment>
    <segment id="40">Os dois j횄징 moravam juntos h횄징</segment>
    <segment id="41">seis meses.</segment>
    <segment id="42">Isto porque</segment>
    <segment id="43">porque</segment>
    <segment id="44">, no in횄짯cio</segment>
    <segment id="45">, a m횄짙e de Ramon n횄짙o aceitava o relacionamento e ele saiu de casa.</segment>
    <segment id="46">At횄짤 desejar o mal para o filho a mulher desejou.</segment>
    <segment id="47">Depois</segment>
    <segment id="48">, ela aceitou e hoje vive no maior chamego com a nora.</segment>
    <segment id="49">Desde que est횄짙o juntos</segment>
    <segment id="50">, Ramon pediu Natalina em casamento v횄징rias vezes.</segment>
    <segment id="51">Mas ela n횄짙o acreditava que ele estivesse falando s횄짤rio.</segment>
    <segment id="52">Ent횄짙o</segment>
    <segment id="53">, o rapaz fez um pedido por escrito.</segment>
    <segment id="54">S횄쨀 a횄짯 ela acreditou e aceitou.</segment>
    <segment id="55">Mas, para ter o consentimento da igreja</segment>
    <segment id="56">, os dois passaram por uma verdadeira maratona.</segment>
    <segment id="57">Houve entrevista de duas horas do padre com cada um e eles</segment>
    <segment id="58">sese comprometeram em fazer catequese durante um ano para</segment>
    <segment id="59">sese batizar na Igreja de S횄짙o Francisco.</segment>
    <segment id="60">Al횄짤m, 횄짤 claro</segment>
    <segment id="61">, da declara횄짠횄짙o de pr횄쨀prio punho da m횄짙e do rapaz.</segment>
    <segment id="62">Tudo deu t횄짙o certo que parentes e amigos fizeram quest횄짙o de ajudar na cerim횄쨈nia.</segment>
    <segment id="63">Eles ganharam de presente as alian횄짠as</segment>
    <segment id="64">, o bolo</segment>
    <segment id="65">, doces e salgados</segment>
    <segment id="66">, al횄짤m de um espa횄짠o na igreja para a festa.</segment>
    <segment id="67">Plano de adotar meninas</segment>
    <segment id="68">Foi uma experi횄짧ncia 횄쨘nica.</segment>
    <segment id="69">N횄짙o tenho nem palavras para descrever.</segment>
    <segment id="70">Eu nunca pensei que isso iria acontecer comigo e aconteceu com uma pessoa que eu realmente gosto.</segment>
    <segment id="71">Eu posso dizer que a amo.</segment>
    <segment id="72">N횄짙o consigo ficar sem ela</segment>
    <segment id="73">, declarou-</segment>
    <segment id="74">sese Ramon.</segment>
    <segment id="75">Para mim</segment>
    <segment id="76">, foi como</segment>
    <segment id="77">como se</segment>
    <segment id="78">se eu estivesse entrado em outra dimens횄짙o.</segment>
    <segment id="79">Foi como</segment>
    <segment id="80">como um conto de fadas</segment>
    <segment id="81">, disse Natalina</segment>
    <segment id="82">, que teve o apoio dos dois filhos.</segment>
    <segment id="83">Felizes e a cada dia mais apaixonados</segment>
    <segment id="84">, Natalina e Ramon t횄짧m planos de comprar uma casa maior e adotar duas meninas negras daqui a dois anos.</segment>
  </rst>
