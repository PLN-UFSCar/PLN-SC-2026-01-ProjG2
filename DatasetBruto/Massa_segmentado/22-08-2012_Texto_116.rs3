    <segment id="7">, durante o dia e</segment>
    <segment id="8">, ﾃδ noite</segment>
    <segment id="9">, aos estudos do 1ﾃつｺ ano do Ensino Mﾃδｩdio no Colﾃδｩgio Estadual Reitor Miguel Calmon</segment>
    <segment id="10">, no Centro de Simﾃδｵes Filho.</segment>
    <segment id="11">Na noite de segunda-feira (20)</segment>
    <segment id="12">, apﾃδｳs mais um dia de trabalho</segment>
