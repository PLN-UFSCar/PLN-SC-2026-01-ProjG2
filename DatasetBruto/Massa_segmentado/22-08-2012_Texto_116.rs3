    <segment id="17">ﾃ｢竄ｬﾅ溺eu filho era um menino bom</segment>
    <segment id="18">, estudioso.</segment>
    <segment id="19">Nﾃδ｣o usava drogas</segment>
    <segment id="20">, nﾃδ｣o</segment>
    <segment id="21">sese envolvia com traficantes.</segment>
    <segment id="22">Isso nﾃδ｣o pode ficar assimﾃ｢竄ｬ</segment>
    <segment id="23">, disse a mﾃδ｣e</segment>
    <segment id="24">, tomada pela emoﾃδｧﾃδ｣o e revolta.</segment>
    <segment id="25">Relatos de populares  apontam duas possﾃδｭveis motivaﾃδｧﾃδｵes para o crime.</segment>
    <segment id="26">Segundo uma delas</segment>
    <segment id="27">, Tiago foi ameaﾃδｧado de morte durante uma discussﾃδ｣o com um colega de sala</segment>
    <segment id="28">, na escola</segment>
    <segment id="29">, no dia anterior.</segment>
    <segment id="30">ﾃ｢竄ｬﾅ摘u perguntei sobre essa discussﾃδ｣o</segment>
    <segment id="31">, masmas ele disse que foi um bate-boca boboﾃ｢竄ｬ</segment>
    <segment id="32">, diz o pai</segment>
    <segment id="33">, o motorista Edson Josﾃδｩ Pereira</segment>
    <segment id="34">, 45.</segment>
    <segment id="35">Outra versﾃδ｣o aponta o namoro de Tiago com a ex-namorada de um traficante do bairro Jardim Eldorado.</segment>
    <segment id="36">O assassinato seria uma vinganﾃδｧa</segment>
    <segment id="37">, pois</segment>
    <segment id="38">pois a menina teria trocado o bandido pela vﾃδｭtima.</segment>
    <segment id="39">Vﾃδｭtima ainda tentou correr</segment>
    <segment id="40">Conforme relatos de moradores</segment>
    <segment id="41">, que preferiram nﾃδ｣o</segment>
    <segment id="42">sese identificar</segment>
    <segment id="43">, quatro homens participaram da morte do jovem.</segment>
    <segment id="44">ﾃ｢竄ｬﾅ摘les chegaram em um Uno branco e pararam na Rua do Pantanal.</segment>
    <segment id="45">Dois desceram e seguiram ao encontro do menino</segment>
    <segment id="46">, que estava em pﾃδｩ no ponto.</segment>
    <segment id="47">Jﾃδ｡ chegaram atirando.</segment>
