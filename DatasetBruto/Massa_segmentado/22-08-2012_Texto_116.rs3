    <segment id="49">O menino correu.</segment>
    <segment id="50">Aﾃδｭ, eles deram mais dois tirosﾃ｢竄ｬ</segment>
    <segment id="51">, relatou um morador.</segment>
    <segment id="52">Segundo outro morador</segment>
    <segment id="53">, a polﾃδｭcia nﾃδ｣o deu as caras no local.</segment>
    <segment id="54">ﾃ｢竄ｬﾅ泥epois dos tiros</segment>
    <segment id="55">, os bandidos ainda ficaram aﾃδｭ por cerca de 20 minutos.</segment>
    <segment id="56">Os moradores que levaram o menino para o hospital</segment>
