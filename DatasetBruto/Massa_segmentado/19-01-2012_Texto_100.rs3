  <rst>
    <segment id="1">Dois moleques contra um trabalhador
Eles alegam que a vítima reagiu</segment>
    <segment id="2">, masmas nada justifica as 10 facadas que deram</segment>
    <segment id="3">Um jovem casal foi identificado pela polícia</segment>
    <segment id="4">comocomo responsável pelo assalto que terminou com a morte</segment>
    <segment id="5">, a facadas</segment>
    <segment id="6">, do taxista</segment>
    <segment id="7">Manoel Francisco dos Santos</segment>
    <segment id="8">, 74 anos.</segment>
    <segment id="9">O crime ocorreu  no último dia 10</segment>
    <segment id="10">, na Rua Dias Gomes</segment>
    <segment id="11">,  Piatã.</segment>
    <segment id="12">Marcos Antônio Mota Evangelista</segment>
    <segment id="13">, 20, e Amanda Carvalho de Meneses</segment>
    <segment id="14">, 18, foram presos por policiais da Delegacia de Itapuã.</segment>
    <segment id="15">Os dois buscaram refúgio em Cachoeira (a 115 km de Salvador)</segment>
    <segment id="16">, onde alugaram uma casa por R$ 180.</segment>
    <segment id="17">Conforme a delegada Aymara Bandeira</segment>
    <segment id="18">, ambos confessaram participação no delito e já estão com a prisão temporária decretada pela Justiça.</segment>
    <segment id="19">Marcos e Amanda serão indiciados por latrocínio (roubo seguido de morte).</segment>
    <segment id="20">A pena para o crime é de reclusão de 20 a 30 anos.</segment>
    <segment id="21">Segundo o depoimento de Amanda</segment>
    <segment id="22">, tudo corria para um assalto bem-sucedido.</segment>
    <segment id="23">Porém, o excesso de violência atribuído a Marcos começou a deixar a situação fora de controle.</segment>
    <segment id="24">O casal tomou o táxi (um Corsa) na Avenida Vasco da Gama</segment>
    <segment id="25">, pedindo que o pracista fosse para Piatã.</segment>
    <segment id="26">Chegando lá</segment>
    <segment id="27">, Marcos anunciou o assalto.</segment>
    <segment id="28">Segundo a jovem</segment>
    <segment id="29">, o taxista reagiu</segment>
    <segment id="30">, gritando e empurrando o ladrão.</segment>
  </rst>
</analysis>