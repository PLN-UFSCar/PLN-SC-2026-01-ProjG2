  <rst>
    <segment id="1">Arrancou coração e fígado do rival</segment>
    <segment id="2">Polícia recebe denúncia de que Albano Neves teria ainda cozinhado os órgãos da vítima</segment>
    <segment id="3">O trabalhador rural Sebastião Ferreira de Jesus</segment>
    <segment id="4">, 24 anos</segment>
    <segment id="5">, foi morto com requintes de crueldade.</segment>
    <segment id="6">Parte do coração e fragmentos do fígado foram arrancados</segment>
    <segment id="7">, segundo peritos do Departamento de Polícia Técnica de Itabuna.</segment>
    <segment id="8">O corpo da vítima foi encontrado dentro de uma fossa</segment>
    <segment id="9">, na manhã de ontem</segment>
    <segment id="10">, numa fazenda do município de Arataca</segment>
    <segment id="11">, (a 500 km ao sul de Salvador).</segment>
    <segment id="12">O assassino confesso</segment>
    <segment id="13">, Albano Neves Barbosa</segment>
    <segment id="14">, 31, disse que enforcou Sebastião</segment>
    <segment id="15">, masmas nega que retirou parte de órgãos da vítima</segment>
    <segment id="16">, que ainda teve a orelha esquerda decepada.</segment>
    <segment id="17">Durante depoimento na Delegacia de Camacan</segment>
    <segment id="18">, Albano justificou o homicídio argumentando que Sebastião vinha assediando a mulher dele.</segment>
    <segment id="19">José Ribeiro</segment>
    <segment id="20">, 36, que é cunhado de Albano e presenciou a barbaridade</segment>
    <segment id="21">, denunciou à polícia que Edvaldo Barbosa dos Santos</segment>
    <segment id="22">, 46, também participou do ritual hediondo contra Sebastião.</segment>
    <segment id="23">Edvaldo é trabalhador da fazenda onde ocorreu o assassinato e teria sido coagido por Albano a ajudar no crime.</segment>
    <segment id="24">A polícia ainda não confirmou a informação de que Albano teria cozinhado as partes dos órgãos retirados da vítima.</segment>
    <segment id="25">Tinha ficha na polícia</segment>
    <segment id="26">Os dois acusados foram presos pela polícia.</segment>
    <segment id="27">Por motivo de segurança</segment>
    <segment id="28">, Albano e Edvaldo foram levados para a delegacia do município de Camacan.</segment>
    <segment id="29">Edvaldo negou participação no crime e Albano o isentou.</segment>
    <segment id="30">Por isso</segment>
    <segment id="31">, Edvaldo foi ouvido na delegacia e</segment>
    <segment id="32">, em seguida</segment>
    <segment id="33">, liberado.</segment>
    <segment id="34">A vítima já tinha ficha na polícia por agredir uma mulher.</segment>
    <segment id="35">O levantamento cadavérico foi realizado pelo delegado João Mendes.</segment>
    <segment id="36">O corpo de Sebastião foi recolhido por peritos do Departamento de Polícia Técnica de Itabuna</segment>
    <segment id="37">, onde foi realizada a necropsia</segment>
    <segment id="38">, na tarde de ontem.</segment>
  </rst>
</analysis>