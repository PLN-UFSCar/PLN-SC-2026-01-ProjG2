  <rst>
    <segment id="1">Policiais prendem 11 bandidos que fizeram arrastão na Lagoa
RIO - Um grupo de 11 bandidos</segment>
    <segment id="2">, maioria menores</segment>
    <segment id="3">, foi preso por volta das 14h30m deste domingo após fazer um arrastão na orla da Lagoa Rodrigo de Freitas.</segment>
    <segment id="4">O bando começou na altura do Quiosque Palaphita Kitsch e seguiu até a escola de remo do clube do Botafogo</segment>
    <segment id="5">, próximo à Fonte da Saudade.</segment>
    <segment id="6">Os bandidos foram levados para a 14ª DP (Leblon).</segment>
    <segment id="7">Os jovens seriam do Morro da Mangueira.</segment>
    <segment id="8">Segundo os policiais envolvidos no</segment>
    <segment id="9">casocaso</segment>
    <segment id="10">, pelo menos oito pessoas foram vítimas</segment>
    <segment id="11">, masmas até o fim da tarde</segment>
    <segment id="12">, apenas uma teria comparecido à delegacia.</segment>
    <segment id="13">Do grupo de 11 ladrões</segment>
    <segment id="14">, três eram maiores de idade e já possuíam mandados de prisão contra eles.</segment>
    <segment id="15">A jovem X.</segment>
    <segment id="16">, de 19 anos</segment>
    <segment id="17">, foi uma das vítimas do bando que promoveu o arrastão.</segment>
    <segment id="18">Ela comemorava o Dia dos Pais com a família quando foi cercada.</segment>
    <segment id="19">Os ladrões levaram seu colar e brincos.</segment>
    <segment id="20">Durante a ação</segment>
    <segment id="21">, ela pulou da bicicleta para tentar</segment>
    <segment id="22">sese proteger.</segment>
    <segment id="23">O pai da jovem afirmou que parte da família veio da Zona Norte e outra da Baixada para comemorar o Dia dos Pais com um passeio.</segment>
    <segment id="24">Eles tinham alugado uma bicicleta no Parque dos Patins e pedalavam em direção ao Corte do Cantagalo quando ocorreu o incidente</segment>
    <segment id="25">, perto da escola de remo do Botafogo.</segment>
  </rst>
</analysis>