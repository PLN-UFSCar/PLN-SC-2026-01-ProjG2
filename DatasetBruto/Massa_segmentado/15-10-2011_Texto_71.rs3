  <rst>
    <segment id="1">Festa na Cinelândia dá início ao Momento Itália-Brasil</segment>
    <segment id="2">, que prevê 200 eventos até junho de 2012
RIO - Cerca de cinco mil pessoas</segment>
    <segment id="3">, segundo estimativas da PM</segment>
    <segment id="4">, acompanharam o início do espetáculo 'Ensaio sobre a Beleza'</segment>
    <segment id="5">, evento que marca a abertura oficial do Momento Itália-Brasil</segment>
    <segment id="6">, na Cinelândia.</segment>
    <segment id="7">Apesar da forte chuva que caiu durante o espetáculo</segment>
    <segment id="8">, todas as coreografias aéreas e de solo previstas para o evento foram executadas para delírio do público que assistiu ao show sob a proteção de guarda-chuvas.</segment>
    <segment id="9">Ao todo</segment>
    <segment id="10">, serão mais de 200 eventos</segment>
    <segment id="11">, incluindo exposições</segment>
    <segment id="12">, peças de teatro</segment>
    <segment id="13">, espetáculos de dança e de música</segment>
    <segment id="14">, mostras de cinema e de moda.</segment>
    <segment id="15">A programação ainda está sendo detalhada (boa parte dos eventos segue sem data certa para acontecer).</segment>
    <segment id="16">Mas é tão vasta que contempla desde uma prosaica Festa da Polenta</segment>
    <segment id="17">, no Espírito Santo</segment>
    <segment id="18">, até exposições de Leonardo Da Vinci (1452-1519)</segment>
    <segment id="19">, Modigliani (1884-1920)</segment>
    <segment id="20">, Caravaggio (1571-1610) e De Chirico (1888-1978)</segment>
    <segment id="21">, além da mostra "</segment>
    <segment id="22">Homenagem a Pier Paolo Pasolini"</segment>
    <segment id="23">, dedicada ao cineasta italiano que viveu entre 1922 e 1975.</segment>
    <segment id="24">Os eventos seguem até junho de 2012 em pelo menos 11 cidades brasileiras</segment>
    <segment id="25">, como</segment>
    <segment id="26">como Rio</segment>
    <segment id="27">, São Paulo</segment>
    <segment id="28">, Porto Alegre</segment>
    <segment id="29">, Salvador</segment>
    <segment id="30">, Brasília e Belo Horizonte.</segment>
    <segment id="31">Iniciativa da embaixada italiana</segment>
    <segment id="32">, em parceria com os institutos italianos de cultura do Rio e de São Paulo</segment>
    <segment id="33">, a proposta é celebrar a história e a amizade entre os dois países.</segment>
    <segment id="34">Assim como</segment>
    <segment id="35">como o ano da França no Brasil</segment>
    <segment id="36">, em 2009</segment>
    <segment id="37">, o Momento Itália-Brasil quer explorar as múltiplas facetas da identidade italiana no país</segment>
    <segment id="38">, além de estreitar os laços entre as duas nações.

- Escolhemos o Brasil</segment>
    <segment id="39">porque</segment>
    <segment id="40">porque temos quase 500 anos de história juntos - diz o diretor do Instituto Italiano de Cultura do Rio</segment>
    <segment id="41">, Rubens Piovano</segment>
    <segment id="42">, também adido cultural italiano na cidade.</segment>
    <segment id="43">Um dos grandes destaques da programação</segment>
    <segment id="44">, a mostra "</segment>
    <segment id="45">Modigliani: imagens de uma vida" será inaugurada na próxima terça-feira no Palácio Anchieta</segment>
    <segment id="46">, em Vitória</segment>
    <segment id="47">, no Espírito Santo.</segment>
    <segment id="48">Agendada para chegar ao Museu Nacional de Belas Artes do Rio (MNBA) no dia 10 de janeiro</segment>
    <segment id="49">, a exposição reúne 12 pinturas a óleo</segment>
    <segment id="50">, como</segment>
    <segment id="51">como a tela "Grand</segment>
    <segment id="52">nu allongé"</segment>
    <segment id="53">, cinco esculturas</segment>
    <segment id="54">, uma série de desenhos</segment>
    <segment id="55">, além de fotografias</segment>
    <segment id="56">, manuscritos e documentos destacando o clima da vida na Paris do início do século XX</segment>
    <segment id="57">, onde o artista</segment>
    <segment id="58">, nascido em Livorno</segment>
    <segment id="59">, morou.

-</segment>
    <segment id="60">O sentido dessa mostra é apresentar</segment>
    <segment id="61">, mais do que obras</segment>
    <segment id="62">, a vida desse homem - explica Diego D'Ermoggine</segment>
    <segment id="63">, diretor de Relações Internacionais da organização Museu a Céu Aberto (MCA)</segment>
    <segment id="64">, responsável por trazer a exposição ao Brasil</segment>
    <segment id="65">, em parceria com o Modigliani Institut Archives Légales Paris-Roma.</segment>
    <segment id="66">As obras foram cedidas pelo instituto</segment>
    <segment id="67">, que representa Modigliani no mundo</segment>
    <segment id="68">, e por colecionadores particulares.</segment>
    <segment id="69">Para traduzir a atmosfera que cercava o artista</segment>
    <segment id="70">, o curador Christian Parisot</segment>
    <segment id="71">, também presidente do instituto</segment>
    <segment id="72">, dedicou uma sala especial aos amigos de Modigliani</segment>
    <segment id="73">, como</segment>
    <segment id="74">como Picasso e Toulouse-Lautrec</segment>
    <segment id="75">, com obras deles.</segment>
    <segment id="76">Ainda como</segment>
    <segment id="77">como parte das ações italianas no Brasil</segment>
    <segment id="78">, foi inaugurada anteontem em São Paulo</segment>
    <segment id="79">, nos Jardins</segment>
    <segment id="80">, a primeira Casa Modigliani do mundo</segment>
    <segment id="81">, que terá palestras</segment>
    <segment id="82">, pequenas mostras</segment>
    <segment id="83">, cursos e residência para artistas.</segment>
    <segment id="84">Outra exposição que promete encher os olhos dos cariocas é "Leonardo Da Vinci - a arte de um gênio"</segment>
    <segment id="85">, que inicia seu percurso no Rio no dia 28 de março</segment>
    <segment id="86">, também no MNBA.</segment>
    <segment id="87">O que será exposto</segment>
    <segment id="88">, entretanto</segment>
    <segment id="89">, ainda não foi confirmado.</segment>
    <segment id="90">A produção do evento negocia obras</segment>
    <segment id="91">comocomo "</segment>
    <segment id="92">Dama con l'ermellino"</segment>
    <segment id="93">, produzida entre 1488 e 1490 e pertencente ao Museu Czartoryski</segment>
    <segment id="94">, na Cracóvia.</segment>
    <segment id="95">Enquanto Da Vinci estiver no Rio</segment>
    <segment id="96">, Belo Horizonte receberá "</segment>
    <segment id="97">Caravaggio e os caravaggescos"</segment>
    <segment id="98">, com telas do pintor italiano</segment>
    <segment id="99">, além de obras de artistas que seguiram seu estilo</segment>
    <segment id="100">, os chamados caravaggescos.</segment>
    <segment id="101">A mostra</segment>
    <segment id="102">, na Casa Fiat de Cultura</segment>
    <segment id="103">, vai para o Masp</segment>
    <segment id="104">, em Sâo Paulo</segment>
    <segment id="105">, em junho.</segment>
    <segment id="106">Palco a céu aberto</segment>
    <segment id="107">Já o precursor do surrealismo</segment>
    <segment id="108">De Chirico irá ocupar dois andares da Fundação Iberê Camargo</segment>
    <segment id="109">, em Porto Alegre</segment>
    <segment id="110">, no início de dezembro.</segment>
    <segment id="111">A mostra "</segment>
    <segment id="112">Giorgio de Chirico - Espaço urbano</segment>
    <segment id="113">comocomo plateia de um humanismo moderno" também segue para a Casa Fiat de Cultura</segment>
    <segment id="114">, em Belo Horizonte</segment>
    <segment id="115">, em março</segment>
    <segment id="116">Para além das artes plásticas</segment>
    <segment id="117">, o Museu da Imagem e do Som (MIS) de São Paulo irá sediar a mostra "</segment>
    <segment id="118">Homenagem a Pier Paolo Pasolini"</segment>
    <segment id="119">, com filmes</segment>
    <segment id="120">, fotos e aquarelas do diretor.</segment>
    <segment id="121">E o Teatro Municipal do Rio recebe</segment>
    <segment id="122">, no ano que vem (ainda sem data) a peça "</segment>
    <segment id="123">Arlecchino servitore di due padroni"</segment>
    <segment id="124">, de Pirandello</segment>
    <segment id="125">, que será encenada pelo Piccolo Teatro di Milano.</segment>
    <segment id="126">O Momento Itália-Brasil começa em grande estilo: neste sábado</segment>
    <segment id="127">, a Cinelândia vai virar um gigantesco palco a céu aberto</segment>
    <segment id="128">, em que mais de 150 artistas brasileiros e italianos</segment>
    <segment id="129">, entre acrobatas</segment>
    <segment id="130">, bailarinos e atores voarão sobre o público</segment>
    <segment id="131">, dançando e representando a história que uniu os dois países.</segment>
    <segment id="132">Trata-</segment>
    <segment id="133">sese do espetáculo "</segment>
    <segment id="134">Ensaio sobre a beleza"</segment>
    <segment id="135">, idealizado pelo italiano Valerio Festi (leia mais ao lado).</segment>
    <segment id="136">O espetáculo</segment>
    <segment id="137">, gratuito</segment>
    <segment id="138">, conta com um grandioso show de luzes e projeções sobre a fachada do Teatro Municipal</segment>
    <segment id="139">, que vai ganhar novos contornos e linhas</segment>
    <segment id="140">, como</segment>
    <segment id="141">como uma simulação do teatro La Scala</segment>
    <segment id="142">, de Milão.</segment>
  </rst>
</analysis>