  <rst>
    <segment id="1">Arrasando
Manu</segment>
    <segment id="2">Souza</segment>
    <segment id="3">destrói corações por onde passa e dá orgulho para galera da Federação</segment>
    <segment id="4">A gata Manuela Souza</segment>
    <segment id="5">, de 22 anos</segment>
    <segment id="6">, não é uma passista de gafieira</segment>
    <segment id="7">masmas tem muito samba no pé.</segment>
    <segment id="8">“Adoro curtir um bom  samba no Pelourinho.</segment>
    <segment id="9">Todos os finais de semana estou lá”</segment>
    <segment id="10">, conta a gata que mora no bairro da  Federação.</segment>
    <segment id="11">Atualmente Manu trabalha na recepção de um instituto de beleza e garante que é bastante  vaidosa.</segment>
    <segment id="12">“</segment>
    <segment id="13">Desde nova gosto de me arrumar</segment>
    <segment id="14">, não saio de casa sem maquiagem ”</segment>
    <segment id="15">, revela.</segment>
    <segment id="16">O sonho de fazer o curso de psicologia vai ter que esperar.</segment>
    <segment id="17">“</segment>
    <segment id="18">O investimento é grande e não estou pronta financeiramente para começar a faculdade”</segment>
    <segment id="19">, explica Manu.</segment>
    <segment id="20">No momento a gata está trabalhando muito para dar uma vida melhor a sua mãe e quem sabe comprar uma casa e sair do aluguel.</segment>
    <segment id="21">O coração de Manu já está preenchido</segment>
    <segment id="22">, masmas a moça revela</segment>
    <segment id="23">comocomo deve ser um bom namorado.</segment>
    <segment id="24">“</segment>
    <segment id="25">O cara perfeito precisa saber respeitar bem uma mulher.</segment>
    <segment id="26">E deve saber</segment>
    <segment id="27">comocomo agradá-la”.</segment>
    <segment id="28">Muitas tatuagens

Fanática por tatoo</segment>
    <segment id="29">, Manu já fez quatro e quer fazer mais

Vaidosa</segment>
    <segment id="30">Manuela adora os olhos e seu belo sorriso.</segment>
    <segment id="31">“São as partes do meu corpo que mais chama atenção”</segment>
    <segment id="32">, acredita</segment>
  </rst>
