  <rst>
    <segment id="1">Vigia escondia furtos no hospital</segment>
    <segment id="2">Jeferson foi preso pela PM após denúncia de populares</segment>
    <segment id="3">Além de trabalhar</segment>
    <segment id="4">comocomo  vigilante terceirizado no  Hospital Municipal de Simões Filho</segment>
    <segment id="5">, Jeferson Reis Lima</segment>
    <segment id="6">, 20 anos</segment>
    <segment id="7">, usava o estacionamento da unidade  para guardar os veículos que</segment>
    <segment id="8">, segundo a polícia</segment>
    <segment id="9">, eram roubados por ele.</segment>
    <segment id="10">Na manhã de ontem</segment>
    <segment id="11">, ele  foi preso por policiais militares da 22ª CIPM (Simões Filho)</segment>
    <segment id="12">, quando abria o carro  modelo Corsa Classic</segment>
    <segment id="13">, cinza</segment>
    <segment id="14">, placa JPT-8026</segment>
    <segment id="15">, no estacionamento.</segment>
    <segment id="16">Segundo a delegada plantonista da Delegacia de  Furtos e Roubos de Veículos</segment>
    <segment id="17">, Elisângela Pereira de Araújo</segment>
    <segment id="18">, o veículo foi surrupiado</segment>
    <segment id="19">, na terça (19)</segment>
    <segment id="20">, em Camaçari.</segment>
    <segment id="21">Além do Corsa</segment>
    <segment id="22">, a polícia encontrou</segment>
    <segment id="23">, no mesmo estacionamento</segment>
    <segment id="24">, um  Fox</segment>
    <segment id="25">, de placa NZV-1139</segment>
    <segment id="26">,  roubado no último dia 15</segment>
    <segment id="27">, no IAPI</segment>
    <segment id="28">, em Salvador.</segment>
    <segment id="29">O dono do Fox  reconheceu Jeferson</segment>
    <segment id="30">comocomo um dos autores do roubo.</segment>
    <segment id="31">“Jeferson vinha sendo investigado</segment>
    <segment id="32">,  há 15 dias.</segment>
    <segment id="33">Sabemos que ele agia armado e contava com o apoio de um comparsa ”</segment>
    <segment id="34">, diz o subtenente José Antônio .</segment>
    <segment id="35">Jeferson relata que os veículos pertencem a um homem  que os deixava em frente ao hospital e pedia para ele colocá-los  no estacionamento da unidade</segment>
    <segment id="36">, assim que surgisse vaga.</segment>
    <segment id="37">“Eu só quis ajudar.</segment>
    <segment id="38">Não sei quem é esse homem.</segment>
    <segment id="39">Ele apareceu há um mês.</segment>
    <segment id="40">Começou a conversar comigo e pediu para eu estacionar os carros para ele</segment>
    <segment id="41">, masmas não</segment>
    <segment id="42">sese identificou”.</segment>
    <segment id="43">Arma para defesa</segment>
    <segment id="44">Na casa de Jeferson</segment>
    <segment id="45">, os PMs encontraram um revólver calibre 38</segment>
    <segment id="46">, com munição</segment>
    <segment id="47">, R$ 1</segment>
    <segment id="48">,5 mil</segment>
    <segment id="49">, além de outros objetos.</segment>
    <segment id="50">“</segment>
    <segment id="51">A arma é de uso pessoal.</segment>
    <segment id="52">Já conduzi várias pessoas à delegacia e vinha sofrendo ameaças de morte”</segment>
    <segment id="53">, explicou.</segment>
    <segment id="54">Já o dinheiro</segment>
    <segment id="55">, ele disse que juntou para curtir o São João</segment>
    <segment id="56">, na cidade de Coração de Maria.</segment>
    <segment id="57">“Locais que funcionam 24 horas</segment>
    <segment id="58">, como</segment>
    <segment id="59">como hospitais e supermercados</segment>
    <segment id="60">, são comumente usados para guardar carros roubados.</segment>
    <segment id="61">A nossa orientação  é</segment>
    <segment id="62">para que</segment>
    <segment id="63">para que os policiais fiscalizem essas áreas”</segment>
    <segment id="64">, afirma o delegado titular da DRFRV</segment>
    <segment id="65">, Nilton Borba.</segment>
  </rst>
</analysis>