  <rst>
    <segment id="1">Ao estilo Felipão</segment>
    <segment id="2">, a promessa de luta do Palmeiras</segment>
    <segment id="3">SÃO PAULO - Se depender de Felipão</segment>
    <segment id="4">, os vascaínos podem ter esperança de título neste domingo.</segment>
    <segment id="5">O técnico do Palmeiras minimizou o clima de rivalidade com o Corinthians</segment>
    <segment id="6">masmas assegurou que seu time jogará para vencer o adversário.</segment>
    <segment id="7">Ele disse que o clima no clube é dos melhores em seis meses e brincou que até as pimenteiras</segment>
    <segment id="8">, colocadas nas salas de imprensa e coletiva</segment>
    <segment id="9">, estão florindo.</segment>
    <segment id="10">Sinal de bons fluidos.
- Olha as pimenteiras</segment>
    <segment id="11">, estão bonitas!</segment>
    <segment id="12">Vocês estão cuidando delas.</segment>
    <segment id="13">As da minha casa secaram.</segment>
    <segment id="14">Não sei quem seca mais: os jornalistas ou minha turminha lá de casa - declarou Felipão.</segment>
    <segment id="15">- O jogo vale um pouco mais de confiança e personalidade para o ano que vem.</segment>
    <segment id="16">Queremos a vitória.</segment>
    <segment id="17">Mas o que acontecer ou não com o Corinthians não é nosso problema.</segment>
    <segment id="18">O título depende do resultado de lá (Rio).</segment>
    <segment id="19">Estatisticamente</segment>
    <segment id="20">, o Flamengo leva vantagem sobre o Vasco</segment>
    <segment id="21">, não?</segment>
    <segment id="22">Olha: não farei nada pelo Vasco</segment>
    <segment id="23">, nem pelo Flamengo!

Corinthians sem mistério

Felipão acredita</segment>
    <segment id="24">, no entanto</segment>
    <segment id="25">, que o Corinthians leva vantagem sobre o Palmeiras.

- Nesse momento eles são superiores.</segment>
    <segment id="26">Estão cerca de vinte pontos na nossa frente.</segment>
    <segment id="27">Se atrapalharmos</segment>
    <segment id="28">, ok.</segment>
    <segment id="29">Se não</segment>
    <segment id="30">, fazer o que?</segment>
    <segment id="31">Aquele jogador inteligente do Corinthians</segment>
    <segment id="32">, o tal de Alex</segment>
    <segment id="33">, falou que</segment>
    <segment id="34">, de nove possibilidades</segment>
    <segment id="35">, o Corinthians vence em oito.</segment>
    <segment id="36">Pelo amor de Deus!</segment>
    <segment id="37">É chance pra caramba.</segment>
    <segment id="38">E olha que só aprendi um pouco de matemática para pagar as contas.</segment>
    <segment id="39">Futebol não é só matemática.</segment>
    <segment id="40">Mas ajuda a analisar os fatos.</segment>
    <segment id="41">Felipão descarta pressão em</segment>
    <segment id="42">casocaso de derrota.

- Engraçado</segment>
    <segment id="43">, pressão só aqui.</segment>
    <segment id="44">O nosso adversário passou a semana bonito.</segment>
    <segment id="45">Lá só tem anjinho.</segment>
    <segment id="46">Aqui só diabinho - comparou Felipão</segment>
    <segment id="47">, referindo-</segment>
    <segment id="48">sese ao São Paulo</segment>
    <segment id="49">, derrotado pelo Palmeiras no último domingo.</segment>
    <segment id="50">O treinador estava bem humorado.</segment>
    <segment id="51">Além de limpar a pimenteira</segment>
    <segment id="52">, retirando as folhas mortas</segment>
    <segment id="53">, deu risada do ensaio de balé que acontecia no ginásio</segment>
    <segment id="54">, próximo à sala de coletivas.</segment>
    <segment id="55">Também arrancou risadas quando comentou a punição a Sheik</segment>
    <segment id="56">, do Corinthians</segment>
    <segment id="57">, que não jogará amanhã.

- Era de quatro a 12 jogos e só teve um.</segment>
    <segment id="58">Também quero matar</segment>
    <segment id="59">, roubar</segment>
    <segment id="60">, fazer o diabo.</segment>
    <segment id="61">A pena é de 30 anos e só fico um - cutucou o técnico que queria saber que som vazava para a sala de coletivas.</segment>
    <segment id="62">- Jesus!</segment>
    <segment id="63">É música de Natal no treino...</segment>
    <segment id="64">Isso está impossível...</segment>
    <segment id="65">Imagina o pessoal dançando isso!</segment>
    <segment id="66">O goleiro Marcos</segment>
    <segment id="67">, que não joga há 13 partidas</segment>
    <segment id="68">, deverá ser relacionado.</segment>
    <segment id="69">Esse pode ser o último jogo dele</segment>
    <segment id="70">, que programou aposentadoria ainda em 2011.

- Não é a despedida que queríamos</segment>
    <segment id="71">, o Corinthians pode ser campeão.</segment>
    <segment id="72">Mas não sou favorável à renovação para 2012.</segment>
    <segment id="73">Ele não tem condições de jogar pelo Palmeiras numa temporada normal.</segment>
    <segment id="74">Já tomou a decisão de parar e ficam falando no ouvido dele para continuar.</segment>
    <segment id="75">Ele ouve</segment>
    <segment id="76">, sabe?</segment>
    <segment id="77">Muda de opinião</segment>
    <segment id="78">masmas o corpo reclama.</segment>
    <segment id="79">Sobre a polêmica em torno do prêmio</segment>
    <segment id="80">, Felipão afirmou que</segment>
    <segment id="81">sese dependesse disso</segment>
    <segment id="82">, o Palmeiras perderia todos os jogos no Brasileirão.

- Nosso bicho é cinco vezes menor do que os outros times...</segment>
    <segment id="83">Se é bicho dinossauro ou formiguinha não faz a menor diferença.</segment>
    <segment id="84">Essa história é ridícula.</segment>
    <segment id="85">Eles estão lá e jogam</segment>
    <segment id="86">porque</segment>
    <segment id="87">porque recebem salários.</segment>
    <segment id="88">Nos bastidores</segment>
    <segment id="89">, no entanto</segment>
    <segment id="90">, o gerente de futebol Cesar Sampaio acabou falando que há algo especial planejado e que o treinador está inflando os jogadores a vencer o arquirrival.

- Se eu falar o que é ele me mata - disse Sampaio.</segment>
    <segment id="91">No Corinthians</segment>
    <segment id="92">, que joga por um empate para ser campeão</segment>
    <segment id="93">, o técnico Tite optou por não fazer mistério</segment>
    <segment id="94">, mesmo com três jogadores titulares suspensos time para o jogo decisivo.</segment>
    <segment id="95">Ele surpreendeu ao anunciar que o zagueiro Wallace será o substituto do volante Ralf.</segment>
    <segment id="96">Pela primeira vez o jogador vai atuar improvisado no meio-campo.</segment>
    <segment id="97">A expectativa era que Tite escolhesse Moradei ou Bruno Octávio</segment>
    <segment id="98">, que são volantes.</segment>
    <segment id="99">Já Danilo dará lugar a Alex</segment>
    <segment id="100">, enquanto Emerson será substituído por Jorge Henrique.</segment>
  </rst>
</analysis>