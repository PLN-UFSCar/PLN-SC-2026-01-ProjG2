  <rst>
    <segment id="1">Festival de Dança agita Caja City</segment>
    <segment id="2">Além da galera de Salvador</segment>
    <segment id="3">, o evento contou com representantes de outras cidades</segment>
    <segment id="4">Uma mistura de arte e ação social.</segment>
    <segment id="5">Assim foi a 4º edição do Festival de Danças de Bairros</segment>
    <segment id="6">,  ontem</segment>
    <segment id="7">, em Cajazeira 10.</segment>
    <segment id="8">Além do concurso de dança com grupos divididos em quatro categorias  (valsa</segment>
    <segment id="9">, pagode quebradeira</segment>
    <segment id="10">, pagode evolução e mista – dança e teatro)</segment>
    <segment id="11">, o evento ainda arrecadou alimentos para distribuir entre instituições de caridade.</segment>
    <segment id="12">Idealizado pelo dançarino do grupo Nossa Juventude</segment>
    <segment id="13">, Anderson Cupim</segment>
    <segment id="14">, o festival surgiu</segment>
    <segment id="15">comocomo forma de resgatar jovens mais propensos ao uso de drogas.</segment>
    <segment id="16">“</segment>
    <segment id="17">A dança é uma forma de aproximar o adolescente da  arte e afastá-lo de atos prejudiciais”</segment>
    <segment id="18">, explica.</segment>
    <segment id="19">Mesmo oferecendo uma premiação simbólica (R$ 100 para os primeiros colocados de cada categoria)</segment>
    <segment id="20">, o evento teve uma participação acima da esperada.</segment>
    <segment id="21">Ao todo</segment>
    <segment id="22">, 60 grupos disputaram.</segment>
    <segment id="23">“Temos mais de dez bairros de Salvador e ainda vieram grupos de outras cidades</segment>
    <segment id="24">, como</segment>
    <segment id="25">como Madre de Deus</segment>
    <segment id="26">, São Francisco do Conde e Santo Amaro”</segment>
    <segment id="27">, enumera Anderson Cupim.</segment>
    <segment id="28">Troca de ideias</segment>
    <segment id="29">A possibilidade de mostrar o trabalho e conhecer outros artistas foram os principais atrativos indicados pelos  grupos que participaram do festival.</segment>
    <segment id="30">O júri foi composto por personalidades de destaque da cena musical</segment>
    <segment id="31">, como</segment>
    <segment id="32">como o coreógrafo de Ivete Sangalo</segment>
    <segment id="33">, Jorge Silva</segment>
    <segment id="34">,  e a Deusa do Samba</segment>
    <segment id="35">, Ane Fagundes.</segment>
    <segment id="36">“É uma oportunidade massa para a gente que está começando.</segment>
    <segment id="37">É um evento que mostra a arte que está sendo feita nos guetos da cidade”</segment>
    <segment id="38">, diz Luciane Marques</segment>
    <segment id="39">, 17 anos</segment>
    <segment id="40">,  integrante do grupo “C vai dançar”</segment>
    <segment id="41">, que participou do festival.</segment>
    <segment id="42">Confira os vencedores!</segment>
    <segment id="43">Após a decisão do corpo de jurados</segment>
    <segment id="44">, os melhores grupos  ganharam medalhas</segment>
    <segment id="45">, troféus e brindes.</segment>
    <segment id="46">Os vencedores de cada uma das quatro categorias agora estão com os bolsos cheios!</segment>
    <segment id="47">Na categoria Pagode Evolução</segment>
    <segment id="48">, o grupo Dançarte</segment>
    <segment id="49">, do bairro da Liberdade</segment>
    <segment id="50">, levou a melhor</segment>
    <segment id="51">; na valsa</segment>
    <segment id="52">, o grupo de Cajazeiras</segment>
    <segment id="53">, Amor Eterno</segment>
    <segment id="54">, foi o vencedor</segment>
    <segment id="55">; na modalidade Mista</segment>
    <segment id="56">, o grupo OG 2</segment>
    <segment id="57">, de Pau da Lima</segment>
    <segment id="58">, conquistou o público com sua mistura de teatro e dança e garantiu o primeiro lugar</segment>
    <segment id="59">; já na categoria Pagode Quebradeira</segment>
    <segment id="60">, o grupo de São Caetano</segment>
    <segment id="61">, Los Black</segment>
    <segment id="62">, agitou a galera com  um verdadeiro show de pagode</segment>
    <segment id="63">, conquistou a plateia e obteve a maioria dos votos dos jurados.</segment>
  </rst>
</analysis>