  <rst>
    <segment id="1">Flamengo tenta voltar aos trilhos das vitórias</segment>
    <segment id="2">FLORIANÓPOLIS - Começar o segundo turno na vice-liderança</segment>
    <segment id="3">, a apenas um ponto do primeiro colocado</segment>
    <segment id="4">, com o ataque mais positivo e a volta do bom futebol de Ronaldinho Gaúcho estava nas expectativas mais otimistas dos rubro-negros no começo da competição</segment>
    <segment id="5">, há três meses e meio.</segment>
    <segment id="6">Mas também é fato que o time que enfrentará o Avaí</segment>
    <segment id="7">, às 21h50m</segment>
    <segment id="8">, na Ressacada</segment>
    <segment id="9">, em Florianópolis</segment>
    <segment id="10">, não vive seu melhor momento.</segment>
    <segment id="11">Para voltar a vencer depois de quatro jogos e ter a chance de assumir a liderança</segment>
    <segment id="12">, o Flamengo aposta no bom retrospecto fora de casa:</segment>
    <segment id="13">é o único time do Campeonato Brasileiro que ainda não foi derrotado</segment>
    <segment id="14">comocomo visitante.
TABELA:</segment>
    <segment id="15">A classificação do Brasileiro

BLOG: 'O Mais Querido'

Nesta noite</segment>
    <segment id="16">, sese a defesa recheada de desfalques (Alex Silva</segment>
    <segment id="17">, Welinton</segment>
    <segment id="18">, David Braz e Júnior César) conseguir</segment>
    <segment id="19">sese sair bem</segment>
    <segment id="20">, é grande a chance de o time sair vencedor</segment>
    <segment id="21">, já que o time voltará a contar com força máxima na frente.</segment>
    <segment id="22">Thiago Neves está recuperado de lesão muscular e volta a fazer dupla com Ronaldinho Gaúcho.</segment>
    <segment id="23">Sua última partida foi justamente a derrota para o Atlético-GO</segment>
    <segment id="24">, quando o camisa 10</segment>
    <segment id="25">, porém</segment>
    <segment id="26">porém, não estava em campo.</segment>
    <segment id="27">David Braz recebe alta

Thiago Neves comemorou seu retorno à equipe num momento em que o campeonato está tão embolado:

- Em casa</segment>
    <segment id="28">, você não pode fazer nada</segment>
    <segment id="29">, só torcer.</segment>
    <segment id="30">Assisti aos jogos</segment>
    <segment id="31">, deixamos escapar alguns pontos importantes</segment>
    <segment id="32">, e agora começa um segundo turno empolgante.</segment>
    <segment id="33">Quem quer ser campeão tem que vencer.</segment>
    <segment id="34">Não temos de pensar no Corintihans.</segment>
    <segment id="35">Até porque</segment>
    <segment id="36">porque não adianta o Corinthians perder e a gente também - afirmou.</segment>
    <segment id="37">Com Gustavo e Ronaldo Angelim na zaga</segment>
    <segment id="38">, o mais provável é que Renato seja improvisado na lateral esquerda.</segment>
    <segment id="39">Se isto</segment>
    <segment id="40">sese confirmar</segment>
    <segment id="41">, há chance também de outra mudança no meio-campo.</segment>
    <segment id="42">O técnico Vanderlei Luxemburgo avalia que o argentino Bottinelli tem jogado melhor quando entra no decorrer do jogo e pode tirá-lo do time titular</segment>
    <segment id="43">, lançando Muralha.</segment>
    <segment id="44">No Rio</segment>
    <segment id="45">, o zagueiro David Braz teve alta depois de seis dias internado.</segment>
    <segment id="46">Ele se</segment>
    <segment id="47">se recupera de uma forte amigdalite que evoluiu para uma infecção pulmonar</segment>
    <segment id="48">, masmas passa bem.</segment>
    <segment id="49">Avaí x Flamengo

Local: Ressacada

Data: 31/08</segment>
    <segment id="50">, às 21h50

Juiz: Wilton Pereira Sampaio (DF)

Avaí: Felipe</segment>
    <segment id="51">, Arlan</segment>
    <segment id="52">, Welton Felipe</segment>
    <segment id="53">, Gustavo Bastos e Romano</segment>
    <segment id="54">; Bruno</segment>
    <segment id="55">, Diogo Orlando</segment>
    <segment id="56">, Pedro Ken e Lincoln</segment>
    <segment id="57">;</segment>
    <segment id="58">Rafael Coelho e William.

Flamengo: Felipe</segment>
    <segment id="59">, Léo Moura</segment>
    <segment id="60">, Gustavo</segment>
    <segment id="61">, Angelim e Renato (Alvim)</segment>
    <segment id="62">; Willians</segment>
    <segment id="63">, Luiz Antônio</segment>
    <segment id="64">, Muralha (Bottinelli ou Renato) e Thiago Neves</segment>
    <segment id="65">; Ronaldinho e Deivid.</segment>
