  </header>
  <rst>
    <segment id="1">Voa voa borboleta!</segment>
    <segment id="2">Josi é cheia de atitude.</segment>
    <segment id="3">Viu uma foto da tatuagem na internet e logo tratou de imitar</segment>
    <segment id="4">Se ninguém copiar</segment>
    <segment id="5">, ela entra em extinção</segment>
    <segment id="6">, pois</segment>
    <segment id="7">pois, como</segment>
    <segment id="8">como ela</segment>
    <segment id="9">, só ela mesma!</segment>
    <segment id="10">O ‘nascimento’ da borboleta aconteceu quando a vendedora Josiane da Hora</segment>
    <segment id="11">, 22, moradora do Garcia</segment>
    <segment id="12">, desejou uma tatuagem diferente.</segment>
    <segment id="13">“fiz há um ano e até hoje nunca vi ninguém com outra igual”</segment>
    <segment id="14">, gaba-</segment>
    <segment id="15">sese.</segment>
    <segment id="16">A ‘abundante base’ é de nascença</segment>
    <segment id="17">, masmas as asas da butterfly são obra do tatuador Dologa.</segment>
    <segment id="18">“</segment>
    <segment id="19">Na hora</segment>
    <segment id="20">, doeu muito.</segment>
    <segment id="21">Mordia meu dedo e gemia de dor”</segment>
    <segment id="22">, conta a gata.</segment>
    <segment id="23">O habitat natural dessa bela espécie de ‘inseto’ é o Porto da Barra</segment>
    <segment id="24">, onde os ‘predadores’ pedem para fotografar a espécie rara.</segment>
    <segment id="25">“</segment>
    <segment id="26">Não ligo para os comentários.</segment>
    <segment id="27">Nunca recebi uma crítica</segment>
    <segment id="28">, muito pelo contrário”</segment>
    <segment id="29">, ressalta a beldade</segment>
    <segment id="30">, que já faz planos para sua nova tatuagem.</segment>
    <segment id="31">“Quero uma mais inusitada.</segment>
    <segment id="32">Um vulcão cairia bem em outro lugar”</segment>
    <segment id="33">, adianta.</segment>
  </rst>
</analysis>