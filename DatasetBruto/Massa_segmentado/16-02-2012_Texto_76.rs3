  <rst>
    <segment id="1">Claudia Leitte é rejeitada</segment>
    <segment id="2">Abaixo-assinado circula nas redes condenando a participação de Claudia na parada Gay</segment>
    <segment id="3">Um abaixo-assinado circula nas redes sociais condenando a participação de Claudia Leitte na Parada Gay da Bahia</segment>
    <segment id="4">, que vai acontecer em 9 de setembro.</segment>
    <segment id="5">A cantora foi escolhida para ser a madrinha da festa pelo Grupo Gay da Bahia</segment>
    <segment id="6">, que – ignorando as críticas dos movimentos LGBTs –</segment>
    <segment id="7">, garante que vai manter o convite.</segment>
    <segment id="8">A artista é rejeitada por parte dos gays após comentar que “não gostaria de ter um filho gay”.</segment>
    <segment id="9">Marcelo Cerqueira</segment>
    <segment id="10">, presidente do GGB</segment>
    <segment id="11">, diz que ela já</segment>
    <segment id="12">sese arrependeu do que falou e tê-la em cima do trio vai garantir visibilidade às causas gays.</segment>
    <segment id="13">“</segment>
    <segment id="14">Ninguém vence uma guerra só.</segment>
    <segment id="15">E ela trará mídia para a parada”</segment>
    <segment id="16">, pontua ele</segment>
    <segment id="17">, dizendo que a cantora teria confirmado sua participação no evento.</segment>
    <segment id="18">E para rebater as críticas</segment>
    <segment id="19">, Marcelo é ácido:</segment>
    <segment id="20">“Nenhuma mãe que ter um filho gay.</segment>
    <segment id="21">E Claudia não é diferente”.</segment>
    <segment id="22">A fala de Marcelo</segment>
    <segment id="23">, no entanto</segment>
    <segment id="24">, vai contra o projeto Mães Pela Igualdade</segment>
    <segment id="25">, que tem orgulho de seus filhos homossexuais.</segment>
  </rst>
</analysis>