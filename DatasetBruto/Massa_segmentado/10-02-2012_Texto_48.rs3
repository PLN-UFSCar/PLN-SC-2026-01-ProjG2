  <rst>
    <segment id="1">Agnaldo Timóteo é expulso de cemitério</segment>
    <segment id="2">"</segment>
    <segment id="3">Ele falou mal do meu pai"</segment>
    <segment id="4">, bradou a filha do rei das calcinhas</segment>
    <segment id="5">Ao tentar prestar uma homenagem a Wando</segment>
    <segment id="6">, durante seu sepultamento</segment>
    <segment id="7">, o cantor foi impedido pela filha do Rei das Calcinhas</segment>
