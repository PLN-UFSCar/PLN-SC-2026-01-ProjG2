  <rst>
    <segment id="1">Barão mandou matar colombiano</segment>
    <segment id="2">Paulo Colombiano descobriu falcatruas envolvendo o plano de saúde Mastermed
Quase dois anos após o assassinato do diretor financeiro do Sindicato dos Rodoviários</segment>
    <segment id="3">, Paulo Colombiano</segment>
    <segment id="4">, e da sua mulher</segment>
    <segment id="5">, Catarina Galindo</segment>
    <segment id="6">, a Polícia Civil prendeu</segment>
    <segment id="7">, ontem</segment>
    <segment id="8">, cinco suspeitos.</segment>
    <segment id="9">Segundo a polícia</segment>
    <segment id="10">, o tesoureiro teria sido morto após descobrir desvio de recursos</segment>
    <segment id="11">, lavagem de dinheiro e peculato por parte de membros da atual administração.</segment>
    <segment id="12">O capitão reformado da PM Claudiomiro César Ferreira Santana</segment>
    <segment id="13">, dono do plano de saúde Mastermed e o do Atacadão Centro Sul</segment>
    <segment id="14">, é apontado</segment>
    <segment id="15">comocomo mandante do crime.</segment>
    <segment id="16">Ele foi preso  com o irmão</segment>
    <segment id="17">, Cássio Antônio Ferreira Santana</segment>
    <segment id="18">, no edifício Victory Tower</segment>
    <segment id="19">, no Corredor da Vitória</segment>
    <segment id="20">, onde os dois têm  apartamentos.</segment>
    <segment id="21">O chefe de segurança do Atacadão e ex-funcionário da Mastermed</segment>
    <segment id="22">, Edilson Duarte de Araújo</segment>
    <segment id="23">, foi detido na Liberdade.</segment>
    <segment id="24">Wagner Luís Lopes de Souza e Adailton Araújo de Jesus</segment>
    <segment id="25">, ex-seguranças do Atacadão</segment>
    <segment id="26">, foram presos nos bairros</segment>
    <segment id="27">Dom Avelar e Plataforma</segment>
    <segment id="28">, respectivamente.</segment>
    <segment id="29">Embora a polícia não tenha identificado os autores dos disparos</segment>
    <segment id="30">, os três são apontados</segment>
    <segment id="31">comocomo participantes diretos do duplo homicídio.</segment>
    <segment id="32">Segundo o secretário de Segurança</segment>
    <segment id="33">,  Maurício Barbosa</segment>
    <segment id="34">, a polícia chegou aos suspeitos após analisar documentos do sindicato e ouvir cerca de 60 pessoas</segment>
    <segment id="35">, entre familiares das vítimas e diretores e funcionários da entidade.</segment>
    <segment id="36">“</segment>
    <segment id="37">Chegamos a uma série de irregularidades</segment>
    <segment id="38">, muitas relacionadas ao plano de saúde”.</segment>
    <segment id="39">Grana rolava solta</segment>
    <segment id="40">Maurício Barbosa contou que no período de um ano em que Colombiano ficou à frente da tesouraria do sindicato verificou um gasto de R$ 106 milhões</segment>
    <segment id="41">, entre 2005 e 2010</segment>
    <segment id="42">, para o pagamento da Mastermed (R$ 36 milhões apenas para taxas administrativas).</segment>
    <segment id="43">“</segment>
    <segment id="44">Além disso</segment>
    <segment id="45">, a vítima identificou empréstimos para membros da diretoria no valor de R$ 1</segment>
    <segment id="46">,4 milhão”</segment>
    <segment id="47">, afirmou Barbosa.</segment>
    <segment id="48">O diretor da DHPP</segment>
    <segment id="49">, Arthur Gallas</segment>
    <segment id="50">, disse que Colombiano descobriu  irregularidades que resultaram em dívidas com o INSS</segment>
    <segment id="51">, FGTS e Receita Federal</segment>
    <segment id="52">, além de pagamentos não declarados a gráficas e postos de combustíveis.</segment>
    <segment id="53">“</segment>
    <segment id="54">A evolução do patrimônio dos dirigentes vai desde a compra de imóveis</segment>
    <segment id="55">, abertura de estabelecimentos comerciais e aplicações financeiras até a compra de gado”</segment>
    <segment id="56">, detalhou Gallas.</segment>
    <segment id="57">Entenda o</segment>
    <segment id="58">casocaso</segment>
    <segment id="59">Em 29 de junho de 2010</segment>
    <segment id="60">, o diretor do Sindicato dos Rodoviários</segment>
    <segment id="61">, Paulo Roberto Colombiano</segment>
    <segment id="62">, 53, e a mulher dele</segment>
    <segment id="63">, Catarina Ascensão Galindo</segment>
    <segment id="64">, foram mortos na Rua Teixeira Barros</segment>
    <segment id="65">, em Brotas</segment>
    <segment id="66">, a 500 m do Condomínio Catavento</segment>
    <segment id="67">, onde moravam.</segment>
    <segment id="68">Segundo testemunhas</segment>
    <segment id="69">, dois homens em uma moto teriam abordado o Kia Sportage conduzido pelo sindicalista</segment>
    <segment id="70">, ao passar por um quebra-molas</segment>
    <segment id="71">, e disparado à queima-roupa.</segment>
    <segment id="72">De acordo com a polícia</segment>
    <segment id="73">, a perícia técnica detectou sete perfurações de bala no corpo de Colombiano</segment>
    <segment id="74">, duas delas no tórax</segment>
    <segment id="75">,  e uma na mulher</segment>
    <segment id="76">, atingida na cabeça.</segment>
    <segment id="77">Colombiano era o responsável financeiro do sindicato</segment>
    <segment id="78">, que possui mais de 14 mil associados</segment>
    <segment id="79">, 80 diretores e 52 funcionários.</segment>
    <segment id="80">A folha de arrecadação com mensalidades é estimada em R$ 5 milhões por ano.</segment>
  </rst>
</analysis>