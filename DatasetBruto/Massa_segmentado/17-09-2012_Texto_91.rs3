    <segment id="1">Gaste menos no caruru de Cosminho</segment>
    <segment id="2">Comerciantes jﾃδ｡ estﾃδ｣o com as vendas a todo vapor
Todos os anos</segment>
    <segment id="3">, no dia 27 de setembro</segment>
    <segment id="4">, muita gente prepara um vasto caruru para homenagear Sﾃδ｣o Cosme e Sﾃδ｣o Damiﾃδ｣o - os santos gﾃδｪmeos da Igreja Catﾃδｳlica e os ibejis do candomblﾃδｩ</segment>
    <segment id="5">, que representam as crianﾃδｧas.</segment>
    <segment id="6">Para deixar a mesa farta</segment>
    <segment id="7">, tudo precisa ser feito no mesmo dia: vatapﾃδ｡</segment>
    <segment id="8">, arroz</segment>
    <segment id="9">, milho branco</segment>
    <segment id="10">, caruru</segment>
    <segment id="11">, xinxim de galinha</segment>
    <segment id="12">, feijﾃδ｣o fradinho</segment>
    <segment id="13">, feijﾃδ｣o preto</segment>
    <segment id="14">, farofa</segment>
    <segment id="15">, acarajﾃδｩ</segment>
    <segment id="16">, abarﾃδ｡</segment>
    <segment id="17">, banana da terra frita</segment>
    <segment id="18">, pipoca e os roletes de cana.</segment>
    <segment id="19">Jﾃδ｡ que ﾃδｩ preciso comprar tantos ingredientes</segment>
    <segment id="20">, os feirantes contam com uma grana  a  mais no final do mﾃδｪs.</segment>
    <segment id="21">ﾃ｢竄ｬﾅ哲a vﾃδｩspera do dia de comemoraﾃδｧﾃδ｣o</segment>
    <segment id="22">, as vendas devem subir muitoﾃ｢竄ｬ</segment>
    <segment id="23">, acredita Lﾃδｺcia Santos</segment>
    <segment id="24">, vendedora de roletes de cana na Feira de Sﾃδ｣o Joaquim.</segment>
    <segment id="25">Como, pela tradiﾃδｧﾃδ｣o</segment>
    <segment id="26">, a dimensﾃδ｣o da oferenda ﾃδｩ medida pela quantidade de quiabos do caruru</segment>
    <segment id="27">, os adeptos devem preparar o bolso.</segment>
    <segment id="28">Nas principais feiras de Salvador</segment>
    <segment id="29">, 100 quiabos estﾃδ｣o saindo a R$ 5.</segment>
    <segment id="30">Pﾃδｳrem</segment>
    <segment id="31">, os vendedores alertam que o preﾃδｧo pode ser alterado de um dia para o outro.</segment>
    <segment id="32">Pensando na melhor maneira de preparar essas delﾃδｭcias</segment>
    <segment id="33">, a nutricionista Amﾃδｩlia Duarte dﾃδ｡ uma dica massa:</segment>
    <segment id="34">ﾃ｢竄ｬﾅ鼎oloque o azeite de dendﾃδｪ somente apﾃδｳs o cozimento dos alimentos</segment>
    <segment id="35">, pois</segment>
    <segment id="36">pois quando ele passa por  esse processo</segment>
    <segment id="37">,  sese torna nocivo</segment>
    <segment id="38">ﾃδ saﾃδｺdeﾃ｢竄ｬ.
Para quem nﾃδ｣o sabe</segment>
    <segment id="39">, o  azeite</segment>
    <segment id="40">ﾃδｩ excelente para a saﾃδｺde</segment>
    <segment id="41">porque</segment>
    <segment id="42">porque ﾃδｩ rico em vitamina</segment>
    <segment id="43">A,  boa para os olhos e para a pele.</segment>
    <segment id="44">Porﾃδｩm</segment>
    <segment id="45">,  ﾃδｩ mesmo necessﾃδ｡rio que ele esteja cru e seja de boa procedﾃδｪncia.</segment>
    <segment id="46">Portanto</segment>
    <segment id="47">, a nutricionista  aconselha as pessoas a pegarem leve na dosagem do dendﾃδｪ</segment>
    <segment id="48">, atﾃδｩ</segment>
    <segment id="49">para que</segment>
    <segment id="50">para que nﾃδ｣o tenham prob lemas intestinais depois.</segment>
    <segment id="51">Para ajudar os leitores</segment>
    <segment id="52">, MASSA! fez uma tabela comparativa com preﾃδｧos de  ingredientes nas principais feiras.</segment>
    <segment id="53">Confira!</segment>
    <segment id="54">Dica do mestre</segment>
    <segment id="55">O cozinheiro Josﾃδｩ</segment>
    <segment id="56">Carlos da Silva</segment>
    <segment id="57">, 35 anos</segment>
    <segment id="58">, ensina aos leitores do MASSA!</segment>
    <segment id="59">comocomo deixar o caruru de Sﾃδ｣o Cosme e Sﾃδ｣o Damiﾃδ｣o mais saboroso.</segment>
    <segment id="60">ﾃ｢竄ｬﾅ鼎omo o caruru ﾃδｩ uma comida tﾃδｭpica e nﾃδ｣o hﾃδ｡ muito</segment>
    <segment id="61">comocomo inovar no seu preparo</segment>
    <segment id="62">, caprichem no camarﾃδ｣o</segment>
    <segment id="63">, na cebola</segment>
    <segment id="64">, na castanha e no amendoimﾃ｢竄ｬ</segment>
    <segment id="65">, aconselha.</segment>
    <segment id="66">Para ele</segment>
    <segment id="67">, o valor gasto no preparo do prato e seus acompanhamentos</segment>
    <segment id="68">, para 20 pessoas</segment>
    <segment id="69">, estﾃδ｡ na faixa de R$ 150.</segment>
    <segment id="70">Quem quiser contratﾃδ｡-lo sﾃδｳ precisa ligar para o telefone (71)</segment>
