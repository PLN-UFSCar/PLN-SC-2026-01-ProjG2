  <rst>
    <segment id="1">Dilma chega a Salvador para período de descanso
SALVADOR (BA) - A presidente Dilma Rousseff desembarcou</segment>
    <segment id="2">, por volta de meio-dia desta segunda-feira</segment>
    <segment id="3">, na base aérea de Salvador.</segment>
    <segment id="4">Após passar a ceia de Natal no Palácio da Alvorada</segment>
    <segment id="5">, a presidente passará a noite de fim de ano ao lado da família na Base Naval de Aratu</segment>
    <segment id="6">, no bairro de São Tomé de Paripe.</segment>
    <segment id="7">No final da tarde</segment>
    <segment id="8">, Dilma apareceu na praia de Inema</segment>
    <segment id="9">, acompanhada da filha</segment>
    <segment id="10">, Paula</segment>
    <segment id="11">, do neto Gabriel</segment>
    <segment id="12">, e da mãe</segment>
    <segment id="13">, Dilma Jane.</segment>
    <segment id="14">A família</segment>
    <segment id="15">sese sentou em cadeiras postas na praia para eles</segment>
    <segment id="16">, onde a presidente ficou por cerca de meia hora</segment>
    <segment id="17">, conversou com a filha e a mãe e tomou uma água de coco.</segment>
    <segment id="18">A presidente chegou de helicóptero à praia de Inema</segment>
    <segment id="19">, mesmo local escolhido pelo ex-presidente Luiz Inácio Lula da Silva para o Réveillon na passagem de 2009 para 2010.</segment>
    <segment id="20">Embora a assessoria de Dilma ainda não tenha divulgado o período de sua estadia no estado</segment>
    <segment id="21">, há uma estimativa de que ela permaneça em Inema até o dia 10 de janeiro</segment>
    <segment id="22">, quando o seu período de férias chega ao fim.</segment>
    <segment id="23">Enquanto isso</segment>
    <segment id="24">, os ministros do Palácio do Planalto continuam de prontidão.</segment>
    <segment id="25">De acordo com as assessorias das pastas</segment>
    <segment id="26">, nenhuma delas entrará de férias enquanto a chefe estiver fora.</segment>
    <segment id="27">O vice presidente Michel Temer só viaja a São Paulo na quinta-feira e retorna para Brasília na semana que vem.</segment>
    <segment id="28">Passa o réveillon numa praia do litoral paulista</segment>
    <segment id="29">, masmas depois volta a despachar do escritório em São Paulo</segment>
    <segment id="30">, antes de retornar a Brasília.</segment>
    <segment id="31">Até o início do mês de dezembro</segment>
    <segment id="32">, a previsão era de que Dilma passasse as férias em Itacaré (a 428 km ao sul de Salvador)</segment>
    <segment id="33">, mesmo local onde a presidente esteve no Réveillon do ano passado.</segment>
    <segment id="34">Entretanto</segment>
    <segment id="35">, a decisão foi alterada no últimos dias.</segment>
  </rst>
</analysis>