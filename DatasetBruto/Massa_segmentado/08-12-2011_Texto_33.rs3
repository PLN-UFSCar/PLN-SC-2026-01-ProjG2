  <rst>
    <segment id="1">Família retoma o poder
Assim</segment>
    <segment id="2">comocomo fez durante a madrugada de ontem</segment>
    <segment id="3">, Marcelinho ri com a vitória
Depois de uma derrota</segment>
    <segment id="4">, Marcelo Guimarães Filho conseguiu vencer uma batalha na guerra que tem incendiado os bastidores do Bahia.</segment>
    <segment id="5">Na tarde de ontem</segment>
    <segment id="6">, ele foi reeleito presidente do Esquadrão</segment>
    <segment id="7">, com todos os 216 votos dos conselheiros que participaram do pleito a seu favor.</segment>
    <segment id="8">O segundo mandato de Marcelinho à frente do tricolor vai até o final de 2014.</segment>
    <segment id="9">O presidente novamente prometeu  a reforma do estatuto do clube:</segment>
    <segment id="10">“Precisamos modernizar o clube com um estatuto mais atual.</segment>
    <segment id="11">Pretendemos fazer isso nos próximos seis meses para</segment>
    <segment id="12">, na próxima eleição (2014)</segment>
    <segment id="13">, o sócio votar”.</segment>
    <segment id="14">As eleições do Bahia haviam sido suspensas na terça-feira</segment>
    <segment id="15">, masmas logo na madrugada de ontem</segment>
    <segment id="16">, a liminar</segment>
    <segment id="17">, que tirou a força da diretoria tricolor e o cargo de Marcelinho</segment>
    <segment id="18">,  foi cassada pelo desembargador Gesivaldo Brito.</segment>
    <segment id="19">Com isso</segment>
    <segment id="20">, ele retomou o cargo de presidente do clube e garantiu que o pleito fosse concluído: 15 membros do Conselho</segment>
    <segment id="21">, que  ainda não haviam participado da eleição</segment>
    <segment id="22">, votaram na tarde de ontem</segment>
    <segment id="23">, na sede social.</segment>
    <segment id="24">Porém, a  guerra continua.</segment>
    <segment id="25">A oposição</segment>
    <segment id="26">, que só perdeu a batalha</segment>
    <segment id="27">,  deve contestar a cassação da liminar ainda hoje.</segment>
    <segment id="28">Com isso</segment>
    <segment id="29">, a reeleição de Marcelinho corre perigo e pode ser suspensa mais uma vez.

 

Ismerim e Acioly admitem erros no Conselho do Bahia</segment>
    <segment id="30">O vice-presidente jurídico do Bahia</segment>
    <segment id="31">, Ademir Ismerim</segment>
    <segment id="32">, falou</segment>
    <segment id="33">, em um programa de ontem</segment>
    <segment id="34">, na Bandeirantes</segment>
    <segment id="35">,  que o clube precisa</segment>
    <segment id="36">sese reorganizar em alguns setores.</segment>
    <segment id="37">Além disso</segment>
    <segment id="38">, Ismerim falou sobre as prováveis irregularidades no Conselho Deliberativo do Esquadrão:</segment>
    <segment id="39">“Deve ter havido equívocos nessa exclusão de nomes do Conselho”</segment>
    <segment id="40">, criticou.</segment>
    <segment id="41">Apesar de negar que os 58 nomes da lista do Conselho Deliberativo foram trocados de forma errada</segment>
    <segment id="42">, Ruy Acioly admitiu que algumas falhas podem ter ocorrido:</segment>
    <segment id="43">“Não tem</segment>
    <segment id="44">comocomo ver</segment>
    <segment id="45">sese o Conselho está legal</segment>
    <segment id="46">porque</segment>
    <segment id="47">porque a lista é grande</segment>
    <segment id="48">, masmas vamos apurar qualquer irregularidade que exista”</segment>
    <segment id="49">, prometeu o presidente do Conselho Deliberativo tricolor.</segment>
  </rst>
</analysis>