  <rst>
    <segment id="1">Maicosuel cresce e Botafogo celebra
RIO - Há algum tempo</segment>
    <segment id="2">, era impensável ver Maicosuel ser vaiado pela torcida do Botafogo.</segment>
    <segment id="3">A impaciência da arquibancada diante da luta do jogador para recuperar seu futebol após</segment>
    <segment id="4">sese recuperar de cirurgia causava apreensão no Botafogo.</segment>
    <segment id="5">Contra o Bahia</segment>
    <segment id="6">, o meia teve chances de gol e desperdiçou.</segment>
    <segment id="7">No entanto</segment>
    <segment id="8">, ele foi um dos principais motivos de satisfação do técnico Caio Júnior.</segment>
    <segment id="9">BLOG: 'É Por Ti Fogo'

Se o empate com o Bahia foi contabilizado</segment>
    <segment id="10">comocomo um tropeço</segment>
    <segment id="11">, o desempenho de Maicosuel agradou.

- Foi o melhor jogo dele.</segment>
    <segment id="12">A tendência é evoluir - disse o técnico Caio Júnior.</segment>
    <segment id="13">Ainda sem saber</segment>
    <segment id="14">sese o jogo com o Corinthians será no domingo ou</segment>
    <segment id="15">sese será adiado em função da participação da seleção brasileira na Copa América</segment>
    <segment id="16">, a diretoria alvinegra tenta dar mais opções a Caio Júnior.</segment>
    <segment id="17">Nesta semana</segment>
    <segment id="18">, o clube precisa pagar 900 mil ao Panathinaikos</segment>
    <segment id="19">, da Grécia</segment>
    <segment id="20">, para poder regularizar a situação do volante Marcelo Mattos que</segment>
    <segment id="21">, por enquanto</segment>
    <segment id="22">, está liberado apenas para treinar.</segment>
    <segment id="23">Horas antes da viagem a Salvador</segment>
    <segment id="24">, o técnico Caio Júnior foi surpreendido com a notícia de que não poderia usar Marcelo Mattos e mostrou certa contrariedade.</segment>
    <segment id="25">Diego mais longe</segment>
    <segment id="26">Enquanto isso</segment>
    <segment id="27">, o sonho com o meia Diego parece mais distante de</segment>
    <segment id="28">sese tornar realidade.</segment>
    <segment id="29">Em entrevista ao site "Globoesporte.com"</segment>
    <segment id="30">, o pai do jogador</segment>
    <segment id="31">, Djair Cunha</segment>
    <segment id="32">, praticamente descartou a transferência.</segment>
    <segment id="33">Segundo ele</segment>
    <segment id="34">, o alvinegro não "poderia arcar com a contratação".</segment>
    <segment id="35">Djair disse ter ouvido dos dirigentes do Botafogo que a folha salarial do clube já está no limite.</segment>
    <segment id="36">O Botafogo</segment>
    <segment id="37">, por enquanto</segment>
    <segment id="38">, evita tratar o</segment>
    <segment id="39">casocaso</segment>
    <segment id="40">comocomo encerrado.</segment>
  </rst>
