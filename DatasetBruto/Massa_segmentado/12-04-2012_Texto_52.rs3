  <rst>
    <segment id="1">Deficiente mental leva bala na cabeça
Wesley estava a caminho do trabalho quando tomou dois tiros no rosto</segment>
    <segment id="2">Um vendedor ambulante portador de deficiência mental foi assassinado na manhã de ontem</segment>
    <segment id="3">, na Rua Juracy Magalhães</segment>
    <segment id="4">, na localidade Baixa do Petróleo</segment>
    <segment id="5">, em Massaranduba.

Wesley Souza de Jesus</segment>
    <segment id="6">, 18 anos</segment>
    <segment id="7">, estava a caminho do Hospital São Jorge</segment>
    <segment id="8">, onde vendia milho cozido.</segment>
    <segment id="9">A mãe de Wesley</segment>
    <segment id="10">, Josenice dos Reis Souza</segment>
    <segment id="11">, 37, conta que devido ao problema mental</segment>
    <segment id="12">, o filho</segment>
    <segment id="13">sese envolvia em confusão.</segment>
    <segment id="14">“</segment>
    <segment id="15">Se alguém olhasse atravessado</segment>
    <segment id="16">, ele já achava que estava falando mal dele”</segment>
    <segment id="17">, relata.</segment>
    <segment id="18">Josenice acredita que a morte tenha relação com esse comportamento do filho.</segment>
    <segment id="19">“Moramos aqui na Baixa do Petróleo há menos de um ano e nem todo mundo sabia que meu filho tinha problema mental” conta a mãe.</segment>
    <segment id="20">Josenice explica que duas vezes ao mês levava o filho a consultas com psiquiatras e neurologistas.</segment>
    <segment id="21">“Ele (Wesley) tomava remédio controlado.</segment>
    <segment id="22">Os médicos diziam que ele  não podia deixar de tomar os remédios”</segment>
    <segment id="23">, relata.</segment>
    <segment id="24">De acordo com Alex Chehade</segment>
    <segment id="25">, delegado do Departamento de Homicídios</segment>
    <segment id="26">, dois homens em uma moto atiraram em Wesley.</segment>
    <segment id="27">Batalha</segment>
    <segment id="28">A dona de casa Josenice lembra que desde a infância Wesley apresentava problema mental.</segment>
    <segment id="29">“</segment>
    <segment id="30">Sempre cuidei dele só</segment>
    <segment id="31">, sem ajuda do pai.</segment>
    <segment id="32">Quem fez isso vai pagar aqui na Terra.</segment>
    <segment id="33">Acredito na Justiça de Deus”</segment>
    <segment id="34">, desabafa.</segment>
    <segment id="35">A autoria e a motivação do crime ainda são desconhecidas.</segment>
  </rst>
</analysis>