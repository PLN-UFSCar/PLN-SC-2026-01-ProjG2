  <rst>
    <segment id="1">Jovem dá a louca</segment>
    <segment id="2">, atira na ex e</segment>
    <segment id="3">sese mata
Leonardo Magalhães</segment>
    <segment id="4">, 27 anos</segment>
    <segment id="5">, surta e mete bala na própria cabeça.</segment>
    <segment id="6">Morreu no HGE
Inconformado com o fim de seu relacionamento com a estudante de medicina Milena Menezes</segment>
    <segment id="7">, 24 anos</segment>
    <segment id="8">, Leonardo Magalhães</segment>
    <segment id="9">, 26, resolveu visitar</segment>
    <segment id="10">, ontem</segment>
    <segment id="11">, a ex para tentar reatar  o namoro.</segment>
    <segment id="12">Porém, o que a jovem não esperava é que Leonardo tinha um plano B</segment>
    <segment id="13">, caso</segment>
    <segment id="14">caso não conseguisse reconquistar a amada.</segment>
    <segment id="15">Estudante do curso de análise de sistema</segment>
    <segment id="16">, Leonardo foi armado ao apartamento da jovem</segment>
    <segment id="17">, que fica no edifício Praia de Itacimirim</segment>
    <segment id="18">, na Pituba.</segment>
    <segment id="19">Sem êxito na conversa com a ex</segment>
    <segment id="20">, ele resolveu tentar matá-la e</segment>
    <segment id="21">, na sequência</segment>
    <segment id="22">, cometeu suicídio.</segment>
    <segment id="23">O universitário já saiu de casa decidido</segment>
    <segment id="24">, pois</segment>
    <segment id="25">pois no apartamento da moça</segment>
    <segment id="26">, a polícia encontrou uma carta de despedida</segment>
    <segment id="27">, na qual pedia desculpas aos familiares da estudante</segment>
    <segment id="28">, com quem  namorou por cerca de três anos e havia</segment>
    <segment id="29">sese separado há 5 meses.</segment>
    <segment id="30">“Deixo esse mundo ao lado de meu amor”.</segment>
    <segment id="31">Cenário de terror no apartamento</segment>
    <segment id="32">Os policiais foram obrigados a entrar no apartamento da vítima</segment>
    <segment id="33">, para saber o que</segment>
    <segment id="34">sese passava lá dentro.</segment>
    <segment id="35">No imóvel</segment>
    <segment id="36">, os policiais</segment>
    <segment id="37">sese depararam com um cenário de filme de terror: havia diversas marcas de tiro nas paredes</segment>
    <segment id="38">, vidros quebrados e diversos objetos espalhados pela sala.</segment>
    <segment id="39">A jovem estava trancada em um dos quartos do apartamento</segment>
    <segment id="40">, em estado de choque.</segment>
    <segment id="41">Já o atirador Leonardo foi encontrado na sala pelos policiais.</segment>
    <segment id="42">Ele estava segurando a arma e tinha um ferimento na cabeça</segment>
    <segment id="43">, provocado pelo disparo que efetuou contra si próprio</segment>
    <segment id="44">, após</segment>
    <segment id="45">sese desentender com a estudante de medicina.</segment>
    <segment id="46">Crime pode ter sido premeditado</segment>
    <segment id="47">Após o ato de loucura para tirar a própria vida</segment>
    <segment id="48">, o jovem foi socorrido por uma ambulância do Serviço de Atendimento Móvel de Urgência (Samu).</segment>
    <segment id="49">Ele foi levado ao Hospital Geral do Estado (HGE)</segment>
    <segment id="50">, em estado gravíssimo.</segment>
    <segment id="51">Já a garota foi encaminhada para a 16ª Delegacia Territorial</segment>
    <segment id="52">, no bairro Pituba</segment>
    <segment id="53">, onde prestou esclarecimentos sobre a ocorrência.</segment>
    <segment id="54">Ela foi</segment>
    <segment id="55">embora</segment>
    <segment id="56">embora da delegacia por volta das 8h30 da noite</segment>
    <segment id="57">, sem falar com a reportagem.</segment>
    <segment id="58">A polícia trabalha com a hipótese que o  crime teria sido premeditado</segment>
    <segment id="59">, pois</segment>
    <segment id="60">pois a carta estava com data do dia 14 de abril.</segment>
  </rst>
</analysis>