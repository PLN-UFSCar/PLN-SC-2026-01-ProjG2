  <rst>
    <segment id="1">Cinderela do Chupa Peito</segment>
    <segment id="2">Piriguete dá sonífero a cliente em centro comercial e deixa rapaz só de cueca
Quando resolveu</segment>
    <segment id="3">, ontem</segment>
    <segment id="4">, dar uma pausa no expediente e tomar uma cervejinha com uma mulher negra</segment>
    <segment id="5">, baixinha e de cabelos ruivos</segment>
    <segment id="6">, o funcionário de uma empresa de telefonia</segment>
    <segment id="7">,  Marcos Paulo dos Santos</segment>
    <segment id="8">, não esperava terminar vítima do golpe</segment>
    <segment id="9">“boa noite</segment>
    <segment id="10">Cinderela”.</segment>
    <segment id="11">O lugar  escolhido para refrescar a garganta  foi um centro comercial  conhecido</segment>
    <segment id="12">comocomo Chupa Peito</segment>
    <segment id="13">, no município de Simões Filho</segment>
    <segment id="14">, onde Marcos trabalha.</segment>
    <segment id="15">Se o rapaz pensava  em materializar o nome pelo qual o lugar é conhecido</segment>
    <segment id="16">, caiu do cavalo.</segment>
    <segment id="17">De quente</segment>
    <segment id="18">,  mesmo</segment>
    <segment id="19">, ele só conseguiu o calor do carro em que ficou desacordado por cerca de uma  hora até a ambulância do Samu chegar e levá-lo para o Hospital Municipal.</segment>
    <segment id="20">Comerciantes locais contaram que os dois chegaram de carro</segment>
    <segment id="21">, por volta de 15h30</segment>
    <segment id="22">, e tomaram duas cervejas.</segment>
    <segment id="23">Depois ele foi ao banheiro</segment>
    <segment id="24">,  voltou para o carro e deu dinheiro para a mulher comprar uma dose de conhaque.</segment>
    <segment id="25">“Acho que foi nesse momento que ela colocou o ‘boa noite Cinderela’</segment>
    <segment id="26">, porque</segment>
    <segment id="27">porque minutos  depois ele começou a vomitar  e ela fugiu em um ônibus”</segment>
    <segment id="28">, contou a estudante Andreza Guimarães</segment>
    <segment id="29">, 16 anos.</segment>
    <segment id="30">Logo em seguida</segment>
    <segment id="31">, o rapaz tirou a roupa e continuou vomitando.</segment>
    <segment id="32">“</segment>
    <segment id="33">A cueca estava rasgada e deu para ver os documentos dele”</segment>
    <segment id="34">, contou  rindo uma comerciante.</segment>
    <segment id="35">Baixinha fez a limpa: Marcos acordou no hospital baratinado</segment>
    <segment id="36">No Hospital Municipal</segment>
    <segment id="37">, onde tomou soro e permanecia em observação até o início da noite</segment>
    <segment id="38">, colegas de Marcos disseram que ele ainda estava muito atordoado e</segment>
    <segment id="39">sese lembrava apenas que sentou</segment>
    <segment id="40">, no Chupa Peito</segment>
    <segment id="41">, para almoçar</segment>
    <segment id="42">, quando a moça</segment>
    <segment id="43">sese aproximou e chamou para tomar uma cerveja.</segment>
    <segment id="44">O rapaz estava tão desnorteado que nem</segment>
    <segment id="45">sese lembrava que a moça  havia lhe roubado a carteira</segment>
    <segment id="46">, dinheiro</segment>
    <segment id="47">, relógio</segment>
    <segment id="48">, celular e até os sapatos.</segment>
    <segment id="49">Conforme relatos de comerciantes</segment>
    <segment id="50">,  antes de irem ao Chupa Peito</segment>
    <segment id="51">, Marcos e a ruiva estavam bebendo no Centro de Abastecimento Otto Alencar</segment>
    <segment id="52">, conhecido</segment>
    <segment id="53">comocomo Linha Direta.</segment>
    <segment id="54">Marcos</segment>
    <segment id="55">, conforme informações de comerciantes</segment>
    <segment id="56">, não foi a primeira vítima da ruiva baixinha.</segment>
    <segment id="57">Ela é conhecida por roubar homens na Linha Direta.</segment>
    <segment id="58">Pelo visto</segment>
    <segment id="59">, Marcos</segment>
    <segment id="60">, que mora em Salvador</segment>
    <segment id="61">, ainda não conhecia a fama da moça.</segment>
    <segment id="62">O flagra: Samba da cueca rasgada</segment>
    <segment id="63">O Centro Comercial José Trindade de Oliveira</segment>
    <segment id="64">, foi inaugurado em 16/11/2005.</segment>
    <segment id="65">Um ano depois</segment>
    <segment id="66">, quando as serestas ainda animavam as noites do local</segment>
    <segment id="67">, um morador  conhecido</segment>
    <segment id="68">comocomo José Neto flagrou um cara sugando os seios de uma mulher em um  banheiro e  batizou o lugar de Chupa Peito.</segment>
    <segment id="69">Agora, comerciantes dizem que ali  vai</segment>
    <segment id="70">sese chamar “Samba Cueca”.</segment>
    <segment id="71">“</segment>
    <segment id="72">Por causa da cueca rasgada e</segment>
    <segment id="73">porque</segment>
    <segment id="74">porque ele levou um samba da mulher”</segment>
    <segment id="75">, disse um deles.</segment>
  </rst>
</analysis>