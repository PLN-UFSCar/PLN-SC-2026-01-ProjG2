  <rst>
    <segment id="1">Sósia de Raul quer R$ 50 mil pela barba</segment>
    <segment id="2">Paulo é um personagem da Feira de São Joaquim e costuma tocar as canções de Raul</segment>
    <segment id="3">A onda de raspar a barba em troca de dinheiro chegou à Feira de São Joaquim.</segment>
    <segment id="4">Paulo Roberto Brito</segment>
    <segment id="5">, 52 anos</segment>
    <segment id="6">, conhecido</segment>
    <segment id="7">comocomo “Raul Seixas</segment>
    <segment id="8">, o retorno”</segment>
    <segment id="9">, está oferecendo os pelos da cara em troca de R$ 50 mil.</segment>
    <segment id="10">Paulo é um personagem  da Feira de São Joaquim e costuma tocar as canções de Raul por lá todo sábado</segment>
    <segment id="11">, ao meio-dia.</segment>
    <segment id="12">Há 15 dias</segment>
    <segment id="13">, o sósia jura ter recebido de uma comerciante local a oferta de R$ 5 mil para raspar a barba.</segment>
    <segment id="14">A reportagem não encontrou tal pessoa</segment>
    <segment id="15">, masmas ele garantiu ser verdade.</segment>
    <segment id="16">“Eu fui ao túmulo de Raul Seixas consultá-lo e ele disse que R$ 5 mil era pouco.</segment>
    <segment id="17">Mandou pedir mais</segment>
    <segment id="18">, com a condição de eu doar uma parte aos pobres”</segment>
    <segment id="19">, conta o Maluco Beleza.</segment>
    <segment id="20">Paulo disse que compraria  R$ 20 mil em comida para os pobres da Cidade Baixa.</segment>
    <segment id="21">“</segment>
    <segment id="22">Esta é uma região onde tem muita gente necessitada ”</segment>
    <segment id="23">, comentou.</segment>
    <segment id="24">Com o restante da grana</segment>
    <segment id="25">, ele quer gravar um CD e investir no próprio negócio de compra e venda de material reciclável.</segment>
    <segment id="26">"</segment>
    <segment id="27">Ele precisa de apoio</segment>
    <segment id="28">porque</segment>
    <segment id="29">porque toca muito bem.</segment>
    <segment id="30">A gente costuma dar um trocado quando ele faz o som aqui na feira".</segment>
    <segment id="31">Antônio Souza Santos</segment>
    <segment id="32">,Comerciante"Paulo é artista do povo.</segment>
    <segment id="33">O governador recebeu</segment>
    <segment id="34">, Bell recebeu</segment>
    <segment id="35">, por que ele não pode ganhar também para raspar a barba?</segment>
    <segment id="36">".</segment>
    <segment id="37">Pedro dos Santos</segment>
    <segment id="38">,Motorista"Tenho uma banca de carne</segment>
    <segment id="39">, masmas daria R$ 1 mil</segment>
    <segment id="40">sese outros comerciantes ajudassem.</segment>
    <segment id="41">Já bebi muito com ele ouvindo som de Raul".</segment>
    <segment id="42">Edvaldo Egídio Moreno</segment>
    <segment id="43">,Feirante</segment>
  </rst>
