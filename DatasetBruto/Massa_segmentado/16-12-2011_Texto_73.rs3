  <rst>
    <segment id="1">Choque de ordem ambiental chega a praias de Búzios e Cabo Frio</segment>
    <segment id="2">Incluída no Parque Estadual da Costa do Sol (PECSol)</segment>
    <segment id="3">, as praias</segment>
    <segment id="4">Azeda e Azedinha</segment>
    <segment id="5">, em Búzios</segment>
    <segment id="6">, e das Conchas</segment>
    <segment id="7">, em Cabo Frio</segment>
    <segment id="8">, vão receber o mesmo choque de ordem que a Secretaria estadual do Ambiente levou para a Praia de Lopes Mendes</segment>
    <segment id="9">, no Parque Estadual da Ilha Grande.</segment>
    <segment id="10">Além do ordenamento de ambulantes e do controle de estacionamentos</segment>
    <segment id="11">, as praias serão as primeiras da Região dos Lagos a receberem as placas de sinalização do mais novo parque estadual</segment>
    <segment id="12">, a primeira unidade de conservação segmentada do Estado do Rio</segment>
    <segment id="13">, que vai de Saquarema a Búzios.
- A relevância das placas é marcar posição</segment>
    <segment id="14">, definir território</segment>
    <segment id="15">, informar e prevenir</segment>
    <segment id="16">para que</segment>
    <segment id="17">para que não</segment>
    <segment id="18">sese cometam crimes ambientais no PECSol.</segment>
    <segment id="19">O conjunto de ações e a chegada dos guardas-parques têm o objetivo de quadruplicar a visitação dos parques estaduais para estimular o ecoturismo sustentável - prevê o secretário estadual do Ambiente</segment>
    <segment id="20">, Carlos Minc.</segment>
  </rst>
</analysis>