    <segment id="22">, que estiveram na  Olimpﾃδｭada</segment>
    <segment id="23">, nﾃδ｣o figuram na lista.</segment>
    <segment id="24">Outro ausente ﾃδｩ o meia-atacante  Ganso</segment>
    <segment id="25">, que  perdeu espaﾃδｧo.</segment>
    <segment id="26">Serﾃδ｡ a primeira vez que a Seleﾃδｧﾃδ｣o  jogarﾃδ｡ no paﾃδｭs apﾃδｳs a medalha de prata nos Jogos Olﾃδｭmpicos de Londres.</segment>
    <segment id="27">Logo apﾃδｳs a queda na final</segment>
    <segment id="28">, o presidente da CBF</segment>
    <segment id="29">, Josﾃδｩ Maria Marin</segment>
    <segment id="30">, afirmou que Mano Menezes estava assegurado no cargo atﾃδｩ o amistoso contra a Argentina</segment>
    <segment id="31">, dia 19 de setembro</segment>
    <segment id="32">, que serﾃδ｡ realizado apenas com jogadores que atuam no Brasil.</segment>
    <segment id="33">Rafael fica fora</segment>
    <segment id="34">Na lista dos 22 jogadores convocados para os amistosos</segment>
    <segment id="35">, Mano nﾃδ｣o chamou tambﾃδｩm o lateral-direito Rafael</segment>
    <segment id="36">, do Manchester United.</segment>
    <segment id="37">O jogador falhou no primeiro gol que a Seleﾃδｧﾃδ｣o sofreu contra o Mﾃδｩxico na final da Olimpﾃδｭada.</segment>
    <segment id="38">"</segment>
    <segment id="39">Nﾃδ｣o me sinto obrigado a dar explicaﾃδｧﾃδｵes</segment>
