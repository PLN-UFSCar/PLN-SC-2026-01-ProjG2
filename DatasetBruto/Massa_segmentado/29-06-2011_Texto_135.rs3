  <rst>
    <segment id="1">Chororô leva Record a afastar Chris</segment>
    <segment id="2">Flor
Houve um tempo em que as duas sorriam juntas</segment>
    <segment id="3">Que a apresentadora do “</segment>
    <segment id="4">Hoje em Dia” não</segment>
    <segment id="5">sese dá com Ana Hickmann todo mundo sabe.</segment>
    <segment id="6">Mas desta vez o desafeto incomodou a alta cúpula da emissora.</segment>
    <segment id="7">A Record convocou a loira para voltar ao programa e esperava fazer um auê com a reaproximação das duas para enfrentar o concorrente “Encontros com Fátima Bernardes”.</segment>
    <segment id="8">Chris Flores não aguentou a volta da ‘inimiga’ e teve um piti</segment>
    <segment id="9">, com direito a mal- -estar e tudo.</segment>
    <segment id="10">Resultado: foi para a geladeira.</segment>
    <segment id="11">Quando sairá de lá?</segment>
