  <rst>
    <segment id="1">Há 50 anos:</segment>
    <segment id="2">Águias portuguesas no Galeão</segment>
    <segment id="3">A delegação do clube das águias ficou 40 minutos no Rio</segment>
    <segment id="4">, sendo que alguns</segment>
    <segment id="5">, como</segment>
    <segment id="6">como Costa Pereira</segment>
    <segment id="7">, Ângelo</segment>
    <segment id="8">, Águas e Coluna</segment>
    <segment id="9">, veteranos do conjunto</segment>
    <segment id="10">, reencontraram amigos.</segment>
    <segment id="11">O técnico Bela Gutman</segment>
    <segment id="12">, que aqui estivera há tempo</segment>
    <segment id="13">, com o Honved e depois</segment>
    <segment id="14">comocomo treinador do São Paulo</segment>
    <segment id="15">, mostrou-</segment>
    <segment id="16">sese satisfeito em rever o Brasil</segment>
    <segment id="17">, confessando que estuda com carinho proposta para voltar no Morumbi em 62.</segment>
    <segment id="18">Analisando para O GLOBO a peleja de Lisboa</segment>
    <segment id="19">, com a contagem de 1 x 0 para o Benfica</segment>
    <segment id="20">, foi franco ao afirmar que o resultado mais justo seria o empate.</segment>
    <segment id="21">Maldição rubro-negra de Zagalo</segment>
    <segment id="22">Mais uma vez</segment>
    <segment id="23">, em partidas disputadas contra o Flamengo</segment>
    <segment id="24">,</segment>
    <segment id="25">seu antigo clube</segment>
    <segment id="26">, Zagalo não foi feliz.</segment>
    <segment id="27">Nas oportunidades anteriores</segment>
    <segment id="28">, choques com Jadir e Joubert deixaram o ponteiro alvi-negro em inatividade</segment>
    <segment id="29">, respectivamente</segment>
    <segment id="30">, um ano e seis meses.</segment>
    <segment id="31">Desta feita</segment>
    <segment id="32">, em encontro com o mesmo Joubert</segment>
    <segment id="33">, Zagalo foi obrigado a</segment>
    <segment id="34">sese afastar da partida</segment>
    <segment id="35">, a fim de ser atendido pelo departamento médico</segment>
    <segment id="36">, com forte contusão sofrida no nariz.</segment>
    <segment id="37">Na manhã de ontem</segment>
    <segment id="38">, Zagalo compareceu ao Hospital dos Acidentados</segment>
    <segment id="39">, sendo submetido a exame radiológico</segment>
    <segment id="40">, o qual positivou a existência de fratura.</segment>
    <segment id="41">Zagalo deverá ficar inativo de 10 a 15 dias.</segment>
  </rst>
</analysis>