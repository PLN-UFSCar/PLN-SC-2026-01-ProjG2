  <rst>
    <segment id="1">Prótese de silicone estourou
Perereca</segment>
    <segment id="2">sese desespera ao ver que o bumbum murchou</segment>
    <segment id="3">Você imagina</segment>
    <segment id="4">comocomo seria uma cápsula de silicone estourando dentro de você?</segment>
    <segment id="5">Pois a dançarina Marina Queiroz</segment>
    <segment id="6">, a Mulher Perereca</segment>
    <segment id="7">, passou por essa situação na noite da última segunda-feira.</segment>
    <segment id="8">“</segment>
    <segment id="9">Quando deitei senti uma pressão em minha nádega esquerda”</segment>
    <segment id="10">, conta a funkeira</segment>
    <segment id="11">, que estreou seu bumbum turbinado nas páginas do MASSA!</segment>
    <segment id="12">, em janeiro.</segment>
    <segment id="13">A dançarina estava sem malhar havia dois dias e não acredita que a lesão  tenha ocorrido por esforço físico.</segment>
    <segment id="14">“Coloquei a prótese há 11 meses</segment>
    <segment id="15">e isso não deveria ter acontecido</segment>
    <segment id="16">porque</segment>
    <segment id="17">porque ela é vitalícia</segment>
    <segment id="18">, ou seja</segment>
    <segment id="19">, para a vida</segment>
    <segment id="20">toda” diz.</segment>
    <segment id="21">O cirurgião plástico Cézar  Velez diz que o risco de o silicone entrar em contato com a corrente sanguínea de Perereca é mínimo.</segment>
    <segment id="22">“Essas próteses não são</segment>
    <segment id="23">comocomo as antigas</segment>
    <segment id="24">, que ficavam em contato com os tecidos do corpo”</segment>
    <segment id="25">, explica.</segment>
    <segment id="26">Ele afirma que a prótese suporta até 300 kg de pressão e só não é resistente a objetos perfurantes.</segment>
    <segment id="27">O MASSA!</segment>
    <segment id="28">tentou entrar em contato com o cirurgião plástico Raidan Góes</segment>
    <segment id="29">, que pôs o silicone em Perereca</segment>
    <segment id="30">, masmas não obteve retorno.</segment>
    <segment id="31">Bola murcha e bola cheia:</segment>
    <segment id="32">O acidente aconteceu na banda esquerda</segment>
    <segment id="33">Por causa do incidente</segment>
    <segment id="34">, a mascarada terá de entrar hoje na faca.</segment>
    <segment id="35">Ela vai retirar a prótese estourada e aproveitar para aumentar as duas</segment>
    <segment id="36">, que vão passar de 350 ml para 400 ml.</segment>
    <segment id="37">“Se colocar do mesmo tamanho</segment>
    <segment id="38">, há o risco de elas não ficarem iguais”</segment>
    <segment id="39">, explica.</segment>
    <segment id="40">Com o bumbum murcho</segment>
    <segment id="41">, a morena perdeu um ensaio fotográfico</segment>
    <segment id="42">, a gravação de um clipe e alguns shows.</segment>
    <segment id="43">“Mas daqui a 15 dias estarei de volta”</segment>
    <segment id="44">, diz.</segment>
  </rst>
</analysis>