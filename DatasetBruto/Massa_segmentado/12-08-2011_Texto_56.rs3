  <rst>
    <segment id="1">Festa alvinegra sem brinde para convidados</segment>
    <segment id="2">A explicação é simples.</segment>
    <segment id="3">Contra os grandes de Rio</segment>
    <segment id="4">, São Paulo</segment>
    <segment id="5">, Porto Alegre e Belo Horizonte</segment>
    <segment id="6">, o clube soma cinco vitórias</segment>
    <segment id="7">, um empate e duas derrotas ( ganhou 59</segment>
    <segment id="8">,2% dos pontos disputados).</segment>
    <segment id="9">Diante dos demais</segment>
    <segment id="10">, foram duas vitórias</segment>
    <segment id="11">, três empates e duas derrotas (42</segment>
    <segment id="12">,8% dos pontos).</segment>
    <segment id="13">Maicosuel começa jogando</segment>
    <segment id="14">Na trajetória da equipe é nítido o problema com os times considerados de menor investimento na competição.</segment>
    <segment id="15">O alvinegro perdeu para o Figueirense e o Atlético-PR</segment>
    <segment id="16">, fora de casa</segment>
    <segment id="17">, empatou com o Bahia</segment>
    <segment id="18">, em Salvador</segment>
    <segment id="19">, e com o Atlético-GO</segment>
    <segment id="20">, em pleno Engenhão.</segment>
    <segment id="21">Mesmo assim</segment>
    <segment id="22">, está invicto jogando em seu estádio no Brasileiro.

- Vamos ter que jogar com inteligência e paciência para conseguirmos a vitória que tanto nos interessa - afirmou Caio Júnior.</segment>
    <segment id="23">O técnico promove a volta de quatro jogadores</segment>
    <segment id="24">, Lucas</segment>
    <segment id="25">, Cortês</segment>
    <segment id="26">, Renato e Elkeson</segment>
    <segment id="27">, que não enfrentaram no meio da semana o Atlético-MG</segment>
    <segment id="28">, na vitória de 2 a 1</segment>
    <segment id="29">, no Ipatingão</segment>
    <segment id="30">, pela Copa Sul-Americana.</segment>
    <segment id="31">Ontem, Caio Júnior trocou a tradicional pelada na véspera de jogo por um treino de um toque na bola.</segment>
    <segment id="32">Depois ensaiou jogadas de bola parada.</segment>
    <segment id="33">No final</segment>
    <segment id="34">, seu filho</segment>
    <segment id="35">, Gabriel</segment>
    <segment id="36">, de 15 anos</segment>
    <segment id="37">, teve permissão para cobrar algumas faltas.</segment>
    <segment id="38">O técnico confirmou Maicosuel na equipe no lugar de Felipe Menezes e justificou.

- Maicosuel está subindo de produção e entendeu que precisa chegar na área e arriscar o chute.</segment>
    <segment id="39">Botafogo: Jéfferson</segment>
    <segment id="40">, Lucas</segment>
    <segment id="41">, Antônio Carlos</segment>
    <segment id="42">, Fábio Ferreira e Cortês</segment>
    <segment id="43">; Marcelo Mattos</segment>
    <segment id="44">, Renato</segment>
    <segment id="45">, Maicosuel e Elkeson</segment>
    <segment id="46">; Herrera e Loco Abreu.</segment>
    <segment id="47">América-MG: Flávio</segment>
    <segment id="48">, Marcos Rocha</segment>
    <segment id="49">, Anderson</segment>
    <segment id="50">, Gabriel e Gílson</segment>
    <segment id="51">; Amaral</segment>
    <segment id="52">, Leandro</segment>
    <segment id="53">, Fabrício e Rodriguinho</segment>
    <segment id="54">; Alessandro e Fábio Júnior.</segment>
    <segment id="55">Juiz: André Luiz de Freitas Castro (GO).

TRANSMISSÂO: Premiere</segment>
    <segment id="56">, Rádios Globo e CBN.</segment>
  </rst>
