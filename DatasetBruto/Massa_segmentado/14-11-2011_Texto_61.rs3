  <rst>
    <segment id="1">Mulher ameaça a PM para atirar nela</segment>
    <segment id="2">Josiane invade corregedoria da polícia com pistola de brinquedo</segment>
    <segment id="3">Para dar fim à própria vida</segment>
    <segment id="4">, Josiane Cristina Xavier de Oliveira</segment>
    <segment id="5">, 31 anos</segment>
    <segment id="6">, tentou provocar um confronto com a polícia.</segment>
    <segment id="7">No início da tarde de ontem</segment>
    <segment id="8">, a mulher parou o carro ao lado da corregedoria da PM</segment>
    <segment id="9">, situada na Rua Amazonas</segment>
    <segment id="10">, na Pituba</segment>
    <segment id="11">, e começou a apontar uma arma para os policiais que faziam a guarda do prédio.</segment>
    <segment id="12">Os PMs protegeram-</segment>
    <segment id="13">sese atrás dos muros</segment>
    <segment id="14">, masmas Josiane desceu do carro e pulou o muro da corregedoria.</segment>
    <segment id="15">“Se não me matar</segment>
    <segment id="16">, eu mato”</segment>
    <segment id="17">, dizia a moça</segment>
    <segment id="18">, segundo o relato do Soldado Augusto</segment>
    <segment id="19">, que participou da ação para conter a mulher.</segment>
    <segment id="20">“</segment>
    <segment id="21">Depois</segment>
    <segment id="22">, ela disse que não queria machucar ninguém e pedia que a gente atirasse nela.</segment>
    <segment id="23">Foi nesse momento que percebemos que ela estava perturbada”</segment>
    <segment id="24">, conta o soldado.</segment>
    <segment id="25">Depois de 40 minutos</segment>
    <segment id="26">, os policiais conseguiram desarmar Josiane e descobriram que a pistola era de brinquedo.</segment>
    <segment id="27">Liberada após pagar fiança</segment>
    <segment id="28">Josiane foi indiciada por porte ilegal de arma e invasão de propriedade do Estado na Delegacia da Boca do Rio</segment>
    <segment id="29">, masmas foi liberada ao pagar fiança de R$ 1 mil.</segment>
    <segment id="30">Ela responderá ao processo em liberdade.</segment>
    <segment id="31">Em depoimento ao delegado Jaime Mendes</segment>
    <segment id="32">, Josiane disse que tentou</segment>
    <segment id="33">sese matar</segment>
    <segment id="34">porque</segment>
    <segment id="35">porque  sofre de depressão</segment>
    <segment id="36">, doença desencadeada após a morte da mãe.</segment>
    <segment id="37">Ela tem dois irmãos que moram nos Estados Unidos.</segment>
    <segment id="38">Josiane é de Minas Gerais e está em Salvador na casa de amigas.</segment>
  </rst>
</analysis>