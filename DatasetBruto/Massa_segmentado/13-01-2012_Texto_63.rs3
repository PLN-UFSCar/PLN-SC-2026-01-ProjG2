  <rst>
    <segment id="1">Afeminado</segment>
    <segment id="2">, por que não?</segment>
    <segment id="3">Estudantes da Ufba criam o projeto “Baphão queer.</segment>
    <segment id="4">A ideia é mostrar a beleza dos gays</segment>
    <segment id="5">Ser gay sim</segment>
    <segment id="6">, masmas afeminado nunca.</segment>
    <segment id="7">O discurso é defendido por muitos que dizem “aceitar” a homossexualidade e</segment>
    <segment id="8">, infelizmente</segment>
    <segment id="9">, por alguns gays que pregam o culto à virilidade masculina.</segment>
    <segment id="10">O conceito</segment>
    <segment id="11">, que vem</segment>
    <segment id="12">sese tornando comum</segment>
    <segment id="13">, no entanto</segment>
    <segment id="14">, reduz uma parcela desta população a um preconceito ainda maior.</segment>
    <segment id="15">Para desmistificar a situação</segment>
    <segment id="16">, um grupo de estudantes da Ufba resolveu criar o projeto “Baphão queer”.</segment>
    <segment id="17">A ideia é mostrar a beleza dos afeminados.</segment>
    <segment id="18">Leonardo Pires</segment>
    <segment id="19">, que integra a equipe e é um dos modelos</segment>
    <segment id="20">, diz que é preciso levantar uma bandeira de valorização deste público.</segment>
    <segment id="21">“</segment>
    <segment id="22">Eles merecem espaço e respeito”</segment>
    <segment id="23">, destaca ele</segment>
    <segment id="24">, acrescentando que existe uma tentativa de tornar a imagem dos gays mais próxima à dos heterossexuais</segment>
    <segment id="25">, o que é chamado de heteronormatividade.</segment>
    <segment id="26">“É isso que combatemos”</segment>
    <segment id="27">, afirma.</segment>
  </rst>
