  <rst>
    <segment id="1">"</segment>
    <segment id="2">Ás de Copas" é carta fora do baralho</segment>
    <segment id="3">Márcio Ribeiro Cavalcanti tentou subornar a polícia com R$ 50 mil</segment>
    <segment id="4">Uma equipe da Rotamo (Batalhão de Choque) prendeu na tarde de ontem</segment>
    <segment id="5">, em ação realizada no Bairro da Paz</segment>
    <segment id="6">, Márcio Ribeiro Cavalcanti</segment>
    <segment id="7">, 34 anos</segment>
    <segment id="8">, um dos homens colocados no site da Secretaria de Segurança Pública (SSP)</segment>
    <segment id="9">comocomo um dos bandidões da Bahia.</segment>
    <segment id="10">Cavalcanti é conhecido</segment>
    <segment id="11">comocomo “Paulista” e atuava no bairro onde foi preso.</segment>
    <segment id="12">No Baralho do Crime</segment>
    <segment id="13">, produzido pela SSP</segment>
    <segment id="14">, ele era procurado por roubo e distinguido</segment>
    <segment id="15">comocomo o “</segment>
    <segment id="16">Ás de Copas”.</segment>
    <segment id="17">No site do Disque Denúncia Bahia</segment>
    <segment id="18">, também é procurado por tráfico.</segment>
    <segment id="19">A polícia chegou até Márcio Cavalcanti após denúncia anônima.</segment>
    <segment id="20">Quando foi abordado por homens do Batalhão de Choque</segment>
    <segment id="21">, “Paulista” apresentou uma identidade falsa e ofereceu R$ 50 mil aos integrantes da guarnição</segment>
    <segment id="22">para que</segment>
    <segment id="23">para que não fosse levado a uma delegacia</segment>
    <segment id="24">, conforme informação do assessor de imprensa da PM</segment>
    <segment id="25">, capitão Marcelo Pitta.</segment>
    <segment id="26">No início da noite de ontem</segment>
    <segment id="27">, o local mais provável para a condução do preso era a Delegacia de Tóxicos e Entorpecentes (DTE)</segment>
    <segment id="28">, nos Barris</segment>
    <segment id="29">, masmas a assessoria da PM ponderou que ele poderia ainda ser encaminhado a outra unidade.</segment>
    <segment id="30">Os policiais militares continuavam no Bairro da Paz realizando novas diligências</segment>
    <segment id="31">, para averiguar a possibilidade de encontrar outros criminosos.</segment>
  </rst>
</analysis>