  <rst>
    <segment id="1">Policial leva bala na cara em assalto
Larissa de Assis Santos retornava ao trabalho quando foi abordada por dois bandidões</segment>
    <segment id="2">A aspirante a oficial da Polícia Militar</segment>
    <segment id="3">, Larissa de Assis Santos</segment>
    <segment id="4">, 32 anos</segment>
    <segment id="5">, havia acabado de lanchar e</segment>
    <segment id="6">sese preparava para  voltar ao serviço no 18º Batalhão (Centro Histórico)</segment>
    <segment id="7">, quando foi  baleada no rosto por um  dos dois homens que chegaram em uma moto</segment>
    <segment id="8">, segundo a polícia.</segment>
    <segment id="9">O crime ocorreu  pouco antes da 1 hora da manhã</segment>
    <segment id="10">, nas proximidades do Hospital Martagão Gesteira</segment>
    <segment id="11">, no Tororó</segment>
    <segment id="12">, onde o namorado dela mora.</segment>
    <segment id="13">Os homens tentaram roubar o veículo  de Larissa</segment>
    <segment id="14">, um GM Celta</segment>
    <segment id="15">, masmas  atiraram quando perceberam que ela estava com a farda da polícia</segment>
    <segment id="16">, conforme a assessoria da PM.</segment>
    <segment id="17">Uma testemunha contou que Larissa conversava com o namorado</segment>
    <segment id="18">, quando os homens chegaram.</segment>
    <segment id="19">“Não falou nada.</segment>
    <segment id="20">Só fez o disparo e foi</segment>
    <segment id="21">embora</segment>
    <segment id="22">embora”</segment>
    <segment id="23">, disse.</segment>
    <segment id="24">Ela foi levada para o Hospital Geral do Estado (HGE)</segment>
    <segment id="25">, de onde teve  alta  à tarde.</segment>
    <segment id="26">Nenhum familiar foi encontrado pela reportagem na casa da aspirante nem da do namorado dela.</segment>
    <segment id="27">O comandante do 18º Batalhão</segment>
    <segment id="28">, major Arnaldo</segment>
    <segment id="29">, disse que Larissa está no comando há seis anos e “é uma excelente profissional”.</segment>
    <segment id="30">Sem suspeitos</segment>
    <segment id="31">Os bandidos fugiram e</segment>
    <segment id="32">, até o início da noite de ontem</segment>
    <segment id="33">, nenhum suspeito havia sido detido.</segment>
    <segment id="34">“</segment>
    <segment id="35">Várias guarnições estão fazendo buscas</segment>
    <segment id="36">, masmas ainda não temos pistas.</segment>
    <segment id="37">Estamos analisando imagens das câmeras de segurança de condomínios e empresas próximas</segment>
    <segment id="38">, a fim de tentar identificá-los”</segment>
    <segment id="39">, informou o major Arnaldo.</segment>
    <segment id="40">O caso</segment>
    <segment id="41">caso está sendo investigado pela 1ª DT (Barris).</segment>
    <segment id="42">Vizinhos acreditam que o crime pode ter sido uma resposta de um ladrão que Larissa conduziu à delegacia.</segment>
    <segment id="43">O bandido foi detido quando tentava roubar uma senhora</segment>
    <segment id="44">, há um mês aproximadamente.</segment>
  </rst>
</analysis>