  <rst>
    <segment id="1">População de Sauipe está apavorada</segment>
    <segment id="2">Sesab admite surto de meningite</segment>
    <segment id="3">, masmas diz que não há motivo para pânico</segment>
    <segment id="4">O surto de meningite no complexo hoteleiro</segment>
    <segment id="5">, confirmado pela Sesab</segment>
    <segment id="6">, deixou assustada a população de Porto Sauipe</segment>
    <segment id="7">, a 5 km do local e a 70 km de Salvador.</segment>
    <segment id="8">Uma manifestação no acesso à localidade pela Linha Verde bloqueou ontem</segment>
    <segment id="9">, por mais de duas horas</segment>
    <segment id="10">, a saída dos ônibus que transportavam funcionários para o complexo.</segment>
    <segment id="11">A população pede a distribuição gratuita da vacina.</segment>
    <segment id="12">Hoje, uma nova manifestação está marcada para as 6h da manhã.</segment>
    <segment id="13">“</segment>
    <segment id="14">A gente não sabe</segment>
    <segment id="15">sese o surto vai nos atingir”</segment>
    <segment id="16">, reclama Tiago Silva</segment>
    <segment id="17">, que tem dois irmãos trabalhando nos hotéis.</segment>
    <segment id="18">Uma das vítimas fatais da doença</segment>
    <segment id="19">, Renan Silva</segment>
    <segment id="20">, morava em Porto Sauipe.</segment>
    <segment id="21">As duas escolas públicas ficaram fechadas</segment>
    <segment id="22">, pois</segment>
    <segment id="23">pois a mãe de Renan  é professora.</segment>
    <segment id="24">Após a morte de três pessoas e da internação de quatro – sendo que uma continua em estado grave no Hospital Couto Maia –</segment>
    <segment id="25">, o coordenador de Vigilância Epidemiológica da Sesab</segment>
    <segment id="26">, Juarez Dias</segment>
    <segment id="27">, reconheceu ontem a existência de um surto da doença no complexo.</segment>
    <segment id="28">Apesar de todas as vítimas serem funcionárias e o complexo ter recebido</segment>
    <segment id="29">, entre a última quarta e o sábado</segment>
    <segment id="30">, três mil pessoas por noite para o Sauipe Folia</segment>
    <segment id="31">, a Sesab descartou a necessidade de medicar os participantes do evento.</segment>
    <segment id="32">Cerca de 1.800 funcionários do complexo e familiares receberam a medicação.</segment>
    <segment id="33">Estado de alerta:</segment>
    <segment id="34">Secretário acompanha</segment>
    <segment id="35">casocaso</segment>
    <segment id="36">Na tarde de ontem</segment>
    <segment id="37">, ao menos duas ambulâncias provenientes do complexo e outra de Mata de São João chegaram ao Couto Maia com pacientes com suspeita de meningite.</segment>
    <segment id="38">A direção da unidade</segment>
    <segment id="39">, que é referência no estado no tratamento de doenças infectocontagiosas</segment>
    <segment id="40">, garantiu que novos casos não foram confirmados.</segment>
    <segment id="41">O secretário de Saúde Jorge Solla explicou ontem que</segment>
    <segment id="42">, após as medidas de bloqueio contra o surto de meningite</segment>
    <segment id="43">, acompanha</segment>
    <segment id="44">sese as ações tiveram sucesso.</segment>
    <segment id="45">“Precisamos manter o estado de alerta e o acompanhamento para saber</segment>
    <segment id="46">sese tivemos sucesso nessa ação”.</segment>
    <segment id="47">Mais sobre a doença na página 22.</segment>
    <segment id="48">Repercussão no Twitter</segment>
    <segment id="49">Não há motivo para pânico nem para aplicar o medicamento contra meningite entre os participantes do Sauipe Folia.</segment>
    <segment id="50">Esta é a recomendação da Sesab.</segment>
    <segment id="51">Apesar disso</segment>
    <segment id="52">, o assunto já repercutiu na internet com foliões preocupados com a situação e críticas à não suspensão do evento.</segment>
    <segment id="53">“</segment>
    <segment id="54">Tô indo ao médico agora.</segment>
    <segment id="55">Tá rolando surto de meningite na Costa do Sauipe!</segment>
    <segment id="56">“</segment>
    <segment id="57">, comentou no Twitter uma turista de Recife que ficou hospedada lá durante cinco dias.</segment>
  </rst>
</analysis>