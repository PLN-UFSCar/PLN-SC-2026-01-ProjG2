  <rst>
    <segment id="1">Mulher sofre nas mãos de traficantes
Aos 42 anos</segment>
    <segment id="2">, ela foi estuprada e espancada por três bandidões e uma mulher</segment>
    <segment id="3">Uma mulher de 42 anos foi espancada e estuprada após</segment>
    <segment id="4">sese recusar a manter relações sexuais com uma traficante de prenome Marise na noite do último sábado</segment>
    <segment id="5">, conforme informações do posto policial do Hospital Ernesto Simões Filho</segment>
    <segment id="6">, no Pau Miúdo.</segment>
    <segment id="7">A mulher contou à polícia que é usuária de crack</segment>
    <segment id="8">, foi atraída para a casa de Marise</segment>
    <segment id="9">, na Rua Almirante Barroso</segment>
    <segment id="10">, em Massaranduba</segment>
    <segment id="11">, e  após recusar a investida foi amarrada e violentada pela traficante e dois homens conhecidos</segment>
    <segment id="12">comocomo Miau e Índio.</segment>
    <segment id="13">A mulher teve ferimentos no rosto</segment>
    <segment id="14">, nas costas e no abdômen.</segment>
    <segment id="15">Após as agressões</segment>
    <segment id="16">, ela ainda chegou a passar horas amarrada até ser socorrida  por Saraiton Campos da Silva</segment>
    <segment id="17">, na madrugada de ontem.</segment>
    <segment id="18">Inicialmente</segment>
    <segment id="19">, o homem a levou  para a 3° DT (Bonfim)</segment>
    <segment id="20">, cujos policiais o ajudaram a levá-la para o Hospital Ernesto Simões Filho.</segment>
    <segment id="21">A mulher teve alta médica ontem mesmo</segment>
    <segment id="22">, de acordo com  informações da recepção  do próprio hospital.</segment>
    <segment id="23">O crime deve ser investigado pela Delegacia Especial de Atendimento a Mulher (DEAM).</segment>
    <segment id="24">Até o início da noite</segment>
    <segment id="25">,  não havia informações sobre a prisão dos  suspeitos.</segment>
    <segment id="26">Dona do pedaço

Moradores confirmaram a versão da vítima de que Marise é traficante da área.</segment>
    <segment id="27">A casa dela</segment>
    <segment id="28">, na Rua Almirante Barroso</segment>
    <segment id="29">, é usada</segment>
    <segment id="30">comocomo ponto de venda de drogas</segment>
    <segment id="31">, segundo eles.</segment>
    <segment id="32">“</segment>
    <segment id="33">Aí já é</segment>
    <segment id="34">casocaso velho.</segment>
    <segment id="35">Ela usa e vende o negócio dela lá</segment>
    <segment id="36">, masmas não vejo mexer com ninguém.</segment>
    <segment id="37">Vem muita gente de fora comprar drogas na mão dela”</segment>
    <segment id="38">, relatou um morador</segment>
    <segment id="39">, cujo nome não foi informado por medo de represálias.</segment>
    <segment id="40">“Devem ser do bando dela.</segment>
    <segment id="41">Tenha cuidado</segment>
    <segment id="42">porque</segment>
    <segment id="43">porque tem gente dela em frente à casa”</segment>
    <segment id="44">, disse outro morador sobre Miau e Índio.</segment>
    <segment id="45">Apesar de residencial e muito estreita</segment>
    <segment id="46">, o fluxo de veículo na Rua Almirante Barroso é sempre muito intenso</segment>
    <segment id="47">,</segment>
    <segment id="48">a exemplo de ontem</segment>
    <segment id="49">, de acordo com moradores.</segment>
  </rst>
</analysis>