  <rst>
    <segment id="1">Onda de pavor por causa de boato
Moradores de Itapuã estão com medo de um carro preto que estaria roubando crianças</segment>
    <segment id="2">Há mais ou menos quinze dias</segment>
    <segment id="3">, moradores de Itapuã andam assustados com as histórias de que um carro preto estaria sequestrando crianças.</segment>
    <segment id="4">Circula</segment>
    <segment id="5">, inclusive</segment>
    <segment id="6">, histórias de que os supostos sequestradores estariam tomando as crianças dos braços das mães.</segment>
    <segment id="7">Contudo</segment>
    <segment id="8">, ao que tudo indica</segment>
    <segment id="9">, as histórias não passam de “lenda urbana” já que</segment>
    <segment id="10">, até o início da noite de ontem</segment>
    <segment id="11">, nenhuma queixa havia sido registrada na 12ª DT (em Itapuã) ou na Delegacia Especializada de Repressão a Crimes contra a Criança e o Adolescente (Derca)</segment>
    <segment id="12">, em Brotas.</segment>
    <segment id="13">Na semana passada</segment>
    <segment id="14">, uma senhora chegou a ser ouvida na delegacia do bairro sobre um carro preto que estaria circulando na área.</segment>
    <segment id="15">Mas não apontou nenhuma vítima.</segment>
    <segment id="16">“</segment>
    <segment id="17">Até o momento</segment>
    <segment id="18">, nenhuma investigação foi iniciada</segment>
    <segment id="19">porque</segment>
    <segment id="20">porque não há registro de ocorrência.</segment>
    <segment id="21">Estamos no aguardo”</segment>
    <segment id="22">, diz o chefe do SI  da 12ª DT Luiz Pereira.</segment>
    <segment id="23">A delegada da Derca Diana Marise Lima informou que tomou conhecimento dos boatos por meio do Conselho Tutelar</segment>
    <segment id="24">, masmas também não recebeu queixas.</segment>
    <segment id="25">“</segment>
    <segment id="26">É estranho ninguém  procurar a delegacia em</segment>
    <segment id="27">casocaso de desaparecimento de uma criança.</segment>
    <segment id="28">Estamos investigando o</segment>
    <segment id="29">casocaso</segment>
    <segment id="30">, masmas ainda não há indícios da história ser verdade”</segment>
    <segment id="31">, afirma.</segment>
    <segment id="32">A delegada orienta a população a entrar em contato com a polícia</segment>
    <segment id="33">casocaso tome conhecimento da existência de alguma vítima.</segment>
    <segment id="34">Ligue  para o Disque Denúncia da Derca: 3116-2151 / 3235-0000  ou para o número nacional  Dique * 100.</segment>
    <segment id="35">O medo é tanto que nenhum morador quis tirar foto para sair na reportagem.</segment>
  </rst>
</analysis>