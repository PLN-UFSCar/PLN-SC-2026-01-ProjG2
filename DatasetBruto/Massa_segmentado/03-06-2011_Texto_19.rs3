  <rst>
    <segment id="1">Humala não descarta indultar Fujimori
RIO - O nacionalista Ollanta Humala disse nesta sexta-feira</segment>
    <segment id="2">, em entrevista à rede americana CNN</segment>
    <segment id="3">, que não descarta indultar o ex-ditador Alberto Fujimori</segment>
    <segment id="4">, preso por crimes contra a humanidade e pai de de Keiko</segment>
    <segment id="5">, sua adversária nas eleições de domingo</segment>
    <segment id="6">, no Peru.</segment>
    <segment id="7">RIO - O nacionalista Ollanta Humala disse nesta sexta-feira</segment>
    <segment id="8">, em entrevista à rede americana CNN</segment>
    <segment id="9">, que não descarta indultar o ex-ditador Alberto Fujimori</segment>
    <segment id="10">, preso por crimes contra a humanidade e pai de de Keiko</segment>
    <segment id="11">, sua adversária nas eleições de domingo</segment>
    <segment id="12">, no Peru.</segment>
    <segment id="13">O nome de Fujimori é um dos pontos mais delicados da imprevisível corrida eleitoral no Peru.</segment>
    <segment id="14">Da prisão</segment>
    <segment id="15">, ele comanda a campanha da filha</segment>
    <segment id="16">, e seus detratores diziam que uma das primeiras medidas de Keiko no poder seria libertar o pai.
PARCEIROS:</segment>
    <segment id="17">Com Humala ou Keiko</segment>
    <segment id="18">, relação Brasil-Peru deve manter pragmatismo</segment>
    <segment id="19">ECONOMIA:</segment>
    <segment id="20">Mercado vive dia de tensão pré-Humala 
SUCESSO:</segment>
    <segment id="21">Marketing brasileiro reforça eleição no Peru
- Ninguém deve morrer na cadeia.</segment>
    <segment id="22">Acredito que deve haver um tratamento humano às pessoas privadas de sua liberdade - disse Humala à jornalista da CNN.</segment>
    <segment id="23">A repórter insistiu na pergunta</segment>
    <segment id="24">, questionando</segment>
    <segment id="25">sese Humala estaria disposto</segment>
    <segment id="26">, então</segment>
    <segment id="27">, a conceder um indulto a Fujimori por motivos de saúde.
- Sim</segment>
    <segment id="28">, por razões humanitárias - assegurou.</segment>
    <segment id="29">Engenheiro agrônomo de formação</segment>
    <segment id="30">, condenado a um quarto de século em regime fechado por crimes contra a Humanidade e corrupção</segment>
    <segment id="31">, Fujimori</segment>
    <segment id="32">, de 73 anos</segment>
    <segment id="33">, está na Penitenciária de Barbadillo.
Eleito presidente em 1990</segment>
    <segment id="34">, com 60% dos votos</segment>
    <segment id="35">, rasgou a Constituição no segundo ano do primeiro mandato.</segment>
    <segment id="36">Fechou o Congresso</segment>
    <segment id="37">, outorgou sua própria Carta</segment>
    <segment id="38">, suspendeu o Poder Judiciário e consolidou uma ditadura</segment>
    <segment id="39">, sustentada pelo exercício do terror</segment>
    <segment id="40">comocomo política de Estado durante uma década.</segment>
    <segment id="41">Disputa continua imprevisível</segment>
    <segment id="42">Humala e Fujimori seguem competindo palmo a palmo pela Presidência</segment>
    <segment id="43">, segundo pesquisas divulgadas nesta sexta-feira.</segment>
    <segment id="44">No que é visto</segment>
    <segment id="45">comocomo um dos segundos turnos mais disputados na história do país</segment>
    <segment id="46">, o que deve acontecer é um resultado definido nos últimos instantes.</segment>
    <segment id="47">Em uma simulação de votação da Universidade Católica</segment>
    <segment id="48">, Humala ficou com 3</segment>
    <segment id="49">,6 pontos percentuais à frente de Keiko Fujimori</segment>
    <segment id="50">, com 51</segment>
    <segment id="51">,8% frente a 48</segment>
    <segment id="52">,2% da candidata</segment>
    <segment id="53">, de acordo com uma fonte que teve acesso à pesquisa</segment>
    <segment id="54">, feita no dia 02 de junho com 1.800 pessoas - a margem de erro é de 2</segment>
    <segment id="55">,31 pontos.</segment>
    <segment id="56">Mais cedo</segment>
    <segment id="57">, outra simulação de votação da empresa Datum - realizada de 31 de março a 1 de junho com 4.820 pessoas - mostrou Keiko com 50</segment>
    <segment id="58">,6%, enquanto Humala ficou com 49</segment>
    <segment id="59">,4%.</segment>
    <segment id="60">O trabalho da Datum teve margem de erro de 1</segment>
    <segment id="61">,4 ponto</segment>
    <segment id="62">, o que significa também um empate técnico.</segment>
  </rst>
