  <rst>
    <segment id="1">Gr횄짧mio derrota o Inter no Beira-Rio e tira 3횂쨘 lugar do Vasco no Brasileir횄짙o
RIO - O Gr횄짧mio soube aproveitar uma oportunidade de gol que teve logo no in횄짯cio do cl횄징ssico contra o Internacional e deixou a casa do advers횄징rio com a vit횄쨀ria de 1 a 0</segment>
    <segment id="2">, que fez o tricolor subir uma posi횄짠횄짙o na tabela.</segment>
    <segment id="3">O resultado levou o time do t횄짤cnico Vanderlei Luxemburgo ao 3횂쨘 lugar</segment>
    <segment id="4">, agora com 37 pontos</segment>
    <segment id="5">, dois a mais do que o Vasco</segment>
    <segment id="6">, que no s횄징bado perdeu do Fluminense e ficou estacionado nos 35.</segment>
    <segment id="7">O Inter permanece com 31.</segment>
    <segment id="8">O gol 횄쨘nico do Grenal saiu logo aos sete minutos</segment>
    <segment id="9">, com Elano</segment>
    <segment id="10">, que aproveitou rebote na frente da 횄징rea</segment>
    <segment id="11">, ap횄쨀s cruzamento da esquerda em que o goleiro Muriel saiu mal e a zaga colorada bateu cabe횄짠a.</segment>
    <segment id="12">Na primeira etapa</segment>
    <segment id="13">, aos 22</segment>
    <segment id="14">, o uruguaio Diego Forl횄징n</segment>
    <segment id="15">, do Inter</segment>
    <segment id="16">, perdeu um gol cara a cara com Marcelo Grohe.</segment>
    <segment id="17">O atacante colorado chutou em cima do goleiro na pequena 횄징rea.</segment>
    <segment id="18">Aos 27</segment>
    <segment id="19">, foi Leandro Dami횄짙o que errou uma cabe횄짠ada livre tamb횄짤m na pequena 횄징rea.</segment>
    <segment id="20">O Gr횄짧mio quase ampliou aos 31</segment>
    <segment id="21">, em cobran횄짠a de falta de Z횄짤 Roberto que Muriel espalmou e Marcelo Moreno chutou cruzado no rebote</segment>
    <segment id="22">, masmas em cima de outro jogador gremista.</segment>
    <segment id="23">Depois do intervalo o Inter adotou a estrat횄짤gia de tentar pressionar</segment>
    <segment id="24">, masmas n횄짙o consegue criar chances de gol.</segment>
    <segment id="25">O Gr횄짧mio</segment>
    <segment id="26">, por sua vez</segment>
    <segment id="27">, joga no contra-ataque.</segment>
    <segment id="28">Num deles</segment>
    <segment id="29">, aos 20 minutos</segment>
    <segment id="30">, Kl횄짤ber lan횄짠ou Leandro e o goleiro Muriel teve que sair e</segment>
    <segment id="31">sese atirar nos p횄짤s do atacante gremista para evitar o gol.</segment>
