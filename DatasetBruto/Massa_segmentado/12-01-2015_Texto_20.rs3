  <rst>
    <segment id="1">MГѓВЈe de Davi espera por milagre</segment>
    <segment id="2">Adolescente estГѓВЎ desaparecido hГѓВЎ 80 dias</segment>
    <segment id="3">, sem retorno da PolГѓВ­cia</segment>
    <segment id="4">Hoje completam 79 dias do desaparecimento de Davi Santos Fiuza</segment>
    <segment id="5">, 16 anos.</segment>
    <segment id="6">Sem nenhuma resposta por parte da polГѓВ­cia</segment>
    <segment id="7">, a mГѓВЈe dele</segment>
    <segment id="8">, a comerciГѓВЎria Rute Fiuza Santos</segment>
    <segment id="9">, 46, afirma estar cansada.</segment>
    <segment id="10">Гўв‚¬Е“Essa impunidade ГѓВ© o que me cansa.</segment>
    <segment id="11">A maioria das mГѓВЈes que tiveram seus filhos levados</segment>
    <segment id="12">sese apega a alguma religiГѓВЈo.</segment>
    <segment id="13">Eu sou um pouco cГѓВ©tica para essas coisas.</segment>
    <segment id="14">Mas agora tambГѓВ©m estou esperando um milagreГўв‚¬</segment>
    <segment id="15">, admite ela</segment>
    <segment id="16">, aos prantos.</segment>
    <segment id="17">Davi desapareceu no dia 24 de outubro do ano passado.</segment>
    <segment id="18">A famГѓВ­lia acusa policiais militares da 49Г‚ВЄ CIPM (Companhia Independente da PolГѓВ­cia Militar - SГѓВЈo CristГѓВіvГѓВЈo)</segment>
    <segment id="19">, inclusive do PelotГѓВЈo de Emprego TГѓВЎtico Operacional (Peto) e da Rondesp (Rondas Especiais) de o terem levado durante uma operaГѓВ§ГѓВЈo na Rua SГѓВЈo Jorge de Baixo</segment>
    <segment id="20">, em Vila Verde</segment>
    <segment id="21">, na Estrada Velha do Aeroporto.</segment>
    <segment id="22">Гўв‚¬Е“Eu espero que a polГѓВ­cia me dГѓВЄ uma satisfaГѓВ§ГѓВЈo</segment>
    <segment id="23">comocomo deu ГѓВ  famГѓВ­lia de DiogoГўв‚¬</segment>
    <segment id="24">, afirmou Rute</segment>
    <segment id="25">, referindo-</segment>
    <segment id="26">sese ao policial militar.</segment>
    <segment id="27">Diogo foi baleado apГѓВіs reagir a um assalto a ГѓВґnibus e morreu no hospital.</segment>
    <segment id="28">Гўв‚¬Е“Em menos de 24h</segment>
    <segment id="29">, a polГѓВ­cia achou os suspeitos.</segment>
    <segment id="30">NГѓВЈo havia cГѓВўmera</segment>
    <segment id="31">, nГѓВЈo havia nada</segment>
    <segment id="32">, e eles prenderam o cara.</segment>
    <segment id="33">AtГѓВ© hoje</segment>
    <segment id="34">, estou sem resposta sobre o que aconteceu com meu filhoГўв‚¬</segment>
    <segment id="35">, completou.</segment>
    <segment id="36">PolГѓВ­cia intima 30 PMs para depor</segment>
    <segment id="37">Atualmente</segment>
    <segment id="38">, o desaparecimento de Davi ГѓВ© investigado pelo Departamento de HomicГѓВ­dios (DHPP).</segment>
    <segment id="39">Segundo o diretor da unidade</segment>
    <segment id="40">, delegado Jorge Figueiredo</segment>
    <segment id="41">, 30 policiais militares foram intimidados para prestar depoimento no DHPP.</segment>
    <segment id="42">AlГѓВ©m disso</segment>
    <segment id="43">, todas as pessoas ouvidas no inquГѓВ©rito policial feito na 12Г‚ВЄ DT [Delegacia de ItapuГѓВЈ] tambГѓВ©m foram intimadas.</segment>
    <segment id="44">Гўв‚¬Е“Identificamos outras pessoas que podem contribuir com as investigaГѓВ§ГѓВµes e estamos levantando informaГѓВ§ГѓВµes sobre quais guarniГѓВ§ГѓВµes participaram dessa operaГѓВ§ГѓВЈoГўв‚¬</segment>
    <segment id="45">, afirmou o delegado Figueiredo</segment>
    <segment id="46">, sem revelar detalhes.</segment>
    <segment id="47">O sumiГѓВ§o do adolescente comeГѓВ§ou a ser investigado pela Corregedoria da PolГѓВ­cia Militar e pela Delegacia de ItapuГѓВЈ (12Г‚ВЄ DT).</segment>
    <segment id="48">Em nota</segment>
    <segment id="49">, a assessoria da PM informou que as investigaГѓВ§ГѓВµes da Corregedoria concluГѓВ­ram nГѓВЈo haver indГѓВ­cios de envolvimento de PM no desaparecimento do jovem.</segment>
    <segment id="50">O delegado ACM Santos</segment>
    <segment id="51">, titular da 12Г‚ВЄ DT</segment>
    <segment id="52">, concluiu que hГѓВЎ indГѓВ­cios e nГѓВЈo comprovaГѓВ§ГѓВЈo de envolvimento de policiais militares no desaparecimento do jovem.</segment>
    <segment id="53">Segundo o delegado</segment>
    <segment id="54">, o pai de Davi</segment>
    <segment id="55">, o agente de portaria CГѓВ©sar Lopes Fiuza</segment>
    <segment id="56">, 49, confirmou que ele usava drogas e andava armado em depoimento.</segment>
    <segment id="57">Em entrevista ao MASSA!</segment>
    <segment id="58">, CГѓВ©sar negou envolvimento do filho com a criminalidade.</segment>
    <segment id="59">VocГѓВЄ sabia?</segment>
    <segment id="60">AlГѓВ©m da manifestaГѓВ§ГѓВЈo</segment>
    <segment id="61">, na PraГѓВ§a da Piedade</segment>
    <segment id="62">, no dia 14 de novembro</segment>
    <segment id="63">, Rute participou de um protesto com outras mГѓВЈes na mesma situaГѓВ§ГѓВЈo em frente ao prГѓВ©dio da Governadoria.</segment>
    <segment id="64">O intuito era conseguir uma reuniГѓВЈo com o governador</segment>
    <segment id="65">, que ainda nГѓВЈo ocorreu.</segment>
    <segment id="66">A manifestaГѓВ§ГѓВЈo foi organizada pela campanha Гўв‚¬ЛњReaja ou SerГѓВЎ</segment>
    <segment id="67">Morto ou Morta!Гўв‚¬в„ў.</segment>
    <segment id="68">Entre outras mobilizaГѓВ§ГѓВµes</segment>
    <segment id="69">, a mГѓВЈe tambГѓВ©m participou de reuniГѓВЈo com representantes da Anistia Internacional no Rio de Janeiro.</segment>
    <segment id="70">Гўв‚¬Е“Busco apoio e forГѓВ§as para reagir.</segment>
    <segment id="71">Por mais que a imprensa bata em cima</segment>
    <segment id="72">, na Bahia</segment>
    <segment id="73">, os casos nГѓВЈo tГѓВЄm muita visibilidadeГўв‚¬</segment>
    <segment id="74">, lamenta Rute.</segment>
  </rst>
