  <rst>
    <segment id="1">Monstra sentiu vontade de matar
Maria de Fátima confessou ter matado Júlia e ainda deu detalhes do crime</segment>
    <segment id="2">Apontada</segment>
    <segment id="3">comocomo principal suspeita de matar  Júlia Lina Rodrigues de Lima Silva e Souza</segment>
    <segment id="4">, 8 anos</segment>
    <segment id="5">, Maria de Fátima dos Santos</segment>
    <segment id="6">, 49, confessou o crime e alegou ter assassinado a filha do vereador Getúlio Silva</segment>
    <segment id="7">, de Lapão (a 478  km de Salvador)</segment>
    <segment id="8">, porque</segment>
    <segment id="9">porque sentiu uma “vontade incontrolável” de matar alguém.</segment>
    <segment id="10">A garota</segment>
    <segment id="11">, segundo ela</segment>
    <segment id="12">, foi escolhida pela facilidade de acesso</segment>
    <segment id="13">, já que frequentava a casa dela para brincar com sua filha adotiva.</segment>
    <segment id="14">Maria confessou o crime na noite de anteontem</segment>
    <segment id="15">, ao ser presa depois de a polícia encontrar o corpo da menina em uma fossa no quintal da casa dela.</segment>
    <segment id="16">“</segment>
    <segment id="17">Mesmo com a descoberta do corpo</segment>
    <segment id="18">, ela negou o crime.</segment>
    <segment id="19">Depois</segment>
    <segment id="20">, confessou</segment>
    <segment id="21">, contando tudo com detalhes”</segment>
    <segment id="22">, disse  o delegado Ciro Palmeira.</segment>
    <segment id="23">A assassina contou que pôs antidepressivos em um brigadeiro para dopar Júlia</segment>
    <segment id="24">, que teve pés e mãos amarrados com fraldas de pano após adormecer</segment>
    <segment id="25">, quando foi sufocada com um saco plástico.</segment>
    <segment id="26">O buraco na fossa</segment>
    <segment id="27">, onde o corpo foi escondido</segment>
    <segment id="28">, foi aberto antes do crime.</segment>
    <segment id="29">“Ela planejou tudo: atraiu a menina e mandou a filha sair para cometer o crime.</segment>
    <segment id="30">E ainda ajudou nas  buscas”</segment>
    <segment id="31">, disse o delegado.</segment>
    <segment id="32">Agora, a polícia investiga</segment>
    <segment id="33">sese a criminosa</segment>
    <segment id="34">sese chama realmente Maria de Fátima.</segment>
    <segment id="35">Natural de Maceió (AL)</segment>
    <segment id="36">, ela já morou em outros estados e outras cidades baianas.</segment>
    <segment id="37">As últimas foram Barreiras e Luís Eduardo Magalhães</segment>
    <segment id="38">, onde teria adotado a garota de 8 anos</segment>
    <segment id="39">, que agora está sob a responsabilidade do Conselho Tutelar da cidade.</segment>
    <segment id="40">“</segment>
    <segment id="41">Nunca desconfiei dela.</segment>
    <segment id="42">Fátima precisa de Deus</segment>
    <segment id="43">, acredito que ela é um monstro”</segment>
    <segment id="44">, resumiu o vereador e pai de Júlia</segment>
    <segment id="45">, Getúlio Silva.</segment>
    <segment id="46">Assassina é transferida</segment>
    <segment id="47">Autuada por homicídio doloso duplamente qualificado e ocultação de cadáver</segment>
    <segment id="48">, Maria de Fátima já foi transferida de Irecê para outra delegacia por causa do risco de linchamento.</segment>
    <segment id="49">Além de já terem incendiado a casa onde a assassina morava há quatro anos</segment>
    <segment id="50">, moradores do povoado de Rodagem ainda falam em fazer justiça com as próprias mãos.</segment>
    <segment id="51">“Estamos tentando acalmar as pessoas</segment>
    <segment id="52">, já que ela foi presa e pagará pelo o que fez”</segment>
    <segment id="53">, frisou o técnico agrícola Joelson Dantas</segment>
    <segment id="54">, amigo da família de Júlia.</segment>
  </rst>
</analysis>