  <rst>
    <segment id="1">Dinheiro rosa: saiba</segment>
    <segment id="2">comocomo proceder</segment>
    <segment id="3">sese receber notas manchadas
RIO - Como o cidadão deve proceder ao receber dinheiro manchado de rosa?</segment>
    <segment id="4">Ele não deve aceitar</segment>
    <segment id="5">, pois</segment>
    <segment id="6">pois as notas podem ser provenientes de roubo.</segment>
    <segment id="7">É importante sempre verificar o dinheiro.</segment>
    <segment id="8">LEIA TAMBÉM:</segment>
    <segment id="9">BC manda banco trocar nota manchada imediatamente</segment>
    <segment id="10">E sese a nota manchada de rosa for sacada no banco</segment>
    <segment id="11">, inclusive em caixa eletrônico</segment>
    <segment id="12">, como</segment>
    <segment id="13">como proceder?</segment>
    <segment id="14">No caso</segment>
    <segment id="15">caso do caixa ou em um terminal de autoatendimento</segment>
    <segment id="16">, a pessoa deve procurar qualquer agência do banco do qual é correntista e apresentar a nota manchada.</segment>
    <segment id="17">O banco é obrigado a trocar o dinheiro imediatamente.</segment>
    <segment id="18">O que devem fazer os aposentados e beneficiários do Bolsa Família que não têm conta em banco</segment>
    <segment id="19">sese sacarem uma nota manchada de rosa?</segment>
    <segment id="20">Devem procurar qualquer agência do banco onde sacou o dinheiro para fazer a troca.</segment>
    <segment id="21">O banco é obrigado a trocá-lo imediatamente.</segment>
    <segment id="22">É obrigatório tirar o extrato e apresentar com a nota manchada?</segment>
    <segment id="23">Não.</segment>
    <segment id="24">Basta ir ao banco e solicitar a substituição imediata da cédula manchada.</segment>
    <segment id="25">Os bancos têm os registros de saques efetuados</segment>
    <segment id="26">, inclusive nos caixas eletrônicos.</segment>
    <segment id="27">É preciso fazer boletim de ocorrência na polícia para realizar a troca de notas manchadas retiradas em caixas eletrônicos?</segment>
    <segment id="28">Não.</segment>
    <segment id="29">As regras determinam apenas que o cidadão deve procurar o banco</segment>
    <segment id="30">, o qual é obrigado a trocar o dinheiro manchado imediatamente.</segment>
    <segment id="31">Se receber</segment>
    <segment id="32">, sem perceber</segment>
    <segment id="33">, uma nota manchada de rosa em outras circunstâncias</segment>
    <segment id="34">, o que fazer?</segment>
    <segment id="35">Se receber em outras circunstâncias</segment>
    <segment id="36">, como</segment>
    <segment id="37">como no comércio</segment>
    <segment id="38">, deve entregar a cédula em uma agência bancária.</segment>
    <segment id="39">O banco anotará seus dados (nome</segment>
    <segment id="40">, endereço</segment>
    <segment id="41">, CPF ou CNPJ no</segment>
    <segment id="42">casocaso de ser empresa) e enviará a nota para análise no BC.</segment>
    <segment id="43">Se ficar comprovado que a mancha não foi provocada por mecanismo antifurto</segment>
    <segment id="44">, a pessoa será ressarcida pelo banco.</segment>
    <segment id="45">Caso a mancha seja desse tipo de dispositivo</segment>
    <segment id="46">, não haverá reembolso.</segment>
    <segment id="47">Em caso</segment>
    <segment id="48">caso de dúvidas</segment>
    <segment id="49">, consulte o site do BC (www.bcb.gov.br) ou ligue para 0800 979 2345.
FONTE: Banco Central</segment>
  </rst>
</analysis>