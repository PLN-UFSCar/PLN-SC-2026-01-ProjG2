  <rst>
    <segment id="1">Explosão do bumbum</segment>
    <segment id="2">O ensaio de Rosana Ferreira está dando o que falar</segment>
    <segment id="3">O ensaio de Rosana Ferreira</segment>
    <segment id="4">, eleita Miss Bumbum 2011 pela revista “Sexy” está dando o que falar.</segment>
    <segment id="5">Em apenas 11 dias</segment>
    <segment id="6">, a primeira tiragem da edição de janeiro</segment>
    <segment id="7">, de 50 mil exemplares</segment>
    <segment id="8">, esgotou.</segment>
    <segment id="9">A dona da poupança nota 10</segment>
    <segment id="10">, que é do Espírito Santo</segment>
    <segment id="11">, masmas ganhou o título representando o Ceará</segment>
    <segment id="12">, recebe</segment>
    <segment id="13">, no próximo sábado</segment>
    <segment id="14">, a faixa de musa da ala dos compositores da escola de samba paulistana X-9.</segment>
    <segment id="15">Resta saber</segment>
    <segment id="16">sese a revista vai colocar mais exemplares nas bancas de todo o Brasil.</segment>
    <segment id="17">Retorno mais que certo!</segment>
