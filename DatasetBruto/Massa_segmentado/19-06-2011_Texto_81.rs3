  <rst>
    <segment id="1">Fim de linha para larápios das sinaleira</segment>
    <segment id="2">Policiais civis capturam dois homens acusados de assaltar motoristas em vários bairro
Engarrafamentos</segment>
    <segment id="3">, mulheres ao volante e objetos de valor expostos nos bancos dos carros.</segment>
    <segment id="4">Esse, segundo a polícia</segment>
    <segment id="5">, é o  cenário preferido por um  bando de criminosos da Santa Cruz e do Boqueirão</segment>
    <segment id="6">, no Nordeste de Amaralina</segment>
    <segment id="7">,  para praticar o crime de roubo</segment>
    <segment id="8">, nas imediações do Parque da Cidade</segment>
    <segment id="9">, no Itaigara</segment>
    <segment id="10">, e na Avenida Manoel Dias da Silva</segment>
    <segment id="11">, na Pituba.</segment>
    <segment id="12">Na tarde de ontem</segment>
    <segment id="13">, Vandilson Costa Araújo</segment>
    <segment id="14">, 29 anos</segment>
    <segment id="15">,   suspeito de  praticar esse mesmo crime</segment>
    <segment id="16">, foi apresentado à imprensa</segment>
    <segment id="17">, na sede da Delegacia da Pituba.</segment>
    <segment id="18">Vandilson atuava na Avenida Manoel Dias da Silva</segment>
    <segment id="19">, na Pituba</segment>
    <segment id="20">, onde</segment>
    <segment id="21">sese fazia passar por guardador de carros.</segment>
    <segment id="22">No último dia 13</segment>
    <segment id="23">, investigadores da unidade policial também prenderam  Marcos Vinícius Pereira dos Santos</segment>
    <segment id="24">, 23, o Secão</segment>
    <segment id="25">, com 56 pedras de crack.</segment>
    <segment id="26">Segundo o delegado Nilton Tormes</segment>
    <segment id="27">, titular da Delegacia da Pituba</segment>
    <segment id="28">,  Secão também praticava essa modalidade de roubo e ainda aliciava adolescentes para a prática desse crime.</segment>
    <segment id="29">“Descem cerca de 10 adolescentes e observam o interior dos veículos.</segment>
    <segment id="30">Eles esperam os policiais militares saírem para agir.</segment>
    <segment id="31">Arrombam os vidros dos veículos com pedras ou velas de carro e depois voltam para o Nordeste</segment>
    <segment id="32">, onde estão os receptores dos produtos roubados”</segment>
    <segment id="33">, explica Nilton Tormes.</segment>
    <segment id="34">De acordo com ele</segment>
    <segment id="35">, os receptores são traficantes de drogas da área.</segment>
    <segment id="36">O bando usa o Parque da Cidade</segment>
    <segment id="37">comocomo abrigo e rota de fuga.
Se diz inocente</segment>
    <segment id="38">Vandilson foi preso</segment>
    <segment id="39">, no último dia 8</segment>
    <segment id="40">, por policiais militares</segment>
    <segment id="41">, ocasião em que  foi detido com duas bermudas e uma camisa.</segment>
    <segment id="42">Ele foi indiciado por furto qualificado.</segment>
    <segment id="43">“Botaram</segment>
    <segment id="44">a roupa na minha mão”</segment>
    <segment id="45">, disse o rapaz.</segment>
    <segment id="46">Ele tem passagem criminal pelas delegacias do Rio Vermelho e Pituba</segment>
    <segment id="47">, além da Deltur e Deam.</segment>
    <segment id="48">“É importante que as pessoas vítimas da ação deles informem à polícia”</segment>
    <segment id="49">, afirmou o delegado titular da Pituba.</segment>
    <segment id="50">Morava na rua
Secão é da Santa Cruz</segment>
    <segment id="51">, masmas morava na rua e costumava ficar perto do Pituba Parque Center</segment>
    <segment id="52">, no Itaigara.</segment>
    <segment id="53">Segundo o delegado</segment>
    <segment id="54">, ele confessou os crimes.</segment>
    <segment id="55">O delegado afirma que Secão foi reconhecido pela irmã de uma delegada e por uma professora universitária</segment>
    <segment id="56">comocomo o autor do roubo aos carros das duas.</segment>
  </rst>
</analysis>