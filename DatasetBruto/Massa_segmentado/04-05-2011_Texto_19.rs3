  <rst>
    <segment id="1">Vasco empata com Atlético-PR pelas quartas da Copa do Brasil

RIO - O Vasco empatou com o Atlético-PR em 2 a 2 na Arena da Baixada</segment>
    <segment id="2">, em Curitiba</segment>
    <segment id="3">, pelas quartas de final da Copa do Brasil.</segment>
    <segment id="4">Os gols foram marcados por Alecsandro e Diego Souza</segment>
    <segment id="5">, para o Vasco</segment>
    <segment id="6">, e Guerrón e Paulo Baier</segment>
    <segment id="7">, para o Atlético.</segment>
    <segment id="8">O Vasco vencia quando os donos da casa empataram aos 41 minutos do segundo tempo</segment>
    <segment id="9">, após pênalti de Ramon em Branquinho.</segment>
    <segment id="10">O jogo da volta será na quinta-feira</segment>
    <segment id="11">, 12, em São Januário</segment>
