  <rst>
    <segment id="1">Fernanda Vasconcellos</segment>
    <segment id="2">Atriz gosta de fazer sexo no 1º encontro</segment>
    <segment id="3">Fernanda Vasconcellos pensa diferente de muitas mulheres que diriam não ao homem que quisesse transar no primeiro encontro.</segment>
    <segment id="4">Segundo ela</segment>
    <segment id="5">, “com consciência e segurança</segment>
    <segment id="6">, é uma delícia”.</segment>
    <segment id="7">A moça</segment>
    <segment id="8">, que está na novela “</segment>
    <segment id="9">A vida da gente”</segment>
    <segment id="10">, declarou ainda</segment>
    <segment id="11">, em entrevista</segment>
    <segment id="12">, que foi ela que tomou a iniciativa de beijar o namorado</segment>
    <segment id="13">, o também ator Henri Castelli: “Agarrei mesmo”.</segment>
  </rst>
