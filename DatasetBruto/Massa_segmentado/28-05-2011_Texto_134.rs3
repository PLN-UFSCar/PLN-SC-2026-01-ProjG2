  <rst>
    <segment id="1">Botafogo derrota reservas do Santos por 1 a 0 no Engenhão

RIO - O Botafogo fez o mínimo necessário para ganhar os três pontos em cima do time reserva do Santos</segment>
    <segment id="2">, no Engenhão</segment>
    <segment id="3">, diante de 8.662 torcedores (6.222 pagantes).</segment>
    <segment id="4">Num jogo lento e tecnicamente fraco</segment>
    <segment id="5">, a equipe comandada pelo técnico Caio Jr venceu por 1 a 0</segment>
    <segment id="6">, gol do zagueiro Fábio Ferreira.</segment>
    <segment id="7">O alvinegro carioca tinha estreado com derrota para o Palmeiras fora de casa no Campeonato Brasileiro</segment>
    <segment id="8">, na semana passada</segment>
    <segment id="9">, e se</segment>
    <segment id="10">se recuperou na tabela.</segment>
    <segment id="11">Já o Peixe</segment>
    <segment id="12">, de Muricy Ramalho</segment>
    <segment id="13">, que põe suas atenções na semifinal da Copa Libertadores</segment>
    <segment id="14">, segue com apenas um ponto na classificação (empatou com o Internacional na Vila</segment>
    <segment id="15">Belmiro na primeira rodada).</segment>
    <segment id="16">O gol do jogo saiu no primeiro tempo</segment>
    <segment id="17">, aos 36 minutos.</segment>
    <segment id="18">O zagueiro Fábio Ferreira emendou de primeira após desvio de cabeça no primeiro pau</segment>
    <segment id="19">, em cobrança de escanteio pela esquerda.</segment>
    <segment id="20">A rigor foi o único momento interessante do time carioca na etapa inicial.</segment>
    <segment id="21">Quem teve boas oportunidades foi o Santos.</segment>
    <segment id="22">Aos 12</segment>
    <segment id="23">, Keirrison</segment>
    <segment id="24">, livre na área</segment>
    <segment id="25">, perdeu gol diante de Jeferson.</segment>
    <segment id="26">E aos 17</segment>
    <segment id="27">, o zagueiro Bruno Aguiar</segment>
    <segment id="28">, também sem marcação</segment>
    <segment id="29">, cabeceou com perigo na pequena área.
LANCE</segment>
    <segment id="30">A LANCE:</segment>
    <segment id="31">Como foi no tempo real 
TORCEDOR: Blog:</segment>
    <segment id="32">O blog É Por Ti</segment>
    <segment id="33">, Fogo</segment>
    <segment id="34">No segundo tempo o jogo</segment>
    <segment id="35">sese arrastou.</segment>
    <segment id="36">Muricy tirou Alan Patrick e Thiago Alves e colocou em seus lugares o garoto Rychely e Maikon Leite.</segment>
    <segment id="37">O time santista melhorou</segment>
    <segment id="38">, masmas sem ser perigoso.</segment>
    <segment id="39">Já o Botafogo</segment>
    <segment id="40">sese animou mais quando o menino Cidinho substituiu Éverton.</segment>
    <segment id="41">Cidinho chegou a ter boa oportunidade aos 29 minutos</segment>
    <segment id="42">, masmas jogou por cima a bola cruzada por Cortês da esquerda.</segment>
    <segment id="43">Elkeson</segment>
    <segment id="44">, que estreou no meio de campo do Botafogo</segment>
    <segment id="45">, teve atuação razoável.</segment>
    <segment id="46">E mostrou que pode ser bastante útil ao esquema de Caio Jr no futuro</segment>
    <segment id="47">, quando estiver mais entrosado.</segment>
    <segment id="48">Ele deixou o campo aos 32 minutos do segundo tempo</segment>
    <segment id="49">, substituído por Thiago Galhardo.</segment>
    <segment id="50">Aos 46</segment>
    <segment id="51">, Maikon Leite quase empatou o jogo</segment>
    <segment id="52">, numa cochilada da zaga do Botafogo.</segment>
    <segment id="53">Ele bateu cruzado</segment>
    <segment id="54">, para fora</segment>
    <segment id="55">, e assustou o goleiro Jeferson.</segment>
    <segment id="56">Logo depois o árbitro Éber Roberto Lopes encerrou a partida.</segment>
    <segment id="57">BOTAFOGO 1</segment>
    <segment id="58">X 0 SANTOS
Estádio: Engenhão</segment>
    <segment id="59">, Rio de Janeiro (RJ)
Data/hora: 28/5/2011 - 18h30 (de Brasília)
Árbitro: Heber Roberto Lopes (Fifa-PR)
Auxiliares: Roberto Braatz (Fifa-PR) e Alessandro Rocha de Matos (Fifa-BA)
Renda/público: R$ 143.110</segment>
    <segment id="60">,00 / 6.222 pagantes / 8.662 presentes</segment>
