  <rst>
    <segment id="1">Histórico de furtos no Pedala Rio</segment>
    <segment id="2">O sistema de aluguel do Rio foi alvo de furtos desde o início de suas operações.
.</segment>
    <segment id="3">Em dezembro de 2009</segment>
    <segment id="4">, com menos de um ano de funcionamento (o projeto começou em janeiro de 2009)</segment>
    <segment id="5">, a concessionária Serttel chegou a suspender o serviço por três meses</segment>
    <segment id="6">porque</segment>
    <segment id="7">porque 56 bicicletas (do total de 100</segment>
    <segment id="8">, na época) haviam sido roubadas em 15 dias.</segment>
    <segment id="9">A polícia recuperou</segment>
    <segment id="10">, dias depois</segment>
    <segment id="11">, 28 bicicletas em uma operação nas favelas Mandela e de Manguinhos</segment>
    <segment id="12">, na Zona Norte do Rio.</segment>
    <segment id="13">Antes de voltar a operar</segment>
    <segment id="14">, a concessionária informou que reforçou as travas de segurança e mudou a cor dos veículos para facilitar a identificação</segment>
    <segment id="15">, masmas as medidas não adiantaram muito.</segment>
    <segment id="16">Após o retorno do serviço com um reforço no número de bicicletas</segment>
    <segment id="17">, para um total de 150</segment>
    <segment id="18">, em março de 2010</segment>
    <segment id="19">, os furtos voltaram a ocorrer.</segment>
    <segment id="20">Em dois meses</segment>
    <segment id="21">, mais 17 bicicletas tinham sido roubadas.</segment>
    <segment id="22">A partir daí</segment>
    <segment id="23">, o número de veículos disponíveis nas estações de aluguel ficou cada vez menor até o serviço ser interrompido para a reestruturação em julho deste ano.</segment>
    <segment id="24">O problema de furtos não é exclusivo do projeto carioca.</segment>
    <segment id="25">O Vélib</segment>
    <segment id="26">, sistema de aluguel de bicicletas de Paris</segment>
    <segment id="27">, que inspirou a iniciativa no Rio e em diversas cidades do mundo</segment>
    <segment id="28">, também enfrentou a ação de ladrões.</segment>
    <segment id="29">Criado em 2007</segment>
    <segment id="30">, o Vélib chegou a ter 80% das 20 mil bicicletas iniciais roubadas ou danificadas em dois anos de operações.</segment>
    <segment id="31">Mas isso não impediu o sucesso do serviço</segment>
    <segment id="32">, que funciona com grande utilização por turistas e parisienses.</segment>
  </rst>
</analysis>