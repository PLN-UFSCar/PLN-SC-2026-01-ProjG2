  <rst>
    <segment id="1">SUSpenso: e o povo é quem sofre
Fila para atendimento no posto do SUS de Pernambués</segment>
    <segment id="2">Até a próxima semana</segment>
    <segment id="3">,  as clínicas de saúde que prestam serviço ao  Sistema Único de Saúde (SUS) não irão atender os pacientes.</segment>
    <segment id="4">As cerca de 300 entidades privadas não filantrópicas</segment>
    <segment id="5">, prestadoras de serviço ao SUS</segment>
    <segment id="6">,   paralisaram as atividades desde ontem e ficarão assim até o dia 31.</segment>
    <segment id="7">Mais de 40 mil atendimentos diários não serão realizados.</segment>
    <segment id="8">As entidades privadas</segment>
    <segment id="9">, para as quais foi terceirizada a prestação deste serviço elementar</segment>
    <segment id="10">, principalmente na área de traumatologia</segment>
    <segment id="11">, alegam que a ação é por conta do corte de 25% do teto do SUS em 2007</segment>
    <segment id="12">, quando  houve a municipalização da gestão básica.</segment>
    <segment id="13">Além disso</segment>
    <segment id="14">, também é contestado o corte de 20% no repasse de abril deste ano.</segment>
    <segment id="15">“</segment>
    <segment id="16">A suspensão do atendimento é por ordem da própria prefeitura.</segment>
    <segment id="17">A pedido do secretário Gilberto José (Saúde)</segment>
    <segment id="18">, estamos atendendo o correspondente da cota que está sendo paga”</segment>
    <segment id="19">, disse o presidente da Associação de Hospitais e Serviço de Saúde do Estado da Bahia (Ahseb)</segment>
    <segment id="20">, Marcelo Britto.</segment>
    <segment id="21">A prefeitura nega.</segment>
    <segment id="22">“</segment>
    <segment id="23">Não existe dívida com nenhuma instituição na parte da contratualização.</segment>
    <segment id="24">Elas (as entidades prestadoras) estão recebendo 100% do teto que foi oferecido”</segment>
    <segment id="25">, disse o secretário de Saúde</segment>
    <segment id="26">, Gilberto José.</segment>
    <segment id="27">A maior parte da demanda atendida pelas prestadoras são na área de traumatologia</segment>
    <segment id="28">, um serviço de urgência.</segment>
    <segment id="29">“Vamos acionar a procuradoria para saber quais providências tomar”</segment>
    <segment id="30">, disse.</segment>
    <segment id="31">Sofrimento danado</segment>
    <segment id="32">O motoboy Diego Barbosa</segment>
    <segment id="33">, 24 anos</segment>
    <segment id="34">, sofreu um acidente de moto no dia 8</segment>
    <segment id="35">, quando teve uma das pernas amputadas e diversas fraturas.</segment>
    <segment id="36">Sentindo muita dor</segment>
    <segment id="37">, ele e a mãe procuraram ontem atendimento na clínica CATO</segment>
    <segment id="38">, na Barra</segment>
    <segment id="39">, onde ele passaria por revisão pós-cirúrgica.</segment>
    <segment id="40">Sofrimento:</segment>
    <segment id="41">Diego</segment>
    <segment id="42">Barbosa não foi atendido no CATO da Barra



“Como obter uma receita?</segment>
    <segment id="43">Os medicamentos são controlados e ele não dormiu de tanta dor.</segment>
    <segment id="44">Não sei o que fazer</segment>
    <segment id="45">, não tenho condições financeiras para pagar a particular”</segment>
    <segment id="46">, disse.</segment>
    <segment id="47">Na Isbot</segment>
    <segment id="48">, da Barra</segment>
    <segment id="49">, o lixeiro Luiz Carvalho</segment>
    <segment id="50">, 60, não foi atendido e teve de recorrer ontem a outro centro de saúde pública.</segment>
  </rst>
</analysis>