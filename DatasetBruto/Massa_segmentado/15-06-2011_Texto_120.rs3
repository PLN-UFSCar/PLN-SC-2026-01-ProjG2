  <rst>
    <segment id="1">Soltura de ‘espadas’ rendeu prisões</segment>
    <segment id="2">A proibição visa reduzir o número de vítimas de queimaduras</segment>
    <segment id="3">Cinco pessoas foram presas</segment>
    <segment id="4">, na noite de sábado</segment>
    <segment id="5">, véspera de São João</segment>
    <segment id="6">, em Cruz das Almas</segment>
    <segment id="7">, a 146 km de Salvador</segment>
    <segment id="8">, após soltar “espadas”.</segment>
    <segment id="9">A Santa Casa de Misericórdia do município não registrou nenhum</segment>
    <segment id="10">casocaso de queimaduras provocados por conta da soltura das espadas</segment>
    <segment id="11">, que foi proibida pela Justiça.</segment>
    <segment id="12">O Ministério Público do Estado da Bahia expediu</segment>
    <segment id="13">, no último dia 14</segment>
    <segment id="14">, uma recomendação</segment>
    <segment id="15">para que</segment>
    <segment id="16">para que as polícias Civil e Militar apreendessem “espadas” e todos os artefatos incendiários em Cruz das Almas.</segment>
    <segment id="17">A proibição visa reduzir o número de vítimas de queimaduras.</segment>
    <segment id="18">Segundo a Santa Casa de Misericórdia</segment>
    <segment id="19">, em 2010</segment>
    <segment id="20">, quando não havia a proibição</segment>
    <segment id="21">, 315 pessoas ficaram feridas durante os festejos juninos na cidade.</segment>
  </rst>
</analysis>