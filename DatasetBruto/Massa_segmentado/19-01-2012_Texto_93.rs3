  <rst>
    <segment id="1">Acidente com navio lembra o Titanic
Acidente com navio lembra o Titanic</segment>
    <segment id="2">A notícia do naufrágio do Cruzeiro   Costa Concordia</segment>
    <segment id="3">,  ocorrido na última sexta feira</segment>
    <segment id="4">, (13) na Itália</segment>
    <segment id="5">,   fez o empresário Dumas Marchi  lembrar dos  sete dias que passou a bordo da embarcação  numa viagem que acabou há apenas três semanas.</segment>
    <segment id="6">Como se</segment>
    <segment id="7">se fosse uma premonição</segment>
    <segment id="8">, Dumas  disse que  durante a sua estadia  no Costa Concórdia</segment>
    <segment id="9">, ele ouviu uma senhora perguntar ao comandante</segment>
    <segment id="10">sese era seguro fazer a viagem</segment>
    <segment id="11">,  já que ela temia  acontecer o mesmo que ocorreu com o Titanic.</segment>
    <segment id="12">“</segment>
    <segment id="13">O  comandante Francesco Schettino disse que era impossível</segment>
    <segment id="14">, que jamais aconteceria coisa igual”.</segment>
    <segment id="15">O empresário ainda faz questão de ressaltar a imagem que teve a respeito do  comandante.</segment>
    <segment id="16">“Ele me pareceu arrogante</segment>
    <segment id="17">, prepotente</segment>
    <segment id="18">, não era nada cativante.</segment>
    <segment id="19">A maneira</segment>
    <segment id="20">comocomo</segment>
    <segment id="21">sese comportava era</segment>
    <segment id="22">comocomo</segment>
    <segment id="23">sese fosse um deus”</segment>
    <segment id="24">, retrata Dumas.</segment>
    <segment id="25">Acostumado a fazer viagens de navio</segment>
    <segment id="26">, ele  afirmou  que o acidente foi uma grande surpresa</segment>
    <segment id="27">, já que o cruzeiro é um dos mais modernos do momento.</segment>
    <segment id="28">“</segment>
    <segment id="29">Acidentes acontecem em todos os meios de transportes</segment>
    <segment id="30">, masmas a embarcação era muito segura</segment>
    <segment id="31">, por isso desconfiei desde o início que</segment>
    <segment id="32">sese tratava de falha humana”</segment>
    <segment id="33">, diz o empresário.</segment>
    <segment id="34">Além de ser considerado  um erro humano</segment>
    <segment id="35">,  uma vez que  o capitão realizou uma manobra equivocada</segment>
    <segment id="36">, as autoridades  italianas  solicitaram  a prisão   do capitão</segment>
    <segment id="37">,  responsabilizando-o  pelos crimes de homicídio múltiplo</segment>
    <segment id="38">, abandono do navio e naufrágio</segment>
    <segment id="39">, que podem lhe render até 15 anos de prisão</segment>
    <segment id="40">casocaso seja condenado.</segment>
    <segment id="41">Todos sobreviveram</segment>
    <segment id="42">O naufrágio ocorreu na última sexta feira</segment>
    <segment id="43">, masmas até ontem pela manhã</segment>
    <segment id="44">, ainda havia 24 pessoas desaparecidas.</segment>
    <segment id="45">Estavam a bordo 4.200 pessoas.

57 brasileiros estavam a bordo e todos saíram com vida e já estão retornando para os seus estados de origem.</segment>
    <segment id="46">Destes</segment>
    <segment id="47">, 51 eram passageiros e 6 trabalhavam na embarcação.</segment>
    <segment id="48">Já foram resgatados 11 corpos.</segment>
    <segment id="49">Estavam a bordo 4.200 pessoas.</segment>
    <segment id="50">Ainda existe o risco de um acidente ambiental</segment>
    <segment id="51">casocaso tenha vazamento de  óleo.</segment>
    <segment id="52">O navio contém 15 depósitos com capacidade para 2.380 toneladas de combustível.</segment>
    <segment id="53">No navio existem   1.500 cabines e  4.800 lugares.</segment>
    <segment id="54">Cruzeiros à vista</segment>
    <segment id="55">Apesar da tragédia</segment>
    <segment id="56">,  a aposentada Lígia Ferreira Barreto</segment>
    <segment id="57">, 84 anos</segment>
    <segment id="58">, que já realizou alguns cruzeiros</segment>
    <segment id="59">, não mudou seu pensamento.</segment>
    <segment id="60">“Lamento muito o que aconteceu.</segment>
    <segment id="61">Uma vez</segment>
    <segment id="62">, quando eu estava em um cruzeiro passando pela Escandinava</segment>
    <segment id="63">, uma onda enorme quase virou o navio.</segment>
    <segment id="64">Mas, nem isso me fez desistir de viajar outras vezes.</segment>
    <segment id="65">Temos que nos preocupar com nossa segurança</segment>
    <segment id="66">, masmas este fato</segment>
    <segment id="67">, é destino”</segment>
    <segment id="68">, disse.</segment>
    <segment id="69">Para Pedro Calvão</segment>
    <segment id="70">, Presidente da Associação Brasileira de Agências de Viagens</segment>
    <segment id="71">, Abav-Bahia- este terrível episódio</segment>
    <segment id="72">, deve provocar impacto imediato nas pessoas</segment>
    <segment id="73">, masmas nada que faça o setor desaquecer.</segment>
    <segment id="74">“Ainda não tivemos notícia de nenhum passageiro que tenha desistido de realizar seu passeio por razão deste naufrágio.</segment>
    <segment id="75">A temporada brasileira de cruzeiros vai de novembro a abril</segment>
    <segment id="76">, os pacotes já foram vendidos.</segment>
    <segment id="77">Este fato serve  para mostrar que temos que respeitar os  itens de segurança”.</segment>
  </rst>
</analysis>