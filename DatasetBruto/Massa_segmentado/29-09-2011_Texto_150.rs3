  <rst>
    <segment id="1">Caruru com crack</segment>
    <segment id="2">, cocaína e maconha
Festa de aniversário acabou com nove presos</segment>
    <segment id="3">, dois feridos e dois mortos em tiroteio</segment>
    <segment id="4">O dia era de São Cosme e São Damião</segment>
    <segment id="5">, masmas quem deu caruru festejando o aniversário de 26 anos foi Emerson Cosme Anjos dos Santos</segment>
    <segment id="6">,  o “Miminho”.</segment>
    <segment id="7">Até aí tudo bem</segment>
    <segment id="8">, masmas além das comidas típicas</segment>
    <segment id="9">, foram servidos crack</segment>
    <segment id="10">, cocaína e maconha.</segment>
    <segment id="11">Segundo informações da 23ª DT (Lauro de Freitas)</segment>
    <segment id="12">, depois de denúncia anônima de que havia uma festa com drogas</segment>
    <segment id="13">, a polícia  deslocou  na madrugada de ontem quatro guarnições da  Rondesp  até a Vila Praiana</segment>
    <segment id="14">,  em Lauro de Freitas. 

“</segment>
    <segment id="15">Quando chegamos</segment>
    <segment id="16">, fomos recebidos a tiros e alvejamos quatro</segment>
    <segment id="17">, dentre eles</segment>
    <segment id="18">, o chefe do tráfico na região</segment>
    <segment id="19">, o “Mão”- acusado de envolvimento no assassinato da dançarina Kelly Cyclone -</segment>
    <segment id="20">, que fugiu com dois comparsas.</segment>
    <segment id="21">Um suspeito não resistiu aos ferimentos e morreu.</segment>
    <segment id="22">Prendemos nove homens e apreendemos um menor</segment>
    <segment id="23">, que foi solto”</segment>
    <segment id="24">, disse Joelson dos Santos Reis</segment>
    <segment id="25">, delegado titular</segment>
    <segment id="26">, revelando que  Antenor Costa Júnior</segment>
    <segment id="27">, 24 (que estava na festa)</segment>
    <segment id="28">, foi morto em outra diligência</segment>
    <segment id="29">, no mesmo local</segment>
    <segment id="30">,  pela manhã.</segment>
    <segment id="31">Dentre os presos há cinco irmãos.</segment>
    <segment id="32">Emerson</segment>
    <segment id="33">, 26; Eliosmar</segment>
    <segment id="34">, 31; Erivelton</segment>
    <segment id="35">, 19; Ericson</segment>
    <segment id="36">, 28;  e Elmo</segment>
    <segment id="37">, 24 todos com o mesmo sobrenome</segment>
    <segment id="38">, Anjos dos Santos.</segment>
    <segment id="39">Além deles</segment>
    <segment id="40">, Edvaldo Pereira  Jr.</segment>
    <segment id="41">, 35; André Conceição</segment>
    <segment id="42">, 27; Robson Costa</segment>
    <segment id="43">, 38; e Plínio Diego Reis</segment>
    <segment id="44">, 23 foram capturados.</segment>
    <segment id="45">Na operação foram encontrados 74 pedras de crack</segment>
    <segment id="46">, 20 papelotes e  31 ampolas plásticas com cocaína</segment>
    <segment id="47">, um pouco de  maconha</segment>
    <segment id="48">,  11 celulares</segment>
    <segment id="49">,  notebooks e 2 revólveres.</segment>
    <segment id="50">Kelly Cyclone</segment>
    <segment id="51">Apesar de os policiais não terem relacionado a festa com o assassinato de Kelly Cyclone</segment>
    <segment id="52">, eles chegaram até os suspeitos através de denúncia anônima</segment>
    <segment id="53">, pela qual foram avisados que os supostos assassinos da dançarina estavam no local.</segment>
    <segment id="54">Dentre os fugitivos</segment>
    <segment id="55">, que segundo a polícia foram feridos</segment>
    <segment id="56">, estão os traficantes Mão - suposto ex-namorado de Kelly - e  Neguinho</segment>
    <segment id="57">, também suspeito de participar da morte da jovem</segment>
    <segment id="58">, em 17 de julho último.</segment>
    <segment id="59">A operação envolveu as polícias Civil e Militar e foi conduzida pelo delegado Joelson</segment>
    <segment id="60">; pelo comandante da 52ª Companhia Independente da Polícia Militar (CIPM)</segment>
    <segment id="61">, major Izidro</segment>
    <segment id="62">; pelo comandante das Rondas Especiais da Região Metropolitana de Salvador (Rondesp/RMS)</segment>
    <segment id="63">, major Sérgio Freitas</segment>
    <segment id="64">; e pelo  coronel Everaldo Mendes da Silva</segment>
    <segment id="65">, comandante do Policiamento da Região Norte.</segment>
    <segment id="66">Juízes</segment>
    <segment id="67">, policiais e vereadores:</segment>
    <segment id="68">Advogada não viu drogas na festa</segment>
    <segment id="69">A advogada dos nove detidos</segment>
    <segment id="70">, Lúcia Arouca</segment>
    <segment id="71">, afirmou  que não havia drogas no caruru.</segment>
    <segment id="72">“</segment>
    <segment id="73">Esta festa acontece há muitos anos</segment>
    <segment id="74">, Eu mesma estava lá e não vi cocaína nenhuma.</segment>
    <segment id="75">Lá tinha magistrados</segment>
    <segment id="76">, vereadores</segment>
    <segment id="77">, policiais</segment>
    <segment id="78">, várias pessoas de bem.</segment>
    <segment id="79">Muitos desses meninos que estão aí presos eram apenas convidados e não têm culpa de nada.</segment>
    <segment id="80">Vamos esperar as investigações”</segment>
    <segment id="81">, afirmou Lúcia</segment>
    <segment id="82">, sem querer revelar os nomes das autoridades presentes ao evento.</segment>
  </rst>
</analysis>