  <rst>
    <segment id="1">Delegada atropela rapaz e foge</segment>
    <segment id="2">A policial não prestou socorro.</segment>
    <segment id="3">Mototaxista teve traumatismo craniano</segment>
    <segment id="4">O mototaxista Carlito Bispo dos Santos</segment>
    <segment id="5">, 36 anos</segment>
    <segment id="6">, foi atropelado na noite de anteontem por uma picape Hilux SW4</segment>
    <segment id="7">, na BR-367</segment>
    <segment id="8">, em Porto Seguro</segment>
    <segment id="9">, a 709 km de Salvador.</segment>
    <segment id="10">A Hilux</segment>
    <segment id="11">, de placa NQR 2121</segment>
    <segment id="12">, de Fortaleza</segment>
    <segment id="13">, estava sendo conduzida pela delegada titular da cidade</segment>
    <segment id="14">, Eliana Teles Barbosa</segment>
    <segment id="15">, que deverá responder por lesão corporal culposa na direção de veículo</segment>
    <segment id="16">, caso</segment>
    <segment id="17">caso a vítima sobreviva.</segment>
    <segment id="18">Ela não foi localizada para dar sua versão.</segment>
    <segment id="19">Segundo familiares do mototaxista</segment>
    <segment id="20">, ele está com traumatismo craniano e ferimentos em outras partes do corpo.</segment>
    <segment id="21">Ele teve que passar por uma cirurgia de emergência.</segment>
    <segment id="22">Na ocorrência da Polícia Rodoviária Federal (PRF) não consta nome da delegada</segment>
    <segment id="23">, masmas sim que o condutor fugiu.</segment>
    <segment id="24">A informação de que ela dirigia a Hilux é do delegado Evy Paternostro</segment>
    <segment id="25">, coordenador da 23ª Coordenadoria de Polícia do Interior</segment>
    <segment id="26">, com sede em Eunápolis.</segment>
    <segment id="27">“Ela me disse que estava saindo da delegacia e não teve</segment>
    <segment id="28">comocomo evitar o choque”.</segment>
    <segment id="29">Segundo ele</segment>
    <segment id="30">, a delegada não ficou no local do acidente</segment>
    <segment id="31">porque</segment>
    <segment id="32">porque teve de ser medicada</segment>
    <segment id="33">, devido a uma  forte queda de pressão arterial.</segment>
    <segment id="34">Ele negou ainda que Eliana Teles estaria bêbada</segment>
    <segment id="35">, conforme dizem familiares da vítima.</segment>
    <segment id="36">Testemunhas disseram que a delegada estava em companhia do deputado estadual Deraldo Damasceno (PSL)</segment>
    <segment id="37">, que atuou</segment>
    <segment id="38">comocomo delegado de Porto Seguro e Eunápolis.</segment>
    <segment id="39">Porém, a informação não foi confirmada.</segment>
    <segment id="40">Parentes revoltados</segment>
    <segment id="41">A mulher de Carlito</segment>
    <segment id="42">, Alexsandra Pires Vieira</segment>
    <segment id="43">, 28, e a mãe dele</segment>
    <segment id="44">, Marinalva Santana Bispo</segment>
    <segment id="45">, 59, estão indignadas.</segment>
    <segment id="46">“Foi muita imprudência da motorista”</segment>
    <segment id="47">, declarou Marinalva</segment>
    <segment id="48">, para quem houve “cobertura de policiais civis na fuga da delegada Eliana”.</segment>
    <segment id="49">A afirmação dela é com base no que diz ter ouvido de outras pessoas.</segment>
    <segment id="50">“Ela acabou com a vida do meu filho”</segment>
    <segment id="51">, falou a mãe da vítima</segment>
    <segment id="52">, referindo-</segment>
    <segment id="53">sese à delegada Eliana.</segment>
    <segment id="54">“Vamos à delegacia pedir providências”</segment>
    <segment id="55">, afirmou Alexsandra.</segment>
  </rst>
</analysis>