  <rst>
    <segment id="1">Professora dá a vida pelos filhos</segment>
    <segment id="2">Os enterros foram acompanhados por centenas de moradores da região
Três irmãos - duas meninas de 9 e 10 anos e um menino de seis anos - foram salvos pela própria mãe</segment>
    <segment id="3">, a professora de reforço escolar Lia Telma Alves Gomes Santana</segment>
    <segment id="4">, 48 anos</segment>
    <segment id="5">, na tragédia da Gameleira</segment>
    <segment id="6">, em Vera Cruz.</segment>
    <segment id="7">Lia morreu no sábado de manhã</segment>
    <segment id="8">, ao ser atropelada</segment>
    <segment id="9">, junto a pelo menos outras 20 pessoas</segment>
    <segment id="10">, por um caminhão desgovernado que invadiu uma festa para comemorar o Dia das Crianças.</segment>
    <segment id="11">“Ela estava do outro lado da rua quando viu o caminhão e correu.</segment>
    <segment id="12">Ficou de costas para ele e com as mãos foi mandando as crianças correrem”</segment>
    <segment id="13">, descreveu uma das primas de Lia</segment>
    <segment id="14">, Noemi Gomes</segment>
    <segment id="15">, 24.</segment>
    <segment id="16">“</segment>
    <segment id="17">Sem dúvidas foi uma heroína</segment>
    <segment id="18">, além dos filhos conseguiu salvar muitas outras crianças”.</segment>
    <segment id="19">Para a secretária Cláudia Gomes</segment>
    <segment id="20">, 46 anos</segment>
    <segment id="21">, uma das irmãs da professora</segment>
    <segment id="22">, é preciso apurar</segment>
    <segment id="23">sese há responsáveis pelo acidente.</segment>
    <segment id="24">“</segment>
    <segment id="25">Essa é a consequência de uma imprudência que precisa ser investigada”</segment>
    <segment id="26">, disse.</segment>
    <segment id="27">O pai da pequena Paula Piedade</segment>
    <segment id="28">, de 7 anos</segment>
    <segment id="29">, estava inconformado com a morte trágica da filha</segment>
    <segment id="30">Os corpos de Lia e mais três crianças foram enterrados ontem.</segment>
    <segment id="31">Além da professora</segment>
    <segment id="32">, Carlos Alberto Neves da Silva</segment>
    <segment id="33">, 14, Eric Kauan Santos</segment>
    <segment id="34">, 7, e Paula Piedade Santos da Silva</segment>
    <segment id="35">, 7,  foram sepultados no Cemitério do Marcelino.</segment>
    <segment id="36">“É muito triste</segment>
    <segment id="37">, pois</segment>
    <segment id="38">pois ela era a única filha do casal”</segment>
    <segment id="39">, lembra o auxiliar de almoxarifado Luciano Gonçalves</segment>
    <segment id="40">, 26, primo de Paula.</segment>
    <segment id="41">População em estado de choque</segment>
    <segment id="42">A festa era organizada há quatro anos pela empresa de materiais de construção Portal da Ilha</segment>
    <segment id="43">, na Rua Direta da Gameleira.</segment>
    <segment id="44">Pelo menos 50 pessoas aguardavam a distribuição de presentes quando foram atingidas.</segment>
    <segment id="45">“</segment>
    <segment id="46">Foi uma ação de bondade que virou uma tragédia.</segment>
    <segment id="47">Estamos em estado de choque”</segment>
    <segment id="48">, comentou o prefeito da cidade</segment>
    <segment id="49">, Antônio Magno</segment>
    <segment id="50">, que esteve nos sepultamentos.</segment>
    <segment id="51">Foi decretado luto oficial de três dias em Vera Cruz.</segment>
    <segment id="52">Erick Cauã Santos</segment>
    <segment id="53">, de 7 anos</segment>
    <segment id="54">, foi um dos enterrados ontem no Cemitério do Marcelino
 

Entenda o</segment>
    <segment id="55">casocaso</segment>
    <segment id="56">O motorista Carlos de Jesus Bahiense</segment>
    <segment id="57">, 29 anos</segment>
    <segment id="58">, havia deixado um caminhão Mercedes Benz (placa JOM 2695)</segment>
    <segment id="59">, carregado com 624 sacos de argamassa</segment>
    <segment id="60">, estacionado na rua da festa.</segment>
    <segment id="61">“Havia um toldo onde as crianças estavam e por isso  não tinha</segment>
    <segment id="62">comocomo ver o caminhão</segment>
    <segment id="63">sese aproximar”</segment>
    <segment id="64">, avaliou Alexsandra Cardoso</segment>
    <segment id="65">, tia de Eric Kauan</segment>
    <segment id="66">, um dos mortos na tragédia.</segment>
    <segment id="67">Em depoimento na Delegacia de Vera Cruz</segment>
    <segment id="68">, o motorista disse que o acidente aconteceu enquanto ele ia até a loja de materiais de construção pegar as chaves para deixar a carga.</segment>
    <segment id="69">Carlos de Jesus foi liberado.</segment>
  </rst>
</analysis>