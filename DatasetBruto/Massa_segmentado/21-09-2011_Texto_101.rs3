  <rst>
    <segment id="1">Mulher-ketchup</segment>
    <segment id="2">sese faz</segment>
    <segment id="3">de morta
Esposa ciumenta encomenda morte de rival</segment>
    <segment id="4">, masmas “criminoso” poupa a “vítima”</segment>
    <segment id="5">Um fato inusitado  ocorrido em Pindobaçu (a 398 km de Salvador)</segment>
    <segment id="6">, em junho deste ano</segment>
    <segment id="7">, veio à tona ontem  depois que fotos relacionadas ao</segment>
    <segment id="8">casocaso caíram na internet.</segment>
    <segment id="9">A dona de casa Maria Nilza Pereira Simões</segment>
    <segment id="10">, com ciúmes do marido</segment>
    <segment id="11">, encomendou a morte de Erenildes Aguiar Araújo</segment>
    <segment id="12">, a Lupita</segment>
    <segment id="13">, e pagou R$  1 mil ao “executor”</segment>
    <segment id="14">, o ex-presidiário Carlos Roberto de Jesus.</segment>
    <segment id="15">O que Maria Nilza  não desconfiava era de que os dois eram amigos de infância.</segment>
    <segment id="16">Juntos</segment>
    <segment id="17">,  “matador” e “vítima” resolveram aplicar um golpe na esposa irada e ficar com a grana.</segment>
    <segment id="18">Carlos e Erenildes compraram dois vidros de ketchup (molho à base de tomate) e montaram uma cena falsa de crime.</segment>
    <segment id="19">Depois de ter amordaçado Lupita</segment>
    <segment id="20">, Carlos colocou uma faca  embaixo do sovaco da falsa defunta</segment>
    <segment id="21">, que teve o corpo coberto com o molho de tomate.</segment>
    <segment id="22">A cena de mentirinha foi fotografada pelo criminoso de araque para ser mostrada à mandante do crime</segment>
    <segment id="23">, assegurando que a rival teria sido morta.</segment>
    <segment id="24">Mas, em cidade pequena</segment>
    <segment id="25">, é difícil sustentar armação.</segment>
    <segment id="26">Dois dias depois de ter apresentado a foto e recebido a grana pelo serviço</segment>
    <segment id="27">, Carlos e Lupita foram vistos juntos em uma festa e a mandante do crime ainda os encontrou em uma feira livre em Pindobaçu.</segment>
    <segment id="28">Bateu com a língua nos dentes na delegacia</segment>
    <segment id="29">Inconformada por ter sido enganada</segment>
    <segment id="30">, Maria Nilza procurou a polícia de Pindobaçu e prestou queixa</segment>
    <segment id="31">, dizendo que tinha sido assaltada por Carlos Roberto.</segment>
    <segment id="32">Mas, na tentativa de</segment>
    <segment id="33">sese livrar da acusação de ser assaltante</segment>
    <segment id="34">, ao comparecer à delegacia para prestar depoimento</segment>
    <segment id="35">, o “matador” abriu o bico para o delegado e disse que foi contratado por Maria Nilza para matar Erenildes</segment>
    <segment id="36">porque</segment>
    <segment id="37">porque ela estava com ciúmes do marido.</segment>
    <segment id="38">O agente decidiu</segment>
    <segment id="39">, então</segment>
    <segment id="40">, averiguar a denúncia apresentada por Carlos Roberto e os três envolvidos foram parar na delegacia.</segment>
    <segment id="41">Virou balaio de gato</segment>
    <segment id="42">De acordo com a polícia</segment>
    <segment id="43">, Maria Nilza foi detida quando prestava depoimento por comunicação falsa de crime</segment>
    <segment id="44">, masmas após ser ouvida  foi liberada.</segment>
    <segment id="45">Carlos responderá por apropriação indébita e Erenildes  responderá por apropriação indébita e coautoria.</segment>
  </rst>
</analysis>