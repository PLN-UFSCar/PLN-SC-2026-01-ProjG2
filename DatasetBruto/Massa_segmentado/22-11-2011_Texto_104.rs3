  <rst>
    <segment id="1">Bandido leva tiro no rosto em assalto
Moradores da Pituba ficaram assustados com o tiroteio na rua</segment>
    <segment id="2">Na noite de ontem</segment>
    <segment id="3">, três rapazes armados com revólveres assaltaram a padaria Paneville</segment>
    <segment id="4">,  na Alameda Pádua</segment>
    <segment id="5">, próximo ao Parque Júlio César</segment>
    <segment id="6">, na Pituba.</segment>
    <segment id="7">Um dos bandidos</segment>
    <segment id="8">, Marcos Vinícius Santos Silva</segment>
    <segment id="9">, 19 anos</segment>
    <segment id="10">, foi baleado acima da orelha direita e levado por policiais da 13ª Companhia Independente da Polícia Militar para o HGE.</segment>
    <segment id="11">Eles roubaram dinheiro e pertences de dois clientes e dos funcionários.</segment>
    <segment id="12">Segundo os policiais da 13ª</segment>
    <segment id="13">, o rapaz permaneceu consciente após levar o tiro.</segment>
    <segment id="14">Até o fechamento desta edição</segment>
    <segment id="15">, não se</segment>
    <segment id="16">se sabiam informações sobre quadro de saúde do ferido</segment>
    <segment id="17">, masmas o hospital confirmou que ele estava vivo.</segment>
    <segment id="18">Os outros dois comparsas fugiram em um Celta</segment>
    <segment id="19">, roubado na Alameda Gênova.</segment>
    <segment id="20">Agentes da 16ª Delegacia Territorial investigam o</segment>
    <segment id="21">casocaso.</segment>
    <segment id="22">Alguns moradores da rua atribuem o tiro que alvejou o ladrão ao segurança da padaria.</segment>
    <segment id="23">O posto policial do HGE informou que há a suspeita de que o ladrão teria sido baleado por um comparsa.</segment>
    <segment id="24">“Quem souber</segment>
    <segment id="25">, morre”</segment>
    <segment id="26">, ironizaram os policiais militares da 13ª CIPM.</segment>
    <segment id="27">O grito: ‘Passa aê</segment>
    <segment id="28">, coroa</segment>
    <segment id="29">, perdeu!</segment>
    <segment id="30">’

Um dos funcionários  da padaria – que preferiu não</segment>
    <segment id="31">sese identificar – pensou que era brincadeira quando ouviu o trio de assaltantes entrar no estabelecimento</segment>
    <segment id="32">, por volta das 20 horas</segment>
    <segment id="33">, gritando: “Passa aê</segment>
    <segment id="34">, coroa!</segment>
    <segment id="35">Perdeu</segment>
    <segment id="36">, perdeu!</segment>
    <segment id="37">”.</segment>
    <segment id="38">Segundo ele</segment>
    <segment id="39">, os caras eram mirrados</segment>
    <segment id="40">, magrelos e de baixa estatura</segment>
    <segment id="41">, por isso ele não levou  fé de que era um assalto.</segment>
    <segment id="42">“</segment>
    <segment id="43">Hoje, quando chegar em casa</segment>
    <segment id="44">, vou dar muito beijo no meu namorado”</segment>
    <segment id="45">, disse uma funcionária.</segment>
  </rst>
</analysis>