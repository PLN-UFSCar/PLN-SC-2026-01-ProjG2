  <rst>
    <segment id="1">‘Momentos de Amor’ vira pânico
Após conhecer homem através de programa de rádio</segment>
    <segment id="2">, Jamile marcou encontro e sumiu</segment>
    <segment id="3">Hoje faz quatro dias que a família de  Jamile Carlos dos Santos Brito</segment>
    <segment id="4">, 19 anos</segment>
    <segment id="5">, convive com a angústia de não saber o paradeiro da  adolescente.</segment>
    <segment id="6">A mãe dela</segment>
    <segment id="7">, a doméstica Mirian Carlos dos Santos</segment>
    <segment id="8">, 40, contou  que  a jovem  saiu</segment>
    <segment id="9">, na tarde do último domingo</segment>
    <segment id="10">,  para encontrar um rapaz  com quem mantinha contato por celular e não retornou para casa.</segment>
    <segment id="11">A família prestou queixa na Delegacia de Proteção à Pessoa (Pituba)</segment>
    <segment id="12">, anteontem.</segment>
    <segment id="13">Jamile pegou o número desse rapaz</segment>
    <segment id="14">, que se</segment>
    <segment id="15">se identificou</segment>
    <segment id="16">comocomo Genilson e disse ter 22 anos</segment>
    <segment id="17">,  no programa ‘Momentos de Amor’ (da rádio Piatã) há aproximadamente  um mês</segment>
    <segment id="18">, de acordo com a família.</segment>
    <segment id="19">Desde então</segment>
    <segment id="20">, os dois passaram a</segment>
    <segment id="21">sese falar diariamente.</segment>
    <segment id="22">“Eles ficavam conversando até altas horas da madrugada.</segment>
    <segment id="23">Genilson  chegou a comentar que gostava de namorar na porta e</segment>
    <segment id="24">, sese ocorresse tudo bem</segment>
    <segment id="25">, eles iriam noivar.</segment>
    <segment id="26">Acho que minha filha</segment>
    <segment id="27">sese empolgou e</segment>
    <segment id="28">, por isso</segment>
    <segment id="29">, foi ao encontro.</segment>
    <segment id="30">Se soubesse que iria acabar nisso</segment>
    <segment id="31">, não teria deixado ela  ir”</segment>
    <segment id="32">, lamentava a mãe</segment>
    <segment id="33">,  que revelou ter conversado por telefone com o rapaz.</segment>
    <segment id="34">Familiares e amigos descrevem Jamile</segment>
    <segment id="35">comocomo uma jovem caseira e sempre preocupada em avisar onde está.</segment>
    <segment id="36">No domingo</segment>
    <segment id="37">, a adolescente estava tão ansiosa para o encontro que esqueceu  o documento de identidade</segment>
    <segment id="38">, coisa que nunca havia ocorrido.</segment>
    <segment id="39">Aviso foi dado!</segment>
    <segment id="40">Irmão pediu para ela não ir

Jamile saiu de casa</segment>
    <segment id="41">, em Pau da Lima</segment>
    <segment id="42">,  por volta de três horas da tarde com o irmão Bruno</segment>
    <segment id="43">, 17.</segment>
    <segment id="44">O encontro com Genilson seria às 17h</segment>
    <segment id="45">, na praça em frente ao Shopping Iguatemi.</segment>
    <segment id="46">“</segment>
    <segment id="47">O rapaz atrasou 40 minutos.</segment>
    <segment id="48">Insisti para irmos</segment>
    <segment id="49">embora</segment>
    <segment id="50">embora</segment>
    <segment id="51">, masmas Jamile disse que só iria quando ele aparecesse”</segment>
    <segment id="52">, contou Bruno.</segment>
    <segment id="53">A pedido da irmã</segment>
    <segment id="54">, Bruno</segment>
    <segment id="55">sese afastou quando o rapaz chegou.</segment>
    <segment id="56">“Ela tinha medo de ele achar ela criança por estar acompanhada”</segment>
    <segment id="57">, explicou.</segment>
    <segment id="58">Celular desligado</segment>
    <segment id="59">A família falou com Jamile no domingo à noite.</segment>
    <segment id="60">Ela disse que estava com Genilson aguardando o ônibus para casa.</segment>
    <segment id="61">Desde então</segment>
    <segment id="62">, o celular dela está desligado.</segment>
    <segment id="63">Uma mensagem enviada do celular do rapaz para o da mãe diz que Jamile está bem e o rapaz é boa pessoa.</segment>
    <segment id="64">“Ele está</segment>
    <segment id="65">sese passando por ela”</segment>
    <segment id="66">, diz a mãe.</segment>
  </rst>
</analysis>