  <rst>
    <segment id="1">‘</segment>
    <segment id="2">Podemos tudo’</segment>
    <segment id="3">, diz Paulett</segment>
    <segment id="4">Primeira transexual a assumir cargo público na Bahia vai espantar preconceito</segment>
    <segment id="5">Com a palavra</segment>
    <segment id="6">, Paulett Furacão</segment>
    <segment id="7">, a nova coordenadora do Núcleo LGBT da Secretaria Estadual de Justiça Cidadania e Direitos Humanos da Bahia e a primeira transexual a assumir um cargo público no Estado.</segment>
    <segment id="8">“</segment>
    <segment id="9">A força e a garra que adquiri na vida para vencer os preconceitos por ser gay e depois por me assumir transexual são as garantias que dou às pessoas que estão confiando em mim de que realizarei um trabalho voltado para promover a inserção social dos transexuais e  travestis no mercado de trabalho”</segment>
    <segment id="10">, afirma Paulett.</segment>
    <segment id="11">Cheia de orgulho</segment>
    <segment id="12">,  ela</segment>
    <segment id="13">, com apenas 25 anos</segment>
    <segment id="14">, será empossada hoje</segment>
    <segment id="15">, às 10h</segment>
    <segment id="16">,  na Secretaria de Justiça</segment>
    <segment id="17">, no Centro Administrativo da Bahia.</segment>
    <segment id="18">Com a  exata noção dos desafios que terá a partir de agora</segment>
    <segment id="19">, ela revela sua trajetória de luta.</segment>
    <segment id="20">“Desde 2006 que milito em prol dos direitos humanos.</segment>
    <segment id="21">Esta minha nomeação representa uma grande conquista.</segment>
    <segment id="22">Precisamos mostrar para os  travestis e para os excluídos que eles  podem</segment>
    <segment id="23">sese qualificar e buscar outras profissões e não só fazer programa ou trabalhar em salão.</segment>
    <segment id="24">O ex-presidente Lula nos ensinou isso.</segment>
    <segment id="25">Podemos tudo.</segment>
    <segment id="26">Hoje, um transexual</segment>
    <segment id="27">, nascido e criado dentro do Nordeste de Amaralina</segment>
    <segment id="28">, quebra o preconceito e assume um cargo público cheio de  sonhos”</segment>
    <segment id="29">,  afirma.</segment>
    <segment id="30">Marco nacional</segment>
    <segment id="31">Convicto de estar promovendo a inserção social e dando um grande passo na luta contra o preconceito</segment>
    <segment id="32">, o secretário estadual de Justiça</segment>
    <segment id="33">, Cidadania e Direitos Humanos</segment>
    <segment id="34">, Almiro Sena</segment>
    <segment id="35">, vê esta nomeação</segment>
    <segment id="36">comocomo um marco nacional na luta por direitos iguais.</segment>
    <segment id="37">“</segment>
    <segment id="38">As pessoas que vêm sofrendo preconceitos historicamente precisam</segment>
    <segment id="39">sese tornar sujeitos de sua própria história.</segment>
    <segment id="40">Se, um dia</segment>
    <segment id="41">, foram considerados o problema</segment>
    <segment id="42">, agora eles passam a fazer parte da solução”</segment>
    <segment id="43">, frisou Almiro</segment>
    <segment id="44">, destacando que Paulett foi nomeada pela sua militância e pela capacidade de diálogo.</segment>
    <segment id="45">Conto de fadas</segment>
    <segment id="46">Apesar de estar muito feliz com a nomeação</segment>
    <segment id="47">, Paulett fez questão de lembrar as angústias que a transformaram em militante do movimento LGBT.</segment>
    <segment id="48">“Em 2004</segment>
    <segment id="49">, uma grande amiga</segment>
    <segment id="50">, a transformista Laleska D' Capri</segment>
    <segment id="51">, foi brutalmente assassinada.</segment>
    <segment id="52">Não consegui conviver com esta realidade e não fazer nada.</segment>
    <segment id="53">Criamos  uma ONG que leva seu nome.</segment>
    <segment id="54">No início</segment>
    <segment id="55">, as pessoas falavam que isso era coisa de veado.</segment>
    <segment id="56">Com o tempo</segment>
    <segment id="57">,  passaram a acreditar em nossa proposta.</segment>
    <segment id="58">Agora que fui nomeada</segment>
    <segment id="59">, não  esqueço que Laleska me chamava de Paula de Neve</segment>
    <segment id="60">, pois</segment>
    <segment id="61">pois achava que eu vivia em um  conto de fadas.</segment>
    <segment id="62">Estou vivendo isto</segment>
    <segment id="63">, graças a ela”.</segment>
  </rst>
</analysis>