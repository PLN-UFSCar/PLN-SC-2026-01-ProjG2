  <rst>
    <segment id="1">Autor pede perdão por criticar Veveta</segment>
    <segment id="2">Autor achava que Heloísa Mafalda não seria substituída à altura e foi grosseiro
Aguinaldo Silva</segment>
    <segment id="3">sese arrependeu de criticar  Ivete Sangalo</segment>
    <segment id="4">comocomo intéprete de Maria Machadão em “Gabriela”.</segment>
    <segment id="5">Depois de dizer no Twitter que esperava que Ivete cantasse uma de suas músicas e “saísse com dignidade” do remake</segment>
    <segment id="6">, ele se</segment>
    <segment id="7">se justificou dizendo que sentiu “ciúmes”</segment>
    <segment id="8">, por achar que Heloísa Mafalda</segment>
    <segment id="9">, que viveu o papel na versão original</segment>
    <segment id="10">, era insubstituível.</segment>
    <segment id="11">“Fui infeliz...</segment>
    <segment id="12">Venho aqui</segment>
    <segment id="13">, humildemente</segment>
    <segment id="14">, retirar o que disse sobre Ivete</segment>
    <segment id="15">, ainda mais depois de constatar o quanto ela ficou linda”</segment>
    <segment id="16">, tuitou.</segment>
  </rst>
