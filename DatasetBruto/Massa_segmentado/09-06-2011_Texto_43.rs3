  <rst>
    <segment id="1">Estaduais sem calendário definido</segment>
    <segment id="2">Universidades esperam fim da greve dos docentes para fixar datas de inscrição e prova</segment>
    <segment id="3">A contagem regressiva para o processo seletivo das maiores instituições de ensino superior já começou</segment>
    <segment id="4">, masmas as universidades estaduais</segment>
    <segment id="5">, em greve</segment>
    <segment id="6">, ainda não decidiram o calendário para 2012.</segment>
    <segment id="7">Em compasso de espera</segment>
    <segment id="8">, candidatos</segment>
    <segment id="9">sese dedicam aos estudos para tentar garantir a aprovação.</segment>
    <segment id="10">Fernanda Souza Batista</segment>
    <segment id="11">, 22, já é formada em biomedicina</segment>
    <segment id="12">, masmas quer fazer medicina:</segment>
    <segment id="13">“Vou tentar Ufba e também a Uneb</segment>
    <segment id="14">, que terá o curso a partir do próximo ano”.</segment>
    <segment id="15">Segundo a professora Romilda Almeida</segment>
    <segment id="16">, presidente em exercício da Comissão Permanente de Vestibular da Uneb</segment>
    <segment id="17">, as datas serão confirmadas após o fim da greve.</segment>
    <segment id="18">A previsão é de que as provas ocorram nos dias 11 e 12 de dezembro</segment>
    <segment id="19">, masmas deve haver mudanças.</segment>
    <segment id="20">“</segment>
    <segment id="21">Na próxima semana</segment>
    <segment id="22">, provavelmente</segment>
    <segment id="23">, esse cronograma já estará definido”</segment>
    <segment id="24">, completou.</segment>
    <segment id="25">As inscrições devem ocorrer entre agosto e setembro.</segment>
    <segment id="26">A Uefs manteve o vestibular do segundo semestre nos dias 10 e 12 de julho</segment>
    <segment id="27">, masmas nada definiu sobre 2012.</segment>
    <segment id="28">A mesma incerteza ocorre na Uesc e na Uesb</segment>
    <segment id="29">, que só fixarão datas depois que a greve de professores acabar.</segment>
    <segment id="30">Confira prazos de outras instituições
UNIFACS - Inscrição: até 15 de junho</segment>
    <segment id="31">; preço: R$ 45</segment>
    <segment id="32">; data da prova: 19 de julho.
UCSAL - Inscrição: até 7 de julho</segment>
    <segment id="33">; preço: R$ 25</segment>
    <segment id="34">; data da prova: 10 de julho.
UNIJORGE - Inscrição: até 14 de julho</segment>
    <segment id="35">; preços: R$ 30 (até o dia 7) e R$ 40</segment>
    <segment id="36">; data da prova: 17 de julho.
UFBA - Inscrição: entre 2 e 24 de agosto</segment>
    <segment id="37">; datas das provas: 13 e 14 de novembro (1ª fase) e 18 e 19 de dezembro.
OPINE:</segment>
    <segment id="38">O que você acha da grave dos professores das universidades estaduais?</segment>
    <segment id="39">Comente!</segment>
  </rst>
</analysis>