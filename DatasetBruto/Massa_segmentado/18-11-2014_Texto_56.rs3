  <rst>
    <segment id="1">CadГѓВЄ o asfalto?</segment>
    <segment id="2">Moradores da Rua Almeida BrandГѓВЈo vivem de promessas hГѓВЎ muitos anos</segment>
    <segment id="3">Escondidos</segment>
    <segment id="4">ГѓВ  beira-mar e ao lado de vizinhos da linha fГѓ</segment>
    <segment id="5">В©rrea do SubГѓВєrbio</segment>
    <segment id="6">, os moradores da Rua Almeida BrandГѓВЈo</segment>
    <segment id="7">, em Plataforma</segment>
    <segment id="8">, escutam promessas sobre o calГѓВ§amento da via hГѓВЎ</segment>
    <segment id="9">mais de quarenta anos.</segment>
    <segment id="10">Гўв‚¬Е“Moro aqui hГѓВЎ 43 anos e essa rua nunca foi asfaltada</segment>
    <segment id="11">, entra prefeito e sai prefeito e o projeto nunca sai do papelГўв‚¬</segment>
    <segment id="12">, diz a aposentada Teresa Santana</segment>
    <segment id="13">, 64 anos.</segment>
    <segment id="14">A reivindicaГѓВ§ГѓВЈo</segment>
    <segment id="15">, segundo os moradores</segment>
    <segment id="16">, ГѓВ© uma necessidade bГѓВЎsica.</segment>
    <segment id="17">Гўв‚¬Е“Quando chove isso aqui vira lama</segment>
    <segment id="18">, sem falar na poeira que invade a casa todos os dias.</segment>
    <segment id="19">Asfalto nГѓВЈo ГѓВ© luxo</segment>
    <segment id="20">, ГѓВ© necessidadeГўв‚¬</segment>
    <segment id="21">, completou a aposentada.</segment>
    <segment id="22">Por meio de nota</segment>
    <segment id="23">, a SuperintendГѓВЄncia de ConservaГѓВ§ГѓВЈo e Obras PГѓВєblicas (Sucop) informou que em um ano e meio asfaltou mais de 200 km de ruas na cidade  e atГѓВ© o final do ano deve asfaltar  mais 80 quilГѓВґmetros de vias.</segment>
    <segment id="24">Na boca do povo
"ГѓвЂ° a orla do subГѓВєrbio que estГѓВЎ desvalorizada por conta disso.</segment>
    <segment id="25">Dizem que na prefeitura esta via ГѓВ© dada</segment>
    <segment id="26">comocomo asfaltada</segment>
    <segment id="27">, masmas nunca jogaram uma borrinha sequer".</segment>
    <segment id="28">Nailson Santana</segment>
    <segment id="29">, 43, Comerciante.</segment>
    <segment id="30">"ГѓвЂњrgГѓВЈos pГѓВєblicos deviam favorecer quem precisa.</segment>
    <segment id="31">Reformar onde jГѓВЎ tem asfalto</segment>
    <segment id="32">ГѓВ© necessГѓВЎrio</segment>
    <segment id="33">, masmas nГѓВЈo antes de contemplar ГѓВЎreas que nunca foram asfaltadas".</segment>
    <segment id="34">Valmir Soares</segment>
    <segment id="35">, 37, Vigilante.</segment>
    <segment id="36">"</segment>
    <segment id="37">Quando chove isso aqui ГѓВ© uma tristeza</segment>
    <segment id="38">, o mato tambГѓВ©m toma conta de tudo.</segment>
    <segment id="39">Quatro prefeitos jГѓВЎ prometeram asfaltar aqui</segment>
    <segment id="40">, masmas atГѓВ© agora nada foi feito".</segment>
    <segment id="41">Venilton Ribeiro</segment>
    <segment id="42">, 58, Aposentado.
"</segment>
    <segment id="43">O mГѓВ­nimo que poderia ser feito era programar uma intervenГѓВ§ГѓВЈo nas ruas que nunca foram asfaltadas.</segment>
    <segment id="44">Estamos escondidos</segment>
