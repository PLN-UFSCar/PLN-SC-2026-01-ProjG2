  <rst>
    <segment id="1">Baila comigo</segment>
    <segment id="2">, Dani
Gata de Pero Vaz dança em grupo de valsa
Daniane Silva</segment>
    <segment id="3">, 22 anos</segment>
    <segment id="4">, é uma legítima cafusa</segment>
    <segment id="5">, ou seja</segment>
    <segment id="6">, representante da mistura de negros e índios</segment>
    <segment id="7">, tão comum em terras baianas e com belos resultados.</segment>
    <segment id="8">A gata de Pero Vaz</segment>
    <segment id="9">sese orgulha muito de carregar o nome escolhido por sua avó</segment>
    <segment id="10">, uma índia para ninguém botar defeito.</segment>
    <segment id="11">Apaixonada por dança</segment>
    <segment id="12">, a morena já passou por bandas de pagode</segment>
    <segment id="13">, masmas resolveu mostrar toda sua leveza e graça participando do grupo de valsa do bairro da Liberdade.</segment>
    <segment id="14">Mas não é de hoje que a menina dança.</segment>
    <segment id="15">Dani começou na ginástica rítmica desportiva (GRD) aos 8 anos.</segment>
    <segment id="16">“Minha mãe logo reconheceu meu talento</segment>
    <segment id="17">, pois</segment>
    <segment id="18">pois dentro de casa eu não parava.</segment>
    <segment id="19">Ela resolveu me matricular nas aulas e eu deslanchei”</segment>
    <segment id="20">, conta.</segment>
    <segment id="21">Se foi fácil identificar na dança a sua arte</segment>
    <segment id="22">, Dani ainda não definiu a profissão que pretende seguir</segment>
    <segment id="23">, masmas confessa que a área de saúde a atrai muito.</segment>
    <segment id="24">Prova disso é que a moça correu atrás e já terminou o curso técnico de enfermagem.</segment>
    <segment id="25">“</segment>
    <segment id="26">Agora, pretendo me especializar na área.</segment>
    <segment id="27">A faculdade está nos meus planos”</segment>
    <segment id="28">, diz.</segment>
    <segment id="29">De olho no futuro

Ele não pretende dançar na vida profissional e investe para</segment>
    <segment id="30">sese especializar na área de saúde</segment>
  </rst>
