  <rst>
    <segment id="1">Esse Ba-Ba vai ser de responsa
Bahia de Feira contra o Bahia de Salvador: é amanhã</segment>
    <segment id="2">, às 5h da tarde</segment>
    <segment id="3">O Baianão só está no começo</segment>
    <segment id="4">, masmas um jogo</segment>
    <segment id="5">, ou melhor</segment>
    <segment id="6">, um Ba-Ba</segment>
    <segment id="7">, já o faz ferver.</segment>
    <segment id="8">É o duelo de amanhã</segment>
    <segment id="9">, às 5h da tarde</segment>
    <segment id="10">, entre Bahia de Feira</segment>
    <segment id="11">, atual campeão</segment>
    <segment id="12">, e Bahia</segment>
    <segment id="13">, um dos favoritos a levantar a taça em 2012.</segment>
    <segment id="14">Depois de um empate dentro de casa</segment>
    <segment id="15">, o tricolor de Salvador precisa vencer o confronto do Estádio Joia da Princesa</segment>
    <segment id="16">, em Feira de Santana</segment>
    <segment id="17">, para recuperar os pontos perdidos.</segment>
    <segment id="18">Joel Santana</segment>
    <segment id="19">, no entanto</segment>
    <segment id="20">, reconhece a dificuldade da partida.</segment>
    <segment id="21">“</segment>
    <segment id="22">Se eles estão na frente são os favoritos”</segment>
    <segment id="23">, contou o treinador</segment>
    <segment id="24">, antes de completar:</segment>
    <segment id="25">“É um time campeão</segment>
    <segment id="26">, que merece todo nosso respeito</segment>
    <segment id="27">, masmas vamos jogar</segment>
    <segment id="28">comocomo o Bahia.</segment>
    <segment id="29">Temos que buscar o resultado”</segment>
    <segment id="30">, justificou.</segment>
    <segment id="31">No lado do Bahia de Feira</segment>
    <segment id="32">,  líder após o 3 a 1 contra o Juazeiro</segment>
    <segment id="33">, Arnaldo Lira preferiu deixar o favoritismo para o Esquadrão.</segment>
    <segment id="34">“Favorito é o Bahia</segment>
    <segment id="35">, que tem um orçamento de R$ 50 milhões e um time de grandes atletas.</segment>
    <segment id="36">Nosso grupo é jovem</segment>
    <segment id="37">, cheio de garotos”</segment>
    <segment id="38">, justificou o treinador do Tremendão</segment>
    <segment id="39">, otimista:</segment>
    <segment id="40">“Já estamos acostumados a ganhar de Bahia e Vitória.</segment>
    <segment id="41">Se fizermos uma boa partida</segment>
    <segment id="42">, podemos vencer o jogo”</segment>
    <segment id="43">, garantiu Lira.</segment>
    <segment id="44">Além disso</segment>
    <segment id="45">, o Ba-Ba terá um duelo especial.</segment>
    <segment id="46">Marcelo Lomba foi lembrado por Joel</segment>
    <segment id="47">porque</segment>
    <segment id="48">porque “tomou muitos gols”.</segment>
    <segment id="49">Então, o goleiro terá que mostrar a força diante de João Neto</segment>
    <segment id="50">, que está com sangue nos olhos para brocar o Bahia</segment>
    <segment id="51">, onde não foi aproveitado.</segment>
  </rst>
</analysis>