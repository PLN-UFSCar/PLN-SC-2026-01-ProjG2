M횄징rio</segment>
    <segment id="44">Alves era baiano e tinha 47 anos quando saiu da casa onde vivia com a mulher</segment>
    <segment id="45">, Dilma Borges</segment>
    <segment id="46">, na Aboli횄짠횄짙o</segment>
    <segment id="47">, sub횄쨘rbio do Rio.</segment>
    <segment id="48">Ele estava acostumado tanto a ser perseguido quanto 횄혻 vida clandestina desde 1942</segment>
    <segment id="49">, quando entrou para o Partido Comunista Brasileiro (PCB).</segment>
    <segment id="50">Preso meses depois do golpe de 1964</segment>
