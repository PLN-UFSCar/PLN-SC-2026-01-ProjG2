  <rst>
    <segment id="1">Mulher no meio de monstros</segment>
    <segment id="2">Dona de cana</segment>
    <segment id="3">ﾃδｩ jogada em cisterna e acusado diz que sequestrou por encomenda
Foi encontrado na tarde de ontem o corpo da dona de casa Clemilda Fraga da Silva</segment>
    <segment id="4">, 42 anos</segment>
    <segment id="5">, que foi sequestrada</segment>
    <segment id="6">, na ﾃδｺltima terﾃδｧa-feira</segment>
    <segment id="7">, quando estava em casa</segment>
    <segment id="8">, no povoado de Alto do Rosﾃδ｡rio</segment>
    <segment id="9">, no distrito de Jaiba</segment>
    <segment id="10">, em Feira de Santana.</segment>
    <segment id="11">O cadﾃδ｡ver foi localizado apﾃδｳs a prisﾃδ｣o de Paulo de Jesus Oliveira</segment>
    <segment id="12">, 19, que confessou ter raptado a mulher e mostrou a cisterna onde o corpo estava.</segment>
    <segment id="13">Porﾃδｩm</segment>
    <segment id="14">, ele acusou outra pessoa de ser o autor do crime.</segment>
    <segment id="15">Paulo contou que foi contratado por Deusdeth de Oliveira Leite</segment>
    <segment id="16">,67, proprietﾃδ｡rio da chﾃδ｡cara onde mora a famﾃδｭlia da dona de casa</segment>
    <segment id="17">, para sequestrar a mulher e que receberia R$ 2 mil pelo serviﾃδｧo.</segment>
    <segment id="18">A prisﾃδ｣o foi feita pelo Tﾃδ｡tico Mﾃδｳvel da Polﾃδｭcia Militar.</segment>
    <segment id="19">O desaparecimento da dona de casa foi denunciado pelo marido dela</segment>
    <segment id="20">, Antonio Horlando Martins da Costa</segment>
    <segment id="21">, 33, que registrou queixa na 2ﾃつｪ Delegacia</segment>
    <segment id="22">, na quarta-feira.</segment>
    <segment id="23">O sequestro foi presenciado por um filho da dona de casa</segment>
    <segment id="24">, de apenas 8 anos.</segment>
    <segment id="25">O garoto viu quando Paulo amarrou a mﾃδ｣e</segment>
    <segment id="26">, colocou um pano na boca da mulher e a jogou no ombro.</segment>
    <segment id="27">O acusado ainda teria ameaﾃδｧado a crianﾃδｧa.</segment>
    <segment id="28">Segundo Antﾃδｴnio Horlando</segment>
    <segment id="29">, o acusado jﾃδ｡ havia roubado a casa sete vezes e o jurado de morte.</segment>
    <segment id="30">Na segunda-feira</segment>
    <segment id="31">, ele teria ameaﾃδｧado matar a mulher.</segment>
    <segment id="32">ﾃ｢竄ｬﾅ溺as nﾃδ｣o acreditei e ele veio e fez isto mesmo.</segment>
    <segment id="33">Agora estou sem rumo</segment>
    <segment id="34">poispois ela era tudo para mimﾃ｢竄ｬ</segment>
    <segment id="35">, desabafou</segment>
    <segment id="36">, entre lﾃδ｡grimas.</segment>
    <segment id="37">Cheio de baratino
ﾃ｢竄ｬﾅ泥esconfiei</segment>
    <segment id="38">porque</segment>
    <segment id="39">porque ele a trouxe para o matagal e segui ele.</segment>
    <segment id="40">Aﾃδｭ, descobri que ele a matou a facadas e ele entﾃδ｣o me obrigou a ajudﾃδ｡-lo a jogar o corpo aqui na cisternaﾃ｢竄ｬ</segment>
    <segment id="41">, alegou.</segment>
    <segment id="42">A polﾃδｭcia prendeu Deusdeth</segment>
    <segment id="43">, na noite de ontem.</segment>
    <segment id="44">Familiares da dona de casa informaram que ele estava em briga com o casal pelo fato de querer a propriedade de volta.</segment>
    <segment id="45">ﾃ｢竄ｬﾅ摘le pediu a casa</segment>
    <segment id="46">, masmas nﾃδ｣o tﾃδｭnhamos onde morar e ele me devia os 7 anos que trabalhei sem receber nada.</segment>
    <segment id="47">Nﾃδｳs ﾃδｭamos deixar a casa</segment>
    <segment id="48">, masmas pedi uma tempo para arrumar um lugar.</segment>
    <segment id="49">Nﾃδ｣o precisava matar ela nﾃδ｣oﾃ｢竄ｬ</segment>
    <segment id="50">, frisou Antﾃδｴnio Horlando.</segment>
    <segment id="51">A noticia da morte da dona de casa revoltou moradores do local</segment>
    <segment id="52">, que se</segment>
    <segment id="53">se aglomeraram para tentar linchar o acusado.</segment>
    <segment id="54">Foi necessﾃδ｡rio reforﾃδｧo policial.</segment>
    <segment id="55">ﾃ｢竄ｬﾅ轍uero que ele pague pelo que fez.</segment>
    <segment id="56">Nﾃδ｣o deveria ter feito isto</segment>
    <segment id="57">, pois</segment>
    <segment id="58">pois a mulher era uma pessoa boaﾃ｢竄ｬ</segment>
    <segment id="59">, gritou uma das irmﾃδ｣s do acusado.</segment>
  </rst>
