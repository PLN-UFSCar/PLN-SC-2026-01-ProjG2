  <rst>
    <segment id="1">Quarto malandro foragido</segment>
    <segment id="2">Fábio Alves servia</segment>
    <segment id="3">comocomo laranja de Maurizzio Cersósimo e também roubou artistas
Acusado de integrar a quadrilha liderada pelo empresário Maurizzio Cersósimo Mattos</segment>
    <segment id="4">, 49 anos</segment>
    <segment id="5">, no golpe para a falsa venda de uma ilha na Baía de Todos-os-Santos</segment>
    <segment id="6">, avaliada em R$ 35 milhões</segment>
    <segment id="7">, Fábio Crisamon Alves Tannus</segment>
    <segment id="8">, que prometeu</segment>
    <segment id="9">sese apresentar ontem à tarde</segment>
    <segment id="10">, na sede da Delegacia de Crimes Econômicos e Contra a Administração Pública (Dececap) não compareceu a unidade.</segment>
    <segment id="11">“</segment>
    <segment id="12">Hoje ele é considerado por nós</segment>
    <segment id="13">comocomo foragido”</segment>
    <segment id="14">, disse a titular da Dececap</segment>
    <segment id="15">, a delegada Pilly Dantas.</segment>
    <segment id="16">De acordo com informações da delegada</segment>
    <segment id="17">, Fábio é amigo do acusado de golpe e sua esposa Cláudia Patrícia Accioly Cersósimo Mattos</segment>
    <segment id="18">, 48 anos</segment>
    <segment id="19">, e era usado</segment>
    <segment id="20">comocomo laranja.</segment>
    <segment id="21">“</segment>
    <segment id="22">Eles falsificaram uma escritura e apresentavam Fábio</segment>
    <segment id="23">comocomo o dono da ilha”</segment>
    <segment id="24">, contou a delegada.</segment>
    <segment id="25">Segundo ela</segment>
    <segment id="26">, o advogado de Fábio prometeu apresentá-lo ontem na unidade policial.</segment>
    <segment id="27">“</segment>
    <segment id="28">Ele esteve aqui disse que o cliente queria</segment>
    <segment id="29">sese apresentar</segment>
    <segment id="30">, masmas não veio”</segment>
    <segment id="31">, contou a titular da Dececap.</segment>
    <segment id="32">Até a empregada do casal</segment>
    <segment id="33">, Cláudia Maria dos Santos</segment>
    <segment id="34">, 38, foi detida por servir de laranja.</segment>
    <segment id="35">Margareth Menezes Cantora foi mais uma vítima</segment>
    <segment id="36">Assim como</segment>
    <segment id="37">como o cantor Ricardo Chaves – que reclama de sucessivos golpes praticados pelo empresário</segment>
    <segment id="38">, que lhe renderam um prejuízo de pelo menos R$ 1 milhão –</segment>
    <segment id="39">, a cantora Margareth Menezes</segment>
    <segment id="40">sese manifestou no Twitter dizendo-</segment>
    <segment id="41">sese também vítima do estelionatário.</segment>
    <segment id="42">“@_RicardoChaves querido</segment>
    <segment id="43">, te assisti no jornal.</segment>
    <segment id="44">Também aprontou com meu nome em Minas Gerais.</segment>
    <segment id="45">Depois eu lhe conto”</segment>
    <segment id="46">, escreveu ela.</segment>
    <segment id="47">Ricardo Chaves respondeu:</segment>
    <segment id="48">“A guerra é longa</segment>
    <segment id="49">, essa foi uma vitória importante.</segment>
    <segment id="50">Quero saber o que houve mesmo”.</segment>
    <segment id="51">A assessoria de comunicação de Margareth não forneceu maiores detalhes sobre a declaração dada pela cantora na rede de relacionamentos.</segment>
    <segment id="52">O casal de empresários foi preso na sexta-feira passada</segment>
    <segment id="53">, na mansão no Condomínio Encontro das Águas</segment>
    <segment id="54">, em Lauro de Freitas.</segment>
  </rst>
</analysis>