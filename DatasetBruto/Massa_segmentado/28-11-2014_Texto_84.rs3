  <rst>
    <segment id="1">Estudantes</segment>
    <segment id="2">sese ligam no valor da educaﾃδｧﾃδ｣o</segment>
    <segment id="3">No ﾃδｺltimo encontro da sﾃδｩrie</segment>
    <segment id="4">, jornalistas e alunos conversam sobre identidade</segment>
    <segment id="5">Com palestra sobre identidade cultural</segment>
    <segment id="6">, educaﾃδｧﾃδ｣o e negritude</segment>
    <segment id="7">, foi encerrada ontem a sﾃδｩrie de encontros do MASSA!</segment>
    <segment id="8">com alunos do 8ﾃつｪ ano do Colﾃδｩgio Estadual Teresa Helena Mata Pires</segment>
    <segment id="9">, no Lobato.</segment>
    <segment id="10">O projeto de leitura do jornal foi iniciativa da professora de Lﾃδｭngua Portuguesa</segment>
    <segment id="11">, Mﾃδｩrcia Abreu.</segment>
    <segment id="12">Os estudantes tiveram a oportunidade de conhecer um pouco mais sobre a histﾃδｳria do bairro por meio de uma reportagem veiculada no jornal na semana anterior e tambﾃδｩm dos jornalistas Maﾃδｭra Azevedo e Lucas Caldas</segment>
    <segment id="13">, que trouxeram questionamentos sobre alguns problemas corriqueiros enfrentados por quem reside na periferia da capital baiana.
ﾃ｢竄ｬﾅ轍uem mora no Subﾃδｺrbio</segment>
    <segment id="14">, por exemplo</segment>
    <segment id="15">, nﾃδ｣o tem acesso fﾃδ｡cil a cultura e lazer</segment>
    <segment id="16">, ﾃδｩ obrigado a pegar ﾃδｴnibus cheio e lidar com a violﾃδｪncia.</segment>
    <segment id="17">Temos que entender que isso nﾃδ｣o</segment>
    <segment id="18">ﾃδｩ normal</segment>
    <segment id="19">.</segment>
    <segment id="20">O povo tem o poder.</segment>
    <segment id="21">Organizados</segment>
    <segment id="22">, podemos tudoﾃ｢竄ｬ</segment>
    <segment id="23">, disse Maﾃδｭra.</segment>
    <segment id="24">Para incentivar ainda mais os jovens</segment>
    <segment id="25">, os repﾃδｳrteres trouxeram histﾃδｳrias de sucesso para ilustrar o importante papel da educaﾃδｧﾃδ｣o na transformaﾃδｧﾃδ｣o da vida das pessoas.</segment>
    <segment id="26">ﾃ｢竄ｬﾅ溺eu avﾃδｴ quebrava pedra e meus pais trabalharam duro para me sustentar.</segment>
    <segment id="27">Sou o ﾃδｺnica da famﾃδｭlia a ter nﾃδｭvel superior e morar na periferia nﾃδ｣o me impediu de seguir em frenteﾃ｢竄ｬ</segment>
    <segment id="28">, conta Lucas</segment>
    <segment id="29">, que ﾃδｩ morador do Lobato</segment>
    <segment id="30">, mostrando-</segment>
    <segment id="31">sese como</segment>
    <segment id="32">como exemplo para os jovens estudantes.
Questﾃδ｣o sempre presente no cotidiano da maioria dos baianos</segment>
    <segment id="33">, o racismo nﾃδ｣o poderia ser deixado de lado.</segment>
    <segment id="34">Desta vez</segment>
    <segment id="35">, Maﾃδｭra fez questﾃδ｣o de enfatizar que ﾃδｩ necessﾃδ｡rio</segment>
    <segment id="36">sese impor e assumir a sua identidade.</segment>
    <segment id="37">ﾃ｢竄ｬﾅ典emos que trabalhar a autoestima</segment>
    <segment id="38">, no que</segment>
    <segment id="39">sese refere ﾃδ nossa negritude e tambﾃδｩm a do local onde moramos.</segment>
    <segment id="40">Sﾃδｳ nﾃδｳs podemos mudar nossa histﾃδｳria.</segment>
    <segment id="41">Isso pode ser conseguido com conhecimento</segment>
    <segment id="42">, porque</segment>
    <segment id="43">porque informaﾃδｧﾃδ｣o ﾃδｩ poderﾃ｢竄ｬ</segment>
    <segment id="44">, enfatizou.</segment>
    <segment id="45">Projeto bombou!</segment>
    <segment id="46">Pofessora Mﾃδｩrcia faz avaliaﾃδｧﾃδ｣o positiva</segment>
    <segment id="47">Para a professora Mﾃδｩrcia</segment>
    <segment id="48">Abreu,</segment>
    <segment id="49">o projeto surtiu resultados imediatos</segment>
    <segment id="50">, nﾃδ｣o somente nos seus alunos.</segment>
    <segment id="51">ﾃ｢竄ｬﾅ擢oi muito enriquecedor tanto para eles quanto para mim.</segment>
    <segment id="52">Tratamos de aspectos voltados para eles poderem rever seus conceitos diante de assuntos sﾃδｩrios e ampliarem a forma de ver o mundo.</segment>
    <segment id="53">Jﾃδ｡</segment>
    <segment id="54">dﾃδ｡ para perceber a mudanﾃδｧa de postura de alguns alunos.</segment>
    <segment id="55">Nos corredores</segment>
    <segment id="56">, sﾃδｳ se</segment>
    <segment id="57">se fala das palestras</segment>
    <segment id="58">, foi um sucessoﾃ｢竄ｬ</segment>
    <segment id="59">, afirma.
Mﾃδｩrcia planeja levar a atividade para toda a escola</segment>
    <segment id="60">, trabalhando com mais professores</segment>
    <segment id="61">, fazendo uma visita ﾃδ redaﾃδｧﾃδ｣o</segment>
    <segment id="62">, dando continuidade</segment>
    <segment id="63">ﾃδs palestras</segment>
    <segment id="64">, isso sem contar com o plano mais ambicioso: elaborar um jornal.</segment>
    <segment id="65">ﾃ｢竄ｬﾅ撤roduzir textos vai ajudar ainda mais na aprendizagem deles.</segment>
    <segment id="66">Nﾃδｳs pudemos observar a influﾃδｪncia que o jornal trouxe ﾃδ escola.</segment>
    <segment id="67">Nosso olhar mudou totalmenteﾃ｢竄ｬ</segment>
    <segment id="68">, garante Mﾃδｩrcia.</segment>
    <segment id="69">A opiniﾃδ｣o dos estudantes
"</segment>
    <segment id="70">Gostei muito dos temas da palestra.</segment>
    <segment id="71">O melhor foi conhecer um pouco mais sobre o bairro".</segment>
    <segment id="72">Wenderson Santana</segment>
    <segment id="73">, 16,estudante.</segment>
    <segment id="74">"</segment>
    <segment id="75">Foi muito bom</segment>
    <segment id="76">, principalmente a questﾃδ｣o da discriminaﾃδｧﾃδ｣o por bairro e os problemas de transporte".</segment>
    <segment id="77">Jeane Nascimento</segment>
    <segment id="78">, 16, estudante.
"</segment>
    <segment id="79">Achei interessante saber que alguns blocos nﾃδ｣o deixavam quem mora no Subﾃδｺrbio desfilar".</segment>
    <segment id="80">Cris Wwelly Pereira</segment>
    <segment id="81">, 17,estudante.</segment>
    <segment id="82">"Chamou a atenﾃδｧﾃδ｣o o que Maﾃδｭra falou sobre</segment>
    <segment id="83">comocomo o bairro</segment>
    <segment id="84">ﾃδｩ visto pelos policiais e a idﾃδｩia de que aqui ﾃδｩ perigoso".</segment>
