  <rst>
    <segment id="1">Traficantes impﾃδｵem a lei do terror
Luﾃδｭs e Magno nﾃδ｣o participaram do estupro</segment>
    <segment id="2">, masmas agrediram o casal</segment>
    <segment id="3">A expressﾃδ｣o assustada de Jean Souza dos Santos</segment>
    <segment id="4">, 21 anos</segment>
    <segment id="5">, ao ser questionado por cerca de sete  homens sobre o sumiﾃδｧo de R$ 250 foi o suficiente para o tribunal do trﾃδ｡fico</segment>
    <segment id="6">, que impera na localidade de Tubarﾃδ｣o</segment>
    <segment id="7">, em Paripe</segment>
    <segment id="8">, impor a sentenﾃδｧa: a mulher dele</segment>
    <segment id="9">, uma adolescente de 17 anos</segment>
    <segment id="10">, foi estuprada e ameaﾃδｧada de morte por cinco homens.</segment>
    <segment id="11">E  Jean foi espancado</segment>
    <segment id="12">, torturado e ameaﾃδｧado de morte.</segment>
    <segment id="13">O casal foi agredido</segment>
    <segment id="14">, ontem</segment>
    <segment id="15">, em uma casa abandonada na localidade.</segment>
    <segment id="16">Jean e a mulher  negam o furto.</segment>
    <segment id="17">Luﾃδｭs Andrﾃδｩ Souza dos Santos</segment>
    <segment id="18">, 18, e Magno Felipe da Silva</segment>
    <segment id="19">, 21, integrantes do grupo</segment>
    <segment id="20">, foram detidos por policiais da 19ﾃつｪ CIPM (Inema) e estﾃδ｣o presos na Delegacia de Periperi.</segment>
    <segment id="21">Eles, segundo a adolescente</segment>
    <segment id="22">, nﾃδ｣o participaram do estupro.</segment>
    <segment id="23">ﾃ｢竄ｬﾅ鏑ﾃδ｡ (Tubarﾃδ｣o)</segment>
    <segment id="24">, nﾃδ｣o pode chamar a polﾃδｭcia</segment>
    <segment id="25">porque</segment>
    <segment id="26">porque tem boca (de fumo).</segment>
    <segment id="27">Eles falaram que iam resolver do jeito delesﾃ｢竄ｬ</segment>
    <segment id="28">, afirmou Luﾃδｭs Andrﾃδｩ.</segment>
    <segment id="29">O trﾃδ｡fico nessa localidade ﾃδｩ comandada por um traficante conhecido</segment>
    <segment id="30">comocomo Dedeco</segment>
    <segment id="31">, conforme a polﾃδｭcia.</segment>
    <segment id="32">Jean contou que estava em casa  quando uma vizinha o chamou.</segment>
    <segment id="33">Ao sair</segment>
    <segment id="34">, sese deparou com  diversos homens que o acusaram de furto e exigiram  os R$ 250</segment>
    <segment id="35">, de propriedade de Magno.</segment>
    <segment id="36">ﾃ｢竄ｬﾅ摘les pediram dinheiro</segment>
    <segment id="37">, eu disse que nﾃδ｣o tinha roubado e eles me espancaram</segment>
    <segment id="38">, me amarraram e ameaﾃδｧavam cortar meu braﾃδｧo com um serrote e me matarﾃ｢竄ｬ</segment>
    <segment id="39">, relatou Jean.</segment>
    <segment id="40">Segundo ele e a mulher</segment>
    <segment id="41">, os bandidos portavam uma metralhadora</segment>
    <segment id="42">, um revﾃδｳlver e vﾃδ｡rias facas.
Sﾃδ｣o cﾃδｺmplices de tudo
Jean fugiu e procurou a polﾃδｭcia para resgatar a mulher.</segment>
    <segment id="43">Com PMs</segment>
    <segment id="44">, ele voltou ao local</segment>
    <segment id="45">, masmas nﾃδ｣o encontrou ninguﾃδｩ</segment>
    <segment id="46">m.</segment>
    <segment id="47">A mulher foi libertada por um senhor</segment>
    <segment id="48">, que botou os caras para correr.</segment>
    <segment id="49">Em Sﾃδ｣o Tomﾃδｩ de Paripe</segment>
    <segment id="50">, Jean reconheceu Luﾃδｭs Andrﾃδｩ e Magno.</segment>
    <segment id="51">Eles tentaram fugir nadando</segment>
    <segment id="52">, masmas foram capturados em perseguiﾃδｧﾃδ｣o de barco.</segment>
    <segment id="53">Ela ficou cerca de duas horas em poder dos bandidos.</segment>
    <segment id="54">ﾃ｢竄ｬﾅ徹 fato de eles nﾃδ｣o terem cometido o estupro nﾃδ｣o quer dizer que nﾃδ｣o tenham responsabilidadeﾃ｢竄ｬ</segment>
    <segment id="55">, afirmou o delegado da 5ﾃつｪ DT</segment>
    <segment id="56">, ACM Santos.</segment>
    <segment id="57">Luﾃδｭs e Magno foram autuados em flagrante por formaﾃδｧﾃδ｣o de quadrilha</segment>
    <segment id="58">, cﾃδ｡rcere privado e pelo roubo de R$ 60 do casal.</segment>
