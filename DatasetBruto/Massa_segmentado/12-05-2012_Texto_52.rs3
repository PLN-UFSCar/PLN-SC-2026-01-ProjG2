  <rst>
    <segment id="1">Geórgia Gomes agita a Lapa com samba e proezas culinárias</segment>
    <segment id="2">RIO - Geórgia é do samba por formação.</segment>
    <segment id="3">É carioca de Botafogo</segment>
    <segment id="4">, mais especificamente da pequena comunidade de Morro Azul</segment>
    <segment id="5">, que já foi até nome de estação de metrô</segment>
    <segment id="6">, masmas voltou ao anonimato quando a tal estação foi rebatizada de Flamengo.</segment>
    <segment id="7">Por ironia</segment>
    <segment id="8">, Morro Azul não tem tradição no samba.</segment>
    <segment id="9">Mas Geórgia nem</segment>
    <segment id="10">sese deu conta disso.</segment>
    <segment id="11">Seu pai foi criado por Noca da Portela</segment>
    <segment id="12">, o compositor da Velha Guarda que a passista chama de "tio" e na casa de quem</segment>
    <segment id="13">, no Engenho de Dentro</segment>
    <segment id="14">, ainda criança</segment>
    <segment id="15">, viu nascer sambas</segment>
    <segment id="16">comocomo "Virada"</segment>
    <segment id="17">, sucesso de Beth Carvalho</segment>
    <segment id="18">, e o enredo campeão da Portela de 1985</segment>
    <segment id="19">, "</segment>
    <segment id="20">Recordar é viver".</segment>
    <segment id="21">O pai de Geórgia também</segment>
    <segment id="22">sese aventurou pela composição.</segment>
    <segment id="23">A mãe desfilava no carnaval.</segment>
    <segment id="24">Resultado: aos seis anos de idade</segment>
    <segment id="25">, estreou</segment>
    <segment id="26">comocomo passista da Canarinhos de Laranjeiras.</segment>
    <segment id="27">De lá para cá</segment>
    <segment id="28">, nunca perdeu um carnaval.</segment>
    <segment id="29">Geórgia tem 35 anos.</segment>
    <segment id="30">São quase 30 anos de samba</segment>
    <segment id="31">, portanto.
- Fiquei nove anos na Unidos da Tijuca.</segment>
    <segment id="32">Saí da escola</segment>
    <segment id="33">, passei pela Vila Isabel</segment>
    <segment id="34">, desfilei no Salgueiro</segment>
    <segment id="35">, masmas</segment>
    <segment id="36">, no ano passado</segment>
    <segment id="37">, voltei para a Tijuca.</segment>
    <segment id="38">Sou muito tijucana.</segment>
    <segment id="39">Tem um corpo e uma simpatia que a tornariam</segment>
    <segment id="40">, facilmente</segment>
    <segment id="41">, candidata séria a musa ou rainha de baterias</segment>
    <segment id="42">, função que hoje chama mais a atenção nos desfiles.</segment>
    <segment id="43">O cantor e compositor Dudu Nobre</segment>
    <segment id="44">, amigo de adolescência da passista</segment>
    <segment id="45">, pode atestar:

- Ela é do Morro Azul</segment>
    <segment id="46">, eu morava no Flamengo.</segment>
    <segment id="47">Quando a Geórgia passava na rua</segment>
    <segment id="48">, parava tudo.</segment>
    <segment id="49">O rebolado dela matava a rapaziada.</segment>
    <segment id="50">É, na atualidade</segment>
    <segment id="51">, uma das grandes passistas do mundo do samba.</segment>
    <segment id="52">Mas Geórgia não está nem aí:

- Não sirvo para musa</segment>
    <segment id="53">, nem sirvo para rainha.</segment>
    <segment id="54">Meu negócio é samba no pé.</segment>
    <segment id="55">É uma paixão que eu tenho.</segment>
    <segment id="56">Não me vejo em outro setor.</segment>
    <segment id="57">Sambando dois meses na China</segment>
    <segment id="58">Geórgia sabe que o setor ao qual é fiel é dos mais desprestigiados no carnaval de hoje.

- A ala de passistas virou uma coisa para tapar buraco na hora do recuo da bateria.</segment>
    <segment id="59">É importante nos ensaios</segment>
    <segment id="60">, masmas</segment>
    <segment id="61">, na hora do desfile</segment>
    <segment id="62">, perde seu valor.</segment>
    <segment id="63">Dudu Nobre atesta outra das qualidades da passista.</segment>
    <segment id="64">Ele tornou-</segment>
    <segment id="65">sese padrinho do Bobó da Geórgia que vem agitando a Lapa.</segment>
    <segment id="66">Ainda não esteve lá</segment>
    <segment id="67">, masmas já provou da iguaria em família:

- Ela já preparou um bobó na casa da minha mãe - diz Dudu.</segment>
    <segment id="68">- Te garanto: é um negócio fantástico.</segment>
    <segment id="69">Com o próximo carnaval ainda distante</segment>
    <segment id="70">, o bobó é hoje a principal atividade de Geórgia.

-</segment>
    <segment id="71">O samba não é meu trabalho.</segment>
    <segment id="72">É minha válvula de escape.</segment>
    <segment id="73">É minha cachaça.

- Ela é uma passista de raiz</segment>
    <segment id="74">, uma passista de chão - diz o jornalista Sidney Rezende</segment>
    <segment id="75">, do SRBD.com</segment>
    <segment id="76">, um site fundamental para quem acompanha a folia carioca</segment>
    <segment id="77">, e que</segment>
    <segment id="78">, há dois anos</segment>
    <segment id="79">, premiou Geórgia com o troféu Estrela do Carnaval.</segment>
    <segment id="80">- Tecnicamente</segment>
    <segment id="81">, ela é perfeita.</segment>
    <segment id="82">Como outras passistas</segment>
    <segment id="83">, Geórgia poderia ser do samba o ano inteiro</segment>
    <segment id="84">, participando de shows em cidades do interior ou até mesmo do exterior</segment>
    <segment id="85">, que promovem carnaval fora de época.</segment>
    <segment id="86">Ela já esteve</segment>
    <segment id="87">, por exemplo</segment>
    <segment id="88">, a serviço do samba</segment>
    <segment id="89">, na China.

- Passei dois meses lá em 2006.</segment>
    <segment id="90">É muito diferente.</segment>
    <segment id="91">Tudo é muito diferente.</segment>
    <segment id="92">O povo mais velho é recatado</segment>
    <segment id="93">, masmas convive com uma juventude muito avançada</segment>
    <segment id="94">, com cabelos coloridos.</segment>
    <segment id="95">Então, fica essa briga entre eles.</segment>
    <segment id="96">Foi a primeira e</segment>
    <segment id="97">, por enquanto</segment>
    <segment id="98">, última experiência de Geórgia no samba tipo exportação.

- Voltei</segment>
    <segment id="99">, engatei num namoro que estou vivendo até hoje - ela tem um filho de 13 anos de uma união anterior ("</segment>
    <segment id="100">masmas ele é

mais do hip hop e do rap") -</segment>
    <segment id="101">, e casamento e viagens não combinam.</segment>
    <segment id="102">Acabei ficando e me acomodando.</segment>
    <segment id="103">Homens não liberam muito</segment>
    <segment id="104">, não.</segment>
    <segment id="105">Faço meu carnaval por aqui mesmo.</segment>
    <segment id="106">Dá menos problema.</segment>
    <segment id="107">A vida a dois é mais difícil na época do carnaval?

- Quando chega o samba</segment>
    <segment id="108">, eu sou do samba.</segment>
    <segment id="109">Aí fica mais difícil administrar.</segment>
    <segment id="110">Mas eu tento coordenar.</segment>
    <segment id="111">Entre mortos e feridos</segment>
    <segment id="112">, a gente está administrando bem.</segment>
    <segment id="113">Ele sabe que metade do meu coração é dele</segment>
    <segment id="114">, masmas a outra metade é do samba.</segment>
    <segment id="115">E ainda sobra um espacinho no coração de Geórgia para as panelas.</segment>
    <segment id="116">Afinal</segment>
    <segment id="117">, comida e samba fazem parte de sua vida desde os tempos da casa de Noca.

- Minha família é de panelas grandes.</segment>
    <segment id="118">A Conceição</segment>
    <segment id="119">, mulher do Noca</segment>
    <segment id="120">, fazia comida enquanto rolava uma roda de samba no terraço do Engenho de Dentro.</segment>
    <segment id="121">Foi assim que aprendi a fazer comida de sambista: feijoada</segment>
    <segment id="122">, mocotó... nada light.</segment>
    <segment id="123">O bobó era a especialidade de Tia Penha</segment>
    <segment id="124">, a irmã do pai de Geórgia.</segment>
    <segment id="125">Num sábado</segment>
    <segment id="126">, ela fez a comida em casa</segment>
    <segment id="127">, para os amigos.</segment>
    <segment id="128">O bobó acabou cedo</segment>
    <segment id="129">, o samba foi até de madrugada.</segment>
    <segment id="130">Os encontros foram</segment>
    <segment id="131">sese repetindo e ficando concorridos.</segment>
    <segment id="132">Juntavam tanta gente que não cabiam mais no Morro Azul.</segment>
    <segment id="133">Em outubro</segment>
    <segment id="134">, a passista resolveu profissionalizar seus dotes culinários.</segment>
    <segment id="135">Levou a fórmula caseira - bobó e samba - para o Centro Cultural Lapa</segment>
    <segment id="136">, uma casa de shows com localização privilegiada</segment>
    <segment id="137">, ao lado do último arco da Lapa.</segment>
    <segment id="138">Na estreia</segment>
    <segment id="139">, a música esteve a cargo de Chiquinho Vírgula</segment>
    <segment id="140">, parceiro de Arlindo Cruz.</segment>
    <segment id="141">A experiência</segment>
    <segment id="142">sese repetiu em janeiro</segment>
    <segment id="143">, com Renato da Rocinha</segment>
    <segment id="144">sese responsabilizando pelo som.</segment>
    <segment id="145">O auge aconteceu no começo deste mês</segment>
    <segment id="146">, quando Noca da Portela apareceu</segment>
    <segment id="147">, em pessoa</segment>
    <segment id="148">, para prestigiar o evento da "sobrinha".</segment>
    <segment id="149">Não sobrou bobó para contar a História.</segment>
    <segment id="150">Uma receita da cozinheira

É ela quem dá aqui a receita do bobó da Lapa:</segment>
    <segment id="151">"</segment>
    <segment id="152">Limpa o camarão"</segment>
    <segment id="153">...</segment>
    <segment id="154">É um começo de receita assustador para quem sabe que Geórgia trabalha sozinha na cozinha.</segment>
    <segment id="155">"</segment>
    <segment id="156">Separa todas as cascas.</segment>
    <segment id="157">Faz um caldo com estas cascas.</segment>
    <segment id="158">Cozinha o aipim neste caldo.</segment>
    <segment id="159">"

Neste ponto</segment>
    <segment id="160">, a receita impressiona cozinheiros amadores outra vez.</segment>
    <segment id="161">São três caixotes de aipim!</segment>
    <segment id="162">"</segment>
    <segment id="163">Bate o aipim com leite de coco.</segment>
    <segment id="164">Deixa guardado.</segment>
    <segment id="165">Refoga o camarão no dendê com alho</segment>
    <segment id="166">, cebola</segment>
    <segment id="167">, pimentão e tomate.</segment>
    <segment id="168">Faz uma mistura bem apurada.</segment>
    <segment id="169">Sal e pimenta à vontade</segment>
    <segment id="170">, é claro.</segment>
    <segment id="171">Taí o bobó da Geórgia.</segment>
    <segment id="172">"</segment>
    <segment id="173">Durante esta entrevista</segment>
    <segment id="174">, Geórgia calçava sandálias</segment>
    <segment id="175">Havaianas.</segment>
    <segment id="176">Quando foi convocada para fazer fotos nos Arcos da Lapa</segment>
    <segment id="177">, subiu no salto.</segment>
    <segment id="178">Literalmente.</segment>
    <segment id="179">Tirou da bolsa um par de sapatos</segment>
    <segment id="180">, trocou as sandálias por ele e ficou 18 centímetros mais alta.

- São mais confortáveis para sambar.</segment>
    <segment id="181">É meu instrumento de trabalho.</segment>
    <segment id="182">Eu queria que as escolas dessem mais valor ao passista.</segment>
    <segment id="183">A gente é muito cobrada</segment>
    <segment id="184">, masmas não tem ajuda.</segment>
    <segment id="185">Muitos passistas não têm nem o dinheiro da passagem de ônibus para chegar ali no desfile.</segment>
