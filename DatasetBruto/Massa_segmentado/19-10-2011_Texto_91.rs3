  <rst>
    <segment id="1">Mortes continuam na Boca do Rio
Bairro volta</segment>
    <segment id="2">a viver um dia de terror</segment>
    <segment id="3">Já são seis o número de mortes</segment>
    <segment id="4">, em apenas  quatro dias</segment>
    <segment id="5">, no bairro Boca do Rio.</segment>
    <segment id="6">Na tarde de ontem</segment>
    <segment id="7">, um homem identificado pela polícia apenas pelo apelido de Monstrinho foi morto com cerca de 13 tiros</segment>
    <segment id="8">, em várias partes do corpo</segment>
    <segment id="9">, na rua João Nunes da Mata</segment>
    <segment id="10">, na localidade da Baixa Fria.</segment>
    <segment id="11">Apesar de acreditar  que  a motivação do crime foi  briga por pontos de tráfico de drogas</segment>
    <segment id="12">, o delegado do Departamento de Homicídios (DHPP)</segment>
    <segment id="13">, Márcio Allan</segment>
    <segment id="14">, afirmou que a morte de Monstrinho não tem relação com as mortes ocorridas nos últimos dias.</segment>
    <segment id="15">“</segment>
    <segment id="16">Parece ser mais uma situação isolada.</segment>
    <segment id="17">Uma disputa por ponto de tráfico”</segment>
    <segment id="18">, disse.</segment>
    <segment id="19">Monstrinho   também era  conhecido</segment>
    <segment id="20">comocomo Popó e Losferato.</segment>
    <segment id="21">Investigação: Suspeita de sequestro</segment>
    <segment id="22">Policiais informaram existir a suspeita de que Monstrinho tenha participado</segment>
    <segment id="23">, há dois meses</segment>
    <segment id="24">, do sequestro da mulher do traficante conhecido</segment>
    <segment id="25">comocomo Nando –  um dos líderes do tráfico de drogas na Boca do Rio.</segment>
    <segment id="26">De acordo com a polícia</segment>
    <segment id="27">, Nando comanda</segment>
    <segment id="28">, inclusive</segment>
    <segment id="29">, o tráfico na rua Simões Filho</segment>
    <segment id="30">, onde  Edileuza Silva dos Santos</segment>
    <segment id="31">, 21, foi morta</segment>
    <segment id="32">, na manhã de segunda-feira</segment>
    <segment id="33">, 17.</segment>
  </rst>
</analysis>