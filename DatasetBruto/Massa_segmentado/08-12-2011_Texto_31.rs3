  <rst>
    <segment id="1">A gata da ladeira do Dois de Julho</segment>
    <segment id="2">No sobe e desce</segment>
    <segment id="3">, Rosi arranca suspiros por onde passa</segment>
    <segment id="4">A gata Rosiane Abreu</segment>
    <segment id="5">, de apenas  19 anos</segment>
    <segment id="6">, mora no bairro</segment>
    <segment id="7">Dois de Julho e garante que não precisa de academia para manter a boa forma.</segment>
    <segment id="8">“</segment>
    <segment id="9">Faço exercícios todos os dias subindo e descendo ladeira no meu bairro</segment>
    <segment id="10">, quando vou trabalhar”</segment>
    <segment id="11">, brinca a moça</segment>
    <segment id="12">, que exibe um corpão por onde passa.</segment>
    <segment id="13">“</segment>
    <segment id="14">A parte do meu corpo que chama mais atenção é o bumbum”</segment>
    <segment id="15">, orgulha-</segment>
    <segment id="16">sese.</segment>
    <segment id="17">Ser dançarina também faz parte dos sonhos da jovem.</segment>
    <segment id="18">“Sempre quis ser dançarina.</segment>
    <segment id="19">Quando era criança brincava com minhas primas imitando o grupo É o Tchan”</segment>
    <segment id="20">, lembra.</segment>
    <segment id="21">Atualmente</segment>
    <segment id="22">, a mulata trabalha</segment>
    <segment id="23">comocomo vendedora</segment>
    <segment id="24">, masmas pensa em cursar faculdade de psicologia.</segment>
    <segment id="25">“Minhas amigas sempre que precisa conversar</segment>
    <segment id="26">, acabam me procurando</segment>
    <segment id="27">, e isso acabou despertando meu interesse pela área”</segment>
    <segment id="28">, conta.</segment>
    <segment id="29">Rosi, como</segment>
    <segment id="30">como é chamada pelas amigas</segment>
    <segment id="31">,  adora frequentar o bairro da Ribeira</segment>
    <segment id="32">, principalmente as casas de shows</segment>
    <segment id="33">, onde a gata vai curtir o melhor do pagode baiano com suas colegas.</segment>
    <segment id="34">“</segment>
    <segment id="35">A banda que eu mais curto é o Saiddy Bamba.</segment>
    <segment id="36">Eu e minhas amigas não perdemos um show”</segment>
    <segment id="37">, diz.</segment>
  </rst>
