  <rst>
    <segment id="1">Êêê paixão!</segment>
    <segment id="2">Pablo arrocha sem cordas</segment>
    <segment id="3">Pablo fará seu desfile em companhia de outros cantores</segment>
    <segment id="4">comocomo Nira Guerreira e Nelsinho
Pablo do Arrocha está com tudo nesse carnaval.</segment>
    <segment id="5">No sábado</segment>
    <segment id="6">, puxará o bloco Arrocha Mutantes</segment>
    <segment id="7">, no circuito Osmar (Avenida)</segment>
    <segment id="8">, e na terça-feira puxará</segment>
    <segment id="9">, pela primeira vez</segment>
    <segment id="10">, um trio sem cordas.</segment>
    <segment id="11">O desfile também ocorrerá no circuito Osmar</segment>
    <segment id="12">, como</segment>
    <segment id="13">como afirmou o presidente do Conselho Municipal do Carnaval (ComCar)</segment>
    <segment id="14">, Fernando Boulhosa.</segment>
    <segment id="15">A voz romântica de Pablo já fez parte de ensaios quentíssimos</segment>
    <segment id="16">, como</segment>
    <segment id="17">como o do Parangolé</segment>
    <segment id="18">, e agora vai marcar presença no próximo  ensaio do Psirico</segment>
    <segment id="19">, onde além de dar uma canja irá participar do DVD do grupo.</segment>
    <segment id="20">O último ensaio do Olodum também promete contar com o arrocheiro</segment>
    <segment id="21">, fazendo uma total mistura de ritmos.</segment>
    <segment id="22">No sábado de Carnaval</segment>
    <segment id="23">, Pablo fará seu desfile em companhia de outros sucessos do romantismo</segment>
    <segment id="24">comocomo Nira Guerreira e Nelsinho do Arrocha.</segment>
    <segment id="25">Com uma bagagem de nove CDs e três DVDs</segment>
    <segment id="26">, não é a primeira vez que Pablo desfila no carnaval.</segment>
    <segment id="27">De acordo com ele</segment>
    <segment id="28">, quando saiu pela primeira vez</segment>
    <segment id="29">, em 2004</segment>
    <segment id="30">, foi uma emoção muito grande e inexplicável</segment>
    <segment id="31">, principalmente</segment>
    <segment id="32">porque</segment>
    <segment id="33">porque estava acostumado a fazer palco.</segment>
    <segment id="34">“Este ano será um carnaval muito especial.</segment>
    <segment id="35">Estamos preparando um cenário muito bacana.</segment>
    <segment id="36">O público pode esperar um grande espetáculo”</segment>
    <segment id="37">, garantiu Pablo.</segment>
    <segment id="38">De Candeias para o Brasil</segment>
    <segment id="39">O jovem de 26 anos</segment>
    <segment id="40">, que poucos conhecem por Agenor Apolinário dos Santos Neto</segment>
    <segment id="41">, sonhava em ser cantor desde os 6 anos</segment>
    <segment id="42">, quando acompanhava o pai nas canções.</segment>
    <segment id="43">Vindo de uma família humilde</segment>
    <segment id="44">, o garoto fazia pequenos serviços</segment>
    <segment id="45">, como</segment>
    <segment id="46">como vender picolé ou frutas</segment>
    <segment id="47">, para ajudar no orçamento da família.</segment>
    <segment id="48">Nascido no município de Candeias</segment>
    <segment id="49">, a 46 km da capital</segment>
    <segment id="50">, Pablo viu a vida mudar quando</segment>
    <segment id="51">, aos 15 anos</segment>
    <segment id="52">, recebeu um convite para assumir os vocais do grupo Asas Livres</segment>
    <segment id="53">, que virou fenômeno na época.</segment>
    <segment id="54">Conhecido</segment>
    <segment id="55">comocomo pai do Arrocha</segment>
    <segment id="56">, o cantor atualmente segue carreira solo e é sucesso no País.</segment>
  </rst>
</analysis>