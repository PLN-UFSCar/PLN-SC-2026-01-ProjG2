  <rst>
    <segment id="1">Thiago Pereira ganha seu primeiro ouro no Pan de Guadalajara
GUADALAJARA</segment>
    <segment id="2">, México - Thiago Pereira venceu na noite deste sábado os 400 metros medley</segment>
    <segment id="3">, com o tempo de 4m16s68</segment>
    <segment id="4">, e deu o primeiro ouro ao Brasil nos Jogos Pan-Americanos de Guadalajara</segment>
    <segment id="5">, no México.</segment>
    <segment id="6">Conor Dwyer (4m18s22) e John Margalis (4m24s88)</segment>
    <segment id="7">, dos Estados Unidos</segment>
    <segment id="8">, completaram o pódio.</segment>
    <segment id="9">Nos 400m medley feminino</segment>
    <segment id="10">, Joana Maranhão ficou com a prata.</segment>
    <segment id="11">Daynara de Paula também levou a prata nos 100m borboleta.</segment>
    <segment id="12">Os 400m medley foi a primeira da maratona de oito que Thiago Pereira pretende cumprir para</segment>
    <segment id="13">sese tornar o maior medalhista de ouros da história do país em jogos pan-americanos.</segment>
    <segment id="14">Ele tem seis</segment>
    <segment id="15">, contra as nove do mesa-tenista Hugo Hoyama</segment>
    <segment id="16">, que está no México para a diputa com equipes.</segment>
    <segment id="17">A segunda prova da maratona de Thiago será neste domingo</segment>
    <segment id="18">, nos 100m costas.

-</segment>
    <segment id="19">Geralmente saio até mais cansado dos 400m medley</segment>
    <segment id="20">, masmas dei uma segurada no final</segment>
    <segment id="21">, aproveitando que estava na frente.</segment>
    <segment id="22">Até porque</segment>
    <segment id="23">porque a semana vai ser longa e com altitude vai ficando cada vez mais difícil - afirmou Thiago logo após a prova.</segment>
    <segment id="24">Joanna Maranhão ficou perto do ouro na final dos 400m medley.</segment>
    <segment id="25">Ela liderou a prova</segment>
    <segment id="26">, caiu para a terceira posição e fechou a prova com 4m46s33.</segment>
    <segment id="27">O ouro ficou com a americana Elizabeth Julia</segment>
    <segment id="28">, com 4m46s15.</segment>
    <segment id="29">A americana Allysa Vavra</segment>
    <segment id="30">, 4m48s05</segment>
    <segment id="31">, levou o bronze.</segment>
    <segment id="32">Nos 100m borboleta</segment>
    <segment id="33">, Daynara de Paula levou a prata com 59s30.</segment>
    <segment id="34">A americana Clair Donahue venceu com 58s73.</segment>
  </rst>
</analysis>