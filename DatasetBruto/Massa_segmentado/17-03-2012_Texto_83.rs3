  <rst>
    <segment id="1">Fidelização de celular?</segment>
    <segment id="2">Tá amarrado!</segment>
    <segment id="3">Empresas de telefonia móvel travam cliente por um ano</segment>
    <segment id="4">, masmas projeto de Lei é contra
Ninguém merece ficar preso em um plano de celular por um ano</segment>
    <segment id="5">, prazo médio de fidelização dos contratos.</segment>
    <segment id="6">O período é considerado muito longo para usuários</segment>
    <segment id="7">comocomo o técnico de radiologia Robson Souza</segment>
    <segment id="8">, 32.</segment>
    <segment id="9">Esse tempo é a principal razão pela qual ele prefere planos pré-pagos.</segment>
    <segment id="10">“Se esse prazo fosse menor</segment>
    <segment id="11">, dava para segurar.</segment>
    <segment id="12">Ou a pessoa espera</segment>
    <segment id="13">, ou paga multa”</segment>
    <segment id="14">, diz.</segment>
    <segment id="15">No entanto</segment>
    <segment id="16">, um projeto de lei do Senado (PLS)</segment>
    <segment id="17">, que será votado nos próximos dias</segment>
    <segment id="18">, estabelece alguns freios para as imposições contratuais de fidelização do consumidor.</segment>
    <segment id="19">O projeto pretende obrigar as empresas de telefonia a oferecerem ao consumidor</segment>
    <segment id="20">, para cada plano com cláusula de fidelização</segment>
    <segment id="21">, um plano alternativo que dispense a vinculação do usuário por prazo determinado.</segment>
    <segment id="22">Além disso</segment>
    <segment id="23">, caberá à operadora esclarecer as diferenças de custos</segment>
    <segment id="24">, vantagens e desvantagens entre os planos</segment>
    <segment id="25">, no ato da contratação.</segment>
    <segment id="26">De acordo com a coordenadora institucional da Associação Brasileira de Defesa do Consumidor (Pro Teste)</segment>
    <segment id="27">, Maria Inês Dolci</segment>
    <segment id="28">, “as cláusulas de fidelização são abusivas</segment>
    <segment id="29">, já que o consumidor fica sem a opção de migrar para outro plano”.</segment>
    <segment id="30">Sem liberdade</segment>
    <segment id="31">O relator do projeto</segment>
    <segment id="32">, senador Clóvis Fecury (PMDB-MA)</segment>
    <segment id="33">, apresentou voto pela aprovação do assunto</segment>
    <segment id="34">, com alterações</segment>
    <segment id="35">, reduzindo o período máximo de fidelidade de 18 para 12 meses.</segment>
    <segment id="36">Ainda assim</segment>
    <segment id="37">, o quesito fidelização incomoda os consumidores.</segment>
    <segment id="38">Para a servidora pública Maiana Teixeira</segment>
    <segment id="39">, 31, a vantagem de contratos de planos de telefonia com fidelização é a possibilidade de redução de custos.</segment>
    <segment id="40">“Mas você fica amarrado e sem liberdade para questionar determinados itens do contrato”</segment>
    <segment id="41">, comenta.</segment>
    <segment id="42">Fique esperto na hora de escolher seu plano

Perfil - Faça uma média do seu consumo durante o ano e verifique os serviços que mais utiliza (minutos</segment>
    <segment id="43">, torpedos</segment>
    <segment id="44">, pacote de dados).</segment>
    <segment id="45">A partir disso</segment>
    <segment id="46">, trace o seu perfil e procure nas operadoras o plano que melhor satisfaça suas necessidades.

Internet - Ao achar um plano 2</segment>
    <segment id="47">G mais atraente em uma empresa concorrente</segment>
    <segment id="48">, tente negociar bônus ou descontos com sua operadora.</segment>
    <segment id="49">Caso contrário</segment>
    <segment id="50">, é possível fazer a portabilidade</segment>
    <segment id="51">, respeitando a carência do contrato.</segment>
    <segment id="52">Compare - Acesse a ferramenta da Pro Teste que ajuda a indicar o plano mais indicado (www.proteste.org.br/ServiceSelector/ PlanosTelefonia</segment>
    <segment id="53">Celular/</segment>
    <segment id="54">BR/</segment>
  </rst>
</analysis>