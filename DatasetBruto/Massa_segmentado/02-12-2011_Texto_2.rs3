  <rst>
    <segment id="1">Porteiros 171 são presos por golpe</segment>
    <segment id="2">Polícia prende 11 pessoas</segment>
    <segment id="3">, sendo 4 funcionários de prédios que violavam cartas</segment>
    <segment id="4">Uma quadrilha especializada em clonagem de cartões de crédito e bancários foi desarticulada ontem</segment>
    <segment id="5">, com a prisão de onze pessoas.</segment>
    <segment id="6">Entre os envolvidos nos golpes – que teriam causado um prejuízo total de R$ 500 mil – estão quatro porteiros de condomínios</segment>
    <segment id="7">, que, violavam as correspondências de moradores e repassavam os dados para os cúmplices</segment>
    <segment id="8">, responsáveis por efetuar as fraudes.</segment>
    <segment id="9">“</segment>
    <segment id="10">Com as informações conseguidas com os porteiros</segment>
    <segment id="11">, os outros integrantes da quadrilha</segment>
    <segment id="12">sese passavam pelas vítimas e conseguiam junto às centrais de atendimento novos cartões</segment>
    <segment id="13">, que eram enviados ao mesmo endereço e retidos pelos porteiros”</segment>
    <segment id="14">, explicou a trama o delegado Charles Leão.</segment>
    <segment id="15">Munidos de 11 mandados de prisão preventiva e outros 14 de busca e apreensão (expedidos pela juíza Ivone Bessa</segment>
    <segment id="16">, da 1ª Vara Criminal)</segment>
    <segment id="17">, 43 policiais civis</segment>
    <segment id="18">, entre delegados e investigadores</segment>
    <segment id="19">, desencadearam a Operação Platino</segment>
    <segment id="20">, efetuando as prisões nas residências e nos locais de trabalho dos acusados</segment>
    <segment id="21">, por volta de 7 horas.</segment>
    <segment id="22">Apontado</segment>
    <segment id="23">comocomo mentor do esquema</segment>
    <segment id="24">, Valdinei Souza dos Santos</segment>
    <segment id="25">, conhecido</segment>
    <segment id="26">comocomo Nei</segment>
    <segment id="27">, 29 anos</segment>
    <segment id="28">, e a mulher dele</segment>
    <segment id="29">, Emanuela Oliveira Santos</segment>
    <segment id="30">, 31, foram presos no apartamento do casal na Boca do Rio.</segment>
    <segment id="31">Tudo errado: Tinha até gente armada</segment>
    <segment id="32">Os porteiros presos são Felipe Ferreira Lima</segment>
    <segment id="33">, 26, funcionário do Edifício Mansão Imperial Boulevard</segment>
    <segment id="34">, no Horto Florestal</segment>
    <segment id="35">, Brotas</segment>
    <segment id="36">; Ednei Carvalho Neves</segment>
    <segment id="37">, 31, empregado do Condomínio Amazônia</segment>
    <segment id="38">, na Avenida Paralela</segment>
    <segment id="39">; e Vagner Valdo Rocha Rodrigues</segment>
    <segment id="40">, 29, e Josenildo Silva da Silva</segment>
    <segment id="41">, conhecido</segment>
    <segment id="42">comocomo Big</segment>
    <segment id="43">, que trabalham no Condomínio Mirantes do Atlântico</segment>
    <segment id="44">, Jardim Armação.</segment>
    <segment id="45">Todos foram encaminhados à sede do Departamento de Crimes</segment>
    <segment id="46">Contra o Patrimônio  na Piedade – assim</segment>
    <segment id="47">comocomo Waldemar Silva Filho</segment>
    <segment id="48">, o Dimas</segment>
    <segment id="49">, 34 (que também foi autuado por porte ilegal de arma</segment>
    <segment id="50">, uma vez que foi flagrado com uma pistola)</segment>
    <segment id="51">, Jânio Silva Arcanjo</segment>
    <segment id="52">, 35, o motorista José dos Santos Camedo</segment>
    <segment id="53">, o Peu</segment>
    <segment id="54">, 37, empregado de condôminos e a companheira dele.</segment>
  </rst>
</analysis>