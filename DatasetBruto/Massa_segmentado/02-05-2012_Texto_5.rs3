  <rst>
    <segment id="1">Construído pela Delta</segment>
    <segment id="2">, prédio do TJ do Rio tem rachaduras
RIO - Um mês depois do aparecimento de rachaduras nas paredes do novo anexo do Tribunal de Justiça do Rio</segment>
    <segment id="3">, obra da Delta Construções inaugurada em 2007</segment>
    <segment id="4">, funcionários continuam com medo de passar pelo local.</segment>
    <segment id="5">A Lâmina 3 apresentou em março falhas nas paredes.</segment>
    <segment id="6">O tribunal afirma que a estrutura do prédio não corre riscos</segment>
    <segment id="7">, masmas há temor de que obras de ampliação do prédio</segment>
    <segment id="8">, conduzida pela empresa</segment>
    <segment id="9">, possam estar causando o problema.</segment>
    <segment id="10">Depois de vistoria no prédio</segment>
    <segment id="11">, o Conselho Regional de Engenharia e Agronomia do Rio (Crea-RJ) aconselhou</segment>
    <segment id="12">, na época</segment>
    <segment id="13">, que o tribunal contratasse uma empresa sem ligações com a construtora para avaliar riscos e acompanhar a situação.</segment>
    <segment id="14">O presidente do Crea-RJ</segment>
    <segment id="15">, Agostinho Guerreiro</segment>
    <segment id="16">, disse que</segment>
    <segment id="17">, apesar de não haver risco de colapso</segment>
    <segment id="18">, era desejável acompanhar a situação.

- Detectamos rachaduras</segment>
    <segment id="19">, masmas nada que pusesse a estrutura em risco.</segment>
    <segment id="20">Como não é nosso papel emitir laudo formal</segment>
    <segment id="21">, recomendamos a contratação de profissional especializado.</segment>
    <segment id="22">Nesta quarta-feira</segment>
    <segment id="23">, o TJ-RJ afirmou que a construtora está analisando o que deve ser feito e realizará reparos.</segment>
    <segment id="24">Em nota</segment>
    <segment id="25">, disse que</segment>
    <segment id="26">, além do Crea-RJ</segment>
    <segment id="27">, vistoriaram o prédio a Defesa Civil e o engenheiro Bruno Contarini</segment>
    <segment id="28">, projetista da Ponte Rio-Niterói</segment>
    <segment id="29">, contratado para avaliação independente</segment>
    <segment id="30">, além de engenheiros da Delta.</segment>
    <segment id="31">E que todos concluíram que não há riscos.</segment>
    <segment id="32">Segundo a Diretoria Geral de Engenharia</segment>
    <segment id="33">, medições demonstraram que a movimentação da estrutura da edificação está dentro dos limites esperados</segment>
    <segment id="34">, e que a estrutura está estabilizada.</segment>
  </rst>
</analysis>