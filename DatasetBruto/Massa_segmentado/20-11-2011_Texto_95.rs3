    <segment id="1">'Perdemos um título que estava na mão'</segment>
    <segment id="2">, diz volante do Botafogo
RIO - Após a derrota para o Internacional</segment>
    <segment id="3">, por 2 a 1</segment>
    <segment id="4">, no Engenhão</segment>
    <segment id="5">, o volante do Botafogo Marcelo Mattos admitiu que o time decepcionou a torcida
- É triste.</segment>
    <segment id="6">Começamos o ano desacreditados e ao longo da temporada passamos confiança para a torcida.</segment>
    <segment id="7">Agora a gente decepcionou.</segment>
    <segment id="8">Infelizmente não estamos com sorte.</segment>
    <segment id="9">Perdemos um título que estava na nossa mão.</segment>
    <segment id="10">Foi a sexta derrota do Botafogo nos últimos sete jogos</segment>
    <segment id="11">, e a quarta seguida.</segment>
    <segment id="12">Com a sequência</segment>
    <segment id="13">, o alvinegro caiu para a oitava colocação.

- Sempre após os jogos</segment>
    <segment id="14">, eu chego em casa e meu filho pergunta</segment>
    <segment id="15">sese ganhamos.</segment>
    <segment id="16">Mas a gente continua perdendo!</segment>
    <segment id="17">Peço desculpas ao torcedor.</segment>
    <segment id="18">Todos erramos</segment>
    <segment id="19">, masmas estamos tentamos fazer o melhor dentro de campo - lamentou o camisa 5.</segment>
