  <rst>
    <segment id="1">No rastro de Platini</segment>
    <segment id="2">, Kim dá as caras no Vasco
VASCO: Julinho e Eduardo Costa são inscritos na CBF
BLOG: 'Meu Caldeirão'</segment>
    <segment id="3">, o blog do torcedor do Vasco

- Em dois meses de clube</segment>
    <segment id="4">, apareci para toda a França.</segment>
    <segment id="5">Aqui, vou dar minha resposta dentro de campo - avisou</segment>
    <segment id="6">, ciente de que chega desconhecido do torcedor.</segment>
    <segment id="7">- A desconfiança é natural</segment>
    <segment id="8">, até por eu estar oito anos fora</segment>
    <segment id="9">, masmas todos verão o resultado.</segment>
    <segment id="10">Consta que Kim está numa lista dos onze maiores jogadores do Nancy.</segment>
    <segment id="11">O site oficial do clube não confirma</segment>
    <segment id="12">, masmas seu perfil</segment>
    <segment id="13">, com foto</segment>
    <segment id="14">, aparece com destaque na galeria dos jogadores com passagem destacada.</segment>
    <segment id="15">Sua transferência para o Vasco também foi noticiada.</segment>
    <segment id="16">Kim só não pode</segment>
    <segment id="17">sese orgulhar de</segment>
    <segment id="18">, como</segment>
    <segment id="19">como Platini</segment>
    <segment id="20">, ter sido formado nas divisões de base e conquistado um dos quatro títulos da Segunda Divisão</segment>
    <segment id="21">, como</segment>
    <segment id="22">como o ex-astro francês.

- Platini aparecia sempre</segment>
    <segment id="23">poispois foi formado lá.</segment>
    <segment id="24">É bom para mim ser lembrado pelo clube dessa forma - disse Kim</segment>
    <segment id="25">, que foi da Arábia Saudita para a França</segment>
    <segment id="26">, e de lá para o Qatar.</segment>
    <segment id="27">- Preciso de um trabalho físico para recuperar meu futebol.</segment>
    <segment id="28">O lateral Julinho e o volante Eduardo Costa foram regularizados e estão à disposição para o jogo contra o Atlético-MG</segment>
    <segment id="29">, no domingo</segment>
    <segment id="30">, no Ipatingão.</segment>
    <segment id="31">Com Felipe suspenso</segment>
    <segment id="32">, Juninho Pernambucano</segment>
    <segment id="33">, que poderia ser poupado</segment>
    <segment id="34">, deve jogar.</segment>
    <segment id="35">Rodrigo Pimpão não teve o contrato renovado e será emprestado.</segment>
  </rst>
</analysis>