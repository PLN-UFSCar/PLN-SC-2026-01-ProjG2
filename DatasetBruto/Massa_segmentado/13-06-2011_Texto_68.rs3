  <rst>
    <segment id="1">Email diz antecipar resultado e gera polêmica na escolha de agência de publicidade do Banco do Brasil
RIO e BRASÍLIA - O processo para escolher as novas agências de marketing do Banco do Brasil (BB) gera polêmica no meio publicitário.</segment>
    <segment id="2">No último fim de semana</segment>
    <segment id="3">, entre sexta-feira e sábado</segment>
    <segment id="4">, um e-mail apócrifo</segment>
    <segment id="5">, enviado a todas as 21 empresas de propaganda que disputam uma verba de R$ 420 milhões por ano</segment>
    <segment id="6">, anunciava os motes publicitários mais bem colocados na disputa e</segment>
    <segment id="7">, portanto</segment>
    <segment id="8">, os possíveis vencedores.</segment>
    <segment id="9">O resultado da primeira fase</segment>
    <segment id="10">, com as notas das empresas</segment>
    <segment id="11">, sai na manhã desta terça-feira em Brasília.</segment>
    <segment id="12">Caso a denúncia seja confirmada</segment>
    <segment id="13">, o banco pode cancelar a licitação</segment>
    <segment id="14">, de acordo com fontes envolvidas</segment>
    <segment id="15">, mostra reportagem de Bruno Rosa e Regina Alvarez publica nesta terça-feira pelo jornal</segment>
    <segment id="16">O GLOBO.</segment>
    <segment id="17">Para participar da licitação</segment>
    <segment id="18">, cada agência teve de elaborar uma proposta.</segment>
    <segment id="19">Além de toda a estratégia de marketing</segment>
    <segment id="20">, havia a criação de um mote publicitário.</segment>
    <segment id="21">Segundo o e-mail</segment>
    <segment id="22">, os slogans mais bem pontuados</segment>
    <segment id="23">, na ordem</segment>
    <segment id="24">, seriam "</segment>
    <segment id="25">O melhor do Brasil para os brasileiros.</segment>
    <segment id="26">Todo seu"</segment>
    <segment id="27">, "</segment>
    <segment id="28">É diferente.</segment>
    <segment id="29">É todo seu" e "BB.</segment>
    <segment id="30">Mais seu.</segment>
    <segment id="31">Mais Brasil".</segment>
    <segment id="32">De acordo com a mensagem</segment>
    <segment id="33">, o segundo mote mais bem pontuado seria da agência carioca Artplan</segment>
    <segment id="34">, que atende o BB há cinco anos.</segment>
    <segment id="35">Além da Artplan</segment>
    <segment id="36">, a agência Master</segment>
    <segment id="37">, com sede no Paraná</segment>
    <segment id="38">, também é responsável pela campanha publicitária do banco.</segment>
    <segment id="39">Segundo fontes</segment>
    <segment id="40">, a agência seria dona de um dos outros dois motes mais bem pontuados.</segment>
    <segment id="41">Nessa nova licitação</segment>
    <segment id="42">, o BB irá escolher três agências.</segment>
    <segment id="43">As vencedoras começam a trabalhar para a instituição financeira em outubro</segment>
    <segment id="44">, em um contrato anual que é renovado automaticamente a cada 12 meses</segment>
    <segment id="45">, ao longo de cinco anos.
Procuradas</segment>
    <segment id="46">, as agências não quiseram</segment>
    <segment id="47">sese pronunciar.</segment>
    <segment id="48">No fim de abril</segment>
    <segment id="49">, em uma audiência pública</segment>
    <segment id="50">, em Brasília</segment>
    <segment id="51">, todos os motes das 21 agências</segment>
    <segment id="52">sese tornaram públicos.</segment>
    <segment id="53">É que, na ocasião</segment>
    <segment id="54">, conforme previsto em lei</segment>
    <segment id="55">, todas as propostas são abertas para verificar</segment>
    <segment id="56">sese não há nenhum tipo de identificação.</segment>
    <segment id="57">Em nota</segment>
    <segment id="58">, o BB desqualificou o conteúdo do e-mail.</segment>
    <segment id="59">"</segment>
    <segment id="60">O Banco do Brasil reafirma seu compromisso com a seriedade desta e de outras licitações que conduz"</segment>
    <segment id="61">, diz a nota.</segment>
    <segment id="62">Após a divulgação do resultado da análise das propostas técnicas</segment>
    <segment id="63">, restarão duas fases para a conclusão do processo de seleção das três agências.</segment>
  </rst>
</analysis>