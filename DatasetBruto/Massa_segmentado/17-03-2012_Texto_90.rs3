  <rst>
    <segment id="1">Estuprador diz que vítima era</segment>
    <segment id="2">casocaso dele
Ela até fingiu que gostou por medo do cara</segment>
    <segment id="3">, que diz que já ficou com ela
Estuprou ou não estuprou?</segment>
    <segment id="4">Eis a questão.</segment>
    <segment id="5">Rosângela Silva dos Santos</segment>
    <segment id="6">, 38 anos</segment>
    <segment id="7">, grávida de quatro meses</segment>
    <segment id="8">, diz que Fernando de Barros Filho</segment>
    <segment id="9">, 29,  a estuprou na madrugada de ontem</segment>
    <segment id="10">, dentro de sua casa</segment>
    <segment id="11">, no Jardim Nova Esperança.</segment>
    <segment id="12">“Fernandinho  me ameaçou com uma faca e disse que</segment>
    <segment id="13">, sese eu não fizesse o que ele queria</segment>
    <segment id="14">, iria me matar e matar minha filha”</segment>
    <segment id="15">, disse ela</segment>
    <segment id="16">, contando ainda ter fingido estar gostando</segment>
    <segment id="17">, por medo.</segment>
    <segment id="18">Fernandinho</segment>
    <segment id="19">, como</segment>
    <segment id="20">como é chamado o acusado</segment>
    <segment id="21">, disse que a mulher está mentindo e não faz nada sem o consentimento dela.</segment>
    <segment id="22">“</segment>
    <segment id="23">Já fiquei com ela três vezes.</segment>
    <segment id="24">Às vezes eu  intimava  ela e outras ela que me chamava.</segment>
    <segment id="25">Ontem ela me chamou”</segment>
    <segment id="26">, defendeu-</segment>
    <segment id="27">sese o rapaz.</segment>
    <segment id="28">A mulher dele</segment>
    <segment id="29">, Claudia Sueli Tourinho de Oliveira</segment>
    <segment id="30">, 39,  mesmo depois da galhada</segment>
    <segment id="31">, foi à 10ª DT (Pau da Lima) para defender o companheiro.</segment>
    <segment id="32">“</segment>
    <segment id="33">Meu marido não é estuprador!</segment>
    <segment id="34">Ele disse que tinha me traído”</segment>
    <segment id="35">, contou.</segment>
    <segment id="36">No final das contas</segment>
    <segment id="37">, Fernandinho foi preso</segment>
    <segment id="38">, indiciado pelo crime de estupro e</segment>
    <segment id="39">, inclusive</segment>
    <segment id="40">, já apanhou dos outros presos.</segment>
    <segment id="41">Miserê
Fernandinho pega geral</segment>
    <segment id="42">Rosângela mostou ainda dois cortes na mão esquerda.</segment>
    <segment id="43">“Tentei tomar a faca da mão dele e ele puxou”</segment>
    <segment id="44">, contou.</segment>
    <segment id="45">O rapaz disse não saber de nenhum corte.</segment>
    <segment id="46">Os dois</segment>
    <segment id="47">sese conhecem desde criança e ele</segment>
    <segment id="48">, inclusive</segment>
    <segment id="49">, afirmou já ter</segment>
    <segment id="50">sese relacionado com a irmã de Rosângela.</segment>
    <segment id="51">“</segment>
    <segment id="52">Não sou esse gostosão todo.</segment>
    <segment id="53">Mas sei intimar uma mulher”</segment>
    <segment id="54">, gabava-</segment>
    <segment id="55">sese.</segment>
    <segment id="56">“Sou um homem de bem.</segment>
    <segment id="57">Tenho irmã e sobrinha e nunca desejaria que fizessem isso com uma delas.</segment>
    <segment id="58">Não sei</segment>
    <segment id="59">porque</segment>
    <segment id="60">porque Rosângela fez isso.</segment>
    <segment id="61">Vou prestar queixa contra ela”.</segment>
  </rst>
</analysis>