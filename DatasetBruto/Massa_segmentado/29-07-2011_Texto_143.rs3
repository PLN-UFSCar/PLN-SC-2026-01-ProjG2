  <rst>
    <segment id="1">Ventania deixa seis feridos na Quinta da Boa Vista
RIO - As rajadas de até 80km/h que atingiram o Rio no fim de semana deixaram</segment>
    <segment id="2">, no sábado</segment>
    <segment id="3">, seis feridos na Quinta da Boa Vista</segment>
    <segment id="4">, um deles dentro do zoológico.</segment>
    <segment id="5">A ventania começou por volta de meio-dia e assustou os visitantes.</segment>
    <segment id="6">Segundo estimativa do Zoo-Rio</segment>
    <segment id="7">, cerca de nove mil pessoas estavam no local na hora do incidente.</segment>
    <segment id="8">Um galho seco caiu sobre uma mulher de 35 anos</segment>
    <segment id="9">, que teve uma vértebra fraturada e precisou ser atendida no Hospital Souza Aguiar.</segment>
    <segment id="10">Os outros feridos sofreram escoriações leves e foram atendidos no ambulatório do próprio zoo.</segment>
    <segment id="11">O dentista Leandro Vieira</segment>
    <segment id="12">, de 36 anos</segment>
    <segment id="13">, estava no local com a mãe e o filho de 2 anos quando as rajadas começaram.

-</segment>
    <segment id="14">As pessoas</segment>
    <segment id="15">sese assustaram com as quedas de galhos e o isolamento de algumas áreas.</segment>
    <segment id="16">Como estava com meu filho</segment>
    <segment id="17">, procurei um lugar seguro e aguardei a ventania passar - relembrou Braga</segment>
    <segment id="18">, que enviou fotos ao Eu-repórter</segment>
    <segment id="19">, a seção de jornalismo participativo do GLOBO.</segment>
    <segment id="20">A equipe de emergência do Zoo-Rio foi acionada</segment>
    <segment id="21">, masmas nenhum dos 2.500 animais</segment>
    <segment id="22">sese feriu.</segment>
    <segment id="23">Segundo a diretoria do zoológico</segment>
    <segment id="24">, as árvores são podadas regularmente para evitar acidentes.</segment>
    <segment id="25">De acordo com o meteorologista Lúcio de Souza</segment>
    <segment id="26">, do Instituto Nacional de Meteorologia (Inmet)</segment>
    <segment id="27">, uma frente fria estacionada entre São Paulo e Rio causou os corredores de ar no litoral fluminense.</segment>
    <segment id="28">No sábado</segment>
    <segment id="29">, os ventos chegaram a 79 km/h na estação de Santa Cruz.</segment>
    <segment id="30">O especialista prevê que os ventos permanecerão ao menos até quarta-feira e diz que nesta segunda-feira as rajadas podem chegar a 80 km/h.</segment>
    <segment id="31">Já Bianca Lobo</segment>
    <segment id="32">, do Instituto Climatempo</segment>
    <segment id="33">, prevê rajadas mais fortes entre terça e quarta-feira</segment>
    <segment id="34">, quando um ciclone formado no Sul influenciará na chegada de uma frente fria</segment>
    <segment id="35">, que vem acompanhada de uma massa de ar polar e deve deixar o tempo fechado.</segment>
    <segment id="36">Segundo os meteorologistas</segment>
    <segment id="37">, há possibilidade de chuva ao longo de toda semana</segment>
    <segment id="38">, que deve ter grandes oscilações de temperatura.</segment>
    <segment id="39">Eles dizem ainda que as frentes frias que passarão pelo estado nesta semana influenciarão principalmente o Litoral Sul</segment>
    <segment id="40">, estendo-</segment>
    <segment id="41">sese à Região Metropolitana ocasionalmente.</segment>
    <segment id="42">O sol deve aparecer entre nuvens até quinta-feira</segment>
    <segment id="43">, o que garante dias abafados.</segment>
    <segment id="44">Para esta segunda-feira</segment>
    <segment id="45">, o Inmet prevê temperaturas entre 16 e 29 graus</segment>
    <segment id="46">, subindo para entre 17 e 34 graus amanhã.</segment>
    <segment id="47">No entanto</segment>
    <segment id="48">, com a chegada da frente fria na quarta-feira</segment>
    <segment id="49">, a temperatura deve cair.</segment>
    <segment id="50">Na sexta-feira</segment>
    <segment id="51">, o sol deve reaparecer.</segment>
  </rst>
</analysis>