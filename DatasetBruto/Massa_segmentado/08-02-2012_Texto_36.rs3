  <rst>
    <segment id="1">Boninho não curtiu comentário de Faustão 
Faustão comentou em seu último programa sobre a possibilidade de Daniel voltar ao BBB</segment>
    <segment id="2">O diretor do BBB</segment>
    <segment id="3">, Boninho</segment>
    <segment id="4">, não aprovou o comentário feito por Faustão</segment>
    <segment id="5">, no último domingo</segment>
    <segment id="6">, para colocar Daniel de volta ao programa.</segment>
    <segment id="7">Ao responder a um de seus seguidores no Twitter</segment>
    <segment id="8">, que questionou sobre a possibilidade de o paulista voltar ao reality</segment>
    <segment id="9">, Boninho escreveu:</segment>
    <segment id="10">“É uma opinião.</segment>
    <segment id="11">Só isso.</segment>
    <segment id="12">Cada um tem a sua.</segment>
    <segment id="13">Não cuida do BBB”.</segment>
    <segment id="14">Retou-</segment>
    <segment id="15">sese!</segment>
