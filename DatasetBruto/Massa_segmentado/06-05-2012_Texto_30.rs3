  <rst>
    <segment id="1">Morte de filho de Policial é mistério</segment>
    <segment id="2">Assassinos já chegaram atirando e nem falaram nada para a vítima</segment>
    <segment id="3">Um jovem trabalhador e querido no bairro onde foi criado.</segment>
    <segment id="4">Esse era o perfil de Danilo dos Santos Barreto</segment>
    <segment id="5">, 24 anos</segment>
    <segment id="6">, conforme vizinhos e familiares.</segment>
    <segment id="7">Funcionário do setor de vendas da loja Riachuelo</segment>
    <segment id="8">, o rapaz foi morto com dois tiros na região da axila</segment>
    <segment id="9">, na Rua Sarapião</segment>
    <segment id="10">, bairro Alto do Peru</segment>
    <segment id="11">, por volta das 12h30 de ontem</segment>
    <segment id="12">, logo após sair de casa para ir ao trabalho.</segment>
    <segment id="13">Danilo era filho do policial militar da reserva Jailton Barreto.</segment>
    <segment id="14">Policiais do Serviço de Investigação da Delegacia de São Caetano afirmam que existem várias hipóteses para o homicídio.</segment>
    <segment id="15">Uma das principais é que a vítima pode ter sido confundida com o indivíduo conhecido</segment>
    <segment id="16">comocomo Pio</segment>
    <segment id="17">, vizinho de Danilo que é envolvido no crime e fisicamente</segment>
    <segment id="18">sese parece muito com ele.</segment>
    <segment id="19">Testemunhas contaram aos policiais que Danilo tentou correr ao perceber a chegada dos dois matadores.</segment>
    <segment id="20">O crime começou a ser apurado pela Delegacia de São Caetano</segment>
    <segment id="21">, pois</segment>
    <segment id="22">pois, inicialmente</segment>
    <segment id="23">, a polícia suspeitou</segment>
    <segment id="24">sese tratar de um latrocínio (roubo seguido de morte).</segment>
    <segment id="25">Porém, a hipótese foi descartada</segment>
    <segment id="26">, na tarde de ontem</segment>
    <segment id="27">, e as investigações estão agora com o Departamento de Homicídios (DHPP).</segment>
    <segment id="28">Sem ficha na polícia</segment>
    <segment id="29">Policiais da Delegacia de São Caetano também não descartam</segment>
    <segment id="30">, como</segment>
    <segment id="31">como motivo do crime</segment>
    <segment id="32">, possíveis rivalidades de jovens do Alto do Peru com os vizinhos do Barro Branco</segment>
    <segment id="33">, Brejal</segment>
    <segment id="34">, Fonte do Capim e Largo do Tanque.</segment>
    <segment id="35">Segundo a polícia</segment>
    <segment id="36">, os dois matadores estavam em uma pickup</segment>
    <segment id="37">Hoggar da Peugeot (placa NYP-0527)</segment>
    <segment id="38">, cor branca.</segment>
    <segment id="39">O veículo foi roubado</segment>
    <segment id="40">, ontem de manhã</segment>
    <segment id="41">, no bairro IAPI</segment>
    <segment id="42">, e abandonado no Bom Juá</segment>
    <segment id="43">, logo depois o crime.</segment>
    <segment id="44">Após ser baleada</segment>
    <segment id="45">, a vítima ainda foi levada de carro</segment>
    <segment id="46">, pelo próprio pai</segment>
    <segment id="47">, ao Hospital Ernesto Simões.</segment>
    <segment id="48">A vítima não tinha ficha na polícia.</segment>
  </rst>
</analysis>