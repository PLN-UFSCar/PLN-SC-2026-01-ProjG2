  <rst>
    <segment id="1">Atirador malvadão é preso</segment>
    <segment id="2">Disparou no inimigo que foi mexer com a mulher errada</segment>
    <segment id="3">Um dos autores das duas tentativas de homicídio</segment>
    <segment id="4">, ocorridas na tarde do último domingo</segment>
    <segment id="5">, 23, na localidade da Baixa Fria</segment>
    <segment id="6">, no bairro Boca do Rio</segment>
    <segment id="7">, foi preso na noite de ontem</segment>
    <segment id="8">, durante uma operação de policiais militares e dos civis da 9ª DT (Boca do Rio).</segment>
    <segment id="9">O pedreiro Diogo Oliveira Santana</segment>
    <segment id="10">, 24 anos</segment>
    <segment id="11">, confessou ter disparado contra Leandro Santos dos Santos</segment>
    <segment id="12">, 20, conhecido</segment>
    <segment id="13">comocomo Neguinho</segment>
    <segment id="14">, que está internado  no HGE.</segment>
    <segment id="15">Neguinho levou  um tiro na cabeça e outro no peito esquerdo.</segment>
    <segment id="16">“Ele (Neguinho) queria ir contra minha vida por causa de uma mulher que eu estava pegando e ele  disse que era dele”</segment>
    <segment id="17">, contou.</segment>
    <segment id="18">Diogo disse que agiu com um comparsa conhecido</segment>
    <segment id="19">comocomo Tointoin</segment>
    <segment id="20">, que, segundo ele</segment>
    <segment id="21">, teria atirado contra Anderson Santos Oliveira</segment>
    <segment id="22">, 18.</segment>
    <segment id="23">A vítima foi levada ao Hospital Roberto Santos</segment>
    <segment id="24">, após ser baleada na boca e na perna direita.</segment>
    <segment id="25">Tointoin</segment>
    <segment id="26">, que está foragido</segment>
    <segment id="27">, teria lhe emprestado o revólver 38 usado para atirar em Neguinho.</segment>
    <segment id="28">As pirraças de  Neguinho também foram motivações para o crime.</segment>
    <segment id="29">“Neguinho estava</segment>
    <segment id="30">sese achando</segment>
    <segment id="31">porque</segment>
    <segment id="32">porque matou Monstrinho.</segment>
    <segment id="33">Matou um cara e acha que é dono do mundo”</segment>
    <segment id="34">, disse Diogo.</segment>
    <segment id="35">Segundo ele</segment>
    <segment id="36">, Neguinho vivia dizendo que comandava a área do Borel e “quem fosse para cima ia ser daquele jeito”.</segment>
    <segment id="37">“Ele disse que não faz parte de nenhuma facção e  não participou da chacina.</segment>
    <segment id="38">Mas, vamos investigar.</segment>
    <segment id="39">Até mesmo</segment>
    <segment id="40">sese ele tem  participação em outros crimes”</segment>
    <segment id="41">, afirmou a delegada titular da 9ª DT</segment>
    <segment id="42">, Fernanda Porfírio.</segment>
    <segment id="43">Já era fichado por furto de celular</segment>
    <segment id="44">Diogo reside na localidade do Borel</segment>
    <segment id="45">, próximo ao Centro de Convenções</segment>
    <segment id="46">, onde residiriam também os traficantes Alex</segment>
    <segment id="47">, Leleco e onde morava Monstrinho</segment>
    <segment id="48">, morto a tiros</segment>
    <segment id="49">, na semana passada</segment>
    <segment id="50">, na Baixa Fria.</segment>
    <segment id="51">Diogo foi preso em flagrante e vai responder por porte ilegal de arma e tentativa de homicídio.</segment>
    <segment id="52">Tointoin (foto ao lado) está foragido.</segment>
    <segment id="53">Policiais  da 9ª DT fizeram buscas</segment>
    <segment id="54">, ontem à noite</segment>
    <segment id="55">, no Boreal</segment>
    <segment id="56">, masmas o barraco onde ele mora estava vazio.</segment>
    <segment id="57">Diogo já tinha ficha na polícia.</segment>
    <segment id="58">Ele foi preso</segment>
    <segment id="59">, em 2006</segment>
    <segment id="60">, depois de furtar um celular.</segment>
  </rst>
</analysis>