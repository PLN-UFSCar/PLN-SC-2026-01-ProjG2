  <rst>
    <segment id="1">Mij횄쨉es e suj횄쨉es est횄짙o na mira da lei</segment>
    <segment id="2">No primeiro dia de puni횄짠횄짙o</segment>
    <segment id="3">, fiscais da Limpurb notificaram 21 pessoas</segment>
    <segment id="4">Fiscais da Limpurb notificaram 21 pessoas no primeiro dia de puni횄짠횄짙o a quem descarta lixo de forma irregular ou urina nas ruas.</segment>
    <segment id="5">Ningu횄짤m foi multado.</segment>
    <segment id="6">Os fiscais atuaram no Com횄짤rcio</segment>
    <segment id="7">, Pelourinho e nas avenidas Sete de Setembro e Joana Ang횄짤lica.</segment>
    <segment id="8">Apenas uma pessoa foi flagrada pela fiscaliza횄짠횄짙o urinando em via p횄쨘blica.</segment>
    <segment id="9">As outras 20</segment>
    <segment id="10">, foram notificadas por jogar papel</segment>
    <segment id="11">, copo descart횄징vel e bituca de cigarro fora da lixeira.</segment>
    <segment id="12">A coordenadora Ivelise Cristina Moreira explica que a multa s횄쨀 ser횄징 aplicada em</segment>
    <segment id="13">casocaso de reincid횄짧ncia.</segment>
    <segment id="14">Estas pessoas tiveram o nome e o CPF anotados e registrados no nosso banco de dados.</segment>
    <segment id="15">Caso sejam flagradas novamente</segment>
    <segment id="16">, ser횄짙o multadas</segment>
    <segment id="17">, afirmou.</segment>
    <segment id="18">Segundo Ivelise</segment>
    <segment id="19">, as pessoas t횄짧m recebido bem as abordagens.</segment>
    <segment id="20">Dos abordados ontem</segment>
    <segment id="21">, s횄쨀 uma pessoa</segment>
    <segment id="22">sese negou a dar os dados e foi liberada</segment>
    <segment id="23">, pois</segment>
    <segment id="24">pois n횄짙o havia guardas municipais na regi횄짙o.</segment>
    <segment id="25">As puni횄짠횄쨉es atendem 횄혻 Lei Municipal 8.512 regulamentada pelo prefeito ACM Neto em novembro.</segment>
    <segment id="26">As infra횄짠횄쨉es s횄짙o classificadas</segment>
    <segment id="27">comocomo leve</segment>
    <segment id="28">, m횄짤dia</segment>
    <segment id="29">, grave e grav횄짯ssima e as multas variam entre R$ 67</segment>
    <segment id="30">,23 a R$ 1.008</segment>
    <segment id="31">,45 para pessoa f횄짯sica e entre R$ 268</segment>
    <segment id="32">, 92 e R$ 2.016</segment>
    <segment id="33">, 90 para pessoa jur횄짯dica.</segment>
    <segment id="34">Nos dois primeiros meses de fiscaliza횄짠횄짙o de car횄징ter educativo os fiscais realizaram 2.305 abordagens e 602 notifica횄짠횄쨉es</segment>
    <segment id="35">, incluindo empresas.</segment>
    <segment id="36">A fiscaliza횄짠횄짙o ocorre entre 8h e 17h.</segment>
    <segment id="37">O hor횄징rio ser횄징 estendido</segment>
    <segment id="38">, masmas ainda n횄짙o h횄징 previs횄짙o para in횄짯cio.</segment>
    <segment id="39">Respeito e obriga횄짠횄짙o</segment>
    <segment id="40">O fiscal Hidelmar Santos</segment>
    <segment id="41">, 31, diz que na periferia o descarte irregular de lixo</segment>
    <segment id="42">횄짤 mais frequente e as pessoas s횄짙o mais resistentes.</segment>
    <segment id="43">J횄징 fui agredido verbalmente v횄징rias vezes</segment>
    <segment id="44">, afirma.</segment>
    <segment id="45">Apesar disso</segment>
    <segment id="46">, ele ressalta que o povo est횄징 aprendendo a respeit횄징-los.</segment>
    <segment id="47">A maioria das pessoas ouvidas pela reportagem demonstrou ser a favor da medida.</segment>
    <segment id="48">A ideia 횄짤 excelente.</segment>
    <segment id="49">As pessoas precisam</segment>
    <segment id="50">sese conscientizar opinou o pintor Anderson Pereira</segment>
    <segment id="51">, 32.</segment>
    <segment id="52">J횄징 o vendedor Edmilson Guerrilha</segment>
    <segment id="53">, 45, 횄짤 contra a puni횄짠횄짙o aos mij횄쨉es.</segment>
    <segment id="54">Quem estiver apertado vai fazer o qu횄짧?</segment>
    <segment id="55">Urinar na garrafa?</segment>
    <segment id="56">, questionou.</segment>
    <segment id="57">O boleto da multa ser횄징 emitido no momento do flagrante por uma impressora port횄징til.</segment>
    <segment id="58">O prazo para quit횄징-lo em qualquer banco 횄짤 de 60 dias.</segment>
    <segment id="59">Quem se</segment>
    <segment id="60">se recusar a informar os dados</segment>
    <segment id="61">, ser횄징 detido.</segment>
    <segment id="62">J횄징 o n횄짙o pagamento resultar횄징 em inscri횄짠횄짙o do nome no Serasa</segment>
    <segment id="63">, SPC e no Cadastro Informativo Municipal (Cadin).</segment>
    <segment id="64">Iemanj횄징 tamb횄짤m n횄짙o gosta de sujeira</segment>
    <segment id="65">Quem gosta de casa suja?</segment>
    <segment id="66">Por que com Iemanj횄징 seria diferente?</segment>
    <segment id="67">, pergunta o bi횄쨀logo marinho Clarencio Baracho.</segment>
    <segment id="68">Ele 횄짤 um dos que defendem a uni횄짙o de f횄</segment>
    <segment id="69">짤 e respeito ao meio ambiente.</segment>
    <segment id="70">Na tentativa de reduzir os impactos ambientais causados pelas oferendas convencionais entregues 횄혻 Rainha do Mar</segment>
    <segment id="71">, em 2 de fevereiro</segment>
    <segment id="72">, a comunidade do Bairro-Escola Rio Vermelho lan횄짠a a campanha</segment>
    <segment id="73">Meu presente para Iemanj횄징</segment>
    <segment id="74">횄짤 (bio)agrad횄징vel.</segment>
    <segment id="75">Representante do grupo</segment>
    <segment id="76">, Fernanda Cola횄짠o explica que o objetivo da mobiliza횄짠횄짙o 횄짤 estimular o uso de materiais biodegrad횄징veis na confec횄짠횄짙o das tradicionais presentes.</segment>
    <segment id="77">J횄징 no dia da festa</segment>
    <segment id="78">, 횄짤 comum perceber lixo dentro e fora do mar.</segment>
    <segment id="79">Os aceitos por Iemanj횄징 amea횄짠am o ecossistema marinho e os que ela devolve poluem a praia.</segment>
    <segment id="80">H횄징 oferendas que levam centenas ou at횄짤 milhares de anos para</segment>
    <segment id="81">sese decompor</segment>
    <segment id="82">, como</segment>
    <segment id="83">como flores de pl횄징stico.</segment>
    <segment id="84">Isso quando os animais do mar n횄짙o as confundem com alimento.</segment>
    <segment id="85">(por jessica sandes)</segment>
  </rst>
