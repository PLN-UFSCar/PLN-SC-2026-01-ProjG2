    <segment id="26">в„ў, Гўв‚¬ЛњMatemГѓВЎticaГўв‚¬в„ў e Гўв‚¬ЛњNovinhaГўв‚¬в„ў.</segment>
    <segment id="27">O evento ainda terГѓВЎ a participaГѓВ§ГѓВЈo da banda</segment>
