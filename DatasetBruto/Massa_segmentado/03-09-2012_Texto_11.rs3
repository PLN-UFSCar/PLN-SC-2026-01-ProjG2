  <rst>
    <segment id="1">O ﾃ｢竄ｬﾋ彡oronel jesuﾃδｭnoﾃ｢竄ｬ邃｢ de ﾃトuas Claras</segment>
    <segment id="2">Sem ser traﾃδｭdo</segment>
    <segment id="3">, homem imita personagem de ﾃ｢竄ｬﾋ廨abrielaﾃ｢竄ｬ邃｢ e sai armado pra matar ex-mulher
ﾃ｢竄ｬﾅ鄭tira!</segment>
    <segment id="4">Atira!ﾃ｢竄ｬ. Eram  os gritos desesperados de uma mulher que nﾃδ｣o suportava mais as agressﾃδｵes do ex-companheiro.</segment>
    <segment id="5">Ontem ﾃδ tarde</segment>
    <segment id="6">, a reportagem do MASSA!</segment>
    <segment id="7">flagrou o momento em que o desempregado Alex Bispo dos Santos</segment>
    <segment id="8">, 37 anos</segment>
    <segment id="9">, armado com um revﾃδｳlver calibre 38</segment>
    <segment id="10">, abordou a diarista Jacinalva dos Santos Silva</segment>
    <segment id="11">, 40, no final de linha do bairro de ﾃトuas Claras</segment>
    <segment id="12">, e ameaﾃδｧou  matﾃδ｡-la.</segment>
    <segment id="13">Ele ainda chegou a bater na ex-mulher e dar um tiro para baixo.</segment>
    <segment id="14">Alex foi detido por duas guarniﾃδｧﾃδｵes da 3ﾃつｪ CIPM (Cajazeiras)</segment>
    <segment id="15">, que faziam ronda pelo local.</segment>
    <segment id="16">ﾃ｢竄ｬﾅ溺e matava.</segment>
    <segment id="17">Estou cansada dissoﾃ｢竄ｬ</segment>
    <segment id="18">, afirmou  Jacinalva</segment>
    <segment id="19">, muito emocionada</segment>
    <segment id="20">, sobre a sua reaﾃδｧﾃδ｣o de mandar o ex-marido atirar nela.</segment>
    <segment id="21">Ao ser questionado sobre o motivo de tamanha agressﾃδ｣o</segment>
    <segment id="22">, Alex disse:</segment>
    <segment id="23">ﾃ｢竄ｬﾅ摘la saiu cedo e estava no bar bebendo cerveja.</segment>
    <segment id="24">Olha a cara dela lﾃδ｡ﾃ｢竄ｬ. Mas ele  negou logo em seguida que a razﾃδ｣o tenha sido essa.</segment>
    <segment id="25">Insistiu  em dizer que era um homem de bem e trabalhador e</segment>
    <segment id="26">sese recusou a dar qualquer informaﾃδｧﾃδ｣o a seu respeito.</segment>
    <segment id="27">Alex diz ter comprado o revﾃδｳlver na Feira do Rolo</segment>
    <segment id="28">, na  Baixa do Fiscal</segment>
    <segment id="29">, por R$ 200.</segment>
    <segment id="30">Ele usava um colete balﾃδｭstico</segment>
    <segment id="31">, onde estava  bordado:  ﾃ｢竄ｬﾅ敵aviﾃδｵes Vigilﾃδ｢ncia e Transportes de Valoresﾃ｢竄ｬ.</segment>
    <segment id="32">ﾃ｢竄ｬﾋ廚ansei de viver humilhadaﾃ｢竄ｬ邃｢
Jacinalva viveu com Alex durante 10 anos.</segment>
    <segment id="33">Hﾃδ｡ 15 dias</segment>
    <segment id="34">, ela descobriu que ele tinha outra mulher e o colocou para fora de casa.</segment>
    <segment id="35">ﾃ｢竄ｬﾅ摘le achava que eu tinha de ficar em casa e aceitar as mulheres que pegava na rua.</segment>
    <segment id="36">Mas cansei de viver humilhada e hoje (ontem) sai para fazer campanha polﾃδｭtica.</segment>
    <segment id="37">Na volta</segment>
    <segment id="38">, aconteceu isso aﾃδｭ que vocﾃδｪ viuﾃ｢竄ｬ. ﾃ｢竄ｬﾅ摘le sempre foi agressivo</segment>
    <segment id="39">, me batia</segment>
    <segment id="40">, ameaﾃδｧava matar eu e minha famﾃδｭlia.</segment>
    <segment id="41">E dizia:</segment>
    <segment id="42">A polﾃδｭcia demora para chegar e a Justiﾃδｧa ﾃδｩ falhaﾃ｢竄ｬ.</segment>
  </rst>
