  <rst>
    <segment id="1">O bicho tá pegando entre a mulherada!</segment>
    <segment id="2">Dani Mangá também vai processar Rianne Ferreira
Rianne Ferreira vai ter que dar várias explicações na Justiça quando deixar “</segment>
    <segment id="3">O Trio - Reality” (TV Aratu).</segment>
    <segment id="4">Anteontem</segment>
    <segment id="5">, a Mulher Perereca registrou queixa contra a loira por difamação.</segment>
    <segment id="6">Como se</segment>
    <segment id="7">se não bastasse</segment>
    <segment id="8">, a loira terá de enfrentar mais um processo</segment>
    <segment id="9">, agora movido por Dani Mangá</segment>
    <segment id="10">, musa oficial do Bahia.</segment>
    <segment id="11">A morena alega que Rianne estaria</segment>
    <segment id="12">sese autointitulando Musa do Bahia</segment>
    <segment id="13">, título conquistado por ela quando eleita</segment>
    <segment id="14">comocomo representante do time no concurso Musa do Brasileirão</segment>
    <segment id="15">, promovido pelo “Caldeirão do Huck” no ano passado.</segment>
    <segment id="16">Vinicius Vianna</segment>
    <segment id="17">, empresário da gata</segment>
    <segment id="18">, informou que Dani  já fez a denúncia por meio de seus advogados.</segment>
    <segment id="19">Por enquanto</segment>
    <segment id="20">, a musa ‘de verdade’ preferiu não</segment>
    <segment id="21">sese pronunciar.</segment>
  </rst>
