  <rst>
    <segment id="1">Ensaio de casamento ainda em cartaz</segment>
    <segment id="2">O casal formado por Wanderley e Maria discute no palco a continuidade do casamento</segment>
    <segment id="3">A peça teatral</segment>
    <segment id="4">Ensaio de Casamento continua em cartaz às sextas e sábados do mês de abril</segment>
    <segment id="5">, no SESC/SENAC Pelourinho.</segment>
    <segment id="6">No espetáculo</segment>
    <segment id="7">, o casal formado por Wanderley e Maria discute no palco a continuidade do casamento enquanto ensaiam “Nossa Peça de Separação”</segment>
    <segment id="8">, revivendo em cena personagens clássicos de Shakespeare:</segment>
    <segment id="9">Romeu e Julieta</segment>
    <segment id="10">, Otelo e Desdêmona e Catarina</segment>
    <segment id="11">, A Megera Domada</segment>
    <segment id="12">, numa trama que envolve os atores</segment>
    <segment id="13">, que funcionam</segment>
    <segment id="14">comocomo pessoas</segment>
    <segment id="15">, personas e personagens</segment>
    <segment id="16">, em um texto que aborda passado</segment>
    <segment id="17">, presente e futuro e que prende a atenção do público do começo ao fim.

“</segment>
    <segment id="18">Dentro dessas diversas camadas do texto que</segment>
    <segment id="19">sese superpõem em um jogo de metalinguagem</segment>
    <segment id="20">, podemos mergulhar nas paixões dos dois artistas pelo teatro</segment>
    <segment id="21">, nas paixões humanas evocadas dentro do próprio jogo da encenação da peça dentro da peça”</segment>
    <segment id="22">, explica Nadja Turenkko</segment>
    <segment id="23">, diretora da peça.</segment>
    <segment id="24">“É um espetáculo que envolve os atores</segment>
    <segment id="25">, com seus diversos personagens</segment>
    <segment id="26">, e a plateia</segment>
    <segment id="27">, que até certo ponto</segment>
    <segment id="28">, não sabe</segment>
    <segment id="29">sese o texto pertence aos personagens de ‘</segment>
    <segment id="30">Nossa Peça de Separação’ ou aos de ‘Ensaio de Casamento’</segment>
    <segment id="31">, dentro de uma perspectiva de metalinguagem</segment>
    <segment id="32">, explica Wanderley Meira</segment>
    <segment id="33">, criador do texto do espetáculo.</segment>
    <segment id="34">Fique ligado!</segment>
    <segment id="35">A peça está em cartaz no teatro SESC/SENAC - Pelourinho às sextas e sábados de abril</segment>
    <segment id="36">Preço: R$ 10 e R$ 5</segment>
  </rst>
</analysis>