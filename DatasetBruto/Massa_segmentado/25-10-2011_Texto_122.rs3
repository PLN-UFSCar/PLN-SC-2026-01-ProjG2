  <rst>
    <segment id="1">Marmanjos babam por ela
Ilca é musa do Pau Miúdo</segment>
    <segment id="2">A bela Ilca Oliveira tem apenas 18 anos e esbanja simpatia por onde passa.</segment>
    <segment id="3">Além de todo o charme</segment>
    <segment id="4">, seu bumbum e suas pernocas chamam bastante a atenção dos marmanjos do bairro Pau Miúdo</segment>
    <segment id="5">, onde a gata mora.</segment>
    <segment id="6">Para manter a boa forma</segment>
    <segment id="7">, a estudante do ensino médio adora malhar.</segment>
    <segment id="8">Na hora da conquista</segment>
    <segment id="9">, a morena valoriza um bom papo.</segment>
    <segment id="10">“Poucos homens sabem dar uma cantada na garota”</segment>
    <segment id="11">, comenta a moça</segment>
    <segment id="12">, que já tem namorado e não admite falta de criatividade em um relacionamento amoroso.</segment>
    <segment id="13">O sonho de Ilca</segment>
    <segment id="14">, caso</segment>
    <segment id="15">caso ganhe o concurso Garota do Tempo</segment>
    <segment id="16">, do jornal “MASSA!</segment>
    <segment id="17">”,  é investir em um curso de técnico em enfermagem.</segment>
    <segment id="18">Sarada</segment>
    <segment id="19">Ilca malha à beça para manter o corpão em cima e vencer o concurso do “MASSA!</segment>
    <segment id="20">”</segment>
  </rst>
</analysis>