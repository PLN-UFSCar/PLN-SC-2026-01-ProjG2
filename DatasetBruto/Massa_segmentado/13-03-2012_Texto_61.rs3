  <rst>
    <segment id="1">Defesa de Bruno admite morte de Eliza</segment>
    <segment id="2">Segundo Pimenta</segment>
    <segment id="3">, ‘Eliza foi morta</segment>
    <segment id="4">, masmas Bruno nunca quis</segment>
    <segment id="5">, nunca desejou isso’</segment>
    <segment id="6">O advogado do goleiro Bruno Fernandes</segment>
    <segment id="7">, Rui Caldas Pimenta</segment>
    <segment id="8">, contou que a estratégia de defesa do atleta admitirá no julgamento a morte de Eliza Samudio.</segment>
    <segment id="9">De acordo com Pimenta</segment>
    <segment id="10">, a tese é diferente da sustentada por outros defensores que já passaram pelo</segment>
    <segment id="11">casocaso.</segment>
    <segment id="12">Até então</segment>
    <segment id="13">, a defesa do goleiro sustentava que a jovem estava viva</segment>
    <segment id="14">, já que o corpo nunca foi encontrado.</segment>
    <segment id="15">Bruno e mais sete pessoas são réus no processo sobre o desaparecimento e morte de Eliza.</segment>
    <segment id="16">De acordo com Pimenta</segment>
    <segment id="17">, a tese de que “sem corpo não há materialidade” está incorreta.</segment>
    <segment id="18">Ainda segundo o advogado</segment>
    <segment id="19">, o amigo do goleiro Luiz Henrique Romão</segment>
    <segment id="20">, o Macarrão</segment>
    <segment id="21">, tomou a decisão de matar a jovem.</segment>
    <segment id="22">“</segment>
    <segment id="23">Era para o Macarrão levar Eliza e entregar R$ 30 mil.</segment>
    <segment id="24">O Macarrão falou (para Bruno) que a deixou na rodoviária</segment>
    <segment id="25">, ele mentiu pro Bruno”.

Macarrão.</segment>
    <segment id="26">Defensor deixa</segment>
    <segment id="27">casocaso</segment>
    <segment id="28">O advogado Wasley César de Vasconcelos informou ontem que deixou a defesa de Luiz Henrique Ferreira Romão</segment>
    <segment id="29">, o Macarrão</segment>
    <segment id="30">, no processo sobre a morte de Eliza Samudio.</segment>
    <segment id="31">O pedido de renúncia foi encaminhado por fax à Justiça.</segment>
    <segment id="32">A substituição da defesa ainda não foi oficializada.</segment>
    <segment id="33">Mais cedo</segment>
    <segment id="34">, o advogado tinha afirmado ao G1</segment>
    <segment id="35">, que acreditava na inocência de seu cliente</segment>
    <segment id="36">, e que Macarrão não iria livrar o goleiro Bruno Fernandes da acusação.</segment>
  </rst>
