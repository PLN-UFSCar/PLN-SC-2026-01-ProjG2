  <rst>
    <segment id="1">Vasco e Fluminense fazem o clássico carioca da rodada no Brasileiro</segment>
    <segment id="2">A rivalidade entre Vasco e Fluminense remonta a tempos do fim do amadorismo do futebol.</segment>
    <segment id="3">Quase 90 anos depois</segment>
    <segment id="4">, na era profissional</segment>
    <segment id="5">, o jogo deste domingo</segment>
    <segment id="6">, às 18h</segment>
    <segment id="7">, no Engenhão</segment>
    <segment id="8">, mantém a rixa.</segment>
    <segment id="9">E a importância que um clássico tem para quem precisa</segment>
    <segment id="10">sese afirmar no Campeonato Brasileiro</segment>
    <segment id="11">, no caso</segment>
    <segment id="12">caso do tricolor</segment>
    <segment id="13">, que está em oitavo lugar</segment>
    <segment id="14">, e terá a volta de Fred após ser poupado.</segment>
    <segment id="15">Ou continuar no encalço dos líderes - pode chegar à vice-liderança -</segment>
    <segment id="16">comocomo pretende a equipe de São Januário</segment>
    <segment id="17">, que está completa.</segment>
    <segment id="18">As provocações ficam a cargo dos torcedores.</segment>
    <segment id="19">Nas quatro linhas</segment>
    <segment id="20">, o respeito é grande.</segment>
    <segment id="21">Não só pelo profissionalismo</segment>
    <segment id="22">, masmas também pela relação típica da troca de clubes do futebol brasileiro</segment>
    <segment id="23">, que faz jogadores e técnicos fincarem raízes em diferentes times.</segment>
    <segment id="24">No Vasco</segment>
    <segment id="25">, as lembranças trazidas das Laranjeiras não são poucas.</segment>
    <segment id="26">Do treinador ao camisa 10</segment>
    <segment id="27">, o tricolor fez parte da vida de alguns que hoje honram a Cruz de Malta.</segment>
    <segment id="28">Ricardo Gomes e Diego Souza têm muito a agradecer ao rival do dia</segment>
    <segment id="29">, por exemplo.</segment>
    <segment id="30">Mas preferem</segment>
    <segment id="31">sese concentrar no presente e</segment>
    <segment id="32">, a pedido do clube atual</segment>
    <segment id="33">, falar pouco do passado para evitar polêmicas.</segment>
    <segment id="34">Ricardo jogou mais de 10 anos no Fluminense e</segment>
    <segment id="35">, tricampeão carioca (1983/84/85) e campeão brasileira (1984)</segment>
    <segment id="36">, foi um dos principais zagueiros do clube.</segment>
    <segment id="37">Mas, como</segment>
    <segment id="38">como técnico</segment>
    <segment id="39">, foi somente no antigo rival</segment>
    <segment id="40">, o Vasco</segment>
    <segment id="41">, que conseguiu um título de expressão no futebol brasileiro</segment>
    <segment id="42">, a Copa do Brasil deste ano.</segment>
    <segment id="43">Do outro lado estará Abel Braga</segment>
    <segment id="44">, que também tem ligação afetiva com o Vasco.

-</segment>
    <segment id="45">O jogo não é Abel x Ricardo</segment>
    <segment id="46">, nem Ricardo x Abel</segment>
    <segment id="47">, é Vasco x Fluminense - resumiu.</segment>
    <segment id="48">Felipe: pronto para voltar</segment>
    <segment id="49">Diego Souza vestiu o uniforme tricolor da infância até completar 20 anos e ser vendido ao Benfica</segment>
    <segment id="50">, de Portugal.</segment>
    <segment id="51">O carinho</segment>
    <segment id="52">, nunca escondeu</segment>
    <segment id="53">, masmas evita falar do ex-clube às vésperas de clássicos.</segment>
    <segment id="54">Lá conquistou seu primeiro título profissional</segment>
    <segment id="55">, o Carioca de 2005</segment>
    <segment id="56">, com Abel</segment>
    <segment id="57">comocomo técnico.</segment>
    <segment id="58">Assim como</segment>
    <segment id="59">como Ricardo Gomes</segment>
    <segment id="60">, somente no Vasco ganhou seu principal troféu - a Copa do Brasil.</segment>
    <segment id="61">Totalmente identificado com o Vasco</segment>
    <segment id="62">, ídolo com sete títulos pelo clube</segment>
    <segment id="63">, Felipe</segment>
    <segment id="64">, que está à disposição do técnico</segment>
    <segment id="65">, também teve seu momento tricolor em 2005 ao lado de Diego Souza.</segment>
    <segment id="66">Até mesmo o zagueiro Dedé tentou a sorte nas Laranjeiras</segment>
    <segment id="67">, masmas não teve muito sucesso.</segment>
    <segment id="68">Afeições à parte</segment>
    <segment id="69">, cada qual defenderá seu clube atual</segment>
    <segment id="70">, em busca de três pontos que podem determinar o rumo que os times terão neste Campeonato Brasileiro.

Abel</segment>
    <segment id="71">, cria do Flu</segment>
    <segment id="72">, chegou à seleção pelo Vasco</segment>
    <segment id="73">Zagueiro reserva da lendário Máquina Tricolor nos anos 70</segment>
    <segment id="74">, Abel Braga chegou ao Fluminense no fim dos anos 1960 e testemunhou a transformação de costumes e de um clube no qual</segment>
    <segment id="75">, como</segment>
    <segment id="76">como jogador</segment>
    <segment id="77">, nunca teve grandes chances de sair do banco.

- Devo ao Fluminense minha formação</segment>
    <segment id="78">comocomo homem.</segment>
    <segment id="79">Ironia do destino</segment>
    <segment id="80">, quando deixou as Laranjeiras rumo a São Januário para ser titular</segment>
    <segment id="81">, Vasco e Fluminense decidiram o Carioca de 76.</segment>
    <segment id="82">E o atacante argentino Doval venceu o zagueiro Abel para fazer o gol do título tricolor de cabeça.</segment>
    <segment id="83">A maior conquista estaria por vir.</segment>
    <segment id="84">Com o título estadual do ano seguinte</segment>
    <segment id="85">, Abel</segment>
    <segment id="86">sese firmaria na zaga do Vasco e na condição de um dos maiores defensores do país.</segment>
    <segment id="87">Com apenas uma derrota</segment>
    <segment id="88">, o time foi campeão (chegou a ficar 15 jogos sem levar gol) e Abel ganhou uma vaga na seleção terceira colocada na Copa do Mundo da Argentina</segment>
    <segment id="89">, em 78:

- Eu fui despontar mesmo no Vasco</segment>
    <segment id="90">, que me ofereceu a chance de ir à seleção.</segment>
    <segment id="91">Naquele Carioca</segment>
    <segment id="92">, ficamos um turno sem sofrer gol.</segment>
    <segment id="93">O Ricardo Gomes não teve esta alegria - brincou Abel com o amigo.</segment>
    <segment id="94">A provocação daqueles que</segment>
    <segment id="95">sese conhecem há anos fica no passado.</segment>
    <segment id="96">Hoje, apesar de cada um estar em seu lado do campo</segment>
    <segment id="97">, estarão unidos por um clássico na concepção da palavra: limpo e bonito de</segment>
    <segment id="98">sese ver.

- Não há confronto nem é Abel contra Ricardo.</segment>
    <segment id="99">É um clássico e todo resultado é normal - declarou o treinador.</segment>
    <segment id="100">A normalidade pode ficar restrita ao discurso</segment>
    <segment id="101">, porque</segment>
    <segment id="102">porque a vitória é o resultado que interessa para dar a partida em uma arrancada que nunca começa neste Brasileiro.

- Já levantamos muito time: Bahia</segment>
    <segment id="103">, América-MG e Grêmio.</segment>
    <segment id="104">O Vasco</segment>
    <segment id="105">, não precisamos levantar.</segment>
    <segment id="106">Já está lá em cima - disse Abel.</segment>
    <segment id="107">VASCO X FLUMINENSE

Vasco: Fernando Prass</segment>
    <segment id="108">, Fágner</segment>
    <segment id="109">, Dedé</segment>
    <segment id="110">, Anderson Martins e Julinho</segment>
    <segment id="111">; Rômulo</segment>
    <segment id="112">, Jumar</segment>
    <segment id="113">, Felipe (Juninho Pernambucano) e Diego Souza</segment>
    <segment id="114">; Éder Luís e Alecsandro.</segment>
    <segment id="115">Fluminense:</segment>
    <segment id="116">Diego Cavalieri</segment>
    <segment id="117">, Mariano</segment>
    <segment id="118">, Gum, Márcio Rosário e Carlinhos</segment>
    <segment id="119">; Edinho</segment>
    <segment id="120">, Valencia</segment>
    <segment id="121">, Marquinho e Lanzini</segment>
    <segment id="122">; Rafael Moura (Rafael Sóbis) e Fred.</segment>
    <segment id="123">Juiz: Marcelo de Lima Henrique.</segment>
  </rst>
</analysis>