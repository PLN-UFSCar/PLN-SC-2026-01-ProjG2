  <rst>
    <segment id="1">Daniel é expulso do BBB e pode ser preso</segment>
    <segment id="2">Ele garantiu que não fez nada demais com Monique</segment>
    <segment id="3">O modelo paulistano Daniel</segment>
    <segment id="4">, participante do Big Brother Brasil 12 foi expulso ontem da casa.</segment>
    <segment id="5">A decisão de tirar o rapaz do programa foi tomada  após a acirrada repercussão  sobre o suposto estupro praticado pelo brother contra a colega de confinamento Monique.</segment>
    <segment id="6">O rala e rola do casal acabou virando</segment>
    <segment id="7">casocaso de polícia.</segment>
    <segment id="8">De acordo com informações do site Terra</segment>
    <segment id="9">, a Polícia Civil do Rio de Janeiro</segment>
    <segment id="10">, da 32ª Delegacia de Polícia</segment>
    <segment id="11">, esteve ontem na casa ‘mais vigiada do Brasil’ - ainda mais agora - para apurar</segment>
    <segment id="12">sese ocorreu “estupro de vulnerável”.</segment>
    <segment id="13">Segundo o delegado</segment>
    <segment id="14">, a moça deve prestar depoimento hoje e</segment>
    <segment id="15">, caso</segment>
    <segment id="16">caso queira</segment>
    <segment id="17">, irá se</segment>
    <segment id="18">se submeter à perícia para provar</segment>
    <segment id="19">sese houve crime.</segment>
    <segment id="20">O bafafá começou na madrugada de domingo</segment>
    <segment id="21">, após a primeira festa na casa.</segment>
    <segment id="22">Na filmagem</segment>
    <segment id="23">, Monique e Daniel</segment>
    <segment id="24">, depois de muita bebedeira</segment>
    <segment id="25">, estavam embaixo do edredom com movimentos de pura pegação.</segment>
    <segment id="26">Depois</segment>
    <segment id="27">, o vídeo mostra Daniel</segment>
    <segment id="28">sese mexendo e Monique aparentemente dormindo</segment>
    <segment id="29">, sem reagir às investidas do rapaz.

Se confirmado o estupro</segment>
    <segment id="30">, Daniel pode pegar entre seis e dez anos de prisão.</segment>
    <segment id="31">Isso porque</segment>
    <segment id="32">porque</segment>
    <segment id="33">, em 2009</segment>
    <segment id="34">, o governo Lula sancionou a lei 12.015</segment>
    <segment id="35">, que amplia a aplicação da pena para os casos que antes eram tratados apenas</segment>
    <segment id="36">comocomo atos libidinosos.</segment>
    <segment id="37">O artigo 215 diz que  é estupro “ter conjunção carnal ou praticar outro ato libidinoso com alguém</segment>
    <segment id="38">, mediante fraude ou outro meio que impeça ou dificulte a livre manifestação de vontade da vítima”.</segment>
    <segment id="39">Especialistas dão suas opiniões sobre o</segment>
    <segment id="40">casocaso

Depois do bafafá entre internautas</segment>
    <segment id="41">, especialistas também opinaram sobre o</segment>
    <segment id="42">casocaso.</segment>
    <segment id="43">Para o advogado criminalista e conselheiro da OAB-BA Domingos Arjones</segment>
    <segment id="44">, as imagens não caracterizam crime.</segment>
    <segment id="45">“</segment>
    <segment id="46">Não foi estupro.</segment>
    <segment id="47">No máximo foi abuso sexual.</segment>
    <segment id="48">Se ela</segment>
    <segment id="49">sese sentiu prejudicada</segment>
    <segment id="50">, deve denunciar”</segment>
    <segment id="51">, afirma.</segment>
    <segment id="52">O caso</segment>
    <segment id="53">caso também foi parar em Brasília.</segment>
    <segment id="54">A ministra da Secretaria de Políticas para as Mulheres Iriny Lopes pediu “providências” ao Ministério Público Estadual do Rio de Janeiro.</segment>
  </rst>
