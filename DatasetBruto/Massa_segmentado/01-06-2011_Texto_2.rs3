  <rst>
    <segment id="1">Braço direito perfumado
Avós</segment>
    <segment id="2">, mães e mulheres são apoios importantes fora do campo para os jogadores</segment>
    <segment id="3">Quando o jogo termina e o estádio esvazia</segment>
    <segment id="4">, são elas que estão lá para dar um conselho certeiro</segment>
    <segment id="5">, oferecer um ombro amigo ou simplesmente preparar sua comida favorita.</segment>
    <segment id="6">Mães, avós</segment>
    <segment id="7">, mulheres e filhas são as verdadeiras responsáveis</segment>
    <segment id="8">para que</segment>
    <segment id="9">para que os jogadores do Bahia e do Vitória continuem dando show em campo.</segment>
    <segment id="10">A tarefa de ser a mulher por trás do atleta não é nada fácil.</segment>
    <segment id="11">“O tempo todo estou sofrendo</segment>
    <segment id="12">, tem muita pressão que as pessoas não enxergam.</segment>
    <segment id="13">Tressor fica abatido quando não é relacionado ou quando está com uma lesão.</segment>
    <segment id="14">Eu acabo sofrendo com ele”</segment>
    <segment id="15">, conta a advogada Isabel</segment>
    <segment id="16">, que abriu mão de tudo na Colômbia para permanecer ao lado do amado</segment>
    <segment id="17">, meia-atacante do Bahia Tressor Moreno.</segment>
    <segment id="18">Quem vê jovens atletas surpreendendo em campo  apesar da pouca idade</segment>
    <segment id="19">, como</segment>
    <segment id="20">como Duylio</segment>
    <segment id="21">, meia do Vitória</segment>
    <segment id="22">, ou Gabriel</segment>
    <segment id="23">, lateral-direito do Bahia</segment>
    <segment id="24">,  não imagina de onde vem tanta energia.</segment>
    <segment id="25">“De manhã cedo faço uma supervitamina de frutas para Gabriel.</segment>
    <segment id="26">Ele não gosta muito de banana</segment>
    <segment id="27">, masmas digo que é importante par dar força”</segment>
    <segment id="28">, conta a vovó</segment>
    <segment id="29">Maria José Conceição</segment>
    <segment id="30">, com quem o lateral vive desde que nasceu</segment>
    <segment id="31">, em frente ao campinho de futebol do Jardim Cruzeiro.</segment>
    <segment id="32">Já o jovem Duylio não dispensa a comida lá de Fortaleza.</segment>
    <segment id="33">“</segment>
    <segment id="34">Depois do jogo</segment>
    <segment id="35">, ele gosta de baião de dois e creme de galinha</segment>
    <segment id="36">, masmas a receita especial é o carinho”</segment>
    <segment id="37">, conta a mãe-coruja Cosma Monteiro</segment>
    <segment id="38">, que veio do Ceará para  morar com o filho em  São Rafael.</segment>
  </rst>
</analysis>