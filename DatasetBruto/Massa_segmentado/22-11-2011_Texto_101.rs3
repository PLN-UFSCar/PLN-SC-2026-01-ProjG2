  <rst>
    <segment id="1">Xanddy move processo contra a Hyundai
Cantor e Carla convocam a massa para batalha</segment>
    <segment id="2">Um dos assuntos mais comentados nas redes sociais ontem foi o processo que o cantor Xanddy</segment>
    <segment id="3">, líder do Harmonia do Samba</segment>
    <segment id="4">, está movendo contra a concessionária Pateo Hyundai.</segment>
    <segment id="5">Até a mulher</segment>
    <segment id="6">, Carla Perez</segment>
    <segment id="7">, amigos e fãs entraram na briga</segment>
    <segment id="8">, divulgando a notícia</segment>
    <segment id="9">, para obrigar a empresa a tomar providências.</segment>
    <segment id="10">Bombou a hashtag #</segment>
    <segment id="11">xanddyxhyundaifalhanos10airbags.</segment>
    <segment id="12">“Mesmo com essa repercussão</segment>
    <segment id="13">, eles ainda não entraram em contato”</segment>
    <segment id="14">, diz o cantor.</segment>
    <segment id="15">Em janeiro</segment>
    <segment id="16">, Xanddy sofreu um acidente com seu  veículo Vera Cruz e nenhum dos 10 air bags funcionou.</segment>
    <segment id="17">“Nem o da lateral do carro</segment>
    <segment id="18">, onde a pancada foi maior.</segment>
    <segment id="19">É exatamente lá que meus filhos ficam”</segment>
    <segment id="20">, relata o cantor</segment>
    <segment id="21">, que estava sozinho na hora do acidente.  Xanddy</segment>
    <segment id="22">, então</segment>
    <segment id="23">, iniciou contatos com a empresa.</segment>
    <segment id="24">“</segment>
    <segment id="25">O último retorno foi em 4 de maio</segment>
    <segment id="26">, quando um dos representantes da Hyundai - disse que estava aguardando as peças chegarem da Coreia.</segment>
    <segment id="27">Até hoje estou esperando”.</segment>
    <segment id="28">Agora, o baiano resolveu colocar a boca no trombone para ver</segment>
    <segment id="29">sese, assim</segment>
    <segment id="30">, tem seus direitos assegurados.</segment>
    <segment id="31">“Se eles tivessem sido corretos conosco</segment>
    <segment id="32">, não agiríamos dessa forma”</segment>
    <segment id="33">, afirma Carla Perez.</segment>
  </rst>
