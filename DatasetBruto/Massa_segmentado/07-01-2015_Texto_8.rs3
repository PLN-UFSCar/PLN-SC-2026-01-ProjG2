  <rst>
    <segment id="1">Professores terﾃδ｣o reajuste no salﾃδ｡rio</segment>
    <segment id="2">O anﾃδｺncio foi feito pelo MEC</segment>
    <segment id="3">; novo valor ﾃδｩ de R$ R$ 1.917</segment>
    <segment id="4">,78</segment>
    <segment id="5">O Ministﾃδｩrio da Educaﾃδｧﾃδ｣o (MEC) divulgou na noite de ontem o valor do novo piso salarial dos professores de todo o Brasil.</segment>
    <segment id="6">Com um aumento relevante de 13</segment>
    <segment id="7">,01% o valor serﾃδ｡ de R$ 1.917</segment>
    <segment id="8">, 78.</segment>
    <segment id="9">As secretarias municipais e estaduais devem</segment>
    <segment id="10">sese adequar para pagar o reajuste jﾃδ｡ no mﾃδｪs de fevereiro prﾃδｳximo.</segment>
    <segment id="11">O salﾃδ｡rio inicial dos professores de escola pﾃδｺblica</segment>
    <segment id="12">, com formaﾃδｧﾃδ｣o de nﾃδｭvel mﾃδｩdio</segment>
    <segment id="13">, leva em conta uma jornada de trabalho de 40 horas semanais.</segment>
    <segment id="14">O valor do reajuste jﾃδ｡ havia sido estimado pela Confederaﾃδｧﾃδ｣o Nacional dos Municﾃδｭpios (CNM) com base em critﾃδｩrios que vﾃδｪm sendo adotados pelo MEC.</segment>
    <segment id="15">O piso salarial</segment>
    <segment id="16">, em 2009</segment>
    <segment id="17">, era de R$ 950.</segment>
    <segment id="18">Um ano depois subiu para R$ 1.024</segment>
    <segment id="19">,67;</segment>
    <segment id="20">em 2011 ficou em R$ 1.187</segment>
    <segment id="21">, 14.</segment>
    <segment id="22">Um ano depois o valor foi reajustado para R$ 1.451 e em 2013 passou para R$ 1.567.</segment>
    <segment id="23">No ano passado</segment>
    <segment id="24">, o reajuste elevou o piso para R$ 1.697</segment>
    <segment id="25">,39.</segment>
    <segment id="26">Os valores estﾃδ｣o listados no site oficial do MEC.</segment>
    <segment id="27">Nos ﾃδｺltimos seis anos o maior reajuste aconteceu em 2012</segment>
    <segment id="28">, com um aumento de 22</segment>
    <segment id="29">,22%.</segment>
    <segment id="30">O reajuste foi apresentado durante um rencontro entre o novo ministro da Educaﾃδｧﾃδ｣o</segment>
    <segment id="31">, Cid Gomes</segment>
    <segment id="32">, e representantes de instituiﾃδｧﾃδｵes voltadas para a gestﾃδ｣o escolar.</segment>
    <segment id="33">Participaram do encontro membros do Conselho Nacional de Secretﾃδ｡rios de Educaﾃδｧﾃδ｣o (Consed)</segment>
    <segment id="34">; da Uniﾃδ｣o Nacional dos Dirigentes Municipais de Educaﾃδｧﾃδ｣o (Undime) e da Confederaﾃδｧﾃδ｣o Nacional dos Trabalhadores em Educaﾃδｧﾃδ｣o (CNTE).</segment>
    <segment id="35">A CNM enviou ofﾃδｭcio solicitando audiﾃδｪncia com o ministro da Educaﾃδｧﾃδ｣o Cid Gomes.</segment>
    <segment id="36">A entidade quer mudanﾃδｧa nos critﾃδｩrios de reajuste do piso.</segment>
    <segment id="37">A justificativa ﾃδｩ que os aumentos tﾃδｪm ficado acima da inflaﾃδｧﾃδ｣o e do crescimento das receitas municipais.
Municﾃδｭpios pagarﾃδ｣o o reajuste:
ﾃ｢竄ｬﾅ徹 novo piso significarﾃδ｡ um aumento de cerca de R$ 7 bilhﾃδｵes nos gastos dos municﾃδｭpiosﾃ｢竄ｬ</segment>
    <segment id="38">, acrescentou o presidente da Confederaﾃδｧﾃδ｣o Nacional dos Municﾃδｭpios (CNM)</segment>
    <segment id="39">, Paulo Ziulkoski.</segment>
    <segment id="40">A Lei 11.738/2008 regulamenta o piso nacional dos professores.</segment>
    <segment id="41">Jﾃδ｡ o reajuste anual tem</segment>
    <segment id="42">comocomo base a variaﾃδｧﾃδ｣o do valor</segment>
    <segment id="43">mﾃδｭnimo gasto com cada aluno das escolas pﾃδｺblicas.</segment>
    <segment id="44">Essa variaﾃδｧﾃδ｣o</segment>
    <segment id="45">ﾃδｩ definida anualmente pelo Fundo de Manutenﾃδｧﾃδ｣o e Desenvolvimento da Educaﾃδｧﾃδ｣o Bﾃδ｡sica e de Valorizaﾃδｧﾃδ｣o dos Profissionais de Educaﾃδｧﾃδ｣o (Fundeb).</segment>
  </rst>
