  <rst>
    <segment id="1">Mistério Homem morre antes do culto</segment>
    <segment id="2">Antônio foi morto a um quilômetro de casa
Antônio Ponciano dos Santos</segment>
    <segment id="3">, 54 anos</segment>
    <segment id="4">, foi assassinado a tiros</segment>
    <segment id="5">, no início da manhã de ontem</segment>
    <segment id="6">, na Rua  Elmano Silveira Castro</segment>
    <segment id="7">, no bairro do IAPI.</segment>
    <segment id="8">Segundo um homem</segment>
    <segment id="9">, que preferiu não</segment>
    <segment id="10">sese identificar</segment>
    <segment id="11">, Antônio era comumente visto descendo a rua</segment>
    <segment id="12">, no início da manhã.</segment>
    <segment id="13">A assessoria de imprensa da Polícia Civil informou que Antônio costumava ir à Igreja Universal do Reino de Deus</segment>
    <segment id="14">, na região do Iguatemi</segment>
    <segment id="15">, nas manhãs de segunda-feira.</segment>
    <segment id="16">Mas, não confirmou</segment>
    <segment id="17">sese ele seguia para o templo</segment>
    <segment id="18">, quando foi assassinado.</segment>
    <segment id="19">A família deve ser ouvida pela polícia</segment>
    <segment id="20">, ainda essa semana.</segment>
    <segment id="21">Família não localizada</segment>
    <segment id="22">Os vizinhos da vítima não  quiseram falar sobre o</segment>
    <segment id="23">casocaso ou dar qualquer informação sobre Antônio.</segment>
    <segment id="24">A reportagem não encontrou nenhum parente  na casa da família e no Instituto Médico Legal (IML).</segment>
    <segment id="25">A polícia investiga a informação</segment>
    <segment id="26">, ainda não confirmada</segment>
    <segment id="27">, de que Antônio responde a um homicídio contra um vizinho</segment>
    <segment id="28">, desde 2004.</segment>
  </rst>
