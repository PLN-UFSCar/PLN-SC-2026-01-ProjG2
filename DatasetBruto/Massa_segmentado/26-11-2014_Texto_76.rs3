  <rst>
    <segment id="1">Mulher mete a faca no marido gringo
Dona de casa mata a facadas o marido gringo enquanto ele dormia</segment>
    <segment id="2">A dona de casa Elaine Marques Marot</segment>
    <segment id="3">, 28, conheceu o belga Louis Emile Chislam Marot</segment>
    <segment id="4">, 52, quando ainda era garota de programa e trabalhava no Pelourinho.</segment>
    <segment id="5">Segundo ela</segment>
    <segment id="6">, foram sete anos de relacionamento atﾃδｩ que</segment>
    <segment id="7">sese casaram</segment>
    <segment id="8">, em fevereiro passado.</segment>
    <segment id="9">Nove meses depois</segment>
    <segment id="10">, ela pﾃδｴs fim ﾃδ relaﾃδｧﾃδ｣o de forma trﾃδ｡gica: esfaqueou Louis</segment>
    <segment id="11">, enquanto ele dormia.</segment>
    <segment id="12">O crime aconteceu na noite de anteontem</segment>
    <segment id="13">, na casa deles</segment>
    <segment id="14">, no Loteamento Pedra do Sol</segment>
    <segment id="15">, em Barra Grande</segment>
    <segment id="16">, municﾃδｭpio de Vera Cruz</segment>
    <segment id="17">, na Ilha de Itaparica.</segment>
    <segment id="18">Elaine alegou que era vﾃδｭtima</segment>
    <segment id="19">, desde o inﾃδｭcio do casamento</segment>
    <segment id="20">, de violﾃδｪncia fﾃδｭsica e verbal.</segment>
    <segment id="21">Ela mostrou ferimentos no corpo e atribuiu ao marido.</segment>
    <segment id="22">A dona de casa contou que cometeu o crime por ﾃ｢竄ｬﾅ途aiva de tanto tempoﾃ｢竄ｬ de agressﾃδ｣o.  ﾃ｢竄ｬﾅ摘le me batia com a mﾃδ｣o mesmo.</segment>
    <segment id="23">Me empurrouﾃ｢竄ｬ.</segment>
    <segment id="24">Louis teria tambﾃδｩm ciﾃδｺmes da mulher.</segment>
    <segment id="25">ﾃ｢竄ｬﾅ摘u nﾃδ｣o queria ter tirado a vida dele.</segment>
    <segment id="26">Nﾃδ｣o era para ter sido dessa forma</segment>
    <segment id="27">, masmas aconteceuﾃ｢竄ｬ.
Sem passagem pela polﾃδｭcia</segment>
    <segment id="28">, Elaine contou que chegou a sair de casa por dois dias</segment>
    <segment id="29">, masmas</segment>
    <segment id="30">, ao retornar para pegar suas coisas</segment>
    <segment id="31">, foi ameaﾃδｧada e permaneceu.</segment>
    <segment id="32">Questionada por que nunca registrou queixa contra Louis</segment>
    <segment id="33">, que era ﾃ｢竄ｬﾅ田apitﾃδ｣o de um navioﾃ｢竄ｬ na Franﾃδｧa</segment>
    <segment id="34">, nﾃδ｣o quis responder.</segment>
    <segment id="35">A filha de Elaine</segment>
    <segment id="36">, 7, de outro relacionamento</segment>
    <segment id="37">, estava em casa.</segment>
    <segment id="38">Ao ver Louis</segment>
    <segment id="39">, a quem chamava de tio</segment>
    <segment id="40">, morto</segment>
    <segment id="41">, comeﾃδｧou a chorar.</segment>
    <segment id="42">Elaine ligou para o Samu e disse que o marido tinha sido vﾃδｭtima de um roubo seguido de morte</segment>
    <segment id="43">, masmas na delegacia confessou o crime.</segment>
    <segment id="44">Dopou com remﾃδｩdio</segment>
    <segment id="45">Elaine contou ﾃδ polﾃδｭcia que havia saﾃδｭdo com a filha para brincar na rua.</segment>
    <segment id="46">Quando voltou</segment>
    <segment id="47">, o marido iniciou uma discussﾃδ｣o e a teria xingado.</segment>
    <segment id="48">Depois</segment>
    <segment id="49">, eles jantaram e ela colocou um comprimido de Diazepam no chﾃδ｡ verde que ele costumava tomar.</segment>
    <segment id="50">Louis teria adormecido no sofﾃδ｡</segment>
    <segment id="51">, masmas acordou</segment>
    <segment id="52">, foi ao banheiro e escovou os dentes.</segment>
    <segment id="53">Depois</segment>
    <segment id="54">, foi dormir no quarto e ainda a chamou</segment>
    <segment id="55">, masmas Elaine respondeu que iria assistir a um filme.</segment>
    <segment id="56">Ela relatou que fumou maconha e esperou.</segment>
    <segment id="57">Apanhou uma peixeira da cozinha e</segment>
    <segment id="58">, enquanto ele dormia</segment>
    <segment id="59">, desferiu um golpe no pescoﾃδｧo do belga</segment>
    <segment id="60">, que ainda teria conseguido levantar</segment>
    <segment id="61">, masmas acabou caindo e morreu no chﾃδ｣o da casa.</segment>
    <segment id="62">ﾃ｢竄ｬﾅ填ma pessoa fria e calculistaﾃ｢竄ｬ</segment>
    <segment id="63">, diz delegado</segment>
    <segment id="64">ﾃ｢竄ｬﾅ摘la</segment>
    <segment id="65">ﾃδｩ uma pessoa fria</segment>
    <segment id="66">, calculista e usuﾃδ｡ria de drogas.</segment>
    <segment id="67">Premeditou a morte do Louis.</segment>
    <segment id="68">A faca atingiu a carﾃδｳtidaﾃ｢竄ｬ</segment>
    <segment id="69">, destacou o titular da 24ﾃつｪ Delegacia (Vera Cruz)</segment>
    <segment id="70">, Geovani Paranhos.</segment>
    <segment id="71">A polﾃδｭcia vai tentar contato com a embaixada belga para encontrar familiares da vﾃδｭtima.</segment>
    <segment id="72">Louis estava construindo uma pousada no local onde moravam.</segment>
    <segment id="73">Um ex-companheiro de Elaine e pai da filha dela contou que jﾃδ｡ havia aconselhado que ela fosse a um mﾃδｩdico:</segment>
    <segment id="74">ﾃ｢竄ｬﾅ撤ara ela fazer exame da cabeﾃδｧa</segment>
    <segment id="75">, para esse nervosismo.</segment>
    <segment id="76">Lutei muito para ela irﾃ｢竄ｬ</segment>
    <segment id="77">, explicou.</segment>
    <segment id="78">A menina de 7 anos foi entregue ao pai</segment>
    <segment id="79">, que nﾃδ｣o quis ser identificado.</segment>
  </rst>
