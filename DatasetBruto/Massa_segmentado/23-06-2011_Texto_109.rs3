  <rst>
    <segment id="1">Quina de São João sai para sete apostadores
RIO - A Quina de São João</segment>
    <segment id="2">, sorteada neste sábado</segment>
    <segment id="3">, na cidade de Caruaru</segment>
    <segment id="4">, em Pernambuco</segment>
    <segment id="5">, saiu para sete apostadores.</segment>
    <segment id="6">Os acertadores irão dividir o maior prêmio pago pela modalidade desde a sua criação.</segment>
    <segment id="7">Foram três ganhadores em São Paulo (SP)</segment>
    <segment id="8">, dois do Rio de Janeiro (RJ)</segment>
    <segment id="9">, um de Curitiba (PR) e um de Ituiutaba (MG).</segment>
    <segment id="10">As dezenas sorteadas foram 02 - 04 - 27 - 36 e 51 e os ganhadores vão receber</segment>
    <segment id="11">, cada um</segment>
    <segment id="12">, o prêmio de R$ 12.712.834</segment>
    <segment id="13">,52.</segment>
    <segment id="14">Na segunda faixa de premiação</segment>
    <segment id="15">, 1.918 apostadores acertaram quatro dezenas e vão levar R$ 4.057</segment>
    <segment id="16">,06 cada.</segment>
    <segment id="17">De acordo com a Caixa</segment>
    <segment id="18">, 128.445 apostadores acertaram três dezenas</segment>
    <segment id="19">, e vão receber R$ 86</segment>
    <segment id="20">,54 cada.</segment>
    <segment id="21">O valor total do prêmio é de cerca de R$ 89 milhões</segment>
    <segment id="22">, ultrapassando a estimativa inicial da CAIXA</segment>
    <segment id="23">, que era de R$ 80 milhões</segment>
    <segment id="24">, e superando em 33% a Quina de São João do ano passado.</segment>
    <segment id="25">Em todo o território nacional</segment>
    <segment id="26">, foram vendidos mais de 33 milhões de bilhetes.</segment>
    <segment id="27">As apostas começaram no dia 24 de maio e o total arrecadado foi de mais de R$ 101 milhões.</segment>
    <segment id="28">De cada concurso regular da Quina</segment>
    <segment id="29">, ao longo do ano</segment>
    <segment id="30">, 15% do valor arrecadado é destinado ao prêmio da primeira faixa do concurso especial da Quina de São João.</segment>
  </rst>
</analysis>