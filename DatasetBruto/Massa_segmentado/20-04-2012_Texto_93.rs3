  <rst>
    <segment id="1">Feliz aniversário</segment>
    <segment id="2">, Rei Roberto!</segment>
    <segment id="3">Há 21 anos</segment>
    <segment id="4">, o fã-clube ‘</segment>
    <segment id="5">Os inimitáveis’ festeja o nascimento do ídolo</segment>
    <segment id="6">O aniversário de 71 anos do rei Roberto Carlos foi comemorado em grande estilo pelo fã-clube “</segment>
    <segment id="7">Os inimitáveis”</segment>
    <segment id="8">, no edifício Adriana Marta</segment>
    <segment id="9">, em Brotas</segment>
    <segment id="10">, com direito a bolo personalizado</segment>
    <segment id="11">, camisas e discografia do cantor.</segment>
    <segment id="12">A festa surgiu a partir de uma brincadeira de amigos na Escola Técnica Federal da Bahia (atual Ifba)</segment>
    <segment id="13">, e ontem foi realizada pelo 21º ano consecutivo.</segment>
    <segment id="14">Organizador do fã clube</segment>
    <segment id="15">, Carlos Alberto</segment>
    <segment id="16">, 42 , relata orgulhoso</segment>
    <segment id="17">cada detalhe da celebração</segment>
    <segment id="18">.</segment>
    <segment id="19">“</segment>
    <segment id="20">Nós seguimos o ritual de bater os parabéns ao som da música ‘Amigo’</segment>
    <segment id="21">, e colocamos ao comando da homenagem a matriarca do grupo</segment>
    <segment id="22">, dona Nininha”</segment>
    <segment id="23">, conta.</segment>
    <segment id="24">Josefa Vieira</segment>
    <segment id="25">, a  dona  Nininha</segment>
    <segment id="26">, é mãe de Alberto e é responsável por ter influenciado a paixão do filho pelo rei.</segment>
    <segment id="27">A casa da dona Nininha é toda decorada com fotos do ídolo e</segment>
    <segment id="28">, segundo diz</segment>
    <segment id="29">, não há um só dia em que ela não escute os discos de Roberto Carlos.</segment>
    <segment id="30">O fã-clube do rei</segment>
    <segment id="31">, apesar de não ser registrado</segment>
    <segment id="32">, conta com cerca de 45 participantes que não perdem um show do artista na cidade.</segment>
    <segment id="33">A turma presta atenção a tudo que envolve a vida de Roberto e faz questão de expressar isso nas festas.</segment>
    <segment id="34">Exemplo disso é que no ano da morte de Maria Rita a camisa foi preta</segment>
    <segment id="35">, em sinal de luto.</segment>
    <segment id="36">Grandes emoções</segment>
    <segment id="37">O grande sonho do fã-clube é conseguir falar com o rei Roberto.</segment>
    <segment id="38">Esse encontro por pouco não foi alcançado no último show realizado pelo cantor no TCA</segment>
    <segment id="39">, em Salvador.</segment>
    <segment id="40">Ao ver o grupo organizado com as camisas</segment>
    <segment id="41">, a produção agendou uma coletiva entre os fãs e o artista</segment>
    <segment id="42">, que logo foi cancelada devido à agenda do cantor.</segment>
    <segment id="43">Adalgisa</segment>
    <segment id="44">, uma das integrantes do grupo</segment>
    <segment id="45">, até já pulou de cadeira em cadeira para alcançar o palco e entregar uma faixa a Roberto Carlos.</segment>
    <segment id="46">De tão fissurada que é</segment>
    <segment id="47">, ela não perde os shows do ídolo nem mesmo em outros estados</segment>
    <segment id="48">, por isso deixou de prestigiar a festa ontem para acompanhá-lo pessoalmente no Maracanãzinho</segment>
    <segment id="49">, no Rio de Janeiro.</segment>
  </rst>
</analysis>