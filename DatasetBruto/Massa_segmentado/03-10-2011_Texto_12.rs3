  <rst>
    <segment id="1">Gordinha arrasa na Chapada
Não tem quem não conheça a gata no bairro onde mora
dilene Machado</segment>
    <segment id="2">, 21 anos</segment>
    <segment id="3">, é uma gordinha bastante sensual.</segment>
    <segment id="4">Mesmo fora dos padrões estéticos impostos pela sociedade</segment>
    <segment id="5">, a gata arrasa por onde passa e quer disputar o concurso “Garota do Tempo”.</segment>
    <segment id="6">Na Chapada do Rio Vermelho</segment>
    <segment id="7">, bairro onde mora desde que veio de Alagoinhas</segment>
    <segment id="8">, sua terra natal</segment>
    <segment id="9">, não tem quem não conheça “Eny Malvadinha”</segment>
    <segment id="10">, apelido carinhoso dado por suas companheiras de farras.</segment>
    <segment id="11">Os reggaes das meninas são regados a muito pagode baiano.</segment>
    <segment id="12">“</segment>
    <segment id="13">Além do ritmo gostoso</segment>
    <segment id="14">, que faz o corpo balançar</segment>
    <segment id="15">, tem músicas que falam da qualidade das mulheres”</segment>
    <segment id="16">, opina Edilene</segment>
    <segment id="17">, sese referindo à canção “</segment>
    <segment id="18">As Gordinhas”</segment>
    <segment id="19">, de Flavinho</segment>
    <segment id="20">, do grupo</segment>
    <segment id="21">Os Barões.</segment>
    <segment id="22">“</segment>
    <segment id="23">Quem nunca provou não sabe o que está perdendo/ É  gordinha</segment>
    <segment id="24">, masmas é gostosa”.</segment>
    <segment id="25">O trecho do pagode parece ter sido feito sob medida para a moça.</segment>
    <segment id="26">“Ser gordinha é muito bom</segment>
    <segment id="27">, tem gente que acha ruim</segment>
    <segment id="28">, masmas eu gosto.</segment>
    <segment id="29">E é sempre bom ter onde apertar”</segment>
    <segment id="30">, sese diverte.</segment>
    <segment id="31">Bem-humorada</segment>
    <segment id="32">, a gata tira de letra qualquer crítica e faz questão de manter a autoestima em alta.</segment>
    <segment id="33">O único assunto que consegue tirar o sorriso da morena e deixá-la sem jeito é o coração.</segment>
    <segment id="34">“</segment>
    <segment id="35">Meu coração está aberto</segment>
    <segment id="36">, estou à procura de um amor”</segment>
    <segment id="37">, conta.</segment>
    <segment id="38">Enquanto ele não chega</segment>
    <segment id="39">, a ‘malvadinha’ corre atrás dos seus objetivos.</segment>
    <segment id="40">Um dos principais é ver reconhecido o valor do seu bairro.</segment>
    <segment id="41">“</segment>
    <segment id="42">A Chapada do Rio Vermelho é maravilhosa</segment>
    <segment id="43">, a fama ruim é</segment>
    <segment id="44">porque</segment>
    <segment id="45">porque o povo não sabe valorizar e cuidar do que temos aqui”.</segment>
    <segment id="46">Fala com propriedade</segment>
    <segment id="47">, já que cuidar de si é algo que ela sabe.</segment>
    <segment id="48">Desde que chegou a Salvador</segment>
    <segment id="49">, a moça fez vários cursos profissionalizantes.</segment>
    <segment id="50">“Sei me virar”.</segment>
  </rst>
</analysis>