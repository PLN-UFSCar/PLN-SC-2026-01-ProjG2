  <rst>
    <segment id="1">Multidão</segment>
    <segment id="2">sese reúne para ver inauguração da árvore de Natal da Lagoa
RIO - A festa de inauguração da árvore de Natal da Lagoa Rodrigo de Freitas atraiu</segment>
    <segment id="3">, na noite deste sábado</segment>
    <segment id="4">, uma multidão para o local.</segment>
    <segment id="5">Ela foi acesa por volta das 20h10</segment>
    <segment id="6">m.</segment>
    <segment id="7">Só na área reservada ao público</segment>
    <segment id="8">, no Estádio de Remo da Lagoa</segment>
    <segment id="9">, estão 10 mil pessoas acompanhando os efeitos especiais de som e luzes sincronizados.</segment>
    <segment id="10">As atrações têm uma estrutura cinematográfica</segment>
    <segment id="11">, com direito a cinco telões</segment>
    <segment id="12">, sendo dois na área do evento e os demais no Parques dos Patins</segment>
    <segment id="13">, no Corte do Cantagalo e no Parque dos Skates.</segment>
    <segment id="14">As telas transmitem em tempo real o show.</segment>
    <segment id="15">Acompanhe aqui</segment>
    <segment id="16">, ao vivo</segment>
    <segment id="17">, a transmissão da festa de inauguração</segment>
    <segment id="18">À tarde uma fila enorme aguardava a entrada</segment>
    <segment id="19">, que era feita por ordem de chegada</segment>
    <segment id="20">, na porta do estádio.</segment>
    <segment id="21">Um pouco antes da inauguração da 16ª edição da árvore</segment>
    <segment id="22">, por volta das 19h30m</segment>
    <segment id="23">, foi feito o lançamento oficial da logomarca dos jogos Paraolímpicos de 2016.</segment>
    <segment id="24">O lançamento foi realizado pelo Comitê Organizador dos Jogos Olimpícos e Paraolimpícos.</segment>
    <segment id="25">Entre as atrações musicais</segment>
    <segment id="26">, houve participações do coral da Fundação Bradesco</segment>
    <segment id="27">, com 60 vozes de alunos</segment>
    <segment id="28">, da orquestra sinfônica de Barra Mansa e dos cantores Gal Costa e Frejat.</segment>
    <segment id="29">O espetáculo também teve a participação do grupo Nós da Dança.</segment>
    <segment id="30">O ator Edson Celulari é o mestre de cerimônias.</segment>
    <segment id="31">A estrutura da árvore tem 85 metros</segment>
    <segment id="32">, o equivalente a edifício de 28 andares.</segment>
    <segment id="33">Ela começou a ser montada no dia 23 de setembro</segment>
    <segment id="34">, o que mobilizou 1200 pessoas.</segment>
    <segment id="35">A diferença para os anos anteriores é que desta vez ela terá presentes flutuantes na sua base.</segment>
    <segment id="36">Uma referência à troca de presentes da noite de Natal.</segment>
    <segment id="37">Ela foi decorada com efeites natalinos infantis</segment>
    <segment id="38">comocomo bengalas e meias.</segment>
    <segment id="39">A cenografia é assinada por Abel Gomes.</segment>
    <segment id="40">A árvores conta com 12 fases de luzes e cores produzidas por 3</segment>
    <segment id="41">, 3 milhões de microlâmpadas.</segment>
    <segment id="42">São 105 quilômetros de mangueiras luminosas e 2.100 estrobos que darão um efeito de estrelas brilhando.</segment>
    <segment id="43">A Secretaria de Ordem Pública (Seop) realizou uma operação no entorno da Lagoa para coibir irregularidades no lançamento da árvore de Natal.</segment>
    <segment id="44">Os agentes multaram 122 veículos e rebocaram 10 por estacionamento irregular.</segment>
    <segment id="45">Os fiscais também apreenderam produtos com ambulantes não autorizados.</segment>
    <segment id="46">Entre os itens estavam 129 embalagens de bebidas</segment>
    <segment id="47">, 35 pacotes de biscoito e dois botijões de gás.</segment>
  </rst>
</analysis>