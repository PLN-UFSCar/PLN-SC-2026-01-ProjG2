  <rst>
    <segment id="1">Fuja dos micos no trabalho
Saiba</segment>
    <segment id="2">comocomo</segment>
    <segment id="3">sese comportar na empresa e não ganhar o título de ‘sem-noção’</segment>
    <segment id="4">Todo mundo vive sendo analisado no ambiente de trabalho.</segment>
    <segment id="5">Seja por colegas ou pelo próprio chefe</segment>
    <segment id="6">, sempre tem uma criatura que espera um pequeno deslize para cair matando.</segment>
    <segment id="7">Para não ficar mal visto</segment>
    <segment id="8">, com fama de trapalhão ou inconveniente</segment>
    <segment id="9">, reavalie suas atitudes dentro da empresa.</segment>
    <segment id="10">Situações</segment>
    <segment id="11">comocomo toque de celular alto</segment>
    <segment id="12">, ouvir música</segment>
    <segment id="13">, vestir-</segment>
    <segment id="14">sese com roupas muito decotadas ou de uma forma “largada” podem sugerir que você não</segment>
    <segment id="15">sese preocupa com a conduta profissional.</segment>
    <segment id="16">Mas tudo depende do local onde você trabalha.</segment>
    <segment id="17">“</segment>
    <segment id="18">A pessoa precisa selecionar o que pode ou não fazer no meio profissional.</segment>
    <segment id="19">É preciso identificar</segment>
    <segment id="20">comocomo funciona a cultura da empresa e agir de acordo com o que é estabelecido”</segment>
    <segment id="21">, orienta o psicólogo Elídio Almeida.</segment>
    <segment id="22">O assessor jurídico Maurício Lunna</segment>
    <segment id="23">, 30, conhece bem essa história.</segment>
    <segment id="24">“Participo de audiências com juiz e essa área é muito tradicional.</segment>
    <segment id="25">Sempre usei piercing</segment>
    <segment id="26">, brincos</segment>
    <segment id="27">, cabelo grande e barba.</segment>
    <segment id="28">Até que uma cliente disse que tinha</segment>
    <segment id="29">sese surpreendido com meu trabalho</segment>
    <segment id="30">, já que minha aparência fez ela pensar que não era capaz”</segment>
    <segment id="31">, conta.</segment>
    <segment id="32">A declaração da moça fez o rapaz mudar radicalmente o visual.</segment>
    <segment id="33">“</segment>
    <segment id="34">Hoje, sinto-me um pacote</segment>
    <segment id="35">, masmas percebi que dá certo.</segment>
    <segment id="36">Visto paletó e gravata</segment>
    <segment id="37">, tirei os brincos</segment>
    <segment id="38">, cortei os cabelos e fiz a barba”</segment>
    <segment id="39">, admite.</segment>
    <segment id="40">Portanto</segment>
    <segment id="41">, faça a sua parte</segment>
    <segment id="42">, respeite os limites e espaços dos colegas e seja uma pessoa bem vista dentro da empresa.</segment>
    <segment id="43">Confira o que não fazer

CELULAR - deve ficar no vibra call.</segment>
    <segment id="44">Aparelhos que tocam alto desconcentram os colegas e é chato ficar ouvindo o toque.</segment>
    <segment id="45">Se quiser ouvir música</segment>
    <segment id="46">, coloque um fone de ouvido para não obrigar aos outros a ouvirem o que você gosta.</segment>
    <segment id="47">E-MAILS - A caixa postal de trabalho é para ser usado somente para assuntos profissionais.</segment>
    <segment id="48">Não mande carinhas</segment>
    <segment id="49">, bonequinhos</segment>
    <segment id="50">, correntes ou papo furado para os colegas.</segment>
    <segment id="51">Seja objetivo!</segment>
    <segment id="52">REDES SOCIAIS - servem para socializar e não para usar de forma leviana.</segment>
    <segment id="53">E pior</segment>
    <segment id="54">, sair falando do chefe ou colegas pode gerar demissão com justa causa.</segment>
    <segment id="55">Por isso</segment>
    <segment id="56">, pense muito 
bem antes de postar qualquer coisa.</segment>
    <segment id="57">REUNIÕES - É coisa séria e</segment>
    <segment id="58">, assim</segment>
    <segment id="59">comocomo você</segment>
    <segment id="60">, os outros também querem que acabe logo.</segment>
    <segment id="61">Ouça atentamente o que os outros dizem e evite 
outras atividades</segment>
    <segment id="62">, como</segment>
    <segment id="63">como falar ao celular ou enviar mensagens.</segment>
  </rst>
</analysis>