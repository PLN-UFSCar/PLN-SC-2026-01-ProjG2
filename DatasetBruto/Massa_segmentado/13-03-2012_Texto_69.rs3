  <rst>
    <segment id="1">Assaltos rondam volta às aulas de alunos da UFF
RIO - Na volta às aulas</segment>
    <segment id="2">, a violência começou a rondar alunos da UFF</segment>
    <segment id="3">, em Niterói.</segment>
    <segment id="4">Somente nos dois primeiros dias do período no Instituto de Artes e Comunicação Social (Iacs)</segment>
    <segment id="5">, esta semana</segment>
    <segment id="6">, estudantes relataram a ocorrência de dois assaltos nas imediações do campus</segment>
    <segment id="7">, na Rua Professor Lara Vilela</segment>
    <segment id="8">, em São Domingos.</segment>
    <segment id="9">Por volta do meio-dia de terça-feira</segment>
    <segment id="10">, nas proximidades do Iacs</segment>
    <segment id="11">, uma aluna foi rendida e teve a bolsa levada por um bandido armado com uma faca.</segment>
    <segment id="12">Na segunda-feira</segment>
    <segment id="13">, duas pessoas - incluindo um segurança da instituição - também tiveram seus pertences roubados na mesma localidade.</segment>
    <segment id="14">E uma aluna do curso de veterinária teve seu carro furtado no Vital Brazil na sexta-feira passada.</segment>
    <segment id="15">Segundo contaram estudantes</segment>
    <segment id="16">, as turmas que teriam aula na segunda-feira à noite no Iacs foram liberadas mais cedo.</segment>
    <segment id="17">Representantes da UFF e do 12º BPM (Niterói)</segment>
    <segment id="18">sese reuniram na terça-feira para traçar um plano de ação no entorno das unidades da instituição.</segment>
    <segment id="19">A Rua Lara Vilela está entre as que serão incluídas no planejamento.</segment>
    <segment id="20">Na quinta-feira passada</segment>
    <segment id="21">, a Polícia Militar realizou uma megaoperação - que continuou na sexta-feira - em 14 favelas de Niterói e Maricá</segment>
    <segment id="22">, na Região Metropolitana do Rio</segment>
    <segment id="23">, e terminou com 17 presos e detidos (sendo 11 adultos e seis menores).</segment>
    <segment id="24">O resultado foi considerado aquém do esperado.</segment>
    <segment id="25">Quatrocentos e doze policiais</segment>
    <segment id="26">, com apoio de dois helicópteros</segment>
    <segment id="27">, participaram da ação que teve</segment>
    <segment id="28">comocomo objetivo reprimir a violência que vem crescendo na cidade.</segment>
    <segment id="29">Todos os presos na ação</segment>
    <segment id="30">, uma das maiores dos últimos anos</segment>
    <segment id="31">, são moradores de Niterói.</segment>
    <segment id="32">Segundo informações do 12º BPM (Niterói)</segment>
    <segment id="33">, nem todos os presos são traficantes.</segment>
    <segment id="34">Entre eles está um ambulante morador do Fonseca</segment>
    <segment id="35">, em Niterói</segment>
    <segment id="36">, que estava vendendo produtos piratas.</segment>
    <segment id="37">Ao todo</segment>
    <segment id="38">, foram apreendidas 115 trouxinhas de maconha</segment>
    <segment id="39">, além de um tablete com um quilo da droga.</segment>
    <segment id="40">Além disso</segment>
    <segment id="41">, a polícia recolheu ainda 763 papelotes de cocaína e 49 pedras de crack.</segment>
    <segment id="42">Foram apreendidos também uma pistola 9mm com treze munições</segment>
    <segment id="43">, 105 motos (só uma roubada)</segment>
    <segment id="44">, 19 carros e um quadriciclo.</segment>
  </rst>
</analysis>