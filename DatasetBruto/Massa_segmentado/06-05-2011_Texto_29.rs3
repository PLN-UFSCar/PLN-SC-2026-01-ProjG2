  <rst>
    <segment id="1">Falta de comando e dinheiro no reinício do Fluminense</segment>
    <segment id="2">Em campo</segment>
    <segment id="3">, o Fluminense ficou preso no Libertad.</segment>
    <segment id="4">Fora dele</segment>
    <segment id="5">, os jogadores continuam livres de comando.</segment>
    <segment id="6">Sem técnico até a chegada de Abel Braga no dia 12 de junho</segment>
    <segment id="7">, gerente e vice-presidente de futebol</segment>
    <segment id="8">, o time vai iniciar a segunda metade da temporada na terça-feira com uma realidade bem diferente do início do ano.</segment>
    <segment id="9">O único motivo para comemorar foi o tímido superávit de R$ 1</segment>
    <segment id="10">,5 milhão no primeiro trimestre.</segment>
    <segment id="11">A dívida total de R$ 380 milhões está entre as três maiores do Brasil.</segment>
    <segment id="12">Com a eliminação na Copa Libertadores</segment>
    <segment id="13">, o Fluminense deixou de ganhar</segment>
    <segment id="14">, em caso</segment>
    <segment id="15">caso de título e arrecadação com bilheterias</segment>
    <segment id="16">, cerca de R$ 20 milhões.</segment>
    <segment id="17">Ações trabalhistas são 500</segment>
    <segment id="18">Em 2010</segment>
    <segment id="19">, o Fluminense adiantou R$ 34 milhões da receita deste ano</segment>
    <segment id="20">, que terá um orçamento apertado.</segment>
    <segment id="21">O clube</segment>
    <segment id="22">, sofre</segment>
    <segment id="23">, ainda</segment>
    <segment id="24">, com as ações trabalhistas.</segment>
    <segment id="25">Nos últimos seis anos</segment>
    <segment id="26">, 90 jogadores entraram com ações contra o clube.</segment>
    <segment id="27">Há cerca de 500 ações trabalhistas contra o clube.</segment>
    <segment id="28">A nova administração afirma ter pago R$ 6 milhões em dívidas desde o início do mandato do presidente Peter Siemsen.</segment>
  </rst>
</analysis>