  <rst>
    <segment id="1">Itapuã é líder de reclamações</segment>
    <segment id="2">Com 1.763 queixas</segment>
    <segment id="3">, o bairro liderou o ranking de reclamações por poluição sonora</segment>
    <segment id="4">Dono de uma paisagem encantadora</segment>
    <segment id="5">, o bairro de Itapuã é considerado também o mais barulhento da cidade.</segment>
    <segment id="6">A informação vem do relatório de reclamações por poluição sonora da Sucom</segment>
    <segment id="7">, divulgado na última sexta-feira.</segment>
    <segment id="8">Os moradores da região confirmam: durante o dia</segment>
    <segment id="9">, a barulheira</segment>
    <segment id="10">sese concentra mais na orla</segment>
    <segment id="11">, onde os carros abrem o porta-malas e tocam o terror no som.</segment>
    <segment id="12">À noite</segment>
    <segment id="13">, porém</segment>
    <segment id="14">porém, o barulho vem dos bares com som ao vivo</segment>
    <segment id="15">, ou simplesmente nas portas das casas</segment>
    <segment id="16">,  incomodando a vizinhança.</segment>
    <segment id="17">“Às vezes o barulho é tão insuportável que é difícil ouvir a televisão”</segment>
    <segment id="18">, afirma Luiz Pedro dos Santos</segment>
    <segment id="19">, 63, morador do Largo do Jenipapeiro.</segment>
    <segment id="20">De acordo com a Sucom</segment>
    <segment id="21">, para combater o problema</segment>
    <segment id="22">, foram realizadas várias ações repressivas</segment>
    <segment id="23">, que resultaram na apreensão de 2.820 equipamentos sonoros e 1.100 autos de infração.</segment>
    <segment id="24">Além disso</segment>
    <segment id="25">, foram feitas 92 ações de caráter educativo entre a população.</segment>
    <segment id="26">Na sequência</segment>
    <segment id="27">, as regiões com maior incidência de barulho foram Boca do Rio</segment>
    <segment id="28">, Liberdade</segment>
    <segment id="29">, Pernambués</segment>
    <segment id="30">, Pituba</segment>
    <segment id="31">, Uruguai</segment>
    <segment id="32">, São Caetano</segment>
    <segment id="33">, Brotas</segment>
    <segment id="34">, Ribeira e Massaranduba.</segment>
    <segment id="35">As fontes sonoras que mais geraram reclamações foram veículos particulares</segment>
    <segment id="36">, representando 45</segment>
    <segment id="37">,31% do total.</segment>
    <segment id="38">Homens barulhentos

Pesquisa desenvolvida pela Gerência de Fiscalização e Prevenção à Poluição Sonora</segment>
    <segment id="39">, da Sucom</segment>
    <segment id="40">, mostrou que os homens com idade entre 26 e 35 anos</segment>
    <segment id="41">, moradores dos bairros de São Caetano</segment>
    <segment id="42">, Pernambués</segment>
    <segment id="43">, Liberdade</segment>
    <segment id="44">, Paripe e Plataforma</segment>
    <segment id="45">, foram os maiores poluidores sonoros de Salvador em 2011.</segment>
    <segment id="46">Estes cinco bairros representaram 47% das ocorrências de toda a capital.</segment>
  </rst>
</analysis>