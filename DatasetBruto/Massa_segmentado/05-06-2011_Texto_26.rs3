  <rst>
    <segment id="1">Vasco sofre apagão e perde por 5 a 1 para o Coritiba
RIO - No duelo de reservas</segment>
    <segment id="2">, o Coritiba</segment>
    <segment id="3">sese impôs neste domingo</segment>
    <segment id="4">, com a força de um titular.</segment>
    <segment id="5">O Vasco sofreu um apagão no estádio Couto Pereira</segment>
    <segment id="6">, em Curitiba</segment>
    <segment id="7">, e a estrela de Anderson Aquino brilhou.</segment>
    <segment id="8">A equipe perdeu por 5 a 1 - três gols do atacante -</segment>
    <segment id="9">, na terceira rodada do Campeonato Brasileiro.</segment>
    <segment id="10">O resultado do confronto entre o Gigante da Colina e o Coxa não repercute na Copa do Brasil</segment>
    <segment id="11">, na qual o Vasco tem vantagem do empate para a partida decisiva na quarta-feira</segment>
    <segment id="12">, no mesmo estádio.</segment>
    <segment id="13">O time carioca venceu por 1 a 0 no jogo de ida</segment>
    <segment id="14">, em São Januário.</segment>
    <segment id="15">Com os elencos titulares sendo preservados para a grande final</segment>
    <segment id="16">, o atacante do Coritiba pôde atuar</segment>
    <segment id="17">porque</segment>
    <segment id="18">porque está suspenso para a partida desta semana.</segment>
    <segment id="19">O Vasco ocupa a sétima posição na tabela</segment>
    <segment id="20">, com seis pontos</segment>
    <segment id="21">, e o Coritiba está em 12º</segment>
    <segment id="22">, com três.
LANCE</segment>
    <segment id="23">A LANCE:
veja</segment>
    <segment id="24">comocomo foi o tempo real da partida
CLASSIFICAÇÃO:</segment>
    <segment id="25">Confira</segment>
    <segment id="26">comocomo está a tabela</segment>
    <segment id="27">O primeiro gol saiu logo no primeiro minuto de jogo</segment>
    <segment id="28">, dos pés de Tcheco.</segment>
    <segment id="29">Ele se</segment>
    <segment id="30">se aproveitou da falha da zaga vascaína e apareceu certeiro no meio da área</segment>
    <segment id="31">, sem deixar chances para Fernando Prass.</segment>
    <segment id="32">Falhas da zaga</segment>
    <segment id="33">, aliás</segment>
    <segment id="34">, sobraram.</segment>
    <segment id="35">Jogadas que começavam pela lateral</segment>
    <segment id="36">, terminando com finalizações pelo meio não pararam de acontecer</segment>
    <segment id="37">, sem que o time de Ricardo Gomes conseguisse impedir.</segment>
    <segment id="38">Os dois gols seguintes vieram aos 10 e aos 14 minutos</segment>
    <segment id="39">, quando Anderson Aquino resolveu deixar sua marca na partida.</segment>
    <segment id="40">No primeiro</segment>
    <segment id="41">, ele recebeu cruzamento de Leonardo pela direita e finalizou com força no fundo das redes de Prass.</segment>
    <segment id="42">Três minutos depois</segment>
    <segment id="43">, o atacante ampliou</segment>
    <segment id="44">, após receber passe pela esquerda e concluir com classe.</segment>
    <segment id="45">O Vasco tentou reagir</segment>
    <segment id="46">, masmas os jogadores já</segment>
    <segment id="47">sese mostravam abatidos</segment>
    <segment id="48">, além de encontrarem dificuldade nas finalizações.</segment>
    <segment id="49">Aos 19</segment>
    <segment id="50">, Leandro chutou em cima da zaga</segment>
    <segment id="51">, a bola voltou nele e</segment>
    <segment id="52">, em seguida</segment>
    <segment id="53">, ele acertou a trave.</segment>
    <segment id="54">Como resposta</segment>
    <segment id="55">, o Coritiba ampliou.</segment>
    <segment id="56">Leonardo invadiu a área vascaína</segment>
    <segment id="57">, atrasou para Anderson Aquino</segment>
    <segment id="58">, que apareceu mais uma vez certeiro pelo meio.</segment>
    <segment id="59">O Coxa estava tão à vontade que a torcida gritava 'olé' na troca de passes.</segment>
    <segment id="60">O Vasco voltou diferente para o segundo tempo</segment>
    <segment id="61">, com Bernardo no lugar de Enrico.</segment>
    <segment id="62">Mas a modificação não adiantou muito e o jogo ficou mais lento.</segment>
    <segment id="63">Até Maranhão invadir a área pela direita e chutar cruzado direto para o gol</segment>
    <segment id="64">, aos 20 minutos.</segment>
    <segment id="65">Aos 23</segment>
    <segment id="66">, Elton ainda fez o gol de honra do Vasco.</segment>
    <segment id="67">Ele recebeu na frente do gol</segment>
    <segment id="68">, dominou e fez o giro</segment>
    <segment id="69">, acertando o fundo das redes de Vanderlei.</segment>
    <segment id="70">Mas não teve jeito.</segment>
    <segment id="71">O Coritiba ainda insistiu</segment>
    <segment id="72">, masmas Fernando Prass fez outras defesas.</segment>
    <segment id="73">Vasco e Coritiba voltam a</segment>
    <segment id="74">sese encontrar na quarta-feira</segment>
    <segment id="75">, no Couto Pereira mesmo</segment>
    <segment id="76">, pela final da Copa do Brasil.</segment>
    <segment id="77">FICHA TÉCNICA:
CORITIBA X VASCO
Local: Couto Pereira</segment>
    <segment id="78">, em Curitiba (PR)
Data/Hora: 5/6/2011 - 18h30min
Árbitro: Célio Amorim (SC)
Auxiliares: Kléber Lúcio Gil (SC) e Angelo Rudimar Bechi (SC)</segment>
    <segment id="79">Gols: Tcheco 1-0 (2'/1ºT)</segment>
    <segment id="80">, Anderson Aquino 2-0 (10'/1ºT)</segment>
    <segment id="81">, Anderson Aquino 3-0 (14'/1ºT)</segment>
    <segment id="82">, Anderson Aquino 4-0 (19'/1ºT)</segment>
    <segment id="83">, Maranhão 5-0 (19'/2ºT)</segment>
    <segment id="84">, Elton 5-1 (22'/2ºT)
CORITIBA: Vanderlei</segment>
    <segment id="85">, Maranhão</segment>
    <segment id="86">, Luccas Claro</segment>
    <segment id="87">, Walisson Ceará e Eltinho (Triguinho 23'/2ºT)</segment>
    <segment id="88">;</segment>
    <segment id="89">Djair, Tcheco</segment>
    <segment id="90">, Marcos Paulo e Everton Ribeiro (Everton Costa 36'/2ºT)</segment>
    <segment id="91">; Anderson Aquino (Geraldo - 15'/2ºT) e Leonardo.</segment>
    <segment id="92">Técnico: Marcelo Oliveira.
VASCO: Fernando Prass</segment>
    <segment id="93">; Fagner</segment>
    <segment id="94">, Fernando</segment>
    <segment id="95">, Jomar e Max (Irrazábal 26'/2ºT)</segment>
    <segment id="96">;</segment>
    <segment id="97">Jumar, Fellipe Bastos</segment>
    <segment id="98">, Enrico (Bernardo - intervalo) e Jéferson</segment>
    <segment id="99">; Leandro e Élton.</segment>
    <segment id="100">Técnico: Ricardo Gomes.</segment>
  </rst>
