  <rst>
    <segment id="1">Claudinha na curiosidade</segment>
    <segment id="2">Na curiosidade Musa mostra barriguinha</segment>
    <segment id="3">, masmas ignora sexo do bebê</segment>
    <segment id="4">Em entrevista à revista “Quem”</segment>
    <segment id="5">, a musa loira do axé finalmente deixou à mostra sua barriguinha</segment>
    <segment id="6">, masmas não revelou o sexo de seu novo filhote.</segment>
    <segment id="7">Na verdade</segment>
    <segment id="8">, o único que detém essa informação é o médico da cantora</segment>
    <segment id="9">, pois</segment>
    <segment id="10">pois ela e seu marido optaram pela surpresa e querem esperar o nascimento da criança para saber</segment>
    <segment id="11">sese é menina ou menino.</segment>
    <segment id="12">Ainda assim</segment>
    <segment id="13">, Claudinha arriscou:</segment>
    <segment id="14">“Acredito que é homem de novo.</segment>
    <segment id="15">Intuição de mãe.</segment>
    <segment id="16">Já tenho costume de falar com menino na barriga”</segment>
    <segment id="17">, afirmou.</segment>
  </rst>
