  <rst>
    <segment id="1">Matou a mãe a pauladas para roubar</segment>
    <segment id="2">Geraldo primeiro falou que chegou em casa e encontrou a mãe morta</segment>
    <segment id="3">O que leva um filho a matar a mãe a pauladas?</segment>
    <segment id="4">Para o lavrador Geraldo Lobo Queiroz</segment>
    <segment id="5">, 37 anos</segment>
    <segment id="6">, R$ 4.550 justificam o crime</segment>
    <segment id="7">, que ocorreu na cidade de Castro Alves</segment>
    <segment id="8">, a 194 km de Salvador.</segment>
    <segment id="9">No Sábado de Aleluia</segment>
    <segment id="10">, Geraldo voltou da feira livre e pegou R$ 3.150 que a mãe juntava para reformar a casa.</segment>
    <segment id="11">A aposentada Maria Lobo Queiroz</segment>
    <segment id="12">, 66, flagrou o filho e tomou o dinheiro de volta.</segment>
    <segment id="13">Foi o bastante para Geraldo ir ao quintal de casa</segment>
    <segment id="14">, pegar um pedaço de tronco de árvore de quase 1 metro de comprimento e  golpear a cabeça da mãe três vezes.</segment>
    <segment id="15">De acordo com o titular da delegacia de Castro Alves</segment>
    <segment id="16">, Adilson Freitas</segment>
    <segment id="17">, Geraldo arrastou o corpo da mãe até o quintal e colocou ao lado de uma bananeira.</segment>
    <segment id="18">“Ele chamou os vizinhos e disse que encontrou a mãe morta.</segment>
    <segment id="19">Desconfiamos da história e continuamos as investigações”</segment>
    <segment id="20">, explica.</segment>
    <segment id="21">Na manhã de ontem</segment>
    <segment id="22">, Geraldo foi convocado a depor novamente e diante das provas da polícia confessou o crime.</segment>
    <segment id="23">“Em 10 anos</segment>
    <segment id="24">comocomo delegado</segment>
    <segment id="25">, nunca vi um camarada com tamanha frieza.</segment>
    <segment id="26">Não demonstrou nenhum tipo de arrependimento.</segment>
    <segment id="27">Só queria ficar com o dinheiro”</segment>
    <segment id="28">, relata o delegado.</segment>
    <segment id="29">Queria a herança</segment>
    <segment id="30">Geraldo morava sozinho com a mãe na localidade de Arrupiado</segment>
    <segment id="31">, zona rural de Castro Alves.</segment>
    <segment id="32">Ele é lavrador</segment>
    <segment id="33">, masmas estava desempregado.</segment>
    <segment id="34">“Geraldo não tem nenhuma passagem pela polícia e não é usuário de drogas.</segment>
    <segment id="35">O que ele queria mesmo era ficar com o dinheiro da mãe</segment>
    <segment id="36">, bem como</segment>
    <segment id="37">como com sua herança</segment>
    <segment id="38">, já que é filho único”</segment>
    <segment id="39">, afirma o delegado Adilson Freitas.</segment>
    <segment id="40">No dia do crime</segment>
    <segment id="41">, Geraldo foi encontrado com R$ 1.400</segment>
    <segment id="42">, que disse pertencer a ele.</segment>
    <segment id="43">Depois os policiais encontraram R$ 3.150 escondidos em um guarda-roupa.</segment>
    <segment id="44">Maria Lobo Queiroz era aposentada e recebia pensão</segment>
    <segment id="45">, cada uma de um salário mínimo.</segment>
    <segment id="46">Geraldo sabia que a mãe havia recebido dinheiro no início do mês.</segment>
  </rst>
</analysis>