  <rst>
    <segment id="1">Léo e Cissa batem boca por Léo Santana</segment>
    <segment id="2">Léo Kret disse que Cissa pediu ao cantor do Parango que não falasse mais com ela</segment>
    <segment id="3">O clima começou a pegar fogo no Trio Reality</segment>
    <segment id="4">, da TV Aratu.</segment>
    <segment id="5">Isso porque</segment>
    <segment id="6">porque  Cissa Chaggas e  Léo Kret iniciaram a maior discussão por conta de Léo Santana.</segment>
    <segment id="7">A vereadora disse que a dançarina teria pedido ao cantor do Parangolé que não falasse com ela na época em que Cissa namorou com Léo.</segment>
    <segment id="8">A gata</segment>
    <segment id="9">, no entanto</segment>
    <segment id="10">, desmentiu:</segment>
    <segment id="11">“</segment>
    <segment id="12">Isso nunca aconteceu.</segment>
    <segment id="13">Se eu tivesse problema com você teria dito”</segment>
