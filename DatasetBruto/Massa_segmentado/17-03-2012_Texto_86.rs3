  <rst>
    <segment id="1">Fael pode deixar de ser boca virgem</segment>
    <segment id="2">A ‘hermana’ Noemí pode ser a oportunidade para o brother finalmente beijar alguém
Finalmente</segment>
    <segment id="3">, os confinados do BBB 12 receberam a nova colega da Espanha ontem.</segment>
    <segment id="4">A “hermana” Noemí</segment>
    <segment id="5">, que passará cinco dias na casa</segment>
    <segment id="6">, foi a escolhida</segment>
    <segment id="7">porque</segment>
    <segment id="8">porque</segment>
    <segment id="9">sese deu melhor na prova sobre brasilidade realizada durante toda a semana no “Gran Hermano”.</segment>
    <segment id="10">E isso graças à ajuda de Laisa.</segment>
    <segment id="11">Com uma nova gata na casa</segment>
    <segment id="12">, essa pode ser a grande oportunidade para Fael sair do “zero a zero” no reality show.</segment>
    <segment id="13">Afinal</segment>
    <segment id="14">, em uma ligação feita entre o Big Brother brasileiro e o espanhol</segment>
    <segment id="15">, na última terça-feira</segment>
    <segment id="16">, cowboy</segment>
    <segment id="17">sese mostrou interessado pela “hermana”.</segment>
    <segment id="18">No dia</segment>
    <segment id="19">, até Jonas resolveu dar um empurrãozinho para ajudar o colega.</segment>
    <segment id="20">"</segment>
    <segment id="21">Tinha uma morena de cabelos cacheados que o Fael gostou bastante"</segment>
    <segment id="22">, disse o modelo para o apresentador Pedro Bial</segment>
    <segment id="23">, quando ainda nem sabia que ela seria a nova moradora da casa mais vigiada do país.</segment>
    <segment id="24">Com um estilo diferente</segment>
    <segment id="25">, Noemí é gerente de uma loja de surf e adora pegar ondas.</segment>
    <segment id="26">No confinamento</segment>
    <segment id="27">, ela tem uma coisa em comum com Laisa: também protagonizou cenas quentes embaixo do edredom  na edição do programa em seu país.</segment>
    <segment id="28">Agora, resta saber</segment>
    <segment id="29">sese o sul-mato-grossense vai investir na moça e</segment>
    <segment id="30">, finalmente</segment>
    <segment id="31">, “molhar o bico” nesta reta final do reality.</segment>
    <segment id="32">No site oficial do BBB 12</segment>
    <segment id="33">, rola até uma enquete sobre o assunto.</segment>
    <segment id="34">Cinquenta e sete por cento dos internautas que votaram até agora acham que o veterinário vai</segment>
    <segment id="35">sese dar bem com a visitante.</segment>
    <segment id="36">Será?</segment>
