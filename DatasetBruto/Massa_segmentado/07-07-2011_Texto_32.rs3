  <rst>
    <segment id="1">Taxista cheio de direito e deveres
Para virar lei</segment>
    <segment id="2">, o texto tem que ser aprovado pela presidente Dilma</segment>
    <segment id="3">O projeto de lei que regulamenta a profissão de taxista foi aprovado ontem pelo Senado.</segment>
    <segment id="4">Entre outras  medidas</segment>
    <segment id="5">, o projeto estabelece que esses profissionais sejam inscritos no INSS.</segment>
    <segment id="6">Conforme a matéria</segment>
    <segment id="7">, o proprietário  do alvará do veículo deverá  recolher a contribuição previdenciária para os taxistas auxiliares (que trabalham em carros de terceiros).</segment>
    <segment id="8">Além disso</segment>
    <segment id="9">, as condições e requisitos para a prestação de serviços (tais</segment>
    <segment id="10">comocomo  prazo de validade</segment>
    <segment id="11">, obrigações e responsabilidades das partes contratantes</segment>
    <segment id="12">, data de pagamento e remuneração) devem ser estabelecidos no contrato entre o condutor autônomo de táxis e os auxiliares.</segment>
    <segment id="13">A medida</segment>
    <segment id="14">, contudo</segment>
    <segment id="15">contudo</segment>
    <segment id="16">, preocupa a categoria</segment>
    <segment id="17">, que teme demissões.</segment>
    <segment id="18">“</segment>
    <segment id="19">Hoje os proprietários não têm custo nenhum</segment>
    <segment id="20">porque</segment>
    <segment id="21">porque</segment>
    <segment id="22">, além de pagar de R$ 300 a R$ 500 semanalmente</segment>
    <segment id="23">, os auxiliares ainda pagam o combustível e manutenção dos veículos.</segment>
    <segment id="24">Não há contratos</segment>
    <segment id="25">, nem recibos e</segment>
    <segment id="26">, sese o auxiliar não  render</segment>
    <segment id="27">, o proprietário muda.</segment>
    <segment id="28">Quem vai querer arcar com o INSS?</segment>
    <segment id="29">”, questiona o presidente da Associação Metropolitana dos Taxistas Valdeilson Miguel dos Santos.</segment>
    <segment id="30">Segundo a associação</segment>
    <segment id="31">, 80% dos 14 mil taxistas registrados são auxiliares.</segment>
    <segment id="32">O auxiliar  Joelmi dos Santos Chagas</segment>
    <segment id="33">, 43, aprova a medida</segment>
    <segment id="34">, masmas não acredita em seu cumprimento.</segment>
    <segment id="35">“</segment>
    <segment id="36">Vai gerar demissão.</segment>
    <segment id="37">Os proprietários não vão querer assinar a carteira” diz  ele que  não contribui com a Previdência.</segment>
    <segment id="38">Táxi de pai para filho:</segment>
    <segment id="39">Não vai mais para prefeitura</segment>
    <segment id="40">Para o presidente da Associação Metropolitana dos Taxistas</segment>
    <segment id="41">, Valdeilson Miguel dos Santos</segment>
    <segment id="42">, o texto do projeto foi feliz quando determina que</segment>
    <segment id="43">, em  caso</segment>
    <segment id="44">caso de morte do condutor</segment>
    <segment id="45">, a autorização do táxi deve ser passada para o cônjuge e herdeiros.</segment>
    <segment id="46">“</segment>
    <segment id="47">Atualmente</segment>
    <segment id="48">, quando o proprietário morre</segment>
    <segment id="49">, o alvará fica com a prefeitura e não com a família.</segment>
    <segment id="50">Se o projeto virar lei</segment>
    <segment id="51">, será menos um trabalho para as famílias”</segment>
    <segment id="52">, explica Santos.</segment>
    <segment id="53">Desde ontem</segment>
    <segment id="54">, estão sendo cobradas as novas tarifas de táxis comuns: a bandeirada passa a custar R$ 3</segment>
    <segment id="55">,75;  cada km rodado na bandeira 1 custa R$ 1</segment>
    <segment id="56">,85 e na 2 R$ 2</segment>
    <segment id="57">,59.</segment>
    <segment id="58">Direitos</segment>
    <segment id="59">O projeto prevê também a criação do piso salarial para a categoria</segment>
    <segment id="60">, que deverá ser estabelecido em acordo com os sindicatos.
É permitida a transferência da autorização do taxista para outro profissional</segment>
    <segment id="61">, desde que seja do ramo.</segment>
    <segment id="62">Passarão a ser assistidos pela Consolidação das Leis do Trabalho (CLT).</segment>
    <segment id="63">Deveres
Não pode penhorar ou leiloar a autorização de táxi.</segment>
    <segment id="64">Deve frequentar cursos de primeiros socorros</segment>
    <segment id="65">, direção defensiva</segment>
    <segment id="66">,  mecânica básica e de relações humanas</segment>
    <segment id="67">, para atender os clientes com agilidade e delicadeza.</segment>
    <segment id="68">Manter o veículo em boas condições de funcionamento</segment>
  </rst>
</analysis>