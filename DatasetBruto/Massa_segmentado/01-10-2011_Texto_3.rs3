  <rst>
    <segment id="1">Fluminense vence o Santos com gol aos 50 minutos do segundo tempo
RIO - Desde a heroica arrancada de 2009 para escapar do rebaixamento</segment>
    <segment id="2">, a torcida do Fluminense</segment>
    <segment id="3">sese acostumou a acreditar até o fim.</segment>
    <segment id="4">Neste sábado</segment>
    <segment id="5">, mais uma vez valeu a pena esperar.</segment>
    <segment id="6">Depois de sofrer o empate aos 44 minutos do segundo tempo</segment>
    <segment id="7">, o tricolor conseguiu uma vitória suada por 3 a 2 sobre o Santos</segment>
    <segment id="8">, graças a um gol de Márcio Rosário aos 50</segment>
    <segment id="9">, de cabeça</segment>
    <segment id="10">, quando já atuava com um a menos</segment>
    <segment id="11">, devido à expulsão de Digão</segment>
    <segment id="12">, pouco antes.</segment>
    <segment id="13">Neymar e o estreante Rentería fizeram os gols santistas.</segment>
    <segment id="14">Marquinho e Rafael Sóbis foram os outros artilheiros do Flu.

- Hoje o torcedor foi fundamental.</segment>
    <segment id="15">Naquela virada contra o Atlético-GO</segment>
    <segment id="16">, houve muita vaia</segment>
    <segment id="17">, masmas hoje o torcedor entendeu.</segment>
    <segment id="18">Depois da expulsão eles continuaram incentivando e ganhamos força para buscar a vitória - declarou o técnico Abel Braga</segment>
    <segment id="19">, lembrando outro triunfo conseguido nos acréscimos</segment>
    <segment id="20">, quando o Fluminense marcou três gols nos sete minutos finais para fazer 3 a 2 sobre a equipe goiana</segment>
    <segment id="21">, há um mês</segment>
    <segment id="22">, também no estádio Raulino de Oliveira.</segment>
    <segment id="23">A vitória garante o time das Laranjeiras em quinto lugar no Brasileiro</segment>
    <segment id="24">, com 44 pontos</segment>
    <segment id="25">, sem se</segment>
    <segment id="26">se preocupar com o complemento da 27ª rodada</segment>
    <segment id="27">, neste domingo.</segment>
    <segment id="28">E mantém a invencibilidade de 11 jogos da equipe em Volta Redonda.</segment>
    <segment id="29">O próximo adversário é o rival Flamengo</segment>
    <segment id="30">, domingo</segment>
    <segment id="31">, no Engenhão.</segment>
    <segment id="32">O Santos é o 11º</segment>
    <segment id="33">, com 35.

Sóbis e Rosário saem do banco para garantir a vitória</segment>
    <segment id="34">As duas equipes tiveram espaço para atacar no primeiro tempo.</segment>
    <segment id="35">O resultado foi uma sucessão de lances de perigo.</segment>
    <segment id="36">Borges testou Diego</segment>
    <segment id="37">Cavalieri aos oito minutos</segment>
    <segment id="38">, e o goleiro mandou a escanteio.</segment>
    <segment id="39">O Fluminense respondeu em cabeçada de Fred</segment>
    <segment id="40">, em cima de Rafael.</segment>
    <segment id="41">Melhor em campo</segment>
    <segment id="42">, Neymar começou o seu repertório de belas jogadas com um lençol em Digão</segment>
    <segment id="43">, seguido de chute de esquerda</segment>
    <segment id="44">, por cima do gol tricolor</segment>
    <segment id="45">, aos 23.</segment>
    <segment id="46">Fred também mostrou talento</segment>
    <segment id="47">, ao deixar Marquinho livre na área</segment>
    <segment id="48">, masmas Rafael salvou o chute rasteiro com o pé direito.</segment>
    <segment id="49">Aos 32</segment>
    <segment id="50">, o Santos abriu o placar: lançado nas costas de Mariano</segment>
    <segment id="51">, Neymar entrou na área e bateu rasteiro</segment>
    <segment id="52">, vencendo Cavalieri</segment>
    <segment id="53">, que chegou a tocar na bola</segment>
    <segment id="54">, no canto direito.</segment>
    <segment id="55">O goleiro tricolor brilhou dois minutos depois</segment>
    <segment id="56">, pegando o chute de primeira de Arouca</segment>
    <segment id="57">, livre na área.</segment>
    <segment id="58">O empate do Fluminense nasceu em novo passe açucarado de Fred para Marquinho</segment>
    <segment id="59">, aos 39:</segment>
    <segment id="60">Rafael ainda pegou o primeiro chute</segment>
    <segment id="61">, masmas o próprio Marquinho marcou no rebote.</segment>
    <segment id="62">O Fluminense voltou do intervalo com Deco no lugar de Lanzini.</segment>
    <segment id="63">Mas a entrada do camisa 20 não acrescentou qualidade ao ataque tricolor</segment>
    <segment id="64">, que não conseguia segurar a bola na frente.</segment>
    <segment id="65">Abel Braga</segment>
    <segment id="66">, então</segment>
    <segment id="67">, decidiu lançar Rafael Sóbis no lugar de Martinuccio</segment>
    <segment id="68">, aos 20.</segment>
    <segment id="69">E na primeira chance que teve</segment>
    <segment id="70">, aos 26</segment>
    <segment id="71">, o atacante marcou o gol da virada: dominou na entrada da área e bateu forte</segment>
    <segment id="72">, surpreendendo o goleiro Rafael.</segment>
    <segment id="73">Muito marcado na segunda etapa</segment>
    <segment id="74">, Neymar já não brilhava</segment>
    <segment id="75">comocomo no primeiro tempo</segment>
    <segment id="76">, facilitando a vida da defesa tricolor.</segment>
    <segment id="77">O que atrapalhou foi a violenta solada de Digão no estreante Rentería</segment>
    <segment id="78">, que entrara cinco minutos antes.</segment>
    <segment id="79">Expulso</segment>
    <segment id="80">, o zagueiro deixou a equipe carioca com um a menos</segment>
    <segment id="81">, aos 37.</segment>
    <segment id="82">O Santos ganhou ânimo para pressionar</segment>
    <segment id="83">, e aos 44 chegou ao empate</segment>
    <segment id="84">, em chute da entrada da área de Rentería.</segment>
    <segment id="85">Mas no último lance do jogo</segment>
    <segment id="86">, aos 50 minutos</segment>
    <segment id="87">, Márcio Rosário</segment>
    <segment id="88">, que só entrou para recompor a defesa após a expulsão de Digão</segment>
    <segment id="89">, acabou virando herói ao marcar de cabeça o gol da vitória</segment>
    <segment id="90">, completando escanteio de Rafael Sóbis.</segment>
  </rst>
</analysis>