  <rst>
    <segment id="1">Greve dos motoristas ronda a cidade</segment>
    <segment id="2">Usuários viajam em buzus sujos</segment>
    <segment id="3">, que demoram de passar.</segment>
    <segment id="4">Eles temem aumento após greve</segment>
    <segment id="5">Enquanto os rodoviários de Salvador lutam por melhores salários</segment>
    <segment id="6">, a população labuta com os descasos do transporte coletivo.</segment>
    <segment id="7">As reclamações são várias</segment>
    <segment id="8">, masmas</segment>
    <segment id="9">sese repetem</segment>
    <segment id="10">, quase sem alteração</segment>
    <segment id="11">, de usuário para usuário.</segment>
    <segment id="12">A frota insuficiente</segment>
    <segment id="13">, a superlotação</segment>
    <segment id="14">, a espera e a sujeira são as principais queixas.</segment>
    <segment id="15">Valdelice de Jesus</segment>
    <segment id="16">, 38, mora no Cabula e  conta que já levou cerca de 2 h esperando um ônibus.</segment>
    <segment id="17">“Quando chega é impossível ir sentada”</segment>
    <segment id="18">,  diz ela reclamando da superlotação.</segment>
    <segment id="19">Nas estações</segment>
    <segment id="20">, em horário de pico os passageiros chegam a viajar pendurados nas portas do veículo.</segment>
    <segment id="21">Já Suede Santos</segment>
    <segment id="22">, 23, tem que pegar dois coletivos na Avenida Suburbana para ir à Faculdade Católica</segment>
    <segment id="23">, na Av. Pinto de Aguiar</segment>
    <segment id="24">, por falta de linha que faça esse roteiro.</segment>
    <segment id="25">Além disso</segment>
    <segment id="26">, passageiros relatam que os assentos são repletos de sujeira e até baratas costumam passear no local.</segment>
    <segment id="27">A usuária Ana Brito</segment>
    <segment id="28">, 45,  teme que a negociação entre os rodoviários e as empresas de transporte gerem o aumento da passagem.</segment>
    <segment id="29">“Se pelo menos eles melhorassem a situação dos ônibus ...</segment>
    <segment id="30">”,  lamenta.</segment>
    <segment id="31">Transtorno gera confusão</segment>
    <segment id="32">Passageiros dizem presenciar confusão entre usuários</segment>
    <segment id="33">, diariamente</segment>
    <segment id="34">, por brigas de assento</segment>
    <segment id="35">, desrespeito a idosos e conduta do motorista.</segment>
    <segment id="36">Além disso</segment>
    <segment id="37">, o empurra-empurra na hora de passar entre o aperto dos passageiros acaba gerando constantes discussões.</segment>
    <segment id="38">“</segment>
    <segment id="39">A gente  acaba descontando o estresse em cima de outras pessoas que também passam pela mesma dificuldade”</segment>
    <segment id="40">, afirma Eliosvaldo Silva</segment>
    <segment id="41">, 32.</segment>
    <segment id="42">Nas estações de transbordo</segment>
    <segment id="43">, as invasões também são motivo de desentendimento.</segment>
    <segment id="44">Para tentar conter a invasão</segment>
    <segment id="45">, a Transalvador instalou seguranças nesses locais em horário de pico.

‘Novela’: Nova rodada sem acordo</segment>
    <segment id="46">A última rodada de negociações entre rodoviários e patronais acabou sem acordo</segment>
    <segment id="47">, na manhã de ontem.</segment>
    <segment id="48">Enquanto o Sindicato dos Rodoviários (Sinttroba) não recua</segment>
    <segment id="49">, o Sindicato das Empresas de Transporte de Passageiros de Salvador (Setps) rebate que não há possibilidade de aumento até setembro.</segment>
    <segment id="50">“</segment>
    <segment id="51">Os patrões sequer colocaram propostas na mesa.</segment>
    <segment id="52">É uma  falta de consideração.</segment>
    <segment id="53">Não houve avanço e a mobilização continua"</segment>
    <segment id="54">, atesta o diretor de imprensa do Sinttroba</segment>
    <segment id="55">, Francisco Costa.</segment>
    <segment id="56">Os rodoviários decidem os rumos dos transportes municipal e intermunicipal em assembleia da categoria</segment>
    <segment id="57">, na próxima quinta-feira.</segment>
  </rst>
</analysis>