  <rst>
    <segment id="1">Botafogo: novo fornecedor à vista para o clube</segment>
    <segment id="2">A queda de braço foi grande.</segment>
    <segment id="3">Mas após um período de idas e vindas em que o negócio chegou a ser dado</segment>
    <segment id="4">comocomo encerrado</segment>
    <segment id="5">, o Botafogo e a Puma</segment>
    <segment id="6">, fornecedora de material esportivo</segment>
    <segment id="7">, devem assinar um contrato de exclusividade na próxima semana.</segment>
    <segment id="8">Quem garante é o diretor executivo do Botafogo</segment>
    <segment id="9">, Sérgio Landau.</segment>
    <segment id="10">Antes preocupado pelo fato de as conversas terem</segment>
    <segment id="11">sese estendido por um longo período após o rompimento com a fornecedora anterior</segment>
    <segment id="12">, ele disse que o clube recebeu ontem uma proposta dentro dos seus interesses e que atende à fornecedora.</segment>
    <segment id="13">Neste fim de semana todos os detalhes do contrato serão analisados</segment>
    <segment id="14">para que</segment>
    <segment id="15">para que o acordo definitivo seja assinado na próxima semana.

- Surgiram sinais de fumaça positivos.</segment>
    <segment id="16">Agora, é uma questão de rapidez</segment>
    <segment id="17">para que</segment>
    <segment id="18">para que a gente assine logo o contrato - disse Landau</segment>
    <segment id="19">, acrescentando: - Ele atende tanto aos nossos interesses</segment>
    <segment id="20">comocomo o da fornecedora</segment>
    <segment id="21">, que é muito importante no mercado e abre uma frente no Rio.</segment>
    <segment id="22">Andrezinho mais próximo do acerto com o clube</segment>
    <segment id="23">Nesta sexta-feira</segment>
    <segment id="24">, os funcionários do clube foram homenageados com uma festa de Natal antecipada.</segment>
    <segment id="25">O gerente de futebol</segment>
    <segment id="26">, Anderson Barros</segment>
    <segment id="27">, continuou trabalhando para trazer reforços e acertar a rescisão do contrato de jogadores que não estão mais nos planos</segment>
    <segment id="28">, como</segment>
    <segment id="29">como Alessandro</segment>
    <segment id="30">, Bruno Thiago e Somália.</segment>
    <segment id="31">Segundo Anderson Barros</segment>
    <segment id="32">, a negociação para a vinda do apoiador Andrezinho</segment>
    <segment id="33">, do Inter</segment>
    <segment id="34">, está caminhando bem e deve ter um final feliz</segment>
    <segment id="35">Cinco jogadores das divisões de base</segment>
    <segment id="36">, Andrey</segment>
    <segment id="37">, Fabiano</segment>
    <segment id="38">, Renan</segment>
    <segment id="39">, Jefferson e Vitinho serão promovidos para os profissionais.</segment>
  </rst>
