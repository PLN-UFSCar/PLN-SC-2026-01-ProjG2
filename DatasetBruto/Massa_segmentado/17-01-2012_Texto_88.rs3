  <rst>
    <segment id="1">Mão na roda para os ambulantes</segment>
    <segment id="2">Unidade de Inclusão Socioprodutiva disponibiliza qualificação e apoio comercial</segment>
    <segment id="3">Os trabalhadores informais do Bairro da Paz já podem fazer planos de melhorar a grana.</segment>
    <segment id="4">Será inaugurada hoje a primeira Unidade de Inclusão Socioprodutiva (Unis) da capital.</segment>
    <segment id="5">Integrante do Programa Vida Melhor-Urbano</segment>
    <segment id="6">, da Secretaria de Desenvolvimento Social e Combate à Pobreza (Sedes)</segment>
    <segment id="7">, a unidade contempla Mussurunga</segment>
    <segment id="8">, São Cristóvão</segment>
    <segment id="9">, Pau da Lima</segment>
    <segment id="10">, Cajazeiras</segment>
    <segment id="11">, Narandiba</segment>
    <segment id="12">, Itapuã e Vila Verde.</segment>
    <segment id="13">Cada Unis terá 30 agentes e 5 consultores  para identificar o perfil socioeconômico dos moradores.</segment>
    <segment id="14">O público-alvo são pessoas entre 18 e 60 anos</segment>
    <segment id="15">, inscritas no Cadastro Único para Programas Sociais (CadÚnico)</segment>
    <segment id="16">, do Ministério do Desenvolvimento Social</segment>
    <segment id="17">, que possuam renda  familiar de meio salário mínimo.</segment>
    <segment id="18">As pessoas cadastradas na unidade terão assistência técnica continuada</segment>
    <segment id="19">, transferência de equipamentos e insumos produtivos (carrinhos para o comércio de cachorro-quente</segment>
    <segment id="20">, churrasquinho e bebidas</segment>
    <segment id="21">, além de fardamento)</segment>
    <segment id="22">, qualificação (cursos e oficinas)</segment>
    <segment id="23">, apoio à comercialização de produtos e serviços e microcrédito assistido.</segment>
    <segment id="24">Meta é criar 30 novas sede</segment>
    <segment id="25">Segundo o coordenador do programa</segment>
    <segment id="26">, Ailton Florêncio</segment>
    <segment id="27">, até o fim do mês</segment>
    <segment id="28">, cinco novas unidades serão criadas no Nordeste de Amaralina (Vale das Pedrinhas</segment>
    <segment id="29">, Santa Cruz e  Chapada do Rio Vermelho)</segment>
    <segment id="30">, Calabar-Alto das Pombas e no subúrbio.</segment>
    <segment id="31">Em abril</segment>
    <segment id="32">, será a vez de  Cajazeiras e Península Itapagipana.</segment>
    <segment id="33">Segundo ele</segment>
    <segment id="34">, a meta  é implantar 30 Unis em toda a Bahia</segment>
    <segment id="35">, no prazo de dois anos.</segment>
    <segment id="36">Ambulante comemora</segment>
    <segment id="37">O presidente da Associação de Vendedores Ambulantes do Bairro da Paz</segment>
    <segment id="38">, Balbino Teles</segment>
    <segment id="39">, 48, passou a vender bebidas nas praias e na entrada das casas de show de Salvador há sete anos</segment>
    <segment id="40">, desde que perdeu o emprego</segment>
    <segment id="41">comocomo padeiro.</segment>
    <segment id="42">“Após uma luta grande</segment>
    <segment id="43">, demos um enorme passo para reunir condições decentes de trabalho”</segment>
    <segment id="44">, comemorou.</segment>
    <segment id="45">“</segment>
    <segment id="46">Nessa unidade</segment>
    <segment id="47">, temos ainda um posto do Banco do Nordeste do Brasil</segment>
    <segment id="48">, onde os técnicos da instituição irão analisar a renda familiar dos empreendedores</segment>
    <segment id="49">, para encontrar a melhor forma de financiamento”</segment>
    <segment id="50">, explica o coordenador da Unis Bairro da Paz</segment>
    <segment id="51">, Lucas Carvalho</segment>
    <segment id="52">, ao acrescentar que os juros por empréstimos serão de 0</segment>
    <segment id="53">,54% mensal.</segment>
  </rst>
</analysis>