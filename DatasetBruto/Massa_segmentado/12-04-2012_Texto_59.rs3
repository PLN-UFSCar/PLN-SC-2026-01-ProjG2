  <rst>
    <segment id="1">Tudo OK no som da comunidade
Sambistas</segment>
    <segment id="2">sese inspiram em bandas</segment>
    <segment id="3">comocomo Sorriso Maroto</segment>
    <segment id="4">, Exaltasamba e Belo</segment>
    <segment id="5">O que não falta para a galera de Pernambués é samba no pé.</segment>
    <segment id="6">Principalmente quando o ritmo é tocado pelos filhos do bairro</segment>
    <segment id="7">, os vizinhos Anderson</segment>
    <segment id="8">, vocalista</segment>
    <segment id="9">; Dinho</segment>
    <segment id="10">, do cavaquinho</segment>
    <segment id="11">; Vandinho</segment>
    <segment id="12">, no violão</segment>
    <segment id="13">;</segment>
    <segment id="14">Thiaguinho</segment>
    <segment id="15">, marcação</segment>
    <segment id="16">;</segment>
    <segment id="17">Ton, na bateria</segment>
    <segment id="18">; e Clécio</segment>
    <segment id="19">, no tan tan.</segment>
    <segment id="20">A rapaziada</segment>
    <segment id="21">sese reuniu e formou a banda</segment>
    <segment id="22">Tudo Ok</segment>
    <segment id="23">, que está bombando na área.</segment>
    <segment id="24">Com dois aninhos de estrada</segment>
    <segment id="25">, o grupo já coloca a comunidade local para arrastar muita sandália com os hits “Replay” e “Amor com Você”</segment>
    <segment id="26">, músicas de trabalho da banda.</segment>
    <segment id="27">Além dessas composições</segment>
    <segment id="28">, a galera produz muito e</segment>
    <segment id="29">, logo no primeiro CD</segment>
    <segment id="30">,  mostra a que veio com 10 faixas autorais.</segment>
    <segment id="31">O vocalista Anderson</segment>
    <segment id="32">, mais conhecido</segment>
    <segment id="33">comocomo Doca</segment>
    <segment id="34">, é o motor de arranque dessa máquina de fazer música.</segment>
    <segment id="35">Compositor incansável</segment>
    <segment id="36">, ele já produzia muitas coisas antes da formação da Tudo Ok.</segment>
    <segment id="37">“</segment>
    <segment id="38">Meu sonho sempre foi emplacar um hit meu na voz de algum artista renomado”</segment>
    <segment id="39">, revela o rapaz.</segment>
    <segment id="40">Apaixonados por música e dispostos a atingir em cheio os corações</segment>
    <segment id="41">, os meninos capricham no samba romântico.</segment>
    <segment id="42">“</segment>
    <segment id="43">Claro que tem uma pitadinha de ousadia para apimentar</segment>
    <segment id="44">, masmas sem esculhambar ninguém.</segment>
    <segment id="45">Queremos apenas brincar e fazer a galera sambar muito”</segment>
    <segment id="46">, garante Doca.</segment>
    <segment id="47">Para que ninguém tenha motivo para ficar parado</segment>
    <segment id="48">, o vocalista promete novidades ainda em 2012.</segment>
    <segment id="49">“</segment>
    <segment id="50">Até o final deste ano vamos gravar o segundo CD</segment>
    <segment id="51">, cheio de coisas novas”</segment>
    <segment id="52">, revela

Ensaios de domingo</segment>
    <segment id="53">O samba romântico da banda</segment>
    <segment id="54">Tudo OK acontece sempre aos domingos</segment>
    <segment id="55">, no restaurante Bela Vista</segment>
    <segment id="56">, na Madeireira Brotas</segment>
    <segment id="57">, próximo ao shopping Iguatemi</segment>
    <segment id="58">, às 19h.</segment>
    <segment id="59">Entrada: R$ 5 para rapazes e R$ 3 para moças.</segment>
    <segment id="60">Mas, a mulher que chegar até as 20h não paga.</segment>
    <segment id="61">Também rola agito pelo interior da Bahia.</segment>
    <segment id="62">Dia 22 tem show garantido em Serrinha</segment>
    <segment id="63">, na praça</segment>
    <segment id="64">, a partir das 22h</segment>
    <segment id="65">, para todo mundo ver.</segment>
    <segment id="66">Já no dia 7 de maio</segment>
    <segment id="67">, a festa é em São Francisco do Conde</segment>
    <segment id="68">, a partir das 13h.</segment>
  </rst>
</analysis>