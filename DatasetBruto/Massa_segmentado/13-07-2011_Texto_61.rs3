  <rst>
    <segment id="1">Buraco nosso de cada dia</segment>
    <segment id="2">Salvador está parecendo a lua</segment>
    <segment id="3">A buraqueira virou pesadelo em todos os bairros da capital baiana.</segment>
    <segment id="4">A prefeitura promete</segment>
    <segment id="5">, promete e... nada.</segment>
    <segment id="6">Tá feia a coisa.</segment>
    <segment id="7">O MASSA!</segment>
    <segment id="8">mapeou as crateras - algumas com até 6 anos de existência - para ver</segment>
    <segment id="9">sese a turma do João para de enrolar e deixa tudo lisinho</segment>
    <segment id="10">comocomo o povo merece.</segment>
    <segment id="11">Promessa é o que não falta  na Sucop</segment>
    <segment id="12">A Superintendência de Conservação e Obras Públicas da Capital (Sucop)</segment>
    <segment id="13">, o serviço de manutenção das vias de modo emergencial</segment>
    <segment id="14">, informou que a  operação tapa-buracos obedece a um cronograma estabelecido diariamente</segment>
    <segment id="15">, conforme o caráter emergencial das vias e o fluxo de veículos.</segment>
    <segment id="16">O órgão informou que algumas crateras registradas pelo MASSA!</segment>
    <segment id="17">foram tapadas há meses</segment>
    <segment id="18">, masmas voltaram a abrir.</segment>
    <segment id="19">Prometem voltar aos locais</segment>
    <segment id="20">, masmas não dizem quando.</segment>
    <segment id="21">Em setembro</segment>
    <segment id="22">,  começa - outra promessa -  o recapeamento asfáltico na cidade.</segment>
    <segment id="23">Prejuízo aumenta com a buraqueira

Evaldo Miranda</segment>
    <segment id="24">, 40 anos</segment>
    <segment id="25">, trabalha</segment>
    <segment id="26">comocomo taxista há 12.</segment>
    <segment id="27">Ele fazia o alinhamento e balanceamento do carro uma vez por mês</segment>
    <segment id="28">, masmas agora precisa realizar o serviço a cada 15 dias.</segment>
    <segment id="29">A média de preço nas oficinas é de R$ 40.</segment>
    <segment id="30">“</segment>
    <segment id="31">Os pneus também estão durando menos.</segment>
    <segment id="32">Antes rodavam 40 mil km</segment>
    <segment id="33">, agora só resistem a  30 mil km”</segment>
    <segment id="34">, diz.</segment>
    <segment id="35">Para evitar cair nos buracos vale a experiência nas ruas</segment>
    <segment id="36">, masmas há casos que são inevitáveis.</segment>
    <segment id="37">“É melhor cair do que provocar um acidente”</segment>
    <segment id="38">, destaca.</segment>
    <segment id="39">Suspensão do carro é o maior problema</segment>
    <segment id="40">A buraqueira provoca mais danos ao sistema de suspensão do carro.</segment>
    <segment id="41">Segundo o consultor de vendas da Monobloco Alinhamento Técnico</segment>
    <segment id="42">, Welington Cerqueira</segment>
    <segment id="43">, muitos carros chegam com os eixos empenados.</segment>
    <segment id="44">“</segment>
    <segment id="45">Para desempenar a dianteira a média de preço é R$ 130.</segment>
    <segment id="46">O desempeno do monobloco custa R$ 180 e do eixo traseiro R$ 250”</segment>
    <segment id="47">, explica.</segment>
    <segment id="48">O pneu mais simples custa R$ 100.</segment>
    <segment id="49">O prejuízo pode ser de R$ 660</segment>
    <segment id="50">casocaso haja defeito em todos os itens listados acima.</segment>
    <segment id="51">Acidente é pior do que o prejuízo</segment>
    <segment id="52">Pior do que o prejuízo financeiro são os casos de acidentes de trânsito.</segment>
    <segment id="53">Joel Conceição Júnior</segment>
    <segment id="54">, 27 anos</segment>
    <segment id="55">, já viu alguns de dentro de sua oficina em Cajazeira 5.</segment>
    <segment id="56">“Semana passada o motoqueiro foi tentar desviar</segment>
    <segment id="57">, masmas caiu no buraco.</segment>
    <segment id="58">Graças a Deus não foi tão grave”</segment>
    <segment id="59">, lembra.</segment>
    <segment id="60">Joel conta que o buraco da Rua Álvaro da França Rocha está lá há um mês.</segment>
    <segment id="61">“</segment>
    <segment id="62">A prefeitura já tapou</segment>
    <segment id="63">, masmas qualquer chuvinha que cai o buraco reaparece”</segment>
    <segment id="64">, conta.</segment>
    <segment id="65">Para piorar as vias do bairro são estreitas e o trânsito é caótico.</segment>
    <segment id="66">Nem dono de oficina aguenta mais

Aílton Araújo é dono de uma borracharia na Avenida Suburbana</segment>
    <segment id="67">, próximo à Ladeira do Cabrito</segment>
    <segment id="68">, onde existe um buraco há um ano.</segment>
    <segment id="69">Apesar de lucrar com o conserto de pneus</segment>
    <segment id="70">, ele faz um apelo</segment>
    <segment id="71">para que</segment>
    <segment id="72">para que a prefeitura resolva o problema.</segment>
    <segment id="73">“</segment>
    <segment id="74">Muita gente vem para cá com jante amassada</segment>
    <segment id="75">, pneu lascado.</segment>
    <segment id="76">Mas eu também tenho carro e tomo muito prejuízo rodando pela cidade”</segment>
    <segment id="77">, declara o borracheiro .</segment>
    <segment id="78">“</segment>
    <segment id="79">A cidade está toda esburacada.</segment>
    <segment id="80">Para onde vai o dinheiro dos nossos impostos?</segment>
    <segment id="81">”, desabafa a funcionária pública Silvana Barreto</segment>
    <segment id="82">, exigindo providências imediatas.</segment>
    <segment id="83">Veja a radiografia completa da buraqueira da cidade nas páginas de seu Jornal MASSA!</segment>
    <segment id="84">desta quarta-feira nas bancas</segment>
  </rst>
</analysis>