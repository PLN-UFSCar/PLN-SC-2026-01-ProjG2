  <rst>
    <segment id="1">Pivetes de Mão caem com Rondesp</segment>
    <segment id="2">Os menores foram ouvidos e serão transferidos para a Casa do Menor Infrator</segment>
    <segment id="3">Um dos integrantes do bando do traficante Wellington Nunes de Castro (o Mão)</segment>
    <segment id="4">, suspeito de assassinar a dançarina Kelly Sales Silva</segment>
    <segment id="5">, 23, a Kelly Cyclone</segment>
    <segment id="6">, no dia 18 deste mês</segment>
    <segment id="7">, foi morto ontem durante operação de rotina das Rondas Especiais (Rondesp) na Favela Boca do Vulcão</segment>
    <segment id="8">, entre as localidades de Lagos dos Patos e Chafariz</segment>
    <segment id="9">, em Lauro de Freitas.</segment>
    <segment id="10">Durante a ação</segment>
    <segment id="11">, dois adolescentes que também fazem parte do bando de Mão e trocaram tiros com os PMs  foram apreendidos.</segment>
    <segment id="12">Ao todo</segment>
    <segment id="13">, seis homens trocaram tiros com os policiais.</segment>
    <segment id="14">Edmílson Santos das Neves</segment>
    <segment id="15">, 18, o Quinho</segment>
    <segment id="16">, foi baleado durante a troca de tiros</segment>
    <segment id="17">, e foi levado  ao Hospital Menandro de Farias</segment>
    <segment id="18">, onde morreu.</segment>
    <segment id="19">Quando foi pego</segment>
    <segment id="20">, Quinho portava um revólver calibre 38 com munições</segment>
    <segment id="21">, dois cartuchos intactos e três estourados</segment>
    <segment id="22">, segundo a polícia.</segment>
    <segment id="23">Ele tinha passagem por tráfico de drogas e porte ilegal de armas.</segment>
    <segment id="24">Os jovens L.B.S</segment>
    <segment id="25">, 17, e L.S.S</segment>
    <segment id="26">, 17, portavam 28 trouxinhas de maconha.</segment>
    <segment id="27">Na 23ª DT (Lauro de Freitas)</segment>
    <segment id="28">,  L.B.S admitiu que trabalhava para Mão</segment>
    <segment id="29">comocomo “guarita” (que faz a segurança).</segment>
    <segment id="30">Ele tem passagem por tráfico e roubo de veículos.</segment>
    <segment id="31">Já   L.S.S. é o braço-direito de Mão</segment>
    <segment id="32">, segundo dados da 23ª DT</segment>
    <segment id="33">, e  tem passagens por tráfico</segment>
    <segment id="34">, roubo de veículos e homicídio.</segment>
    <segment id="35">“</segment>
    <segment id="36">Há anos não trabalho para ele (Mão).</segment>
    <segment id="37">Comprava apenas lanche quando me pediam”</segment>
    <segment id="38">, negou o menor.</segment>
    <segment id="39">Polícia está ligada no movimento</segment>
    <segment id="40">“</segment>
    <segment id="41">Estamos seguindo algumas linhas de investigação</segment>
    <segment id="42">, masmas não descartamos nenhuma possibilidade”</segment>
    <segment id="43">, afirmou o delegado titular da 23ª DT (Lauro de Freitas)</segment>
    <segment id="44">, Joelson dos Santos Reis.</segment>
    <segment id="45">Ontem, Reis convocou três pessoas para prestar depoimento sobre o</segment>
    <segment id="46">casocaso Kelly Cyclone</segment>
    <segment id="47">, masmas apenas duas compareceram à unidade policial.</segment>
    <segment id="48">“</segment>
    <segment id="49">São pessoas que foram citadas em outros depoimentos e que pediram sigilo sobre suas identidades.</segment>
    <segment id="50">Estamos tentando confirmar as informações”.</segment>
    <segment id="51">Além de Mão</segment>
    <segment id="52">, Carlos Gustavo Cohen de Alencar Braga</segment>
    <segment id="53">, 26, conhecido</segment>
    <segment id="54">comocomo Gustavinho</segment>
    <segment id="55">, é outro suspeito de ter assassinado a Patroa do Pó.</segment>
    <segment id="56">Gustavinho foi apontado por familiares e amigos que relataram que ele não aceitava o fim do relacionamento com a dançarina.</segment>
    <segment id="57">Em depoimento à polícia</segment>
    <segment id="58">, Gustavinho negou que tenha</segment>
    <segment id="59">sese relacionado amorosamente com Kelly Cyclone e disse que a conheceu 15 dias antes de ela ser morta.</segment>
  </rst>
</analysis>