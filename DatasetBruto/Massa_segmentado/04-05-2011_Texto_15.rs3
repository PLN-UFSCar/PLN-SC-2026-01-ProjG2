  <rst>
    <segment id="1">Polêmica no Baêa
Médico pode travar chegada do jogador Jobson</segment>
    <segment id="2">Enquanto a diretoria do Bahia corre contra o tempo para acertar os últimos detalhes com o Jobson</segment>
    <segment id="3">, ex-Botafogo e Atlético-MG</segment>
    <segment id="4">, o diretor médico do tricolor</segment>
    <segment id="5">,  Marcos Lopes</segment>
    <segment id="6">, afirma que a situação não é tão simples</segment>
    <segment id="7">comocomo parece.</segment>
    <segment id="8">“</segment>
    <segment id="9">O contrato só será efetivado depois da minha assinatura.</segment>
    <segment id="10">E para que</segment>
    <segment id="11">para que isso aconteça preciso ter informações sobre a história do Jobson”</segment>
    <segment id="12">, afirmou o médico</segment>
    <segment id="13">, que completou:</segment>
    <segment id="14">“Eu preciso investigar a vida dele.</segment>
    <segment id="15">Tenho que falar com os médicos dele e saber</segment>
    <segment id="16">comocomo ele está.</segment>
    <segment id="17">Preciso de um parecer contendo todo o acompanhamento da recuperação dele”.</segment>
    <segment id="18">Lopes aproveitou para falar sobre o contrato.</segment>
    <segment id="19">“Terá cláusulas especiais.</segment>
    <segment id="20">A ideia é cobrir o Bahia de todas as formas.</segment>
    <segment id="21">A parte médica será importante.</segment>
    <segment id="22">Se não estiver bem eu irei vetá-lo”.</segment>
    <segment id="23">Ramon deixa o tricolor</segment>
    <segment id="24">O meia Ramon pediu ontem o seu desligamento do elenco tricolor.</segment>
    <segment id="25">O instável jogador participou normalmente do treinamento realizado na manhã de ontem</segment>
    <segment id="26">, masmas ao final da atividade foi conversar com o diretor de futebol Paulo Angioni e solicitou a sua liberação do clube.</segment>
    <segment id="27">Ramon fez três gols com a camisa do Bahia</segment>
    <segment id="28">, dois pelo Baiano e um pela Copa do Brasil.</segment>
    <segment id="29">O zagueiro Titi comentou a saída do atleta.</segment>
    <segment id="30">“</segment>
    <segment id="31">Fico triste.</segment>
    <segment id="32">Além de um companheiro</segment>
    <segment id="33">, era um amigo que eu tinha.</segment>
    <segment id="34">O grupo todo está um pouco chateado</segment>
    <segment id="35">, masmas vida que segue”.</segment>
  </rst>
</analysis>