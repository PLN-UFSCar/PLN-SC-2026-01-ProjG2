  <rst>
    <segment id="1">Fluminense vence o Inter no Engenhão e dedica o resultado a Fred
RIO - O pedido de Fred para não enfrentar o Internacional</segment>
    <segment id="2">, horas antes da partida</segment>
    <segment id="3">, alegando falta de condições psicológicas após ter sido perseguido por torcedores num bar na madrugada de quarta</segment>
    <segment id="4">, poderia ter gerado uma crise nas Laranjeiras.</segment>
    <segment id="5">Mas o episódio virou combustível para a vitória por 2 a 0 nesta quinta-feira</segment>
    <segment id="6">, no Engenhão</segment>
    <segment id="7">, que levou o time à sétima colocação no Brasileiro</segment>
    <segment id="8">, com 21 pontos.</segment>
    <segment id="9">Souza fez o primeiro gol e Rafael Moura</segment>
    <segment id="10">, que estava com Fred no episódio polêmico</segment>
    <segment id="11">, fechou o placar de pênalti.</segment>
    <segment id="12">Os dois demonstraram solidariedade ao capitão tricolor:

- Corremos por um companheiro que teve de sair da concentração para</segment>
    <segment id="13">sese proteger de algumas coisas.</segment>
    <segment id="14">Essa vitória a gente dedica ao Fred</segment>
    <segment id="15">, que é um cara que é fundamental para o nosso esquema de jogo</segment>
    <segment id="16">, um líder.</segment>
    <segment id="17">É inadmissível você não poder sair.</segment>
    <segment id="18">Isso não é torcedor</segment>
    <segment id="19">, torcedor não segue ninguém.</segment>
    <segment id="20">Isso é</segment>
    <segment id="21">casocaso de polícia.</segment>
    <segment id="22">Torcedor tem o direito de cobrar aqui dentro de campo - desabafou Souza.

- Alguns membros da torcida usam da paixão e deixam a razão de lado</segment>
    <segment id="23">, e isso não é bacana.</segment>
    <segment id="24">Ter membros de uma torcida na porta da sua casa é desagradável.</segment>
    <segment id="25">Esse gol é para o Fred - completou Rafael Moura.</segment>
    <segment id="26">O próximo compromisso do Fluminense será contra o América-MG</segment>
    <segment id="27">, domingo</segment>
    <segment id="28">, em Sete Lagoas</segment>
    <segment id="29">, quando o tricolor buscará a terceira vitória seguida no Brasileiro.</segment>
    <segment id="30">O Inter</segment>
    <segment id="31">, oitavo colocado com 19 pontos</segment>
    <segment id="32">, receberá o Cruzeiro no mesmo dia.</segment>
    <segment id="33">Flu leva susto no início</segment>
    <segment id="34">masmas domina o jogo com facilidade</segment>
    <segment id="35">O Fluminense demorou a acordar na partida e</segment>
    <segment id="36">, com menos de dez minutos Tinga já tinha aparecido três vezes com perigo na área de Diego Cavalieri.</segment>
    <segment id="37">O Inter</segment>
    <segment id="38">, no entanto</segment>
    <segment id="39">, errava muitos passes e não aproveitava os espaços dados pela defesa tricolor.</segment>
    <segment id="40">O Flu só acordou aos 27</segment>
    <segment id="41">, numa cabeçada de Gum</segment>
    <segment id="42">, bem defendida por Muriel.</segment>
    <segment id="43">O panorama do primeiro tempo então mudou</segment>
    <segment id="44">, e O time carioca passou a jogar no campo do adversário.</segment>
    <segment id="45">Aos 41</segment>
    <segment id="46">, Marquinho dominou na área</segment>
    <segment id="47">masmas foi puxado por Kleber na hora de concluir</segment>
    <segment id="48">, pênalti ignorado pelo árbitro Nielson Nogueira Dias.</segment>
    <segment id="49">No último lance antes do intervalo</segment>
    <segment id="50">, Tinga novamente assustou</segment>
    <segment id="51">, com um voleio</segment>
    <segment id="52">, masmas Diego Cavalieri espalmou para fora.</segment>
    <segment id="53">No segundo tempo</segment>
    <segment id="54">, o Fluminense manteve a postura ofensiva do fim da primeira etapa.</segment>
    <segment id="55">Logo aos dois minutos</segment>
    <segment id="56">, Muriel mais uma vez teve trabalho em cabeçada de Gum</segment>
    <segment id="57">, em lance mal anulado por impedimento.</segment>
    <segment id="58">Aos 11</segment>
    <segment id="59">, a pressão deu resultado: Mariano cruzou alto</segment>
    <segment id="60">, Souza apareceu por trás de Rafael Moura e cabeceou no canto esquerdo para fazer 1 a 0.</segment>
    <segment id="61">O segundo quase saiu aos 15</segment>
    <segment id="62">, masmas o chute de Carlinhos saiu rente à trave direita.</segment>
    <segment id="63">Logo depois</segment>
    <segment id="64">, o Fluminense reclamou outro pênalti não marcado</segment>
    <segment id="65">, de Tinga em Souza.</segment>
    <segment id="66">O árbitro irritou novamente os tricolores aos 21</segment>
    <segment id="67">, quando marcou pênalti de Diguinho em Leandro Damião</segment>
    <segment id="68">, ignorando a falta do atacante em Carlinhos no início da jogada.</segment>
    <segment id="69">Mas D'Alessandro bateu mal</segment>
    <segment id="70">, no meio do gol</segment>
    <segment id="71">, e Cavalieri defendeu com a mão direita.</segment>
    <segment id="72">O lance abateu o Inter</segment>
    <segment id="73">, que não voltou mais a incomodar.</segment>
    <segment id="74">E o Flu chegou ao segundo quase no fim: Fernando Bob foi derrubado por Wilson Mathias na área</segment>
    <segment id="75">, e Rafael Moura bateu o pênalti com categoria</segment>
    <segment id="76">, aos 42.</segment>
  </rst>
</analysis>