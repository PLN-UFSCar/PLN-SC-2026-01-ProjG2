  <rst>
    <segment id="1">Boataria atrapalha as vendas em S. Filho</segment>
    <segment id="2">Homens de preto espalham o terror na cidade e atrapalham até o delegado
Boatos.</segment>
    <segment id="3">Muitos boatos.</segment>
    <segment id="4">E com eles medo</segment>
    <segment id="5">, ruas vazias e prejuízos para vendedores ambulantes</segment>
    <segment id="6">, que não vendem.</segment>
    <segment id="7">Os policiais da 22ª DT também perdem tempo apurando crimes que não ocorreram.</segment>
    <segment id="8">Assim têm sido os dias de greve da Polícia Militar</segment>
    <segment id="9">, em Simões Filho</segment>
    <segment id="10">, Região Metropolitana.</segment>
    <segment id="11">Na tarde de ontem</segment>
    <segment id="12">, por exemplo</segment>
    <segment id="13">, “os homens de preto” –</segment>
    <segment id="14">comocomo foram chamados os integrantes de um suposto arrastão – foram os responsáveis pelos estabelecimentos fechados e raros ambulantes encontrados no Centro.</segment>
    <segment id="15">Tudo começou por volta das 12h40</segment>
    <segment id="16">, quando  pessoas corriam e gritavam pela Avenida Ruy Barbosa.</segment>
    <segment id="17">“Havia  rumores de arrastão  e saques.</segment>
    <segment id="18">Acolhemos algumas pessoas  e fechamos as portas por cerca de uma hora.</segment>
    <segment id="19">Mas não houve ataque ao Todo Dia”</segment>
    <segment id="20">, afirmou o funcionário Lucimário Cruz.</segment>
    <segment id="21">“</segment>
    <segment id="22">O arrastão foi na rua de trás.</segment>
    <segment id="23">Saquearam uma loja”</segment>
    <segment id="24">, contou a ambulante Jéssica Delmondes</segment>
    <segment id="25">, 21.</segment>
    <segment id="26">A rua de trás é a Avenida Altamirando de Araújo</segment>
    <segment id="27">, onde os estabelecimentos comerciais também estavam fechados e os poucos transeuntes  comentavam a ocorrência de arrastão e assalto a um mercadinho</segment>
    <segment id="28">, na Rua Tiradentes.</segment>
    <segment id="29">“</segment>
    <segment id="30">Aqui não ocorreu nada.</segment>
    <segment id="31">Ouvi comentários de que foi no CIA” disse uma funcionária do Pão San.</segment>
    <segment id="32">Prejuízo até no Chupa-Peito</segment>
    <segment id="33">Os comerciantes reclamam dos prejuízos decorrentes da greve.</segment>
    <segment id="34">“</segment>
    <segment id="35">Não vi nenhum arrastão.</segment>
    <segment id="36">Só boatos.</segment>
    <segment id="37">Já cheguei a vender R$ 300 por dia.</segment>
    <segment id="38">Agora, não passo de R$ 70”</segment>
    <segment id="39">, reclamava a vendedora de verduras Edilma de Jesus</segment>
    <segment id="40">, 48.</segment>
    <segment id="41">Até os bares do famoso Chupa-Peito estavam fechados.</segment>
    <segment id="42">“Estamos com medo de trabalhar.</segment>
    <segment id="43">Hoje, só vendi um refrigerante (R$ 3).</segment>
    <segment id="44">Normalmente</segment>
    <segment id="45">, vendo em média R$ 80 por dia”</segment>
    <segment id="46">, lamentava Josué Reis</segment>
    <segment id="47">, 58.</segment>
    <segment id="48">“</segment>
    <segment id="49">Recebemos a informação de que homens de preto fizeram um arrastão</segment>
    <segment id="50">, masmas não confirmamos</segment>
    <segment id="51">poispois o comércio estava fechado.</segment>
    <segment id="52">Alguém está</segment>
    <segment id="53">sese aproveitando da greve para espalhar o terror.</segment>
    <segment id="54">Recebemos muitas denúncias falsas”</segment>
    <segment id="55">, diz o delegado da 22ª DT</segment>
    <segment id="56">, Fernando do Carmo.</segment>
  </rst>
</analysis>