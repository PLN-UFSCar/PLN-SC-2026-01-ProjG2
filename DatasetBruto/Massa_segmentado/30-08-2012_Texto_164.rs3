  <rst>
    <segment id="1">Гўв‚¬Е“Eles estragaram os sonhos delaГўв‚¬
MГѓВЈe de uma das adolescentes afirma que sofre ameaГѓВ§as de morte e pede justiГѓВ§a
Гўв‚¬Е“Eles cometem o crime e nГѓВіs ГѓВ© que somos as criminosasГўв‚¬.</segment>
    <segment id="2">Foi com estas palavras que a mГѓВЈe de uma das adolescentes</segment>
    <segment id="3">, que acusam mГѓВєsicos da banda New Hit de estupro</segment>
    <segment id="4">, falou sobre o drama vivido pela famГѓВ­lia.</segment>
    <segment id="5">A mГѓВЈe</segment>
    <segment id="6">, que pede anonimato</segment>
    <segment id="7">, e os trГѓВЄs filhos</segment>
    <segment id="8">, estГѓВЈo sem sair de casa</segment>
    <segment id="9">, por medo</segment>
    <segment id="10">, pois</segment>
    <segment id="11">pois sГѓВЈo ameaГѓВ§ados</segment>
    <segment id="12">, por telefone.</segment>
    <segment id="13">Ela mora em um bairro simples da cidade de Itaberaba.</segment>
    <segment id="14">Гўв‚¬Е“Ligam constantemente.</segment>
    <segment id="15">Uma mulher falou que viriam de Salvador matar as meninas</segment>
    <segment id="16">, que eram responsГѓВЎveis pela prisГѓВЈo dos bebГѓВЄs dela.</segment>
    <segment id="17">NГѓВЈo estou trabalhando e meus filhos nГѓВЈo vГѓВЈo para a escolaГўв‚¬.</segment>
    <segment id="18">Гўв‚¬Е“ГѓвЂ° uma sensaГѓВ§ГѓВЈo de impotГѓВЄncia</segment>
    <segment id="19">, porque</segment>
    <segment id="20">porque nГѓВЈo pude proteger minha filha.</segment>
    <segment id="21">Me sinto pГѓВ©ssimaГўв‚¬</segment>
    <segment id="22">, desabafou</segment>
    <segment id="23">, entre lГѓВЎgrimas.
Гўв‚¬Е“Levei ela (a filha) para a mГѓВ©dica (ginecologista)</segment>
    <segment id="24">, na segunda-feira</segment>
    <segment id="25">, e foi confirmado com exames que ela era virgem e havia sofrido a violГѓВЄncia.</segment>
    <segment id="26">A coisa foi tГѓВЈo brutal que ainda existiam hematomas nas partes intimas delaГўв‚¬</segment>
    <segment id="27">, destaca a mГѓВЈe</segment>
    <segment id="28">, que ГѓВ© comerciГѓВЎria.</segment>
    <segment id="29">Гўв‚¬Е“Quero justiГѓВ§a.</segment>
    <segment id="30">Eles estragaram os sonhos de minha filha.</segment>
    <segment id="31">Eles devem pagar e espero em Deus que este exame mostrarГѓВЎ que elas nГѓВЈo estГѓВЈo mentindoГўв‚¬</segment>
    <segment id="32">, acredita a mГѓВЈe.</segment>
    <segment id="33">Гўв‚¬ЛњSujas de espermaГўв‚¬в„ў</segment>
    <segment id="34">Elas deixaram o ГѓВґnibus todas sujas de esperma</segment>
    <segment id="35">, fedendo.</segment>
    <segment id="36">A menina que foi abusada por 10 homens estava branca</segment>
    <segment id="37">, debilitada.</segment>
    <segment id="38">Elas encontraram uma amiga</segment>
    <segment id="39">, que orientou a denunciar o</segment>
    <segment id="40">casocaso.</segment>
    <segment id="41">Primeiro</segment>
    <segment id="42">, foram atГѓВ© a companhia de polГѓВ­cia e depois para a delegacia.</segment>
    <segment id="43">As meninas estavam muito abaladas.</segment>
    <segment id="44">Fiquei com elas por mais de 10 horas e nesse intervalo nГѓВЈo aceitaram comer nada.</segment>
    <segment id="45">A gente tem contato com muitas adolescentes.</segment>
    <segment id="46">Ao nossos olhos</segment>
    <segment id="47">, essas meninas nГѓВЈo aparentam ser piriguetesГўв‚¬</segment>
    <segment id="48">, relembra a conselheira tutelar da cidade de Ruy Barbosa</segment>
    <segment id="49">, Evanda Soares</segment>
    <segment id="50">, que acompanhou as meninas apГѓВіs o registro da queixa de estupro.</segment>
    <segment id="51">As jovens contaram para Evanda que sГѓВЈo fГѓВЈs da banda</segment>
    <segment id="52">, masmas nГѓВЈo tinham grana para vir ГѓВ  Salvador assistir um show.</segment>
    <segment id="53">Elas saГѓВ­ram de Itaberaba</segment>
    <segment id="54">, onde moram</segment>
    <segment id="55">, e viajaram 60 Km para conhecer os agora ex-ГѓВ­dolos.</segment>
    <segment id="56">Viajou acompanhada</segment>
    <segment id="57">A comerciГѓВЎria nega que a filha viajou sem a autorizaГѓВ§ГѓВЈo e afirma que estava com ela na cidade</segment>
    <segment id="58">, masmas nГѓВЈo a acompanhou</segment>
    <segment id="59">porque</segment>
    <segment id="60">porque ГѓВ© cardГѓВ­aca.</segment>
    <segment id="61">Ao revelar que era virgem ao vocalista Eduardo Martins</segment>
    <segment id="62">, o Dudu</segment>
    <segment id="63">, a garota disse que ele deu risada.</segment>
    <segment id="64">Depois</segment>
    <segment id="65">, nГѓВЈo permitiu que ninguГѓВ©m</segment>
    <segment id="66">sese aproximasse dela.</segment>
    <segment id="67">Гўв‚¬Е“Quando ele viu que ela era mesmo virgem</segment>
    <segment id="68">, mandou que elas fossem retiradas.</segment>
    <segment id="69">Ele tinha consciГѓВЄncia do que faziaГўв‚¬.</segment>
    <segment id="70">A  mГѓВЈe diz que a casa vive rodeada de pessoas falando coisas terrГѓВ­veis.</segment>
    <segment id="71">Laudo confirma estupro</segment>
    <segment id="72">Em um laudo mГѓВ©dico (que nГѓВЈo ГѓВ© o do DPT)</segment>
    <segment id="73">, a ginecologista Maria VerГѓВґnica SimГѓВµes (CRM- 11837) confirma o estupro.</segment>
    <segment id="74">Confira o que a ginecologista escreveu no laudo.</segment>
    <segment id="75">Гўв‚¬Е“A paciente sofreu violГѓВЄncia sexual hГѓВЎ</segment>
    <segment id="76">dois dias (foi estuprada)</segment>
    <segment id="77">, foi examinada</segment>
    <segment id="78">, onde foi comprovado o estupro (vulva apresenta fissura em intrГѓВіito vaginal</segment>
    <segment id="79">,</segment>
    <segment id="80">o hГѓВ­men apresenta rutura e hematoma no mesmo local).</segment>
    <segment id="81">O laudo estГѓВЎ no Conselho Tutelar de Ruy Barbosa.</segment>
  </rst>
