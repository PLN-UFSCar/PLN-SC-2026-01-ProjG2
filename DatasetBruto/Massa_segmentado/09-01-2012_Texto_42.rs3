  <rst>
    <segment id="1">Aquecido?</segment>
    <segment id="2">Pegando fogo!</segment>
    <segment id="3">Em 5 anos</segment>
    <segment id="4">, o mercado de produtos eróticos saltou de 300 profissionais para 40 mil
Não é à toa que os óleos lubrificantes e o gel aquecedor são os exemplares mais vendidos nos sex shops espalhados pelo País.</segment>
    <segment id="5">Os produtos eróticos  entraram devagarzinho no gosto popular</segment>
    <segment id="6">, deslizando sobre preconceitos e tabus</segment>
    <segment id="7">, para depois gerar um grande aquecimento no mercado de trabalho</segment>
    <segment id="8">, sendo responsável pelo prazer pessoal e profissional de várias pessoas.</segment>
    <segment id="9">Com o casal Fábio Rocha e Dilza Cruz foi assim.</segment>
    <segment id="10">“Sempre usamos</segment>
    <segment id="11">, daí veio a ideia de vender.</segment>
    <segment id="12">Comecei arrumando um nécessaire para o meu marido vender no trabalho.</segment>
    <segment id="13">Isso já faz três anos”</segment>
    <segment id="14">, revela Dilza</segment>
    <segment id="15">, contando</segment>
    <segment id="16">comocomo surgiu a Deliriu's &amp; Prazeres Sex Shop.</segment>
    <segment id="17">O negócio</segment>
    <segment id="18">sese transformou em duas lojas</segment>
    <segment id="19">, uma na Caixa d'Água e outra na Liberdade</segment>
    <segment id="20">, sete funcionários diretos e mais de 800 indiretos.</segment>
    <segment id="21">“Vendemos para lojas especializadas em moda feminina e salões de beleza.</segment>
    <segment id="22">Revendemos para outros lojistas do ramo e para nossos parceiros”</segment>
    <segment id="23">, afirma Fábio</segment>
    <segment id="24">, que largou o emprego fixo para</segment>
    <segment id="25">sese dedicar exclusivamente ao novo comércio.</segment>
    <segment id="26">Para Paula Aguiar</segment>
    <segment id="27">, presidente da Associação Brasileira de Empresas do Mercado Erótico e Sensual (Abeme)</segment>
    <segment id="28">, o exemplo do casal</segment>
    <segment id="29">sese espalhou pelo País nos últimos três anos.</segment>
    <segment id="30">“Antigamente</segment>
    <segment id="31">, os produtos eram caros e  importados</segment>
    <segment id="32">, masmas a indústria nacional resolveu a questão.</segment>
    <segment id="33">A Bahia é o Estado que mais emprega nesse segmento.</segment>
    <segment id="34">Hoje, o grande filão do mercado são as classes C e D</segment>
    <segment id="35">, que podem aumentar seu prazer por preços bem mais dentro de sua realidade”</segment>
    <segment id="36">, afirma.</segment>
    <segment id="37">Para o prazer:</segment>
    <segment id="38">O negócio é investir em novidades</segment>
    <segment id="39">O lançamento para as mulheres é o vibrador em spray.</segment>
    <segment id="40">Após aplicação</segment>
    <segment id="41">, a vagina</segment>
    <segment id="42">sese contrai e dilata</segment>
    <segment id="43">, provocando o orgasmo.</segment>
    <segment id="44">Para os homens</segment>
    <segment id="45">, o masturbador egg simula movimentos de sexo oral</segment>
    <segment id="46">, anal e vaginal.</segment>
    <segment id="47">Inovando</segment>
    <segment id="48">, o casal Ana Carolina e Francisco França criou a Maria Safada e as reuniões eróticas.</segment>
    <segment id="49">“</segment>
    <segment id="50">A cliente convida algumas amigas e vamos exibir nossos produtos.</segment>
    <segment id="51">Em breve</segment>
    <segment id="52">, teremos o chá de lingerie para noivas”</segment>
    <segment id="53">, revela Ana.</segment>
    <segment id="54">Renda certa</segment>
    <segment id="55">, lucro de 100%</segment>
    <segment id="56">De usuária frequente dos produtos a revendedora satisfeita com os lucros.</segment>
    <segment id="57">“</segment>
    <segment id="58">Tenho retorno garantido de praticamente 100% do investimento.</segment>
    <segment id="59">Hoje, pago minhas contas de luz</segment>
    <segment id="60">, água</segment>
    <segment id="61">, telefone e condomínio com o dinheiro dos eróticos”</segment>
    <segment id="62">, revela Vivian Leal.</segment>
    <segment id="63">Caso estranhe uma mulher neste ramo</segment>
    <segment id="64">, saiba que quase 80% dos revendedores são do sexo feminino.</segment>
    <segment id="65">“Elas  ficam mais à vontade quando são atendidas por iguais”</segment>
    <segment id="66">, destaca Isa Muniz</segment>
    <segment id="67">, 33, revendedora</segment>
    <segment id="68">, que paga a faculdade vendendo para colegas.</segment>
    <segment id="69">Como se</segment>
    <segment id="70">se tornar profissional

HOT BAHIA - Compra mínima de R$ 200.</segment>
