  <rst>
    <segment id="1">Fornecimento de água interrompido</segment>
    <segment id="2">O fornecimento de água será interrompido nesta quarta-feira a partir de 8 horas</segment>
    <segment id="3">O fornecimento de água será interrompido nesta quarta-feira (1º)</segment>
    <segment id="4">, a partir de 8 horas</segment>
    <segment id="5">, em Simões Filho.</segment>
    <segment id="6">De acordo com a Embasa</segment>
    <segment id="7">, a suspensão é para realização de serviços de melhoria na rede distribuidora.</segment>
    <segment id="8">A interrupção atinge os seguintes bairros: Conjunto Residencial CIA I e II</segment>
    <segment id="9">, Pitanguinha</segment>
    <segment id="10">, CIA SUL</segment>
    <segment id="11">, Comunidade Jardim Esperança e Barródromo.</segment>
    <segment id="12">O abastecimento será normalizado durante a noite.</segment>
