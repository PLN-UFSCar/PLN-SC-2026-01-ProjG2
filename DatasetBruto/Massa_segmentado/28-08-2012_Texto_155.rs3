    <segment id="17">tambГғВ©m das ForГғВ§as Armadas</segment>
    <segment id="18">, foi baleado e jГғВЎ recebeu alta do Hospital Geral do Estado.</segment>
    <segment id="19">Paulo nГғВЈo foi localizado pela reportagem.</segment>
    <segment id="20">Segundo a titular da Delegacia para o Adolescente Infrator (DAI)</segment>
    <segment id="21">, Claudenice Mayo</segment>
    <segment id="22">, nГғВЈo</segment>
    <segment id="23">sese sabe os verdadeiros motivos do crime.</segment>
    <segment id="24">Entretanto</segment>
    <segment id="25">, ela trabalha com duas hipГғВіteses.</segment>
    <segment id="26">ГўвӮ¬Е“Crime passional e vinganГғВ§a</segment>
    <segment id="27">, pois</segment>
    <segment id="28">pois o adolescente nos informou que os dois jovens jГғВЎ tinham atentado contra a vida dele</segment>
    <segment id="29">, masmas sГғВі as investigaГғВ§ГғВөes poderГғВЈo afirmar a motivaГғВ§ГғВЈo corretaГўвӮ¬.</segment>
    <segment id="30">O adolescente nГғВЈo sabe informar o motivo do desentendimento.</segment>
    <segment id="31">Segundo a delegada plantonista da DAI</segment>
    <segment id="32">, Jacqueline Gordilho</segment>
    <segment id="33">, o adolescente jГғВЎ tinha</segment>
    <segment id="34">sese relacionado com uma ex-namorada de Diego.</segment>
    <segment id="35">ГўвӮ¬Е“Quem nos revelou foi a atual namorada do adolescente e que a briga teria motivado o crimeГўвӮ¬.</segment>
    <segment id="36">O adolescente informou que</segment>
    <segment id="37">, hГғВЎ cerca de dois meses</segment>
    <segment id="38">, os rapazes tinham tentado assassinГғВЎ-lo.</segment>
    <segment id="39">Ele acrescenta que o homicГғВӯdio nГғВЈo tem relaГғВ§ГғВЈo com ciГғВәmes e nem com o trГғВЎfico de drogas.</segment>
    <segment id="40">ГўвӮ¬Е“Sempre encontrava eles nos mesmos pagodes</segment>
    <segment id="41">, na Baixa do Tubo</segment>
    <segment id="42">, e sempre arranjavam confusГғВЈo comigo.</segment>
    <segment id="43">NГғВЈo vou ficar apanhando de ninguГғВ©mГўвӮ¬.</segment>
    <segment id="44">O amigo de infГғВўncia de Diego</segment>
    <segment id="45">, MГғВЎrcio Cardoso</segment>
    <segment id="46">, 18, levantou uma terceira hipГғВіtese: rixa entre jovens de Cosme de Farias e OgunjГғВЎ.
ГўвӮ¬ЛңVГғВӯcio dele</segment>
    <segment id="47">era Coca-ColaГўвӮ¬в„ў
Familiares de Diego</segment>
    <segment id="48">nГғВЈo acreditam em crime passional e nГғВЈo conhecem o rapaz baleado.</segment>
    <segment id="49">De acordo com a tia de Diego</segment>
    <segment id="50">, Josenilda Menezes dos Santos</segment>
    <segment id="51">, 55, o sobrinho nunca</segment>
    <segment id="52">sese meteu em confusГғВЈo.</segment>
    <segment id="53">ГўвӮ¬Е“ Todos conheciam a ГғВӯndole do Diego.</segment>
    <segment id="54">ГғвҖ° muito fГғВЎcil o rapaz falar</segment>
    <segment id="55">, meu sobrinho nГғВЈo estГғВЎ vivo para</segment>
    <segment id="56">sese defender.</segment>
    <segment id="57">Afirmar que Diego jГғВЎ tinha tentado matar ГғВ© mentira</segment>
    <segment id="58">, ele sГғВі andava desarmado.</segment>
    <segment id="59">AtГғВ© onde sei</segment>
    <segment id="60">, ele nГғВЈo usava drogas e nГғВЈo era festeiro.</segment>
    <segment id="61">Ele voltava da AeronГғВЎutica todos os dias e</segment>
    <segment id="62">sese o pai nГғВЈo desse comida</segment>
    <segment id="63">, dor mia com fome.</segment>
