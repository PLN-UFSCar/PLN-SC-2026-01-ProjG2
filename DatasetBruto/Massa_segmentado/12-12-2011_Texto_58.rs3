  <rst>
    <segment id="1">Andrade</segment>
    <segment id="2">, o ídolo que não parou de vencer pelo Flamengo
RIO - Algo distingue Andrade dos demais campeões do mundo de 1981.</segment>
    <segment id="3">Foi ele o que mais recentemente deu ao Flamengo mais uma grande conquista.</segment>
    <segment id="4">Era o técnico do time hexacampeão brasileiro em 2009.</segment>
    <segment id="5">Mas Andrade garante que não</segment>
    <segment id="6">sese sentia realizando um trabalho individual.</segment>
    <segment id="7">Ao contrário</segment>
    <segment id="8">, ele se</segment>
    <segment id="9">se via</segment>
    <segment id="10">comocomo representante daquela geração.</segment>
    <segment id="11">E hoje</segment>
    <segment id="12">, exatos 30 anos após a mágica atuação de Tóquio</segment>
    <segment id="13">, admite: demorou muito tempo para ter a real noção do que aquele time conquistara.
- Numa data</segment>
    <segment id="14">comocomo essa</segment>
    <segment id="15">, em que todos voltam a falar do título</segment>
    <segment id="16">, você vê de verdade o quanto foi importante para o clube</segment>
    <segment id="17">, para a torcida.</segment>
    <segment id="18">É a maior conquista que uma entidade pode ter.</segment>
    <segment id="19">Na época</segment>
    <segment id="20">, a gente não tinha a dimensão.</segment>
    <segment id="21">Você olha e vê que</segment>
    <segment id="22">, 30 anos depois</segment>
    <segment id="23">, ainda é lembrado por aquilo.</segment>
    <segment id="24">Profissionalmente</segment>
    <segment id="25">, foi o dia mais importante da minha vida - diz Andrade.</segment>
    <segment id="26">Imagens de Tóquio vivas na memória do craque</segment>
    <segment id="27">Andrade não parou de vencer pelo Flamengo após o título de Tóquio.</segment>
    <segment id="28">Em 1982</segment>
    <segment id="29">, ganhou outro Brasileiro</segment>
    <segment id="30">, seu segundo no clube.</segment>
    <segment id="31">Repetiu a conquista em 1983 e em 1987.</segment>
    <segment id="32">Passados 28 anos do Mundial</segment>
    <segment id="33">, coube a Andrade ser o condutor do Flamengo em outro momento crucial: devolver à Gávea a taça de Campeão Brasileiro que o clube não ganhava havia 17 anos.</segment>
    <segment id="34">O Flamengo mudara</segment>
    <segment id="35">, o papel de Andrade também.</segment>
    <segment id="36">O que não mudou foi o comportamento</segment>
    <segment id="37">, a simplicidade inabalável.</segment>
    <segment id="38">Um traço de personalidade que não permite ao Tromba</segment>
    <segment id="39">, como</segment>
    <segment id="40">como é até hoje chamado pelos companheiros</segment>
    <segment id="41">, sese apropriar de um feito que foi dele e de uma nova geração de jogadores.

- Mas eu me sentia um representante daquela geração</segment>
    <segment id="42">, de todos aqueles caras.</segment>
    <segment id="43">Se a torcida estava me apoiando tanto</segment>
    <segment id="44">, era pela história que tínhamos construído.</segment>
    <segment id="45">Um trabalho de mais de 20 anos no clube foi coroado - afirma.</segment>
    <segment id="46">O 13 de dezembro de 1981 está vivo na memória:

- Lembro cada lance</segment>
    <segment id="47">, cada passo.</segment>
    <segment id="48">Parece que foi ontem.</segment>
    <segment id="49">Fomos para o jogo com a certeza de que venceríamos.</segment>
    <segment id="50">Os três jogos com o Cobreloa (final da Libertadores) e os três com o Vasco (final do Estadual) fizeram a gente viajar em ótima forma e com a autoestima em alta.</segment>
    <segment id="51">No início</segment>
    <segment id="52">, estudamos o Liverpool e logo impusemos nosso estilo.</segment>
    <segment id="53">No segundo tempo</segment>
    <segment id="54">, com o 3 a 0 a nosso favor não arriscamos.</segment>
    <segment id="55">Eles também não</segment>
    <segment id="56">, com medo de uma goleada</segment>
    <segment id="57">, de passar vergonha.</segment>
    <segment id="58">Andrade lamenta um lance:

- No segundo tempo</segment>
    <segment id="59">, acertei um chute e o goleiro pegou no ângulo.</segment>
    <segment id="60">Sempre brinco que a única bola que ele pegou foi a minha - diz</segment>
    <segment id="61">, rindo.</segment>
    <segment id="62">Nesta segunda-feira</segment>
    <segment id="63">, ao lado de outros campeões de 1981</segment>
    <segment id="64">, Andrade esteve na Gávea para uma festa organizada pelo clube</segment>
    <segment id="65">, na loja do fornecedor de material esportivo.</segment>
    <segment id="66">Zico, técnico do Iraque</segment>
    <segment id="67">, gravou uma mensagem em vídeo</segment>
    <segment id="68">, reproduzida no evento.</segment>
    <segment id="69">Pouco mais de um ano antes</segment>
    <segment id="70">, Andrade deixara a Gávea após ser demitido.</segment>
    <segment id="71">Chegou a ensaiar um discurso de ressentimento.</segment>
    <segment id="72">Hoje, prefere falar do carinho pelo Flamengo:

- Vivi tantas coisas boas.</segment>
    <segment id="73">Você fica triste na hora</segment>
    <segment id="74">, masmas mágoa não consigo ter.</segment>
    <segment id="75">Prefiro pensar que não era mesmo para ficar</segment>
    <segment id="76">, que poderia ter um desgaste que apagasse tudo de bom.</segment>
    <segment id="77">Quem sabe</segment>
    <segment id="78">, um dia volto para iniciar outro trabalho e ter outras conquistas.</segment>
  </rst>
</analysis>