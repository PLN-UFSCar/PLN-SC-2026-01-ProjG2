  <rst>
    <segment id="1">Sacizeiro ﾃδｩ morto em ﾃδ｡rea ﾃ｢竄ｬﾋ徘acificadaﾃ｢竄ｬ邃｢
Jonas ﾃδｩ o 11ﾃつｺ morto na regiﾃδ｣o</segment>
    <segment id="2">, em Santa Cruz
Ainda ﾃδｩ um mistﾃδｩrio as circunstﾃδ｢ncias da morte de Jonas Silveira Santos</segment>
    <segment id="3">, 44 anos</segment>
    <segment id="4">, assassinado anteontem ﾃδ noite</segment>
    <segment id="5">, na Rua do Futuro</segment>
    <segment id="6">, bairro Santa Cruz.</segment>
    <segment id="7">Ele foi morto com vﾃδ｡rias pancadas na cabeﾃδｧa.</segment>
    <segment id="8">Segundo informaﾃδｧﾃδｵes do Departamento de Homicﾃδｭdios  (DHPP)</segment>
    <segment id="9">, a vﾃδｭtima carregava um cachimbo usado para fumar crack.</segment>
    <segment id="10">Jonas foi levado ao Hospital Geral do Estado por policiais militares</segment>
    <segment id="11">, masmas nﾃδ｣o resistiu.</segment>
    <segment id="12">Segundo dados da Secretaria de Seguranﾃδｧa Pﾃδｺblica</segment>
    <segment id="13">, essa ﾃδｩ a 11ﾃつｪ pessoa assassinada</segment>
    <segment id="14">, este ano</segment>
    <segment id="15">, na ﾃδ｡rea que compreende os bairros do Nordeste de Amaralina</segment>
    <segment id="16">, Vale das Pedrinhas</segment>
    <segment id="17">, Santa Cruz e Chapada do Rio Vermelho</segment>
    <segment id="18">, regiﾃδｵes onde foram instaladas  trﾃδｪs Bases Comunitﾃδ｡rias de Seguranﾃδｧa (BCS)</segment>
    <segment id="19">, em setembro do ano passado.</segment>
    <segment id="20">Em 2011</segment>
    <segment id="21">, ocorreram 18 homicﾃδｭdios na ﾃδ｡rea.</segment>
    <segment id="22">Conforme informaﾃδｧﾃδｵes do DHPP</segment>
    <segment id="23">, a rua onde ocorreu o crime</segment>
    <segment id="24">ﾃδｩ muito perigosa.</segment>
    <segment id="25">Traficantes costumam atirar nos policiais.</segment>
    <segment id="26">Os PMs da BCS de Santa Cruz foram chamados por populares para socorrer Jonas</segment>
    <segment id="27">, que foi encontrado com sinais de espancamento</segment>
    <segment id="28">, masmas ninguﾃδｩm soube informar</segment>
    <segment id="29">comocomo ocorreu a agressﾃδ｣o.</segment>
    <segment id="30">Cheio de passagens</segment>
    <segment id="31">O delegado do DHPP</segment>
    <segment id="32">, Juvﾃδｪncio Meneses Neto</segment>
    <segment id="33">, informou que Jonas possui passagens por agressﾃδ｣o.</segment>
    <segment id="34">Jﾃδ｡ foi presso tambﾃδｩm por receptaﾃδｧﾃδ｣o</segment>
    <segment id="35">, furto e roubo.</segment>
    <segment id="36">A motivaﾃδｧﾃδ｣o e a autoria do crime ainda sﾃδ｣o investigadas.</segment>
    <segment id="37">ﾃ｢竄ｬﾅ哲ﾃδ｣o encontramos parentes dele no local.</segment>
    <segment id="38">A ﾃδ｡rea estava desertaﾃ｢竄ｬ</segment>
    <segment id="39">, conta o delegado.</segment>
    <segment id="40">Alﾃδｩm do cachimbo de crack</segment>
    <segment id="41">, Jonas estava com uma faca de mesa</segment>
    <segment id="42">, cinco baterias de celulares</segment>
    <segment id="43">, dois pares de ﾃδｳculos</segment>
    <segment id="44">, um par de chaves e a carteira de trabalho dele.</segment>
    <segment id="45">A perﾃδｭcia encontrou marcas de sangue e fragmentos de dentes da vﾃδｭtima no local do crime.</segment>
    <segment id="46">Apesar de ser uma ﾃδ｡rea onde existe a BCS</segment>
    <segment id="47">, sete moradores foram consultados</segment>
    <segment id="48">, masmas nenhum quis falar sobre o crime.</segment>
