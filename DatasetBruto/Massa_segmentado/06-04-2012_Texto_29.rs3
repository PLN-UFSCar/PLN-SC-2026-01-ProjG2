  <rst>
    <segment id="1">Adolescente é refém do primo há uma semana</segment>
    <segment id="2">BELO HORIZONTE.</segment>
    <segment id="3">Uma adolescente de 14 anos é mantida refém há sete dias pelo primo</segment>
    <segment id="4">, que faz de cativeiro os 200 mil hectares do Parque Nacional da Serra da Canastra</segment>
    <segment id="5">, em São Roque de Minas (MG).

Lindair Marques</segment>
    <segment id="6">, de 32 anos</segment>
    <segment id="7">, chegou a telefonar duas vezes para uma rádio local e</segment>
    <segment id="8">, ao vivo</segment>
    <segment id="9">, afirmou que libertaria a garota</segment>
    <segment id="10">, que é filha de um ex-prefeito do município</segment>
    <segment id="11">, na noite da última segunda-feira</segment>
    <segment id="12">, masmas não cumpriu a promessa.</segment>
    <segment id="13">Moradores da região relatam tiros vindos da mata</segment>
    <segment id="14">, aumentando a tensão na área</segment>
    <segment id="15">, cercada por forte aparato policial.</segment>
    <segment id="16">As polícias Civil e Militar de Minas montaram uma equipe de 80 homens</segment>
    <segment id="17">, reforçada por agentes da Delegacia Antissequestro de Belo Horizonte e do Grupo de Ações Táticas</segment>
    <segment id="18">, um helicóptero e cães farejadores</segment>
    <segment id="19">, para encontrar Lindair</segment>
    <segment id="20">, conhecido por sua habilidade em</segment>
    <segment id="21">sese esconder de autoridades após furtos na região.</segment>
    <segment id="22">Foragido da Justiça</segment>
    <segment id="23">, ele já estava refugiado na mata havia 15 dias quando</segment>
    <segment id="24">, na sexta-feira passada</segment>
    <segment id="25">, amarrou os próprios familiares e levou de casa Sarita Marques Batista</segment>
    <segment id="26">, sob a mira de um revólver.</segment>
    <segment id="27">Como resgate</segment>
    <segment id="28">, pediu R$ 20 mil ao pai da vítima</segment>
    <segment id="29">, Antônio Marques Sobrinho</segment>
    <segment id="30">, de 80.</segment>
    <segment id="31">Lindair só entrou em contato com a família dois dias após o sequestro.</segment>
    <segment id="32">Ao ouvir um apelo da mulher pela rádio</segment>
    <segment id="33">, telefonou e disse que libertaria a prima</segment>
    <segment id="34">, desde que a polícia deixasse o</segment>
    <segment id="35">casocaso.</segment>
    <segment id="36">A entrega da vítima foi marcada para o dia seguinte</segment>
    <segment id="37">, masmas Lindair não apareceu.</segment>
    <segment id="38">No horário combinado</segment>
    <segment id="39">, ele pôs Sarita na linha com o locutor</segment>
    <segment id="40">, para assegurar a todos que ela estava bem.</segment>
    <segment id="41">E pediu que a polícia parasse de sobrevoar o parque</segment>
    <segment id="42">, caso</segment>
    <segment id="43">caso contrário</segment>
    <segment id="44">, mataria a adolescente.

- Não quero nenhum helicóptero em cima desta serra</segment>
    <segment id="45">, porque</segment>
    <segment id="46">porque</segment>
    <segment id="47">, sese eu ver (sic)</segment>
    <segment id="48">, vou continuar onde eu estou.</segment>
    <segment id="49">Aí eu não vou sair daqui.</segment>
    <segment id="50">Quero ver</segment>
    <segment id="51">sese eles me acham - desafiou.</segment>
    <segment id="52">Desesperada</segment>
    <segment id="53">, a família teme que garota seja morta ou que haja confronto com a polícia.</segment>
    <segment id="54">No dia do sequestro</segment>
    <segment id="55">, Lindair foi à fazenda onde Sarita vive e pediu comida.</segment>
    <segment id="56">Ao entrar</segment>
    <segment id="57">, amarrou pai</segment>
    <segment id="58">, mãe e irmã da vítima.</segment>
    <segment id="59">Sarita</segment>
    <segment id="60">sese ofereceu para ir com ele</segment>
    <segment id="61">, com a condição de que ninguém da família fosse machucada.</segment>
    <segment id="62">O perfil de Lindair</segment>
    <segment id="63">, descrito por parentes</segment>
    <segment id="64">comocomo intempestivo e violento</segment>
    <segment id="65">, e seu histórico familiar preocupam a polícia.</segment>
    <segment id="66">Três irmãos dele</segment>
    <segment id="67">sese mataram</segment>
    <segment id="68">, dois após cometer assassinatos.</segment>
    <segment id="69">O pai também</segment>
    <segment id="70">sese suicidou quando o sequestrador era criança.</segment>
    <segment id="71">Ee tem passagens por furtos e roubos e já passou 70 dias escondido no mato após assaltar uma fazenda.</segment>
    <segment id="72">Desde terça-feira</segment>
    <segment id="73">, a polícia tem adotado a tática do silêncio para evitar que o sequestrador saiba detalhes das buscas.</segment>
    <segment id="74">Uma das hipóteses para a falta de comunicação é que a bateria do celular de Lindair tenha descarregado ou que ele esteja com medo de ser rastreado.</segment>
  </rst>
</analysis>