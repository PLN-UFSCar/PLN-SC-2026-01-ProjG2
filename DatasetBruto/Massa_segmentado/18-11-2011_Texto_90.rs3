  <rst>
    <segment id="1">Policiais da UPP de São Carlos prendem cinco homens
RIO - Policiais da Unidade de Polícia Pacificadora (UPP) do Morro de São Carlos prenderam quatro homens na noite de sexta-feira numa casa na comunidade.</segment>
    <segment id="2">Eles eram conhecidos popularmente</segment>
    <segment id="3">comocomo Xuxa</segment>
    <segment id="4">, Magu</segment>
    <segment id="5">, 2G e SN.</segment>
    <segment id="6">Com eles foram apreendidos pedras de crack</segment>
    <segment id="7">, cocaína</segment>
    <segment id="8">, maconha</segment>
    <segment id="9">, uma pistola 45</segment>
    <segment id="10">, três carregadores deste calibre e cerca de R$ 600 em espécie.</segment>
    <segment id="11">A polícia chegou à Rua São Carlos</segment>
    <segment id="12">, no Estácio</segment>
    <segment id="13">, por meio de uma denúncia anônima.</segment>
    <segment id="14">O quinto homem foi preso na manhã desta sexta-feira</segment>
    <segment id="15">, no Querosene</segment>
    <segment id="16">, ainda no complexo do São Carlos.</segment>
    <segment id="17">Ele é conhecido</segment>
    <segment id="18">comocomo Camisa 11 e estava com uma pistola 9 mm.</segment>
    <segment id="19">Todos foram conduzidos à 6ª D.P. (Cidade Nova).</segment>
    <segment id="20">O ex-chefe do tráfico no Morro de São Carlos</segment>
    <segment id="21">, Anderson Rosa Mendonça</segment>
    <segment id="22">, conhecido</segment>
    <segment id="23">comocomo Coelho</segment>
    <segment id="24">, foi preso no último dia 9</segment>
    <segment id="25">, durante operação da Polícia Federal</segment>
    <segment id="26">, na Zona Sul do Rio.</segment>
    <segment id="27">Na ocasião</segment>
    <segment id="28">, cinco agentes civis e militares escoltavam cinco traficantes que teriam fugido da Favela da Rocinha.</segment>
    <segment id="29">Nos quatro carros usados pelo grupo foram apreendidas armas</segment>
    <segment id="30">, granadas e drogas.</segment>
    <segment id="31">Além de Coelho</segment>
    <segment id="32">, outro dos principais chefes do tráfico no Morro de São Carlos</segment>
    <segment id="33">, no Estácio</segment>
    <segment id="34">, também estava entre os presos naquela noite.</segment>
    <segment id="35">Sandro Luiz de Paula Amorim</segment>
    <segment id="36">, o Lindinho ou Peixe</segment>
    <segment id="37">, foi procurar abrigo na Rocinha logo após seu reduto ser ocupado por uma UPP.</segment>
    <segment id="38">Ele foi encarregado de assumir também o comandos das favelas de Macaé</segment>
    <segment id="39">, após a morte do traficante Roupinol</segment>
    <segment id="40">, ocorrida em 2010.</segment>
    <segment id="41">Os outros três bandidos eram Paulo Roberto Lima da Luz</segment>
    <segment id="42">, conhecido</segment>
    <segment id="43">comocomo Paulinho</segment>
    <segment id="44">; Varquia Garcia dos Santos</segment>
    <segment id="45">, conhecido</segment>
    <segment id="46">comocomo "Carré"</segment>
    <segment id="47">; e Sandro Oliveiro.</segment>
  </rst>
</analysis>