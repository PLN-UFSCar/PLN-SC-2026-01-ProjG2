  <rst>
    <segment id="1">A rua ГѓВ© o lar dessa gente MASSA!</segment>
    <segment id="2">Quem nГѓВЈo tem onde morar nГѓВЈo</segment>
    <segment id="3">ГѓВ© bandido e merece respeito</segment>
    <segment id="4">Morar na rua nГѓВЈo ГѓВ© fГѓВЎcil.</segment>
    <segment id="5">Pessoas em situaГѓВ§ГѓВЈo de risco estГѓВЈo sujeitas a agressГѓВµes fГѓВ­sicas</segment>
    <segment id="6">, humilhaГѓВ§ГѓВЈo e desconforto.</segment>
    <segment id="7">Mas hГѓВЎ quem diga que as ruas tГѓВЄm coisas boas a oferecer.</segment>
    <segment id="8">Em Salvador</segment>
    <segment id="9">, alguns viadutos viraram o lar para muita gente.</segment>
    <segment id="10">No Largo do AquidabГѓВЈ</segment>
    <segment id="11">, Baixa dos Sapateiros</segment>
    <segment id="12">, o viaduto Marta Vasconcelos serve de abrigo para cerca de 60 pessoas.</segment>
    <segment id="13">O espaГѓВ§o foi dividido pela turma em pГѓВЎtios 1</segment>
    <segment id="14">, 2 e 3.</segment>
    <segment id="15">Cada grupo vive em uma ГѓВЎrea e quem</segment>
    <segment id="16">sese comporta mal</segment>
    <segment id="17">ГѓВ© segregado para o canto do castigo</segment>
    <segment id="18">, onde o vento bate mais forte.</segment>
    <segment id="19">Suzane da Costa Souza</segment>
    <segment id="20">, 27, vive no pГѓВЎtio 2</segment>
    <segment id="21">, masmas quer mudar para o 3 em busca de mais conforto para a pequena Cleidiane de Souza</segment>
    <segment id="22">, de  apenas quatro meses.</segment>
    <segment id="23">Maloqueiro paloso nГѓВЈo perde tempo!</segment>
    <segment id="24">HГѓВЎ seis meses</segment>
    <segment id="25">, Anderson Moura de Oliveira</segment>
    <segment id="26">, 27, conhecido entre a galera do viaduto do Politeama</segment>
    <segment id="27">comocomo Гўв‚¬Е“TourinhoГўв‚¬</segment>
    <segment id="28">, chegou na cidade para curtir o Carnaval.</segment>
    <segment id="29">Ele trabalhava em Pojuca</segment>
    <segment id="30">, masmas</segment>
    <segment id="31">sese apegou tanto ГѓВ  turma do viaduto que nunca mais quis sair de lГѓВЎ.</segment>
    <segment id="32">Ele se</segment>
    <segment id="33">se define</segment>
    <segment id="34">comocomo um Гўв‚¬Е“maloqueiro ousadoГўв‚¬</segment>
    <segment id="35">, gosta de tirar onda e pegar as gatinhas.</segment>
    <segment id="36">Гўв‚¬Е“Eu me enrolo com a gata no cobertor e fico quentinho a noite todaГўв‚¬</segment>
    <segment id="37">, brinca.</segment>
    <segment id="38">Fim do vГѓВ­cio na escola de vida</segment>
    <segment id="39">Foi nas ruas</segment>
    <segment id="40">, local onde estГѓВЎ desde os 15 anos de idade</segment>
    <segment id="41">, que Oberdan Souza de Jesus</segment>
