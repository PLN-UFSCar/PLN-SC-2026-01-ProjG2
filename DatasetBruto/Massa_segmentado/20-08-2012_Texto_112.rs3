    <segment id="43">, masmas hГѓВЎ um ano ele conseguiu</segment>
    <segment id="44">sese libertar e estГѓВЎ limpo.</segment>
    <segment id="45">Depois de passar seis meses em um centro de recuperaГѓВ§ГѓВЈo para alcoГѓВіlatras</segment>
    <segment id="46">, Oberdan</segment>
    <segment id="47">sese orgulha da mudanГѓВ§a que exibe na forma fГѓВ­sica Гўв‚¬</segment>
    <segment id="48">вЂњ de barba feita e</segment>
    <segment id="49">, segundo ele</segment>
    <segment id="50">, bem mais encorpado.</segment>
    <segment id="51">Ele diz que a rua lhe deu experiГѓВЄncia para nГѓВЈo cometer os mesmos erros.</segment>
    <segment id="52">Sofrimento que virou paixГѓВЈo
HГѓВЎ quase quatro meses</segment>
    <segment id="53">Soraia PurificaГѓВ§ГѓВЈo de Souza</segment>
    <segment id="54">, 30, conheceu Luiz Fernando Souza</segment>
    <segment id="55">, 23, e vive um pouco mais feliz.</segment>
    <segment id="56">Ainda com a face inchada por ter sido agredida pelo ex-namorado</segment>
