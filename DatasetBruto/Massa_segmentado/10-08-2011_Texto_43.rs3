  <rst>
    <segment id="1">Operários querem mais segurança</segment>
    <segment id="2">Trabalhadores vão às ruas para protestar contra a morte de nove operários ontem</segment>
    <segment id="3">Os operários da Construção Civil protestam nesta quarta-feira (10) pela morte de nove colegas em um acidente na obra do Edifício Empresarial Paulo VI</segment>
    <segment id="4">, na terça-feira (9).</segment>
    <segment id="5">A categoria segue em passeata pela Avenida Paralela até o cemitério Bosque da Paz para o enterro de Antônio Elias da Silva</segment>
    <segment id="6">, Lourival Ferreira e José Roque dos Santos a partir das 10 horas.</segment>
    <segment id="7">O sepultamento de Hélio Sampaio será às 15 horas no Campo Santo.</segment>
    <segment id="8">O corpo das outras cinco vítimas serão enterradas em cidades do interior baiano: Jairo Correia (Irará)</segment>
    <segment id="9">; Martinho dos Santos (Conceição de Feira)</segment>
    <segment id="10">; Antônio Luiz (Conceição do Jacuípe)</segment>
    <segment id="11">; Antônio Reis do Carmo (Nazaré do Jacuípe)</segment>
    <segment id="12">;</segment>
    <segment id="13">Manoel Bispo Pereira (São Miguel das Matas).</segment>
    <segment id="14">Cerca de 1</segment>
    <segment id="15">,5 mil operários participam do protesto</segment>
    <segment id="16">, além de representantes da Central dos Trabalhadores Brasileira (CTB) e dos Sindicato dos Trabalhadores da Construção Civil (Sintracom) e Sindicato dos Comerciários.</segment>
    <segment id="17">O Sintracom propôs uma paralisação de 24 horas nesta quarta</segment>
    <segment id="18">para que</segment>
    <segment id="19">para que os colegas participem do enterro dos corpos dos operários mortos.</segment>
    <segment id="20">Alguns trabalhadores</segment>
    <segment id="21">, porém</segment>
    <segment id="22">porém, alegam que estão sendo ameaçados pelos empresários.

"</segment>
    <segment id="23">As construtoras estão ameaçando cortar o dia</segment>
    <segment id="24">casocaso eles não trabalhem.</segment>
    <segment id="25">Conhecia alguns dos operários que morreram</segment>
    <segment id="26">, estudei com eles.</segment>
    <segment id="27">É um dia muito triste para mim</segment>
    <segment id="28">, estou acabado.</segment>
    <segment id="29">Não tenho medo de perder emprego</segment>
    <segment id="30">, tenho medo de perder a vida"</segment>
    <segment id="31">, disse um operário que não quis</segment>
    <segment id="32">sese identificar.</segment>
    <segment id="33">O presidente da CTB</segment>
    <segment id="34">, Adilson Araújo</segment>
    <segment id="35">, disse que a Construção Civil está de luto.</segment>
    <segment id="36">"</segment>
    <segment id="37">Já fizemos manifestações por melhoria salarial e por demisões</segment>
    <segment id="38">, masmas hoje nossa paralisação é pela vida.</segment>
    <segment id="39">O patronato prefere dinheiro do que investir em segurança para a vida do trabalhador".</segment>
    <segment id="40">Com as noves mortes do acidente desta terça</segment>
    <segment id="41">, são contabilizadas 15 mortes com 60 feridos na Construção Civil este ano.</segment>
    <segment id="42">"</segment>
    <segment id="43">Se não houver fiscalização e valorização do trabalho dos operários</segment>
    <segment id="44">, esses acidentes vão continuar acontecendo"</segment>
    <segment id="45">, disse Vera Lúcia Silva Santana</segment>
    <segment id="46">, diretora do Sintracom.</segment>
    <segment id="47">Acidente

Antônio Elias da Silva</segment>
    <segment id="48">, Lourival Ferreira</segment>
    <segment id="49">, José Roque dos Santos</segment>
    <segment id="50">, Hélio Sampaio</segment>
    <segment id="51">, Antônio Luiz A. dos Reis</segment>
    <segment id="52">, Manoel Bispo Pereira</segment>
    <segment id="53">, Jairo de A. Correia</segment>
    <segment id="54">, Martinho F. dos Santos e Antônio Reis do Carmo morreram após o elevador que utilizavm cair do 28º andar do prédio em construção.</segment>
    <segment id="55">As primeiras investigações apontam para a quebra no eixo da roldana que sustenta o cabo de tração do equipamento</segment>
    <segment id="56">, seguida de falha no sistema de freios de emergência.</segment>
  </rst>
</analysis>