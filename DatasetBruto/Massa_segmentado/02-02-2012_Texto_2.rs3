  <rst>
    <segment id="1">New Hit cria polêmica com foto picante</segment>
    <segment id="2">A imagem sugere que uma fã da banda fez sexo oral no cantor Dudu</segment>
    <segment id="3">Na tarde de ontem</segment>
    <segment id="4">, uma foto deu o que falar nas redes sociais: o vocalista da banda New Hit</segment>
    <segment id="5">, Eduardo Martins</segment>
    <segment id="6">, 18, o Dudu</segment>
    <segment id="7">, parecia simular cena de sexo oral com uma fã</segment>
    <segment id="8">, em um show na “Noite da Apertadinha” (</segment>
    <segment id="9">comocomo são chamados os ensaios do grupo</segment>
    <segment id="10">, realizados no Oba</segment>
    <segment id="11">, Oba, em Patamares).</segment>
    <segment id="12">Em pouco tempo a imagem rendeu milhares de compartilhamentos no Facebook e os comentários da galera não param de subir.</segment>
    <segment id="13">Até os fãs mais ardorosos da banda ficaram indignados com a imagem e nada entenderam.</segment>
    <segment id="14">Jorge Sacramento</segment>
    <segment id="15">, empresário da banda</segment>
    <segment id="16">, afirmou que a única justificativa para a foto seria uma espécie de montagem.</segment>
    <segment id="17">“Aquela apresentação aconteceu há sete meses.</segment>
    <segment id="18">Não houve nada disso que estão dizendo.</segment>
    <segment id="19">Há sensualidade por parte do vocalista nos shows</segment>
    <segment id="20">, masmas não daquele jeito”</segment>
    <segment id="21">, garantiu.</segment>
    <segment id="22">Se a fã chegou às vias de fato não</segment>
    <segment id="23">sese sabe</segment>
    <segment id="24">, masmas é fato que o Justin Bieber do pagode</segment>
    <segment id="25">, como</segment>
    <segment id="26">como é conhecido Dudu</segment>
    <segment id="27">, e os dançarinos da banda tem coreografias bem ousadas e letras bem sugestivas.</segment>
    <segment id="28">“</segment>
    <segment id="29">Não sei por que as pessoas criaram essa polêmica.</segment>
    <segment id="30">Quem vai para os shows da New Hit</segment>
    <segment id="31">, sabe que na música ‘Cabecinha ou Tudo’</segment>
    <segment id="32">, o cantor e seus dançarinos fazem uma coreografia em que insinuam um striptease</segment>
    <segment id="33">, masmas em nenhum momento eles ficam nus”</segment>
    <segment id="34">, assegura Jorge.</segment>
  </rst>
