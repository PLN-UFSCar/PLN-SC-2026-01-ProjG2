  <rst>
    <segment id="1">Não foi por dindim!</segment>
    <segment id="2">Mesmo sabendo da morte da irmã</segment>
    <segment id="3">, ela ficou na disputa por R$ 2 milhões</segment>
    <segment id="4">Mesmo com a morte de sua irmã</segment>
    <segment id="5">, Angelina Filgueira</segment>
    <segment id="6">, a modelo Angela Bismarchi resolveu ficar em “</segment>
    <segment id="7">A Fazenda” para disputar o prêmio de R$ 2 milhões.</segment>
    <segment id="8">"</segment>
    <segment id="9">Resolvi ficar</segment>
    <segment id="10">porque</segment>
    <segment id="11">porque sou forte"</segment>
    <segment id="12">, disse ela</segment>
    <segment id="13">, que, por conta da escolha</segment>
    <segment id="14">, não pôde ir ao enterro da irmã</segment>
    <segment id="15">, sepultada na tarde de anteontem</segment>
    <segment id="16">, no Cemitério do Inhaúma</segment>
    <segment id="17">, na zona norte do Rio de Janeiro (RJ).</segment>
    <segment id="18">O cirurgião plástico Wagner de Moraes</segment>
    <segment id="19">, marido da peoa</segment>
    <segment id="20">, justificou ontem</segment>
    <segment id="21">, durante um programa na Record</segment>
    <segment id="22">, a atitude da mulher.</segment>
    <segment id="23">“Eu e os cinco irmãos da Angela íamos apoiar qualquer decisão dela.</segment>
    <segment id="24">Eu tinha certeza que minha mulher ia ficar</segment>
    <segment id="25">, principalmente</segment>
    <segment id="26">, porque</segment>
    <segment id="27">porque Angelina já estava morta.</segment>
    <segment id="28">Se a irmã estivesse no hospital</segment>
    <segment id="29">, ela sairia na hora.</segment>
    <segment id="30">Ela não decidiu por dinheiro</segment>
    <segment id="31">, não decidiu por vaidade”</segment>
    <segment id="32">, garantiu.</segment>
    <segment id="33">A decisão da moça não foi bem vista por alguns participantes</segment>
    <segment id="34">, como</segment>
    <segment id="35">como Penélope Nova</segment>
    <segment id="36">, Vavá e Shayene Cesário</segment>
    <segment id="37">, que disse:</segment>
    <segment id="38">“Eu sairia desesperada”.</segment>
    <segment id="39">Viviane Araújo</segment>
    <segment id="40">, por sua vez</segment>
    <segment id="41">, aprovou a decisão de Angela.</segment>
    <segment id="42">No último sábado</segment>
    <segment id="43">, antes de receber a notícia</segment>
    <segment id="44">, ela chegou a sonhar com sua irmã:</segment>
    <segment id="45">“Ela era meu porto seguro.</segment>
    <segment id="46">Não estou acreditando.</segment>
    <segment id="47">Deve ser por isso que tive um sonho com ela na tarde de sábado”.</segment>
    <segment id="48">Suicídio após briga
Angelina teria</segment>
    <segment id="49">sese matado depois que o ex-marido invadiu sua casa e iniciou uma briga com o atual namorado.</segment>
    <segment id="50">Ela pegou a arma e atirou contra o próprio peito.</segment>
    <segment id="51">Três dias antes</segment>
    <segment id="52">, ela já tinha tentado</segment>
    <segment id="53">sese matar por conta do ex.</segment>
  </rst>
</analysis>