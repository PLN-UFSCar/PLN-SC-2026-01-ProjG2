  <rst>
    <segment id="1">“</segment>
    <segment id="2">Ai sese eu te pego”</segment>
    <segment id="3">Hit baiano domina campos e boates na Espanha</segment>
    <segment id="4">A Bahia é o mundo!</segment>
    <segment id="5">Se não for</segment>
    <segment id="6">, ao menos o torna muito mais divertido.</segment>
    <segment id="7">Prova disso é o sucesso do hit que tem embalado as comemorações do craque do Real Madrid Cristiano Ronaldo em seus gols.</segment>
    <segment id="8">“</segment>
    <segment id="9">Ai sese eu te pego” nasceu em Porto Seguro</segment>
    <segment id="10">, pelas mãos de Sharon</segment>
    <segment id="11">, a mesma de “Dança do Quadrado”</segment>
    <segment id="12">, em parceria com o compositor feirense Antonio Dyggs.</segment>
    <segment id="13">Sucesso no sul do estado</segment>
    <segment id="14">, a música caiu no gosto da rapaziada do Cangaia de Jegue</segment>
    <segment id="15">, que incorporou-a ao seu repertório e ecoou pelos quatro cantos da Bahia.</segment>
    <segment id="16">“Cantamos a música pelo interior do Estado durante esses anos.</segment>
    <segment id="17">Acreditamos na letra que abraçamos”</segment>
    <segment id="18">, ressalta Norberto Curvello</segment>
    <segment id="19">, vocalista do grupo que criou a coreografia bombada.</segment>
    <segment id="20">Em visita a Salvador</segment>
    <segment id="21">, o sertanejo Michel Teló ouviu a canção e foi atrás de seus autores para gravá-la.</segment>
    <segment id="22">O resultado é o que</segment>
    <segment id="23">sese vê nos gramados e</segment>
    <segment id="24">, de quebra</segment>
    <segment id="25">, nas boates espanholas.</segment>
    <segment id="26">Depois do ‘bailado’ de Cristiano Ronaldo</segment>
    <segment id="27">, a música está bombando nas pistas da Espanha.</segment>
    <segment id="28">Golaço da Bahia!</segment>
  </rst>
</analysis>