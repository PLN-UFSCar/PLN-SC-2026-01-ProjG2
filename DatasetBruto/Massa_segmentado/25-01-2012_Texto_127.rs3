  <rst>
    <segment id="1">Rildo precisa ter ‘cabeça de gelo’</segment>
    <segment id="2">Após excesso contra o Juazeiro</segment>
    <segment id="3">, atacante alega vontade de fazer gols</segment>
    <segment id="4">Depois de ficar quase quatro meses sem jogar por tentar agredir um árbitro na Série B 2011</segment>
    <segment id="5">, Rildo garantiu ao MASSA!</segment>
    <segment id="6">que estaria mais calmo em 2012.</segment>
    <segment id="7">Porém, a nova versão do atleta tem apresentado alguns defeitos.</segment>
    <segment id="8">No último domingo</segment>
    <segment id="9">, no 6 a 1 do Vitória diante do Juazeiro</segment>
    <segment id="10">, o jogador  ficou irado  quando o pedido para cobrar um pênalti foi negado por Neto Baiano e</segment>
    <segment id="11">, depois</segment>
    <segment id="12">, ao ser substituído por Alan Pinheiro.</segment>
    <segment id="13">Sem querer aceitar os erros</segment>
    <segment id="14">, ele justifica:</segment>
    <segment id="15">“Estava tranquilo.</segment>
    <segment id="16">Foi a vontade de vencer.</segment>
    <segment id="17">Não tem nada com o episódio do ano passado.</segment>
    <segment id="18">Queria bater o pênalti</segment>
    <segment id="19">porque</segment>
    <segment id="20">porque já sofri muitos e nunca bati um.</segment>
    <segment id="21">E  o Neto já tinha feito um gol.</segment>
    <segment id="22">Sobre a saída</segment>
    <segment id="23">,  foi para me poupar”</segment>
    <segment id="24">, contou o atacante que pode ter a fome de gols saciada hoje</segment>
    <segment id="25">, às 10h da noite</segment>
    <segment id="26">, contra o Vitória da Conquista</segment>
    <segment id="27">, no Lomanto Júnior</segment>
    <segment id="28">, no sudoeste baiano:</segment>
    <segment id="29">“Prometo muito empenho e</segment>
    <segment id="30">, sese Deus me abençoar</segment>
    <segment id="31">, vou marcar</segment>
    <segment id="32">, masmas  o importante é sairmos com os três pontos”.</segment>
    <segment id="33">Para ter ‘cabeça de gelo’</segment>
    <segment id="34">, Rildo ouve o melhor amigo Geovanni.</segment>
    <segment id="35">“</segment>
    <segment id="36">Sei o que devo fazer em campo</segment>
    <segment id="37">, masmas sempre converso com o Geovanni.</segment>
    <segment id="38">Ele vai em minha casa</segment>
    <segment id="39">, liga para a minha mãe</segment>
    <segment id="40">, sempre me monitora.</segment>
    <segment id="41">Confio nele”</segment>
    <segment id="42">, contou o atleta.</segment>
  </rst>
</analysis>