  <rst>
    <segment id="1">Noiva teria pago por privilégios a goleiro Bruno na prisão
BELO HORIZONTE - Os privilégios do ex-goleiro do Flamengo Bruno Fernandes na Penitenciária Nelson Hungria</segment>
    <segment id="2">, em Contagem (MG)</segment>
    <segment id="3">, não parecem ter sido resultado apenas da fama do atleta em campo.</segment>
    <segment id="4">Escutas telefônicas realizadas com autorização da Justiça flagraram a noiva do jogador</segment>
    <segment id="5">, a dentista Ingrid Calheiros</segment>
    <segment id="6">, sese comprometendo</segment>
    <segment id="7">, em conversa com um amigo de Bruno</segment>
    <segment id="8">, a enviar dinheiro para a então diretora de atendimento da unidade prisional</segment>
    <segment id="9">, Márcia Ermelina Fortes</segment>
    <segment id="10">, que foi afastada em abril.</segment>
    <segment id="11">Na gravação</segment>
    <segment id="12">, feita em novembro do ano passado</segment>
    <segment id="13">, Ingrid conversa com Vítor Carvalho</segment>
    <segment id="14">, ex-procurador de Bruno.</segment>
    <segment id="15">Logo após citarem Márcia</segment>
    <segment id="16">, a dentista diz "</segment>
    <segment id="17">Ah, então tá beleza</segment>
    <segment id="18">, vou mandar dinheiro pra ela.</segment>
    <segment id="19">Vou deixar pra ligar amanhã".</segment>
    <segment id="20">Em outros telefonemas grampeados com autorização da Justiça</segment>
    <segment id="21">, Ingrid fala de Márcia Fortes</segment>
    <segment id="22">comocomo uma pessoa de confiança dentro do complexo penitenciário onde Bruno está preso sob a acusação de participação do desaparecimento e morte da ex-namorada Eliza Samudio.</segment>
    <segment id="23">"</segment>
    <segment id="24">Tudo o que a acontece lá (no presídio) ela me liga para dizer"</segment>
    <segment id="25">, afirma a dentista em outra conversa com seu advogado</segment>
    <segment id="26">, Cláudio Dalledone.</segment>
    <segment id="27">Em abril</segment>
    <segment id="28">, Márcia Fortes foi exonerada por "incompatibilidade com o cargo".</segment>
    <segment id="29">Ela continua trabalhando na unidade</segment>
    <segment id="30">, no Núcleo de Evolução Criminológica.</segment>
    <segment id="31">O advogado de Bruno</segment>
    <segment id="32">, Cláudio Dalledone</segment>
    <segment id="33">, negou ontem que o dinheiro para Márcia citado por Ingrid tenha relação com a obtenção de facilidades para seu cliente.</segment>
  </rst>
