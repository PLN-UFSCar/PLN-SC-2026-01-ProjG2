  <rst>
    <segment id="1">Grupo Forrozão é danado de bom!</segment>
    <segment id="2">Banda faz show para gravar CD ao vivo com a participação de quem gosta de dançar</segment>
    <segment id="3">Na estrada desde 2006</segment>
    <segment id="4">, a trupe da Forrozão capricha no ritmo típico do nordeste brasileiro e faz um suingue bem ao estilo Aviões do Forró</segment>
    <segment id="5">, banda na qual os três vocalistas - Marcão</segment>
    <segment id="6">, Nanda e Léo Fera - buscam inspiração para assumir a linha de frente do grupo</segment>
    <segment id="7">, que conta com sete integrantes.</segment>
    <segment id="8">A equipe ganha mais fôlego</segment>
    <segment id="9">, masmas tira o ar dos fãs</segment>
    <segment id="10">, com a presença de seis dançarinos</segment>
    <segment id="11">, que arrasam nas coreografias.</segment>
    <segment id="12">O sucesso da galera é tamanho que</segment>
    <segment id="13">, desde a estreia</segment>
    <segment id="14">, contabiliza nada menos do que oito CDs e três DVDs.</segment>
    <segment id="15">Agora, esses incansáveis profissionais estão em contagem regressiva para a gravação de mais um CD ao vivo</segment>
    <segment id="16">, que rola hoje</segment>
    <segment id="17">, no Coliseu do Forró</segment>
    <segment id="18">, em Patamares.</segment>
    <segment id="19">O álbum vai contar com 20 faixas</segment>
    <segment id="20">, seis delas autorais</segment>
    <segment id="21">, incluindo a música de trabalho</segment>
    <segment id="22">“Carinho e Barata”</segment>
    <segment id="23">.</segment>
    <segment id="24">“Vamos fazer a galera dançar muito.</segment>
    <segment id="25">Ninguém vai ficar parado”</segment>
    <segment id="26">, garante o vocalista Marcão.</segment>
    <segment id="27">A noite dos forrozeiros promete.</segment>
    <segment id="28">É uma ótima oportunidade para esquentar o corpo</segment>
    <segment id="29">, que deve chegar no São João danado de bom!</segment>
    <segment id="30">Aproveite!</segment>
    <segment id="31">Gravação do CD</segment>
    <segment id="32">Os ensaio da banda</segment>
    <segment id="33">Forrozão rolam todos os sábados</segment>
    <segment id="34">, às 22H</segment>
    <segment id="35">, na casa de shows</segment>
    <segment id="36">Coliseu do Forró</segment>
    <segment id="37">, em Patamares.</segment>
    <segment id="38">Entrada: R$ 20 (Mulher) e R$ 25 (Homem).</segment>
    <segment id="39">Hoje, em especial</segment>
    <segment id="40">, tem gravação do novo CD e não vão faltar forrozeiros de carteirinha e gente bonita para dançar ao som de um arrasta-pé de primeira.</segment>
    <segment id="41">Depois</segment>
    <segment id="42">, os músicos</segment>
    <segment id="43">sese preparam para cair na estrada e agitar o interior do Estado.</segment>
  </rst>
</analysis>