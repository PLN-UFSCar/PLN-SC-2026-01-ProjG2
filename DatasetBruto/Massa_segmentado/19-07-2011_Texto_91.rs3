  <rst>
    <segment id="1">Encontro com a morte em Itinga
Kelly saiu do Salvador Fest</segment>
    <segment id="2">, foi para o Largo do Caranguejo e apareceu morta</segment>
    <segment id="3">Apesar de a Polícia Civil não confirmar oficialmente o nome de nenhum suspeito pelo assassinato da  dançarina Kelly Sales Silva</segment>
    <segment id="4">, 23 anos</segment>
    <segment id="5">, popularmente conhecida</segment>
    <segment id="6">comocomo Kelly Cyclone ou Kelly Doçura</segment>
    <segment id="7">, familiares e amigos da jovem acreditam que ela foi vítima de um crime passional praticado por vingança</segment>
    <segment id="8">, por um ex-namorado</segment>
    <segment id="9">, que não aceitava o fim da relação.</segment>
    <segment id="10">“</segment>
    <segment id="11">Um ex-namorado tentava reatar a relação e ela não queria.</segment>
    <segment id="12">O cara é um bandido.</segment>
    <segment id="13">Mas quem anda nesse meio está sujeito a isso”</segment>
    <segment id="14">, disse  o pai de Kelly</segment>
    <segment id="15">, o comerciante Antônio Carlos Santos Silva</segment>
    <segment id="16">, 55,  ao ir reconhecer o corpo da filha no Instituto Médico-Legal</segment>
    <segment id="17">, na manhã de ontem.</segment>
    <segment id="18">Ele não disse o nome do ex-namorado.</segment>
    <segment id="19">“Ela se</segment>
    <segment id="20">se envolveu com namorados errados.</segment>
    <segment id="21">Mas era uma menina ótima.</segment>
    <segment id="22">O sonho atual dela era ser vereadora”</segment>
    <segment id="23">, completou o pai</segment>
    <segment id="24">, durante o enterro.</segment>
    <segment id="25">Sem revelar a identidade</segment>
    <segment id="26">, amigos disseram que o ex-namorado de Kelly seria um traficante de drogas conhecido</segment>
    <segment id="27">comocomo “Mão”</segment>
    <segment id="28">, que atua em Lauro.</segment>
    <segment id="29">Após o Salvador Fest</segment>
    <segment id="30">, no Parque de Exposições</segment>
    <segment id="31">, Kelly teria ido com amigas até o Largo do Caranguejo</segment>
    <segment id="32">, no bairro de Itinga.</segment>
    <segment id="33">De lá, teria saído para</segment>
    <segment id="34">sese encontrar com  o ex-namorado.</segment>
    <segment id="35">“Ela saiu dizendo que voltava logo”</segment>
    <segment id="36">, disse uma das irmãs</segment>
    <segment id="37">, Carla Souza</segment>
    <segment id="38">, 24.</segment>
    <segment id="39">“</segment>
    <segment id="40">Eu falei que era para ela não ir”</segment>
    <segment id="41">, lamentou a jovem</segment>
    <segment id="42">, aos prantos.</segment>
    <segment id="43">Kelly Cyclone foi encontrada morta</segment>
    <segment id="44">, com marcas de tiros e facadas</segment>
    <segment id="45">, no final da noite do último domingo</segment>
    <segment id="46">, 17, na Rua Romualdo de Brito</segment>
    <segment id="47">, no centro de Lauro de Freitas.</segment>
    <segment id="48">Kelly tinha 20 tatuagens</segment>
    <segment id="49">, uma dela no cóccix com a expressão “vida  loka”.</segment>
  </rst>
</analysis>