  <rst>
    <segment id="1">Ministro admite contato com diretor do Dnit</segment>
    <segment id="2">, masmas nega ter lhe dado qualquer ordem ou recebido empreiteiras</segment>
    <segment id="3">O ministro das Comunicações</segment>
    <segment id="4">, Paulo Bernardo</segment>
    <segment id="5">, negou ontem que tenha recebido empreiteiras</segment>
    <segment id="6">, quando comandava a pasta do Planejamento</segment>
    <segment id="7">, para acertar obras rodoviárias executadas pelo Departamento Nacional de Infraestrutura de Trans$(Dnit).</segment>
    <segment id="8">Afirmou</segment>
    <segment id="9">, porém</segment>
    <segment id="10">porém, que pediu ao diretor-geral do Dnit</segment>
    <segment id="11">, Luiz Antonio Pagot</segment>
    <segment id="12">, informações sobre o andamento de obras no Paraná</segment>
    <segment id="13">, base política do ministro e de sua mulher</segment>
    <segment id="14">, a chefe da Casa Civil</segment>
    <segment id="15">, Gleisi Hoffmann.</segment>
    <segment id="16">O diretor do Dnit disse a interlocutores ter provas de que empreiteiras negociavam com Paulo Bernardo um $pronto de projetos</segment>
    <segment id="17">, como</segment>
    <segment id="18">como publicou ontem Jorge Bastos Moreno na coluna "Nhenhenhém".
- Pagot não era meu subordinado</segment>
    <segment id="19">, e servidor público obedece a ordens formais que ficam registradas no sistema do governo.</segment>
    <segment id="20">No serviço público</segment>
    <segment id="21">, fazemos apenas o que a lei determina - afirmou o ministro</segment>
    <segment id="22">, por e-mail.</segment>
    <segment id="23">Quando era ministro do Planejamento</segment>
    <segment id="24">, o senhor recebia empreiteiras para apresentação de projetos na área de transportes?
PAULO BERNARDO:</segment>
    <segment id="25">Não.</segment>
    <segment id="26">Embora seja hoje ministro das Comunicações</segment>
    <segment id="27">, vou explicar</segment>
    <segment id="28">comocomo funciona no Planejamento.</segment>
    <segment id="29">O governo faz o planejamento dos investimentos que considera importantes</segment>
    <segment id="30">, encomenda os projetos</segment>
    <segment id="31">, que são incluídos no Orçamento.</segment>
    <segment id="32">Em seguida</segment>
    <segment id="33">, são feitas as licitações para contratar as empresas que executarão as obras.</segment>
    <segment id="34">Assim, no Planejamento</segment>
    <segment id="35">, não recebíamos empresas para apresentar projetos de qualquer área.</segment>
    <segment id="36">O governo contrata empresas</segment>
    <segment id="37">, por meio dos ministérios setoriais</segment>
    <segment id="38">, como</segment>
    <segment id="39">como é o dos Transportes.</segment>
    <segment id="40">Quero acrescentar ainda que é tarefa cotidiana de ministros receber em audiência empresários</segment>
    <segment id="41">, trabalhadores ou entidades da sociedade civil.</segment>
    <segment id="42">Quero repelir insinuações que tentam associar malfeitos ou irregularidades a tarefas normais de um ministro de Estado.</segment>
    <segment id="43">As empreiteiras lhe apresentavam "</segment>
    <segment id="44">pacotes fechados" para ação e liberação de projetos na área de transportes</segment>
    <segment id="45">, mediante pagamento de propina?
PAULO</segment>
    <segment id="46">BERNARDO:</segment>
    <segment id="47">Pretendo responder respeitosamente às suas perguntas</segment>
    <segment id="48">, masmas exijo que me tratem com o mesmo respeito.</segment>
    <segment id="49">Sua pergunta é insultuosa.</segment>
    <segment id="50">O GLOBO tem publicado insinuações atribuídas a fontes que não</segment>
    <segment id="51">sese identificam.</segment>
    <segment id="52">Publiquem os nomes dessas fon$e tomarei as medidas cabíveis a respeito.</segment>
    <segment id="53">O senhor tinha alguma influência na aprovação de projetos no Dnit?</segment>
    <segment id="54">Leia a íntegra desta reportagem no GLOBO DIGITAL (conteúdo exclusivo para assinantes)</segment>
  </rst>
</analysis>