  <rst>
    <segment id="1">Servidores botam a boca no trombone</segment>
    <segment id="2">Funcionários municipais alegam que novo plano de cargos da prefeitura reduziu salário
Secretarias e superintendências municipais suspenderam o funcionamento em 70%</segment>
    <segment id="3">, ontem</segment>
    <segment id="4">, devido à paralisação de servidores que segue até amanhã</segment>
    <segment id="5">, quando haverá nova rodada de negociação com a prefeitura.</segment>
    <segment id="6">A pauta de reivindicação é sobre as mudanças no Plano de Cargos e Vencimentos (PCV).</segment>
    <segment id="7">Segundo os servidores</segment>
    <segment id="8">, a última versão do plano prevê redução em seus salários</segment>
    <segment id="9">porque</segment>
    <segment id="10">porque a gratificação que compõe a remuneração seria reduzida.</segment>
    <segment id="11">“Nossa reivindicação é com relação ao Plano de Cargos e Vencimentos.</segment>
    <segment id="12">O prefeito mudou a matriz salarial e isso gerará perdas salariais para servidores.</segment>
    <segment id="13">O PCV  não é para reduzir salários</segment>
    <segment id="14">, não  aceitaremos isso”</segment>
    <segment id="15">, frisou o coordenador-geral do Sindicato dos Servidores da Prefeitura de Salvador (Sindseps)</segment>
    <segment id="16">, Jeiel Soares.</segment>
    <segment id="17">Ontem pela manhã</segment>
    <segment id="18">, a categoria fez protesto na região do Iguatemi e promete  fazer uma caminhada</segment>
    <segment id="19">, hoje</segment>
    <segment id="20">, às 8h</segment>
    <segment id="21">, do Campo Grande até a Praça Municipal e</segment>
    <segment id="22">, amanhã</segment>
    <segment id="23">, uma assembleia</segment>
    <segment id="24">, às 15h</segment>
    <segment id="25">, será realizada nos Barris.</segment>
    <segment id="26">Negociação</segment>
    <segment id="27">Em nota</segment>
    <segment id="28">, a Prefeitura de Salvador informou</segment>
    <segment id="29">, por meio da Secretaria de Planejamento</segment>
    <segment id="30">, Gestão e Tecnologia (Seplag)</segment>
    <segment id="31">, que apresentará hoje o Plano de Cargos e Vencimentos (PCV) aos representantes dos servidores municipais.</segment>
    <segment id="32">Na ocasião</segment>
    <segment id="33">, serão demonstrados os valores finais</segment>
    <segment id="34">, após as análises da Controladoria Geral do Município (CGM) e da Secretaria Municipal da Fazenda (Sefaz)</segment>
    <segment id="35">, com base na Lei da Responsabilidade Fiscal.</segment>
    <segment id="36">A Seplag informou ainda que os estudos da CGM e da Sefaz estão voltados para conciliar as solicitações dos servidores.</segment>
  </rst>
</analysis>