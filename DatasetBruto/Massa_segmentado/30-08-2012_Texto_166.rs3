  <rst>
    <segment id="1">Eles querem justiﾃδｧa para amenizar a dor</segment>
    <segment id="2">Professor foi achado morto em Sﾃδ｣o Sebastiﾃδ｣o do Passﾃδｩ depois de sair da casa da tia</segment>
    <segment id="3">Primeiro a notﾃδｭcia do desaparecimento.</segment>
    <segment id="4">Depois a descoberta da morte.</segment>
    <segment id="5">Agora, a luta por Justiﾃδｧa.</segment>
    <segment id="6">Esta ﾃδｩ a via-crﾃδｺcis da famﾃδｭlia do professor de educaﾃδｧﾃδ｣o fﾃδｭsica Vitor Santos Oliveira</segment>
    <segment id="7">, 28 anos</segment>
    <segment id="8">, que havia desaparecido na ﾃδｺltima sexta-feira e foi encontrado morto dois dias depois pelos parentes</segment>
    <segment id="9">, no Instituto Mﾃδｩdico Legal (IML)</segment>
    <segment id="10">, em Salvador.</segment>
    <segment id="11">O corpo de Vﾃδｭtor Oliveira jﾃδ｡ estava no IML desde o dia anterior</segment>
    <segment id="12">, masmas nﾃδ｣o havia sido identificado</segment>
    <segment id="13">porque</segment>
    <segment id="14">porque foi encontrado queimado ao lado de uma moto no Assentamento Sﾃδ｣o Dominigos</segment>
    <segment id="15">, em Sﾃδ｣o Sebastiﾃδ｣o do Passﾃδｩ (Grande Salvador).</segment>
    <segment id="16">O professor estava na casa de uma tia</segment>
    <segment id="17">, no municﾃδｭpio de Dias Dﾃ｢竄ｬ邃｢</segment>
    <segment id="18">ﾃプila, e saiu na noite de sexta-feira dizendo que ia receber o dinheiro de uma dﾃδｭvida.</segment>
    <segment id="19">Na manhﾃδ｣ seguinte</segment>
    <segment id="20">, a famﾃδｭlia registrou queixa de desaparecimento na 25ﾃつｪ DT (Dias Dﾃ｢竄ｬ邃｢</segment>
    <segment id="21">ﾃプila)</segment>
    <segment id="22">.</segment>
    <segment id="23">De acordo com o delegado titular da 25ﾃつｪ DT</segment>
    <segment id="24">, Joﾃδ｣o Pithon</segment>
    <segment id="25">, Vﾃδｭtor estava em um posto de gasolina do municﾃδｭpio quando duas pessoas o levaram  em um carro e uma terceira saiu pilotando a moto.</segment>
    <segment id="26">ﾃ｢竄ｬﾅ鄭 investigaﾃδｧﾃδ｣o aponta para um acerto de contas.</segment>
    <segment id="27">Nﾃδ｣o posso passar mais detalhes para nﾃδ｣o atrapalhar o trabalhoﾃ｢竄ｬ</segment>
    <segment id="28">, explicou o delegado Joﾃδ｣o Pithon.</segment>
    <segment id="29">Ramon Souza dos Santos</segment>
    <segment id="30">, 24 anos</segment>
    <segment id="31">, irmﾃδ｣o de Vﾃδｭtor Oliveira</segment>
    <segment id="32">, afirma que apenas a descoberta e a prisﾃδ｣o dos assassinos poderﾃδ｡ confortar e amenizar a dor da famﾃδｭlia.</segment>
    <segment id="33">ﾃ｢竄ｬﾅ鄭 gente quer Justiﾃδｧa.</segment>
    <segment id="34">Eles nﾃδ｣o vﾃδ｣o pagar da forma que meu irmﾃδ｣o pagou.</segment>
    <segment id="35">Sﾃδ｣o monstros</segment>
    <segment id="36">, nﾃδ｣o podem ficar soltos para fazer o mesmo com outras pessoasﾃ｢竄ｬ</segment>
    <segment id="37">, declarou.</segment>
    <segment id="38">Um cara batalhador
Vﾃδｭtor era o mais velho entre quatro irmﾃδ｣os.</segment>
    <segment id="39">Ele deixou uma filha de 2 anos.</segment>
    <segment id="40">ﾃ｢竄ｬﾅ摘stou vendo a hora de minha mﾃδ｣e entrar em depressﾃδ｣o.</segment>
    <segment id="41">Ela vendeu uma casa de R$ 20 mil por R$ 10 mil para contratar um advogado para acompanhar o casoﾃ｢竄ｬ</segment>
    <segment id="42">, conta Reinaldo Oliveira</segment>
    <segment id="43">, 21, irmﾃδ｣o da vﾃδｭtima.</segment>
    <segment id="44">Vﾃδｭtor era professor de educaﾃδｧﾃδ｣o fﾃδｭsica em uma escola no municﾃδｭpio de Candeias (Grande Salvador).ﾃ｢竄ｬﾅ溺eu irmﾃδ｣o era um cara esforﾃδｧado</segment>
    <segment id="45">, batalhador.</segment>
    <segment id="46">Saiu de casa cedo.</segment>
    <segment id="47">Este ano</segment>
    <segment id="48">, ele passou no concurso de oficiais da Polﾃδｭcia Militar</segment>
    <segment id="49">, estava noivo e ia morar em Jequiﾃδｩ</segment>
    <segment id="50">, onde comprou um apartamento.</segment>
    <segment id="51">A noiva dele estﾃδ｡ arrasada tambﾃδｩmﾃ｢竄ｬ</segment>
    <segment id="52">, relata Ramon Souza.</segment>
    <segment id="53">O irmﾃδ｣o da vﾃδｭtima conta que uniﾃδ｣o da famﾃδｭlia estﾃδ｡ sendo fundamental para enfrentar a dor.</segment>
    <segment id="54">ﾃ｢竄ｬﾅ徹s</segment>
    <segment id="55">parentes estﾃδ｣o</segment>
    <segment id="56">sese amparando.</segment>
    <segment id="57">Nunca tinha perdido um familiar prﾃδｳximo.</segment>
    <segment id="58">Agora estou sentindo a dorﾃ｢竄ｬ</segment>
    <segment id="59">, lamenta Reinaldo.</segment>
  </rst>
