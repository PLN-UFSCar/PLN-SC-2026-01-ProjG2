    <segment id="23">, tambГѓВ©m foram importantes para garantir a vitГѓВіria de Dilma: 52</segment>
    <segment id="24">,41% dos votos</segment>
    <segment id="25">, contra 47</segment>
    <segment id="26">,59% do adversГѓВЎrio.</segment>
    <segment id="27">Na Bahia e em Pernambuco</segment>
    <segment id="28">, Dilma venceu com mais de 70%.</segment>
    <segment id="29">Em Salvador</segment>
