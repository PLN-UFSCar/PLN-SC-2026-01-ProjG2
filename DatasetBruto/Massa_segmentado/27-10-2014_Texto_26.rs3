    <segment id="37">ConheГѓВ§a o perfil da presidenta reeleita
Dilma Vana Rousseff tem 66 anos</segment>
    <segment id="38">, ГѓВ© divorciada</segment>
    <segment id="39">, e nasceu em Belo Horizonte.</segment>
    <segment id="40">Tem trГѓВЄs filhos e um neto.</segment>
    <segment id="41">Iniciou a militГѓВўncia polГѓВ­tica aos 16 anos.</segment>
    <segment id="42">Foi presa em plena ditadura militar</segment>
    <segment id="43">, em 1970.</segment>
    <segment id="44">Ficou detida por quase trГѓВЄs anos e submetida ГѓВ  tortura.</segment>
    <segment id="45">Ela saiu da prisГѓВЈo e mudou-</segment>
    <segment id="46">sese para Porto Alegre</segment>
    <segment id="47">, onde formou-</segment>
    <segment id="48">sese em Economia.</segment>
    <segment id="49">Na dГѓВ©cada de 80</segment>
    <segment id="50">, ela ajudou a fundar o PDT.</segment>
    <segment id="51">Somente ingressou no PT em 2001.</segment>
