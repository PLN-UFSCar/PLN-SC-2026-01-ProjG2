  <rst>
    <segment id="1">Mago do trânsito tem seus truques
Ideias de Sival</segment>
    <segment id="2">fazem todo sentido para a especialista Helena Spinelli</segment>
    <segment id="3">Quem precisa  passar pela avenida Paralela no início da manhã ou da noite já tem uma certeza: vai enfrentar intermináveis engarrafamentos.</segment>
    <segment id="4">Com o objetivo de colocar um ponto final na situação</segment>
    <segment id="5">, o rodoviário Sival  Patrocínio Souza</segment>
    <segment id="6">, 31,  que há oito anos trabalha</segment>
    <segment id="7">comocomo motorista de ônibus em Salvador</segment>
    <segment id="8">, elaborou um projeto  baseado em sua  batalha diária</segment>
    <segment id="9">, sugerindo pequenas intervenções emergenciais na via.</segment>
    <segment id="10">“</segment>
    <segment id="11">Só no sentido Paralela / Aeroporto existem 15 erros que</segment>
    <segment id="12">sese forem resolvidos</segment>
    <segment id="13">, acabarão com 50% dos engarrafamentos em pouco tempo”</segment>
    <segment id="14">, garante Sival.</segment>
    <segment id="15">Em uma de suas sugestões</segment>
    <segment id="16">, ele pretende  dividir alguns trechos da avenida com gelo baiano</segment>
    <segment id="17">, evitando  que os carros cruzem  de um lado a outro</segment>
    <segment id="18">, fazendo as famosas “tesouras”</segment>
    <segment id="19">, que atrasam o fluxo de veículos e provocam acidentes.</segment>
    <segment id="20">Para a arquiteta Helena Spinelli</segment>
    <segment id="21">, mestre  em planejamento  urbano</segment>
    <segment id="22">, as alterações propostas por Sival apresentam fundamentação técnica.</segment>
    <segment id="23">“Se elas forem implementadas</segment>
    <segment id="24">, os engarrafamentos diminuirão muito.</segment>
    <segment id="25">Acho que nos primeiros  dez dias</segment>
    <segment id="26">, vai ser um grande caos.</segment>
    <segment id="27">Mas depois</segment>
    <segment id="28">, com o tempo</segment>
    <segment id="29">, quando nos acostumarmos</segment>
    <segment id="30">, vai ser  mais tranquilo passar na Paralela”</segment>
    <segment id="31">, garante Helena Spinelli.</segment>
    <segment id="32">Mais ideias</segment>
    <segment id="33">Sival garante ter um projeto ideal e diz que as ações propostas agora têm  caráter emergencial.</segment>
    <segment id="34">Neste contexto</segment>
    <segment id="35">, ele  indica a reabertura e fechamento de  retornos</segment>
    <segment id="36">, mudanças de pequenos trechos</segment>
    <segment id="37">, alargamento das faixas de integração</segment>
    <segment id="38">, recuo de  pontos</segment>
    <segment id="39">, construção de pequenas estações horizontais de transbordo e a utilização de placas de sinalização e campanhas educativas alertando sobre as mudanças.</segment>
    <segment id="40">Sival também analisou e propõem alterações no transito na Av. Tancredo Neves</segment>
    <segment id="41">, na Estação Pirajá e  na  da região do Iguatemi.</segment>
    <segment id="42">Espera: MASSA!</segment>
    <segment id="43">vai ficar de olho</segment>
    <segment id="44">Segundo a Transalvador</segment>
    <segment id="45">, Sival  deve dar entrada no órgão</segment>
    <segment id="46">, no Vale do Barris</segment>
    <segment id="47">, e esperar que a Gerência de Projetos de Transporte (Gepro) e a Secretaria Municipal dos Transportes e Infraestrutura (Setin)  deem os seus pareceres.</segment>
    <segment id="48">“</segment>
    <segment id="49">Tenho medo de que seja engavetado.</segment>
    <segment id="50">Lamento</segment>
    <segment id="51">, pois</segment>
    <segment id="52">pois tenho certeza de que o projeto resolverá os problemas”.</segment>
  </rst>
</analysis>