  <rst>
    <segment id="1">Para colunista</segment>
    <segment id="2">, maior tarefa de Humala será conter 'mexicanização' do país
BUENOS AIRES - Desde sua vitória no segundo turno das eleições presidenciais</segment>
    <segment id="3">, a popularidade de Ollanta Humala recuou de 70% para 41% - culpa</segment>
    <segment id="4">, em grande parte</segment>
    <segment id="5">, de um escândalo de corrupção envolvendo um de seus irmãos.</segment>
    <segment id="6">Mas, para Mirko Lauer</segment>
    <segment id="7">, colunista do jornal "La República"</segment>
    <segment id="8">, os principais obstáculos do novo governante do Peru serão outros: combate ao narcotráfico</segment>
    <segment id="9">, contrabando</segment>
    <segment id="10">, crime organizado e demandas de movimentos indígenas e ecologistas.</segment>
    <segment id="11">O GLOBO:</segment>
    <segment id="12">Nas últimas semanas</segment>
    <segment id="13">, a popularidade de Humala despencou.</segment>
    <segment id="14">Seu primeiro desafio será recuperar parte do apoio perdido?</segment>
    <segment id="15">MIRKO LAUER:</segment>
    <segment id="16">Não.</segment>
    <segment id="17">Entendo que um jornalista brasileiro</segment>
    <segment id="18">sese preocupe por esses números</segment>
    <segment id="19">, masmas no</segment>
    <segment id="20">casocaso da política peruana a popularidade de um presidente é pouco importante.</segment>
    <segment id="21">Toledo governou com 10% de aprovação e o mundo não acabou.</segment>
    <segment id="22">Alan García (que está encerrando seus cinco anos de mandato) também teve entre 20% e 30% e permaneceu.</segment>
    <segment id="23">Humala vai assumir agora e ainda é cedo para saber qual será sua evolução.</segment>
    <segment id="24">Era mais fácil falar sobre Humala candidato.</segment>
    <segment id="25">O Humala presidente ainda nem começou.</segment>
    <segment id="26">Mas a queda em sua popularidade não é motivo de preocupação.</segment>
    <segment id="27">O GLOBO:</segment>
    <segment id="28">Como o senhor avalia o gabinete do novo presidente?</segment>
    <segment id="29">LAUER:</segment>
    <segment id="30">É uma espécie de clone do gabinete dos presidentes brasileiros Lula e Dilma Rousseff.</segment>
    <segment id="31">A direita controla a economia e promete produzir dinheiro que o governo espera poder usar em programas sociais.</segment>
    <segment id="32">Os ministros da área econômica são empresários</segment>
    <segment id="33">, homens claramente de direita.</segment>
    <segment id="34">Vemos um modelo inspirado no governo Lula.</segment>
    <segment id="35">O GLOBO:</segment>
    <segment id="36">A assessoria do PT continua atuando em Lima.

LAUER:</segment>
    <segment id="37">Sim, claro</segment>
    <segment id="38">, os homens do PT continuam assessorando o novo presidente.</segment>
    <segment id="39">Por informações que temos aqui em Lima</segment>
    <segment id="40">, Luis Favre está instalado no Peru e parece que tem atividade permanente no país.</segment>
    <segment id="41">O GLOBO:</segment>
    <segment id="42">Qual será</segment>
    <segment id="43">, então</segment>
    <segment id="44">, o principal desafio do novo governo?

LAUER:</segment>
    <segment id="45">Não podemos falar numa única meta.</segment>
    <segment id="46">Mas eu diria que alguns dos principais problemas que Humala enfrentará nos primeiros meses serão os protestos sociais</segment>
    <segment id="47">, o crime organizado</segment>
    <segment id="48">, o narcotráfico</segment>
    <segment id="49">, a crescente atividade mineradora informal e o contrabando.</segment>
    <segment id="50">Problemas que</segment>
    <segment id="51">, pouco a pouco</segment>
    <segment id="52">, estão "mexicanizando" o Peru.</segment>
    <segment id="53">O GLOBO:</segment>
    <segment id="54">De que setores surgem esses protestos sociais?

LAUER:</segment>
    <segment id="55">O Peru não tem máfias sindicais e novos pobres</segment>
    <segment id="56">, como</segment>
    <segment id="57">como a Argentina</segment>
    <segment id="58">, por exemplo.</segment>
    <segment id="59">Aqui temos protestos organizados por grupos ecologistas</segment>
    <segment id="60">, indígenas</segment>
    <segment id="61">, ou produtores que pedem aumento dos preços de seus produtos.</segment>
    <segment id="62">Muitos grupos estão crescendo e operam aliados com organizações internacionais dedicadas a promover a ecologia.</segment>
    <segment id="63">Suas manifestações são cada vez mais frequentes e eficientes.</segment>
    <segment id="64">García viveu momentos de muita tensão</segment>
    <segment id="65">, muitos protestos terminaram com policiais mortos.</segment>
  </rst>
</analysis>