  <rst>
    <segment id="1">Malandro tenta instalar ‘chupa-cabra’</segment>
    <segment id="2">Querubim foi preso em flagrante por tentativa de furto mediante fraude</segment>
    <segment id="3">Policiais da Delegacia Especial de Apoio ao Turismo (DEAT) prenderam</segment>
    <segment id="4">, no fim de semana</segment>
    <segment id="5">, Querubim Pupu da Silva Filho que tentava instalar um equipamento de clonagem de cartões de crédito</segment>
    <segment id="6">, conhecido</segment>
    <segment id="7">comocomo chupa-cabra</segment>
    <segment id="8">, em um banco da zona sul do Rio de Janeiro.</segment>
    <segment id="9">O acusado foi preso em flagrante.</segment>
