  <rst>
    <segment id="1">PM do mal: Abusou do próprio filho
Mãe da criança de três anos faz denúncia à polícia</segment>
    <segment id="2">, em Feira de Santana</segment>
    <segment id="3">Sob a suspeita de ter abusado sexualmente do filho de três anos</segment>
    <segment id="4">, o soldado da Polícia Militar Luciano Pereira dos Santos</segment>
    <segment id="5">, morador de Feira de Santana (a 108 km de Salvador)</segment>
    <segment id="6">, foi encaminhado para a Coordenadoria de Custódia Provisória do Batalhão de Choque</segment>
    <segment id="7">, em Lauro de Freitas (Grande Salvador)</segment>
    <segment id="8">, ontem.</segment>
    <segment id="9">De acordo com agentes da Delegacia para o Adolescente Infrator (DAI)</segment>
    <segment id="10">, a denúncia partiu da mãe da vítima.</segment>
    <segment id="11">Na quarta</segment>
    <segment id="12">, 16, ela teria percebido que o filho sentia um incômodo no bumbum</segment>
    <segment id="13">, provavelmente causado pelo dedo do agressor.</segment>
    <segment id="14">Segundo a mãe</segment>
    <segment id="15">, a informação teria partido da própria criança.</segment>
    <segment id="16">Sendo encaminhado à polícia</segment>
    <segment id="17">, poucas horas após o depoimento da mãe da vítima</segment>
    <segment id="18">, o pai da criança afirmou que ingeriu bebida alcoólica no dia do crime</segment>
    <segment id="19">, masmas considerou a impossibilidade de ter praticado o delito.</segment>
    <segment id="20">Conforme agentes da DAI</segment>
    <segment id="21">, o suspeito estava embriagado no momento da prisão.</segment>
    <segment id="22">Em depoimento à polícia</segment>
    <segment id="23">, a mãe da criança contou que o PM é alcoólatra.</segment>
    <segment id="24">Pai é alcoólatra</segment>
    <segment id="25">; abandonou tratamento</segment>
    <segment id="26">De acordo com o capitão Marcelo Pitta</segment>
    <segment id="27">, chefe de comunicação da PM</segment>
    <segment id="28">, o policial</segment>
    <segment id="29">, que é lotado na 6ª Companhia Independente de Polícia Militar (Rio Real)</segment>
    <segment id="30">, permanecerá na Custódia Provisória do Batalhão de Choque</segment>
    <segment id="31">, em Lauro de Freitas</segment>
    <segment id="32">, até a conclusão dos trabalhos de investigação.</segment>
    <segment id="33">Há seis meses</segment>
    <segment id="34">, o PM abandonou o tratamento contra o alcoolismo.</segment>
  </rst>
</analysis>