  <rst>
    <segment id="1">Joel Santana é o novo técnico do Bahia</segment>
    <segment id="2">O treinador deve desembarcar em terras baianas na próxima terça-feira</segment>
    <segment id="3">As especulações mais recentes sobre a contratação de um novo treinador para o Bahia</segment>
    <segment id="4">, após a saída de René Simões</segment>
    <segment id="5">, foram confirmadas.</segment>
    <segment id="6">O empresário do técnico Joel Santana</segment>
    <segment id="7">, Léo Rabello</segment>
    <segment id="8">, afirmou na tarde deste domingo (4)</segment>
    <segment id="9">, que o carioca será o novo comandante do time.</segment>
    <segment id="10">O treinador deve desembarcar em terras baianas na próxima terça-feira (6)</segment>
    <segment id="11">, quando assinará o contrato.</segment>
    <segment id="12">Joel Santana já é bastante conhecido pela torcida baiana.</segment>
    <segment id="13">Em 1994 e em 1999</segment>
    <segment id="14">, ele assumiu o comando do time e</segment>
    <segment id="15">, em ambas as oportunidades</segment>
    <segment id="16">, levou o time à taça do Campeonato Baiano.</segment>
    <segment id="17">Entretanto</segment>
    <segment id="18">, a relação do treinador com a torcida baiana nem sempre foi a melhor.</segment>
    <segment id="19">Ainda este ano</segment>
    <segment id="20">, quando deixou o Botafogo e a sua contratação pelo Bahia foi especulada</segment>
    <segment id="21">, Joel gerou polêmica ao afirmar que queria treinar um peixe grande</segment>
    <segment id="22">, não uma sardinha.</segment>
    <segment id="23">O técnico afirmou que foi mal interpretado e que tem grande admiração pelo time baiano.</segment>
    <segment id="24">Último Clube
Joel Santana foi dispensado do Cruzeiro na última quinta-feira (1)</segment>
    <segment id="25">, após o time ter sido derrotado pelo Figueirense por 4 a 2</segment>
    <segment id="26">, em Ipatinga</segment>
    <segment id="27">, no dia anterior.</segment>
    <segment id="28">O novo comandante do Cruzeiro é Emerson Ávila</segment>
    <segment id="29">, coordenador técnico das categorias de base do clube.</segment>
  </rst>
