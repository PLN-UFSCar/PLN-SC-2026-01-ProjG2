  <rst>
    <segment id="1">Restaurante no térreo de prédio onde houve explosão atendia trabalhadores e hóspedes de hotéis vizinhos
RIO - O Riqueza</segment>
    <segment id="2">, na Praça Tiradentes 9</segment>
    <segment id="3">, é um edifício comercial e residencial com 12 andares</segment>
    <segment id="4">, mais subsolo.</segment>
    <segment id="5">No térreo funcionavam o Filé Carioca</segment>
    <segment id="6">, a sorveteria Yofruts</segment>
    <segment id="7">, uma lan house e uma loja de discos antigos.</segment>
    <segment id="8">Todos os estabelecimentos viraram escombros depois da explosão.</segment>
    <segment id="9">A sobreloja</segment>
    <segment id="10">, também atingida</segment>
    <segment id="11">, era ocupada por salões de beleza e por uma loja de informática.</segment>
    <segment id="12">O restante do prédio é formado por escritórios</segment>
    <segment id="13">, como</segment>
    <segment id="14">como o da figurinista Fátima Cherem.</segment>
    <segment id="15">Fátima tinha uma empresa de produções artísticas no quarto andar há mais de 20 anos.</segment>
    <segment id="16">Ela disse que nunca presenciou um acidente no prédio nem nunca chegou a sentir cheiro de gás.</segment>
    <segment id="17">Como o escritório funcionava das 10h às 17h</segment>
    <segment id="18">, ela não estava no local na hora da explosão.

-</segment>
    <segment id="19">Olhei o prédio pelos fundos</segment>
    <segment id="20">, que dá para a janela do escritório</segment>
    <segment id="21">, e vi (no térreo) um grande buraco.</segment>
    <segment id="22">Não sei o que vou fazer agora - disse a empresária</segment>
    <segment id="23">, que se</segment>
    <segment id="24">se preparava para iniciar produções de Natal.

Márcia Saraiva</segment>
    <segment id="25">, que há dois anos montou a Yofruts</segment>
    <segment id="26">, disse que a sua loja não tinha seguro.</segment>
    <segment id="27">Ela chegou às 8h para abrir a sorveteria e encontrou tudo destruído.</segment>
    <segment id="28">O prejuízo</segment>
    <segment id="29">, segundo a empresária</segment>
    <segment id="30">, deve chegar aos R$ 400 mil.</segment>
    <segment id="31">O Filé Carioca era um restaurante a quilo com grande variedade</segment>
    <segment id="32">, inclusive oriental</segment>
    <segment id="33">, usado de dia por trabalhadores da região e hóspedes do hotel Ibis Formule 1.</segment>
    <segment id="34">À noite</segment>
    <segment id="35">, funcionava no sistema à la carte.</segment>
    <segment id="36">A casa tinha um bar que funcionava até as 23h e um salão de festas no subsolo.</segment>
    <segment id="37">O Edifício Riqueza também é ocupado por moradores de classe média que vivenciaram um período de degradação da Praça Tiradentes.</segment>
    <segment id="38">A restauração do entorno e a frequente movimentação de pessoas à noite</segment>
    <segment id="39">, com a recente notoriedade de casas de shows</segment>
    <segment id="40">comocomo o Centro Cultural Carioca e o Espaço Acústica</segment>
    <segment id="41">, também era bem vista pelos moradores.</segment>
    <segment id="42">Da mesma forma</segment>
    <segment id="43">, as produções dos teatros</segment>
    <segment id="44">Carlos Gomes e João Caetano - este</segment>
    <segment id="45">, reformado recentemente - prometiam revitalizar a região</segment>
    <segment id="46">, ainda dormitório de moradores de rua.</segment>
  </rst>
</analysis>