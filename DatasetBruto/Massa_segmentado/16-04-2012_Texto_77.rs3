  <rst>
    <segment id="1">Um pedal aqui</segment>
    <segment id="2">, uma música acolá</segment>
    <segment id="3">Comerciante usa bike para vender de tudo</segment>
    <segment id="4">, inclusive seus próprios CDs independentes
Quem disse que camelô só vende?</segment>
    <segment id="5">Benedito Bento</segment>
    <segment id="6">, ou melhor Bener Mil</segment>
    <segment id="7">,  entre uma pedalada  e outra</segment>
    <segment id="8">, vende os mais diversos objetos e aproveita para anunciar seu próprio CD - uma produção independente - para a galera .</segment>
    <segment id="9">O cantor ambulante conta que a paixão pela música nasceu em 1993</segment>
    <segment id="10">,  quando</segment>
    <segment id="11">, em uma brincadeira entre amigos</segment>
    <segment id="12">, começou a  participar dos shows da banda de pagode Bliss</segment>
    <segment id="13">, no bar da Chota</segment>
    <segment id="14">, que fica no Alto do Cangira</segment>
    <segment id="15">,  na Vasco da Gama.</segment>
    <segment id="16">Desde então</segment>
    <segment id="17">, sese empolgou e compôs cerca de 100 músicas.</segment>
    <segment id="18">Parte delas estão nos  seis CDs gravados.</segment>
    <segment id="19">De porta em porta e com boa lábia de vendedor</segment>
    <segment id="20">,  já conseguiu vender quase mil cópias.</segment>
    <segment id="21">Atualmente</segment>
    <segment id="22">, Bener Mil está com  o CD  de trabalho</segment>
    <segment id="23">“Bener Mil</segment>
    <segment id="24">, no Arrocha”</segment>
    <segment id="25">, recheado de canções  para dançar agarradinho.</segment>
    <segment id="26">Destaque para a  música de trabalho</segment>
    <segment id="27">“Thaca Thaca na Muthaca”.</segment>
    <segment id="28">O músico revela que já cantou no Idearium</segment>
    <segment id="29">, no Rio Vermelho</segment>
    <segment id="30">, e em evento no Centro de Convenções e</segment>
    <segment id="31">, agora</segment>
    <segment id="32">, sese prepara para shows agendados fora do estado.</segment>
    <segment id="33">No dia 10 de julho</segment>
    <segment id="34">, parte para Luiz Correia</segment>
    <segment id="35">, no Piauí</segment>
    <segment id="36">, para fazer a galera arrochar ao som de seus maiores sucessos</segment>
    <segment id="37">, como</segment>
    <segment id="38">como “Forró do Mingau” e “Beijo na Bochecha”.</segment>
    <segment id="39">Onde encontrá-lo

Bener Mil é conhecido nos bairros de Santa Cruz</segment>
    <segment id="40">, Vale das Pedrinhas</segment>
    <segment id="41">, Garibaldi e Federação por percorrê-los com uma inusitada bicicleta.</segment>
    <segment id="42">Com adaptações  feitas pelo próprio Bener</segment>
    <segment id="43">, leva as mais diversas bugigangas.</segment>
    <segment id="44">De guarda-chuvas a calcinhas</segment>
    <segment id="45">, tem de tudo.</segment>
    <segment id="46">Bener conta que começou com uma malinha</segment>
    <segment id="47">, de porta em porta</segment>
    <segment id="48">, vendendo artigos de costura.</segment>
    <segment id="49">O boca a boca ajudou a clientela a crescer</segment>
    <segment id="50">, assim</segment>
    <segment id="51">comocomo a necessidade de ampliar a variedade de produtos.</segment>
    <segment id="52">Hoje, sua bike carrega mais de 30 itens.</segment>
    <segment id="53">Trabalhando e cantando</segment>
    <segment id="54">, surgiu Bener Mil</segment>
    <segment id="55">, que mantém sua família e produz seus CDs com o comércio informal.</segment>
    <segment id="56">Mas ele quer mais e pretende realizar seu mais recente sonho: participar do programa Raul Gil.</segment>
    <segment id="57">Alguém duvida de que ele vai chegar lá?</segment>
  </rst>
</analysis>