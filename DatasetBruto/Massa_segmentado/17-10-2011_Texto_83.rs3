  <rst>
    <segment id="1">Esquadrão arranca ponto de aço precioso</segment>
    <segment id="2">Bahia aumentou para seis pontos a distância da zona de rebaixamento</segment>
    <segment id="3">A 30ª rodada não poderia ser melhor para o Bahia.</segment>
    <segment id="4">Além das derrotas de América-MG</segment>
    <segment id="5">, Avaí</segment>
    <segment id="6">, Atlético-PR</segment>
    <segment id="7">, Atlético-MG</segment>
    <segment id="8">, Cruzeiro e Ceará - times que estão nas últimas posições do Brasileiro -</segment>
    <segment id="9">, com o empate em 0 a 0 de ontem</segment>
    <segment id="10">, diante do Coritiba</segment>
    <segment id="11">, no Couto Pereira</segment>
    <segment id="12">, o Esquadrão  conquistou um ponto precioso na luta para não cair à Série B.</segment>
    <segment id="13">Com o resultado</segment>
    <segment id="14">, a equipe de Joel Santana chegou aos 36 pontos e</segment>
    <segment id="15">sese manteve na 14ª colocação</segment>
    <segment id="16">, seis pontos à frente do 17º colocado</segment>
    <segment id="17">, o Atlético-MG</segment>
    <segment id="18">, primeiro clube da zona de rebaixamento.</segment>
    <segment id="19">Quando a bola rolou na etapa inicial</segment>
    <segment id="20">, o Bahia conseguiu segurar o ataque do Coxa e teve duas grandes chances de gol.</segment>
    <segment id="21">Na primeira</segment>
    <segment id="22">, Dodô invadiu a área pela esquerda</segment>
    <segment id="23">, masmas Vanderlei evitou o gol no chute do lateral.</segment>
    <segment id="24">A segunda foi com Fahel</segment>
    <segment id="25">, que aproveitou rebote em escanteio e mandou para o gol</segment>
    <segment id="26">, masmas o volante Gil salvou em cima da linha.</segment>
    <segment id="27">No segundo tempo</segment>
    <segment id="28">, o Coritiba teve boas oportunidades</segment>
    <segment id="29">, masmas parou nas mãos de Marcelo Lomba.</segment>
    <segment id="30">Dodô ainda teve outra chance</segment>
    <segment id="31">, masmas seu chute de primeira parou em Vanderlei.</segment>
    <segment id="32">Agora, o tricolor tem uma semana de preparação para sagrar-</segment>
    <segment id="33">sese ‘campeão carioca’ diante do Vasco</segment>
    <segment id="34">, no próximo domingo</segment>
    <segment id="35">, em Pituaçu.</segment>
  </rst>
</analysis>