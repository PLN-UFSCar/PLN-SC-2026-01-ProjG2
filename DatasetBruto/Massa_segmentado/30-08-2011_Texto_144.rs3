  <rst>
    <segment id="1">Desarmar líbios será desafio no pós-guerra
TRÍPOLI - Três horas da manhã.</segment>
    <segment id="2">Um barulho infernal de estampidos ecoou por toda a cidade.</segment>
    <segment id="3">Não fosse Trípoli a capital de uma Líbia ainda em ritmo de guerra</segment>
    <segment id="4">, poderia-</segment>
    <segment id="5">sese dizer que</segment>
    <segment id="6">sese estava na praia de Copacabana</segment>
    <segment id="7">, na virada do Ano Novo</segment>
    <segment id="8">, tamanho os estrondos.</segment>
    <segment id="9">Mas, não</segment>
    <segment id="10">, eram líbios</segment>
    <segment id="11">sese divertindo</segment>
    <segment id="12">, dando tiros para o alto</segment>
    <segment id="13">, usando até artilharia antiaérea.</segment>
    <segment id="14">Ao ponto de um enorme cartaz ter sido erguido na praça central com a ordem:</segment>
    <segment id="15">"Não atirem para o alto!</segment>
    <segment id="16">"</segment>
    <segment id="17">Trípoli</segment>
    <segment id="18">sese livrou do regime de Muamar Kadafi</segment>
    <segment id="19">, masmas não de suas armas: a população está armada até os dentes.</segment>
    <segment id="20">E o pós-guerra já</segment>
    <segment id="21">sese anuncia complicado</segment>
    <segment id="22">, com uma questão espinhosa para o governo de transição:</segment>
    <segment id="23">quando e</segment>
    <segment id="24">comocomo desamar um povo que</segment>
    <segment id="25">, de uma hora para outra</segment>
    <segment id="26">, sese autoproclamou herói e soldado?

ENTREVISTA: 'Só é preciso uma faísca</segment>
    <segment id="27">para que</segment>
    <segment id="28">para que o povo volte às ruas'</segment>
    <segment id="29">, analisa escritor argelino

CONTRAMÃO:</segment>
    <segment id="30">Apoio a Kadafi isola Argélia no Norte da África

SEM EXÍLIO:</segment>
    <segment id="31">Argélia entregará Kadafi</segment>
    <segment id="32">sese ditador também fugir para o país</segment>
    <segment id="33">, diz jornal 

LÍBIA:</segment>
    <segment id="34">Imigrantes negros enfrentam risco de prisão e morte sob acusação de apoiarem Kadafi

AISHA:</segment>
    <segment id="35">Filha de Kadafi dá à luz após fugir para Argélia</segment>
    <segment id="36">Nasser Edin</segment>
    <segment id="37">, 30 anos</segment>
    <segment id="38">, é um exemplo.</segment>
    <segment id="39">Ele trabalhava verificando passageiros no aeroporto de Trípoli.</segment>
    <segment id="40">E garante que nunca tinha apertado o gatilho de uma arma até o conflito estourar.</segment>
    <segment id="41">Agora, circula com um Kalashnikov pelo centro da capital</segment>
    <segment id="42">, verificando carros</segment>
    <segment id="43">comocomo</segment>
    <segment id="44">sese fosse um policial.</segment>
    <segment id="45">Ninguém questiona: rebelde aqui</segment>
    <segment id="46">, agora manda.</segment>
    <segment id="47">Edin comprou a arma no novo mercado negro de Trípoli</segment>
    <segment id="48">, por 3 mil dinares (pouco mais de US$ 1.500)</segment>
    <segment id="49">, antes mesmo de os rebeldes tomarem a capital.

- Comprei para me proteger.</segment>
    <segment id="50">Mantinha escondida atrás do armário.</segment>
    <segment id="51">Ninguém sabia que eu tinha - conta.</segment>
    <segment id="52">Americanos temem que terroristas tenham acesso</segment>
    <segment id="53">Como em toda a guerra</segment>
    <segment id="54">, não tardou em florescer o mercado clandestino de armas</segment>
    <segment id="55">, na maioria retiradas ou roubadas dos quartéis de Kadafi conquistados pelos rebeldes.</segment>
    <segment id="56">Na Líbia inteira as armas estão circulando</segment>
    <segment id="57">, sem controle.</segment>
    <segment id="58">Edin garante que vai entregar a arma ao novo governo.</segment>
    <segment id="59">Mas sob uma condição:

- Só quando acharem Kadafi - diz.</segment>
    <segment id="60">Circulando com ele estava Mustafa Mabrouk</segment>
    <segment id="61">, 29 anos.</segment>
    <segment id="62">Antes da guerra</segment>
    <segment id="63">, ele vendia joias.</segment>
    <segment id="64">Agora, o ouro está escondido e ele policia as ruas</segment>
    <segment id="65">, também com um Kalashnikov - a arma mais usada hoje na Líbia.

- Liberdade tem o seu preço.</segment>
    <segment id="66">Um deles</segment>
    <segment id="67">, é esse - diz</segment>
    <segment id="68">, justificando a quantidade de pessoas armadas nas ruas.</segment>
    <segment id="69">Alguns</segment>
    <segment id="70">, como</segment>
    <segment id="71">como Imad Tapti</segment>
    <segment id="72">, 35 anos</segment>
    <segment id="73">, que vendia roupas e hoje também patrulha o centro de Trípoli</segment>
    <segment id="74">, sese dão conta do perigo.

- Em qualquer lugar do mundo</segment>
    <segment id="75">, uma população armada é perigosa.</segment>
    <segment id="76">Acho que vai ser difícil coletar as armas aqui.</segment>
    <segment id="77">Tem gente com arma em casa</segment>
    <segment id="78">, e que não vai dizer que tem - afirma.</segment>
    <segment id="79">Aiman Sultan</segment>
    <segment id="80">, 28 anos</segment>
    <segment id="81">, era um policial especializado no combate às drogas</segment>
    <segment id="82">, que também são vendidas sem problemas pela cidade desde os tempos de Kadafi.</segment>
    <segment id="83">Hoje, armado</segment>
    <segment id="84">, integra um conselho de um bairro em Trípoli e diz que comunidades estão</segment>
    <segment id="85">sese organizando para anotar o número das armas.

- Estamos coletando as armas - garante.</segment>
    <segment id="86">-</segment>
    <segment id="87">Vemos o que acontece nos Estados Unidos</segment>
    <segment id="88">, a violência por causa das armas.</segment>
    <segment id="89">E não queremos que isso aconteça com a gente.</segment>
    <segment id="90">Seu discurso é praticamente desmentido por um membro do Conselho Nacional de Transição</segment>
    <segment id="91">, Abdallah Gzema</segment>
    <segment id="92">, professor universitário de Zawiya.</segment>
    <segment id="93">Ele diz que a coleta de armas não começou e nem é prioridade agora</segment>
    <segment id="94">, porque</segment>
    <segment id="95">porque "a libertação da Líbia ainda não esta completa".

- Isso só vai acontecer quando libertarmos todo o país.</segment>
    <segment id="96">As armas não são um problema para os líbios.</segment>
    <segment id="97">Eles querem armas para</segment>
    <segment id="98">sese libertarem</segment>
    <segment id="99">, e não para lutar entre si - disse.</segment>
    <segment id="100">A proliferação de armas</segment>
    <segment id="101">, entretanto</segment>
    <segment id="102">, preocupa europeus</segment>
    <segment id="103">, americanos e a Organização do Tratado do Atlântico Norte (Otan).</segment>
    <segment id="104">Os americanos</segment>
    <segment id="105">, em especial</segment>
    <segment id="106">, temem que mísseis antiaéreos do regime acabem nas mãos de terroristas.</segment>
    <segment id="107">Em novembro de 2002</segment>
    <segment id="108">, por exemplo</segment>
    <segment id="109">, militantes da al-Qaeda lançaram dois mísseis contra um avião da companhia israelense El Al Airlines</segment>
    <segment id="110">, logo depois da decolagem de Mombasa</segment>
    <segment id="111">, no Quênia.</segment>
    <segment id="112">Não acertaram por pouco.</segment>
  </rst>
</analysis>