  <rst>
    <segment id="1">Presos assassinos do ‘bom velhinho’
Vizinhos de aposentado que</segment>
    <segment id="2">sese vestia de Papai Noel no Natal queimaram a vítima</segment>
    <segment id="3">O aposentado Renato Pereira de Santana</segment>
    <segment id="4">, 82 anos</segment>
    <segment id="5">, passava os últimos dias de sua vida morando sozinho em uma casa às margens da BA 093</segment>
    <segment id="6">, no trecho que passa por Dias D’Ávila (Grande Salvador)</segment>
    <segment id="7">, criando galinhas.</segment>
    <segment id="8">No Natal</segment>
    <segment id="9">, sese vestia de Papai Noel e distribuía presentes para as crianças.</segment>
    <segment id="10">Mas, no último dia 6 de março</segment>
    <segment id="11">, ele foi vítima da ganância e crueldade de três vizinhos.

Ana Maria Santana dos Santos</segment>
    <segment id="12">, 44, a Ana “Rasta”</segment>
    <segment id="13">, Paulo Lobato Filho</segment>
    <segment id="14">, 25, o Paulinho</segment>
    <segment id="15">, e Antônio Geraldo da Silva</segment>
    <segment id="16">, 55, o Sete Oito</segment>
    <segment id="17">,  invadiram a casa do aposentado um dia depois de ele receber a aposentadoria para roubá-lo.

Ana e Paulo foram presos na última segunda-feira e apresentados ontem à imprensa na 25ª Delegacia Territorial (Dias D’Ávila).</segment>
    <segment id="18">Geraldo ainda está foragido.</segment>
    <segment id="19">O trio invadiu a casa durante a madrugada para realizar o roubo</segment>
    <segment id="20">, masmas encontraram o aposentado  acordado.</segment>
    <segment id="21">Paulo foi o responsável por desferir três pauladas na cabeça da vítima para iniciar o saque à vontade.</segment>
    <segment id="22">De acordo com o coordenador do Serviço de Investigação da 25ª DT</segment>
    <segment id="23">, Edmundo Carvalho Júnior</segment>
    <segment id="24">, o trio roubou a casa e depois decidiu voltar para atear fogo.</segment>
    <segment id="25">“Foi Ana quem deu a ideia de queimar o imóvel com o aposentado dentro para a perícia não encontrar as impressões digitais”</segment>
    <segment id="26">, afirma.</segment>
    <segment id="27">“Atribulação da mente”</segment>
    <segment id="28">Paulo disse que não pensava em matar o aposentado.</segment>
    <segment id="29">“</segment>
    <segment id="30">Foi coisa de momento.</segment>
    <segment id="31">Atribulação da mente.</segment>
    <segment id="32">Estava alcoolizado”</segment>
    <segment id="33">, revela.

Ana ‘Rasta’ defende-</segment>
    <segment id="34">sese dizendo que só comprou os produtos roubados.</segment>
    <segment id="35">“</segment>
    <segment id="36">Tenho minha consciência limpa que não matei ninguém.</segment>
    <segment id="37">Só comprei as coisas”</segment>
    <segment id="38">, declara.</segment>
    <segment id="39">Mas Paulo confessou o crime e contou</segment>
    <segment id="40">comocomo os três planejaram o assalto.</segment>
    <segment id="41">Até o violão</segment>
    <segment id="42">Além de R$ 80</segment>
    <segment id="43">, os bandidos levaram da casa do aposentado um botijão de gás</segment>
    <segment id="44">, aparelho de DVD</segment>
    <segment id="45">, uma espingarda</segment>
    <segment id="46">, conjunto de panelas</segment>
    <segment id="47">, dois facões</segment>
    <segment id="48">, uma roçadeira e um violão.</segment>
  </rst>
</analysis>