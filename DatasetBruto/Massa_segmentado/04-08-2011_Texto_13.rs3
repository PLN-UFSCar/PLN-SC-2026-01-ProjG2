  <rst>
    <segment id="1">Carta já estava fora do baralho
Mãe fica furiosa ao ver foto do filho</segment>
    <segment id="2">, morto em junho</segment>
    <segment id="3">, como</segment>
    <segment id="4">como um dos procurados da SSP</segment>
    <segment id="5">Familiares de Cleidson Souza dos Santos</segment>
    <segment id="6">, 23 anos</segment>
    <segment id="7">, ficaram revoltados ontem com a Secretaria de Segurança Pública (SSP)</segment>
    <segment id="8">, após o órgão divulgar para toda a imprensa que o rapaz era um dos mais novos integrantes do baralho do crime</segment>
    <segment id="9">, que contém os nomes e as fotos dos bandidos mais procurados da Bahia.</segment>
    <segment id="10">A revolta da família é por um único motivo:</segment>
    <segment id="11">Cleidson já está morto.</segment>
    <segment id="12">Ele foi assassinado a tiros no dia 28 de junho</segment>
    <segment id="13">, na  Jaqueira do Carneiro.</segment>
    <segment id="14">“Fiquei bastante chateada.</segment>
    <segment id="15">Meu filho já morreu há mais de um mês e colocaram foto dele em todos os jornais</segment>
    <segment id="16">,  televisão</segment>
    <segment id="17">, internet</segment>
    <segment id="18">, como</segment>
    <segment id="19">como se</segment>
    <segment id="20">se ele fosse procurado.</segment>
    <segment id="21">Hoje foi um transtorno.</segment>
    <segment id="22">Muita gente me ligando.</segment>
    <segment id="23">Tenho pressão alta</segment>
    <segment id="24">, fiquei nervosa quando vi.</segment>
    <segment id="25">Prejudicou a nossa reputação.</segment>
    <segment id="26">Ele tem um filho de seis anos”</segment>
    <segment id="27">, desabafou a mãe de Cleidson.</segment>
    <segment id="28">Polícia confirma o erro: SSP esclarece</segment>
    <segment id="29">Em nota enviada pela assessoria de comunicação da SSP</segment>
    <segment id="30">, a coordenadora do serviço Disque-Denúncia</segment>
    <segment id="31">, Dayse Dantas</segment>
    <segment id="32">, explicou o que causou o erro no baralho.</segment>
    <segment id="33">“A identificação e seleção dos bandidos mais procurados é complexa.</segment>
    <segment id="34">Além da categorização dos crimes e da confirmação dos mandados de prisão em aberto</segment>
    <segment id="35">, ainda temos que aguardar a confecção das cartas e a divulgação no site.</segment>
    <segment id="36">Durante esse processo</segment>
    <segment id="37">, o Dez de Espadas (Cleidson) morreu”.</segment>
    <segment id="38">Teve medo:</segment>
    <segment id="39">Márcio Coroa</segment>
    <segment id="40">sese entregou

Dayse Dantas</segment>
    <segment id="41">, coordenadora do Disque-Denúncia</segment>
    <segment id="42">,</segment>
    <segment id="43">disse que Cleidson deu entrada no IML</segment>
    <segment id="44">comocomo indigente</segment>
    <segment id="45">, “sendo necessária a realização do exame datiloscópico</segment>
    <segment id="46">, no Departamento de Polícia Técnica</segment>
    <segment id="47">, para identificá-lo</segment>
    <segment id="48">, o que demora cerca de 30 dias”.</segment>
    <segment id="49">Ontem, Márcio Oliveira da Silva</segment>
    <segment id="50">, o “Márcio Coroa”</segment>
    <segment id="51">, Três de Ouros do Baralho</segment>
    <segment id="52">, sese apresentou a uma guarnição do Batalhão de Guardas da Polícia Militar e foi encaminhado à DTE.</segment>
    <segment id="53">Coroa disse aos agentes que ficou com medo ao saber</segment>
    <segment id="54">, pelos jornais</segment>
    <segment id="55">, que era um  bandidos mais procurados.</segment>
    <segment id="56">Ele cumpria pena por roubo</segment>
    <segment id="57">, saiu do presídio em 2007</segment>
    <segment id="58">, e não retornou.</segment>
  </rst>
</analysis>