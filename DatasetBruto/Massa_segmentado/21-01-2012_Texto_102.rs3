  <rst>
    <segment id="1">Mostrar na tela?</segment>
    <segment id="2">Nem por 1 milhão
Hazel Jones</segment>
    <segment id="3">, que tem duas vaginas</segment>
    <segment id="4">, recusou proposta milionária para filme pornô</segment>
    <segment id="5">Os marmanjos já estavam ansiosos para ver  Hazel Jones e suas duas periquitas em ação.</segment>
    <segment id="6">Então, a britânica de 27 anos</segment>
    <segment id="7">, que ficou famosa por ter duas vaginas</segment>
    <segment id="8">,  foi convidada por uma das maiores produtoras pornô dos Estados Unidos</segment>
    <segment id="9">, a Vivid Entertainment</segment>
    <segment id="10">, para estrelar um filme.</segment>
    <segment id="11">Era questão de tempo.</segment>
    <segment id="12">A proposta de um milhão de dólares (mais de um milhão e meio de reais) parecia excelente</segment>
    <segment id="13">, masmas não para Hazel</segment>
    <segment id="14">, que recusou.</segment>
    <segment id="15">“Eu nunca havia recebido ofertas desse tipo e eu nunca consideraria fazer isso nem em um milhão de anos.</segment>
    <segment id="16">Eu apenas quero ser deixada em paz”</segment>
    <segment id="17">, contou Hazel</segment>
    <segment id="18">, que havia feito fotos   para revistas masculinas</segment>
    <segment id="19">,  mas</segment>
    <segment id="20">mas sem mostrar as vaginas.</segment>
    <segment id="21">Steven Hirsch</segment>
    <segment id="22">, dono da produtora</segment>
    <segment id="23">, valorizou</segment>
    <segment id="24">Hazel no convite.</segment>
    <segment id="25">“</segment>
    <segment id="26">Você é uma pessoa extraordinária e eu gostaria de lhe fazer uma proposta para estrelar uma de nossas produções.</segment>
    <segment id="27">Nós pagaríamos até US$ 1 milhão pelos seus serviços”.</segment>
    <segment id="28">Deformação curiosa

Hazel Jones sofre de uma condição rara conhecida</segment>
    <segment id="29">comocomo útero didelfo.</segment>
    <segment id="30">Além de possuir dois úteros</segment>
    <segment id="31">, a inglesa também tem duas vaginas.</segment>
    <segment id="32">Hazel foi diagnosticada quando tinha 18 anos.</segment>
    <segment id="33">Porém, ela não sofre com a situação.</segment>
    <segment id="34">A moça</segment>
    <segment id="35">, que perdeu a virgindade duas vezes</segment>
    <segment id="36">, diz ser muito feliz.</segment>
