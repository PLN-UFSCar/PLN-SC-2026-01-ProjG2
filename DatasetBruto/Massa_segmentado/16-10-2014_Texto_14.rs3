  <rst>
    <segment id="1">Sete PMs s횄짙o suspeitos de executar trio</segment>
    <segment id="2">Dois rapazes tombaram em troca de tiros com os policiais.</segment>
    <segment id="3">A m횄짙e de um deles 'sumiu'</segment>
    <segment id="4">Os sete policiais militares do 14횂쨘 Batalh횄짙o de Pol횄짯cia Militar (Santo Ant횄쨈nio de Jesus) suspeitos de envolvimento nos assassinatos de F횄징bio Jos횄짤 dos Santos</segment>
    <segment id="5">, 33 anos</segment>
    <segment id="6">, de Crispim de Jesus Santos</segment>
    <segment id="7">, 23, e da m횄짙e dele</segment>
    <segment id="8">, Maria de Lourdes de Jesus Santos</segment>
    <segment id="9">, 47, foram transferidos</segment>
    <segment id="10">, na manh횄짙 de ontem</segment>
    <segment id="11">, para o Batalh횄짙o de Choque da Pol횄짯cia Militar</segment>
    <segment id="12">, em Lauro de Freitas.</segment>
    <segment id="13">F횄징bio era companheiro da senhora.</segment>
    <segment id="14">Eles foram presos em cumprimento de mandados de pris횄쨉es tempor횄징rias decretados por uma comiss횄짙o formada pela Corregedoria Geral da PM para investigar o</segment>
    <segment id="15">casocaso.</segment>
    <segment id="16">Eles ficar횄짙o detidos at횄짤 a conclus횄짙o do Inqu횄짤rito Policial Militar (IPM).</segment>
    <segment id="17">Conforme o tenente-coronel Luziel Andrade</segment>
    <segment id="18">, comandante do batalh횄짙o</segment>
    <segment id="19">, os rapazes foram mortos durante troca de tiros com os PMs</segment>
    <segment id="20">, na manh횄짙 do domingo (05).</segment>
    <segment id="21">No mesmo dia</segment>
    <segment id="22">, a senhora desapareceu.</segment>
    <segment id="23">Ainda segundo ele</segment>
    <segment id="24">, na manh횄짙 do domingo</segment>
    <segment id="25">, quando soube das mortes de F횄징bio e de Crispim e do desaparecimento de Maria de Lourdes</segment>
    <segment id="26">, os PMs come횄짠aram a ser investigados.</segment>
    <segment id="27">A susposta troca de tiro foi na madrugada do dia 5 e</segment>
    <segment id="28">, pela manh횄짙</segment>
    <segment id="29">, quando soubemos dos fatos</segment>
    <segment id="30">, come횄짠amos as oitivas.</segment>
    <segment id="31">Na segunda</segment>
    <segment id="32">, informamos 횄혻 Corregedoria e ela criou uma comiss횄짙o para investigar</segment>
    <segment id="33">, revelou Andrade.</segment>
    <segment id="34">Popula횄짠횄짙o deu o canal</segment>
    <segment id="35">O comandante revelou que a pr횄쨀pria popula횄짠횄짙o deu informa횄짠횄쨉es sobre os crimes.</segment>
    <segment id="36">Tinhamos a informa횄짠횄짙o de que foi apenas uma viatura</segment>
    <segment id="37">, masmas a popula횄짠횄짙o disse que foram duas guarni횄짠횄쨉es</segment>
    <segment id="38">, declarou ele.</segment>
    <segment id="39">Segundo Andrade</segment>
    <segment id="40">, os PMs disseram que os rapazes</segment>
    <segment id="41">, que eram catadores de papel횄짙o</segment>
    <segment id="42">, foram mortos durante um auto de resist횄짧ncia.</segment>
    <segment id="43">Maria, que tinha problemas mentais</segment>
    <segment id="44">, sumiu no mesmo dia e seu corpo s횄쨀 foi localizado na quarta-feira (08)</segment>
    <segment id="45">, num lix횄짙o</segment>
    <segment id="46">, em Gandu [a 108 km de Santo Ant횄쨈nio de Jesus]</segment>
    <segment id="47">, com sinais de queimadura e em decomposi횄짠횄짙o.</segment>
    <segment id="48">Este foi um fato isolado e houve uma resposta r횄징pida.</segment>
    <segment id="49">N횄짙o acredito em exterm횄짯nio</segment>
    <segment id="50">, acredito em uma opera횄짠횄짙o mal feita</segment>
    <segment id="51">, analisou o tenente-coronel.</segment>
    <segment id="52">Segundo ele</segment>
    <segment id="53">, F횄징bio j횄징 havia sido preso</segment>
    <segment id="54">, h횄징 muito tempo</segment>
    <segment id="55">, por porte ilegal de armas.</segment>
  </rst>
