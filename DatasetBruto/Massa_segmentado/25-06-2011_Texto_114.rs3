  <rst>
    <segment id="1">Bebê morto largado perto de igreja</segment>
    <segment id="2">O corpo foi deixado na orla e comoveu policiais militares e moradores</segment>
    <segment id="3">O corpo de um recém-nascido encontrado na orla da Ribeira</segment>
    <segment id="4">, ao lado da Igreja da Penha</segment>
    <segment id="5">, chamou a atenção de transeuntes e comoveu policiais militares</segment>
    <segment id="6">, na tarde de ontem.</segment>
    <segment id="7">“</segment>
    <segment id="8">Parece que foi asfixiado</segment>
    <segment id="9">, porque</segment>
    <segment id="10">porque todo o corpo está enrolado em um pano</segment>
    <segment id="11">, masmas só a cabeça está com o saco.</segment>
    <segment id="12">O pior é que colocar um filho para a adoção não é crime no Brasil”</segment>
    <segment id="13">, disse</segment>
    <segment id="14">, em tom de lamento</segment>
    <segment id="15">, o soldado PM Albuquerque</segment>
    <segment id="16">, da 17ª CIPM.</segment>
    <segment id="17">O comandante da companhia</segment>
    <segment id="18">, major Demetrius</segment>
    <segment id="19">, informou que a polícia tomou conhecimento do corpo após denúncias da população.</segment>
    <segment id="20">Polícia vai investigar
“</segment>
    <segment id="21">Pelo odor</segment>
    <segment id="22">, não creio que tenha sido deixado aqui hoje”</segment>
    <segment id="23">, afirmou o major Demetrius</segment>
    <segment id="24">, da 17ª CIPM.</segment>
    <segment id="25">O sexo da criança e a possível causa da morte não foram confirmados.</segment>
    <segment id="26">Até as 15h</segment>
    <segment id="27">, aproximadamente</segment>
    <segment id="28">, o corpo não havia sido removido pelo Departamento de Polícia Técnica (DPT).</segment>
    <segment id="29">O caso</segment>
    <segment id="30">caso será investigado pela 3ª DT (Delegacia do Bonfim).</segment>
  </rst>
