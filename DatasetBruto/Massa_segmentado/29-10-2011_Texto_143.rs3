  <rst>
    <segment id="1">Willians falta treino e não joga contra o Grêmio
Willians</segment>
    <segment id="2">, que sexta-feira já não havia participado do coletivo</segment>
    <segment id="3">, poupado por ter jogado dois dias antes contra a Universidad de Chile</segment>
    <segment id="4">, em Santiago</segment>
    <segment id="5">, não apareceu no Ninho do Urubu para o treino de sábado de manhã.</segment>
    <segment id="6">Como não deu justificativa</segment>
    <segment id="7">, foi cortado da viagem para Porto Alegre pelo técnico Vanderlei Luxemburgo</segment>
    <segment id="8">, que ficou muito irritado com a reincidência do volante nesta indisciplina.</segment>
    <segment id="9">Esta é a terceira ausência de Willians a um treino este ano.</segment>
    <segment id="10">A mulher do jogador</segment>
    <segment id="11">, grávida de oito meses</segment>
    <segment id="12">, chegou a ir ao centro de treinamento procurá-lo</segment>
    <segment id="13">, dizendo que também não sabia o seu paradeiro.</segment>
    <segment id="14">À tarde</segment>
    <segment id="15">, o assessor de imprensa de Willians informou que não havia acontecido nada grave com ele</segment>
    <segment id="16">, sem dar mais detalhes.

- Não sabemos o que aconteceu.</segment>
    <segment id="17">Nós sempre nos preocupamos</segment>
    <segment id="18">porque</segment>
    <segment id="19">porque é um companheiro.</segment>
    <segment id="20">A diretoria está resolvendo isso.</segment>
    <segment id="21">Só nos preocupamos em jogar futebol - disse Léo Moura.</segment>
    <segment id="22">Fla precisa da vitória para recuperar quarta colocação</segment>
    <segment id="23">O jovem Muralha deve substituí-lo no meio de campo e formará dupla com Aírton</segment>
    <segment id="24">, de volta após ser barrado da partida contra o Santos.</segment>
    <segment id="25">Maldonado</segment>
    <segment id="26">, suspenso</segment>
    <segment id="27">, não enfrenta o Grêmio neste domingo.</segment>
    <segment id="28">Como o Fluminense venceu o Ceará</segment>
    <segment id="29">, chegando a 53 pontos</segment>
    <segment id="30">, o Flamengo</segment>
    <segment id="31">, com 52</segment>
    <segment id="32">, precisa vencer para recuperar a quarta colocação.</segment>
    <segment id="33">Um empate será suficiente para o time permanecer no G-5.</segment>
    <segment id="34">O time do Flamengo participou do tradicional treino recreativo de véspera das partidas.</segment>
    <segment id="35">Ronaldinho era um dos mais animados e mostrou que está tranquilo para o confronto contra o ex-time no Olímpico.</segment>
    <segment id="36">O camisa 10 brincou muito com os companheiros durante a atividade.</segment>
    <segment id="37">No fim</segment>
    <segment id="38">, o time de Léo Moura venceu o de Ronaldinho e fez a festa.

GRÊMIO</segment>
    <segment id="39">X FLAMENGO

Grêmio: Victor</segment>
    <segment id="40">, Mário Fernandes</segment>
    <segment id="41">, Saimon</segment>
    <segment id="42">, Rafael Marques e Júlio César</segment>
    <segment id="43">;</segment>
    <segment id="44">Gilberto Silva</segment>
    <segment id="45">, Fernando</segment>
    <segment id="46">, Marquinhos</segment>
    <segment id="47">, Douglas e Escudero</segment>
    <segment id="48">; André Lima.</segment>
    <segment id="49">Flamengo: Felipe</segment>
    <segment id="50">, Léo Moura</segment>
    <segment id="51">, Alex Silva</segment>
    <segment id="52">, Welinton e Júnior César</segment>
    <segment id="53">; Aírton</segment>
    <segment id="54">, Thomas</segment>
    <segment id="55">, Renato e Thiago Neves</segment>
    <segment id="56">; Ronaldinho e Deivid.</segment>
    <segment id="57">Juiz: Evandro Rogério Roman (PR).</segment>
  </rst>
