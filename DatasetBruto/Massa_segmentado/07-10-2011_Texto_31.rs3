  <rst>
    <segment id="1">Casório virou uma festa de horrores</segment>
    <segment id="2">Quinze atiradores armados invadem a festa para matar um jovem de 15 anos</segment>
    <segment id="3">A festa de casamento de Gilmar Cunha Ferreira e Josiane Ferreira</segment>
    <segment id="4">, ambos de  27 anos</segment>
    <segment id="5">, foi interrompida a tiros</segment>
    <segment id="6">, por volta das 3 h da tarde de ontem</segment>
    <segment id="7">, depois que cerca de 15 homens armados invadiram  a quadra de esportes onde ocorriam as comemorações</segment>
    <segment id="8">,  na rua Cosme Damião</segment>
    <segment id="9">, na localidade conhecida</segment>
    <segment id="10">comocomo Campinho do IAPI.</segment>
    <segment id="11">O alvo dos criminosos era Gabriel Santos Pereira</segment>
    <segment id="12">, de apenas 15 anos.</segment>
    <segment id="13">O jovem</segment>
    <segment id="14">, que não estava na festa</segment>
    <segment id="15">, masmas perto da quadra</segment>
    <segment id="16">, foi assassinado com pelo menos sete tiros</segment>
    <segment id="17">, segundo os policiais da Delegacia da Liberdade.</segment>
    <segment id="18">Os balaços atingiram o braço (3)</segment>
    <segment id="19">, o abdômen</segment>
    <segment id="20">, a coxa direita (2) e a cabeça.</segment>
    <segment id="21">Em depoimento à polícia</segment>
    <segment id="22">, a mãe de Gabriel contou que o garoto “estava na porta de casa”.</segment>
    <segment id="23">A vítima estava sem documento de identidade.</segment>
    <segment id="24">A saraivada de tiros sobrou para o noivo Gilmar Cunha</segment>
    <segment id="25">, que foi  baleado de raspão nas costas.</segment>
    <segment id="26">Outra vítima dos disparos foi Sônia Maria Bastos Cardoso</segment>
    <segment id="27">, 50,  que passava pelo local</segment>
    <segment id="28">, no momento do crime.</segment>
    <segment id="29">Ela foi atingida no braço esquerdo.</segment>
    <segment id="30">Gabriel e os demais feridos foram levados ao Hospital Ernesto Simões Filho</segment>
    <segment id="31">, no bairro Pau Miúdo.</segment>
    <segment id="32">O jovem de 15 anos não resistiu aos ferimentos e morreu.</segment>
    <segment id="33">Gilmar e Sônia</segment>
    <segment id="34">, as outras vítimas levadas ao hospital</segment>
    <segment id="35">, já receberam alta médica e passam bem.</segment>
    <segment id="36">Outro atentado ocorreu pela manhã</segment>
    <segment id="37">A polícia investiga</segment>
    <segment id="38">sese uma tentativa de homicídio cometida contra um adolescente de 17 anos</segment>
    <segment id="39">, na mesma rua Cosme e Damião</segment>
    <segment id="40">, por volta das 12h30 de ontem</segment>
    <segment id="41">, tem relação com o assassinato de Gabriel.</segment>
    <segment id="42">De acordo com informações passadas pela polícia</segment>
    <segment id="43">, Edinei havia</segment>
    <segment id="44">sese desentendido com um outro adolescente</segment>
    <segment id="45">, na manhã de ontem.</segment>
    <segment id="46">Durante depoimento na delegacia</segment>
    <segment id="47">, o adolescente contou que estava indo</segment>
    <segment id="48">sese retratar com o rapaz</segment>
    <segment id="49">, quando este teria subido a rua acompanhado de um outro jovem</segment>
    <segment id="50">, que puxou uma arma da cintura e disparou várias vezes contra ele.</segment>
    <segment id="51">Edinei foi atingido por  um tiro no abdômen.</segment>
    <segment id="52">Também levado ao Hospital Ernesto Simões Filho</segment>
    <segment id="53">, o garoto passou por uma cirurgia e já foi liberado logo em seguida.</segment>
    <segment id="54">A vítima da tentativa de homicídio não tinha passagem pela polícia.</segment>
  </rst>
</analysis>