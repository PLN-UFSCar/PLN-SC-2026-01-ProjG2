  <rst>
    <segment id="1">Uma conta de bar de US$ 105 mil
NOVA YORK - O Cavalli Club</segment>
    <segment id="2">, do Fairmont Hotel</segment>
    <segment id="3">, em Dubai</segment>
    <segment id="4">, foi agraciado na semana passada com uma presença ilustre: um frequentador que gastou na da mais nada menos que US$ 105 mil em uma única noite.</segment>
    <segment id="5">A despesa</segment>
    <segment id="6">sese refere apenas ao consumo de be bidas</segment>
    <segment id="7">, além de uma única fatia de bolo de aniversário</segment>
    <segment id="8">, que indica que a gastança tinha</segment>
    <segment id="9">comocomo objetivo comemorar algo.</segment>
    <segment id="10">A foto da conta paga

acabou circulando no Twitter e gerou grande repercussão.</segment>
    <segment id="11">O bar não revelou a identidade ou nacionalidade da pessoa que pagou a conta.</segment>
    <segment id="12">Mas o gasto</segment>
    <segment id="13">, ainda segundo o "Wall Street Journal"</segment>
    <segment id="14">, foi confirmado pelo Cavalli Club.</segment>
    <segment id="15">Também não há informações sobre quantas pessoas</segment>
    <segment id="16">sese fartaram com a gastança no Fairmont Hotel.</segment>
    <segment id="17">E sese em 2009</segment>
    <segment id="18">Dubai sofria com problemas de fluxo de caixa</segment>
    <segment id="19">, agora</segment>
    <segment id="20">, segundo o gerente do estabelecimento</segment>
    <segment id="21">, contas de cerca de US$ 100 mil são rotineiras.</segment>
    <segment id="22">Além disso</segment>
    <segment id="23">, a conta mostra que os ricaços parecem imunes a crise financeira internacional</segment>
    <segment id="24">, que afeta principalmente os países desenvolvidos.</segment>
    <segment id="25">Mas gastar tanto no Cavalli Club não é tão difícil.</segment>
    <segment id="26">Além dos exageros</segment>
    <segment id="27">, os preços são bem salgados.</segment>
    <segment id="28">Segundo o recibo da conta astro nômica</segment>
    <segment id="29">, uma garrafa de champagne</segment>
    <segment id="30">Cristal de seis litros saiu por US$

35 mil.</segment>
    <segment id="31">Duas de dois litros da mesma bebida saíram por US$ 19 mil.</segment>
    <segment id="32">Outras 13 garrafas</segment>
    <segment id="33">, de Roederer Cristal</segment>
    <segment id="34">, custaram US$ 23 mil - cerca de US$ 1.800 cada.</segment>
    <segment id="35">Um refrigerante</segment>
    <segment id="36">, US$ 6.</segment>
    <segment id="37">Foram consumidos 24.</segment>
    <segment id="38">Já o Red Bull saiu por US$ 7</segment>
    <segment id="39">,80.</segment>
    <segment id="40">O pedido incluía dez.</segment>
    <segment id="41">Por uma garrafa de vodka Cavalli</segment>
    <segment id="42">, o bar cobrou US$ 1.341.</segment>
    <segment id="43">Já por quatro de Chivas</segment>
    <segment id="44">, US$ 1.181.</segment>
    <segment id="45">A fatia de bolo custou a bagatela de US$ 32.</segment>
    <segment id="46">Segundo o site Gulfnews.com</segment>
    <segment id="47">, com o valor da conta</segment>
    <segment id="48">, o consumidor

poderia ter com prado dois Porsche Cayennes.</segment>
  </rst>
