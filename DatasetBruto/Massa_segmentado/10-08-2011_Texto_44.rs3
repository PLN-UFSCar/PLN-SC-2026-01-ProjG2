  <rst>
    <segment id="1">Gaúcha</segment>
    <segment id="2">sese transforma na ‘Miss peitinho’</segment>
    <segment id="3">A Miss Brasil não perderá a majestade</segment>
    <segment id="4">, pois</segment>
    <segment id="5">pois as fotos não mostram a genitália da moça</segment>
    <segment id="6">Mais um babado envolvendo a Miss Brasil 2011</segment>
    <segment id="7">, Priscila Machado</segment>
    <segment id="8">, agitou a internet ontem.</segment>
    <segment id="9">Após uma foto da gaúcha com os seios de fora vazar na web um dia depois de sua vitória no concurso</segment>
    <segment id="10">, surgiram novas fotos da morena em um ensaio sensual.

Desta vez</segment>
    <segment id="11">, as imagens da moça com os peitos à mostra estão em um site de  pornografia.</segment>
    <segment id="12">Nas fotos</segment>
    <segment id="13">, Priscila aparece só de calcinha</segment>
    <segment id="14">, abraçada a outra mulher e é chamada Sara</segment>
    <segment id="15">, 19 anos.</segment>
    <segment id="16">As fotos estão  lá  desde  agosto de 2007.</segment>
    <segment id="17">O problema é que as concorrentes do Miss Brasil</segment>
    <segment id="18">, segundo o regulamento</segment>
    <segment id="19">,  não podem ter aparecido em fotos nuas.</segment>
    <segment id="20">Depois da primeira foto divulgada</segment>
    <segment id="21">, a miss negou que já tivesse feito um ensaio sensual e disse que o fotógrafo agiu de má-fé.</segment>
    <segment id="22">O diretor do concurso</segment>
    <segment id="23">, Boanerges Gaeta</segment>
    <segment id="24">, falou que não vai tirar o título da gaúcha.</segment>
    <segment id="25">“Ela fez fotos que não tinham autorização para serem divulgadas.</segment>
    <segment id="26">No momento</segment>
    <segment id="27">, ela está muito envolvida com o Miss Universo</segment>
    <segment id="28">, masmas depois vai estudar com calma</segment>
    <segment id="29">sese toma ou não medidas jurídicas para o vazamento dessas fotos.</segment>
    <segment id="30">Quem fica chupando dedo é a Miss Bahia</segment>
    <segment id="31">, Gabriela Rocha</segment>
    <segment id="32">, que ficou em segundo lugar  e viu a campeã ser vaiada pelo público na final.</segment>
    <segment id="33">“</segment>
    <segment id="34">O público torcia por mim.</segment>
    <segment id="35">Foi uma vitória e tenho a sensação de dever cumprido”</segment>
    <segment id="36">, afirmou na época do concurso.</segment>
  </rst>
