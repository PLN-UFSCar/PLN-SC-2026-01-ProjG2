  <rst>
    <segment id="1">Chuvas põem Defesa Civil de Friburgo estado de alerta
RIO - As pancadas de chuva</segment>
    <segment id="2">, que já duram uma semana e</segment>
    <segment id="3">sese intensificaram a partir das 13h do dia 31</segment>
    <segment id="4">, puseram a Defesa Civil do estado em alerta em Friburgo.</segment>
    <segment id="5">Uma barreira desabou sobre os fundos de uma casa no bairro de Santa Luzia.</segment>
    <segment id="6">Ninguém</segment>
    <segment id="7">sese feriu</segment>
    <segment id="8">, e os moradores foram retirados.</segment>
    <segment id="9">Duas das 35 sirenes instaladas em 20 comunidades - que alertam os moradores sobre risco de enchentes e desabamentos - foram acionadas.</segment>
    <segment id="10">Parte da população teve de sair de suas casas em duas localidades: no Córrego Dantas</segment>
    <segment id="11">, ameaçada pela proximidade com o Rio Bengalas</segment>
    <segment id="12">, que corta a cidade</segment>
    <segment id="13">; e no Jardim Califórnia.</segment>
    <segment id="14">Na noite de ontem</segment>
    <segment id="15">, o volume do rio subiu consideravelmente</segment>
    <segment id="16">, faltando um metro para transbordar.</segment>
    <segment id="17">O coordenador da Defesa Civil de Friburgo</segment>
    <segment id="18">, coronel João Paulo Mori</segment>
    <segment id="19">, disse nesta tarde que</segment>
    <segment id="20">, caso</segment>
    <segment id="21">caso a chuva piorasse nas horas seguintes</segment>
    <segment id="22">, todas as sirenes seriam acionadas.</segment>
    <segment id="23">Por volta das 20h</segment>
    <segment id="24">, a média de chuva era de 10mm por hora na região central da cidade.</segment>
    <segment id="25">Passando dos 25mm/hora</segment>
    <segment id="26">, a precipitação é considerada forte.

- O que mais nos preocupa é o fato de a chuva estar constante.</segment>
    <segment id="27">Estamos atentos e com as equipes nas ruas - disse.</segment>
    <segment id="28">Também neste domingo</segment>
    <segment id="29">, houve quedas de barreiras em dois trechos no sentido Rio da RJ-116 (Friburgo-Teresópolis):</segment>
    <segment id="30">nas proximidades de Cardinó e de Campo do Coelho.</segment>
    <segment id="31">Não houve feridos</segment>
    <segment id="32">, e o trânsito não precisou ser interditado.</segment>
    <segment id="33">Há quase um ano</segment>
    <segment id="34">, uma enxurrada em 12 de janeiro causou uma tragédia que deixou mais de 900 mortos na Região Serrana.</segment>
    <segment id="35">Teresópolis e Petrópolis</segment>
    <segment id="36">, também atingidas</segment>
    <segment id="37">, não tiveram queimas de fogos</segment>
    <segment id="38">No Rio tempo chuvoso persiste hoje</segment>
    <segment id="39">, diz Climatempo</segment>
    <segment id="40">No Rio</segment>
    <segment id="41">, segundo o instituto de meteorologia Climatempo</segment>
    <segment id="42">, o tom cinzento do primeiro dia do ano deve persistir nesta segunda-feira.</segment>
    <segment id="43">O motivo é a presença de um sistema de baixa pressão que favorece a formação de nuvens sobre todo o estado.</segment>
    <segment id="44">No Norte Fluminense</segment>
    <segment id="45">, pode chover a qualquer hora do dia</segment>
    <segment id="46">, com risco de temporais.</segment>
    <segment id="47">Na capital e nas outras áreas</segment>
    <segment id="48">, o tempo pode não ficar fechado por completo</segment>
    <segment id="49">, masmas é bom os cariocas e turistas</segment>
    <segment id="50">sese prepararem para enfrentar chuva a qualquer momento.</segment>
    <segment id="51">Na Região Serrana também há risco de chuva forte.</segment>
    <segment id="52">Choveu forte na Zona Oeste da cidade do Rio na noite deste domingo.</segment>
    <segment id="53">De acordo com o Centro de Operações da Prefeitura</segment>
    <segment id="54">, a chuva segue no sentido Zona Sul e pode ainda atingir o Centro e a Tijuca.</segment>
    <segment id="55">Durante o dia</segment>
    <segment id="56">, houve registro de chuva fraca em diversos pontos da cidade.</segment>
    <segment id="57">Às 14h30m</segment>
    <segment id="58">, o maior acúmulo foi na Avenida Brasil</segment>
    <segment id="59">, na altura de Mendanha</segment>
    <segment id="60">, Campo Grande.</segment>
    <segment id="61">A Defesa Civil do município atendeu a uma ocorrência neste domingo</segment>
    <segment id="62">, masmas sem gravidade.</segment>
    <segment id="63">A temperatura mínima foi de 20</segment>
    <segment id="64">,5 graus</segment>
    <segment id="65">, na Restinga de Marambaia</segment>
    <segment id="66">, e a máxima</segment>
    <segment id="67">, de 28</segment>
    <segment id="68">,1 graus</segment>
    <segment id="69">, na Vila Militar</segment>
    <segment id="70">, de acordo com o Instituto Nacional de Meteorologia (Inmet).</segment>
    <segment id="71">Para amanhã</segment>
    <segment id="72">, a previsão é de pancadas de chuva</segment>
    <segment id="73">, com períodos de sol.</segment>
  </rst>
</analysis>