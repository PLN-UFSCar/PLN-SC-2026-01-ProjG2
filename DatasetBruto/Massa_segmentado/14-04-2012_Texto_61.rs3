  <rst>
    <segment id="1">Casa caiu para matador de policial</segment>
    <segment id="2">Tiago Sampaio foi preso na mesma operação na qual também foi detido o rival Michel</segment>
    <segment id="3">Dois criminosos de quadrilhas rivais foram obrigados a ficar frente a frente após serem presos</segment>
    <segment id="4">, na última terça-feira</segment>
    <segment id="5">, no Nordeste de Amaralina</segment>
    <segment id="6">, durante a Operação Manutenção da Ordem</segment>
    <segment id="7">, realizada em conjunto pelas Polícias Civil e Militar.</segment>
    <segment id="8">Tiago Santos Sampaio</segment>
    <segment id="9">, 23 anos</segment>
    <segment id="10">, foi detido na porta de casa</segment>
    <segment id="11">, na Rua do Gás.</segment>
    <segment id="12">Ele é acusado de ser um dos autores do assassinato do policial civil João Carvalho Filho</segment>
    <segment id="13">, que era lotado na Delegacia para o Adolescente Infrator (DAI).</segment>
    <segment id="14">O crime ocorreu no último dia 4 de fevereiro</segment>
    <segment id="15">, na Avenida ACM.</segment>
    <segment id="16">O policial estava dentro do carro Voyage</segment>
    <segment id="17">, aguardando a mulher que estava em uma clínica médica.</segment>
    <segment id="18">“</segment>
    <segment id="19">No depoimento</segment>
    <segment id="20">, Tiago disse que ele e mais dois comparsas saíram com a intenção de roubar um carro.</segment>
    <segment id="21">Eles queriam pegar uma vítima distraída.</segment>
    <segment id="22">O policial estava no carro</segment>
    <segment id="23">, lendo jornal.</segment>
    <segment id="24">Tiago o abordou pelo lado do motorista.</segment>
    <segment id="25">O policial tentou puxar a arma</segment>
    <segment id="26">masmas foi surpreendido por Valdinei Felício Barbosa</segment>
    <segment id="27">, que estava em pé ao lado da porta do carona e já foi atirando”</segment>
    <segment id="28">, afirma a delegada Mariana Ouais</segment>
    <segment id="29">, do Departamento de Homicídios.</segment>
    <segment id="30">Rival de Tiago</segment>
    <segment id="31">, Michel Santos Borges</segment>
    <segment id="32">, 25, foi preso na região do Boqueirão.</segment>
    <segment id="33">Assassinos cruéis</segment>
    <segment id="34">Valdinei está foragido.</segment>
    <segment id="35">Segundo a delegada</segment>
    <segment id="36">, imagens de câmeras de segurança mostram Tiago e Valdinei disparando 12 vezes contra o policial.</segment>
    <segment id="37">Eles teriam retirado o agente do carro e espancado a vítima</segment>
    <segment id="38">, já baleada.</segment>
    <segment id="39">A polícia afirma que Tiago era comparsa do traficante Wellington Barão</segment>
    <segment id="40">, morto em janeiro</segment>
    <segment id="41">, após sair do presídio.</segment>
    <segment id="42">Segundo a polícia</segment>
    <segment id="43">, o rival Michel Santos integra a quadrilha do traficante Elias Pinto</segment>
    <segment id="44">, do Nordeste de Amaralina.</segment>
  </rst>
</analysis>