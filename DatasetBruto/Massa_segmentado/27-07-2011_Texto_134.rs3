  <rst>
    <segment id="1">Humoristas invadem funeral de Amy
Eles usaram até um quipá na cabeça</segment>
    <segment id="2">, para mostrar que eram judeus</segment>
    <segment id="3">Os impostores</segment>
    <segment id="4">, inclusive</segment>
    <segment id="5">, deram uma entrevista em inglês a uma emissora de TV alemã falando da morte da cantora</segment>
    <segment id="6">; chegaram a chorar.</segment>
    <segment id="7">Confira!</segment>
    <segment id="8">Dois brasileiros chamaram a atenção no funeral da cantora Amy Winehouse</segment>
    <segment id="9">, na tarde de ontem na Inglaterra.</segment>
    <segment id="10">Fingindo muita tristeza e choro</segment>
    <segment id="11">, Daniel Zukerman</segment>
    <segment id="12">, o Impostor do programa Pânico na TV (RedeTV!)</segment>
    <segment id="13">,  foi flagrado</segment>
    <segment id="14">sese passando por familiar da cantora durante cerimônia de adeus.</segment>
    <segment id="15">Ele estava abraçado a André Machado</segment>
    <segment id="16">, editor do programa.</segment>
    <segment id="17">Como Impostor</segment>
    <segment id="18">, Zukerman já</segment>
    <segment id="19">sese infiltrou em diversos eventos fechados e importantes pelo mundo.</segment>
    <segment id="20">Em 2009</segment>
    <segment id="21">, ele conseguiu entrar no velório de Michael Jackson sem ter convite.</segment>
    <segment id="22">Eles enganaram tão bem que convenceram até os jornalistas.</segment>
    <segment id="23">A rede  internacional de notícias CNN identificou os dois</segment>
    <segment id="24">comocomo “assessores” de Amy.</segment>
    <segment id="25">A brincadeira  levou a agência de notícias Reuters a emitir uma nota de desculpas ao público</segment>
    <segment id="26">, depois de dizer que eles eram amigos da cantora.</segment>
    <segment id="27">Amy Winehouse morreu em seu apartamento em Londres no sábado</segment>
    <segment id="28">, aos 27 anos.</segment>
    <segment id="29">O corpo foi cremado e parte das cinzas serão misturadas às da avó.</segment>
    <segment id="30">A outra vai ser levada para Santa Lúcia</segment>
    <segment id="31">, no Caribe</segment>
    <segment id="32">, local onde ela</segment>
    <segment id="33">sese internou</segment>
    <segment id="34">, em 2008</segment>
    <segment id="35">,  para tentar</segment>
    <segment id="36">sese livrar das drogas.</segment>
  </rst>
</analysis>