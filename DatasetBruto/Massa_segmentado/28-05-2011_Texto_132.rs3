  <rst>
    <segment id="1">Barcelona faz 3 a 1 no Manchester United e conquista título da Liga dos Campeões da Europa

LONDRES - O Barcelona parece de outro mundo.</segment>
    <segment id="2">O time espanhol joga um futebol encantado</segment>
    <segment id="3">, e quanto mais forte o adversário</segment>
    <segment id="4">, mais</segment>
    <segment id="5">sese inspira a dar show.</segment>
    <segment id="6">Beirando a perfeição</segment>
    <segment id="7">, a equipe comandada pelo talento gigante do argentino Messi aliou mais uma vez espetáculo e eficiência e derrotou por 3 a 1 o Manchester United na final da Liga dos Campeões da Europa</segment>
    <segment id="8">, em Wembley.</segment>
    <segment id="9">Os gols foram de Pedro</segment>
    <segment id="10">, Messi e Villa</segment>
    <segment id="11">, com Rooney descontando para os ingleses.</segment>
    <segment id="12">O campeão espanhol</segment>
    <segment id="13">, agora mais uma vez campeão europeu</segment>
    <segment id="14">, só não jogou seu futebol alucinante nos primeiros dez minutos da partida.</segment>
    <segment id="15">No início foi o Manchester quem buscou o ataque e tentou sufocar o adversário.</segment>
    <segment id="16">Mas coube ao Barcelona o primeiro grande momento de perigo.</segment>
    <segment id="17">Aos 15 minutos</segment>
    <segment id="18">, em jogada envolvente</segment>
    <segment id="19">, Messi e Villa tabelaram e Pedro perdeu o gol na pequena área.</segment>
    <segment id="20">Em seguida</segment>
    <segment id="21">, aos 19</segment>
    <segment id="22">, Villa chutou rasteiro de fora da área</segment>
    <segment id="23">, a bola saiu raspando a trave esquerda de Van der Sar.
FOTOGALERIA: Veja mais fotos do jogão em Wembley e da festa do Barça
TEMPO REAL:</segment>
    <segment id="24">Como foi o lance a lance
DESAFIO:</segment>
    <segment id="25">Tente achar um defeito no time do Barcelona
Àquela altura</segment>
    <segment id="26">, só dava Barcelona.</segment>
    <segment id="27">A pressão surtiu efeito aos 27.</segment>
    <segment id="28">Xavi deu um passe espetacular para Pedro</segment>
    <segment id="29">, após triangulação no meio de campo.</segment>
    <segment id="30">Diante do goleiro</segment>
    <segment id="31">, o jovem atacante não hesitou:</segment>
    <segment id="32">tocou no canto esquerdo e correu para comemorar: 1 a 0.</segment>
    <segment id="33">Do outro lado</segment>
    <segment id="34">, porém</segment>
    <segment id="35">porém, não estava um time qualquer.</segment>
    <segment id="36">Mesmo dominado e assustado com o gol</segment>
    <segment id="37">, o Manchester reagiu.</segment>
    <segment id="38">Em posição irregular por centímetros</segment>
    <segment id="39">, Chicharito Hernandez recebeu de Ronney e devolveu para o chute forte</segment>
    <segment id="40">, de primeira</segment>
    <segment id="41">, do companheiro de ataque.</segment>
    <segment id="42">Rooney acertou o ângulo de Valdés e empatou: 1 a 1.</segment>
    <segment id="43">Antes do intervalo</segment>
    <segment id="44">, Messi deu a primeira demonstração de que estava muito a fim de ser decisivo.</segment>
    <segment id="45">Ele deu um drible entre as pernas de um adversário</segment>
    <segment id="46">, arrancou em velocidade e tocou para Villa</segment>
    <segment id="47">, que devolveu de primeira</segment>
    <segment id="48">, na pequena área.</segment>
    <segment id="49">Messi quase alcançou</segment>
    <segment id="50">, masmas chegou um segundo atrasado embaixo do gol.</segment>
    <segment id="51">Depois de um primeiro tempo alucinante</segment>
    <segment id="52">, disputado com categoria e em ritmo forte</segment>
    <segment id="53">, Barcelona e Manchester voltaram para a segunda etapa demonstrando a mesma disposição ofensiva.</segment>
    <segment id="54">Especialmente o campeão espanhol</segment>
    <segment id="55">, que logo aos seis minutos quase passou à frente no placar.</segment>
    <segment id="56">Daniel Alves ficou cara a cara com Van der Sar</segment>
    <segment id="57">, masmas chutou em cima do goleiro.</segment>
    <segment id="58">No rebote</segment>
    <segment id="59">, Messi tentou por cobertura</segment>
    <segment id="60">, masmas o lateral Evra salvou de cabeça.</segment>
    <segment id="61">Não demorou nada e o Barça marcou o segundo gol.</segment>
    <segment id="62">Aos oito</segment>
    <segment id="63">, Iniesta tocou para Messi na meia-lua da área.</segment>
    <segment id="64">O craque argentino recebeu</segment>
    <segment id="65">, ajeitou e bateu forte</segment>
    <segment id="66">, de canhota.</segment>
    <segment id="67">Van der Sar</segment>
    <segment id="68">, mal colocado</segment>
    <segment id="69">, não chegou a tempo: bola na rede e Barcelona 2 a 1.</segment>
    <segment id="70">A partida</segment>
    <segment id="71">, que no primeiro tempo teve apenas sete faltas</segment>
    <segment id="72">, sendo cinco cometidas pelo Manchester</segment>
    <segment id="73">, ganhou um pouco de rispidez.</segment>
    <segment id="74">Aos 14 e 15</segment>
    <segment id="75">, Daniel Alves</segment>
    <segment id="76">, para o Barcelona</segment>
    <segment id="77">, e Carrick</segment>
    <segment id="78">, para o Manchester</segment>
    <segment id="79">, receberam cartões amarelos por faltas duras.</segment>
    <segment id="80">E veio então uma incrível sequência de ataques perigosos do Barcelona</segment>
    <segment id="81">, um verdadeiro massacre.</segment>
    <segment id="82">Aos 17</segment>
    <segment id="83">, Messi bateu de canhota na área</segment>
    <segment id="84">, Van der Sar defendeu e largou</segment>
    <segment id="85">, masmas a zaga afastou o perigo.</segment>
    <segment id="86">Aos 18</segment>
    <segment id="87">, de novo Messi.</segment>
    <segment id="88">Ele quase marcou de letra</segment>
    <segment id="89">, após passe de Daniel Alves.</segment>
    <segment id="90">Aos 19</segment>
    <segment id="91">, Xávi soltou uma bomba cheia de efeito</segment>
    <segment id="92">, para defesa espetacular de Van der Sar.</segment>
    <segment id="93">E aos 20</segment>
    <segment id="94">, Messi tabelou om Daniel Alves e rolou para Xávi chutar de primeira.</segment>
    <segment id="95">O goleiro do Manchester voltou a fazer boa defesa.</segment>
    <segment id="96">Diante de um sufoco desse</segment>
    <segment id="97">, o Manchester sucumbiu de vez aos 24 minutos.</segment>
    <segment id="98">Messi entortou dois adversários e tocou para o meio da área.</segment>
    <segment id="99">A zaga tirou</segment>
    <segment id="100">, masmas a bola sobrou para David Villa.</segment>
    <segment id="101">Ele bateu de fora da área</segment>
    <segment id="102">, no ângulo superior esquerdo de Van der Sar: um golaço e 3 a 1 no placar.</segment>
    <segment id="103">Campeão europeu pela quarta vez em sua história (as outras foram em 1992</segment>
    <segment id="104">, 2006 e 2009)</segment>
    <segment id="105">, o Barcelona</segment>
    <segment id="106">, que faturou o título do Campeonato Espanhol nas últimas três temporadas</segment>
    <segment id="107">, sese afirma e reafirma</segment>
    <segment id="108">comocomo melhor time do mundo na atualidade.</segment>
    <segment id="109">Com um futebol vistoso</segment>
    <segment id="110">, competitivo e vitorioso.
BARCELONA 3x1 MANCHESTER UNITED
ESTÁDIO: Wembley</segment>
    <segment id="111">, em Londres</segment>
    <segment id="112">, InglaterraDATA E HORA: Sábado</segment>
    <segment id="113">, 28 de maio de 2011</segment>
    <segment id="114">, às 15h45 (de Brasília)
ÁRBITRO: Viktor Kassai (HUN)
CARTÕES: Daniel Alves</segment>
    <segment id="115">, Valdés (BAR)</segment>
    <segment id="116">; Carrick</segment>
    <segment id="117">, Valencia (MAN)
PÚBLICO: 87.695 pagantes
GOLS: Pedro (1-0)</segment>
    <segment id="118">, aos 27'/1ºT</segment>
    <segment id="119">;</segment>
    <segment id="120">Rooney (1-1)</segment>
    <segment id="121">, aos 34'/1ºT</segment>
    <segment id="122">; Messi (2-1)</segment>
    <segment id="123">, aos 9'/2ºT</segment>
    <segment id="124">; Villa (3-1)</segment>
    <segment id="125">, aos 24'/2ºT
BARCELONA: Valdés</segment>
    <segment id="126">; Daniel Alves (Puyol)</segment>
    <segment id="127">, Mascherano</segment>
    <segment id="128">, Piqué</segment>
    <segment id="129">, Abidal</segment>
    <segment id="130">; Busquets</segment>
    <segment id="131">, Xavi</segment>
    <segment id="132">, Iniesta</segment>
    <segment id="133">; Pedro (Afellay)</segment>
    <segment id="134">, Villa (Keita) e Messi
TÉCNICO: Pep Guardiola
MANCHESTER UNITED: Van der Sar</segment>
    <segment id="135">; Fabio (Nani)</segment>
    <segment id="136">, Vidic</segment>
    <segment id="137">, Ferdinand</segment>
    <segment id="138">, Evra</segment>
    <segment id="139">; Carrick (Scholes)</segment>
    <segment id="140">, Giggs</segment>
    <segment id="141">, Park</segment>
    <segment id="142">, Valencia</segment>
    <segment id="143">; Rooney e Chicharito Hernández
TÉCNICO: Alex Ferguson</segment>
  </rst>
</analysis>