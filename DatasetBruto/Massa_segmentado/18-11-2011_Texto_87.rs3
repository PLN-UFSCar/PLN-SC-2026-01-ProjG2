  <rst>
    <segment id="1">Katy Perry vai</segment>
    <segment id="2">sese afastar da música para ter filhos</segment>
    <segment id="3">A popstar Katy Perry deve ficar afastada da música durante cerca de um ano</segment>
    <segment id="4">, segundo fontes ligadas a ela.</segment>
    <segment id="5">A cantora americana quer começar uma família com seu marido</segment>
    <segment id="6">, o ator Russell Brand</segment>
    <segment id="7">, e acha que não pode fazer isso sem dar um tempo do showbiz.</segment>
    <segment id="8">Ao que tudo indica</segment>
    <segment id="9">, esse intervalo na carreira da Katy deve começar assim que acabar a turnê</segment>
    <segment id="10">"</segment>
    <segment id="11">American Dreams"</segment>
    <segment id="12">,</segment>
    <segment id="13">cujo último show acontece dia 23 de novembro</segment>
    <segment id="14">, em Los Angeles.</segment>
    <segment id="15">O jornal "New York Post" publicou a notícia citando</segment>
    <segment id="16">comocomo fontes os empresários da estrela de 27 anos</segment>
    <segment id="17">, responsável por megahits</segment>
    <segment id="18">comocomo "I kissed a girl" e "California gurls".</segment>
    <segment id="19">Numa entrevista recente com a apresentadora Ellen DeGeneres</segment>
    <segment id="20">, Katheryn Elizabeth Hudson</segment>
    <segment id="21">, nascida em Santa Barbara</segment>
    <segment id="22">, na Califórnia</segment>
    <segment id="23">, já havia dito que mal podia esperar para ter um bebê.</segment>
    <segment id="24">"</segment>
    <segment id="25">Eu adoraria ter filhos.</segment>
    <segment id="26">Esta é uma das razões para você</segment>
    <segment id="27">sese casar.</segment>
    <segment id="28">Você pensa 'essa pessoa vai ser um bom parceiro</segment>
    <segment id="29">, um bom pai...</segment>
    <segment id="30">Se não doer da primeira vez</segment>
    <segment id="31">, eu vou continuar parindo"</segment>
    <segment id="32">, disse Kate.</segment>
