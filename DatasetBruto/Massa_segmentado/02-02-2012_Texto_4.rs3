  <rst>
    <segment id="1">Iemanjá:</segment>
    <segment id="2">O Psi não vai descer
Márcio Victor anunciou ontem que não levaria mais seus músicos para as ruas</segment>
    <segment id="3">Após três anos fazendo o arrastão percussivo da festa profana de Iemanjá</segment>
    <segment id="4">, Márcio Victor anunciou ontem que não levaria mais seus músicos para as ruas.</segment>
    <segment id="5">A decisão é em virtude da proibição do uso do minitrio proposta pelo Ministério Público Estadual e acatada pela prefeitura.</segment>
    <segment id="6">Além disso</segment>
    <segment id="7">, o cantor alega que a possível falta de policiamento na cidade</segment>
    <segment id="8">, por conta da greve dos policiais militares</segment>
    <segment id="9">, pode aumentar a insegurança.</segment>
    <segment id="10">“</segment>
    <segment id="11">Faço festa para levar paz.</segment>
    <segment id="12">E isso ficaria comprometido.</segment>
    <segment id="13">E a proibição do uso de carro de som  poderia prejudicar o cortejo”</segment>
    <segment id="14">, pontua.</segment>
    <segment id="15">Por conta disso</segment>
    <segment id="16">, ele antecipou a entrega da oferenda para Iemanjá.</segment>
    <segment id="17">O barco com os presentes saiu ontem à tarde da Bahia Marina</segment>
    <segment id="18">,  em direção ao alto mar.</segment>
    <segment id="19">O momento também foi usado para a gravação de parte do DVD do Psirico.</segment>
    <segment id="20">O bloco Olodum</segment>
    <segment id="21">, por sua vez</segment>
    <segment id="22">, confirmou que levará 100 percussionistas para a folia</segment>
    <segment id="23">, bem como</segment>
    <segment id="24">como o cantor Carlinhos Brown</segment>
    <segment id="25">, que vai  liderar 100  timbaleiros e o Zárabe no cortejo pelo Rio Vermelho.</segment>
  </rst>
</analysis>