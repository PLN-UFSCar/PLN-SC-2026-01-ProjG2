  <rst>
    <segment id="1">Hermano fogoso leva golpe da ‘viúva’
Com um perfil falso</segment>
    <segment id="2">, Ivonete atraiu Alfredo a Ilhéus e o manteve em cárcere privado</segment>
    <segment id="3">Embarcou no aeroporto de Ilhéus na tarde de ontem</segment>
    <segment id="4">, com destino a Buenos Aires</segment>
    <segment id="5">, Alfredo Valetin de Pereira</segment>
    <segment id="6">, 62 anos.</segment>
    <segment id="7">Ele foi resgatado pela Polícia Civil na noite da última segunda em Barro Preto</segment>
    <segment id="8">, no sul da Bahia (a 454 km de Salvador)</segment>
    <segment id="9">, onde era mantido em cárcere privado na residência de Ivonete Santos da Rocha Klein</segment>
    <segment id="10">, 55.</segment>
    <segment id="11">Segundo o delegado Irineu Andrade</segment>
    <segment id="12">, titular da 7ª Coordenadoria de Polícia do Interior</segment>
    <segment id="13">, Ivonete usava dois perfis falsos no site de relacionamento Badoo</segment>
    <segment id="14">, com nome e fotos de outras pessoas</segment>
    <segment id="15">, no qual atraía suas vítimas dizendo ser uma “viúva bem-sucedida e carente”.</segment>
    <segment id="16">“Ela o atraiu e assim que a vítima desembarcou no aeroporto</segment>
    <segment id="17">, teve seus documentos retidos e dinheiro (cerca de R$ 2</segment>
    <segment id="18">,8 mil) roubados por ela.</segment>
    <segment id="19">Com ameaças</segment>
    <segment id="20">, dizendo que ele estava ilegal no país e que</segment>
    <segment id="21">sese fosse à rua a polícia o prenderia</segment>
    <segment id="22">, a vítima era impedida de pedir socorro”</segment>
    <segment id="23">, acrescenta Irineu.</segment>
    <segment id="24">Interpol em ação</segment>
    <segment id="25">O crime foi descoberto depois que o dinheiro acabou e Ivonete começou a ligar para os familiares de Alfredo</segment>
    <segment id="26">, na Argentina</segment>
    <segment id="27">, exigindo mais dinheiro.</segment>
    <segment id="28">“</segment>
    <segment id="29">A família acionou o consulado da Argentina que</segment>
    <segment id="30">, por sua vez</segment>
    <segment id="31">, acionou a Polícia Internacional (Interpol) e nos contatou”</segment>
    <segment id="32">, revelou o delegado Irineu.</segment>
    <segment id="33">Ivonete foi autuada em flagrante por cárcere privado e extorsão</segment>
    <segment id="34">, e foi encaminhada para o Conjunto Penal de Itabuna</segment>
    <segment id="35">, onde já está à disposição da Justiça.</segment>
    <segment id="36">O delegado disse ainda que Ivonete</segment>
    <segment id="37">sese passava por Suzana Schmitt e Maria de Lourdes Kano</segment>
    <segment id="38">, e teria aplicado o mesmo golpe em outros dois argentinos no início deste ano.</segment>
    <segment id="39">Ivonete</segment>
    <segment id="40">sese defendeu da acusação e disse que ela foi vítima de uma tentativa de sequestro do argentino.</segment>
  </rst>
</analysis>