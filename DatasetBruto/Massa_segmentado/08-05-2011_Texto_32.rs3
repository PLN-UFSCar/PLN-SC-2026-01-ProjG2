  <rst>
    <segment id="1">Corinthians e Santos ficam no 0 a 0 no Pacaembu

Santos e Corinthians empataram em 0 a 0 neste domingo na primeira partida da decisão do Campeonato Paulista</segment>
    <segment id="2">, no Pacaembu.</segment>
    <segment id="3">Com o estádio lotado pela torcida corintiana e a presença de Ronaldo</segment>
    <segment id="4">, o jogo teve atuações apagadas e manteve tudo igual para a partida do dia 15</segment>
    <segment id="5">, na Vila Belmiro.</segment>
    <segment id="6">Quem marcar</segment>
    <segment id="7">, leva a taça.</segment>
    <segment id="8">No caso</segment>
    <segment id="9">caso de novo empate</segment>
    <segment id="10">, o Paulistão será decidido nos pênaltis.</segment>
    <segment id="11">A julgar pela importância de Paulo Henrique Ganso para a equipe santista</segment>
    <segment id="12">, o grupo comandado por Muricy Ramalho deve entrar em campo em desvantagem</segment>
    <segment id="13">, apesar de jogar em casa</segment>
    <segment id="14">, já que o meia sentiu dores musculares na coxa direita</segment>
    <segment id="15">, após disputa de bola com Jorge Henrique</segment>
    <segment id="16">, no fim do primeiro tempo.</segment>
    <segment id="17">Após exames realizados no Hospital Sírio Libanês</segment>
    <segment id="18">, em São Paulo</segment>
    <segment id="19">, divulgou-</segment>
    <segment id="20">sese que ele sofreu uma ruptura no músculo adutor da coxa.</segment>
    <segment id="21">De acordo com o assessor de imprensa do jogador</segment>
    <segment id="22">, Ganso ficará aproximadamente 30 dias sem jogar.</segment>
    <segment id="23">Mesmo com a dupla Neymar e Ganso em campo</segment>
    <segment id="24">, o Santos esteve apagado na primeira etapa.</segment>
    <segment id="25">O primeiro</segment>
    <segment id="26">, no entanto</segment>
    <segment id="27">, mostrou a diferença que pode fazer na equipe ao driblar a zaga e chutar cruzado</segment>
    <segment id="28">, com força</segment>
    <segment id="29">, para o gol adversário</segment>
    <segment id="30">, exigindo bastante do goleiro Julio César.</segment>
    <segment id="31">Com a partida equilibrada</segment>
    <segment id="32">, Liedson assustou aos 34 do segundo tempo</segment>
    <segment id="33">, ao chutar na trave e levantando a torcido do Corinthians.

CORINTHIANS 0X0 SANTOS
Estádio: Pacaembu</segment>
    <segment id="34">, São Paulo (SP)
Árbitro: Cleber Wellington Abade
Auxiliares: Rogerio Pablos Zanardo e Fausto Augusto Viana Moretti
Cartões amarelos: Wallace (COR)</segment>
    <segment id="35">; Danilo</segment>
    <segment id="36">, Neymar (SAN)
