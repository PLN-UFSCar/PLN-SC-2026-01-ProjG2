  <rst>
    <segment id="1">Bafão musical.</segment>
    <segment id="2">Furdunço pegou!</segment>
    <segment id="3">Paraibanas querem sua parte da fortuna gerada pela música "</segment>
    <segment id="4">Ai, se</segment>
    <segment id="5">se eu te pego" de Teló</segment>
    <segment id="6">A novela sobre a autoria do refrão de “Ai</segment>
    <segment id="7">, sese eu te pego”</segment>
    <segment id="8">, sucesso na voz de Michel Teló</segment>
    <segment id="9">, ganhou novo capítulo.</segment>
    <segment id="10">Na segunda-feira</segment>
    <segment id="11">, 12, um juiz de João Pessoa determinou o bloqueio de toda a grana que as empresas de Michel Teló e outros envolvidos na confusão</segment>
    <segment id="12">, como</segment>
    <segment id="13">como Sharon Acioly</segment>
    <segment id="14">, arrecadaram com a canção.</segment>
    <segment id="15">“</segment>
    <segment id="16">Não fui notificado judicialmente”.</segment>
    <segment id="17">Essa foi a resposta de todo o povo envolvido no bafafá de “Ai</segment>
    <segment id="18">, sese eu te pego”.</segment>
    <segment id="19">As coincidências acabam por aí.</segment>
    <segment id="20">O cantor Michel Teló disse que o</segment>
    <segment id="21">casocaso parecia brincadeira de telefone sem fio.</segment>
    <segment id="22">“</segment>
    <segment id="23">Não tenho nada a ver com essa história.</segment>
    <segment id="24">Meus bens não estão bloqueados e tenho todos os direitos legais para continuar cantando a música”</segment>
    <segment id="25">, garante.</segment>
    <segment id="26">O compositor baiano Antônio Diggs também diz não saber sobre a decisão do juiz.</segment>
    <segment id="27">“Não sei do processo.</segment>
    <segment id="28">Fiz minha parte</segment>
    <segment id="29">comocomo compositor.</segment>
    <segment id="30">Dividi a autoria  com Sharon</segment>
    <segment id="31">, que eu pensava ser a autora do refrão”</segment>
    <segment id="32">, lava as mãos.</segment>
    <segment id="33">Já Sharon Acioly</segment>
    <segment id="34">, acusada de ‘roubar’ o refrão das garotas paraibanas</segment>
    <segment id="35">, prefere fechar o bico.</segment>
    <segment id="36">Adelson Barbosa</segment>
    <segment id="37">, pai de uma das supostas autoras</segment>
    <segment id="38">, afirma que as meninas aguardam o prazo de 60 dias concedido pelo juiz</segment>
    <segment id="39">para que</segment>
    <segment id="40">para que</segment>
    <segment id="41">sese conheça o valor arrecadado com a música e</segment>
    <segment id="42">sese estabeleça a devida indenização.</segment>
    <segment id="43">Não menor do que R$ 3 milhões!</segment>
    <segment id="44">Especialista fala sobre o</segment>
    <segment id="45">casocaso

Provas - Segundo o professor de direitos autorais da Ufba Rodrigo Moraes</segment>
    <segment id="46">, o registro de uma música não define a sua autoria.</segment>
    <segment id="47">“</segment>
    <segment id="48">A lei não exige o registro para prestigiar o autor</segment>
    <segment id="49">, ou seja</segment>
    <segment id="50">, a boa-fé de quem compôs.</segment>
    <segment id="51">Se as meninas provarem a coautoria</segment>
    <segment id="52">, quem</segment>
    <segment id="53">sese apropriou da letra é quem responde o processo”</segment>
    <segment id="54">, diz.</segment>
    <segment id="55">Ou seja</segment>
    <segment id="56">, Sharon pode estar em maus lençóis.</segment>
    <segment id="57">Já</segment>
    <segment id="58">Teló pode dormir tranquilo.</segment>
  </rst>
