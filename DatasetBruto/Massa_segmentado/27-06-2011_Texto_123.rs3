  <rst>
    <segment id="1">Feirantes piram com obra lenta</segment>
    <segment id="2">Comerciantes compareceram à aula inaugural de curso de qualificação</segment>
    <segment id="3">Para qualificar mais de três mil comerciantes que atuam na Feira de São Joaquim</segment>
    <segment id="4">, a  Secretaria Estadual de Turismo (Setur)</segment>
    <segment id="5">, em parceria com a Companhia de Desenvolvimento Urbano do Estado (Conder)</segment>
    <segment id="6">,  o Sebrae e a Faculdade de Nutrição da UFBA</segment>
    <segment id="7">, vai desenvolver um curso gratuito com aulas práticas e teóricas.</segment>
    <segment id="8">Ontem, durante a aula inaugural</segment>
    <segment id="9">, o secretário de turismo</segment>
    <segment id="10">, Domingos Leoneli</segment>
    <segment id="11">, apresentou parte da programação do curso</segment>
    <segment id="12">, que começa no dia 9 de julho</segment>
    <segment id="13">, e falou das melhorias físicas que a feira receberá com a reforma que já está em andamento.</segment>
    <segment id="14">“</segment>
    <segment id="15">Com a inovação</segment>
    <segment id="16">,  a feira ganhará nova  freguesia</segment>
    <segment id="17">, que são turistas</segment>
    <segment id="18">, e as vendas aumentarão”</segment>
    <segment id="19">, enfatizou o secretário.</segment>
    <segment id="20">Porém, os feirantes demonstraram insatisfação com as autoridades.</segment>
    <segment id="21">“Nossa preocupação é com a entrega das obras.</segment>
    <segment id="22">Pelo cronograma que nos foi apresentado em janeiro</segment>
    <segment id="23">, elas  deveriam ser concluídas seis meses depois</segment>
    <segment id="24">, masmas pelo andamento atual</segment>
    <segment id="25">, não serão entregues no prazo”</segment>
    <segment id="26">, revelou</segment>
    <segment id="27">, indignado</segment>
    <segment id="28">, Marcílio Costa</segment>
    <segment id="29">, presidente do Sindicato dos Feirantes.</segment>
    <segment id="30">Segundo Marcílio</segment>
    <segment id="31">, os feirantes pensavam que o deslocamento para o Galpão Água de Meninos seria um sucesso</segment>
    <segment id="32">, masmas cerca de 40% deles estão sendo prejudicados.</segment>
    <segment id="33">“Quem está</segment>
    <segment id="34">sese dando bem são os vendedores de bebidas</segment>
    <segment id="35">, porém</segment>
    <segment id="36">porém os outros comerciantes estão vendendo pouco</segment>
    <segment id="37">, pois</segment>
    <segment id="38">pois faltam clientes no local</segment>
    <segment id="39">, ao contrário da Feira em São Joaquim”</segment>
    <segment id="40">, acrescentou o presidente.</segment>
  </rst>
</analysis>