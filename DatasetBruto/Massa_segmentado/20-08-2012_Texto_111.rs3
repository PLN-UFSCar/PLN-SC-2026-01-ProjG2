  <rst>
    <segment id="1">Reggae bom rola no niver da rua</segment>
    <segment id="2">Para festejar</segment>
    <segment id="3">, os moradores da Rua 18 de Agosto organizaram eventos culturais</segment>
    <segment id="4">Em comemoraГѓВ§ГѓВЈo de aniversГѓВЎrio</segment>
    <segment id="5">, o que nГѓВЈo pode faltar ГѓВ© bolo e animaГѓВ§ГѓВЈo.</segment>
    <segment id="6">EntГѓВЈo</segment>
    <segment id="7">, o aniversГѓВЎrio da Rua 18 de Agosto</segment>
    <segment id="8">, no Candeal</segment>
    <segment id="9">, nГѓВЈo fugiu da tradiГѓВ§ГѓВЈo.</segment>
    <segment id="10">Realizada no ГѓВєltimo fim de semana e em alto estilo</segment>
    <segment id="11">,  a festa  contou com diversas atraГѓВ§ГѓВµes culturais.</segment>
    <segment id="12">Houve  shows dos grupos</segment>
    <segment id="13">Som de Sereno</segment>
    <segment id="14">, Pegada da Gente</segment>
    <segment id="15">, ForrГѓВі Seu Malaquias e muito mais.</segment>
    <segment id="16">O fim de semana ainda foi recheado com feira de arte e cultura</segment>
    <segment id="17">, oficinas de culinГѓВЎria e beleza e apresentaГѓВ§ГѓВµes de danГѓВ§a.</segment>
    <segment id="18">O melhor de tudo: de graГѓВ§a!</segment>
    <segment id="19">Гўв‚¬Е“Esse evento</segment>
    <segment id="20">ГѓВ© importante para fortalecer os conceitos culturais da regiГѓВЈo.</segment>
    <segment id="21">Toda a comunidade contribuiu</segment>
    <segment id="22">para que</segment>
    <segment id="23">para que ele acontecesse.</segment>
    <segment id="24">Sem ela</segment>
    <segment id="25">, nada disso existiriaГўв‚¬</segment>
    <segment id="26">, diz Jair Resende</segment>
    <segment id="27">, um dos organizadores da bela festa.</segment>
    <segment id="28">O aniversГѓВЎrio foi da rua</segment>
