    <segment id="42">N횄짙o fica claro</segment>
    <segment id="43">, por횄짤m</segment>
    <segment id="44">, o que acontecer횄징 em dezembro.</segment>
    <segment id="45">Nas 횄쨘ltimas semanas</segment>
    <segment id="46">, circularam rumores at횄짤 sobre uma interven횄짠횄짙o estatal 횄혻 for횄짠a.</segment>
    <segment id="47">A legisla횄짠횄짙o 횄짤 motivo de ampla pol횄짧mica na Argentina.</segment>
