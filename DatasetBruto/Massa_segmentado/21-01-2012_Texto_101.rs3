  <rst>
    <segment id="1">Gangue da Calcinha.</segment>
    <segment id="2">Quadrilha dançou</segment>
    <segment id="3">A gangue nega que vende entorpecentes e diz que o negócio delas são verduras</segment>
    <segment id="4">As cinco mulheres presas em Alagoinhas (a 108 km de Salvador) por formarem uma quadrilha de traficantes de drogas</segment>
    <segment id="5">sese defenderam dizendo que  são feirantes na Central de Abastecimento da cidade</segment>
    <segment id="6">, local onde foram presas com 77 pedras de crack.</segment>
    <segment id="7">“</segment>
    <segment id="8">Vendo verduras na feira.</segment>
    <segment id="9">Acharam a droga em um balde de lixo”</segment>
    <segment id="10">, esquiva-</segment>
    <segment id="11">sese Vanuza Pacheco dos Santos</segment>
    <segment id="12">, 29 anos.</segment>
    <segment id="13">Com exceção de Marcela Santos Nascimento</segment>
    <segment id="14">, 28, que diz ser cabeleireira</segment>
    <segment id="15">, Tatiane Alves dos Santos</segment>
    <segment id="16">, 18, Sivalda dos Santos</segment>
    <segment id="17">, 21, e Jacimara Santos de Santana</segment>
    <segment id="18">, 27, disseram ajudar</segment>
    <segment id="19">Vanuza na banca de verduras.</segment>
    <segment id="20">Mas, para a polícia</segment>
    <segment id="21">, esse não é o negócio principal delas.</segment>
    <segment id="22">A partir de denúncias anônimas apontando o envolvimento de  mulheres na venda de drogas na Central de Abastecimento</segment>
    <segment id="23">, a polícia passou semanas investigando a movimentação e conseguiu desarticular a quadrilha.</segment>
    <segment id="24">Vanuza e Jacimara já foram presas na Central de Abastecimento ano passado por tráfico de drogas.</segment>
    <segment id="25">“</segment>
    <segment id="26">Vanuza foi presa em abril e liberada em junho.</segment>
    <segment id="27">As investigações começaram a partir do nome dela”</segment>
    <segment id="28">, informa o  plantonista da delegacia de Alagoinhas</segment>
    <segment id="29">, Roberto Lima.</segment>
    <segment id="30">Vanuza também já foi presa em 2008 com 83 pedras de crack e R$ 112 em dinheiro.</segment>
    <segment id="31">Apenas Tatiane não tinha antecedentes criminais no Portal da Secretaria de Segurança Pública.</segment>
    <segment id="32">Marcela já respondeu inquérito por roubo</segment>
    <segment id="33">, em 2001</segment>
    <segment id="34">, na Delegacia de Repressão a Furtos e Roubos em Salvador.</segment>
    <segment id="35">Sivalda  ficou presa durante 11 meses por tráfico de drogas</segment>
    <segment id="36">, parte da pena cumprida durante o ano passado.</segment>
    <segment id="37">Área da gangue</segment>
    <segment id="38">No setor da Central de Abastecimento onde a gangue da calcinha atuava</segment>
    <segment id="39">, os feirantes preferiram o silêncio.</segment>
    <segment id="40">“Rapaz</segment>
    <segment id="41">, ninguém fala sobre esse assunto aqui”</segment>
    <segment id="42">, disse um deles sem</segment>
    <segment id="43">sese identificar.</segment>
    <segment id="44">Outros comerciantes falaram apenas que as mulheres circulavam pelo local realizando o comércio de drogas.</segment>
    <segment id="45">“</segment>
    <segment id="46">Elas escondiam a droga no banheiro e andavam com pouca quantidade na mão para dizer que era para uso próprio”</segment>
    <segment id="47">, explica o delegado Roberto Lima o modo de operação da quadrilha.</segment>
    <segment id="48">“Elas também escondiam a droga na vagina.</segment>
    <segment id="49">”

 

Elas querem conforto</segment>
    <segment id="50">As meninas do tráfico aproveitaram a presença da equipe de reportagem para reclamar do rango da cadeia.</segment>
    <segment id="51">“</segment>
    <segment id="52">A comida é horrível.</segment>
    <segment id="53">O fígado estava duro e cheio de nervos.</segment>
    <segment id="54">Fique aí para almoçar com a gente e veja”</segment>
    <segment id="55">, convidou Sivalda.</segment>
    <segment id="56">Vaidosas</segment>
    <segment id="57">, elas reclamaram  que estão com apenas uma muda de roupas e só poderão receber visitas na próxima quarta-feira.</segment>
    <segment id="58">Apesar de não apresentarem marcas visíveis ontem</segment>
    <segment id="59">, elas disseram ter apanhado dos policiais que realizaram a prisão na noite da última quarta-feira.</segment>
    <segment id="60">“</segment>
    <segment id="61">Eles nos agrediram para a gente dizer onde estava a droga.</segment>
    <segment id="62">Somos perseguidas pela polícia</segment>
    <segment id="63">porque</segment>
    <segment id="64">porque já fomos presas”</segment>
    <segment id="65">, conta Marcela.</segment>
  </rst>
</analysis>