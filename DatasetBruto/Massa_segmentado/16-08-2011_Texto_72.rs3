  <rst>
    <segment id="1">Pavio curto</segment>
    <segment id="2">Marido admite que Dani Bolina não leva desaforo
Mateus Verdelho</segment>
    <segment id="3">, modelo e marido da peoa que substituiu Duda Yankovich</segment>
    <segment id="4">, disse em entrevista à revista Caras que confia na mulher.</segment>
    <segment id="5">Ele garante que a bela não vai nem perceber</segment>
    <segment id="6">sese derem em cima dela</segment>
    <segment id="7">, masmas reagirá a possíveis fofocas a seu respeito.</segment>
    <segment id="8">“</segment>
    <segment id="9">A Dani é pavio curto”</segment>
    <segment id="10">, avisou.</segment>
    <segment id="11">João Kleber</segment>
    <segment id="12">, Dinei</segment>
    <segment id="13">, Thiago e Compadre Washington que</segment>
    <segment id="14">sese cuidem.</segment>
    <segment id="15">Os quatro meteram a boca na garota</segment>
    <segment id="16">, pois</segment>
    <segment id="17">pois acreditam que a modelo tem informações privilegiadas e chegou</segment>
    <segment id="18">sese achando.</segment>
    <segment id="19">Quem apostou em barracos entre Dani e Joana</segment>
    <segment id="20">sese deu mal.</segment>
    <segment id="21">As duas viveram um triângulo com o jogador Adriano e</segment>
    <segment id="22">sese estranharam no início</segment>
    <segment id="23">, masmas acabaram</segment>
    <segment id="24">sese entendendo.</segment>
    <segment id="25">Vai saber até quando!</segment>
  </rst>
</analysis>