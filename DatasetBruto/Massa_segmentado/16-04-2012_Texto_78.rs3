  <rst>
    <segment id="1">Gata tipo exportação</segment>
    <segment id="2">Ela não perde tempo e lança mão da capoeira para deixar o corpo sempre em ordem
Elisete de Araújo</segment>
    <segment id="3">, 25 anos</segment>
    <segment id="4">, vive na ponte aérea Salvador-Roma.</segment>
    <segment id="5">Na capital italiana</segment>
    <segment id="6">, ela faz parte da Companhia Brasil Bahia Show</segment>
    <segment id="7">, na qual demonstra</segment>
    <segment id="8">, por meio da dança afro</segment>
    <segment id="9">, o orgulho que tem de suas origens.</segment>
    <segment id="10">Na Soterópolis</segment>
    <segment id="11">, ela não perde tempo e</segment>
    <segment id="12">, além de exercitar seu gingado</segment>
    <segment id="13">, lança mão da capoeira para deixar o corpo sempre em ordem.</segment>
    <segment id="14">“Tenho de respeitar meu corpo</segment>
    <segment id="15">, já que ele é instrumento para o meu trabalho</segment>
    <segment id="16">comocomo dançarina e professora.</segment>
    <segment id="17">Vivo disso.</segment>
    <segment id="18">Dou aula de capoeira e dança em duas escolas municipais”</segment>
    <segment id="19">, revela a beleza negra do bairro de Massaranduba</segment>
    <segment id="20">, onde mora e costuma arrasar corações.</segment>
    <segment id="21">Mas os marmanjos não devem avançar o sinal</segment>
    <segment id="22">, já que a moça é comprometida.</segment>
    <segment id="23">“Já tenho meu gato”</segment>
    <segment id="24">, diz tímida.</segment>
  </rst>
