  <rst>
    <segment id="1">Forrozeira leva rasteira de vizinha</segment>
    <segment id="2">José é acusado de ser o mentor do assalto a Margarida
Margarida das Dores Silva dos Santos</segment>
    <segment id="3">, 68 anos</segment>
    <segment id="4">, já se</segment>
    <segment id="5">se aposentou</segment>
    <segment id="6">, masmas toda quinta-feira canta forró  no Restaurante Grande Sertão</segment>
    <segment id="7">, onde vende seu CD por R$ 5.</segment>
    <segment id="8">Ela juntou R$ 4 mil durante dois anos vendendo os discos.</segment>
    <segment id="9">Ontem, Margarida foi assaltada no bairro Rio Sena por dois homens a bordo de uma moto</segment>
    <segment id="10">, quando ia depositar o dinheiro no banco.</segment>
    <segment id="11">A cantora estava acompanhada da vizinha e amiga Maria Aparecida dos Santos</segment>
    <segment id="12">, 36 anos</segment>
    <segment id="13">, que a convenceu a ir registrar queixa na 5ª Delegacia Territorial (Periperi).</segment>
    <segment id="14">Ao serem ouvidas na 5ª DT</segment>
    <segment id="15">, os agentes perceberam o envolvimento de Maria Aparecida na ação.</segment>
    <segment id="16">“Ela disse que teve R$ 50 e o celular roubado também.</segment>
    <segment id="17">Quando pedi o número</segment>
    <segment id="18">, ela forneceu três diferentes.</segment>
    <segment id="19">O celular tocou e estava escondido na sombrinha dela.</segment>
    <segment id="20">Fomos apertando e ela confessou”</segment>
    <segment id="21">, relata o delegado plantonista da 5ª DT</segment>
    <segment id="22">, Sérgio Schilang.</segment>
    <segment id="23">Maria contou com a participação de José Teles</segment>
    <segment id="24">, 54, que foi preso com R$ 1 mil.</segment>
    <segment id="25">O dindim seria dividido entre os dois.</segment>
    <segment id="26">Segundo o delegado</segment>
    <segment id="27">, o filho de José</segment>
    <segment id="28">, Marcos da Cruz Teles e um homem conhecido</segment>
    <segment id="29">comocomo Leleu são os homens que estavam na moto.</segment>
    <segment id="30">“Estamos à procura deles”</segment>
    <segment id="31">, disse Schilang.</segment>
    <segment id="32">Tanto Maria quanto José são casados e têm filhos</segment>
    <segment id="33">, masmas são amantes.</segment>
    <segment id="34">Maria teria dito que foi pressionada por José a bolar o crime.</segment>
    <segment id="35">Ela é diarista e José vende e conserta celular no bairro da Calçada.</segment>
    <segment id="36">“</segment>
    <segment id="37">Eles foram autuados em flagrante por roubo e formação de quadrilha.</segment>
    <segment id="38">Estamos investigando a participação deles em algumas saidinhas bancárias em Periperi”</segment>
    <segment id="39">, informou o delegado.</segment>
    <segment id="40">Era como</segment>
    <segment id="41">como uma filha

Margarida das Dores lembra que conhece Maria Aparecida há cinco anos.</segment>
    <segment id="42">A relação de confiança era tão grande que Margarida já forneceu a senha da conta bancária pela qual recebe a aposentadoria para Maria sacar o dinheiro.</segment>
    <segment id="43">“Tinha ela</segment>
    <segment id="44">comocomo minha filha.</segment>
    <segment id="45">Nunca tive o que dizer contra ela.</segment>
    <segment id="46">Ela já sacou minha aposentadoria várias vezes e nunca veio faltando nada”</segment>
    <segment id="47">, conta.</segment>
    <segment id="48">Por conta dos problemas de saúde</segment>
    <segment id="49">, como</segment>
    <segment id="50">como artrose e hipertensão</segment>
    <segment id="51">, Margarida pedia para a vizinha sacar o dinheiro.</segment>
    <segment id="52">A vítima também não sabe ler.</segment>
  </rst>
</analysis>