  <rst>
    <segment id="1">Presos dois espanhóis acusados de assassinato em Arraial do Cabo
RIO - Dois espanhóis</segment>
    <segment id="2">, técnicos em engenharia</segment>
    <segment id="3">, foram presos na quinta-feira acusados do assassinato da escriturária Denise Moraes de Carvalho</segment>
    <segment id="4">, de 31 anos</segment>
    <segment id="5">, ocorrido na terça-feira de carnaval em Arraial do Cabo</segment>
    <segment id="6">, na Região dos Lagos.</segment>
    <segment id="7">Denise foi espancada até a morte durante uma tentativa de estupro.</segment>
    <segment id="8">Os estrangeiros trabalham numa empresa espanhola que presta serviços no Porto do Forno</segment>
    <segment id="9">, em Arraial</segment>
    <segment id="10">, onde estão sendo construídas estruturas para o Porto do Açu</segment>
    <segment id="11">, em São João da Barra.</segment>
    <segment id="12">Também está presa uma garçonete que assistiu ao espancamento.</segment>
    <segment id="13">Os três têm mandados de prisão temporária expedidos pela Justiça.</segment>
    <segment id="14">Segundo a delegada titular da 132ª DP (Arraial do Cabo)</segment>
    <segment id="15">, Cláudia Faissal</segment>
    <segment id="16">, a vítima era funcionária pública do estado</segment>
    <segment id="17">, morava em São João de Meriti</segment>
    <segment id="18">, na Baixada Fluminense</segment>
    <segment id="19">, e passava o carnaval em Arraial.</segment>
    <segment id="20">Os acusados</segment>
    <segment id="21">, Pedro Manoel Gomes Lozzano e Pedro Luiz Toríbio</segment>
    <segment id="22">, teriam abordado a vítima num cruzamento</segment>
    <segment id="23">, alegando que precisavam de informações.</segment>
    <segment id="24">Segundo investigações</segment>
    <segment id="25">, ela teria sido forçada a entrar no carro</segment>
    <segment id="26">, onde estaria escondida Jaqueline do Carmo</segment>
    <segment id="27">, de 21 anos.</segment>
    <segment id="28">O objetivo dos dois homens era fazer sexo grupal.</segment>
    <segment id="29">Denise não teria consentido e foi morta por espancamento.</segment>
    <segment id="30">O corpo foi encontrado atrás de uma escola na Praia do Pontal</segment>
    <segment id="31">, em Arraial.</segment>
    <segment id="32">Vítima teve o pescoço quebrado</segment>
    <segment id="33">A delegada informou que a vítima teve costelas</segment>
    <segment id="34">, o pescoço e um braço fraturados durante o espancamento.</segment>
    <segment id="35">Ela disse</segment>
    <segment id="36">, no entanto</segment>
    <segment id="37">, que o laudo do Instituto Médico-Legal (IML) não indica a ocorrência de estupro.</segment>
    <segment id="38">A polícia investiga ainda a presença de um terceiro homem durante o crime.</segment>
    <segment id="39">A polícia chegou aos acusados após um minucioso trabalho de investigação</segment>
    <segment id="40">, a partir da informação de que o grupo usou um Sandero prata.</segment>
    <segment id="41">Os policiais descobriram que havia uma empresa no Porto do Forno que fornece o mesmo modelo</segment>
    <segment id="42">, de cor igual</segment>
    <segment id="43">, para funcionários.</segment>
    <segment id="44">Um deles</segment>
    <segment id="45">sese encaixou no perfil que testemunhas traçaram de um dos acusados.</segment>
    <segment id="46">Em depoimento</segment>
    <segment id="47">, ele apontou Jaqueline</segment>
    <segment id="48">, sua namorada</segment>
    <segment id="49">, como</segment>
    <segment id="50">como seu álibi.</segment>
    <segment id="51">No entanto</segment>
    <segment id="52">, em seu depoimento</segment>
    <segment id="53">, ela caiu em contradição.</segment>
    <segment id="54">A polícia descobriu que Jaqueline pedira demissão do restaurante onde trabalhava e planejava a fuga</segment>
    <segment id="55">, quando foi presa.</segment>
  </rst>
</analysis>