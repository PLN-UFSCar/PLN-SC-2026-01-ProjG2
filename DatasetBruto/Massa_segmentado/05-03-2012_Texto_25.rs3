  <rst>
    <segment id="1">Vitória goleia e renasce</segment>
    <segment id="2">Com três de Neto Baiano na tarde de ontem</segment>
    <segment id="3">, Leão meteu 5 a 0 no Atlético</segment>
    <segment id="4">, no Barradão</segment>
    <segment id="5">O torcedor rubro-negro está aliviado após o jogo de ontem</segment>
    <segment id="6">, contra o Atlético de Alagoinhas</segment>
    <segment id="7">, no Barradão.</segment>
    <segment id="8">É que o Vitória mostrou que está na briga pelo título do Baianão com a goleada sobre o Carcará</segment>
    <segment id="9">, por 5 a 0.</segment>
    <segment id="10">Neto Baiano foi o destaque do jogo</segment>
    <segment id="11">, pois</segment>
    <segment id="12">pois marcou três gols e</segment>
    <segment id="13">sese tornou o artilheiro isolado do Estadual</segment>
    <segment id="14">, com 14</segment>
    <segment id="15">, com direito a “homenagem” ao rival Souza</segment>
    <segment id="16">, do Bahia.</segment>
    <segment id="17">O Leão foi para cima desde o início</segment>
    <segment id="18">, masmas o primeiro gol só saiu aos 34</segment>
    <segment id="19">, quando Neto Baiano aproveitou sobra de bola na área para abrir o placar.</segment>
    <segment id="20">No fim do primeiro tempo</segment>
    <segment id="21">, o pênalti sofrido por Marquinhos foi convertido por Neto: 2 a 0.</segment>
    <segment id="22">No segundo tempo</segment>
    <segment id="23">, Bira</segment>
    <segment id="24">, do Atlético</segment>
    <segment id="25">, foi expulso.</segment>
    <segment id="26">Com isso</segment>
    <segment id="27">, o jogo ficou mais fácil para o rubro-negro</segment>
    <segment id="28">, que marcou com Gabriel Paulista</segment>
    <segment id="29">, após matada no peito e chute com categoria.</segment>
    <segment id="30">Mineiro</segment>
    <segment id="31">, de fora da área</segment>
    <segment id="32">, e Neto Baiano</segment>
    <segment id="33">, depois de drible no goleiro</segment>
    <segment id="34">, encerraram a goleada.</segment>
    <segment id="35">Com o resultado</segment>
    <segment id="36">, o Leão chegou aos 23 pontos e ultrapassou o Vitória da Conquista na classificação do Campeonato Baiano.</segment>
    <segment id="37">No entanto</segment>
    <segment id="38">, o rubro-negro vai dar uma parada na competição estadual para estrear na Copa do Brasil</segment>
    <segment id="39">, contra o São Domingos</segment>
    <segment id="40">, nesta quinta-feira.</segment>
    <segment id="41">Neto Baiano ‘homenageia’ aniversariante Souza

Além de pedir música pelos três gols</segment>
    <segment id="42">, Neto Baiano prestou uma “homenagem”.</segment>
    <segment id="43">“Souza está fazendo aniversário hoje (ontem).</segment>
    <segment id="44">Dedico estes três que fiz para ele.</segment>
    <segment id="45">Parabéns</segment>
    <segment id="46">, Souza!</segment>
    <segment id="47">Tudo de bom para você”</segment>
    <segment id="48">, brincou o centroavante</segment>
    <segment id="49">, que garantiu gostar do atacante do Bahia.</segment>
    <segment id="50">“É uma disputa saudável.</segment>
    <segment id="51">É uma homenagem a ele.</segment>
    <segment id="52">Não estou brincando.</segment>
    <segment id="53">Gosto muito dele”</segment>
    <segment id="54">, justificou o camisa 9</segment>
    <segment id="55">, que provocou:</segment>
    <segment id="56">“Estão dizendo que o Vitória não está na briga e que o campeonato está na mão do líder.</segment>
    <segment id="57">Com todo respeito</segment>
    <segment id="58">, masmas importante mesmo é ser campeão no final.</segment>
    <segment id="59">É isso que queremos”</segment>
    <segment id="60">, garantiu.</segment>
  </rst>
</analysis>