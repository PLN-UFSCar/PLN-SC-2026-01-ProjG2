  <rst>
    <segment id="1">Comida está pela hora da morte!</segment>
    <segment id="2">Com os alimentos agora mais caros</segment>
    <segment id="3">, é preciso criatividade para por a comida na mesa</segment>
    <segment id="4">Se para você a expressão “a preço de banana” quer dizer  barato</segment>
    <segment id="5">, é melhor encontrar um novo ditado.</segment>
    <segment id="6">É que com a seca que assola o interior da Bahia a fruta em questão teve um aumento de até 50%.</segment>
    <segment id="7">A caixa com 15 kg</segment>
    <segment id="8">, que até o mês passado era vendida a R$ 25</segment>
    <segment id="9">, agora não custa menos que R$ 45.</segment>
    <segment id="10">“</segment>
    <segment id="11">Foi a fruta que teve o maior aumento.</segment>
    <segment id="12">Eu vendia para os meus clientes a dúzia a R$ 2</segment>
    <segment id="13">, masmas agora está saindo por R$ 3</segment>
    <segment id="14">, às vezes R$ 2</segment>
    <segment id="15">,50.</segment>
    <segment id="16">É o menor preço que posso fazer “</segment>
    <segment id="17">, explica o feirante Luís Ribeiro (foto acima)</segment>
    <segment id="18">, que há 30 anos trabalha no posto da Ceasa da Avenida Ogunjá.</segment>
    <segment id="19">O feijão é o outro vilão do aumento dos preços.</segment>
    <segment id="20">Um quilo do produto varia entre R$ 4 e R$ 9.</segment>
    <segment id="21">Para não mudar os hábitos alimentares</segment>
    <segment id="22">, o baiano precisa usar a sua criatividade e até mesmo ter muita paciência para procurar produtos com um valor mais acessível.</segment>
    <segment id="23">É isso que está fazendo a motorista de turismo Gracinete Teixeira</segment>
    <segment id="24">, que decidiu reduzir a quantidade de produtos que consome e só compra o que encontra em oferta.</segment>
    <segment id="25">“</segment>
    <segment id="26">Eu diminuí as compras de mercado que faço e apenas levo pra casa o que tá em promoção.</segment>
    <segment id="27">Mas eu tenho consciência de que só consigo fazer isso</segment>
    <segment id="28">porque</segment>
    <segment id="29">porque moro sozinha”</segment>
    <segment id="30">, explica.</segment>
    <segment id="31">Além da banana e do feijão</segment>
    <segment id="32">, o tomate</segment>
    <segment id="33">, a abóbora e o aipim são alimentos que estão com o preço disparado.</segment>
    <segment id="34">Alimentos alternativos

Para não ficar com o bolso vazio</segment>
    <segment id="35">, muita gente tem trocado os alimentos por outros mais baratos.</segment>
    <segment id="36">Veja as dicas da nutricionista Fernanda Piccolo:

Feijão</segment>
    <segment id="37">– Qualquer leguminosa</segment>
    <segment id="38">, como</segment>
    <segment id="39">como soja em grão</segment>
    <segment id="40">, ervilhas</segment>
    <segment id="41">, lentilhas e grão de bico.

Banana – Qualquer fruta de época</segment>
    <segment id="42">, desde que não seja cozida.

Aipim – Inhame</segment>
    <segment id="43">, batata-doce e fruta-pão.</segment>
    <segment id="44">Tomate – Aqui a dica é aumentar a porção de cebola</segment>
    <segment id="45">, pimentão e folhas.</segment>
    <segment id="46">Pode ficar ainda pior</segment>
    <segment id="47">Segundo o  Instituto do Meio Ambiente e Recursos Hídricos (Inema)</segment>
    <segment id="48">, a estiagem ainda vai continuar pelos próximos meses.</segment>
    <segment id="49">Como isso compromete diretamente o plantio e a colheita dos produtos agrícolas</segment>
    <segment id="50">, a tendência é que os preços continuem a subir.</segment>
    <segment id="51">De acordo com o Dieese</segment>
    <segment id="52">, o feijão registrou a quarta alta consecutiva de preço em Salvador</segment>
    <segment id="53">, com variação de 9</segment>
    <segment id="54">,14% em março.</segment>
    <segment id="55">O tomate</segment>
    <segment id="56">, que teve uma variação de 15</segment>
    <segment id="57">,76% é outro produto cujo preço tende a subir ainda mais.</segment>
  </rst>
</analysis>