  <rst>
    <segment id="1">Justiceiros do mal vão para o xadrez
Trio foi preso quando ia em busca de alguém do bando de “Paulinho da Lagoa”
Justiceiros.</segment>
    <segment id="2">É assim que Jonatas de Souza</segment>
    <segment id="3">, 19 anos</segment>
    <segment id="4">, o “Calango”</segment>
    <segment id="5">; Jucimário da Silva Machado</segment>
    <segment id="6">, 20; e Eliel Nascimento Alcântara</segment>
    <segment id="7">, 20, se</segment>
    <segment id="8">se denominam.</segment>
    <segment id="9">Eles foram presos por policiais da 52ª CIPM</segment>
    <segment id="10">, na quarta-feira</segment>
    <segment id="11">,  na Lagoa dos Patos</segment>
    <segment id="12">, em Lauro de Freitas</segment>
    <segment id="13">, quando iam vingar a morte do primo de Calango</segment>
    <segment id="14">, Flávio Rangel</segment>
    <segment id="15">,  conforme informações do Serviço de Investigação da 23ª DT (Lauro de Freitas).</segment>
    <segment id="16">Em depoimento</segment>
    <segment id="17">, o trio disse que pretendia matar qualquer integrante do grupo dos traficantes</segment>
    <segment id="18">“Paulinho da Lagoa” e Cristiano</segment>
    <segment id="19">, aos quais eles  atribuem o assassinato de Flávio</segment>
    <segment id="20">, ocorrido  na última sexta-feira</segment>
    <segment id="21">, no Chafariz.</segment>
    <segment id="22">Segundo policiais</segment>
    <segment id="23">, Jucimário e Eliel moram em Salvador e foram mandados a Lauro de Freitas para ajudar Calango</segment>
    <segment id="24">, que teria pedido ajuda.</segment>
    <segment id="25">Jucimário mora em Paripe e tem passagem na polícia por duplo homicídio.</segment>
    <segment id="26">Ele disse que foi “a mando da patroa do tráfico do subúrbio”</segment>
    <segment id="27">, que segundo ele</segment>
    <segment id="28">sese chama  Grace Kelly e seria parente de Maria Lúcia dos Santos Gomes</segment>
    <segment id="29">, 36, a Nem Gorda</segment>
    <segment id="30">, que é acusada de liderar o tráfico no Rio Sena</segment>
    <segment id="31">, e está presa em Mata Escura.</segment>
    <segment id="32">Grace Kelly é desconhecida</segment>
    <segment id="33">;</segment>
    <segment id="34">Pivô morreu</segment>
    <segment id="35">porque</segment>
    <segment id="36">porque devia</segment>
    <segment id="37">O coordenador do SI da 23ª DT</segment>
    <segment id="38">, Ubirajara Braga</segment>
    <segment id="39">, acredita que Flávio</segment>
    <segment id="40">, que era usuário de drogas</segment>
    <segment id="41">,  foi morto por dever a traficantes.</segment>
    <segment id="42">Segundo ele</segment>
    <segment id="43">, existe uma guerra entre a gangue da Lagoa dos Patos (comandada por Paulinho) e Chafariz</segment>
    <segment id="44">, cujo comando é dividido entre pequenos traficantes.</segment>
    <segment id="45">“</segment>
    <segment id="46">Nunca ouvi falar.</segment>
    <segment id="47">Só sese for uma cabeça nova assumido o comando com a prisão de Nem Gorda”</segment>
    <segment id="48">, disse o delegado da 5ª DT (Paripe)</segment>
    <segment id="49">, Antônio Carlos Magalhães Santos</segment>
    <segment id="50">, sobre Grace Kelly.</segment>
  </rst>
</analysis>