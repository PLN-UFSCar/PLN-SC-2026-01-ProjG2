  <rst>
    <segment id="1">Feira na veia!</segment>
    <segment id="2">Jake intima ator que criticou sua terra natal</segment>
    <segment id="3">A ex-BBB</segment>
    <segment id="4">, mais uma vez</segment>
    <segment id="5">, mostrou que não leva desaforo para casa.</segment>
    <segment id="6">Ainda mais quando está no seu território</segment>
    <segment id="7">, em Feira de Santana.</segment>
    <segment id="8">Ao saber que o ator Bernardo Falcone</segment>
    <segment id="9">, o Téo</segment>
    <segment id="10">, de “Rebelde”</segment>
    <segment id="11">, estaria falando mal da sua cidade natal</segment>
    <segment id="12">, a moça bateu no quarto do artista - que estava hospedado no mesmo hotel que ela durante a micareta da Princesa do Sertão - para tirar satisfação.</segment>
    <segment id="13">O rapaz deixou a moça falando sozinha</segment>
    <segment id="14">, masmas disse no Twitter que havia passado por um perrengue na festa</segment>
    <segment id="15">, sem explicar o motivo.</segment>
  </rst>
