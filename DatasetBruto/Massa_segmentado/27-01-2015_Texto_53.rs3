  <rst>
    <segment id="1">Mata Escura sofre sem transporte p횄쨘blico
Rodovi횄징rios temem entrar no bairro por conta de 횄쨈nibus queimados na 횄쨘ltima sexta</segment>
    <segment id="2">O clima de inseguran횄짠a e temor que tomou conta do bairro da Mata Escura</segment>
    <segment id="3">, desde a noite da 횄쨘ltima quinta-feira</segment>
    <segment id="4">, ainda amedronta e preocupa motoristas e cobradores de 횄쨈nibus que circulam na localidade.</segment>
    <segment id="5">Embora o policiamento tenha sido refor횄짠ado e a comunidade volte aos poucos 횄혻 rotina</segment>
    <segment id="6">, eles</segment>
    <segment id="7">sese negam a seguir viagem at횄</segment>
    <segment id="8">짤</segment>
    <segment id="9">o final de linha</segment>
    <segment id="10">e dizem temer repres횄징lia por parte dos traficantes.</segment>
    <segment id="11">A morte de Marcos Ant횄쨈nio Santos Nunes</segment>
    <segment id="12">, 34 anos</segment>
    <segment id="13">, na noite de domingo</segment>
    <segment id="14">, fortaleceu ainda mais a decis횄짙o dos rodovi횄징rios</segment>
    <segment id="15">, que n횄짙o entram na Mata Escura desde a sexta-feira</segment>
    <segment id="16">, quando dois 횄쨈nibus foram incendiados no bairro</segment>
    <segment id="17">, ap횄쨀s dois homens morrerem em confronto com a pol횄짯cia</segment>
    <segment id="18">, na noite de quinta-feira.</segment>
    <segment id="19">Segundo a Central de Comunica횄짠횄짙o de Pol횄짯cias (Centel)</segment>
    <segment id="20">, Marcos era usu횄징rio de drogas e foi executado com seis tiros na rua Parque S횄짙o Jorge rua Direta da Mata Escura</segment>
    <segment id="21">, pr횄쨀ximo ao supermercado Todo Dia.</segment>
    <segment id="22">Durante todo o dia de ontem</segment>
    <segment id="23">, os rodovi횄징rios mantiveram a orienta횄짠횄짙o do sindicato da categoria de fazerem hor횄징rio no Conjunto Arvoredo</segment>
    <segment id="24">, em Tancredo Neves.</segment>
    <segment id="25">Os passageiros s횄짙o deixados pr횄쨀ximo ao Col횄짤gio 3횂쨘 Mil횄짧nio e t횄짧m que andar cerca de tr횄짧s quil횄쨈metros at횄짤 a entrada do bairro.</segment>
    <segment id="26">Sem se</segment>
    <segment id="27">se identificar</segment>
    <segment id="28">, um motorista informou que at횄짤 os mototaxistas est횄짙o com medo de entrar no local.</segment>
    <segment id="29">A determina횄짠횄짙o 횄짤 permanecer aqui at횄짤 segunda ordem.</segment>
    <segment id="30">O final de linha s횄쨀 vai sair daqui [do Arvoredo]</segment>
    <segment id="31">, quando a Secretaria de Seguran횄짠a P횄쨘blica (SSP/BA)</segment>
    <segment id="32">sese posicionar</segment>
    <segment id="33">, afirma S횄짤rgio Silva</segment>
    <segment id="34">, diretor do Sindicato dos Rodovi횄징rios</segment>
    <segment id="35">, revelando que uma reuni횄짙o est횄징 prevista para hoje pela manh횄짙.</segment>
    <segment id="36">De acordo com o comandante da 48횂짧 CIPM (Sussuarana)</segment>
    <segment id="37">, major Jos횄짤 Luiz</segment>
    <segment id="38">, a tranquilidade e a ordem no bairro j횄징 foi retomada e n횄짙o h횄징 o que temer.</segment>
    <segment id="39">A popula횄짠횄짙o est횄징 chateada com os rodovi횄징rios.</segment>
    <segment id="40">Voc횄짧 pode ver</segment>
    <segment id="41">, o com횄짤rcio est횄징 aberto e as pessoas est횄짙o na rua.</segment>
    <segment id="42">Policiamento n횄짙o 횄짤 problema</segment>
    <segment id="43">, avaliou o major.</segment>
    <segment id="44">Os 횄쨈nibus que</segment>
    <segment id="45">sese dirigem para o Jardim Santo In횄징cio voltaram a rodar normalmente pela avenida Cardeal Avelar Brand횄짙o Vilela.</segment>
    <segment id="46">A circula횄짠횄짙o tamb횄짤m havia sido interrompida na sexta-feira.</segment>
    <segment id="47">Policiamento</segment>
    <segment id="48">횄짤 insuficiente</segment>
    <segment id="49">Segundo S횄짤rgio Silva</segment>
    <segment id="50">, uma das reivindica횄짠횄쨉es da categoria 횄짤 a reativa횄짠횄짙o da base policial que fica no final de linha do bairro.</segment>
    <segment id="51">Tem um m횄쨀dulo l횄징</segment>
    <segment id="52">, por que n횄짙o reativam?</segment>
    <segment id="53">Ele</segment>
    <segment id="54">횄</segment>
    <segment id="55">짤</segment>
    <segment id="56">seguran횄짠a n횄짙o</segment>
    <segment id="57">s횄쨀 para os rodovi횄징rios</segment>
    <segment id="58">, masmas tamb횄짤m para a comunidade</segment>
    <segment id="59">, afirma o diretor.</segment>
    <segment id="60">Silva disse ainda que o policiamento na 횄징rea 횄짤 insuficiente.</segment>
    <segment id="61">De madrugada a pol횄짯cia n횄짙o aparece.</segment>
    <segment id="62">Quando aparece</segment>
    <segment id="63">, faz a ronda e vai</segment>
    <segment id="64">embora</segment>
    <segment id="65">embora</segment>
    <segment id="66">, masmas o trabalhador fica</segment>
    <segment id="67">, revela ele</segment>
    <segment id="68">, afirmando que desde o dia 6 de janeiro espera uma posi횄짠횄짙o da SSP/BA.</segment>
    <segment id="69">Mandamos um documento para eles e at횄짤 hoje n횄짙o obtivemos resposta</segment>
    <segment id="70">, diz.</segment>
    <segment id="71">Volta 횄혻 rotina</segment>
    <segment id="72">Em ronda pelas principais ruas do bairro</segment>
    <segment id="73">, o MASSA!</segment>
    <segment id="74">verificou que a popula횄짠횄짙o voltou a circular tranquilamente.</segment>
    <segment id="75">Diferentemente da sexta-feira - quando as lojas</segment>
    <segment id="76">, o posto de sa횄쨘de</segment>
    <segment id="77">, as igrejas e as escolas permaneceram fechadas -</segment>
    <segment id="78">, hoje o clima era de seguran횄짠a e confian횄짠a entre os moradores.</segment>
    <segment id="79">Alguns s횄쨀 reclamaram da dist횄짖ncia que tinham de percorrer para pegar o 횄쨈nibus.</segment>
    <segment id="80">Est횄징 ruim</segment>
    <segment id="81">,</segment>
    <segment id="82">temos que andar muito para pegar o transporte</segment>
    <segment id="83">, reclamou uma moradora.</segment>
    <segment id="84">O com횄짤rcio est횄징 normal</segment>
    <segment id="85">, a pol횄짯cia est횄징 circulando por a횄짯. N횄짙o</segment>
    <segment id="86">sei porqu횄짧 os 횄쨈nibus n횄짙o est횄짙o entrando.</segment>
    <segment id="87">S횄징bado e domingo foram tranquilos</segment>
    <segment id="88">, informou um motorista de 43 anos</segment>
    <segment id="89">, morador da localidade.</segment>
    <segment id="90">Estes dias foram ruins.</segment>
    <segment id="91">Fechei</segment>
    <segment id="92">porque</segment>
    <segment id="93">porque n횄짙o teve movimento.</segment>
    <segment id="94">Vendo lanches</segment>
    <segment id="95">, refrigerantes e sucos</segment>
    <segment id="96">, os motoristas ficam aqui</segment>
    <segment id="97">, revelou um comerciante que trabalha numa barraca no final de linha.</segment>
    <segment id="98">Segundo ele</segment>
    <segment id="99">, o preju횄짯zo foi grande.
(Foto: Almiro Lopes)</segment>
