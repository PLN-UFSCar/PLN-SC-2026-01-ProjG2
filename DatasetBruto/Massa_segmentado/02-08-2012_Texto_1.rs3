  <rst>
    <segment id="1">Bala perdida mata pai de famГѓВ­lia</segment>
    <segment id="2">Era a primeira entrega de jornais de Nei Ferreira.</segment>
    <segment id="3">Ele voltou ao posto ensanguentado</segment>
    <segment id="4">Pai dedicado</segment>
    <segment id="5">, o funcionГѓВЎrio da empresa Rental</segment>
    <segment id="6">, Edson Nei Ferreira do Nascimento</segment>
    <segment id="7">, 48 anos</segment>
    <segment id="8">, que trabalhava</segment>
    <segment id="9">comocomo terceirizado na distribuiГѓВ§ГѓВЈo do jornal</segment>
    <segment id="10">A TARDE</segment>
    <segment id="11">, nГѓВЈo saГѓВ­a de casa sem beijar a filha Lara</segment>
    <segment id="12">, de  10 meses.</segment>
    <segment id="13">Гўв‚¬Е“Era raro</segment>
    <segment id="14">, masmas quando esquecia</segment>
    <segment id="15">, ele voltava para beijar a meninaГўв‚¬</segment>
    <segment id="16">, contou a irmГѓВЈ dele</segment>
    <segment id="17">, a professora Estermeire Ferreira do Nascimento</segment>
    <segment id="18">, 39.</segment>
    <segment id="19">HГѓВЎ quatro dias</segment>
    <segment id="20">, a menina ficou sem o carinho do pai.</segment>
    <segment id="21">Edson morreu no inГѓВ­cio da manhГѓВЈ da ГѓВєltima segunda-feira (30)</segment>
    <segment id="22">, apГѓВіs ser atingido por uma bala perdida</segment>
    <segment id="23">, quando passava de moto pela localidade conhecida</segment>
    <segment id="24">comocomo Iguatemi</segment>
    <segment id="25">, em Periperi.</segment>
    <segment id="26">O corpo dele foi sepultado no dia seguinte</segment>
    <segment id="27">, no CemitГѓВ©rio Municipal do bairro.</segment>
    <segment id="28">AlГѓВ©m de Lara</segment>
    <segment id="29">, Nei,</segment>
    <segment id="30">comocomo era conhecido</segment>
    <segment id="31">, tinha uma filha do primeiro casamento:</segment>
    <segment id="32">JГѓВ©ssica</segment>
    <segment id="33">, de 17 anos.</segment>
    <segment id="34">Segundo familiares</segment>
    <segment id="35">, uma das principais preocupaГѓВ§ГѓВµes do entregador era</segment>
    <segment id="36">sese manter empregado para poder dar Гўв‚¬Е“tudo do bom e do melhor para as filhasГўв‚¬. Ele costumava dizer que seguia o exemplo dos pais</segment>
    <segment id="37">, que sempre</segment>
    <segment id="38">sese esforГѓВ§aram para nГѓВЈo deixar faltar nada a ele aos outros filhos.</segment>
    <segment id="39">Гўв‚¬Е“Meu filho era muito cuidadoso e carinhoso comigo.</segment>
    <segment id="40">Sempre vinha saber</segment>
    <segment id="41">comocomo havia sido meu dia</segment>
    <segment id="42">, quando chegava do trabalhoГўв‚¬</segment>
    <segment id="43">, disse a mГѓВЈe</segment>
    <segment id="44">, a pensionista Neusa Ferreira do Nascimento</segment>
    <segment id="45">, 75, com a voz falhando e os olhos carregados de tristeza.</segment>
    <segment id="46">BrincalhГѓВЈo e amigo</segment>
    <segment id="47">Nei trabalhava na Rental hГѓВЎ sete anos e era tido</segment>
    <segment id="48">comocomo brincalhГѓВЈo e bom colega.</segment>
    <segment id="49">Гўв‚¬Е“Гѓв‚¬s vezes</segment>
    <segment id="50">, a turma estava meio para baixo</segment>
    <segment id="51">, ele chegava e motivava todo mundo.</segment>
    <segment id="52">Para mim</segment>
    <segment id="53">, ele era</segment>
    <segment id="54">comocomo um familiarГўв‚¬</segment>
    <segment id="55">, disse o encarregado de distribuiГѓВ§ГѓВЈo da Rental</segment>
    <segment id="56">, Elias Leolino de Souza</segment>
    <segment id="57">, 47.</segment>
    <segment id="58">Foi ele quem levou o encarregado em seu carro para o Hospital do SubГѓВєrbio.</segment>
    <segment id="59">Naquela manhГѓВЈ</segment>
    <segment id="60">, contou Elias</segment>
    <segment id="61">, os entregadores saГѓВ­ram mais tarde do posto de entrega por causa de tiros ouvidos mais cedo nas proximidades.</segment>
    <segment id="62">PolГѓВ­cia sem pistas</segment>
    <segment id="63">Quem quer que tenha efetuado os disparos</segment>
    <segment id="64">, ainda ГѓВ© um desconhecido da polГѓВ­cia.</segment>
    <segment id="65">De acordo com a delegada do Departamento de HomicГѓВ­dios (DHPP)</segment>
    <segment id="66">, Laura Argolo</segment>
    <segment id="67">, parentes e possГѓВ­veis testemunhas devem ser ouvidas atГѓВ© a prГѓВіxima semana.</segment>
    <segment id="68">O capitГѓВЈo CzГѓВ©kus</segment>
    <segment id="69">, da 18Г‚ВЄ CIPM (Periperi)</segment>
    <segment id="70">, afirmou que a companhia realiza rondas e operaГѓВ§ГѓВµes</segment>
    <segment id="71">, constantemente</segment>
    <segment id="72">, no Iguatemi.</segment>
    <segment id="73">Inclusive</segment>
    <segment id="74">, durante a madrugada.</segment>
  </rst>
