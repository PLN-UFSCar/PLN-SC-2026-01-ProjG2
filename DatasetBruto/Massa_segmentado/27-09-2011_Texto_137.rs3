  <rst>
    <segment id="1">PMs presos com R$ 13 mil do mensalão do tráfico em UPP fazem a guarda do Quartel-General
Apontados num inquérito policial-militar (IPM)</segment>
    <segment id="2">comocomo integrantes de um esquema de corrupção conhecido</segment>
    <segment id="3">comocomo mensalão do tráfico
RIO - Na UPP dos morros da Coroa</segment>
    <segment id="4">, do Fallet e do Fogueteiro</segment>
    <segment id="5">, em Santa Teresa</segment>
    <segment id="6">, um sargento e dois cabos</segment>
    <segment id="7">, que atuavam na unidade pacificadora</segment>
    <segment id="8">, foram transferidos para o Quartel-General da PM.</segment>
    <segment id="9">No dia 6 de agosto passado</segment>
    <segment id="10">, os três foram presos em flagrante com R$ 13.400 num carro estacionado em frente ao Batalhão de Choque.</segment>
    <segment id="11">O dinheiro</segment>
    <segment id="12">, segundo as investigações</segment>
    <segment id="13">, seria parte da propina paga por traficantes das comunidades do Fallet e do Fogueteiro</segment>
    <segment id="14">para que</segment>
    <segment id="15">para que PMs da UPP não reprimissem a venda de drogas nas comunidades.</segment>
    <segment id="16">No IPM</segment>
    <segment id="17">, o sargento Rinaldo do Desterro Santos é apontado</segment>
    <segment id="18">comocomo o principal articulador do esquema</segment>
    <segment id="19">, que pagaria propina ao comandante e ao subcomandante da UPP</segment>
    <segment id="20">, afastados durante a investigação.</segment>
    <segment id="21">Apesar dos indícios contra os três PMs</segment>
    <segment id="22">, o sargento e os soldados Alexandre Pinela e Gilmar Macário</segment>
    <segment id="23">, flagrados com o dinheiro</segment>
    <segment id="24">, foram lotados no QG</segment>
    <segment id="25">, onde fazem serviço de sentinela.</segment>
    <segment id="26">O advogado do sargento</segment>
    <segment id="27">, Marcos César da Silva</segment>
    <segment id="28">, nega o envolvimento de Rinaldo no esquema de corrupção e confirma que ele e os dois soldados estão lotados no comando da corporação</segment>
    <segment id="29">, aguardando o desfecho do processo na Auditoria Militar.</segment>
    <segment id="30">O caso</segment>
    <segment id="31">caso dos três PMs não é isolado.</segment>
    <segment id="32">Na terça-feira</segment>
    <segment id="33">, O GLOBO revelou que o sargento Antônio Carlos Nascimento Ribeiro - citado em dois autos de resistência (mortes de civis em confronto com a polícia) investigados a pedido da juíza Patrícia Acioli - também havia sido transferido ao QG da PM</segment>
    <segment id="34">, onde atua</segment>
    <segment id="35">comocomo motorista no gabinete do comandante-geral da corporação</segment>
    <segment id="36">, coronel Mário Sérgio Duarte.</segment>
    <segment id="37">Procurada pelo GLOBO</segment>
    <segment id="38">, a PM não</segment>
    <segment id="39">sese pronunciou sobre as transferências dos policiais investigados para o QG.</segment>
  </rst>
</analysis>