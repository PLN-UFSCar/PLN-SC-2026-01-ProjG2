  <rst>
    <segment id="1">Reencontro de primeira
RESUMO DA NOTÍCIA</segment>
    <segment id="2">Torcedor volta a ver em casa na Série A e Trio Elétrico do Tricolor encara o Flamengo</segment>
    <segment id="3">Finalmente o Bahia pôde sentir ontem o gostinho de estar de volta à elite.</segment>
    <segment id="4">Após sete anos</segment>
    <segment id="5">, o Esquadrão voltou a enfrentar um dos maiores times do Brasileirão e conseguiu mostrar para o resto do País que a parada aqui vai ser dura.</segment>
    <segment id="6">O empate alcançado no finalzinho</segment>
    <segment id="7">, com um jogador a menos</segment>
    <segment id="8">, deu um sabor de vitória que encheu o torcedor de orgulho.</segment>
    <segment id="9">“Quem quiser bater o Bahia em Pituaçu vai ter que batalhar muito”</segment>
    <segment id="10">, opina o comerciante Jonas Carvalho</segment>
    <segment id="11">, que fez coro à maioria dos torcedores para os erros de arbitragem.</segment>
    <segment id="12">“</segment>
    <segment id="13">Os jogadores do Flamengo foram tratados</segment>
    <segment id="14">comocomo</segment>
    <segment id="15">sese fossem de porcelana.</segment>
    <segment id="16">Qualquer bobagem era motivo de falta a favor deles”</segment>
    <segment id="17">, disse Luiz Santos.</segment>
    <segment id="18">Enquanto isso</segment>
    <segment id="19">, as faltas em cima do Bahia e até um pênalti foram ignorados pelo juiz.</segment>
    <segment id="20">Mesmo desfavorecido pela arbitragem</segment>
    <segment id="21">, a partida foi marcada pelo equilíbrio.</segment>
    <segment id="22">Se o primeiro tempo foi dominado pelo Bahia</segment>
    <segment id="23">, na segunda etapa o tricolor recuou e deu espaço para Ronaldinho e companhia.</segment>
    <segment id="24">Jobson provou que foi uma excelente contratação marcando dois.</segment>
    <segment id="25">Lulinha e Gabriel também foram elogiados pela torcida.</segment>
    <segment id="26">“Achei que esse Gabriel fosse inexperiente</segment>
    <segment id="27">, masmas jogou demais”</segment>
    <segment id="28">, opina João Antonio Ramos.</segment>
    <segment id="29">O Trio Elétrico do Bahia conseguiu frear o Bonde</segment>
    <segment id="30">, imagine o que fará com quem vier.</segment>
    <segment id="31">Ronaldinho diz que Flamengo dominou o jogo</segment>
    <segment id="32">Na visão do autor do primeiro gol do Mengão</segment>
    <segment id="33">, o time teve mais posse de bola nos 90 minutos.</segment>
    <segment id="34">“Nossos erros não podem apagar nosso bom jogo.</segment>
    <segment id="35">Dominamos a partida</segment>
    <segment id="36">, masmas tomamos três gols em três erros nossos”.</segment>
  </rst>
</analysis>