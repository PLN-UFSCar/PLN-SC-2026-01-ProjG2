  <rst>
    <segment id="1">Flamengo afina os acordes para decisão antes da festa de aniversário
RIO - Primeiro a obrigação</segment>
    <segment id="2">, depois o lazer</segment>
    <segment id="3">, ainda que os preparativos de um e de outro ocorram simultaneamente</segment>
    <segment id="4">, a alguns metros de distância.</segment>
    <segment id="5">Preferência musical e amigo de vários jogadores do elenco rubro-negro</segment>
    <segment id="6">, o sambista Arlindo Cruz esteve ontem no Ninho do Urubu</segment>
    <segment id="7">, onde assistiu a parte do coletivo comandado por Vanderlei Luxemburgo e gravou uma chamada de televisão para a festa de aniversário que o Flamengo promoverá na noite de segunda-feira na Fundição Progresso</segment>
    <segment id="8">, na Lapa.</segment>
    <segment id="9">Antes,</segment>
    <segment id="10">porémporém</segment>
    <segment id="11">, há o compromisso mais importante</segment>
    <segment id="12">, amanhã à tarde</segment>
    <segment id="13">, contra o Coritiba.</segment>
    <segment id="14">Numa rodada em que Corinthians e Fluminense jogam em casa contra times da zona do rebaixamento</segment>
    <segment id="15">, e Botafogo e Vasco</segment>
    <segment id="16">sese enfrentam</segment>
    <segment id="17">, voltar de Curitiba com a vitória é fundamental.</segment>
    <segment id="18">O Flamengo não terá Alex Silva</segment>
    <segment id="19">, suspenso</segment>
    <segment id="20">, o que pode não ser a única surpresa na zaga.</segment>
    <segment id="21">Depois de ser poupado durante a semana por dores musculares</segment>
    <segment id="22">, Welinton participou do treino de ontem.</segment>
    <segment id="23">Mas foi escalado</segment>
    <segment id="24">, por opção de Luxemburgo</segment>
    <segment id="25">, na equipe reserva.</segment>
    <segment id="26">O treinador não informou</segment>
    <segment id="27">sese foi mesmo uma barração ou</segment>
    <segment id="28">sese quis testar no treino a dupla David Braz e Ronaldo Angelim por não ter certeza ainda de que Welinton poderá atuar.</segment>
    <segment id="29">Enquanto rolava o coletivo - que confirmou Thomás no time -</segment>
    <segment id="30">, Arlindo Cruz</segment>
    <segment id="31">, junto do sambista Leandro Sapucahy</segment>
    <segment id="32">, cantava músicas de exaltação ao rubro-negro numa gravação de promoção da festa da próxima segunda.</segment>
    <segment id="33">Para evitar aliar ainda mais o clima de festa ao treino</segment>
    <segment id="34">, a gravação foi rapidamente transferida da beira do gramado para a sala de imprensa.

-</segment>
    <segment id="35">Rumo ao hepta.</segment>
    <segment id="36">O torcedor do Flamengo não desiste nunca.</segment>
    <segment id="37">Conheço alguns jogadores.</segment>
    <segment id="38">Ronaldinho</segment>
    <segment id="39">, Léo Moura</segment>
    <segment id="40">, Welinton</segment>
    <segment id="41">, Willians</segment>
    <segment id="42">, Alex Silva...</segment>
    <segment id="43">Às vezes aparecem no samba nos dias de folga - disse Arlindo.

Contratos com Traffic</segment>
    <segment id="44">Gaúcho de nascimento e carioca no gosto musical</segment>
    <segment id="45">, Ronaldinho ensaiou rápida dança ao deixar o gramado.</segment>
    <segment id="46">Longe do Ninho do Urubu</segment>
    <segment id="47">, dirigentes do Flamengo e da Traffic estavam reunidos na Zona Sul para discutir os contratos que definem a parceria e até hoje não foram assinados.</segment>
    <segment id="48">O impasse levou a empresa a suspender</segment>
    <segment id="49">, já há três meses</segment>
    <segment id="50">, o pagamento de sua parte nos salários de Ronaldinho.</segment>
    <segment id="51">Segundo representantes de ambos</segment>
    <segment id="52">, há consenso e os papeis estarão assinados até semana que vem.</segment>
    <segment id="53">Mais do que a redivisão de lucros e direitos de cada um - que continuarão basicamente</segment>
    <segment id="54">comocomo acordado em janeiro -</segment>
    <segment id="55">, a discussão é sobre garantias para evitar prejuízos.</segment>
    <segment id="56">Avaliando que não obteve retorno em 2011</segment>
    <segment id="57">, a Traffic quer que os contratos expressem que ela tem exclusividade para negociar patrocínio do uniforme.</segment>
    <segment id="58">O Flamengo não</segment>
    <segment id="59">sese opõe</segment>
    <segment id="60">, e diz que isso já ocorreu em 2011</segment>
    <segment id="61">, embora</segment>
    <segment id="62">embora a Traffic tenha</segment>
    <segment id="63">sese sentindo alijada da negociação do patrocínio master com a P&amp;G</segment>
    <segment id="64">, em agosto.</segment>
    <segment id="65">O clube lembra que a Traffic não havia conseguido patrocinadores até então.</segment>
    <segment id="66">A Traffic tem ainda outras fontes de retorno ao investimento anual de R$ 9 milhões:</segment>
    <segment id="67">gerenciará os programas de fidelidade e sócio-torcedor</segment>
    <segment id="68">, em gestação</segment>
    <segment id="69">, e tem a conta de publicidade de Ronaldinho em ações que não envolvam o clube.</segment>
  </rst>
</analysis>