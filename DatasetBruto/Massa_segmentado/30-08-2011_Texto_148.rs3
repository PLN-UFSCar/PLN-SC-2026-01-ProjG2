  <rst>
    <segment id="1">Vasco volta à rotina por 90 minutos
RIO - Uma noite repleta de sensações estranhas aguarda os jogadores do Vasco nesta quarta</segment>
    <segment id="2">, quando pisarem o gramado de São Januário para o jogo com o Ceará.</segment>
    <segment id="3">A começar pelo horário das 18h</segment>
    <segment id="4">, pouco usual para um dia de semana.</segment>
    <segment id="5">Mas o horário é o de menos.</segment>
    <segment id="6">Afinal</segment>
    <segment id="7">, uma pergunta ronda a cabeça dos jogadores vascaínos:</segment>
    <segment id="8">comocomo</segment>
    <segment id="9">sese concentrar num jogo sobre o qual</segment>
    <segment id="10">, admitem todos</segment>
    <segment id="11">, ninguém conseguiu sequer pensar nos últimos dias?</segment>
    <segment id="12">O pensamento está longe</segment>
    <segment id="13">, voltado para a recuperação do técnico Ricardo Gomes</segment>
    <segment id="14">, que luta pela vida após o acidente vascular encefálico que sofreu no jogo com o Flamengo.</segment>
    <segment id="15">Do drama do treinador</segment>
    <segment id="16">, da vontade de oferecê-lo uma vitória</segment>
    <segment id="17">, os vascaínos tentam tirar força.</segment>
    <segment id="18">Caiu nas mãos de Cristóvão Borges</segment>
    <segment id="19">, até semana passada o auxiliar de Ricardo</segment>
    <segment id="20">, uma chance que muitos almejam: comandar o Vasco.</segment>
    <segment id="21">E o treinador admite: não sente qualquer satisfação.</segment>
    <segment id="22">Já os jogadores têm pela frente uma partida que pode colocá-los até na liderança do Brasileiro.</segment>
    <segment id="23">Mas ninguém parece</segment>
    <segment id="24">sese comover com a possibilidade.</segment>
    <segment id="25">O que antes era obsessão</segment>
    <segment id="26">, agora</segment>
    <segment id="27">sese tornou a vitória menos importante que o elenco gostaria de obter.</segment>
    <segment id="28">Mobilização</segment>
    <segment id="29">, isto sim</segment>
    <segment id="30">, o time promete ao saber que um grupo de torcedores quer fazer uma oração por Ricardo Gomes antes do apito inicial.</segment>
    <segment id="31">E o elenco quer tomar parte.</segment>
    <segment id="32">Na terça pela manhã</segment>
    <segment id="33">, no campo de São Januário</segment>
    <segment id="34">, acontecia um treino recreativo em que</segment>
    <segment id="35">, mais do que descontração</segment>
    <segment id="36">, predominava a ansiedade por notícias.</segment>
    <segment id="37">Antes, o assistente técnico Gaúcho reuniu os jogadores para um relato pessoal.</segment>
    <segment id="38">Contou sobre um problema de saúde grave com o pai</segment>
    <segment id="39">, agora recuperado.</segment>
    <segment id="40">Gaúcho disse ao grupo o quanto sofreu</segment>
    <segment id="41">, a dificuldade que teve de dormir</segment>
    <segment id="42">, masmas enfatizou o final feliz da história e a importância de cada um valorizar o fato de ter saúde.</segment>
    <segment id="43">Na véspera</segment>
    <segment id="44">, um dos médicos do clube explicou em detalhes ao elenco o que é o problema de Ricardo Gomes.</segment>
    <segment id="45">E, diante da preocupação geral</segment>
    <segment id="46">, ouviu uma série de perguntas.</segment>
    <segment id="47">Diego</segment>
    <segment id="48">Souza admitiu a dificuldade de</segment>
    <segment id="49">sese concentrar na partida contra o Ceará.

- Está todo mundo chateado</segment>
    <segment id="50">, nem pensamos muito no jogo</segment>
    <segment id="51">, só em enviar pensamentos positivos ao Ricardo.</segment>
    <segment id="52">O jogo vai acontecer</segment>
    <segment id="53">, e o que podemos fazer é dar o máximo</segment>
    <segment id="54">para que</segment>
    <segment id="55">para que</segment>
    <segment id="56">, quando o Ricardo acordar</segment>
    <segment id="57">, receba boas notícias.</segment>
    <segment id="58">Depois</segment>
    <segment id="59">, esperar que tenhamos boas notícias</segment>
    <segment id="60">, que ele acordou bem</segment>
    <segment id="61">, sem sequelas - disse.</segment>
    <segment id="62">- Vamos ter que nos desligar por 90 minutos.</segment>
    <segment id="63">E jogar por ele.</segment>
    <segment id="64">Se vencermos</segment>
    <segment id="65">, ficará mais claro o quanto o trabalho dele é bom.</segment>
    <segment id="66">Problemas nas laterais</segment>
    <segment id="67">Cristóvão ressaltou que é impossível sentir satisfação por assumir o time.

- Não tem alegria.</segment>
    <segment id="68">A única satisfação será fazer a vontade do Ricardo</segment>
    <segment id="69">, que é o time jogar bem e seguir vencendo.</segment>
    <segment id="70">É o que podemos fazer</segment>
    <segment id="71">, o que ele gostaria que a gente fizesse.</segment>
    <segment id="72">Temos que rezar</segment>
    <segment id="73">, torcer por ele e nos concentrarmos por um momento no jogo para satisfazê-lo - disse Cristóvão.</segment>
    <segment id="74">- A pancada foi forte</segment>
    <segment id="75">, é tudo muito recente.</segment>
    <segment id="76">Mas a missão é imediata: o jogo com o Ceará.</segment>
    <segment id="77">Cristóvão não terá o lateral-direito Fágner e Jumar</segment>
    <segment id="78">, que vinha atuando na esquerda.</segment>
    <segment id="79">Os substitutos serão Allan e Márcio Careca.</segment>
    <segment id="80">Juninho Pernambucano</segment>
    <segment id="81">, poupado do treino</segment>
    <segment id="82">, vai jogar.</segment>
    <segment id="83">Vasco x Ceará

Local: São Januário

Data: 31/08</segment>
    <segment id="84">, às 18h

Árbitro: Emerson de Almeida Ferreira (MG)

Vasco: Fernando Prass</segment>
    <segment id="85">, Allan</segment>
    <segment id="86">, Dedé</segment>
    <segment id="87">, Renato Silva e Márcio Careca</segment>
    <segment id="88">; Rômulo</segment>
    <segment id="89">, Eduardo Costa</segment>
    <segment id="90">, Juninho Pernambucano e Diego Souza</segment>
    <segment id="91">; Éder Luís e Alecsandro.</segment>
    <segment id="92">Ceará: Diego</segment>
    <segment id="93">, Boiadeiro</segment>
    <segment id="94">, Edmílson</segment>
    <segment id="95">, Erivélton e Vicente</segment>
    <segment id="96">; Michel</segment>
    <segment id="97">, Cléber</segment>
    <segment id="98">, Eusébio e Thiago Humberto</segment>
    <segment id="99">; Osvaldo e Marcelo Nicácio.</segment>
  </rst>
