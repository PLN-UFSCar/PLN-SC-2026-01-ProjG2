  <rst>
    <segment id="1">Gol de Henrique dá vitória a Fla
RIO - Mais de 80 mil pessoas</segment>
    <segment id="2">, apesar da noite fria</segment>
    <segment id="3">, estiveram no Maracanã ontem</segment>
    <segment id="4">, para ver Vasco e Flamengo</segment>
    <segment id="5">, estreando no turno de classificação</segment>
    <segment id="6">O jôgo</segment>
    <segment id="7">, de um modo geral</segment>
    <segment id="8">, foi bem disputado</segment>
    <segment id="9">, apesar dos desfalques da equipe rubro-negra.</segment>
    <segment id="10">O Vasco dominou grande parte do encontro</segment>
    <segment id="11">, masmas não soube abrir o caminho do arco</segment>
    <segment id="12">, enquanto o Flamengo não deixou escapar a sua maior "chance"</segment>
    <segment id="13">, ao fazer o tento da vitória por intermédio de Henrique.</segment>
    <segment id="14">O árbitro do match</segment>
    <segment id="15">, Armando Marques</segment>
    <segment id="16">, esteve muito mal</segment>
    <segment id="17">, deixando de assinalar um penalty escandaloso cometido pelo rubro-negro Bolero.

QUADROS - FLAMENGO: Fernando</segment>
    <segment id="18">, Marinho</segment>
    <segment id="19">, Ouraci</segment>
    <segment id="20">, Bolero e Jordan</segment>
    <segment id="21">; Carlinhos e Gérson</segment>
    <segment id="22">;</segment>
    <segment id="23">Joel, Henrique</segment>
    <segment id="24">, Dida e Babá</segment>
    <segment id="25">; VASCO: Miguel</segment>
    <segment id="26">, Paulinho</segment>
    <segment id="27">, Belini</segment>
    <segment id="28">, Barbosinha e Dario</segment>
    <segment id="29">; Laerte e Roberto Pinto</segment>
    <segment id="30">; Sabará</segment>
    <segment id="31">, Lorico</segment>
    <segment id="32">, Javan e Da Silva.</segment>
    <segment id="33">Pequenos surpreendem na estréia</segment>
    <segment id="34">Bem mais do que</segment>
    <segment id="35">sese possa imaginar</segment>
    <segment id="36">, a vitória do Canto do Rio sôbre o Madureira (2x1) foi mais importante que o triunfo rubro-negro sôbre o Vasco.</segment>
    <segment id="37">Na partida de ontem</segment>
    <segment id="38">, válida pela rodada inaugural do Campeonato Carioca</segment>
    <segment id="39">, em General Severiano</segment>
    <segment id="40">, jogavam dois quadros ameaçados de desclassificação</segment>
    <segment id="41">, enquanto no Maracanã atuavam candidatos certo à classificação.</segment>
    <segment id="42">Tratava-</segment>
    <segment id="43">sese de dois pontos irrecuperáveis para o vencido de ontem</segment>
    <segment id="44">, daí a razão da tristeza no vestiário do Madureira após o match.</segment>
    <segment id="45">Já o São Cristóvão proporcionou</segment>
    <segment id="46">, em São Januário</segment>
    <segment id="47">, a primeira surprêsa do certame</segment>
    <segment id="48">, pelo 0 x 0 com o Bangu e</segment>
    <segment id="49">, principalmente</segment>
    <segment id="50">, pela exibição de seu team.</segment>
  </rst>
</analysis>