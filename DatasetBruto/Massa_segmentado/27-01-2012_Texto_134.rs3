  <rst>
    <segment id="1">Água-dura fica mais controlada na casa
Depois da confusão do casal Monique e Daniel</segment>
    <segment id="2">, Boninho resolveu segurar mais as bebida</segment>
    <segment id="3">As farras no BBB costumam ser regadas a muita bebida</segment>
    <segment id="4">,  o que deixa os brothers ainda mais animados para curtir a noite de badalação.</segment>
    <segment id="5">Mas, depois do rolo que teve houve Daniel e Monique</segment>
    <segment id="6">, causado pelo excesso de bebidas alcoólicas</segment>
    <segment id="7">, parece que tudo mudou.</segment>
    <segment id="8">Desde a Festa das Rosas</segment>
    <segment id="9">, os brothers vêm reclamando da pouca quantidade de álcool.</segment>
    <segment id="10">Na Festa Burlesca</segment>
    <segment id="11">, que aconteceu no sábado passado</segment>
    <segment id="12">, a situação</segment>
    <segment id="13">sese repetiu e os brothers reclamaram de novo.</segment>
    <segment id="14">“Eu quero cerva!</segment>
    <segment id="15">Eu quero cerva!</segment>
    <segment id="16">”, gritou Rafa</segment>
    <segment id="17">, muito alterado.</segment>
    <segment id="18">Anteontem na Festa Halloween</segment>
    <segment id="19">, os confinados  fizeram birra ao ver pouca quantidade de cerveja.</segment>
    <segment id="20">A sister Renata chegou a implorar: "</segment>
    <segment id="21">Preciso de mais bebida</segment>
    <segment id="22">, por favor</segment>
    <segment id="23">, todo mundo quer ficar louco".</segment>
    <segment id="24">Mas, nada disso foi mostrado pela edição do programa.</segment>
    <segment id="25">Talvez a postura adotada pela produção seja para evitar que a cena protagonizada por Monique e Daniel  seja repetida por outros casais.</segment>
  </rst>
