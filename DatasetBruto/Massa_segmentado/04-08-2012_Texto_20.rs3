    <segment id="24">Como o ano de 2014 cismava em</segment>
    <segment id="25">sese aproximar</segment>
    <segment id="26">, a desconfian횄짠a foi crescendo: atrasos nas obras de infraestrutura</segment>
    <segment id="27">, a횄짠횄쨉es desastrosas da pol횄짯cia</segment>
    <segment id="28">, corrup횄짠횄짙o at횄짤 com o dinheiro destinado a v횄짯timas de enchentes.</segment>
    <segment id="29">E logo a desconfian횄짠a aprendeu a falar:</segment>
    <segment id="30">"</segment>
    <segment id="31">Imagina na Copa!</segment>
    <segment id="32">"</segment>
