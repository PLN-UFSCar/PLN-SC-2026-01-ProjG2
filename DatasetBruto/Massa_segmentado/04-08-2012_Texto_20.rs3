    <segment id="17">O Brasil</segment>
    <segment id="18">, aquele pa횄짯s com tr횄짖nsito de manh횄짙 e engarrafamento 횄혻 noite?</segment>
    <segment id="19">O Brasil</segment>
    <segment id="20">, aquela praia ali perto de Buenos Aires</segment>
    <segment id="21">, com macacos e jacar횄짤s?</segment>
    <segment id="22">O Brasil</segment>
