    <segment id="46">"</segment>
    <segment id="47">Dengue</segment>
    <segment id="48">Tipo 4?</segment>
    <segment id="49">"Imagina...</segment>
    <segment id="50">"</segment>
    <segment id="51">O bord횄짙o ganhou as conversas da cidade e "viralizou" (Estrangeirismos?</segment>
    <segment id="52">"</segment>
    <segment id="53">Imagina na Copa!</segment>
    <segment id="54">")</segment>
    <segment id="55">nas redes sociais.</segment>
    <segment id="56">E como</segment>
    <segment id="57">como todo mundo resolveu fazer o exerc횄짯cio de futurologia</segment>
    <segment id="58">, a Revista</segment>
    <segment id="59">O GLOBO pegou carona no escracho: convidamos dez personalidades para escrever textos</segment>
    <segment id="60">, imaginando</segment>
