    <segment id="5">, Zurique</segment>
    <segment id="6">, quando o Brasil foi anunciado pela Fifa</segment>
    <segment id="7">comocomo sede da Copa de 2014.</segment>
    <segment id="8">Mal a not횄짯cia fez ecoar um grito euf횄쨀rico de Brasil-il-il nos quatro cantos do mundo</segment>
    <segment id="9">, a desconfian횄짠a</segment>
    <segment id="10">, ainda rec횄짤m-nascida</segment>
