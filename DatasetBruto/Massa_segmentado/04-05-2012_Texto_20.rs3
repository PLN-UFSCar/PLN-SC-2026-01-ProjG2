  <rst>
    <segment id="1">"</segment>
    <segment id="2">Superlua</segment>
    <segment id="3">"</segment>
    <segment id="4">é atração no céu neste fim de semana
RIO - Uma "Superlua"</segment>
    <segment id="5">, a única de 2012</segment>
    <segment id="6">, foi a grande atração do céu na madrugada deste sábado para domingo.</segment>
    <segment id="7">À 00h35 de domingo</segment>
    <segment id="8">, o único satélite natural da Terra atingiu sua fase cheia praticamente ao mesmo tempo em que esteve no perigeu</segment>
    <segment id="9">, isto é</segment>
    <segment id="10">, o ponto de sua órbita em que fica mais próximo do nosso planeta.</segment>
    <segment id="11">Segundo a Nasa</segment>
    <segment id="12">, ela pareceu até 14% maior e 30% mais brilhante que uma Lua cheia "normal".</segment>
    <segment id="13">O termo científico para o fenômeno é Lua de perigeu.</segment>
    <segment id="14">As luas de perigeu variam de tamanho por causa do formato oval da órbita do satélite</segment>
    <segment id="15">, semelhante à eclipse que a Terra e os outros planetas orbitam em torno do Sol.</segment>
    <segment id="16">Isso faz com que de um lado</segment>
    <segment id="17">, o perigeu</segment>
    <segment id="18">, ela esteja cerca de 50 mil quilômetros mais próxima do que do outro</segment>
    <segment id="19">, o apogeu.</segment>
    <segment id="20">Neste domingo</segment>
    <segment id="21">, ela esteve no perigeu à 00h34</segment>
    <segment id="22">, apenas um minuto antes de ficar totalmente cheia</segment>
    <segment id="23">, em uma sincronização quase perfeita.</segment>
    <segment id="24">Mas embora</segment>
    <segment id="25">embora a Lua vá estar maior e mais brilhante</segment>
    <segment id="26">, foi difícil perceber isso.</segment>
    <segment id="27">No alto do céu</segment>
    <segment id="28">, sem pontos de referência e de escala</segment>
    <segment id="29">, uma "Superlua" pode parecer igual a qualquer outra Lua cheia.</segment>
    <segment id="30">Por isso</segment>
    <segment id="31">, é melhor observar a Lua quando ela estiver mais baixa no horizonte.</segment>
    <segment id="32">Por razões ainda não totalmente compreendidas pelos astrônomos e psicólogos que estudam a percepção humana</segment>
    <segment id="33">, isso faz com que o satélite pareça bem maior que o natural</segment>
    <segment id="34">, já que sua luz tem que atravessar áreas com árvores</segment>
    <segment id="35">, prédios ou outros objetos que podem dar algum senso de escala.</segment>
    <segment id="36">Com a Lua de perigeu</segment>
    <segment id="37">, essa ilusão tende a ficar ainda mais impressionante.</segment>
    <segment id="38">No Rio de Janeiro</segment>
    <segment id="39">, ela vai nasceu às 16h59</segment>
    <segment id="40">, pondo-</segment>
    <segment id="41">sese às 5h27 deste domingo.</segment>
  </rst>
</analysis>