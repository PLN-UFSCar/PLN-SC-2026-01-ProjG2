  <rst>
    <segment id="1">Uma ribanceira no meio do caminho</segment>
    <segment id="2">Bandido morre após roubar carro e sofrer acidente</segment>
    <segment id="3">Uma perseguição policial a dois assaltantes terminou com a morte de um dos criminosos</segment>
    <segment id="4">, ontem</segment>
    <segment id="5">, em São Marcos.

Desta vez</segment>
    <segment id="6">, o óbito não foi consequência de uma troca de tiros</segment>
    <segment id="7">, masmas de uma trapalhada do bandido que dirigia o carro na fuga.</segment>
    <segment id="8">Ao tentar escapar por uma rua sem saída</segment>
    <segment id="9">, projetou o veículo em uma ribanceira de três metros.</segment>
    <segment id="10">O motorista conseguiu escapar a pé</segment>
    <segment id="11">, porém</segment>
    <segment id="12">porém Peterson Santos da Silva</segment>
    <segment id="13">, 24, morreu com o impacto.</segment>
    <segment id="14">O carro</segment>
    <segment id="15">, o VW Gol branco (JPE-4591)</segment>
    <segment id="16">, havia sido roubado pela dupla em Castelo Branco</segment>
    <segment id="17">, por volta das 12h20 – cerca de meia hora antes do acidente.</segment>
    <segment id="18">Os ladrões foram perseguidos por policiais militares da 47ª CIPM (Pau da Lima).</segment>
    <segment id="19">“Iniciamos a perseguição na Via Regional e fomos no encalço até a rua do posto médico de São Marcos.</segment>
    <segment id="20">Eles entraram em alta velocidade</segment>
    <segment id="21">, acredito que não sabiam</segment>
    <segment id="22">sese tratar de um beco sem saída.</segment>
    <segment id="23">O motorista até tentou frear</segment>
    <segment id="24">, masmas não o bastante para evitar o acidente”</segment>
    <segment id="25">, relatou o soldado Anaxágoras.</segment>
    <segment id="26">O acidente poderia ter um desfecho mais trágico</segment>
    <segment id="27">, pois</segment>
    <segment id="28">pois o carro tombou num vão entre duas casas.</segment>
    <segment id="29">Antes do Gol</segment>
    <segment id="30">, os criminosos roubaram uma Saveiro.</segment>
  </rst>
