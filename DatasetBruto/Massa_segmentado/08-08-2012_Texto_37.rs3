  <rst>
    <segment id="1">Gordo vai ter que fazer dieta na cadeia
Robson Trindade dos Santos</segment>
    <segment id="2">Гѓ</segment>
    <segment id="3">В© apontado</segment>
    <segment id="4">comocomo o matador de uma quadrilha de traficantes
Robson Trindade dos Santos</segment>
    <segment id="5">, 26 anos</segment>
    <segment id="6">, o Gordo</segment>
    <segment id="7">, ГѓВ©  apontado pela polГѓВ­cia</segment>
    <segment id="8">comocomo um dos matadores e gerente de uma Гўв‚¬Е“boca de fumoГўв‚¬ na localidade de Caipe</segment>
    <segment id="9">, em SГѓВЈo Francisco do Conde.</segment>
    <segment id="10">Gordo,  Marcelo Carvalho AraГѓВєjo</segment>
    <segment id="11">, 31, o Galego</segment>
    <segment id="12">, e os irmГѓВЈos Davson Santos Barbosa</segment>
    <segment id="13">, 23, e Daniel dos Santos Barbosa</segment>
    <segment id="14">, 19, o Tequinho</segment>
    <segment id="15">, foram os responsГѓВЎveis por sete homicГѓВ­dios ocorridos nos ГѓВєltimos 15 meses nas cidades de Candeias</segment>
    <segment id="16">, SГѓВЈo Francisco do Conde e Madre de Deus (Grande Salvador)</segment>
    <segment id="17">, conforme o delegado da 21Г‚ВЄ DT (SГѓВЈo Francisco do Conde)</segment>
    <segment id="18">, Bruno Oliveira.</segment>
    <segment id="19">Eles foram apresentados  pela polГѓВ­cia na tarde de ontem</segment>
    <segment id="20">, na sede da instituiГѓВ§ГѓВЈo</segment>
    <segment id="21">, na Piedade.</segment>
    <segment id="22">O quarteto</segment>
    <segment id="23">, segundo a polГѓВ­cia</segment>
    <segment id="24">,  faz parte de uma  quadrilha de trГѓВЎfico de drogas liderada por  Geilson da ConceiГѓВ§ГѓВЈo Santos</segment>
    <segment id="25">, o GГѓВЄ CabeГѓВ§ГѓВЈo</segment>
    <segment id="26">, e cuja atuaГѓВ§ГѓВЈo abrange  essas trГѓВЄs cidades.</segment>
    <segment id="27">Entre as vГѓВ­timas do bando estГѓВЈo os traficantes</segment>
    <segment id="28">MaurГѓВ­cio dos Santos Pinho</segment>
    <segment id="29">,  Edvaney Francelino Pereira</segment>
    <segment id="30">,  Paulino dos Santos JГѓВєnior e Gileno Carvalho Lemos Гўв‚¬</segment>
    <segment id="31">вЂњ todos mortos no perГѓВ­odo entre abril de 2011 e abril de 2012.</segment>
    <segment id="32">Гўв‚¬Е“A quadrilha toda</segment>
    <segment id="33">, incluindo as trГѓВЄs cidades</segment>
    <segment id="34">, possui uma mГѓВ©dia de 50 integrantes e ГѓВ© responsГѓВЎvel por</segment>
    <segment id="35">, pelo menos 30 homicГѓВ­dios nesses municГѓВ­piosГўв‚¬</segment>
    <segment id="36">, afirmou o titular da 21Г‚ВЄ DT</segment>
    <segment id="37">, delegado Bruno Oliveira.</segment>
    <segment id="38">Гўв‚¬Е“Muitas vГѓВ­timas foram usuГѓВЎrios ou pessoas que adquiraram drogas para revender e nГѓВЈo pagaram por algum motivoГўв‚¬</segment>
    <segment id="39">, completou.</segment>
    <segment id="40">De acordo com o ele</segment>
    <segment id="41">, a maioria</segment>
    <segment id="42">, cerca de 30 integrantes</segment>
    <segment id="43">, atua</segment>
    <segment id="44">comocomo aviГѓВЈo (responsГѓВЎvel por levar  a droga ao usuГѓВЎrio).</segment>
    <segment id="45">Гўв‚¬Е“SГѓВЈo usuГѓВЎrios de drogas que acabaram</segment>
    <segment id="46">sese envolvendo com o trГѓВЎfico para sustentar o vГѓВ­cioГўв‚¬</segment>
    <segment id="47">, informou.</segment>
    <segment id="48">PolГѓВ­cia ficou de tocaia</segment>
    <segment id="49">Gordo foi preso na ГѓВєltima segunda-feira (6) por policiais da 21Г‚ВЄ DT em uma pensГѓВЈo na cidade de Cruz das Almas</segment>
    <segment id="50">, apГѓВіs a polГѓВ­cia receber informaГѓВ§ГѓВµes de que ele estava na cidade em processo de retirada de habilitaГѓВ§ГѓВЈo para carro.</segment>
    <segment id="51">Davson foi preso no mesmo dia.</segment>
    <segment id="52">Os policiais pediram para Gordo marcar um encontro com ele por telefone e quando o rapaz chegou ao local combinado</segment>
    <segment id="53">, na Boca da Mata</segment>
    <segment id="54">, deu de cara com os policiais.</segment>
    <segment id="55">Daniel</segment>
    <segment id="56">, o Tequinho</segment>
    <segment id="57">, sese entregou na 21Г‚ВЄ DT</segment>
    <segment id="58">, na manhГѓВЈ de ontem</segment>
    <segment id="59">, ao saber que estava sendo procurado pela polГѓВ­cia.</segment>
    <segment id="60">AГѓВ§ГѓВЈo em dupla</segment>
    <segment id="61">Marcelo Carvalho AraГѓВєjo</segment>
    <segment id="62">, o Galego</segment>
    <segment id="63">, segundo a polГѓВ­cia</segment>
    <segment id="64">, tambГѓВ©m atuava</segment>
    <segment id="65">comocomo matador da quadrilha juntamente com Gordo.</segment>
    <segment id="66">Parte dos sete homicГѓВ­dios ocorridos nos ГѓВєltimos 15 meses foi praticada pela dupla.</segment>
    <segment id="67">Гўв‚¬Е“ApГѓВіs receberem informaГѓВ§ГѓВµes sobre o paradeiro das vГѓВ­timas</segment>
    <segment id="68">, Galego e Gordo chegavam ao local de moto</segment>
    <segment id="69">, surpreendiam a vГѓВ­tima e deflagravam diversos tiros</segment>
    <segment id="70">, principalmente</segment>
    <segment id="71">, no abdГѓВґmen e cabeГѓВ§aГўв‚¬</segment>
    <segment id="72">, informou o delegado.</segment>
    <segment id="73">Galego foi preso em flagrante</segment>
    <segment id="74">, hГѓВЎ dois meses</segment>
    <segment id="75">, apГѓВіs matar um homem durante uma discussГѓВЈo em uma mesa de bar em SГѓВЈo Francisco do Conde.</segment>
    <segment id="76">Gordo, Davson</segment>
    <segment id="77">, Tequinho e Galego tinham mandos de prisГѓВЈo preventiva em aberto.</segment>
    <segment id="78">Inclusive</segment>
    <segment id="79">, Galego e Davson sГѓВЈo acusados de terem estuprado uma adolescente em SГѓВЈo Francisco do Conde.</segment>
    <segment id="80">Гўв‚¬Е“Eles matam sem penaГўв‚¬
Гўв‚¬Е“O bando</segment>
    <segment id="81">ГѓВ© muito cruel</segment>
    <segment id="82">.</segment>
    <segment id="83">Eles matam sem pena e matam por dГѓВ­vida.</segment>
    <segment id="84">GГѓВЄ CabeГѓВ§ГѓВЈo e Gordo sГѓВЈo os mais perigososГўв‚¬</segment>
    <segment id="85">, afirmou o delegado Bruno Oliveira.</segment>
    <segment id="86">Inclusive</segment>
    <segment id="87">, alГѓВ©m da participaГѓВ§ГѓВЈo nos sete homicГѓВ­dios</segment>
    <segment id="88">, Gordo ГѓВ© acusado pela polГѓВ­cia de ter cometido uma tentativa de homicГѓВ­dio e outros cinco assassinatos.</segment>
    <segment id="89">Existem dois mandados de prisГѓВЈo preventiva em aberto contra GГѓВЄ CabeГѓВ§ГѓВЈo</segment>
    <segment id="90">, que estГѓВЎ foragido.</segment>
    <segment id="91">Conforme a polГѓВ­cia</segment>
    <segment id="92">, ele tentou matar o traficante Tiago de Andrade Viana  por ele ter assassinado uma ex-namorada de Gordo.</segment>
    <segment id="93">A jovem teria sido apontada</segment>
    <segment id="94">comocomo dedo duro.</segment>
  </rst>
</analysis>