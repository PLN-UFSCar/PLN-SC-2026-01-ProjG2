  <rst>
    <segment id="1">Tragﾃδｩdia na BR</segment>
    <segment id="2">Cinco mortos e 22 feridos na estrada</segment>
    <segment id="3">Cinco pessoas morreram e 22 ficaram feridas em um acidente de ﾃδｴnibus</segment>
    <segment id="4">, na madrugada de ontem.</segment>
    <segment id="5">As vﾃδｭtimas fatais - trﾃδｪs homens e duas mulheres - nﾃδ｣o haviam sido identificados atﾃδｩ o fechamento desta ediﾃδｧﾃδ｣o.</segment>
    <segment id="6">O veﾃδｭculo despencou de uma ribanceira com cerca de 50 metros</segment>
    <segment id="7">, no km 344 da BR-381</segment>
    <segment id="8">, perto do municﾃδｭpio de Bela Vista</segment>
    <segment id="9">, em Minas Gerais.</segment>
    <segment id="10">Os 27 passageiros saﾃδｭram da cidade baiana de Ribeira do Pombal</segment>
    <segment id="11">, a 289 km de Salvador</segment>
    <segment id="12">, com destino a Sﾃδ｣o Paulo.</segment>
    <segment id="13">Segundo a Polﾃδｭcia Rodoviﾃδ｡ria Federal da Bahia</segment>
    <segment id="14">, o motorista alegou falhas no sistema mecﾃδ｢nico do carro.</segment>
    <segment id="15">Entre os 22 feridos</segment>
    <segment id="16">, nove jﾃδ｡ foram liberados.</segment>
    <segment id="17">Uma jovem de 16 anos e um adulto de 59 tiveram traumatismo craniano e foram encaminhados a um hospital de Belo Horizonte.</segment>
    <segment id="18">Ainda sem identificaﾃδｧﾃδ｣o</segment>
    <segment id="19">, a menina tem estado grave.</segment>
    <segment id="20">O homem ﾃδｩ Alﾃδｭpio Eduardo Santana</segment>
    <segment id="21">, que passa bem</segment>
    <segment id="22">, masmas nﾃδ｣o hﾃδ｡ previsﾃδ｣o de alta.</segment>
    <segment id="23">(Ludmila Silveira).</segment>
    <segment id="24">Buzu estﾃδ｡ irregular</segment>
    <segment id="25">Segundo a polﾃδｭcia</segment>
    <segment id="26">, o ﾃδｴnibus tem registro na Agﾃδｪncia Nacional de Transportes Terrestres</segment>
    <segment id="27">, masmas a documentaﾃδｧﾃδ｣o que regulamenta viagens interestaduais nﾃδ｣o foi encontrada.</segment>
    <segment id="28">ﾃ｢竄ｬﾅ鄭 informaﾃδｧﾃδ｣o preliminar ﾃδｩ de que o ﾃδｴnibus estava transitando irregularmenteﾃ｢竄ｬ</segment>
    <segment id="29">, afirma Mﾃδｩrcia Oliveira</segment>
    <segment id="30">, a chefe de comunicaﾃδｧﾃδ｣o da PRF-BA.</segment>
    <segment id="31">Entre as ferragens foi encontrado rebite</segment>
    <segment id="32">, droga sintﾃδｩtica capaz de inibir o sono.</segment>
    <segment id="33">Mas o motorista negou a posse da substﾃδ｢ncia.</segment>
    <segment id="34">O ﾃδｴnibus ﾃδｩ Gil Tur Turismo</segment>
    <segment id="35">, que foi procurada</segment>
    <segment id="36">, masmas nﾃδ｣o retornou as ligaﾃδｧﾃδｵes.</segment>
  </rst>
