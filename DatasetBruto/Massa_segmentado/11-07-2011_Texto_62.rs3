  <rst>
    <segment id="1">Grana extra para 131 mil aposentados</segment>
    <segment id="2">O aumento médio no benefício desses segurados será de R$ 184</segment>
    <segment id="3">,86</segment>
    <segment id="4">O ministro da Previdência</segment>
    <segment id="5">, Garibaldi Alves</segment>
    <segment id="6">, anunciou ontem que o governo vai pagar a revisão do teto do INSS a partir de setembro.</segment>
    <segment id="7">A decisão vai beneficiar mais de 131 mil pessoas que começaram a receber aposentadorias e pensões entre 5 de abril de 1991 e 1º de janeiro de 2004.</segment>
    <segment id="8">O aumento médio no benefício desses segurados será de R$ 184</segment>
    <segment id="9">,86.</segment>
    <segment id="10">Os segurados que</segment>
    <segment id="11">sese aposentaram pelo teto neste período não precisam procurar a Previdência Social para solicitar a revisão</segment>
    <segment id="12">, que será automática.</segment>
    <segment id="13">A decisão do governo cumpre determinação do Supremo Tribunal Federal que</segment>
    <segment id="14">, em setembro de 2010</segment>
    <segment id="15">, estabeleceu a revisão do teto para todos os beneficiários que começaram a receber o pagamento do INSS a partir de 1988 e não tiveram reajuste incorporado ao salário.</segment>
    <segment id="16">A revisão é válida</segment>
    <segment id="17">porque</segment>
    <segment id="18">porque em dezembro de 1998 e em janeiro de 2004 o governo elevou o teto previdenciário acima do que era pago aos segurados que recebiam esse valor</segment>
    <segment id="19">, masmas não incorporou a diferença aos benefícios pagos na época.</segment>
    <segment id="20">O aumento será incluído já na folha de agosto.</segment>
    <segment id="21">Segundo o INSS</segment>
    <segment id="22">, o impacto mensal será de R$ 28 milhões.</segment>
    <segment id="23">Pagamento dos atrasados:</segment>
    <segment id="24">Dá R$ 11</segment>
    <segment id="25">,5 mil por pessoa

Além do reajuste</segment>
    <segment id="26">, os segurados do INSS terão direito ao pagamento dos atrasados nos últimos cinco anos – no valor médio de R$ 11</segment>
    <segment id="27">,5 mil por beneficiário.</segment>
    <segment id="28">O pagamento dos valores retroativos</segment>
    <segment id="29">, que somam R$ 1</segment>
    <segment id="30">,6 bilhão</segment>
    <segment id="31">, será definido hoje.</segment>
    <segment id="32">Uma das ideias é parcelar os atrasados.</segment>
    <segment id="33">“Dependemos agora de uma decisão da equipe econômica”</segment>
    <segment id="34">, disse o presidente do INSS</segment>
    <segment id="35">, Mauro Luciano Hauschild.</segment>
    <segment id="36">Também na folha de agosto (com pagamento no início de setembro)</segment>
    <segment id="37">, os aposentados receberão o 13º salário.</segment>
    <segment id="38">Segundo o ministro da Previdência</segment>
    <segment id="39">, Garibaldi Alves</segment>
    <segment id="40">, a medida já foi acertada e deverá ser objeto de um decreto da presidente Dilma Rousseff.</segment>
  </rst>
</analysis>