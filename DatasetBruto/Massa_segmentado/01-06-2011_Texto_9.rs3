  <rst>
    <segment id="1">Santos empata com o Cerro e está na final da Libertadores
RIO - O Santos empatou em 3 a 3 com o Cerro Porteño no jogo de volta da semifinal da Copa Libertadores</segment>
    <segment id="2">, no estádio La Olla Azulgrana</segment>
    <segment id="3">, em Assunção (PAR)</segment>
    <segment id="4">, e garantiu seu lugar na decisão da competição continental.</segment>
    <segment id="5">O Peixe</segment>
    <segment id="6">sese valeu da vantagem obtida no jogo de ida</segment>
    <segment id="7">, quando venceu a equipe paraguaia por 1 a 0 no Pacaembu.</segment>
    <segment id="8">Agora, o time da Baixada disputa o título da Libertadores contra o vencedor de Peñarol (URU) e Vélez Sarsfield (ARG).</segment>
    <segment id="9">No jogo de ida entre estas duas equipes</segment>
    <segment id="10">, o time uruguaio venceu</segment>
    <segment id="11">, em casa</segment>
    <segment id="12">, por 1 a 0.</segment>
    <segment id="13">A partida de volta será nesta quinta-feira.</segment>
    <segment id="14">No primeiro tempo</segment>
    <segment id="15">, o Santos abriu 3 a 1.</segment>
    <segment id="16">Na segunda etapa</segment>
    <segment id="17">, o que</segment>
    <segment id="18">sese viu foi um grande recuo do Santos e o Cerro comandando o ataque até empatar a partida.</segment>
    <segment id="19">Zé Eduardo abriu o placar logo aos dois minutos de jogo</segment>
    <segment id="20">, completando de cabeça cruzamento de Elano.</segment>
    <segment id="21">Aos 27 saiu o segundo gol santista</segment>
    <segment id="22">, em um lance bisonho.</segment>
    <segment id="23">Pedro Benítez recuou de cabeça e o goleiro paraguaio</segment>
    <segment id="24">Barreto saltou para frente</segment>
    <segment id="25">, errando na bola.</segment>
    <segment id="26">Frango inacreditável.
Aos 31</segment>
    <segment id="27">, César Benítez diminuiu para o Cerro de cabeça.</segment>
    <segment id="28">Mas ainda antes do intervalo o Santos marcou de novo</segment>
    <segment id="29">, em um belo gol de Neymar.</segment>
    <segment id="30">O Santos recuou muito no segundo tempo e Lucero e Fabbro marcaram belos gols para empatar para o Cerro.</segment>
    <segment id="31">Porém, o time paraguaio ainda precisava mais dois gols para chegar à final.</segment>
    <segment id="32">O técnico Muricy Ramalho foi atingido por um objeto arremessado da arquibancada</segment>
    <segment id="33">, e a torcida santista presente no estádio sofreu com uma chuva de pedras atiradas pelos paraguaios.
CERRO PORTEÑO (PAR) 3</segment>
    <segment id="34">X 3 SANTOS
Estádio: La Olla Azulgrana</segment>
    <segment id="35">, Assunção (PAR)</segment>
    <segment id="36">Árbitro: Wilmar Roldán (COL)
Cartões amarelos: Iturbe</segment>
