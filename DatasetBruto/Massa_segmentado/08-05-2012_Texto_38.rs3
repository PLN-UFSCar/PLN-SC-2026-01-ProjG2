  <rst>
    <segment id="1">Estudante sofre sequestro-relâmpago no Fundão
RIO - Antigo problema da Ilha do Fundão</segment>
    <segment id="2">, um sequestro-relâmpago voltou a ocorrer no campus da Universidade Federal do Rio de Janeiro (UFRJ) na manhã de terça-feira.</segment>
    <segment id="3">Um aluno de pós-graduação foi abordado por quatro homens armados</segment>
    <segment id="4">, por volta das 7h30m</segment>
    <segment id="5">, quando chegava de carro à Coppead</segment>
    <segment id="6">, o instituto de pós-graduação e pesquisa em administração da universidade.</segment>
    <segment id="7">O jovem chegou a levar uma coronhada e foi colocado dentro do carro dos bandidos</segment>
    <segment id="8">, com uma camisa cobrindo os olhos.</segment>
    <segment id="9">Cerca de duas horas depois</segment>
    <segment id="10">, ele foi deixado na Vila do João</segment>
    <segment id="11">, no Complexo da Maré</segment>
    <segment id="12">, em Bonsucesso.</segment>
    <segment id="13">No início do ano passado</segment>
    <segment id="14">, ocorreram cinco sequestros relâmpago na cidade universitária.</segment>
    <segment id="15">Enquanto esteve sequestrado</segment>
    <segment id="16">, o jovem de 25 anos foi obrigado a revelar as senhas de seus cartões.</segment>
    <segment id="17">Em compras e saques</segment>
    <segment id="18">, os bandidos levaram cerca de R$ 5 mil</segment>
    <segment id="19">, além de celular e outros pertences.</segment>
    <segment id="20">Seu carro também não havia sido encontrado até a noite de ontem.</segment>
    <segment id="21">A vítima levou cinco pontos na cabeça.</segment>
    <segment id="22">O boletim de ocorrência foi registrado na 10 DP (Botafogo).</segment>
    <segment id="23">Segundo a assessoria de imprensa da Polícia Civil</segment>
    <segment id="24">, o delegado da 37 DP (Ilha do Governador)</segment>
    <segment id="25">, Deoclécio Francisco de Assis Filho</segment>
    <segment id="26">, vai ouvir o estudante novamente.</segment>
    <segment id="27">Atualmente</segment>
    <segment id="28">, um convênio entre a UFRJ e a Secretaria de Segurança garante a presença de policiais civis à paisana e de cinco carros da PM no campus.</segment>
    <segment id="29">Há ainda a presença de seguranças contratados pela universidade.</segment>
    <segment id="30">Segundo o prefeito do Fundão</segment>
    <segment id="31">, Ivan Ferreira Carmo</segment>
    <segment id="32">, desde fevereiro não havia uma ocorrência do tipo:

- Na época</segment>
    <segment id="33">, reorganizamos a equipe de segurança.</segment>
    <segment id="34">É possível que os bandidos tenham observado e encontrado uma falha</segment>
    <segment id="35">, masmas vamos corrigi-la.</segment>
    <segment id="36">Dados do Instituto de Segurança Pública mostram</segment>
    <segment id="37">, no primeiro trimestre deste ano</segment>
    <segment id="38">, 18 roubos com condução da vítima para saque em instituição financeira no estado</segment>
    <segment id="39">, ante 16</segment>
    <segment id="40">, em 2011.</segment>
    <segment id="41">Bandidos agridem jovem e fazem saques e compras no valor de R$ 5 mil</segment>
    <segment id="42">, usando cartões da vítima</segment>
  </rst>
