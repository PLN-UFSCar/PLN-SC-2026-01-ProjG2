  <rst>
    <segment id="1">Bonde do Flamengo no caminho certo

THIAGO NEVES:</segment>
    <segment id="2">'Estamos jogando</segment>
    <segment id="3">comocomo time grande'
BLOG: '</segment>
    <segment id="4">O Mais Querido'</segment>
    <segment id="5">, o blog do torcedor do Flamengo
- O nosso projeto é o sétimo título do Flamengo no Campeonato Brasileiro e começamos bem.</segment>
    <segment id="6">O Ronaldinho está</segment>
    <segment id="7">sese readaptando</segment>
    <segment id="8">, e o time tem que ajudá-lo.</segment>
    <segment id="9">Olhando para a frente</segment>
    <segment id="10">, vejo que estamos no caminho certo - afirmou o treinador rubro-negro.</segment>
    <segment id="11">Apesar da boa atuação na estreia</segment>
    <segment id="12">, Luxemburgo sabe que o Flamengo ainda tem carências.</segment>
    <segment id="13">A principal delas no ataque.</segment>
    <segment id="14">O sonho continua sendo Vágner Love</segment>
    <segment id="15">, do CSKA Moscou</segment>
    <segment id="16">, masmas a diretoria já tem um plano B para o</segment>
    <segment id="17">casocaso de o atacante não ser liberado.</segment>
    <segment id="18">O alvo é André</segment>
    <segment id="19">, ex-Santos</segment>
    <segment id="20">, que está sem chance no Bordeaux</segment>
    <segment id="21">, da França.</segment>
    <segment id="22">O passe do atacante pertence ao Dínamo Kiev</segment>
    <segment id="23">, da Ucrânia.</segment>
    <segment id="24">- O André é um nome que também agrada e</segment>
    <segment id="25">, como</segment>
    <segment id="26">como é jovem (20 anos)</segment>
    <segment id="27">, pode valer o esforço.</segment>
    <segment id="28">Ainda não fizemos propostas nem sabemos ainda</segment>
    <segment id="29">comocomo a faremos.</segment>
    <segment id="30">Mas temos interesse.</segment>
    <segment id="31">Não podemos apostar todas as fichas em um único jogador.</segment>
    <segment id="32">Se a coisa emperra</segment>
    <segment id="33">, acabamos ficando sem ninguém - explicou a presidente Patrícia Amorim.</segment>
    <segment id="34">Já outro problema crônico</segment>
    <segment id="35">, a lateral esquerda</segment>
    <segment id="36">, parece perto de uma solução.</segment>
    <segment id="37">O clube</segment>
    <segment id="38">sese acertou com Júnior César.</segment>
    <segment id="39">Agora, só falta pagar ao São Paulo</segment>
    <segment id="40">, clube com o qual o lateral tem contrato até dezembro de 2012.
- Está tudo bem encaminhado</segment>
    <segment id="41">, masmas é preciso esperar o jogador assinar o contrato direitinho - frisou Luxemburgo.</segment>
    <segment id="42">Além de acertar a contratação de Júnior César</segment>
    <segment id="43">, a diretoria do Flamengo tem outra missão esta semana.</segment>
    <segment id="44">Até mais importante.</segment>
    <segment id="45">Os jogadores e o treinador estão cobrando o prêmio prometido pela conquista invicta do Campeonato Carioca.</segment>
    <segment id="46">O vice de finanças</segment>
    <segment id="47">, Michel Levy</segment>
    <segment id="48">, reconhece a dívida</segment>
    <segment id="49">, que seria de R$ 35 mil para cada jogador</segment>
    <segment id="50">, masmas não deu prazo para quitá-la.</segment>
    <segment id="51">Patrícia Amorim preferiu minimizar o problema.
- Não vejo isso</segment>
    <segment id="52">comocomo um grande problema.</segment>
    <segment id="53">Premiação é uma coisa que foge do cronograma.</segment>
    <segment id="54">Fomos campeões no dia 1 de maio e</segment>
    <segment id="55">, de lá para cá</segment>
    <segment id="56">, fizemos investimentos.</segment>
    <segment id="57">Espero fazer o pagamento até o fim da semana.</segment>
    <segment id="58">O dinheiro para o pagamento da premiação deverá sair do novo contrato de televisão</segment>
    <segment id="59">, que ainda precisa ser aprovado pelo Conselho Deliberativo do clube.</segment>
    <segment id="60">O Flamengo deve receber R$ 20 milhões de adiantamento.</segment>
  </rst>
</analysis>