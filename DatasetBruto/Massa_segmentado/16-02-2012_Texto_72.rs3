  <rst>
    <segment id="1">Índia retada Arrasa na Boa Vista</segment>
    <segment id="2">Os marmanjos podem tirar o cavalinho da chuva</segment>
    <segment id="3">, pois</segment>
    <segment id="4">pois a moça já tem dono...</segment>
    <segment id="5">A gata Vanessa Ferreira</segment>
    <segment id="6">, 18, é bastante moleca e adora estar com os amigos.</segment>
    <segment id="7">Curtição é com ela mesmo.</segment>
    <segment id="8">“Adoro ir à praia e curtir uma boa festa</segment>
    <segment id="9">, principalmente</segment>
    <segment id="10">sese for com o Eva</segment>
    <segment id="11">, minha banda preferida”</segment>
    <segment id="12">, conta a estudante.</segment>
    <segment id="13">Os traços indígenas</segment>
    <segment id="14">, herdados dos avós</segment>
    <segment id="15">, chamam a atenção.</segment>
    <segment id="16">“Quero investir na carreira de modelo</segment>
    <segment id="17">, masmas também pretendo ser nutricionista”</segment>
    <segment id="18">, diz acertiva.</segment>
    <segment id="19">Por enquanto</segment>
    <segment id="20">, ela só nutre fantasias.</segment>
    <segment id="21">Mas os marmanjos podem tirar o cavalinho da chuva</segment>
    <segment id="22">, pois</segment>
    <segment id="23">pois a moça já tem dono.</segment>
    <segment id="24">“</segment>
    <segment id="25">Ele é ciumento</segment>
    <segment id="26">, masmas disfarça bem.</segment>
    <segment id="27">Eu é que sou brava”</segment>
    <segment id="28">, confessa.</segment>
  </rst>
</analysis>