  <rst>
    <segment id="1">Tentativa de assalto e saque em Itapuã</segment>
    <segment id="2">Quatro homens tentaram assaltar a joalheria Anel e Cordão</segment>
    <segment id="3">Quatro homens tentaram assaltar a joalheria Anel e Cordão</segment>
    <segment id="4">, ontem</segment>
    <segment id="5">, na Avenida Dorival Caymmi</segment>
    <segment id="6">, em Itapuã.</segment>
    <segment id="7">“</segment>
    <segment id="8">Um deles saiu armado da loja</segment>
    <segment id="9">, seguido pelo dono e o segurança</segment>
    <segment id="10">, também armados.</segment>
    <segment id="11">Houve troca de tiros e o Exército chegou”</segment>
    <segment id="12">, diz a ambulante Eliene Barbosa.</segment>
    <segment id="13">Ninguém foi preso ou prestou queixa</segment>
    <segment id="14">, até o início da noite.</segment>
    <segment id="15">Na madrugada</segment>
    <segment id="16">, a Ricardo Eletro foi saqueada  por homens que invadiram a loja com um carro.</segment>
