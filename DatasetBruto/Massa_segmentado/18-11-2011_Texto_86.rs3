  <rst>
    <segment id="1">Vasco vai decidir fora de casa vaga na final da Sul-Americana
RIO - Pela primeira vez na atual edição da Copa Sul-Americana o Vasco vai decidir a vaga para a próxima fase fora de casa.</segment>
    <segment id="2">Na semifinal contra o Universidad de Chile</segment>
    <segment id="3">, a primeira partida será em São Januário</segment>
    <segment id="4">, na quarta-feira que vem</segment>
    <segment id="5">, dia 23</segment>
    <segment id="6">, às 21h50</segment>
    <segment id="7">m.</segment>
    <segment id="8">O jogo da volta está marcado para a semana seguinte</segment>
    <segment id="9">, dia 30</segment>
    <segment id="10">, no Estádio Nacional de Santiago</segment>
    <segment id="11">, o mesmo onde o clube conquistou invicto o Sul-Americano de 1948.</segment>
    <segment id="12">O cruzamento nas semifinais foi definido na noite de quinta-feira.</segment>
    <segment id="13">O Universidad de Chile</segment>
    <segment id="14">, algoz do Flamengo nas oitavas de final</segment>
    <segment id="15">, confirmou o favoritismo e aplicou 3 a 0 no Arsenal de Sarandí</segment>
    <segment id="16">, da Argentina</segment>
    <segment id="17">, em Santiago</segment>
    <segment id="18">, pelas quartas de final.</segment>
    <segment id="19">O time chileno já tinha vencido o primeiro jogo por 2 a 1</segment>
    <segment id="20">, fora de casa.</segment>
    <segment id="21">Em Santiago</segment>
    <segment id="22">, o Universidad jamais esteve ameaçado.</segment>
    <segment id="23">O primeiro tempo terminou 2 a 0</segment>
    <segment id="24">, com gols de Eduardo Vargas e Francisco Castro.</segment>
    <segment id="25">Na segunda etapa</segment>
    <segment id="26">, Gustavo Canales</segment>
    <segment id="27">, logo aos 10 minutos</segment>
    <segment id="28">, consolidou o placar.

- É um adversário muito forte</segment>
    <segment id="29">, assisti a uma parte do primeiro tempo</segment>
    <segment id="30">, tem vários jogadores bons no ataque.</segment>
    <segment id="31">Vamos ter que marcá- los forte.</segment>
    <segment id="32">Vamos fazer o resultado aqui em São Januário para jogar lá mais tranquilo - disse o volante Rômulo.</segment>
    <segment id="33">A outra chave será entre o argentino Vellez Sarsfield</segment>
    <segment id="34">, que já estava classificado</segment>
    <segment id="35">, e a LDU</segment>
    <segment id="36">, do Equador</segment>
    <segment id="37">, que sofreu nesta quinta</segment>
    <segment id="38">masmas conseguiu a vaga nos pênaltis</segment>
    <segment id="39">, diante do Libertad</segment>
    <segment id="40">, no Paraguai.</segment>
    <segment id="41">No caso</segment>
    <segment id="42">caso da LDU a classificação foi bem menos tranquila.</segment>
    <segment id="43">Na verdade</segment>
    <segment id="44">, dramática.</segment>
    <segment id="45">Em casa o time equatoriano tinha vencido por 1 a 0.</segment>
    <segment id="46">Nesta quinta-feira</segment>
    <segment id="47">, no Paraguai</segment>
    <segment id="48">, o Libertad devolveu o placar</segment>
    <segment id="49">, gol de Pablo Velázquez aos 44 do segundo tempo.</segment>
    <segment id="50">Nos pênaltis</segment>
    <segment id="51">, refeita da frustração no tempo normal</segment>
    <segment id="52">, a LDU venceu por 5 a 4.</segment>
    <segment id="53">O herói foi o goleiro Domínguez</segment>
    <segment id="54">, que defendeu a cobrança de Maciel.</segment>
    <segment id="55">Se passar na semifinal</segment>
    <segment id="56">, o Vasco decidirá o título fora de casa</segment>
    <segment id="57">, em Buenos Aires</segment>
    <segment id="58">, sese tiver</segment>
    <segment id="59">comocomo adversário o Velez.</segment>
    <segment id="60">Se o rival for a LDU</segment>
    <segment id="61">, a partida decisiva será disputada em São Januário.</segment>
  </rst>
</analysis>