  <rst>
    <segment id="1">Bandido atira na testa de comerciante</segment>
    <segment id="2">Maria quis acompanhar o filho em perseguição aos ladrões que roubaram seu mercado</segment>
    <segment id="3">O triste desfecho do assalto ao Supermercado Fortaleza no bairro de Itinga</segment>
    <segment id="4">, em Lauro de Freitas (Grande Salvador)</segment>
    <segment id="5">,</segment>
    <segment id="6">mostra que reagir é pior escolha em situações de roubo.</segment>
    <segment id="7">A comerciante Maria Bispo Coni</segment>
    <segment id="8">, 45 anos</segment>
    <segment id="9">, está internada na UTI do HGE</segment>
    <segment id="10">, após ter levado um tiro na testa ao perseguir de carro os bandidos que roubaram o seu estabelecimento.</segment>
    <segment id="11">Na verdade</segment>
    <segment id="12">, o filho dela</segment>
    <segment id="13">, Nicácio Bispo Coni</segment>
    <segment id="14">, 25, decidiu ir atrás dos bandidos depois de ter assistido à ação pelo circuito interno de TV.</segment>
    <segment id="15">“</segment>
    <segment id="16">A mãe viu o desespero do filho e o entrou no carro com ele para não deixá-lo fazer uma besteira”</segment>
    <segment id="17">, contou o titular da 27ª DT (Itinga)</segment>
    <segment id="18">, Jacinto Alberto.</segment>
    <segment id="19">Os bandidos  atiraram quando perceberam a perseguição.</segment>
    <segment id="20">Nicácio desistiu da empreitada ao ver a mãe sangrando e a levou até uma clínica no bairro de São Cristóvão.</segment>
    <segment id="21">Diante do quadro</segment>
    <segment id="22">, Maria foi encaminhada imediatamente ao Hospital Menandro de Farias</segment>
    <segment id="23">, que também não tinha estrutura para prestar o socorro e encaminhou a vítima ao HGE.</segment>
    <segment id="24">Os bandidos trocaram tiros com a PM na Estrada Velha do Aeroporto</segment>
    <segment id="25">, masmas conseguiram fugir.</segment>
    <segment id="26">O melhor a fazer</segment>
    <segment id="27">O delegado Jacinto Alberto lembra que a polícia sempre alerta à população a não reagir a assalto em nenhuma circunstância.</segment>
    <segment id="28">“</segment>
    <segment id="29">O marginal vai preparado para cometer o delito.</segment>
    <segment id="30">O cidadão é pego desprevinido”</segment>
    <segment id="31">, explica.</segment>
    <segment id="32">Ainda não</segment>
    <segment id="33">sese sabe a quantia levada do supermercado.</segment>
    <segment id="34">Segundo o delegado</segment>
    <segment id="35">, os bandidos renderam a filha de Maria Bispo e outros funcionários apontando armas para a cabeça deles e ordenaram que colocassem o dinheiro em um saco.</segment>
    <segment id="36">Ninguém havia reagido.</segment>
    <segment id="37">“</segment>
    <segment id="38">Não esperava que isso fosse acontecer.</segment>
    <segment id="39">Foi uma situação inesperada”</segment>
    <segment id="40">, afirma uma sobrinha da comerciante de prenome Mariana.</segment>
    <segment id="41">Ela informou que Nicácio está abalado e não queria falar sobre o</segment>
    <segment id="42">casocaso.</segment>
  </rst>
</analysis>