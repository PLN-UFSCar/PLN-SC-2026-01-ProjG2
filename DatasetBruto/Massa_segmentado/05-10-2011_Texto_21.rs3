  <rst>
    <segment id="1">Leão-Abelha longe da Série</segment>
    <segment id="2">A
Vitória dá vexame em casa e fica a oito pontos do G-4</segment>
    <segment id="3">Ontem, dia de São Francisco de Assis</segment>
    <segment id="4">, padroeiro dos animais</segment>
    <segment id="5">, um confronto chamou a  atenção na Série B. Mais uma vez o Vitória  vestiu-</segment>
    <segment id="6">sese no Barradão com seu uniforme abelha</segment>
    <segment id="7">, na cor amarela</segment>
    <segment id="8">, para aproximar-</segment>
    <segment id="9">sese do G-4</segment>
    <segment id="10">, masmas o mascote do Barueri</segment>
    <segment id="11">, a ‘Abelha Original’</segment>
    <segment id="12">, surpreendeu o ‘Leão-Abelha’ e venceu o jogo por 2 a 1.</segment>
    <segment id="13">Saldanha e Alê executaram as ferroadas mais fortes do enxame comandado por René Simões.</segment>
    <segment id="14">Fábio Santos descontou para o Vitória.</segment>
    <segment id="15">O resultado deixa o time de Benazzi mais longe das quatro primeiras posições.</segment>
    <segment id="16">Com 40 pontos</segment>
    <segment id="17">, o rubro-negro ocupa o nono lugar</segment>
    <segment id="18">, oito pontos atrás do quarto colocado</segment>
    <segment id="19">, o Americana.</segment>
    <segment id="20">Dentro de campo</segment>
    <segment id="21">, o Vitória teve um maior volume de jogo</segment>
    <segment id="22">, masmas vacilou na defesa.</segment>
    <segment id="23">Saldanha aproveitou-</segment>
    <segment id="24">sese disso para tabelar com Alê e abrir o placar</segment>
    <segment id="25">, aos 13 minutos de jogo.</segment>
    <segment id="26">Aos 45</segment>
    <segment id="27">, quando o Leão buscava o empate</segment>
    <segment id="28">, levou o segundo gol.</segment>
    <segment id="29">Em outra tabela</segment>
    <segment id="30">, Alê chutou cruzado e contou com o erro de  Gilberto para ampliar.</segment>
    <segment id="31">Na etapa final</segment>
    <segment id="32">, Benazzi botou seu time no ataque</segment>
    <segment id="33">, masmas o gol de pênalti de Fábio Santos saiu tarde demais.</segment>
    <segment id="34">Depois da derrota</segment>
    <segment id="35">, resta ao Vitória buscar o triunfo contra o Bragantino</segment>
    <segment id="36">, neste sábado</segment>
    <segment id="37">,  fora de casa</segment>
    <segment id="38">, para continuar sonhando com o acesso.</segment>
    <segment id="39">Suspensos pelo acúmulo de cartões</segment>
    <segment id="40">, Alison e Geovanni estão fora da partida.</segment>
  </rst>
</analysis>