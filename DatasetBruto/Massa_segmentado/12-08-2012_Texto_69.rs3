  <rst>
    <segment id="1">Jogos de Londres: em oito minutos</segment>
    <segment id="2">, uma s횄짯ntese da cultura do Brasil
RIO - O gari Renato Sorriso subiu no domingo ao palco do Est횄징dio Ol횄짯mpico de Londres para mostrar o que sabe fazer de melhor: esbanjar alegria.</segment>
    <segment id="3">Sempre sambando</segment>
    <segment id="4">, ele abriu e conduziu a participa횄짠횄짙o brasileira na cerim횄쨈nia de encerramento das Olimp횄짯adas.</segment>
    <segment id="5">Pel횄짤 apareceu</segment>
    <segment id="6">comocomo um convidado de honra da festa</segment>
    <segment id="7">, que contou ainda com os cantores Marisa Monte</segment>
    <segment id="8">, Seu Jorge e BNeg횄짙o.</segment>
    <segment id="9">Ao final da apresenta횄짠횄짙o brasileira</segment>
    <segment id="10">, um minidesfile de oito minutos de dura횄짠횄짙o</segment>
    <segment id="11">, apareceram ainda os atletas Robert Scheidt</segment>
    <segment id="12">, dono de tr횄짧s medalhas ol횄짯mpicas no iatismo</segment>
    <segment id="13">, e Maurren Maggi</segment>
    <segment id="14">, ouro no salto em dist횄짖ncia nos Jogos de Pequim</segment>
    <segment id="15">, em 2008.</segment>
    <segment id="16">O r횄징pido cap횄짯tulo verde-amarelo teve in횄짯cio quando o evento j횄징 tinha mais de duas horas de dura횄짠횄짙o.</segment>
    <segment id="17">O prefeito de Londres</segment>
    <segment id="18">, Boris Johnson</segment>
    <segment id="19">, entregou a bandeira ol횄짯mpica ao presidente do Comit횄짧 Ol횄짯mpico Internacional (COI)</segment>
    <segment id="20">, Jacques Rogge</segment>
    <segment id="21">, que a repassou ao prefeito Eduardo Paes.</segment>
    <segment id="22">Logo ap횄쨀s a passagem simb횄쨀lica</segment>
    <segment id="23">, a festa brasileira come횄짠ou.</segment>
    <segment id="24">Na encena횄짠횄짙o</segment>
    <segment id="25">, Sorriso</segment>
    <segment id="26">, com uma roupa laranja que imitava seu uniforme de trabalho</segment>
    <segment id="27">, apareceu sambando e logo foi "repreendido" por um ator que interpretava um seguran횄짠a e pretendia tir횄징-lo do palco.</segment>
    <segment id="28">Com jogo de cintura</segment>
    <segment id="29">, Sorriso acabou ensinando ao seu mais novo amigo os primeiros passos de samba.</segment>
    <segment id="30">O gari mais famoso da cidade guiou o seguran횄짠a em uma visita por s횄짯mbolos tradicionais do Brasil e do Rio.</segment>
    <segment id="31">Marisa Monte cantou a 횄ria que abre as "Bachianas Brasileiras n횂쨘 5"</segment>
    <segment id="32">, de Villa-Lobos</segment>
    <segment id="33">, vestida de Iemanj횄징</segment>
    <segment id="34">, simbolizando a diversidade religiosa</segment>
    <segment id="35">, enquanto o rapper BNeg횄짙o homenageou o movimento mangue beat com "Maracatu at횄쨈mico"</segment>
    <segment id="36">, de Chico Science e Na횄짠횄짙o Zumbi.</segment>
    <segment id="37">O malandro carioca foi representado por Seu Jorge</segment>
    <segment id="38">, todo de branco</segment>
    <segment id="39">, que cantou "</segment>
    <segment id="40">Nem vem que n횄짙o tem"</segment>
    <segment id="41">, sucesso na voz de Wilson Simonal.</segment>
    <segment id="42">Os m횄쨘sicos cantavam "</segment>
    <segment id="43">Aquele abra횄짠o"</segment>
    <segment id="44">, de Gilberto Gil</segment>
    <segment id="45">, e dividiam o palco com uma roda de capoeira</segment>
    <segment id="46">, atores representando 횄짯ndios</segment>
    <segment id="47">, alegorias de escola de samba e a modelo Alessandra Ambr횄쨀sio</segment>
    <segment id="48">, quando Pel횄짤 entrou.</segment>
    <segment id="49">Aplaudido</segment>
    <segment id="50">, ele abra횄짠ou Sorriso</segment>
    <segment id="51">, encerrando a participa횄짠횄짙o brasileira</segment>
    <segment id="52">, dirigida por Daniela Thomas</segment>
    <segment id="53">, Cao Hamburger e Abel Gomes.</segment>
    <segment id="54">Antes da festa brasileira</segment>
    <segment id="55">, a cena foi dominada pelo rock e pelo pop.</segment>
    <segment id="56">Se na cerim횄쨈nia de abertura a estrela maior foi Paul McCartney</segment>
    <segment id="57">, no domingo as aten횄짠횄쨉es foram divididas.</segment>
    <segment id="58">George Michael</segment>
    <segment id="59">, Kaiser Chiefs</segment>
    <segment id="60">, Pet Shop Boys</segment>
    <segment id="61">, Fatboy Slim</segment>
    <segment id="62">, The Who</segment>
    <segment id="63">, One Direction e at횄짤 as Spice Girls</segment>
    <segment id="64">, que chegaram nos tradicionais t횄징xis pretos londrinos</segment>
    <segment id="65">, apresentaram-</segment>
    <segment id="66">sese no evento.</segment>
    <segment id="67">Freddie Mercury foi homenageado no tel횄짙o</segment>
    <segment id="68">, e em seguida os remanescentes do Queen tocaram "</segment>
    <segment id="69">We will rock you" com a cantora Jessie J.</segment>
    <segment id="70">A cerim횄쨈nia foi menos teatral do que a da abertura.</segment>
    <segment id="71">Um ator representando Winston Churchill</segment>
    <segment id="72">, primeiro-ministro brit횄짖nico durante a Segunda Guerra Mundial</segment>
    <segment id="73">, discursou na apresenta횄짠횄짙o</segment>
    <segment id="74">, que teve ainda representa횄짠횄짙o da hora do rush londrina</segment>
    <segment id="75">, com t횄징xis presos em um engarrafamento.</segment>
  </rst>
