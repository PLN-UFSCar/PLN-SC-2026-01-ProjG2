  <rst>
    <segment id="1">Famosos mandam mensagens para Ivete</segment>
    <segment id="2">A notícia da doença da cantora é uma das mais comentadas no twitter
Depois de confirmado que a cantora Ivete Sangalo está com meningite</segment>
    <segment id="3">, vários fãs da cantora fizeram questão de comentar o assunto no microblog twitter.</segment>
    <segment id="4">Famosos também</segment>
    <segment id="5">sese manifestaram</segment>
    <segment id="6">, como</segment>
    <segment id="7">como a cantora Alinne Rosa.</segment>
    <segment id="8">A vocalista da banda Cheio de Amor solicitou:</segment>
    <segment id="9">"Quero pedir a todos os meus fãs e amigos que façam uma corrente de oração por Ivetinha! @ivetesangalo</segment>
    <segment id="10">Que ela volte cheia de saúde logo!</segment>
    <segment id="11">".</segment>
    <segment id="12">Flora Gil</segment>
    <segment id="13">, esposa do cantor Gilberto Gil</segment>
    <segment id="14">, também falou sobre o assunto: "</segment>
    <segment id="15">Falei com minha amiga Cyntia Sangalo.</segment>
    <segment id="16">@ivetesangalo está bem</segment>
    <segment id="17">, sendo bem cuidada</segment>
    <segment id="18">, e logo mais volta pra ativa de novo!</segment>
    <segment id="19">".</segment>
    <segment id="20">O mesmo desejo de que Ivete</segment>
    <segment id="21">sese recupere o quanto antes foi expressado pela banda Jammil.</segment>
    <segment id="22">"</segment>
    <segment id="23">Todo nosso carinho hoje vai pra amiga @ivetesangalo.</segment>
    <segment id="24">Que você fique boa logo pra voltar a fazer o povo inteiro balançar</segment>
    <segment id="25">, Ivetinha.</segment>
    <segment id="26">Beijos!</segment>
    <segment id="27">", escreveu no twitter.</segment>
    <segment id="28">Por conta da doença</segment>
    <segment id="29">, parte da agenda da artista foi cancelada.</segment>
    <segment id="30">Ivete ainda não tem previsão de alta do Hospital Aliança</segment>
    <segment id="31">, onde está internada.</segment>
  </rst>
