  <rst>
    <segment id="1">Há 50 anos:</segment>
    <segment id="2">Peñarol</segment>
    <segment id="3">, campeão do mundo
Derrotado ontem à noite</segment>
    <segment id="4">, no Estádio Centenário</segment>
    <segment id="5">, por 2 x 1</segment>
    <segment id="6">, a equipe do Benfica</segment>
    <segment id="7">, de Portugal</segment>
    <segment id="8">, o Peñarol conquistou</segment>
    <segment id="9">, de forma brilhante</segment>
    <segment id="10">, a Taça dos Clubes Campeões.</segment>
    <segment id="11">A partida foi precedida de longas horas de nervosismo</segment>
    <segment id="12">, tendo em vista que os portuguêses</segment>
    <segment id="13">sese mantinham irredutíveis na posição que assumiram</segment>
    <segment id="14">, recusando terminantemente o trio de arbitragem argentino para a direção do encontro.</segment>
    <segment id="15">Finalmente</segment>
    <segment id="16">, por volta das 16h</segment>
    <segment id="17">, chegou-</segment>
    <segment id="18">sese a um acôrdo</segment>
    <segment id="19">, concordando os dirigentes do Benfica com a designação de José Luís Praddaude para a direção do match.</segment>
    <segment id="20">Grande público compareceu ao estádio</segment>
    <segment id="21">, calculando-</segment>
    <segment id="22">sese a presença de 70 mil espectadores</segment>
    <segment id="23">, proporcionando a arrecadação de aproximadamente 85 mil dólares.</segment>
    <segment id="24">As duas equipes assim</segment>
    <segment id="25">sese apresentaram no gramado: PEÑAROL - Maldana</segment>
    <segment id="26">, Martinez</segment>
    <segment id="27">, Cano e Gonzalez</segment>
    <segment id="28">;</segment>
    <segment id="29">Gonçalves e Aguirre</segment>
    <segment id="30">;</segment>
    <segment id="31">Cubillas</segment>
    <segment id="32">, Ledesma</segment>
    <segment id="33">, Sasia</segment>
    <segment id="34">, Spencer e Joya</segment>
    <segment id="35">; BENFICA - Costa Pereira</segment>
    <segment id="36">, Ângelo</segment>
    <segment id="37">, Humberto e Cruz</segment>
    <segment id="38">; Neto e Cavém</segment>
    <segment id="39">; Augusto</segment>
    <segment id="40">, Eusébio</segment>
    <segment id="41">, Águas</segment>
    <segment id="42">, Coluna e Simões.</segment>
    <segment id="43">Ao término do encontro</segment>
    <segment id="44">, inconformados com a atuação do árbitro</segment>
    <segment id="45">, alguns jogadores do Benfica cercaram o juiz Praddaude</segment>
    <segment id="46">, que foi agredido pelo ponteiro José Augusto.</segment>
    <segment id="47">Morre a torcedora n 1 do Fla</segment>
    <segment id="48">Com 70 anos de idade</segment>
    <segment id="49">, Dona Maria era a mais animada torcedora do Flamengo.</segment>
    <segment id="50">Devota de Cosme e Damião</segment>
    <segment id="51">, nunca faltava aos jogos do clube</segment>
    <segment id="52">, distribuindo cocadas e doces aos conhecidos.</segment>
    <segment id="53">Ela faleceu ontem em seu barracão</segment>
    <segment id="54">, perto da Igreja Nossa Senhora da Luz</segment>
    <segment id="55">, numa vila situada à Rua Ana Néri.</segment>
  </rst>
</analysis>