  <rst>
    <segment id="1">No Rio</segment>
    <segment id="2">, promessas de candidatos v횄짙o custar meio bi para educa횄짠횄짙o
RIO - Para cumprir duas das principais promessas na educa횄짠횄짙o feitas na campanha eleitoral do Rio - hor횄징rio integral nas escolas da rede e acesso a creches para popula횄짠횄짙o de baixa renda -</segment>
    <segment id="3">, o pr횄쨀ximo prefeito ter횄징 de aplicar</segment>
    <segment id="4">, pelo menos</segment>
    <segment id="5">, um valor de R$ 506</segment>
    <segment id="6">,3 milh횄쨉es</segment>
    <segment id="7">, segundo estimativa do GLOBO</segment>
    <segment id="8">, em conjunto com a Campanha Nacional pelo Direito 횄혻 Educa횄짠횄짙o.</segment>
    <segment id="9">S횄쨀 o hor횄징rio integral em toda a rede pode ser estimado em R$ 197</segment>
    <segment id="10">,6 milh횄쨉es</segment>
    <segment id="11">, enquanto o maior acesso a creches daria</segment>
    <segment id="12">, pelo menos</segment>
    <segment id="13">, mais R$ 308</segment>
    <segment id="14">,7 milh횄쨉es.</segment>
    <segment id="15">O montante de meio bilh횄짙o 횄짤 11</segment>
    <segment id="16">,4% do or횄짠amento previsto para a Secretaria municipal de Educa횄짠횄짙o em 2012</segment>
    <segment id="17">, cerca de R$ 4</segment>
    <segment id="18">,4 bilh횄쨉es</segment>
    <segment id="19">; masmas o pr횄쨀ximo prefeito ter횄징 de lidar com o fato de que cerca de 60% do or횄짠amento est횄짙o comprometidos com pessoal</segment>
    <segment id="20">, o que diminui a margem para novos investimentos.</segment>
    <segment id="21">Outras promessas tamb횄짤m carecem de viabilidade</segment>
    <segment id="22">, segundo an횄징lise de profissionais da 횄징rea a pedido do GLOBO: o coordenador da Campanha Nacional pelo Direito 횄혻 Educa횄짠횄짙o</segment>
    <segment id="23">, Daniel Cara</segment>
    <segment id="24">, que viu as propostas sem saber de quais candidatos eram</segment>
    <segment id="25">; o consultor Sinoel Batista</segment>
    <segment id="26">, que participa de projetos do Todos pela Educa횄짠횄짙o</segment>
    <segment id="27">, e que tamb횄짤m viu as propostas sem identifica횄짠횄짙o</segment>
    <segment id="28">; e a educadora Andrea Ramal</segment>
    <segment id="29">, que j횄징 conhecia os autores das propostas.</segment>
    <segment id="30">O prefeito Eduardo Paes (PMDB)</segment>
    <segment id="31">, candidato 횄혻 reelei횄짠횄짙o</segment>
    <segment id="32">, promete turno integral a 240 mil alunos.</segment>
    <segment id="33">Marcelo Freixo (PSOL) fala em tempo integral primeiro para todos os alunos das Escolas do Amanh횄짙. Rodrigo Maia (DEM)</segment>
    <segment id="34">prop횄쨉e atividades fora da escola de pr횄징tica esportiva e cultural.</segment>
    <segment id="35">E Otavio Leite (PSDB) tamb횄짤m defende atividades art횄짯sticas e esportivas em espa횄짠os da sociedade.</segment>
    <segment id="36">Segundo Daniel Cara</segment>
    <segment id="37">, o custo a mais</segment>
    <segment id="38">, por aluno</segment>
    <segment id="39">, que o hor횄징rio integral requer</segment>
    <segment id="40">횄짤 de R$ 369 dentro do Mais Educa횄짠횄짙o (programa federal que aumenta a oferta de atividades da escola)</segment>
    <segment id="41">, e de R$ 2.847 segundo valor ideal da campanha coordenada por Cara.</segment>
    <segment id="42">Considerando que h횄징 535.686 alunos no ensino fundamental</segment>
    <segment id="43">, seria preciso</segment>
    <segment id="44">, no m횄짯nimo - com base no valor de R$ 369 -</segment>
    <segment id="45">, que a prefeitura aplicasse mais R$ 197</segment>
    <segment id="46">,6 milh횄쨉es.</segment>
    <segment id="47">Se for para 240 mil alunos</segment>
    <segment id="48">, como</segment>
    <segment id="49">como prop횄쨉e Paes</segment>
    <segment id="50">, seriam necess횄징rios mais R$ 88</segment>
    <segment id="51">,5 milh횄쨉es.</segment>
    <segment id="52">Para acabar com a fila de espera para creches municipais - estimada em 19 mil crian횄짠as at횄짤 3 anos</segment>
    <segment id="53">, segundo Andrea Ramal -</segment>
    <segment id="54">, e considerando que cada creche teria 250 crian횄짠as (limite das creches da prefeitura)</segment>
    <segment id="55">, seriam necess횄징rias mais 76 unidades.</segment>
    <segment id="56">Se sese levar em conta que todas precisariam ser constru횄짯das</segment>
    <segment id="57">, e como</segment>
    <segment id="58">como o valor m횄짤dio de constru횄짠횄짙o de cada Espa횄짠o de Desenvolvimento Infantil</segment>
    <segment id="59">, diz a secretaria</segment>
    <segment id="60">, 횄짤 de R$ 4 milh횄쨉es</segment>
    <segment id="61">, seria preciso um valor</segment>
    <segment id="62">, a mais</segment>
    <segment id="63">, de R$ 304 milh횄쨉es.</segment>
    <segment id="64">Para manuten횄짠횄짙o</segment>
    <segment id="65">, como</segment>
    <segment id="66">como a secretaria calcula que cada EDI custa R$ 62 mil/m횄짧s</segment>
    <segment id="67">, daria mais R$ 4</segment>
    <segment id="68">,7 milh횄쨉es.</segment>
    <segment id="69">Mais tempo de aula poderia ajudar a Escola Municipal Desembargador Oscar Ten횄쨀rio</segment>
    <segment id="70">, na G횄징vea</segment>
    <segment id="71">, a melhorar a posi횄짠횄짙o no Ideb: ela piorou a nota em rela횄짠횄짙o a 2009 e chegou no ano passado a 2</segment>
    <segment id="72">,5, a pior da rede (cuja m횄짤dia</segment>
    <segment id="73">, nos anos finais</segment>
    <segment id="74">횄짤 4,4).</segment>
    <segment id="75">M횄짙e de um aluno da escola</segment>
    <segment id="76">, Ellen Andr횄짤a defende tamb횄짤m o investimento nas creches:
- A creche da minha neta</segment>
    <segment id="77">횄짤</segment>
    <segment id="78">s횄쨀 por metade do dia.</segment>
    <segment id="79">Ao tentar explicar de onde tirariam verba para as propostas</segment>
    <segment id="80">, os advers횄징rios de Paes chamam aten횄짠횄짙o para o m횄짯nimo de 25% dos impostos que o munic횄짯pio 횄짤 obrigado a investir em educa횄짠횄짙o.</segment>
    <segment id="81">O Minist횄짤rio P횄쨘blico</segment>
    <segment id="82">, em a횄짠횄짙o civil p횄쨘blica de 2004</segment>
    <segment id="83">, afirma que a prefeitura</segment>
    <segment id="84">, para chegar aos 25%</segment>
    <segment id="85">, incluiria valores indevidos</segment>
    <segment id="86">comocomo despesas com inativos e recursos do Fundeb.</segment>
    <segment id="87">Em abril</segment>
    <segment id="88">, a a횄짠횄짙o resultou em condena횄짠횄짙o pela Justi횄짠a</segment>
    <segment id="89">, para que</segment>
    <segment id="90">para que a prefeitura mude o c횄징lculo e reponha mais de R$ 2</segment>
    <segment id="91">,2 bilh횄쨉es que n횄짙o foram aplicados desde 1999</segment>
    <segment id="92">; o munic횄짯pio ainda pode recorrer.</segment>
    <segment id="93">Paes disse que</segment>
    <segment id="94">, pela primeira vez desde que a Lei de Responsabilidade Fiscal entrou em vigor</segment>
    <segment id="95">, o Rio teve as contas aprovadas no Minist횄짤rio da Educa횄짠횄짙o e no Tribunal de Contas do Munic횄짯pio.</segment>
