  <rst>
    <segment id="1">Baralho estampa 52 procurados</segment>
    <segment id="2">Denuncie os bandidos.</segment>
    <segment id="3">Ligue 3235-0000 ou 181 (interior)</segment>
    <segment id="4">Após a prisão de Fal</segment>
    <segment id="5">, o  número um na lista dos  bandidos mais procurados da Bahia</segment>
    <segment id="6">, agora é o traficante Marcelo Henrique Menezes dos Santos</segment>
    <segment id="7">, o Elias</segment>
    <segment id="8">, que está foragido.</segment>
    <segment id="9">“</segment>
    <segment id="10">Com a prisão de Fal e de Peu</segment>
    <segment id="11">, Elias passa a ser a pessoa mais procurada no Estado”</segment>
    <segment id="12">, sentenciou o titular da Secretaria de Segurança Pública (SSP)</segment>
    <segment id="13">, Maurício Teles Barbosa.</segment>
    <segment id="14">Segundo a polícia</segment>
    <segment id="15">, Elias é o  responsável pelo tráfico de drogas nas regiões da Santa Cruz</segment>
    <segment id="16">, Boqueirão</segment>
    <segment id="17">, Sucupira e Areal.</segment>
    <segment id="18">Durante a coletiva de imprensa</segment>
    <segment id="19">, ontem</segment>
    <segment id="20">, os jornalistas receberam um baralho onde as cartas contêm os nomes e fotos dos 52 bandidos mais procurados da Bahia.</segment>
    <segment id="21">Os crimes cometidos pelos acusados estão escritos na parte de trás das cartas.</segment>
    <segment id="22">Todos os criminosos divulgados no baralho possuem mandado de prisão em aberto.</segment>
    <segment id="23">“</segment>
    <segment id="24">O Fal era  nosso Ás de Ouros e agora é carta fora do baralho”</segment>
    <segment id="25">, frisou o secretário.</segment>
    <segment id="26">De acordo com a assessoria de comunicação da  SSP</segment>
    <segment id="27">, o baralho não será distribuído à população</segment>
    <segment id="28">, nos bairros</segment>
    <segment id="29">, e nem será comercializado.</segment>
    <segment id="30">A ideia de criar o baralho com os nomes dos mais procurados partiu da Superintendência de Inteligência (SI) da SSP.</segment>
    <segment id="31">Grave as fotos dos bandidos!</segment>
    <segment id="32">Os membros da Inteligência também idealizaram um jogo de memórias com as fotos dos bandidos</segment>
    <segment id="33">, já disponível no site da SSP.</segment>
    <segment id="34">Para acessar o jogo</segment>
    <segment id="35">, acesse www.ssp.ba.gov.br.</segment>
    <segment id="36">Depois</segment>
    <segment id="37">, é só clicar na janela (pop-up) que irá aparecer com as frases “Pacto</segment>
    <segment id="38">Pela Vida - Ajude a Proteger</segment>
    <segment id="39">a nossa Bahia</segment>
    <segment id="40">-Memorize os criminosos mais procurados no Jogo da Memória e denuncie!</segment>
    <segment id="41">”</segment>
  </rst>
</analysis>