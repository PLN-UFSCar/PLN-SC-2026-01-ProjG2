  <rst>
    <segment id="1">Bahia e Vitória faz carnaval de gols</segment>
    <segment id="2">Vitória devorou o time do polo e o esquadrão arrebentou a carranca em Juazeiro</segment>
    <segment id="3">Fim do jejum!</segment>
    <segment id="4">Vitória devora o time do Polo</segment>
    <segment id="5">Os poucos mais de quatro mil torcedores que foram ao Barradão na noite de ontem viram a ótima estreia do lateral-esquerdo Mansur</segment>
    <segment id="6">, de apenas 18 anos.</segment>
    <segment id="7">Ele foi o destaque da partida e</segment>
    <segment id="8">, junto com o artilheiro Neto Baiano</segment>
    <segment id="9">, que fez dois gols</segment>
    <segment id="10">, e Lúcio Flávio</segment>
    <segment id="11">, autor do terceiro</segment>
    <segment id="12">, garantiu o triunfo rubro-negro contra o Camaçari</segment>
    <segment id="13">, por 3 a 1.</segment>
    <segment id="14">O início da partida foi logo movimentado com o gol de Neto Baiano</segment>
    <segment id="15">,  aos dois minutos.</segment>
    <segment id="16">O passe não foi de Mansur</segment>
    <segment id="17">, que em janeiro deixou a equipe sub-20 do Bahia por causa de salários atrasados.</segment>
    <segment id="18">Mas, após o Leão abrir o placar</segment>
    <segment id="19">, o guri “comeu” a bola e foi o nome da partida.</segment>
    <segment id="20">Como jogador tarimbado</segment>
    <segment id="21">, ia na linha de fundo e cruzava.</segment>
    <segment id="22">Ainda arriscou chutes de fora da área.</segment>
    <segment id="23">Só faltou mesmo o gol.</segment>
    <segment id="24">O segundo</segment>
    <segment id="25">, por sinal</segment>
    <segment id="26">, também foi marcado por Neto Baiano.</segment>
    <segment id="27">O terceiro foi de Lúcio Flávio</segment>
    <segment id="28">, na segunda etapa.</segment>
    <segment id="29">O Camaçari até diminuiu o placar com Diogo</segment>
    <segment id="30">, masmas não teve fôlego para buscar o empate.</segment>
    <segment id="31">Depois de duas rodadas em jejum</segment>
    <segment id="32">, o Vitória conseguiu “tirar a barriga da miséria”.</segment>
    <segment id="33">Isso graças a um garoto que deixou o Fazendão para não passar fome e a um artilheiro faminto por gols.</segment>
    <segment id="34">Esquadrão arrebenta a Carranca em Juazeiro</segment>
    <segment id="35">O Bahia acabou com a Carranca na noite de ontem</segment>
    <segment id="36">, no Estádio Adauto Moraes</segment>
    <segment id="37">, em Juazeiro.</segment>
    <segment id="38">Com show de Souza</segment>
    <segment id="39">, que marcou dois gols</segment>
    <segment id="40">, o tricolor goleou o Juazeiro por 4 a 0</segment>
    <segment id="41">, pela nona rodada do Campeonato Baiano.</segment>
    <segment id="42">Com o resultado</segment>
    <segment id="43">, o Esquadrão chegou aos 20 pontos</segment>
    <segment id="44">, um atrás do líder Bahia de Feira.</segment>
    <segment id="45">O placar foi construído ainda na primeira etapa.</segment>
    <segment id="46">Logo aos 15 minutos</segment>
    <segment id="47">, Morais cruzou na cabeça de Souza</segment>
    <segment id="48">, que mandou para as redes.</segment>
    <segment id="49">Aos 31</segment>
    <segment id="50">, Fahel colocou Gabriel de frente para o paraíso.</segment>
    <segment id="51">O meia-atacante driblou o goleiro e tocou de esquerda para marcar um golaço.</segment>
    <segment id="52">Três minutos depois</segment>
    <segment id="53">, Gabriel achou Coelho na direita.</segment>
    <segment id="54">O lateral retribuiu e  cruzou na cabeça de Júnior: 3 a  0.</segment>
    <segment id="55">Para fechar a festa da primeira etapa</segment>
    <segment id="56">, Júnior tocou para Souza após um contra-ataque rápido.</segment>
    <segment id="57">O Caveirão</segment>
    <segment id="58">sese livrou da marcação e tocou para marcar o quarto gol tricolor na partida.</segment>
    <segment id="59">No segundo tempo</segment>
    <segment id="60">, o técnico Falcão resolveu poupar Souza</segment>
    <segment id="61">, que foi substituído por Zé Roberto.</segment>
    <segment id="62">Ciro e Magno também entraram</segment>
    <segment id="63">, nos lugares de Júnior e Gabriel</segment>
    <segment id="64">, respectivamente</segment>
    <segment id="65">, masmas o Esquadrão caiu de ritmo.</segment>
    <segment id="66">Com isso</segment>
    <segment id="67">, o Juazeiro foi para cima e fez o gol de honra</segment>
    <segment id="68">, em cobrança de falta de Stefan</segment>
    <segment id="69">, que Omar aceitou</segment>
    <segment id="70">, aos 24 minutos.</segment>
  </rst>
</analysis>