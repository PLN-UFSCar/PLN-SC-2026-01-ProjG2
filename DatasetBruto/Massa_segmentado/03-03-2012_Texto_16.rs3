  <rst>
    <segment id="1">As santinhas do BBB 12</segment>
    <segment id="2">Até hoje</segment>
    <segment id="3">, Kelly e Fabiana resistiram às tentações e não traíram seus parceiros</segment>
    <segment id="4">Enquanto tem confinados no Big Brother que só querem saber de curtir e beijar na boca (até os comprometidos!)</segment>
    <segment id="5">, tem gente que está sabendo</segment>
    <segment id="6">sese comportar direitinho dentro da casa.</segment>
    <segment id="7">As sisters Kelly e Fabiana estão dando exemplos de fidelidade.</segment>
    <segment id="8">Mesmo com tantos gatos no BBB 12</segment>
    <segment id="9">, a morena Kelly</segment>
    <segment id="10">, que namora há um ano e meio com Fernando David</segment>
    <segment id="11">, está  controlando os desejos e não</segment>
    <segment id="12">sese envolveu com nenhum brother.</segment>
    <segment id="13">Fabiana</segment>
    <segment id="14">, que é casada há oito anos com o cantor sertanejo Roby</segment>
    <segment id="15">, também não traiu o maridão.</segment>
    <segment id="16">Mesmo a loira andando bem próxima de Fael -   o que deixa a dúvida na cabeça de algumas pessoas</segment>
    <segment id="17">sese eles estariam interessados um no outro -  Roby não demonstra ciúmes.</segment>
    <segment id="18">“Assim</segment>
    <segment id="19">comocomo Fabi é amiga do Fael</segment>
    <segment id="20">, ela também é amiga da Kelly.</segment>
    <segment id="21">Ela o tem</segment>
    <segment id="22">comocomo um amigo”</segment>
    <segment id="23">, disse ele em entrevista ao site oficial do BBB 12.</segment>
    <segment id="24">Quando perguntado sobre o que faria</segment>
    <segment id="25">casocaso Fabi o traísse</segment>
    <segment id="26">, ele foi direto.</segment>
    <segment id="27">“Não cogito essa possibilidade”</segment>
    <segment id="28">, disse.

Tomara que as gatas não decepcionem!</segment>
  </rst>
