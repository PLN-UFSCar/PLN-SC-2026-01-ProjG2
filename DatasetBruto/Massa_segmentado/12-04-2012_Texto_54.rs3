  <rst>
    <segment id="1">Roubou para curtir o pagodão sábado</segment>
    <segment id="2">Reimilton disse que decidiu roubar os passageiros de um ônibus para ir pro pagodão
Belo</segment>
    <segment id="3">, Sorriso Maroto</segment>
    <segment id="4">, Harmonia do Samba</segment>
    <segment id="5">, Rodriguinho</segment>
    <segment id="6">, Revelação e Pixote.</segment>
    <segment id="7">Estes artistas deverão atrair  muita gente no próximo sábado para o Wet’n Wild.</segment>
    <segment id="8">Reimilton Silva da Paixão</segment>
    <segment id="9">, 24 anos</segment>
    <segment id="10">, o Rei</segment>
    <segment id="11">, estaria lá</segment>
    <segment id="12">, caso</segment>
    <segment id="13">caso não tivesse sido preso por policiais militares depois de assaltar um ônibus.</segment>
    <segment id="14">“Estava precisando de dinheiro para ir ao Samba Salvador”</segment>
    <segment id="15">, justificou Rei.</segment>
    <segment id="16">No final da tarde de anteontem</segment>
    <segment id="17">, Rei subiu no ônibus que fazia a linha Estação Mussurunga- Barra 2 e roubou seis passageiros que não haviam passado ainda pela catraca.</segment>
    <segment id="18">“</segment>
    <segment id="19">Não roubei o dinheiro do cobrador.</segment>
    <segment id="20">Só o celular da galera que estava na traseira”</segment>
    <segment id="21">, conta Reimilton.</segment>
    <segment id="22">Ele desceu do ônibus pela porta do fundo</segment>
    <segment id="23">, no bairro de Sete Portas</segment>
    <segment id="24">, e uma das vítimas pediu apoio aos PMs que passavam pelo local.</segment>
    <segment id="25">Reimilton tentou fugir</segment>
    <segment id="26">, porém</segment>
    <segment id="27">porém foi alcançado pelos policiais da 58ª CIPM (Cosme de Farias).</segment>
    <segment id="28">Rei foi preso com um revólver calibre 38</segment>
    <segment id="29">, seis telefones celulares</segment>
    <segment id="30">, um relógio</segment>
    <segment id="31">, uma corrente de prata</segment>
    <segment id="32">, outra de aço</segment>
    <segment id="33">, dois aparelhos MP3 e R$ 16.</segment>
    <segment id="34">Disse que foi a 1ª vez

Reimilton Silva da Paixão foi autuado em flagrante por assalto à mão armada pela delegada Maria Dail Sá Barreto</segment>
    <segment id="35">, titular da 6ª Delegacia Territorial (Brotas).</segment>
    <segment id="36">Ele disse que foi o primeiro assalto que cometeu.</segment>
    <segment id="37">Não constam nos registros policiais passagens de Rei por outros crimes.</segment>
    <segment id="38">“Queria ver todas as bandas do Samba Salvador</segment>
    <segment id="39">, masmas agora estou arrependido do que eu fiz”</segment>
    <segment id="40">, declara.</segment>
    <segment id="41">Rei subiu no ônibus na Avenida Heitor Dias</segment>
    <segment id="42">, próximo à localidade do Sertanejo</segment>
    <segment id="43">, no Pau Miúdo</segment>
    <segment id="44">, onde ele mora.</segment>
    <segment id="45">Ele escolheu o Estação Mussurunga-Barra 2</segment>
    <segment id="46">porque</segment>
    <segment id="47">porque o veículo estava cheio e com passageiros na parte traseira.</segment>
    <segment id="48">“Era só levar o celular e descer pelo fundo mesmo”</segment>
    <segment id="49">, explica.</segment>
    <segment id="50">As quatro vítimas que compareceram à 6ª DT para registrar queixa eram mulheres.</segment>
    <segment id="51">Rei fez questão de dizer que era homossexual ao ser questionado</segment>
    <segment id="52">sese era casado ou tinha filhos.</segment>
  </rst>
</analysis>