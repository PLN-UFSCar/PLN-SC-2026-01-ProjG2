  <rst>
    <segment id="1">Linchado depois de matar o vizinho</segment>
    <segment id="2">Homem mata vizinho com uma facada</segment>
    <segment id="3">, foge pelo mato e é morto horas depois a pauladas
Moradores do bairro de Águas Claras lincharam o vigilante Deive Mendes Silva</segment>
    <segment id="4">, 32 anos</segment>
    <segment id="5">, na manhã de ontem</segment>
    <segment id="6">, na Rua Ayrton Senna</segment>
    <segment id="7">, em represália ao assassinato do pedreiro Joceval Pereira da Cruz</segment>
    <segment id="8">, 33, conhecido</segment>
    <segment id="9">comocomo Val</segment>
    <segment id="10">, na noite de sábado.</segment>
    <segment id="11">De acordo com testemunhas</segment>
    <segment id="12">, Deive matou Val com uma facada no peito durante uma discussão por causa da fechadura de um portão.</segment>
    <segment id="13">Ambos eram vizinhos.</segment>
    <segment id="14">“Val foi abrir o portão do beco depois que a mulher de Deive começou a bater e gritar</segment>
    <segment id="15">porque</segment>
    <segment id="16">porque não conseguia entrar.</segment>
    <segment id="17">Deive saiu de casa perguntando o que estava acontecendo e deu a facada quando Val</segment>
    <segment id="18">sese virou”</segment>
    <segment id="19">, conta Luiz Antonio</segment>
    <segment id="20">, compadre de Joceval.</segment>
    <segment id="21">Val colocou o portão no beco onde morava há cerca de 15 dias pensando na segurança do local e distribuiu as chaves aos vizinhos.</segment>
    <segment id="22">Deive e a mulher</segment>
    <segment id="23">, Antônia Elias</segment>
    <segment id="24">, conhecida</segment>
    <segment id="25">comocomo Tonha</segment>
    <segment id="26">, fugiram após o crime.</segment>
    <segment id="27">“Tonha disse que Val deu uma chave falsa e por isso  ela não conseguia abrir o portão.</segment>
    <segment id="28">Mas ela estava bebendo muito no dia do crime”</segment>
    <segment id="29">, afirma Luiz.</segment>
    <segment id="30">Família presenciou a morte de Joceval</segment>
    <segment id="31">A mulher de Joceval</segment>
    <segment id="32">, Robéria Alves da Silva</segment>
    <segment id="33">, e o filho de 7 anos do casal viram ele ser esfaqueado.</segment>
    <segment id="34">“</segment>
    <segment id="35">Meu afilhado disse que Deive empurrou ele</segment>
    <segment id="36">, que acabou batendo a cabeça na parede”</segment>
    <segment id="37">, conta o pedreiro Luiz Antônio.</segment>
    <segment id="38">“</segment>
    <segment id="39">Eu cheguei cinco minutos após o assassinato.</segment>
    <segment id="40">Ia dar a notícia a ele (Val) que no dia 1º de fevereiro era para ele comparecer ao novo emprego”</segment>
    <segment id="41">, completa.</segment>
    <segment id="42">A população passou a madrugada procurando Deive</segment>
    <segment id="43">, que fugiu por uma mata.</segment>
    <segment id="44">O adeus</segment>
    <segment id="45">O corpo de Joceval foi enterrado ontem no Cemitério Quinta dos Lázaros.</segment>
    <segment id="46">“Era uma pessoa honesta</segment>
    <segment id="47">, trabalhadora.</segment>
    <segment id="48">Conheço ele há 20 anos.</segment>
    <segment id="49">Era um bom profissional.</segment>
    <segment id="50">Construiu e reformou várias casas em Águas Claras”</segment>
    <segment id="51">, lembra o carpinteiro José Costa</segment>
    <segment id="52">, 40.</segment>
    <segment id="53">“Era pacífico</segment>
    <segment id="54">, gente boa e muito alegre”</segment>
    <segment id="55">, afirma a professora Telma Gomes.</segment>
    <segment id="56">Joceval deixou mulher e três filhos.</segment>
  </rst>
</analysis>