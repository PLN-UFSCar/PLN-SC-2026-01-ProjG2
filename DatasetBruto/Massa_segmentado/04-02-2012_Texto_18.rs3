  <rst>
    <segment id="1">Fofoqueiro tricolor será titular</segment>
    <segment id="2">Morais soltou que Renato Gaúcho quer ficar no Rio para cuidar da “bela” filha</segment>
    <segment id="3">Morais botou a boca no trombone no Fazendão.</segment>
    <segment id="4">Principal novidade do Bahia para enfrentar o Itabuna amanhã</segment>
    <segment id="5">, às 5h da tarde</segment>
    <segment id="6">, no Estádio Luís Viana Filho</segment>
    <segment id="7">, o meia deu uma de fofoqueiro e entregou Renato Gaúcho.</segment>
    <segment id="8">O treinador é o mais cotado para assumir o Bahia</segment>
    <segment id="9">, masmas</segment>
    <segment id="10">, segundo Morais</segment>
    <segment id="11">, ele não quer deixar o Rio de Janeiro para cuidar da filha</segment>
    <segment id="12">, a bela Carolina Portaluppi</segment>
    <segment id="13">, de 17 anos.</segment>
    <segment id="14">“Tem uma resenha forte que rola nos bastidores.</segment>
    <segment id="15">O Renato estava muito bem em Curitiba (no Atlético-PR</segment>
    <segment id="16">, em 2011)</segment>
    <segment id="17">, masmas de repente pediu para sair.</segment>
    <segment id="18">Parece que ele estava preocupado</segment>
    <segment id="19">, pois</segment>
    <segment id="20">pois tem uma filha muito bonita.</segment>
    <segment id="21">E um monte de revista está atrás para tirar foto dela.</segment>
    <segment id="22">Dizem que ele quer ficar no Rio para cuidar dela”</segment>
    <segment id="23">, brincou o fofoqueiro tricolor.</segment>
    <segment id="24">E o meia parece ter razão.</segment>
    <segment id="25">Em uma entrevista de 2011</segment>
    <segment id="26">, Renato Gaúcho mostrou que é um ‘pai coruja’.</segment>
    <segment id="27">“Eu sou muito ciumento com ela mesmo.</segment>
    <segment id="28">Mas nossa relação</segment>
    <segment id="29">, como</segment>
    <segment id="30">como eu falei</segment>
    <segment id="31">, é aberta.</segment>
    <segment id="32">Ela me conta tudo.</segment>
    <segment id="33">Só que a Carol está crescendo.</segment>
    <segment id="34">Essa é a fase em que acontecem os namoros</segment>
    <segment id="35">, fica querendo sair.</segment>
    <segment id="36">Não posso estar 24 horas ao seu lado.</segment>
    <segment id="37">Só espero que ela saiba</segment>
    <segment id="38">sese defender”</segment>
    <segment id="39">, contou.</segment>
    <segment id="40">Enquanto Renato Gaúcho e o Bahia não definem o futuro</segment>
    <segment id="41">, a sexta rodada do Baianão está prestes a acontecer.</segment>
    <segment id="42">Por isso</segment>
    <segment id="43">, a diretoria tricolor improvisou o auxiliar Eduardo Souza para o jogo contra o Itabuna.</segment>
    <segment id="44">O novo treinador mudou pouco: o volante Fahel volta no lugar de Lenine e Morais substitui o criticado Vander.</segment>
    <segment id="45">O esquema tático</segment>
    <segment id="46">, com três volantes</segment>
    <segment id="47">, é o mesmo implementado por Joel Santana.</segment>
    <segment id="48">“</segment>
    <segment id="49">A gente vem de três vitórias e não tive tempo para treinar.</segment>
    <segment id="50">Temos evoluído nos jogos e mudar será muito complicado”</segment>
    <segment id="51">, explicou Eduardo Souza</segment>
  </rst>
</analysis>