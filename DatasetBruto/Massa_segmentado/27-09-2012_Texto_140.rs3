  <rst>
    <segment id="1">Movido pela dor</segment>
    <segment id="2">, pai captura assassino</segment>
    <segment id="3">Seu Gregﾃδｳrio nﾃδ｣o descansou atﾃδｩ pﾃδｴr as mﾃδ｣os no assassino de sua filha
Desde que a filha Larissa dos Santos</segment>
    <segment id="4">, 23 anos</segment>
    <segment id="5">, foi espancada pelo ex-namorado</segment>
    <segment id="6">, Rodrigo Costa dos Santos</segment>
    <segment id="7">, 22 anos</segment>
    <segment id="8">, o porteiro Gregﾃδｳrio Luﾃδｭs dos Santos</segment>
    <segment id="9">, 51, nﾃδ｣o descansou atﾃδｩ ver o assassino da filha preso.</segment>
    <segment id="10">Ontem, oito dias apﾃδｳs o crime</segment>
    <segment id="11">, Rodrigo foi parar atrﾃδ｡s das grades graﾃδｧas a Gregﾃδｳrio.</segment>
    <segment id="12">ﾃ｢竄ｬﾅ滴oje eu vou dormir tranquilo.</segment>
    <segment id="13">Tem oito dias que nﾃδ｣o durmo sﾃδｳ pensando nele e na caﾃδｧadaﾃ｢竄ｬ</segment>
    <segment id="14">, afirmou o pai de Larissa.</segment>
    <segment id="15">O crime ocorreu na manhﾃδ｣ da ﾃδｺltima quarta-feira (19)</segment>
    <segment id="16">, na casa do agressor</segment>
    <segment id="17">, em Fazenda Coutos 2.</segment>
    <segment id="18">Larissa chegou a ser internada no Hospital do Subﾃδｺrbio</segment>
    <segment id="19">, masmas morreu dois dias depois.</segment>
    <segment id="20">No final da manhﾃδ｣ de ontem</segment>
    <segment id="21">, Gregﾃδｳrio recebeu informaﾃδｧﾃδｵes por telefone de que Rodrigo estaria vendendo frutas</segment>
    <segment id="22">, nas proximidades da Madeireira Brotas</segment>
    <segment id="23">, em Pernambuﾃδｩs</segment>
    <segment id="24">, ou na Ceasa</segment>
    <segment id="25">, no CIA.</segment>
    <segment id="26">Ele entﾃδ｣o informou aos policiais da Delegacia Especial de Atendimento ﾃδ Mulher (Deam-Periperi).</segment>
    <segment id="27">Enquanto uma equipe da Deam seguiu para Pernambuﾃδｩs</segment>
    <segment id="28">, Gregﾃδｳrio</segment>
    <segment id="29">, um irmﾃδ｣o e dois colegas seguiram para o CIA e conseguiram impedir a fuga de Rodrigo</segment>
    <segment id="30">, cujos planos era sair do Estado de carona e</segment>
    <segment id="31">sese apresentar com um advogado um ano depois</segment>
    <segment id="32">, conforme foi revelado por ele ontem ﾃδ tarde durante apresentaﾃδｧﾃδ｣o na Deam.</segment>
    <segment id="33">Quando Gregﾃδｳrio e os colegas chegaram ﾃδ Ceasa</segment>
    <segment id="34">, Rodrigo passava a pﾃδｩ em frente ao Galpﾃδ｣o 6.</segment>
    <segment id="35">Ele e um colega o seguiram de carro</segment>
    <segment id="36">, enquanto informavam sobre os passos do agressor ao irmﾃδ｣o e a outro colega.</segment>
    <segment id="37">Ele espera Justiﾃδｧa</segment>
    <segment id="38">ﾃ｢竄ｬﾅ溺eu colega que ﾃδｩ oficial de menor e estava a pﾃδｩ rendeu Rodrigo.</segment>
    <segment id="39">Ele ainda tentou fugir</segment>
    <segment id="40">, masmas meu irmﾃδ｣o segurou e o colega algemouﾃ｢竄ｬ</segment>
    <segment id="41">, contou Gregﾃδｳrio.</segment>
    <segment id="42">Segundo ele</segment>
    <segment id="43">, trabalhadores da Ceasa ameaﾃδｧaram linchar Rodrigo.</segment>
    <segment id="44">Eles foram contidos por policiais e seguranﾃδｧas do centro de abastecimento.</segment>
    <segment id="45">ﾃ｢竄ｬﾅ摘spero agora que haja justiﾃδｧaﾃ｢竄ｬ</segment>
    <segment id="46">, completou o pai da vﾃδｭtima.</segment>
    <segment id="47">ﾃ｢竄ｬﾅ摘le diz que deu apenas um empurrﾃδ｣o</segment>
    <segment id="48">, masmas sabemos que quebrou uma televisﾃδ｣o na cabeﾃδｧa delaﾃ｢竄ｬ</segment>
    <segment id="49">, afirma a delegada da Deam</segment>
    <segment id="50">,  Olveranda Oliveira</segment>
    <segment id="51">, que representou pela prisﾃδ｣o preventiva de Rodrigo no mesmo dia do crime.</segment>
    <segment id="52">Segundo ela</segment>
    <segment id="53">, ele ﾃδｩ traficante</segment>
    <segment id="54">, muito temido</segment>
    <segment id="55">, no bairro e tem passagens por furto</segment>
    <segment id="56">, estupro e envolvimento com um homicﾃδｭdio.</segment>
