  <rst>
    <segment id="1">Tenente-coronel assumiu seu 1º batalhão</segment>
    <segment id="2">, em São Gonçalo</segment>
    <segment id="3">, por indicação do comandante da PM</segment>
    <segment id="4">O Tenente-coronel é famoso por seus serviços operacionais
RIO - Ex-"caveira"</segment>
    <segment id="5">, como</segment>
    <segment id="6">como são conhecidos os integrantes do Batalhão de Operações Especiais (Bope)</segment>
    <segment id="7">, o tenente-coronel Cláudio Luiz Silva de Oliveira</segment>
    <segment id="8">, de 46 anos</segment>
    <segment id="9">, trabalhou na tropa de elite da Polícia Militar no setor de inteligência</segment>
    <segment id="10">, conhecido</segment>
    <segment id="11">comocomo serviço reservado</segment>
    <segment id="12">, no ano de 1995.</segment>
    <segment id="13">Ao todo</segment>
    <segment id="14">, são 26 anos na corporação</segment>
    <segment id="15">, entrando</segment>
    <segment id="16">comocomo aspirante em 1987.</segment>
    <segment id="17">Seu primeiro comando foi do 7 BPM (São Gonçalo)</segment>
    <segment id="18">, onde permaneceu de 15 de outubro do ano passado a 2 de setembro</segment>
    <segment id="19">, logo depois do assassinato da juíza Patrícia Acioli.</segment>
    <segment id="20">O oficial foi nomeado pelo comandante-geral da PM</segment>
    <segment id="21">, Mário Sérgio Duarte</segment>
    <segment id="22">, que na época disse que ele tinha</segment>
    <segment id="23">comocomo missão melhorar a produtividade do quartel e reduzir os índices de criminalidade da região</segment>
    <segment id="24">, principalmente os das mortes em confronto.</segment>
    <segment id="25">Sua fama de ser um policial operacional</segment>
    <segment id="26">, por conta da atuação que teve no Bope</segment>
    <segment id="27">, fez com que o tenente-coronel Cláudio assumisse</segment>
    <segment id="28">, por último</segment>
    <segment id="29">, o comando do 22 BPM (Maré)</segment>
    <segment id="30">, numa das áreas conflagradas da cidade -- que inclui o Complexo da Maré e Manguinhos.</segment>
    <segment id="31">Na véspera de sua prisão</segment>
    <segment id="32">, na madrugada de ontem</segment>
    <segment id="33">, o oficial ganhou destaque nas páginas dos jornais por ter pedido o fechamento da Unidade de Pronto Atendimento (UPA) da Maré.</segment>
    <segment id="34">Informações do serviço de inteligência do batalhão davam conta da existência de bandidos com armamento perto do local.</segment>
    <segment id="35">Oficial estava no 9 BPM quando ocorreu chacina</segment>
    <segment id="36">O lado operacional do oficial também é lembrado quando ele era major do 9 BPM (Rocha Miranda)</segment>
    <segment id="37">, período em que ocorreu a chacina de Vigário Geral</segment>
    <segment id="38">, em 29 de agosto de 1993</segment>
    <segment id="39">, na qual 21 pessoas foram executadas.</segment>
    <segment id="40">Na época</segment>
    <segment id="41">, o crime foi atribuído a um grupo de extermínio formado por PMs daquele quartel</segment>
    <segment id="42">, conhecido</segment>
    <segment id="43">comocomo "cavalos corredores".</segment>
    <segment id="44">Mesmo antes de assumir o comando do 7 BPM</segment>
    <segment id="45">, o tenente-coronel já tinha passado por lá</segment>
    <segment id="46">, masmas não</segment>
    <segment id="47">comocomo comandante.</segment>
    <segment id="48">Ele também esteve no 16 BPM (Olaria) e no 3 BPM (Méier).</segment>
    <segment id="49">Neste último</segment>
    <segment id="50">, o oficial atuou</segment>
    <segment id="51">comocomo subcomandante do coronel Marcus Alexandre Santos de Almeida - exonerado no início do ano por ter visitado o sargento da PM Marcos Vieira de Souza</segment>
    <segment id="52">, o Falcon</segment>
    <segment id="53">, no Batalhão de Choque da PM</segment>
    <segment id="54">, suspeito de envolvimento com uma milícia.</segment>
    <segment id="55">Outro episódio emblemático ocorreu nesse batalhão em janeiro de 2008: um grupo de PMs foi flagrado furtando cerveja e outras bebidas de um caminhão de uma cervejaria</segment>
    <segment id="56">, no Lins.</segment>
    <segment id="57">Um dos acusados era o tenente Daniel dos Santos Benitez Lopes</segment>
    <segment id="58">, acusado de ser um dos assassinos de Patrícia Acioli.</segment>
    <segment id="59">Até carros da PM foram usados para o transporte da bebida.</segment>
    <segment id="60">Benitez já era tenente nessa época e trabalhava</segment>
    <segment id="61">comocomo supervisor da equipe.</segment>
    <segment id="62">Logo que assumiu o 7 BPM (São Gonçalo)</segment>
    <segment id="63">, o tenente-coronel Cláudio o convidou para integrar sua equipe</segment>
    <segment id="64">comocomo chefe do Grupamento de Apoio Tático (GAT)</segment>
    <segment id="65">, uma espécie de tropa de choque do quartel.</segment>
    <segment id="66">Perguntado</segment>
    <segment id="67">sese o tenente-coronel respondia a alguma sindicância na Corregedoria da PM</segment>
    <segment id="68">, o secretário de Segurança Pública</segment>
    <segment id="69">, José Mariano Beltrame</segment>
    <segment id="70">, disse que não tinha essa informação.</segment>
    <segment id="71">A PM também não informou a ficha do oficial.</segment>
    <segment id="72">Segundo uma fonte</segment>
    <segment id="73">, em depoimento informal à Justiça</segment>
    <segment id="74">, o PM preso que colaborou para elucidar o assassinato da juíza disse que o comandante tinha o apelido de Tudão</segment>
    <segment id="75">, por exigir que os integrantes do GAT fossem cada vez mais operacionais.</segment>
  </rst>
</analysis>