  <rst>
    <segment id="1">Mara nasceu virada pra lua
Ela já ganhou vários prêmios de rádios e Tvs.</segment>
    <segment id="2">Agora, levou uma sala da Itapoan FM</segment>
    <segment id="3">Enquanto muitos buscam  sorte para</segment>
    <segment id="4">sese dar bem na vida</segment>
    <segment id="5">, parece que a sorte é quem procura por Mara Souza</segment>
    <segment id="6">, 29.</segment>
    <segment id="7">Só no ano passado</segment>
    <segment id="8">, ela ganhou mais de dez prêmios de emissoras de rádio e televisão.</segment>
    <segment id="9">Este ano</segment>
    <segment id="10">, a sortuda já faturou cinco prêmios.</segment>
    <segment id="11">Para incentivar os fluidos positivos</segment>
    <segment id="12">, ela comemorou o aniversário de 29 anos</segment>
    <segment id="13">, ontem</segment>
    <segment id="14">, com um presentão da Itapoan FM: um conjunto de móveis para sala com hack</segment>
    <segment id="15">, TV de 42 polegadas e home theater.</segment>
    <segment id="16">São tantos prêmios faturados que Mara já perdeu a conta.</segment>
    <segment id="17">Fazem parte da lista ferro elétrico</segment>
    <segment id="18">, máquina de lavar</segment>
    <segment id="19">, geladeira</segment>
    <segment id="20">, freezer</segment>
    <segment id="21">, vale-compras</segment>
    <segment id="22">, ingresso e até dinheiro</segment>
    <segment id="23">, na virada de ano.</segment>
    <segment id="24">A danada nem compra mais ingresso para show</segment>
    <segment id="25">, pois</segment>
    <segment id="26">pois ganha com frequência.</segment>
    <segment id="27">Para festejar o niver em grande estilo</segment>
    <segment id="28">, foi preparado um bolo com o logotipo da rádio e uma feijoada.</segment>
    <segment id="29">Agora, ela espera ganhar um  computador para completar o estoque.</segment>
    <segment id="30">O segredo de tanta sorte: apostas constantes

Não é à toa que Mara ganha tantos prêmios.</segment>
    <segment id="31">Sempre atenta</segment>
    <segment id="32">, ela liga todos os dias para todas a emissoras de rádios que costuma ouvir.</segment>
    <segment id="33">Com 10 mil em bônus no celular</segment>
    <segment id="34">, as ligações não param e o ouvido</segment>
    <segment id="35">, às vezes</segment>
    <segment id="36">, até esquenta.</segment>
    <segment id="37">Além do investimento</segment>
    <segment id="38">, a imagem de Santa Bárbara</segment>
    <segment id="39">, de quem é devota</segment>
    <segment id="40">, serve de amuleto e está sempre guardado na carteira.</segment>
    <segment id="41">Sabendo da vantagem que acompanha Mara</segment>
    <segment id="42">, os amigos fazem várias gozações</segment>
    <segment id="43">, além de passar trotes diários</segment>
    <segment id="44">, anunciando falsos prêmios.</segment>
    <segment id="45">Enquanto ela</segment>
    <segment id="46">sese dá bem nas apostas</segment>
    <segment id="47">, no amor</segment>
    <segment id="48">, afirma ser um pouco diferente.</segment>
    <segment id="49">De vez em quando</segment>
    <segment id="50">, a sortuda costuma enfrentar altas crises no relacionamento.</segment>
    <segment id="51">Você sabia?</segment>
    <segment id="52">Para ter sorte</segment>
    <segment id="53">, toda manhã</segment>
    <segment id="54">, coloque uma vasilha com água sob o sol até que o líquido esquente.</segment>
    <segment id="55">Tire a vasilha antes de anoitecer.</segment>
    <segment id="56">Em casa</segment>
    <segment id="57">, coloque  uma estatueta de coruja em um lugar especial.</segment>
    <segment id="58">A estatueta pode ser comprada de acordo com sua preferência.</segment>
    <segment id="59">À noite</segment>
    <segment id="60">, banhe a coruja com a água em uma banheira ou  torneira.</segment>
    <segment id="61">Repita esse ritual todas as quartas-feiras</segment>
    <segment id="62">, durante um mês</segment>
    <segment id="63">, trocando a água sempre que fizer a simpatia.</segment>
    <segment id="64">Após ter feito o ritual</segment>
    <segment id="65">, não deixe ninguém tocar na estátua</segment>
    <segment id="66">, pois</segment>
    <segment id="67">pois ela será o seu amuleto de sorte.</segment>
    <segment id="68">Guarde-o sempre com você</segment>
    <segment id="69">, inclusive na bolsa.</segment>
    <segment id="70">A vasilha pode ser usada normalmente depois do ritual</segment>
    <segment id="71">, inclusive por outras pessoas.</segment>
  </rst>
</analysis>