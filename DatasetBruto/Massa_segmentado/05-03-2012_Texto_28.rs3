  <rst>
    <segment id="1">Kina acende o fogo das paixões</segment>
    <segment id="2">Cantor bota o povo para dançar juntinho</segment>
    <segment id="3">O cantor e compositor  sertanejo Kina Rodrigues completa um ano de carreira solo depois de 15 anos de estrada.</segment>
    <segment id="4">Tímido</segment>
    <segment id="5">, no palco ele</segment>
    <segment id="6">sese transforma fazendo o público dançar e</segment>
    <segment id="7">sese emocionar.</segment>
    <segment id="8">O assédio das fãs é inevitável</segment>
    <segment id="9">, já que o músico fala de amor.</segment>
    <segment id="10">Com esse cenário</segment>
    <segment id="11">, algumas tietes mais assanhadas querem tirar uma lasquinha do cantor.</segment>
    <segment id="12">“Eu nunca fui pegador</segment>
    <segment id="13">, masmas respeito quando elas chegam sem respeito”</segment>
    <segment id="14">, brinca o autor de “Bombeiro Apaixonado” e “Você me Perdeu”</segment>
    <segment id="15">, sua mais nova  música de trabalho.</segment>
    <segment id="16">Assim como</segment>
    <segment id="17">como boa parte dos cantores sertanejos</segment>
    <segment id="18">, Kina leva na bagagem o forró.</segment>
    <segment id="19">Não é para menos</segment>
    <segment id="20">, já que o músico integrou a Estakazero.</segment>
    <segment id="21">“Não é possível</segment>
    <segment id="22">sese afastar do forró tocando sertanejo.</segment>
    <segment id="23">Um ritmo lembra o outro”</segment>
    <segment id="24">, afirma o moço de Irecê</segment>
    <segment id="25">, onde já levou multidões a seus shows.</segment>
    <segment id="26">A aprovação do público também vem do contato mantido com seus fãs pelas redes sociais.</segment>
    <segment id="27">“</segment>
    <segment id="28">Reconheço seus rostos de cima do palco”</segment>
    <segment id="29">, garante.</segment>
    <segment id="30">Novo trabalho</segment>
    <segment id="31">O primeiro CD autoral do cantor e compositor Kina Rodrigues será lançado no início do mês de abril.</segment>
    <segment id="32">“</segment>
    <segment id="33">Criei músicas para as pessoas dançarem e</segment>
    <segment id="34">sese apaixonarem.</segment>
    <segment id="35">Quero que todos curtam”</segment>
    <segment id="36">, comenta.</segment>
    <segment id="37">O músico compôs 12 canções para o álbum.</segment>
    <segment id="38">Entre elas</segment>
    <segment id="39">, “Dança e Mexe”</segment>
    <segment id="40">, que dá nome ao disco e que promete embalar o coração de muitos nas baladas de Salvador.</segment>
  </rst>
</analysis>