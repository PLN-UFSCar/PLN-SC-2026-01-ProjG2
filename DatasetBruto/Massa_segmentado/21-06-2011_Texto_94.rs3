  <rst>
    <segment id="1">Aulas do 3º ano começam na segunda</segment>
    <segment id="2">Aulas serão diárias em 19 escolas e seguem a carga horária das disciplinas
Aulas presenciais</segment>
    <segment id="3">, revisão de conteúdos do Exame Nacional do Ensino Médio (Enem) e aulas shows.</segment>
    <segment id="4">Essas foram as medidas apresentadas pelo secretário de Educação</segment>
    <segment id="5">, Osvaldo Barreto</segment>
    <segment id="6">,  ontem</segment>
    <segment id="7">, para que</segment>
    <segment id="8">para que os  alunos do 3° ano do Ensino Médio não fiquem sem aulas durante a greve dos professores da rede estadual</segment>
    <segment id="9">, que entra</segment>
    <segment id="10">, hoje</segment>
    <segment id="11">, no 72° dia.</segment>
    <segment id="12">As aulas</segment>
    <segment id="13">, que começam a partir da próxima segunda-feira</segment>
    <segment id="14">, serão diárias</segment>
    <segment id="15">, em 19 unidades escolares e vão obedecer à carga horária de cada disciplina.</segment>
    <segment id="16">Segundo Barreto</segment>
    <segment id="17">, os estudantes serão mantidos em suas turmas originais.</segment>
    <segment id="18">O  projeto engloba também 384 aulões para o Enem</segment>
    <segment id="19">, distribuídos em 24 polos</segment>
    <segment id="20">, dos quais 13 em Salvador e 11 no interior do Estado.</segment>
    <segment id="21">Cada aulão será ministrado por quatro professores de diferentes áreas e será organizado e apresentado pelo professor Jorge Portugal.</segment>
    <segment id="22">O primeiro aulão acontece na próxima quarta-feira</segment>
    <segment id="23">,  na Escola Parque</segment>
    <segment id="24">, no bairro da Caixa D’Água.</segment>
    <segment id="25">Além de Salvador</segment>
    <segment id="26">, os aulões serão realizados</segment>
    <segment id="27">, ainda</segment>
    <segment id="28">, em Lauro de Freitas</segment>
    <segment id="29">, Feira de Santana</segment>
    <segment id="30">, Alagoinhas</segment>
    <segment id="31">, Ilhéus</segment>
    <segment id="32">, Itabuna</segment>
    <segment id="33">, Eunápolis</segment>
    <segment id="34">, Teixeira de Freitas</segment>
    <segment id="35">, Paulo Afonso</segment>
    <segment id="36">, Jequié</segment>
    <segment id="37">, Juazeiro</segment>
    <segment id="38">, Vitória da Conquista e Barreiras.</segment>
    <segment id="39">Está prevista</segment>
    <segment id="40">, também</segment>
    <segment id="41">, a gravação de 175 edições do programa</segment>
    <segment id="42">É Bom Saber</segment>
    <segment id="43">, que abordará temáticas contemporâneas.</segment>
    <segment id="44">O programa (TVE) compreende 15 aulas show gravadas em bairros populares da capital e em cidades do interior.</segment>
  </rst>
</analysis>