  <rst>
    <segment id="1">PolГғВӯcia procura fujГғВЈo que deu o ninja</segment>
    <segment id="2">Ele</segment>
    <segment id="3">ГғВ© amigo do cara que fez os policiais de besta</segment>
    <segment id="4">A polГғВӯcia procura o homem que arrombou a mala de uma viatura da 26ГӮВӘ CIPM (Brotas) e fugiu instantes antes de o veГғВӯculo entrar na 6ГӮВӘ DT (Brotas)</segment>
    <segment id="5">, na terГғВ§a-feira (14).</segment>
    <segment id="6">ГўвӮ¬Е“Ele deu uma pesada e arrombou o fundo da viatura</segment>
    <segment id="7">, quando o policial manobrava para entrar na delegacia.</segment>
    <segment id="8">Um PM ainda correu atrГғВЎs</segment>
    <segment id="9">, masmas nГғВЈo adiantouГўвӮ¬</segment>
    <segment id="10">, disse o delegado MГғВЎrio Augusto Ribeiro.</segment>
    <segment id="11">Ao contrГғВЎrio do que foi divulgado</segment>
    <segment id="12">, o fujГғВЈo nГғВЈo</segment>
    <segment id="13">sese chama Wellington Matos Nascimento</segment>
    <segment id="14">, 27, o Chocolate</segment>
    <segment id="15">, segundo a polГғВӯcia.</segment>
    <segment id="16">Na realidade</segment>
    <segment id="17">, Wellington ГғВ© comparsa do fujГғВЈo</segment>
    <segment id="18">, que ainda nГғВЈo teve o nome identificado.</segment>
    <segment id="19">Chocolate estava junto do fujГғВЈo</segment>
    <segment id="20">, masmas escapou antes de ser preso.</segment>
    <segment id="21">Entenda a confusГғВЈo</segment>
    <segment id="22">Com o fujГғВЈo</segment>
    <segment id="23">, os policiais encontraram uma sacola com a cГғВіpia de uma certidГғВЈo de nascimento em nome de Wellington</segment>
    <segment id="24">, daГғВӯ a confusГғВЈo de pensarem que o espertinho era Chocolate.</segment>
    <segment id="25">Chocolate tem passagens e mandado de prisГғВЈo em aberto por roubo.</segment>
    <segment id="26">O rapaz que fugiu da viatura era suspeito de ter roubado o celular de uma adolescente</segment>
    <segment id="27">, naquele dia</segment>
    <segment id="28">, na regiГғВЈo de Brotas.</segment>
