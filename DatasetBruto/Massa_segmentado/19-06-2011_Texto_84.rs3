  <rst>
    <segment id="1">Maior abandonado</segment>
    <segment id="2">Alberto ‘mora’ no ponto do buzu e faz as necessidades fisiológicas em garrafas</segment>
    <segment id="3">Há cinco meses</segment>
    <segment id="4">Alberto Pinho de Campos</segment>
    <segment id="5">, 61, é morador de um ponto de ônibus na Alameda Praia Barra dos Coqueiros</segment>
    <segment id="6">, em Stella Maris.</segment>
    <segment id="7">Ele depende da bondade de moradores dos condomínios</segment>
    <segment id="8">, que lhe dão comida e água.</segment>
    <segment id="9">Com as pernas machucadas e inchadas</segment>
    <segment id="10">, Alberto está acima do peso e tem dificuldade para</segment>
    <segment id="11">sese locomover.</segment>
    <segment id="12">Ele passa os dias lendo revistas</segment>
    <segment id="13">, jornais velhos e desenhando.</segment>
    <segment id="14">Ele foi parar nas ruas em 2001 e diz que tinha uma moradia e acusa os irmãos de tê-lo enganado para conseguir vender o imóvel da família.</segment>
    <segment id="15">“Eles me fizeram assinar um papel em branco para vender a casa”</segment>
    <segment id="16">, lamenta.</segment>
    <segment id="17">A Setad tentou levá-lo para um abrigo</segment>
    <segment id="18">, masmas ele recusa e fica agressivo.</segment>
    <segment id="19">O órgão informa que vai encaminhá-lo para tratamento médico.</segment>
  </rst>
</analysis>