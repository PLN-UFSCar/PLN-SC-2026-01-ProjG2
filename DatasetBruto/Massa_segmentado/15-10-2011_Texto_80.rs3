  <rst>
    <segment id="1">Mega-Sena de R$ 45 milhões sai para aposta do Piauí
RIO-</segment>
    <segment id="2">O prêmio principal do concurso 1328 da Mega-Sena</segment>
    <segment id="3">, de R$ 45.390.782</segment>
    <segment id="4">,32, saiu para um bilhete deTeresina</segment>
    <segment id="5">, no Piauí</segment>
    <segment id="6">, segundo informou a Caixa Econômica Federal neste sábado</segment>
    <segment id="7">O sorteio aconteceu neste sábado</segment>
    <segment id="8">, em Chapecó</segment>
    <segment id="9">, em Santa Catarina.</segment>
    <segment id="10">Os números sorteados foram: 10- 23 - 27 - 43 - 53 - 59.</segment>
    <segment id="11">A quinasaiu para 213 apostadores</segment>
    <segment id="12">, que vão receber R$ 16.945</segment>
    <segment id="13">,58 cada.</segment>
    <segment id="14">Já 14.179apostadores acertaram a quadra e receberão R$ 363</segment>
    <segment id="15">,65 cada um.</segment>
    <segment id="16">Para o próximoconcurso</segment>
    <segment id="17">, a ser sorteado na quarta-feira</segment>
    <segment id="18">, dia 19</segment>
    <segment id="19">, o prêmio estimado é de R$ 2 milhões</segment>
  </rst>
</analysis>