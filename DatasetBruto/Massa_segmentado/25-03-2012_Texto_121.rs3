  <rst>
    <segment id="1">Dupla é flagrada ao tentar assaltar caixa em Ipanema
RIO - Por volta das 8h da manhã deste domingo</segment>
    <segment id="2">, dois homens</segment>
    <segment id="3">, munidos de um maçarico</segment>
    <segment id="4">, tentaram violar um caixa eletrônico da agência do Santander da Rua Visconde de Pirajá 585</segment>
    <segment id="5">, em Ipanema.</segment>
    <segment id="6">Os bandidos foram surpreendidos por um policial à paisana</segment>
    <segment id="7">, que, ao perceber o objeto</segment>
    <segment id="8">, além de um pouco de fumaça</segment>
    <segment id="9">, deu voz de prisão aos dois.</segment>
    <segment id="10">Um deles conseguiu fugir num Corsa preto.</segment>
    <segment id="11">O outro</segment>
    <segment id="12">, menor de idade</segment>
    <segment id="13">, foi interceptado por policiais do 23 BPM (Leblon)</segment>
    <segment id="14">, que estavam próximo ao local.</segment>
    <segment id="15">A ocorrência foi registrada na 14ª DP (Leblon).</segment>
    <segment id="16">O menor e o comparsa não conseguiram concluir o roubo</segment>
    <segment id="17">, e uma perícia foi solicitada para investigar</segment>
    <segment id="18">sese a máquina sofreu algum dano.</segment>
    <segment id="19">Até a conclusão da análise</segment>
    <segment id="20">, a agência ficará interditada.</segment>
    <segment id="21">Segundo a PM</segment>
    <segment id="22">, o jovem contou ser integrante de uma quadrilha de Santa Catarina especializada em roubo a caixas eletrônicos.</segment>
    <segment id="23">Disse ainda que ele e os cúmplices estavam hospedados no hotel Formule 1</segment>
    <segment id="24">, na Praça Tiradentes.</segment>
    <segment id="25">Policiais fizeram uma busca no local</segment>
    <segment id="26">, masmas ninguém foi encontrado.</segment>
    <segment id="27">Os suspeitos vestiam a mesma roupa: calça jeans</segment>
    <segment id="28">, camiseta preta</segment>
    <segment id="29">, e por cima</segment>
    <segment id="30">, uma camisa vermelha.</segment>
    <segment id="31">No momento da fuga</segment>
    <segment id="32">, eles correram em direções e trocaram as blusas</segment>
    <segment id="33">, para tentar dificultar a identificação pela polícia.</segment>
    <segment id="34">Uma moradora de Ipanema que pediu para não ser identificada presenciou a cena:

- Foi tudo muito rápido</segment>
    <segment id="35">, só entendemos o que aconteceu quando a polícia chegou.</segment>
    <segment id="36">Segundo a delegada Ana Paula Costa Marques</segment>
    <segment id="37">, o rapaz será apresentado hoje ao Juizado de Menores.</segment>
    <segment id="38">Ele foi apreendido sem documento de identificação.</segment>
    <segment id="39">Segundo a Polícia Federal catarinense</segment>
    <segment id="40">, somente este ano</segment>
    <segment id="41">, já foram registrados cerca de 20 roubos a caixas eletrônicos em todo o estado.</segment>
  </rst>
</analysis>