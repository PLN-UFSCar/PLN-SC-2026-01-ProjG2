  <rst>
    <segment id="1">Rubro-negra
Mayara comemora triunfo do Vitória
Mayara Freitas só tem 17 anos</segment>
    <segment id="2">, masmas já é um mulherão.</segment>
    <segment id="3">A moradora da Lapinha</segment>
    <segment id="4">, no entanto</segment>
    <segment id="5">, avisa: seu coração já tem dono.</segment>
    <segment id="6">“Somos muito apaixonados um pelo outro.</segment>
    <segment id="7">Mas em relação ao ciúmes</segment>
    <segment id="8">, eu acho que ganho”</segment>
    <segment id="9">, admite.

Paixão igual</segment>
    <segment id="10">, só pelo seu time do coração.</segment>
    <segment id="11">Nem por isso  ela deixa as críticas de lado.</segment>
    <segment id="12">“Não  gosto da tática de Cerezo</segment>
    <segment id="13">, de manter mais de um volante no jogo.</segment>
    <segment id="14">Isso torna a equipe menos defensiva e com pouca opção de ataque”</segment>
    <segment id="15">, comenta a  convicta torcedora do Vitória.</segment>
    <segment id="16">Amor aos bichos</segment>
    <segment id="17">Ela não tem medo de nada.</segment>
    <segment id="18">E pretende estudar para ser veterinária e cuidar de feras</segment>
    <segment id="19">, como</segment>
    <segment id="20">como o leão</segment>
    <segment id="21">, mascote de seu time.</segment>
  </rst>
