  <rst>
    <segment id="1">Xadrez: Incendiário em cana
Morador de rua que ateou fogo em vendedor ambulante é capturado no interior do estado</segment>
    <segment id="2">A polícia colocou as mãos no morador de rua Antônio Conceição Almeida</segment>
    <segment id="3">, conhecido</segment>
    <segment id="4">comocomo Grande.</segment>
    <segment id="5">Ele estava sendo procurado desde o dia três de outubro quando ateou fogo ao corpo do vendedor ambulante Mário Sérgio Cunha Santos</segment>
    <segment id="6">, 43 anos.</segment>
    <segment id="7">O crime aconteceu na Travessa Bonfim</segment>
    <segment id="8">, no bairro do Pero Vaz.</segment>
    <segment id="9">Grande foi preso em Valença</segment>
    <segment id="10">, cidade da região do Baixo Sul baiano</segment>
    <segment id="11">, que fica a 256 Km de Salvador.</segment>
    <segment id="12">Ele deve ser apresentado hoje à imprensa depois de ser ouvido pela delegada titular da 2ª DT (Lapinha)</segment>
    <segment id="13">, Heleneci Souza Nascimento.</segment>
    <segment id="14">De acordo com a irmã de Mário</segment>
    <segment id="15">, Celidalva Campos Santos</segment>
    <segment id="16">, o ambulante sofreu queimaduras em 80% do corpo  e está internado no Hospital Geral do Estado (HGE).</segment>
    <segment id="17">O quadro de saúde é grave.</segment>
    <segment id="18">Segundo a polícia</segment>
    <segment id="19">, Grande dormia na porta de uma padaria</segment>
    <segment id="20">, masmas o dono não o queria mais por lá.</segment>
    <segment id="21">Uma das hipóteses para o crime é que Grande acreditava que partiu da vítima a ideia de expulsá-lo do local.</segment>
    <segment id="22">Ele chegou por trás do ambulante</segment>
    <segment id="23">,  jogou   gasolina e ateou fogo.</segment>
    <segment id="24">As pessoas tiveram que usar extintor para apagar as chamas.</segment>
    <segment id="25">Fé e oração:</segment>
    <segment id="26">Sem previsão de alta</segment>
    <segment id="27">A irmã de Mário Sérgio</segment>
    <segment id="28">, Celidalva Campos</segment>
    <segment id="29">, diz que o irmão ainda não tem previsão de receber alta.</segment>
    <segment id="30">Mário tinha uma banca onde vendia frutas na Travessa Bonfim</segment>
    <segment id="31">, no Pero Vaz.</segment>
    <segment id="32">Quando ele foi queimado</segment>
    <segment id="33">, Grande também colocou fogo nas mercadorias.</segment>
    <segment id="34">O prejuízo seria de R$ 1.500.</segment>
    <segment id="35">Mário tem mulher e dois filhos</segment>
    <segment id="36">, que dependem do trabalho dele.</segment>
    <segment id="37">“A situação do meu irmão é bastante grave.</segment>
    <segment id="38">Ele está vivo pela misericórdia de Deus.</segment>
    <segment id="39">Tem muita gente orando por ele”</segment>
    <segment id="40">, conta Celidalva.</segment>
    <segment id="41">“</segment>
    <segment id="42">Meu irmão é uma pessoa direita.</segment>
    <segment id="43">Não tem passagem pela polícia.</segment>
    <segment id="44">Nem por discussão”</segment>
    <segment id="45">, completa.</segment>
    <segment id="46">Mário acordava cedo todos os dias e às 4 horas da manhã já estava na Feira de São Joaquim para comprar frutas e revender no bairro do Pero Vaz.</segment>
    <segment id="47">Agora, Celidalva está indo comprar as frutas</segment>
    <segment id="48">, e a mulher de Mário</segment>
    <segment id="49">, vendendo.</segment>
    <segment id="50">Mário Sérgio Santos está internado em estado grave no HGE com 80% do corpo queimado</segment>
    <segment id="51">Amigos organizam festa</segment>
    <segment id="52">A comunidade do Pero Vaz está organizando um evento beneficente para ajudar Mário Sérgio.</segment>
    <segment id="53">Uma comissão</segment>
    <segment id="54">sese reúne hoje para definir a atração e o horário da festa</segment>
    <segment id="55">, que deverá ser realizada na Associação de Pais e Mestres da Meireles</segment>
    <segment id="56">, no Pero Vaz</segment>
    <segment id="57">, no próximo sábado.</segment>
    <segment id="58">O dinheiro arrecadado com a venda dos ingressos será revertido para a família do vendedor.</segment>
    <segment id="59">Um carro de som vai circular pelas ruas dos bairros da Liberdade e Pero Vaz para anunciar o evento.</segment>
    <segment id="60">“</segment>
    <segment id="61">Meu irmão é um homem que vivia do próprio suor.</segment>
    <segment id="62">O que ganhava em um dia usava para sobreviver e comprar mais mercadoria.</segment>
    <segment id="63">Todo mundo conhece e gosta dele”</segment>
    <segment id="64">, lembra Celidalva.</segment>
  </rst>
</analysis>