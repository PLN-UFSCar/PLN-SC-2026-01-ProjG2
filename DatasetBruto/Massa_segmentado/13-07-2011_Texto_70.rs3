  <rst>
    <segment id="1">Caso Juan:</segment>
    <segment id="2">apenas um cabo atirou</segment>
    <segment id="3">, diz laudo
RIO - O laudo de confronto balístico feito por peritos do Instituto de Criminalística Carlos Éboli nos dez fuzis calibre 7</segment>
    <segment id="4">,62 apreendidos com os policiais do 20º BPM (Mesquita) envolvidos no sumiço do menino Juan Moraes Neves</segment>
    <segment id="5">, de 11 anos</segment>
    <segment id="6">, na Favela Danon</segment>
    <segment id="7">, em Nova Iguaçu</segment>
    <segment id="8">, atestou que todas as cápsulas encontradas no beco onde ocorreu o suposto confronto foram disparadas pelo cabo Edilberto Barros do Nascimento</segment>
    <segment id="9">, de 43 anos.</segment>
    <segment id="10">O policial está envolvido ainda em 13 autos de resistência (mortes de suspeitos em confronto com a polícia).
CRÍTICA:</segment>
    <segment id="11">Beltrame declara que</segment>
    <segment id="12">casocaso Juan é 'vergonhoso' e exige transparência</segment>
    <segment id="13">LEIA TAMBÉM:</segment>
    <segment id="14">Após erros em</segment>
    <segment id="15">casocaso Juan</segment>
    <segment id="16">, polícia vai mudar investigação de confrontos</segment>
    <segment id="17">O subcomandante operacional do 20º BPM</segment>
    <segment id="18">, major Caetano</segment>
    <segment id="19">, depôs na quarta-feira na Divisão de Homicídios da Baixada.</segment>
    <segment id="20">Os investigadores queriam saber</segment>
    <segment id="21">sese a operação realizada na Favela Danon no dia 20 de junho</segment>
    <segment id="22">, quando Juan sumiu</segment>
    <segment id="23">, havia sido autorizada pelo comando do batalhão.</segment>
    <segment id="24">O conteúdo das declarações do oficial não foi revelado.</segment>
    <segment id="25">Além de Edilberto</segment>
    <segment id="26">, participaram diretamente da operação que resultou no sumiço de Juan os PMs Isaías Souza do Carmo</segment>
    <segment id="27">, Rubens da Silva e Ubirani Soares.</segment>
    <segment id="28">Os quatro já</segment>
    <segment id="29">sese envolveram em pelo menos 37 autos de resistência.</segment>
    <segment id="30">Edilberto também é réu num processo de homicídio que</segment>
    <segment id="31">, inicialmente</segment>
    <segment id="32">, foi registrado</segment>
    <segment id="33">comocomo auto de resistência.</segment>
  </rst>
</analysis>