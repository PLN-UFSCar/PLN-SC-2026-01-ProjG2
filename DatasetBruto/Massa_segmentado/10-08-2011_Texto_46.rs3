  <rst>
    <segment id="1">Insegurança é comum nas obras</segment>
    <segment id="2">O trabalhador que quiser apontar irregularidades deve ligar</segment>
    <segment id="3">3496-6238
Até julho</segment>
    <segment id="4">, a Superintendência Regional do Trabalho emitiu cerca de R$ 50 milhões em autos de infração na Bahia.</segment>
    <segment id="5">Mais de um quarto (26</segment>
    <segment id="6">,5%) das obras  sofreram embargo ou interdição.</segment>
    <segment id="7">Foram fiscalizados 241 canteiros  e emitidos 1.174 autos de infração por descumprimento de medidas de segurança do trabalhador.</segment>
    <segment id="8">Ou seja</segment>
    <segment id="9">, foram encontradas cinco vezes mais irregularidades do que o número de obras fiscalizadas.</segment>
    <segment id="10">Uma reunião na próxima terça vai tentar costurar um Termo de Ajustamento de Conduta entre patrões e empregados da construção</segment>
    <segment id="11">, com a intermediação da Superintendência do Trabalho.</segment>
    <segment id="12">O encontro foi acertado ontem</segment>
    <segment id="13">, na sede da SRTE</segment>
    <segment id="14">, da qual participaram o Sintracom e o Sinduscon</segment>
    <segment id="15">, que representa as empresas.</segment>
    <segment id="16">Segundo o vice-presidente do Sintracom</segment>
    <segment id="17">, Florivaldo Bispo</segment>
    <segment id="18">, a reunião vai abordar as supostas irregularidades cometidas pelas empresas no cumprimento das Normas Técnicas de Segurança no Trabalho.</segment>
  </rst>
</analysis>