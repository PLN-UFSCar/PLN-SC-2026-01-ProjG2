  <rst>
    <segment id="1">Está pegando
Ex-candidata a musa do Bahia fisga</segment>
    <segment id="2">Neymar</segment>
    <segment id="3">A gata Rianne Ferreira</segment>
    <segment id="4">, ex-candidata a musa do Bahia</segment>
    <segment id="5">, é o novo ‘</segment>
    <segment id="6">casocaso’ do jogador Neymar.</segment>
    <segment id="7">Segundo o site EGO</segment>
    <segment id="8">, a loira já teria até passado alguns dias com o atleta</segment>
    <segment id="9">, em Santos.</segment>
    <segment id="10">Rianne não negou o relacionamento com Neymar.</segment>
    <segment id="11">Ela apenas declarou que não ia comentar o assunto:</segment>
    <segment id="12">“Não tenho nada a dizer sobre isso”</segment>
    <segment id="13">, disse ao blog Donas do Campinho.</segment>
    <segment id="14">Ontem,  Rianne postou uma foto dos dois juntos em seu Facebook e fez uma declaração de amor ao jogador: “Vou te contratar pra vir pro meu Bahia</segment>
    <segment id="15">, meu amor!</segment>
    <segment id="16">Hahahaha....</segment>
    <segment id="17">Sou sua fã e não abro mão!</segment>
    <segment id="18">”.</segment>
    <segment id="19">A gata continuou.</segment>
    <segment id="20">“Ele é lindo!!!!!!!</segment>
    <segment id="21">Vocês falam de todo mundo também!</segment>
    <segment id="22">Neymar é o cara e pronto....</segment>
    <segment id="23">Adoro ele!</segment>
    <segment id="24">Vão ficar na curiosidade!</segment>
    <segment id="25">Quem pode pode</segment>
    <segment id="26">, quem não pode</segment>
    <segment id="27">sese sacode</segment>
    <segment id="28">, fui”</segment>
    <segment id="29">, postou.</segment>
    <segment id="30">Rianne teria conhecido Neymar durante uma partida do Santos contra o Bahia</segment>
    <segment id="31">, em Pituaçu</segment>
  </rst>
</analysis>