  <rst>
    <segment id="1">Alison:</segment>
    <segment id="2">Primeiro título não</segment>
    <segment id="3">sese esquece
Zagueirão chegou em 2007 a Salvador</segment>
    <segment id="4">, masmas até hoje só sabe o que é ser vice</segment>
    <segment id="5">Ao comemorar ontem o aniversário de três aninhos da filha Ana Clara</segment>
    <segment id="6">, Alison também completa três anos em busca do título do Campeonato Baiano.</segment>
    <segment id="7">Após duas tentativas de conquistar a maior glória do futebol estadual com a camisa do Bahia</segment>
    <segment id="8">, Alison está novamente bem perto de alcançar o título.</segment>
    <segment id="9">E desta vez</segment>
    <segment id="10">, como</segment>
    <segment id="11">como capitão da equipe do Vitória</segment>
    <segment id="12">, cabe a ele a honra de levantar a taça</segment>
    <segment id="13">casocaso o time derrote ou empate com o Bahia de Feira no próximo domingo.</segment>
    <segment id="14">“</segment>
    <segment id="15">A expectativa pelo título é tão grande</segment>
    <segment id="16">comocomo das outras vezes</segment>
    <segment id="17">, masmas estou confiante que desta vez teremos um final feliz”</segment>
    <segment id="18">, diz ele</segment>
    <segment id="19">, que levou a filha para brincar no shopping durante a folga</segment>
    <segment id="20">, antes de  retornar aos treinos hoje pela manhã.</segment>
    <segment id="21">Eleito melhor jogador das últimas partidas</segment>
    <segment id="22">, Alison praticamente segura sozinho as pontas na zaga do Vitória</segment>
    <segment id="23">, enquanto Léo Fortunato e Reniê não raramente protagonizam falhas que resultam em gols.</segment>
    <segment id="24">“Acho que os meninos estão indo bem.</segment>
    <segment id="25">Fortunato vem fazendo um belo campeonato e Reniê está dando conta do recado.</segment>
    <segment id="26">Jamais eu estaria fazendo um bom campeonato sem a ajuda dos meus companheiros”</segment>
    <segment id="27">, opina Alison.</segment>
    <segment id="28">No entanto</segment>
    <segment id="29">, o que</segment>
    <segment id="30">sese viu contra o Bahia de Feira foi Reniê falhando e sendo salvo pelo gol que marcou.</segment>
    <segment id="31">“Sempre que acontece algum tipo de vacilo colocam a culpa na defesa.</segment>
    <segment id="32">Mas muitas vezes a falha de marcação começa na frente...</segment>
    <segment id="33">”</segment>
    <segment id="34">Vida nova:</segment>
    <segment id="35">Potiguar quer acabar a fama de pé-fri</segment>
    <segment id="36">Quando foi dispensado do Bahia ao final da temporada passada</segment>
    <segment id="37">, Alison chegou a ser chamado de pé frio pelos torcedores.</segment>
    <segment id="38">Afinal</segment>
    <segment id="39">, foram quatro anos no tricolor e nenhum título baiano.</segment>
    <segment id="40">Em 2008</segment>
    <segment id="41">,  uma falha do zagueiro contribuiu para o placar de  3x0 que deu o título ao Vitória</segment>
    <segment id="42">, jogo lembrado pela provocação do "Senta que é de menta".</segment>
    <segment id="43">O Bahia goleado por 4 a 1</segment>
    <segment id="44">, no Barradão</segment>
    <segment id="45">, no jogo de ida e ainda  assim terminou com o vice.</segment>
    <segment id="46">Uma lesão fez com que ele abandonasse pela metade o Campeonato Baiano de 2009.</segment>
    <segment id="47">Já em 2010</segment>
    <segment id="48">, Alison retornou com força total</segment>
    <segment id="49">, masmas novamente viu o Vitória levar o título graças à vantagem do empate pela  melhor campanha.</segment>
    <segment id="50">“Não fomos campeões duas vezes por causa de um gol”</segment>
    <segment id="51">, recordou Alison.</segment>
    <segment id="52">Depois de ver a taça  ir para as mãos do Vitória por três vezes</segment>
    <segment id="53">, chegou a hora de provar que de pé frio ele não tem nada.</segment>
  </rst>
</analysis>