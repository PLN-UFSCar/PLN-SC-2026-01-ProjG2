  <rst>
    <segment id="1">Delegacia da Barra debaixo-d’água</segment>
    <segment id="2">A unidade espera há mais de sete meses por reforma para resolver o problema
Nada mudou na Delegacia da Barra (14ªDT).</segment>
    <segment id="3">Em novembro do ano passado</segment>
    <segment id="4">, o MASSA!</segment>
    <segment id="5">publicou reportagem mostrando o estado da unidade</segment>
    <segment id="6">, em dias de chuva forte.</segment>
    <segment id="7">As goteiras</segment>
    <segment id="8">sese espalhavam pela delegacia e a água acumulada ameaçava destruir o forro do teto.</segment>
    <segment id="9">Após sete meses</segment>
    <segment id="10">, nada foi feito e a situação piorou.</segment>
    <segment id="11">Na época</segment>
    <segment id="12">, a Polícia Civil emitiu uma nota esclarecendo que a reforma na 14ª DT começaria em breve.</segment>
    <segment id="13">Com o temporal dos últimos dias</segment>
    <segment id="14">, uma tábua do forro do teto do primeiro andar</segment>
    <segment id="15">sese soltou.</segment>
    <segment id="16">A sala do delegado plantonista está praticamente inutilizada devido às goteiras.</segment>
    <segment id="17">Uma bacia é a arma que fica sobre a mesa para aparar a água.</segment>
    <segment id="18">Nesta mesma sala</segment>
    <segment id="19">, está o servidor de internet.</segment>
    <segment id="20">“</segment>
    <segment id="21">A gente já mudou o servidor de lugar três vezes para não molhar.</segment>
    <segment id="22">Ele é o coração da delegacia.</segment>
    <segment id="23">Se der defeito</segment>
    <segment id="24">, os sistemas não funcionam”</segment>
    <segment id="25">, explica um policial</segment>
    <segment id="26">, pedindo anonimato.</segment>
    <segment id="27">Quando a delegacia fica sem internet</segment>
    <segment id="28">, os policiais têm que registrar as ocorrências à mão e não podem acessar o Portal da Secretaria de Segurança Pública (SSP)</segment>
    <segment id="29">, onde é possível consultar a ficha criminal do indivíduo.</segment>
    <segment id="30">Além dos problemas que afetam o trabalho</segment>
    <segment id="31">, existe o risco de vida.</segment>
    <segment id="32">“Se o teto cair na cabeça de alguém</segment>
    <segment id="33">, como</segment>
    <segment id="34">como é que fica?</segment>
    <segment id="35">É complicado trabalhar assim”</segment>
    <segment id="36">, questiona outro policial.</segment>
    <segment id="37">Ações emergenciais</segment>
    <segment id="38">O delegado titular da 14ª DT</segment>
    <segment id="39">, João Roberto Cavadas</segment>
    <segment id="40">, informou que todos os problemas de infraestrutura na delegacia já foram informados ao setor competente da SSP.</segment>
    <segment id="41">A assessoria de comunicação da Polícia Civil informou que medidas serão tomadas</segment>
    <segment id="42">, em caráter de emergência</segment>
    <segment id="43">, sem especificar quais.</segment>
    <segment id="44">O órgão também não informou quando seria feita uma reforma completa na 14ª DT</segment>
    <segment id="45">, diferente do que havia prometido há sete meses.</segment>
    <segment id="46">Enquanto isso</segment>
    <segment id="47">, os serventes da delegacia têm trabalho dobrado para manter o chão seco com tantas goteiras.</segment>
    <segment id="48">“É a mesma coisa de enxugar gelo.</segment>
    <segment id="49">Sábado</segment>
    <segment id="50">, saí daqui 14h</segment>
    <segment id="51">secando as coisas.</segment>
    <segment id="52">Era para eu ter saído 11 horas da manhã”</segment>
    <segment id="53">, relata uma auxiliar de serviços gerias</segment>
    <segment id="54">, que pediu para não ser identificada.</segment>
  </rst>
</analysis>