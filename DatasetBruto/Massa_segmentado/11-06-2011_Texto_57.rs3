  <rst>
    <segment id="1">Vasco sofre gol no fim e empata com Figueirense em dia de festa
TEMPO REAL:</segment>
    <segment id="2">Veja como</segment>
    <segment id="3">como foi o jogo
'REIZINHO':</segment>
    <segment id="4">As imagens da volta de Juninho</segment>
    <segment id="5">A VOLTA: Juninho diz que chega para jogar em 'um time vencedor'
FICA: Ricardo Gomes nega ida para Arábia Saudita
Antes da partida</segment>
    <segment id="6">, Antônio Lopes</segment>
    <segment id="7">, Edmundo e Geovani participaram da festa comandada pela cantora vascaína Fernanda Abreu.</segment>
    <segment id="8">Depois de um atraso de mais de uma hora</segment>
    <segment id="9">, quando a torcida já lotava o estádio</segment>
    <segment id="10">, Juninho chegou e foi ovacionado.</segment>
    <segment id="11">Na plateia</segment>
    <segment id="12">, além de mais de 18 mil pagantes</segment>
    <segment id="13">, Alexandre Pato e a namorada Bárbara Berlusconi</segment>
    <segment id="14">, filha do primeiro-ministro de Itália</segment>
    <segment id="15">, Silvio Berlusconi.</segment>
    <segment id="16">Além deles</segment>
    <segment id="17">, Erasmo Carlos reforçava a torcida vascaína.</segment>
    <segment id="18">Apesar de ter apenas Fernando Prass</segment>
    <segment id="19">, Anderson Martins</segment>
    <segment id="20">, Rômulo</segment>
    <segment id="21">, Allan e Éder Luís do time titular que conquistou a Copa do Brasil no último domingo - e recebeu as faixas do título neste sábado -</segment>
    <segment id="22">, o Vasco começou bem.</segment>
    <segment id="23">Logo aos 3 minutos</segment>
    <segment id="24">, Márcio Careca chutou forte da entrada da área e Wilson espalmou para fora.</segment>
    <segment id="25">O Vasco continuou pressionando e</segment>
    <segment id="26">, aos 18</segment>
    <segment id="27">, após lindo passe de Éder Luís</segment>
    <segment id="28">, Elton chutou cruzado para marcar.</segment>
    <segment id="29">Depois do gol</segment>
    <segment id="30">, Éder Luís foi o único jogador do Vasco que continuou levando perigo ao gol de Wilson.</segment>
    <segment id="31">Ele teve duas chances aos 31 e 35</segment>
    <segment id="32">, masmas não conseguiu marcar.</segment>
    <segment id="33">Sem criatividade</segment>
    <segment id="34">, o Figueirense cresceu no jogo</segment>
    <segment id="35">, masmas</segment>
    <segment id="36">, sem meias eficientes</segment>
    <segment id="37">, não levava perigo ao gol de Fernando Prass.</segment>
    <segment id="38">Ainda assim</segment>
    <segment id="39">, após escanteio e desvio de Ygor na primeira trave</segment>
    <segment id="40">, Aloísio quase marca no fim do primeiro tempo.</segment>
    <segment id="41">No segundo tempo</segment>
    <segment id="42">, o Vasco que já não vinha bem ficou ainda pior.</segment>
    <segment id="43">Ricardo Gomes tentou mudar o time</segment>
    <segment id="44">, com a entrada de Jéferson e Leandro</segment>
    <segment id="45">, masmas eles não conseguiram melhorar a movimentação do time.</segment>
    <segment id="46">Sorte dos donos da casa que o Figueirense</segment>
    <segment id="47">, apesar de comandar o meio-campo durante boa parte do segundo tempo</segment>
    <segment id="48">, não chegava a assustar o Vasco.</segment>
    <segment id="49">O melhor momento do Vasco aconteceu pelos pés de Fernando.</segment>
    <segment id="50">O zagueiro fez um lindo lançamento para Bernardo</segment>
    <segment id="51">, que invadiu a área</segment>
    <segment id="52">, masmas demorou para chutar</segment>
    <segment id="53">, desperdiçando o lance.</segment>
    <segment id="54">No fim</segment>
    <segment id="55">, o Figueirense pressionava e</segment>
    <segment id="56">, após boa jogada de Pittoni</segment>
    <segment id="57">, Aloísio recebeu pela esquerda e chutou cruzado para marcar aos 44 do segundo tempo.
VASCO</segment>
    <segment id="58">X FIGUEIRENSE
Local: São Januário</segment>
    <segment id="59">, Rio de Janeiro (RJ)
Árbitro: Luis Flávio de Oliveira (SP)
Público/renda: 17.777 presentes/R$533.015</segment>
    <segment id="60">Cartões amarelos: Jumar</segment>
    <segment id="61">, Fernando</segment>
    <segment id="62">, Diego Rosa (VAS).</segment>
    <segment id="63">Rhayner (FIG)
VASCO: Fernando Prass</segment>
    <segment id="64">; Fagner</segment>
    <segment id="65">, Fernando</segment>
    <segment id="66">, Anderson Martins e Márcio Careca</segment>
    <segment id="67">; Jumar (Diego Rosa</segment>
    <segment id="68">, 27'/1ºT)</segment>
    <segment id="69">, Rômulo (Leandro</segment>
    <segment id="70">, 28'/2ºT)</segment>
    <segment id="71">, Allan e Bernardo (Jéfferson</segment>
    <segment id="72">, 25'/2ºT)</segment>
    <segment id="73">; Eder Luis e Elton - Técnico: Ricardo Gomes
CORITIBA: Wilson</segment>
    <segment id="74">, Bruno</segment>
    <segment id="75">, João Paulo</segment>
    <segment id="76">, Edson e Juninho</segment>
    <segment id="77">; Ygor</segment>
    <segment id="78">, Túlio (Joílson</segment>
    <segment id="79">, intervalo)</segment>
    <segment id="80">, Maicon (Wilson Pittoni</segment>
    <segment id="81">, 24'/2ºT) e Coutinho (Eder</segment>
    <segment id="82">, intervalo)</segment>
    <segment id="83">; Aloísio e Rhayner - Técnico: Jorginho</segment>
  </rst>
