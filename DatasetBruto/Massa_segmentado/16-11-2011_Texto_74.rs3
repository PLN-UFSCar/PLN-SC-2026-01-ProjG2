  <rst>
    <segment id="1">O cantinho do Rei
Roberto Carlos leva camarim por todo o canto do Brasil</segment>
    <segment id="2">Nada de pedidos megalomaníacos.</segment>
    <segment id="3">Apesar de pertencer à nobreza musical brasileira</segment>
    <segment id="4">, Roberto Carlos é um homem simples.</segment>
    <segment id="5">Basta observar a lista de exigências que ele faz para seu camarim.</segment>
    <segment id="6">A estrutura é sempre a mesma e viaja com ele.</segment>
    <segment id="7">Uma espécie de pré-moldado</segment>
    <segment id="8">, que é montado próximo ao palco e serve de refúgio para o Rei</segment>
    <segment id="9">sese concentrar antes dos shows e receber os amigos depois do espetáculo.</segment>
    <segment id="10">Para manter o bom funcionamento dessa estrutura</segment>
    <segment id="11">, a produção do cantor exige que o local seja abastecido com 2 mil litros de água</segment>
    <segment id="12">, destinada aos banheiros</segment>
    <segment id="13">, cozinha</segment>
    <segment id="14">, refrigeração e limpeza.</segment>
    <segment id="15">No espaço só não entra mesmo bebida alcóolica.</segment>
    <segment id="16">Para beber</segment>
    <segment id="17">, só água mineral e refrigerantes do tipo zero.</segment>
    <segment id="18">A fome de Rei Roberto Carlos é saciada com pães e queijos</segment>
    <segment id="19">, além de uma boa dose de chocolates.</segment>
    <segment id="20">A maior exigência do Rei diz respeito às famosas rosas distribuídas por ele no final de cada show.</segment>
    <segment id="21">Roberto Carlos pede 12 dúzias de rosas vermelhas</segment>
    <segment id="22">, em botões</segment>
    <segment id="23">, sem espinhos e sem folhas</segment>
    <segment id="24">, frescas e boa qualidade</segment>
    <segment id="25">, do tipo colombiana ou carola.</segment>
    <segment id="26">Como se</segment>
    <segment id="27">se vê, o maior cuidado cantor mais amado do Brasil é com seus fãs.</segment>
    <segment id="28">Não é à toa que ele conquistou e conquistando uma legião deles.</segment>
    <segment id="29">O cara merece!</segment>
    <segment id="30">Para ver o rei de graça</segment>
    <segment id="31">O MASSA!</segment>
    <segment id="32">dá mais uma chance para você ganhar um par de ingressos para ver o Rei.</segment>
    <segment id="33">Siga @jornalmassa no Twitter e envie uma frase criativa com a hashtag #RCéMassa dizendo por que você merece que o MASSA!</segment>
    <segment id="34">te leve para o show.</segment>
    <segment id="35">Saiba mais em www.twitter.com/jornalmassa</segment>
  </rst>
</analysis>