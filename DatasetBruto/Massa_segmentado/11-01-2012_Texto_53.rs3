  <rst>
    <segment id="1">Torcida para a ‘famosidade’</segment>
    <segment id="2">Feirenses</segment>
    <segment id="3">sese reúnem para ver Jakeline</segment>
    <segment id="4">O telão não funcionou nos primeiros minutos.</segment>
    <segment id="5">Mas não estragou a festa organizada pelos pais e amigos da feirense Jakeline Leal</segment>
    <segment id="6">, na estreia do BBB 12</segment>
    <segment id="7">, ontem à noite.</segment>
    <segment id="8">Cerca de cem pessoas literalmente vestiram a camisa em apoio à estudante e vibraram quando ela aparecia.</segment>
    <segment id="9">O clima era de festa.</segment>
    <segment id="10">Como a imagem projetada na parede não era das melhores</segment>
    <segment id="11">, as pessoas disputaram espaços na frente do televisor acoplado ao datashow.</segment>
    <segment id="12">Outros</segment>
    <segment id="13">, mais prevenidos</segment>
    <segment id="14">, apelaram para celulares que captam sinal de televisão.</segment>
    <segment id="15">A alegria estampada nos rostos ganhou coloridos adereços.</segment>
    <segment id="16">As pequenas Gabrielly e Suelen</segment>
    <segment id="17">, irmãs de Jake</segment>
    <segment id="18">, aderiram à moda</segment>
    <segment id="19">, enquanto o namorado da sister baiana ficou longe da muvuca.</segment>
    <segment id="20">Quem mais demonstrou alegria foi o pai da estudante de zootecnia</segment>
    <segment id="21">, Danilo Lucena.</segment>
    <segment id="22">Numa explosão de sentimentos</segment>
    <segment id="23">, gritou:</segment>
    <segment id="24">“Minha filha está no BBB”.</segment>
    <segment id="25">Ele aposta que a exposição de Jake vai lhe abrir portas</segment>
    <segment id="26">, no futuro.</segment>
    <segment id="27">Quer “a famosidade” para a filha.</segment>
    <segment id="28">Olhares curiosos no primeiro encontro</segment>
    <segment id="29">Antes de saírem do hotel</segment>
    <segment id="30">, os 12 participantes finalmente</segment>
    <segment id="31">sese encontraram.</segment>
    <segment id="32">Enquanto alguns ainda sentiam ‘a ficha cair’</segment>
    <segment id="33">, outros já</segment>
    <segment id="34">sese assanhavam.</segment>
    <segment id="35">“Tem muita gente gostosa na minha frente”</segment>
    <segment id="36">, sese animou Mayara.</segment>
    <segment id="37">“Vou analisar elas de biquíni”</segment>
    <segment id="38">, emendou Jonas.</segment>
    <segment id="39">Ariadna sobre brother:</segment>
    <segment id="40">'Quem parece ter pegada é o Yuri'

Há quem desista</segment>
    <segment id="41">, masmas tem ex-BBB que daria tudo para voltar à casa.</segment>
    <segment id="42">“Voltaria correndo.</segment>
    <segment id="43">Quando vi os BBBs entrando na casa me deu um apertinho no coração</segment>
    <segment id="44">, uma saudade”</segment>
    <segment id="45">, confessou Ariadna.</segment>
    <segment id="46">A transexual afirmou que ainda não tem opinião formada sobre os novos participantes</segment>
    <segment id="47">, porém</segment>
    <segment id="48">porém admitiu que</segment>
    <segment id="49">, no quesito beleza</segment>
    <segment id="50">, Yuri tem sua preferência.</segment>
  </rst>
