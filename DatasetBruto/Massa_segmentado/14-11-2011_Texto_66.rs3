  <rst>
    <segment id="1">Presos mantêm greve de fome em Almadina</segment>
    <segment id="2">Os detentos também reclamam de superlotação</segment>
    <segment id="3">Os presos da delegacia de Almadina</segment>
    <segment id="4">, no sul da Bahia</segment>
    <segment id="5">, continuam nesta segunda-feira (14) com a greve de fome iniciada nesta sexta (11).</segment>
    <segment id="6">Eles pedem celeridade nos seus processos.</segment>
    <segment id="7">De acordo com os internos</segment>
    <segment id="8">, alguns detentos estão há mais de três anos presos sem serem julgados.</segment>
    <segment id="9">Eles também alegam que alguns já teriam cumprido o tempo da pena</segment>
    <segment id="10">casocaso fossem condenados.</segment>
    <segment id="11">A delegada Valéria Fonseca Chaves</segment>
    <segment id="12">, titular de Coaraci e que também responde pela unidade de Almadina</segment>
    <segment id="13">, disse que agendou com o juiz de Itapitanga</segment>
    <segment id="14">, Alisson Camilo Flores</segment>
    <segment id="15">, uma visita a delegacia</segment>
    <segment id="16">para que</segment>
    <segment id="17">para que ele reveja as penas dos presos.</segment>
    <segment id="18">Superlotação</segment>
    <segment id="19">Os detentos também reclamam de superlotação.</segment>
    <segment id="20">Atualmente</segment>
    <segment id="21">, há 24 presos no espaço reservado para oito.</segment>
    <segment id="22">A situação piorou há um ano e nove meses depois que a delegacia de Coaraci foi desativada após uma rebelião.</segment>
    <segment id="23">Durante o motim</segment>
    <segment id="24">, os internos destruíram a estrutura de Coaraci e os detentos foram transferidos para Almadina.</segment>
    <segment id="25">Um dos presos</segment>
    <segment id="26">, Marcelo Oliveira Santos</segment>
    <segment id="27">, conhecido</segment>
    <segment id="28">comocomo "Índio"</segment>
    <segment id="29">, teve uma crise epiléptica na sexta e foi hospitalizado.</segment>
    <segment id="30">Após ser medicado</segment>
    <segment id="31">, ele foi liberado</segment>
    <segment id="32">, masmas voltou a passar mal nesta segunda.</segment>
    <segment id="33">Não há informações</segment>
    <segment id="34">sese o problema de saúde dele foi desencadeado pela situação na delegacia.</segment>
    <segment id="35">Fuga</segment>
    <segment id="36">Dez presos escaparam da delegacia de Almadina no dia 18 de outubro.</segment>
    <segment id="37">Destes</segment>
    <segment id="38">, dois ainda não foram recuperados.</segment>
    <segment id="39">São eles</segment>
    <segment id="40">Carleone Santos de Jesus</segment>
    <segment id="41">, o "Galego"</segment>
    <segment id="42">, e Philippe Silva Soares</segment>
    <segment id="43">, o "Philippão".</segment>
  </rst>
</analysis>