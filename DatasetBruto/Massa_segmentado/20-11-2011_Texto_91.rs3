  <rst>
    <segment id="1">Sem criatividade</segment>
    <segment id="2">, Flamengo empata sem gols com Atlético-GO
RIO - Em tarde sem o brilho de Ronaldinho Gaúcho e Thiago Neves</segment>
    <segment id="3">, que foi substituído no segundo tempo e deixou o campo vaiado</segment>
    <segment id="4">, o Flamengo não conseguiu sair do empate sem gols contra o Atlético-GO</segment>
    <segment id="5">, no Serra Dourada</segment>
    <segment id="6">, neste domingo.</segment>
    <segment id="7">Com o resultado</segment>
    <segment id="8">, o rubro-negro carioca chega aos 57 pontos.</segment>
    <segment id="9">Ultrapassado pelo Internacional</segment>
    <segment id="10">, que ganhou do Botafogo</segment>
    <segment id="11">, o time chega à sexta colocação do Brasileiro e fica fora da zona de classificação para a Libertadores.</segment>
    <segment id="12">O Inter é o próximo adversário do Flamengo</segment>
    <segment id="13">, no próximo domingo</segment>
    <segment id="14">, em Macaé.</segment>
    <segment id="15">Com o terceiro amarelo</segment>
    <segment id="16">, Júnior César e Muralha desfalcam a equipe.

- O Flamengo sempre esteve entre os seis colocado no Brasileiro.</segment>
    <segment id="17">Jogamos aqui (em Goiás)</segment>
    <segment id="18">, estava muito quente e não perdemos.</segment>
    <segment id="19">Agora é o Inter dentro de casa.</segment>
    <segment id="20">A torcida tem que nos aplaudir e não ficar vaiando - reclamou o zagueiro Alex Silva ao final da partida.</segment>
    <segment id="21">Apesar de precisar resultado para ficar na zona de classificação para a Libertadores</segment>
    <segment id="22">, o Flamengo fez um primeiro tempo apático e saiu reclamando do calor.</segment>
    <segment id="23">Ronaldinho Gaúcho entrou pressionado para voltar às boas atuações pela torcida - que o vaiou no empate para o Figueirense -</segment>
    <segment id="24">, masmas não esteve bem e chegou a levar um chapéu de Bida.</segment>
    <segment id="25">Também sem</segment>
    <segment id="26">sese arriscar muito</segment>
    <segment id="27">, o Atléti-GO criava as melhores chances de gol</segment>
    <segment id="28">, apesar de não dar grande trabalho para o goleiro Felipe.</segment>
    <segment id="29">Homem de área dos donos da casa</segment>
    <segment id="30">, Marcão teve chance cara a cara com Felipe depois de girar sobre David Braz</segment>
    <segment id="31">, aos 6 minutos</segment>
    <segment id="32">, masmas chutou para fora.</segment>
    <segment id="33">Aos 10</segment>
    <segment id="34">, o zagueiro do Flamengo vacilou e perdeu a bola na defesa.</segment>
    <segment id="35">Na sequência</segment>
    <segment id="36">, Marcão recebeu de Juninho e colocou dentro do gol</segment>
    <segment id="37">, masmas o juiz marcou impedimento.</segment>
    <segment id="38">A primeira chance do Flamengo veio apenas aos 20</segment>
    <segment id="39">, em chute de fora da área de Renato Abreu.</segment>
    <segment id="40">Em outro chute de fora</segment>
    <segment id="41">, com Deivid</segment>
    <segment id="42">, aos 40</segment>
    <segment id="43">, o Flamengo voltou a assutar.</segment>
    <segment id="44">A bola bateu na rede pelo lado de fora.</segment>
    <segment id="45">No segundo tempo</segment>
    <segment id="46">, o Flamengo voltou com o mesmo time e a mesma postura.</segment>
    <segment id="47">Sem agredir o Atlético-GO</segment>
    <segment id="48">, o time dava oportunidade para os donos da casa</segment>
    <segment id="49">, que chegaram com perigo aos 16</segment>
    <segment id="50">, com Marcão</segment>
    <segment id="51">, e aos 25</segment>
    <segment id="52">, com o atacante Felipe.</segment>
    <segment id="53">Luxemburgo mexeu no time</segment>
    <segment id="54">, masmas as mudanças não surtiram efeito.</segment>
    <segment id="55">Aos 15</segment>
    <segment id="56">, Deivid deixou o campo para dar lugar a Thomás.</segment>
    <segment id="57">Aos 27 foi a vez de Thiago Neves sair vaiado.</segment>
    <segment id="58">Em seu lugar entrou Diego Maurício</segment>
    <segment id="59">, que teve uma boa oportunidade de marcar de cabeça três minutos depois.</segment>
    <segment id="60">O Flamengo chegou a esboçar uma pressão no final</segment>
    <segment id="61">, masmas foi o Atlético-GO que quase marcou aos 46 do segundo tempo</segment>
    <segment id="62">, quando Diogo Campos apareceu cara a cara com o goleiro</segment>
    <segment id="63">, masmas estava desequilibrado.</segment>
    <segment id="64">Atlético-GO 0 x 0 Flamengo

Local: Serra Dourada

Árbitro: Paulo César Oliveira (Fifa-SP)</segment>
    <segment id="65">Atlético-GO: Márcio</segment>
    <segment id="66">; Rafael Cruz</segment>
    <segment id="67">, Gilson</segment>
    <segment id="68">, Anderson e Thiago Feltri</segment>
    <segment id="69">; Ernandes</segment>
    <segment id="70">, Pituca</segment>
    <segment id="71">, Joilson e Bida (Marinho)</segment>
    <segment id="72">; Marcão (Diogo Campos) e Juninho (Felipe)

Flamengo: Felipe</segment>
    <segment id="73">; Leonardo Moura</segment>
    <segment id="74">, David Braz</segment>
    <segment id="75">, Alex Silva e Junior Cesar</segment>
    <segment id="76">; Airton (Muralha)</segment>
    <segment id="77">, Willians</segment>
    <segment id="78">, Renato Abreu e Thiago Neves (Diego Maurício)</segment>
    <segment id="79">;</segment>
    <segment id="80">Ronaldinho Gaúcho e Deivid (Thomás)</segment>
  </rst>
