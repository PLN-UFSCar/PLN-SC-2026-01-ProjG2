  <rst>
    <segment id="1">Se dê bem com método de estudo</segment>
    <segment id="2">Os estudantes devem ter disciplina para conseguir um bom resultado</segment>
    <segment id="3">A rotina de estudos para quem</segment>
    <segment id="4">sese prepara para provas de ingresso em universidades</segment>
    <segment id="5">, a exemplo do Enem</segment>
    <segment id="6">, não é nada fácil e exige método dos candidatos.</segment>
    <segment id="7">Para quem ainda está cursando o 3º ano do ensino médio</segment>
    <segment id="8">, a situação é ainda mais complicada</segment>
    <segment id="9">porque</segment>
    <segment id="10">porque</segment>
    <segment id="11">, além das disciplinas da escola</segment>
    <segment id="12">, precisa dar conta dos conteúdos dos exames.</segment>
    <segment id="13">É o caso</segment>
    <segment id="14">caso do estudante Manuel Rosa</segment>
    <segment id="15">, 18, que concluirá o ensino médio no Colégio Central e vai fazer o Enem para tentar vaga em um  curso de jornalismo.</segment>
    <segment id="16">Em 2010</segment>
    <segment id="17">, quando era aluno do 2º ano</segment>
    <segment id="18">,  Manuel fez a prova do Enem e sua pontuação já lhe garantiria a sonhada vaga.</segment>
    <segment id="19">Uma das posturas adotadas por ele é não descuidar do 3º ano:</segment>
    <segment id="20">“</segment>
    <segment id="21">Faço primeiro as atividades da escola e depois vejo os conteúdos do Enem”.</segment>
    <segment id="22">Manuel</segment>
    <segment id="23">, que  pretende entrar em um cursinho no segundo semestre</segment>
    <segment id="24">, diz ainda que estudar em grupo as matérias com as quais tem menos afinidade   é outro método adotado por ele.</segment>
    <segment id="25">“Todos  esclarecem as dúvidas de todos.</segment>
    <segment id="26">Fica mais fácil estudar química</segment>
    <segment id="27">, física</segment>
    <segment id="28">, matemática e biologia”</segment>
    <segment id="29">, diz.</segment>
    <segment id="30">Aos alunos que não gostam de determinadas matérias e</segment>
    <segment id="31">, por isso</segment>
    <segment id="32">, têm resistência em estudá-las</segment>
    <segment id="33">, o professor de biologia do Status</segment>
    <segment id="34">, Antônio Carrilho</segment>
    <segment id="35">, faz um alerta:   a questão que o candidato  acertar  nas disciplinas com menor peso  poderá classificá-lo.</segment>
    <segment id="36">Isto porque</segment>
    <segment id="37">porque a maioria dos concorrentes terá bom desempenho nas disciplinas   específicas de seus  cursos.</segment>
    <segment id="38">Confira as dicas MASSA!</segment>
    <segment id="39">dos professores
INTERPRETAÇÃO -</segment>
    <segment id="40">O professor de biologia Antônio Carrilho explica que o Enem cobra raciocínio lógico e interpretação</segment>
    <segment id="41">, além de conteúdos básico.</segment>
    <segment id="42">“</segment>
    <segment id="43">Existem questões que não precisam de cálculos e o aluno responde</segment>
    <segment id="44">sese souber interpretar”</segment>
    <segment id="45">,  diz.</segment>
    <segment id="46">ESTILO - O professor de literatura Renato Dórea chama a atenção para o estilo da prova</segment>
    <segment id="47">, que “avalia a capacidade de o candidato estabelecer relação entre os assuntos”.
PROVAS -</segment>
    <segment id="48">Um método aprovado por  professores e alunos é a resolução de provas anteriores</segment>
    <segment id="49">porque</segment>
    <segment id="50">porque há a possibilidade de aparecerem questões com os mesmos raciocínios.</segment>
  </rst>
</analysis>