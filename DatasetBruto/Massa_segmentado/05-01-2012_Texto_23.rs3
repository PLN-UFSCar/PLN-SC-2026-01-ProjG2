  <rst>
    <segment id="1">Tem baiana no Big Brother Brasil 12!</segment>
    <segment id="2">Conheça os participantes do reality show deste ano</segment>
    <segment id="3">, entre eles</segment>
    <segment id="4">, a feirense Jakeline
Contagem regressiva para o Brasil entrar na nave Big Brother!</segment>
    <segment id="5">Ontem, foram apresentados os novos participantes da casa mais espiada do país</segment>
    <segment id="6">, que está em sua 12ª edição.</segment>
    <segment id="7">Com tanta gente bonita e jovem</segment>
    <segment id="8">, a paquera deve rolar solta!</segment>
    <segment id="9">Os participantes parecem ter estilos bem diferentes e opções sexuais também</segment>
    <segment id="10">, motivos que podem gerar confusões entre a galera.</segment>
    <segment id="11">Desta vez</segment>
    <segment id="12">, serão 4 integrantes gays.</segment>
    <segment id="13">Babado puro!</segment>
    <segment id="14">Mas,  o importante agora é ficar de olhos atentos aos 12 brothers que já estão confinados em um hotel no Rio de Janeiro.</segment>
    <segment id="15">A única representante da Bahia é a jovem feirense Jakeline Leal Lucena</segment>
    <segment id="16">, 22 anos.</segment>
    <segment id="17">A morena é de Feira de Santana e estuda zootecnia no Instituto Federal Baiano</segment>
    <segment id="18">, em Santa Inês</segment>
    <segment id="19">, cidade a 300 quilômetros da capital.</segment>
    <segment id="20">A notícia deixou os habitantes de Feira empolgados</segment>
    <segment id="21">, entre eles</segment>
    <segment id="22">, os pais da jovem</segment>
    <segment id="23">, que ainda estão surpresos com a notícia.</segment>
    <segment id="24">“</segment>
    <segment id="25">Tudo começou com uma brincadeira.</segment>
    <segment id="26">Num dia de domingo</segment>
    <segment id="27">, ela entrou no quarto e quando saiu</segment>
    <segment id="28">, disse que tinha</segment>
    <segment id="29">sese inscrito no programa”</segment>
    <segment id="30">, diz Danilo Lucena</segment>
    <segment id="31">, pai de Jakeline.</segment>
    <segment id="32">A jovem é muito religiosa</segment>
    <segment id="33">, não bebe</segment>
    <segment id="34">, tem um namorado e adora animais.</segment>
    <segment id="35">Ela foi retirada de casa pela produção  anteontem.</segment>
    <segment id="36">“</segment>
    <segment id="37">Até então não sabíamos de nada.</segment>
    <segment id="38">Chegaram aqui e levaram ela</segment>
    <segment id="39">, dizendo que ainda iria passar por uma seleção com 30 pessoas</segment>
    <segment id="40">, masmas quando vimos na internet</segment>
    <segment id="41">, o nome dela já estava lá”</segment>
    <segment id="42">, comemora dona Edilene Leal</segment>
    <segment id="43">, a mãe.</segment>
  </rst>
