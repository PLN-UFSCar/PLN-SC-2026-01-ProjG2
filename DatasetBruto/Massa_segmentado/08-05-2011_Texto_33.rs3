  <rst>
    <segment id="1">Com ruptura no músculo da coxa</segment>
    <segment id="2">, Ganso fica fora por 30 dias</segment>
    <segment id="3">O meia Paulo Henrique Ganso</segment>
    <segment id="4">, que deixou o campo pouco antes do fim do primeiro tempo</segment>
    <segment id="5">, na primeira partida da final do Paulista entre Corinthians e Santos</segment>
    <segment id="6">, vai ficar pelo menos um mês fora dos campos.</segment>
    <segment id="7">O jogador sentiu uma dor na coxa direita e foi levado ao Hospital Sírio Libanês</segment>
    <segment id="8">, em São Paulo</segment>
    <segment id="9">, para realizar exames</segment>
    <segment id="10">, que revelaram uma ruptura no músculo adutor da coxa.</segment>
    <segment id="11">De acordo com o assessor de imprensa do jogador</segment>
    <segment id="12">, Ganso ficará aproximadamente 30 dias sem jogar.</segment>
    <segment id="13">O Santos enfrenta o Once Caldas</segment>
    <segment id="14">, da Colômbia</segment>
    <segment id="15">, na próxima quarta-feira</segment>
    <segment id="16">, em Manizales</segment>
    <segment id="17">, na Colômbia</segment>
    <segment id="18">, pelas quartas de final da Libertadores.</segment>
    <segment id="19">O meia também vai ficar de fora dos dois últimos amistosos do Brasil antes da Copa América</segment>
    <segment id="20">, contra a Holanda</segment>
    <segment id="21">, em Goiânia</segment>
    <segment id="22">, em 4 de junho</segment>
    <segment id="23">, e contra a Romênia</segment>
    <segment id="24">, em São Paulo</segment>
    <segment id="25">, três dias depois</segment>
    <segment id="26">, na despedida de Ronaldo.</segment>
    <segment id="27">Após a lesão de Ganso</segment>
    <segment id="28">, o técnico Muricy Ramalho voltou a criticar o calendário do futebol brasileiro.
-</segment>
    <segment id="29">As pessoas lá do outro lado (pessoas que administram o futebol) estão cansadas de ouvir que não dá para jogar futebol assim.</segment>
    <segment id="30">Era esperado termos jogadores com lesões</segment>
    <segment id="31">, porque</segment>
    <segment id="32">porque é uma pré-temporada sempre muito pequena</segment>
    <segment id="33">, com excesso de lesões - lamentou o treinador.</segment>
    <segment id="34">O atacante Neymar</segment>
    <segment id="35">, que pediu para sair no fim do segundo tempo</segment>
    <segment id="36">, torce para a maratona não fazer mais vítimas.
- No fim eu pedi para sair.</segment>
    <segment id="37">Cansaço está enorme e nesta segunda-feira tem a viagem.</segment>
    <segment id="38">Espero que Deus nos abençoe</segment>
    <segment id="39">para que</segment>
    <segment id="40">para que não percamos mais nenhum jogador.</segment>
    <segment id="41">São muitos jogos em um mês.</segment>
    <segment id="42">Ninguém é maquina.</segment>
    <segment id="43">A gente acaba cansando e</segment>
    <segment id="44">sese machucando - disse o atacante.  




TExTO</segment>
    <segment id="45">34
Massa!</segment>
    <segment id="46">08/05/2011
O Globo


Lentidão na Niterói-Manilha</segment>
    <segment id="47">, sentido Niterói</segment>
    <segment id="48">De acordo com a concessionária</segment>
    <segment id="49">Autopista Fluminense</segment>
    <segment id="50">, o tráfego é intenso na noite deste domingo</segment>
    <segment id="51">, com pontos de lentidão entre o km 299 e o km 320</segment>
    <segment id="52">, da pista sentido Niterói da BR-101</segment>
    <segment id="53">, entre as regiões de São Gonçalo e Niterói</segment>
    <segment id="54">, devido ao excesso de veículos.</segment>
