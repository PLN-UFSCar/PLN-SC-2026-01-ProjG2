  <rst>
    <segment id="1">Ex-campeão de boxe morto com 40 tiros</segment>
    <segment id="2">“</segment>
    <segment id="3">Eles chegaram dizendo: ‘</segment>
    <segment id="4">Atira na cabeça.</segment>
    <segment id="5">Só na cabeça’</segment>
    <segment id="6">, diz mulher da vítima.</segment>
    <segment id="7">Foi sepultado ontem</segment>
    <segment id="8">, no cemitério do Campo Santo</segment>
    <segment id="9">, o professor de boxe Jorge Rosa de Jesus</segment>
    <segment id="10">, 41 anos</segment>
    <segment id="11">, assassinado anteontem com cerca de 40 tiros</segment>
    <segment id="12">, por  três homens encapuzados</segment>
    <segment id="13">, dentro da própria casa</segment>
    <segment id="14">, na Rua Doutor Deraldo Dias de Morais</segment>
    <segment id="15">, na localidade da Roça da Sabina</segment>
    <segment id="16">, no bairro da Barra.</segment>
    <segment id="17">O crime ocorreu por volta das 23h.</segment>
    <segment id="18">A polícia ainda  investiga os motivos e autoria do homicídio.</segment>
    <segment id="19">Apelidado de professor Niola</segment>
    <segment id="20">, desde 1990</segment>
    <segment id="21">, quando era pugilista</segment>
    <segment id="22">, Jorge Rosa conquistou o título de campeão brasileiro.</segment>
    <segment id="23">“Eu tinha 15 anos quando Niola lutava boxe.</segment>
    <segment id="24">Ele lutou três vezes com o meu irmão Luís Cláudio e foi aluno de Luiz Dórea”</segment>
    <segment id="25">, resgatou o ex-pugilista e hoje deputado federal Acelino Popó Freitas.</segment>
    <segment id="26">A hipótese de execução motivada por envolvimento com o tráfico de drogas foi rejeitada pela família e pelo próprio Popó.</segment>
    <segment id="27">“</segment>
    <segment id="28">Nunca ouvi falar nada envolvendo ele com drogas.</segment>
    <segment id="29">Niola sempre foi trabalhador</segment>
    <segment id="30">, vivia dando aula de boxe.</segment>
    <segment id="31">Inclusive</segment>
    <segment id="32">, conheço empresários que ele dava aula”</segment>
    <segment id="33">, afirmou Popó.</segment>
    <segment id="34">A mulher do boxeador</segment>
    <segment id="35">, Zenaide do Carmo</segment>
    <segment id="36">, relembra o assassinato.</segment>
    <segment id="37">“</segment>
    <segment id="38">Eles chegaram dizendo: ‘</segment>
    <segment id="39">Atira na cabeça.</segment>
    <segment id="40">Só na cabeça’.</segment>
    <segment id="41">Um dos bandidos ainda atirou em Zenaide</segment>
    <segment id="42">, que se</segment>
    <segment id="43">se escondeu atrás da cama e do colchão e escapou.</segment>
    <segment id="44">Suspeita de vingança do tráfico</segment>
    <segment id="45">Além de dar aulas de boxe</segment>
    <segment id="46">, Jorge Rosa tinha alugado um bar na Vasco da Gama</segment>
    <segment id="47">, próximo ao local onde</segment>
    <segment id="48">, no dia 19 desse mês</segment>
    <segment id="49">, policiais apreenderam drogas</segment>
    <segment id="50">, armamentos e materiais de refino</segment>
    <segment id="51">, na localidade de Manguinhos.</segment>
    <segment id="52">Existe a suspeita de que o professor de boxe poderia ter sido executado por traficantes.</segment>
    <segment id="53">Esses criminosos estariam desconfiados com a possibilidade de a vítima ter avisado à polícia sobre as atividades irregulares do tráfico na região.</segment>
  </rst>
</analysis>