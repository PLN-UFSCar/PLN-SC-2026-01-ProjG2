  <rst>
    <segment id="1">Vacilão vai em cana e leva tapão de irmã</segment>
    <segment id="2">Ladinho foi preso durante operação da polícia para pegar quadrilha de desmanche
Além de ter sido preso em flagrante  por desmanche de carros roubados</segment>
    <segment id="3">, durante  operação da Delegacia de Repressão a Furtos e Roubos de Veículos (DRFRV) e do Departamento de Homicídios e Proteção à Pessoa (DHPP)</segment>
    <segment id="4">, o chapista Eraldo Pereira Brito</segment>
    <segment id="5">, 36 anos</segment>
    <segment id="6">, o Ladinho</segment>
    <segment id="7">, despertou  a ira dos parentes.</segment>
    <segment id="8">Enquanto a mulher externava o desejo de dar dois murros no pé da barriga do malandro</segment>
    <segment id="9">, a irmã partiu para a ação e deu um tapa no rapaz quando os policiais o conduziam para a viatura.</segment>
    <segment id="10">Ladinho foi preso no final da tarde de ontem</segment>
    <segment id="11">, na oficina de sua propriedade</segment>
    <segment id="12">, na Ladeira da Carmosina</segment>
    <segment id="13">, final de linha da  Cidade Nova.</segment>
    <segment id="14">No estabelecimento</segment>
    <segment id="15">, conforme denúncia recebida pela polícia</segment>
    <segment id="16">, é feito o desmanche de veículos  roubados.</segment>
    <segment id="17">“</segment>
    <segment id="18">Os veículos eram desmanchados na oficina e as peças levadas para comercialização na Avenida Suburbana”</segment>
    <segment id="19">, informou o investigador da DRFRV e coordenador da operação</segment>
    <segment id="20">, Silvino Neto.</segment>
    <segment id="21">A polícia busca agora outros integrantes da quadrilha</segment>
    <segment id="22">, os quais seriam responsáveis por tomar os carros de assalto e  comercializar as peças.</segment>
    <segment id="23">A casa caiu</segment>
    <segment id="24">Segundo o investigador</segment>
    <segment id="25">, Eraldo foi indiciado por receptação.</segment>
    <segment id="26">Um comparsa dele conseguiu fugir.</segment>
    <segment id="27">Na oficina</segment>
    <segment id="28">, a polícia encontrou um Fiat Uno (placa clonada GPX-4498)</segment>
    <segment id="29">, além de um Corsa Classic já desmontado.</segment>
    <segment id="30">Um  Vectra estacionado do lado de fora do galpão também foi apreendido.</segment>
    <segment id="31">Todos foram tomados de assalto</segment>
    <segment id="32">, de acordo com a polícia.</segment>
    <segment id="33">“Aqui não funciona nenhum desmanche.</segment>
    <segment id="34">Trabalho aqui há quase 10 anos”</segment>
    <segment id="35">, defendeu-</segment>
    <segment id="36">sese Ladinho.</segment>
    <segment id="37">“</segment>
    <segment id="38">Um homem</segment>
    <segment id="39">, que conheço só de fisionomia</segment>
    <segment id="40">, acertou de me pagar R$ 200 para desmontar o Uno hoje de manhã.</segment>
    <segment id="41">O Corsa já veio desmontado.</segment>
    <segment id="42">Foi trazido por um homem</segment>
    <segment id="43">, que também não sei o nome</segment>
    <segment id="44">, para emendar em outro carro batido.</segment>
    <segment id="45">Não tenho nada a ver com o Vectra.</segment>
    <segment id="46">Sou inocente”</segment>
    <segment id="47">, disse.</segment>
  </rst>
</analysis>