  <rst>
    <segment id="1">Invasores de terra não comem 'reggae'
Cerca de 650 pessoas estão há 18 dias em uma área de Vida Nova e exigem direitos</segment>
    <segment id="2">Cerca de 650  pessoas ocupam</segment>
    <segment id="3">, há 18 dias</segment>
    <segment id="4">, um terreno em Vida Nova</segment>
    <segment id="5">, em Lauro de Freitas</segment>
    <segment id="6">, e avisam:</segment>
    <segment id="7">“Vamos resistir</segment>
    <segment id="8">, caso</segment>
    <segment id="9">caso haja confronto!”.</segment>
    <segment id="10">Segundo eles</segment>
    <segment id="11">, a área é do governo estadual e nela serão construídas moradias do Projeto Minha Casa Minha Vida.</segment>
    <segment id="12">Ainda de acordo com os invasores</segment>
    <segment id="13">, hoje</segment>
    <segment id="14">, representantes da Conder prometeram ir até lá para exigir a desocupação.</segment>
    <segment id="15">Os invasores afirmam que só deixarão o acampamento</segment>
    <segment id="16">, caso</segment>
    <segment id="17">caso passem a receber auxílio-aluguel e inscrição no Minha Casa Minha Vida.</segment>
    <segment id="18">Em abrigos feitos de  lonas</segment>
    <segment id="19">, folhas de coqueiro e paus</segment>
    <segment id="20">,  mulheres</segment>
    <segment id="21">, crianças e idosos tentam transformar seus barracos em algo parecido com um lar.</segment>
    <segment id="22">Tudo começou quando o segurança  Joel Leão</segment>
    <segment id="23">, 30 anos</segment>
    <segment id="24">, ao passar  pelo local</segment>
    <segment id="25">, tomou uma decisão: invadir o terreno de 8 mil metros quadrados.</segment>
    <segment id="26">“</segment>
    <segment id="27">Meu  aluguel estava atrasado há  14 dias.</segment>
    <segment id="28">Vi o terreno e resolvi  me instalar</segment>
    <segment id="29">,  e aí a galera  fez o mesmo.</segment>
    <segment id="30">Só sairemos daqui  com a confirmação de que teremos direto a moradias dignas ”</segment>
    <segment id="31">, diz  Leão.</segment>
    <segment id="32">As famílias sofrem com a falta de água</segment>
    <segment id="33">, banheiro e comida</segment>
    <segment id="34">, já que a maioria das pessoas está  desempregada.</segment>
    <segment id="35">“Não sei o que vou comer hoje.</segment>
    <segment id="36">Não tenho emprego e tenho quatro filhos”</segment>
    <segment id="37">, confessa Edna Magalhães</segment>
    <segment id="38">, 32.</segment>
    <segment id="39">Desde o último final de semana</segment>
    <segment id="40">, seguranças da Conder  permanecem  em frente ao local</segment>
    <segment id="41">, para evitar novas ocupações.</segment>
    <segment id="42">Os invasores temem um confronto na reintegração de posse</segment>
    <segment id="43">,  pois</segment>
    <segment id="44">pois  na última terça-feira representantes do órgão estiveram lá em companhia de policiais militares da Rondesp.</segment>
    <segment id="45">Procurada pelo MASSA!</segment>
    <segment id="46">,  a assessoria de comunicação da  Conder não</segment>
    <segment id="47">sese pronunciou</segment>
    <segment id="48">,  até o fechamento da edição.</segment>
  </rst>
</analysis>