  <rst>
    <segment id="1">União colorida está aprovada</segment>
    <segment id="2">A Justiça decidiu que as mesmas regras valem para casais héteros e gays</segment>
    <segment id="3">O Supremo Tribunal Federal reconheceu ontem a união estável entre casais do mesmo sexo</segment>
    <segment id="4">comocomo entidade familiar.</segment>
    <segment id="5">Ou seja</segment>
    <segment id="6">, as regras que valem para relações estáveis entre homens e mulheres serão aplicadas aos casais gays.</segment>
    <segment id="7">Com a mudança</segment>
    <segment id="8">, o Supremo cria um precedente que pode ser seguido pelas outras instâncias da Justiça.</segment>
    <segment id="9">A decisão foi bastante comemorada pelos homossexuais baianos.</segment>
    <segment id="10">O sonho do microempresário Joniel Rios</segment>
    <segment id="11">, 36 anos</segment>
    <segment id="12">,  e do professor Henrique Plinio Nascimento</segment>
    <segment id="13">, 40 anos</segment>
    <segment id="14">, de ter o documento registrado em cartório garantido por lei</segment>
    <segment id="15">,  os deixaram esperançosos.</segment>
    <segment id="16">O casal já está junto desde 2003.</segment>
    <segment id="17">“Acompanhei a votação  pela internet e  estamos muito feliz com o resultado positivo.</segment>
    <segment id="18">Com a lei ao nosso lado mais pessoas irão nos respeitar”</segment>
    <segment id="19">, diz Joniel</segment>
    <segment id="20">, satisfeito.</segment>
    <segment id="21">Eles têm um documento registrado em cartório e foram o primeiro casal homossexual de Camaçari a casar no livro de uniões estáveis do Grupo Gay da Bahia.</segment>
    <segment id="22">Comemoração:</segment>
    <segment id="23">Comunidade gay está feliz</segment>
    <segment id="24">Para o presidente do Grupo Gay da Bahia (GGB)</segment>
    <segment id="25">, Marcelo Cerqueira</segment>
    <segment id="26">, foi feito justiça.</segment>
    <segment id="27">“Era injusto que morte do companheiro significasse desamparo para o parceiro”</segment>
    <segment id="28">, disse Cerqueira.</segment>
    <segment id="29">A notícia também foi comemorada pelo secretário estadual de Justiça e Direitos Humanos</segment>
    <segment id="30">, Almiro Sena.</segment>
    <segment id="31">“</segment>
    <segment id="32">A decisão  garantirá os direitos fundamentais.</segment>
    <segment id="33">Felizmente</segment>
    <segment id="34">, na prática</segment>
    <segment id="35">, os casamentos homoafetivos já são uma realidade.</segment>
    <segment id="36">Mas a decisão judicial garante o direitos desses casais.</segment>
    <segment id="37">É uma decisão histórica”</segment>
    <segment id="38">, avaliou o secretário.</segment>
    <segment id="39">Religiosos são contrários</segment>
    <segment id="40">Pouco depois de o Supremo Tribunal Federal tomar a decisão</segment>
    <segment id="41">, alguns bispos em São Paulo</segment>
    <segment id="42">sese manifestaram contra a proposta.</segment>
    <segment id="43">Para os religiosos</segment>
    <segment id="44">, que estão reunidos na 49ª Assembleia Geral da Conferência Nacional dos Bispos do Brasil</segment>
    <segment id="45">, no interior do estado</segment>
    <segment id="46">, a Igreja defende a família</segment>
    <segment id="47">comocomo uma instituição formada por homem e mulher</segment>
    <segment id="48">, capaz de gerar filhos.</segment>
    <segment id="49">O dom Anuar Battisti disse que a união é uma "agressão frontal" à família.</segment>
    <segment id="50">O deputado Pastor Marco Feliciano disse no Twitter:</segment>
    <segment id="51">“Estará oficializado o começo da decadência do moral”.</segment>
    <segment id="52">O que fica mais fácil com a decisão</segment>
    <segment id="53">Reconhecer  a união estável</segment>
    <segment id="54">Adotar sobrenome do parceiro</segment>
    <segment id="55">Garantir a pensão alimentícia em</segment>
    <segment id="56">casocaso de separação</segment>
    <segment id="57">Assumir a guarda do filho do cônjuge</segment>
    <segment id="58">Adotar o filho do parceiro</segment>
    <segment id="59">Visita íntima na prisão</segment>
    <segment id="60">Autorizar cirurgia</segment>
    <segment id="61">Participar da partilha da herança</segment>
    <segment id="62">comocomo qualquer casal</segment>
    <segment id="63">Somar renda para alugar imóvel</segment>
    <segment id="64">Fazer declaração conjunta do IR</segment>
  </rst>
</analysis>