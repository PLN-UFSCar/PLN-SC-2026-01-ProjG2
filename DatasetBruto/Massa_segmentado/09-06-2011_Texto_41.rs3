  <rst>
    <segment id="1">Jurou tirar bebê de rival a facão</segment>
    <segment id="2">Marilene prometeu arrancar o filho de Daniela da barriga na tora
Ódio</segment>
    <segment id="3">, ciúme</segment>
    <segment id="4">, tráfico de drogas e assassinato.</segment>
    <segment id="5">Esses são os elementos do mal que giram em torno do desaparecimento de duas irmãs</segment>
    <segment id="6">, Gilcleide de Souza Lucena</segment>
    <segment id="7">, 32, e Daniela de Souza Lucena</segment>
    <segment id="8">, 27.</segment>
    <segment id="9">Elas estão sumidas desde 27 de março deste ano.</segment>
    <segment id="10">Dois meses de investigações policiais apontam para um crime bárbaro</segment>
    <segment id="11">, de vingança</segment>
    <segment id="12">, cometido por Marilene da Silva Cerqueira</segment>
    <segment id="13">, 32, de acordo com o delegado adjunto da 11ª Delegacia Territorial (Tancredo Neves)</segment>
    <segment id="14">, Eduardo Rafael.</segment>
    <segment id="15">Segundo ele</segment>
    <segment id="16">, por ciúme</segment>
    <segment id="17">, Marilene teria atraído Daniela para uma emboscada mortal</segment>
    <segment id="18">, no Subúrbio Ferroviário.</segment>
    <segment id="19">A acusada teria ficado furiosa ao saber que seu companheiro</segment>
    <segment id="20">, o detento José Jackson Costa dos Santos</segment>
    <segment id="21">, 32, vulgo Capoeira</segment>
    <segment id="22">, tinha um romance com Daniela</segment>
    <segment id="23">, que estava grávida dele de três meses.</segment>
    <segment id="24">De acordo com o delegado Eduardo Rafael</segment>
    <segment id="25">, “Jackson confirmou que ela (Marilene) foi à prisão dizer que arrancaria o bebê da barriga de Daniela a facão”</segment>
    <segment id="26">, contou abismado.</segment>
    <segment id="27">O delegado disse que a polícia desconsidera o envolvimento de Jackson no sumiço.</segment>
    <segment id="28">“Ele já estava preso na ocasião</segment>
    <segment id="29">, por conta de denúncia feita pela própria Marilene”</segment>
    <segment id="30">, relatou.</segment>
    <segment id="31">Segundo o delegado</segment>
    <segment id="32">, quando Jackson conheceu Daniela</segment>
    <segment id="33">, ele era foragido do sistema prisional.</segment>
    <segment id="34">Ele recebeu o indulto de fim de ano e não retornou para o Complexo Penitenciário da Mata Escura</segment>
    <segment id="35">, onde cumpre pena por roubo.</segment>
    <segment id="36">Marilene está presa desde 6 de maio passado</segment>
    <segment id="37">, quando foi flagrada com 1 kg de pasta-base de cocaína.</segment>
    <segment id="38">Suspeita tem frieza sinistra
“Ela (Marilene) é uma pessoa que aparentemente é normal</segment>
    <segment id="39">, masmas que demonstra ter uma frieza estranha</segment>
    <segment id="40">, porque</segment>
    <segment id="41">porque ela não</segment>
    <segment id="42">sese abala com nada"</segment>
    <segment id="43">, diz o delegado Adailton Adam</segment>
    <segment id="44">, um dos responsáveis pelas investigações do</segment>
    <segment id="45">casocaso.</segment>
    <segment id="46">Entenda o</segment>
    <segment id="47">casocaso</segment>
    <segment id="48">No dia do desaparecimento</segment>
    <segment id="49">, Daniela comemorava o aniversário em um churrasco com a família</segment>
    <segment id="50">, quando a irmã Gilcleide recebeu um telefonema anônimo.</segment>
    <segment id="51">A pessoa do outro lado da linha pedia à aniversariante que fosse para o subúrbio</segment>
    <segment id="52">, onde a aguardava com uma “surpresa”.</segment>
    <segment id="53">“Gilcleide não queria deixar a irmã ir sozinha e resolveu acompanhá-la.</segment>
    <segment id="54">A mãe das vítimas</segment>
    <segment id="55">, Maria do Socorro</segment>
    <segment id="56">, 64, ainda tem esperanças de encontrá-las vivas.</segment>
    <segment id="57">Ela conta que</segment>
    <segment id="58">, antes do desaparecimento</segment>
    <segment id="59">, Marilene ameaçou Daniela várias vezes</segment>
    <segment id="60">, por conta do relacionamento da filha com Capoeira.</segment>
    <segment id="61">“</segment>
    <segment id="62">Ela (Marilene) dizia que não ia perder para minha filha.</segment>
    <segment id="63">Quando soube que Daniela estava grávida</segment>
    <segment id="64">, a mulher enlouqueceu”</segment>
    <segment id="65">, disse a dona de casa.</segment>
  </rst>
</analysis>