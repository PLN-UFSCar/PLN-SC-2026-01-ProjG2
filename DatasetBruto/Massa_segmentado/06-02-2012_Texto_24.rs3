  <rst>
    <segment id="1">Sophie Charlotte cai no samba
Moça cai a farra</segment>
    <segment id="2">, carrega uma bandeja de salgadinhos e grava cena para seriado</segment>
    <segment id="3">A atriz mostrou que é retada mesmo.</segment>
    <segment id="4">A Amália de “Fina Estampa” mostrou que tem gingado no ensaio da escola de samba Salgueiro</segment>
    <segment id="5">, no Rio</segment>
    <segment id="6">, quando</segment>
    <segment id="7">sese acabou de dançar na quadra.</segment>
    <segment id="8">Além de arrastar muita sandália</segment>
    <segment id="9">, a atriz também carregou uma bandeja recheada de salgadinhos no camarote para os amigos.</segment>
    <segment id="10">E não parou por aí.</segment>
    <segment id="11">Cheia de fôlego</segment>
    <segment id="12">, no mesmo dia</segment>
    <segment id="13">, Sophie ainda gravou cenas para o seriado da Globo “</segment>
    <segment id="14">As Brasileiras".</segment>
    <segment id="15">Haja disposição!</segment>
    <segment id="16">Todo esse gás pode ser reflexo da alegria de ter reatado o namoro com o ator Malvino Salvador.</segment>
    <segment id="17">Segundo as más línguas</segment>
    <segment id="18">, os pombinhos teriam terminado depois do suposto affair dela com Thiago Martins.</segment>
    <segment id="19">Mas os dois negam o fato.</segment>
  </rst>
