  <rst>
    <segment id="1">Homem mata mulher e deixa mensagens nos espelhos de motel em Campo Grande

RIO - Policiais da Divisão de Homicídios (DH) investigam a morte de Rosineyde Rodrigues Haiki</segment>
    <segment id="2">, na noite de quarta-feira</segment>
    <segment id="3">, em um motel de Campo Grande</segment>
    <segment id="4">, na Zona Oeste do Rio.</segment>
    <segment id="5">Ao entrarem no quarto</segment>
    <segment id="6">, onde a vítima foi deixada seminua</segment>
    <segment id="7">, os agentes encontraram mensagens nos espelhos.</segment>
    <segment id="8">O assassino</segment>
    <segment id="9">, identificado</segment>
    <segment id="10">comocomo José Carlos Barreto</segment>
    <segment id="11">, de 31 anos</segment>
    <segment id="12">, justificou o ato alegando que a ex-namorada</segment>
    <segment id="13">, que faria 30 anos neste sábado</segment>
    <segment id="14">, o traía com outro homem.</segment>
    <segment id="15">EM OUTRO MOTEL:
PM morre após noite com travesti na Lapa
Imagens do circuito interno de segurança do estabelecimento vem auxiliando as investigações</segment>
    <segment id="16">, que apontam para crime passional.</segment>
    <segment id="17">Segundo os agentes</segment>
    <segment id="18">, a vítima havia rompido o relacionamento com o ex-namorado em janeiro e</segment>
    <segment id="19">, desde então</segment>
    <segment id="20">, os dois teriam apenas encontros casuais.</segment>
    <segment id="21">O suspeito</segment>
    <segment id="22">, no entanto</segment>
    <segment id="23">, não estaria aceitando a separação.</segment>
    <segment id="24">No dia do assassinato</segment>
    <segment id="25">, o casal entrou de moto no motel por volta das 18h</segment>
    <segment id="26">, e pediu para alugar um quarto por um período de 12 horas.</segment>
    <segment id="27">Próximo às 14h de quinta-feira</segment>
    <segment id="28">, depois de tentarem telefonar para os hóspedes repetidamente</segment>
    <segment id="29">, os funcionários do motel decidiram entrar no quarto e encontraram Rosyneide com o rosto afundado no travesseiro.</segment>
    <segment id="30">A mulher foi morta por asfixia e pancadas.</segment>
    <segment id="31">O suspeito fugiu do local e está foragido.</segment>
    <segment id="32">Também na quarta-feira</segment>
    <segment id="33">, Aline Lima Moragas da Rocha</segment>
    <segment id="34">, de 31 anos</segment>
    <segment id="35">, foi assassinada a facadas dentro do motel Classic</segment>
    <segment id="36">, em Cascadura</segment>
    <segment id="37">, na Zona Norte.</segment>
    <segment id="38">Seu marido</segment>
    <segment id="39">, Adriano Souza de Araújo</segment>
    <segment id="40">, de 37</segment>
    <segment id="41">, foi preso em flagrante no local.</segment>
    <segment id="42">A faca usado crime foi apreendida por policiais da 28ª DP (Campinho).</segment>
  </rst>
