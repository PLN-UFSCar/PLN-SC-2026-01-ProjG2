  <rst>
    <segment id="1">Flamengo e Luxemburgo voltam a</segment>
    <segment id="2">sese encontrar
RIO - Nos 142 dias que separam a traumática saída de Vanderlei Luxemburgo do clube</segment>
    <segment id="3">, em 3 de fevereiro</segment>
    <segment id="4">, e o jogo entre Grêmio e Flamengo</segment>
    <segment id="5">, às 16h deste domingo</segment>
    <segment id="6">, no Estádio Olímpico</segment>
    <segment id="7">, o time rubro-negro e seu ex-técnico trilharam caminhos diferentes para chegar ao mesmo lugar: eliminados das competições do primeiro semestre e empatados com nove pontos após cinco rodadas do Brasileiro.</segment>
    <segment id="8">Enquanto o Flamengo somava fracassos e até vexames na Libertadores e no Carioca</segment>
    <segment id="9">, Luxemburgo tinha um bom início de trabalho no Grêmio.</segment>
    <segment id="10">Não conseguiu</segment>
    <segment id="11">, porém</segment>
    <segment id="12">porém, ganhar o estadual e na quinta-feira viu-</segment>
    <segment id="13">sese fora da Copa do Brasil.</segment>
    <segment id="14">Após perder Ronaldinho Gaúcho</segment>
    <segment id="15">, o Flamengo esboça uma reação no Brasileiro.</segment>
    <segment id="16">Sobrevivente no cargo</segment>
    <segment id="17">, Joel Santana</segment>
    <segment id="18">, substituto de Vanderlei</segment>
    <segment id="19">, não vê</segment>
    <segment id="20">comocomo o adversário possa tirar vantagem da recente passagem de mais um ano pelo Flamengo.
- Ele conhece o elenco</segment>
    <segment id="21">, masmas o time mudou muito desde que ele saiu - afirmou.
Mudanças no Fla</segment>
    <segment id="22">Embora o Flamengo continue apresentando um futebol irregular (o que também era um problema nos tempos de Vanderlei)</segment>
    <segment id="23">, Joel tem razão ao falar da transformação do time</segment>
    <segment id="24">, ao menos na escalação.</segment>
    <segment id="25">Dos 11 titulares do último jogo de Luxemburgo no Flamengo (a vitória sobre o Real Potosí que garantiu o time na Libertadores)</segment>
    <segment id="26">, apenas dois estarão em campo hoje no Olímpico: Luiz Antônio e Renato.</segment>
    <segment id="27">Dos outros nove</segment>
    <segment id="28">, Léo Moura está machucado</segment>
    <segment id="29">; Felipe</segment>
    <segment id="30">, Welinton</segment>
    <segment id="31">, Bottinelli e Deivid foram barrados por Joel</segment>
    <segment id="32">; e David Braz</segment>
    <segment id="33">, Júnior César</segment>
    <segment id="34">, Willians e Ronaldinho Gaúcho já deixaram o clube.</segment>
    <segment id="35">Do time deste domingo</segment>
    <segment id="36">, Ibson</segment>
    <segment id="37">, Vágner Love</segment>
    <segment id="38">, Wellington Silva</segment>
    <segment id="39">, González e Hernane estrearam já sob a gestão de Joel</segment>
    <segment id="40">, que também promoveu a titulares Paulo Victor</segment>
    <segment id="41">, Marllon</segment>
    <segment id="42">, Magal e Aírton.
- O currículo do Vanderlei fala por si.</segment>
    <segment id="43">É um dos grandes técnicos do Brasil</segment>
    <segment id="44">, é da velha guarda</segment>
    <segment id="45">comocomo eu.</segment>
    <segment id="46">Nos anos 1990</segment>
    <segment id="47">, nós nos enfrentamos muito</segment>
    <segment id="48">, tínhamos muito conhecimento (um do outro).</segment>
    <segment id="49">Ele inclusive levou integrantes da minha comissão - lembrou Joel</segment>
    <segment id="50">, que, pelo Fluminense</segment>
    <segment id="51">, impôs aquela que talvez tenha sido a mais dolorosa derrota de Vanderlei no Flamengo</segment>
    <segment id="52">, na final do Campeonato Carioca de 1995.</segment>
    <segment id="53">Um dos pivôs da demissão de Luxemburgo</segment>
    <segment id="54">, Ronaldinho Gaúcho também já faz parte do passado do Flamengo.</segment>
    <segment id="55">No início da atual temporada</segment>
    <segment id="56">, Vanderlei chegou a cobrar mais de uma vez da diretoria punições para as indisciplinas do craque.</segment>
    <segment id="57">Jamais foi atendido</segment>
    <segment id="58">, e acabou sendo ele o demitido.</segment>
    <segment id="59">Mágoa na saída</segment>
    <segment id="60">Na entrevista que deu um dia após deixar o clube</segment>
    <segment id="61">, Vanderlei revelou mágoa com a diretoria</segment>
    <segment id="62">, queixando-</segment>
    <segment id="63">sese da falta de respaldo principalmente no</segment>
    <segment id="64">casocaso Ronaldinho.</segment>
    <segment id="65">Citou, entre os problemas que enfrentou no clube</segment>
    <segment id="66">, a relação com o vice de Finanças Michel Levy</segment>
    <segment id="67">, com quem teve vários atritos.</segment>
    <segment id="68">O dirigente rubro-negro hoje põe panos quentes.
- Não tenho problema pessoal nenhum com o Vanderlei</segment>
    <segment id="69">, pelo contrário.</segment>
    <segment id="70">Se encontrá-lo</segment>
    <segment id="71">, faço questão de cumprimentá-lo.</segment>
    <segment id="72">Ele ficou chateado</segment>
    <segment id="73">porque</segment>
    <segment id="74">porque não pôde continuar um projeto que tinha no Flamengo</segment>
    <segment id="75">, entendo.</segment>
    <segment id="76">Estamos pagando a rescisão do jeito que foi combinado na demissão - afirmou Michel Levy.</segment>
    <segment id="77">Precisando reabilitar-</segment>
    <segment id="78">sese após a eliminação na Copa do Brasil</segment>
    <segment id="79">, o Grêmio esperava contar com a estreia do meia Zé Roberto</segment>
    <segment id="80">, de 37 anos</segment>
    <segment id="81">, sua principal contratação para o Brasileiro.</segment>
    <segment id="82">Mas o clube não conseguiu inscrevê-lo a tempo na CBF para este jogo.</segment>
    <segment id="83">Grêmio x Flamengo
Local: Estádio Olímpico</segment>
    <segment id="84">, em Porto Alegre
Horário: 16h
Grêmio: Victor</segment>
    <segment id="85">, Edilson</segment>
    <segment id="86">, Werley</segment>
    <segment id="87">, Gilberto Silva e Pará</segment>
    <segment id="88">; Fernando</segment>
    <segment id="89">, Souza</segment>
    <segment id="90">, Léo Gago e Marco Antônio</segment>
    <segment id="91">;</segment>
    <segment id="92">Marcelo Moreno e Kléber
Flamengo: Paulo Victor</segment>
    <segment id="93">, Wellington Silva</segment>
    <segment id="94">, Marllon</segment>
    <segment id="95">, González e Magal</segment>
    <segment id="96">;</segment>
    <segment id="97">Aírton</segment>
    <segment id="98">, Luiz Antônio</segment>
    <segment id="99">, Renato e Ibson</segment>
    <segment id="100">; Hernane e Vágner Love
Juiz: Wilson Luiz Seneme (Fifa-SP)</segment>
  </rst>
</analysis>