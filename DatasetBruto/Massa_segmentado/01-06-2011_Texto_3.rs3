  <rst>
    <segment id="1">Operação prende policiais e barões
SSP e MP vão para cima de suspeitos de tráfico e outros crimes: 19 são presos</segment>
    <segment id="2">A Operação Esfinge</segment>
    <segment id="3">, que visa  combater  formação de quadrilha</segment>
    <segment id="4">, receptação de carga roubada</segment>
    <segment id="5">, homicídio</segment>
    <segment id="6">, extorsão</segment>
    <segment id="7">, tráfico de drogas</segment>
    <segment id="8">, dentre outros</segment>
    <segment id="9">, sese arrastou ontem por Salvador e o interior e já prendeu 19 pessoas.</segment>
    <segment id="10">Um delegado</segment>
    <segment id="11">, um major da PM</segment>
    <segment id="12">, dois agentes da Polícia Civil</segment>
    <segment id="13">, uma escrivã e empresários estão entre os  presos.</segment>
    <segment id="14">Apesar da pouca informação divulgada</segment>
    <segment id="15">, estão entre os detidos o delegado de Camacã</segment>
    <segment id="16">, Jackson Silva</segment>
    <segment id="17">, dois agentes e uma escrivã da mesma unidade.</segment>
    <segment id="18">O major da PM foi identificado</segment>
    <segment id="19">comocomo Silvério.</segment>
    <segment id="20">A ação foi realizada pela Secretaria de Segurança Pública (SSP) em parceria com o Grupo de Atuação Especial de Combate às Organizações Criminosas e de Investigações Criminais (Gaeco)</segment>
    <segment id="21">, do Ministério Público da Bahia.</segment>
    <segment id="22">O objetivo é cumprir 21 mandados de prisão e 25 de busca e apreensão por crimes de extorsão</segment>
    <segment id="23">, tráfico de drogas</segment>
    <segment id="24">, homicídio e formação de quadrilha.</segment>
    <segment id="25">A operação ocorreu  em Salvador</segment>
    <segment id="26">, Vitória da Conquista</segment>
    <segment id="27">, Camacã</segment>
    <segment id="28">, Ilhéus e Itabuna e é comandada pela delegacia de Ilhéus.</segment>
    <segment id="29">Viatura da Civil cai em rio de Camacã</segment>
    <segment id="30">Não há informações oficiais sobre o efetivo de policiais envolvidos na Operação Esfinge.</segment>
    <segment id="31">No entanto</segment>
    <segment id="32">, pelo menos 15 viaturas da Polícia Civil e uma do Batalhão de Choque de Lauro de Freitas participaram da ação.</segment>
    <segment id="33">Entre os homens envolvidos há policiais de diversas unidades</segment>
    <segment id="34">, como</segment>
    <segment id="35">como Teixeira de Freitas</segment>
    <segment id="36">, Eunápolis</segment>
    <segment id="37">, Itabuna e Ilhéus</segment>
    <segment id="38">, sem contar a ajuda da Força Nacional de Segurança Pública.</segment>
    <segment id="39">Apesar de todo o sigilo que envolve a ação</segment>
    <segment id="40">, pelo menos um esparro foi registrado: uma viatura da Polícia Civil caiu em um rio em Camacã</segment>
    <segment id="41">, masmas os policiais não deram detalhes sobre possíveis  feridos.</segment>
  </rst>
</analysis>