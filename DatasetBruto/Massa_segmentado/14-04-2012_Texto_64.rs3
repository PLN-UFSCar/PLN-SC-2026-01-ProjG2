  <rst>
    <segment id="1">Paulista mora na encolha no aeroporto</segment>
    <segment id="2">Emprego deu xabu.</segment>
    <segment id="3">Agora Gerson quer voltar pra casa e rever a mulher e 4 filhos</segment>
    <segment id="4">Há dois meses morando clandestinamente no Aeroporto Internacional Luís Eduardo Magalhães</segment>
    <segment id="5">, em Salvador</segment>
    <segment id="6">, Gerson Ferreira da Silva</segment>
    <segment id="7">, 46, não esperava que sua primeira visita à capital baiana o fizesse viver drama semelhante ao do personagem Viktor Navorski</segment>
    <segment id="8">, interpretado pelo ator Tom Hanks  no filme "</segment>
    <segment id="9">O terminal"</segment>
    <segment id="10">, de 2004.


Iludido por uma falsa promessa de emprego</segment>
    <segment id="11">, ele, que trabalhava em um loja de móveis em Campinas</segment>
    <segment id="12">, São Paulo</segment>
    <segment id="13">, saiu de sua cidade em busca de melhores salários.</segment>
    <segment id="14">Gerson conta que chegou a  Salvador  com um caminhoneiro</segment>
    <segment id="15">, que supostamente integrava a mesma empresa que ele trabalhava em Campinas.</segment>
    <segment id="16">Juntos</segment>
    <segment id="17">,  planejavam atuar em uma filial da loja em Salvador.</segment>
    <segment id="18">Ao chegar à cidade</segment>
    <segment id="19">, Gerson foi comunicado</segment>
    <segment id="20">, por alguém que não soube identificar</segment>
    <segment id="21">, que a loja não abriria por problemas no alvará de funcionamento.</segment>
    <segment id="22">Enquanto Gerson tentava digerir a frustração</segment>
    <segment id="23">, o caminhoneiro informou que não voltaria a Campinas.</segment>
    <segment id="24">Desde então</segment>
    <segment id="25">, o paulista está no aeroporto de Salvador</segment>
    <segment id="26">, onde dorme na “encolha”.</segment>
    <segment id="27">Com a ajuda de alguns taxistas</segment>
    <segment id="28">, consegue alimentos e dinheiro para revender água no próprio local.</segment>
    <segment id="29">Ajuda em boa hora</segment>
    <segment id="30">O Coletivo de Entidades Negras (CEN)</segment>
    <segment id="31">sese ofereceu para comprar uma passagem aérea para Gerson.

"</segment>
    <segment id="32">A história deste homem é típica de muitos negros que</segment>
    <segment id="33">, por falta de opção de emprego e educação</segment>
    <segment id="34">, saem de suas cidades e são explorados e enganados em outras regiões"</segment>
    <segment id="35">, disse o coordenador do CEN na Bahia</segment>
    <segment id="36">, Marcos Rezende.</segment>
    <segment id="37">Segundo Rezende</segment>
    <segment id="38">, os representantes do CEN conversarão com Gerson para descobrir sua relação com a loja e</segment>
    <segment id="39">, após o esclarecer o</segment>
    <segment id="40">casocaso</segment>
    <segment id="41">, sua passagem será entregue.</segment>
    <segment id="42">"</segment>
    <segment id="43">Pretendemos resolver as pendências até o fim desta semana.</segment>
    <segment id="44">Dando tudo certo</segment>
    <segment id="45">, ele já estará em Campinas na próxima semana"</segment>
    <segment id="46">, completou Rezende.</segment>
  </rst>
