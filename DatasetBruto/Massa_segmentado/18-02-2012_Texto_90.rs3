  <rst>
    <segment id="1">Morre uma das seis vítimas de acidente
Soraia Souza e Souza</segment>
    <segment id="2">, 45 anos</segment>
    <segment id="3">, passou mal enquanto dirigia e atropelou cinco pessoas</segment>
    <segment id="4">Uma mulher</segment>
    <segment id="5">, que ficou ferida em um acidente na Avenida Bonocô na manhã desta terça-feira (28)</segment>
    <segment id="6">, não resistiu ao choque e morreu.</segment>
    <segment id="7">As outras cinco vítimas tiveram politraumatismo e não correm risco de morte</segment>
    <segment id="8">, de acordo com a Secretaria de Saúde do Estado (Sesab).</segment>
    <segment id="9">Todas estão internadas no Hospital Geral do Estado (HGE).</segment>
    <segment id="10">De acordo com agentes da Transalvador que estavam no local</segment>
    <segment id="11">, a motorista Soraia Souza e Souza</segment>
    <segment id="12">, 45 anos</segment>
    <segment id="13">, passou mal enquanto dirigia e atropelou cinco pessoas no ponto de ônibus na altura da Codesal.</segment>
