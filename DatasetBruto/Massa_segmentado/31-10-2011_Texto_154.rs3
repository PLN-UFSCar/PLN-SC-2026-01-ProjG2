  <rst>
    <segment id="1">As aventuras do pequeno Ed em Catu</segment>
    <segment id="2">Edcity ainda conserva a alegria da infância pura do interior
Cheio de energia e brincalhão.</segment>
    <segment id="3">Quando Edcarlos da Conceição Santos nasceu em 28 de março de 1982</segment>
    <segment id="4">, os pais</segment>
    <segment id="5">, Dona Schirley e Seu Jonas não imaginavam que a criança arteira</segment>
    <segment id="6">, que aprontava pelas ruas</segment>
    <segment id="7">, viraria mais tarde um dos cantores de pagode mais admirados na Bahia - Edcity.</segment>
    <segment id="8">Ed nasceu em Pojuca</segment>
    <segment id="9">, masmas com um 1 ano de idade foi morar em Catu.</segment>
    <segment id="10">E é de lá que ele guarda as melhores lembranças.</segment>
    <segment id="11">“Tive uma infância linda</segment>
    <segment id="12">, na beira do rio</segment>
    <segment id="13">, em contato com a natureza.</segment>
    <segment id="14">Foi tão marcante que desejo um dia poder morar no meio do mato”</segment>
    <segment id="15">, diz ele</segment>
    <segment id="16">, que não parava quieto dentro de casa.</segment>
    <segment id="17">Subia em coqueiro</segment>
    <segment id="18">, jogava bola e empinava pipa (brincadeira que faz até hoje)</segment>
    <segment id="19">, sempre com a irmã Elba a tiracolo.</segment>
    <segment id="20">“</segment>
    <segment id="21">Lembro de uma vez que escondi fogos de artifícios para soltar no São João</segment>
    <segment id="22">, masmas ele e Elba descobriram e soltaram tudo na frente de casa antes da festa junina começar”</segment>
    <segment id="23">, conta o pai Jonas dos Santos</segment>
    <segment id="24">, 49 anos.</segment>
    <segment id="25">Quem ficava com a mão na cabeça de tanta preocupação era a mãe de Ed</segment>
    <segment id="26">,  Schirley da Conceição Santos</segment>
    <segment id="27">, 47, mais conhecida</segment>
    <segment id="28">comocomo Géssi.</segment>
    <segment id="29">“</segment>
    <segment id="30">Ele era brincalhão</segment>
    <segment id="31">comocomo qualquer criança.</segment>
    <segment id="32">Toda mãe quer que o filho vire médico ou advogado</segment>
    <segment id="33">, masmas desde pequeno que Ed já falava que queria ser ou músico ou jogador de futebol”</segment>
    <segment id="34">, lembra dona Géssi.</segment>
    <segment id="35">Quando Ed tinha 5 anos</segment>
    <segment id="36">, via sempre o pai reunir os amigos em casa para um sambão.</segment>
    <segment id="37">“Foi meu primeiro contato com a música.</segment>
    <segment id="38">Saía batendo pelas panelas da casa tentando imitar meu pai”</segment>
    <segment id="39">, conta o cantor.</segment>
    <segment id="40">A mãe queria que ele fosse médico</segment>
    <segment id="41">, masmas logo ela percebeu que a música já estava no sangue</segment>
    <segment id="42">O menino era todo estabanado.</segment>
    <segment id="43">“</segment>
    <segment id="44">Ed tem miopia e vivia quebrando os óculos.</segment>
    <segment id="45">Os tênis dele viviam rasgados toda hora eu tinha que comprar novos.</segment>
    <segment id="46">E ele ainda era metido</segment>
    <segment id="47">, só queria que eu desse Mizuno</segment>
    <segment id="48">, não aceitava Kichute”</segment>
    <segment id="49">, ri o pai ao lembrar que desde pequeno Ed tinha muita personalidade.</segment>
    <segment id="50">Uma infância tão ativa só poderia render boas histórias.</segment>
    <segment id="51">Nasceu uma estrela:</segment>
    <segment id="52">Que bebê fofinho

Edcarlos Conceição Santos</segment>
    <segment id="53">, o Edcity</segment>
    <segment id="54">, nasceu em 28 de março de 1982 em Pojuca</segment>
    <segment id="55">, a 67 quilômetros de Salvador.</segment>
    <segment id="56">Mas com um aninho de idade</segment>
    <segment id="57">, a família decidiu morar em Catu</segment>
    <segment id="58">, local onde viveu uma infância cheia de amor familiar e contato com a natureza.</segment>
    <segment id="59">Na foto</segment>
    <segment id="60">, o pequeno Ed já mostrava a cara de guloso ao esperar a papinha na sua cadeirinha.</segment>
    <segment id="61">“Ele sempre foi bom de boca.</segment>
    <segment id="62">Até hoje ele come de tudo e não engorda”</segment>
    <segment id="63">, lembra a mãe</segment>
    <segment id="64">, dona Géssi.</segment>
  </rst>
</analysis>