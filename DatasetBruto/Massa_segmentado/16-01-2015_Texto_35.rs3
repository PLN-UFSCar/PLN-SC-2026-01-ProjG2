  <rst>
    <segment id="1">Veja os personagens da Lavagem do Bomfim
HГѓВЎ os que pedem e os que agradecem</segment>
    <segment id="2">, masmas todos sobem a colina com muita fГѓВ© e devoГѓВ§ГѓВЈo
Na sua 261Г‚ВЄ ediГѓВ§ГѓВЈo</segment>
    <segment id="3">, a Lavagem do Bonfim</segment>
    <segment id="4">, uma das festas mais populares do Brasil</segment>
    <segment id="5">, contou com a participaГѓВ§ГѓВЈo de cerca de 1 milhГѓВЈo de pessoas.</segment>
    <segment id="6">Muitas vieram para pagar promessas</segment>
    <segment id="7">, agradecer conquistas ou simplesmente para acompanhar o cortejo</segment>
    <segment id="8">, sese divertir e tomar todas.</segment>
    <segment id="9">O MASSA!</segment>
    <segment id="10">acompanhou todo o trajeto de 8 km entre a Igreja da ConceiГѓВ§ГѓВЈo da Praia</segment>
    <segment id="11">, no ComГѓВ©rcio</segment>
    <segment id="12">, e a Igreja do Bonfim</segment>
    <segment id="13">, e encontrou vГѓВЎrias histГѓВіrias de verdadeira fГѓВ© e devoГѓВ§ГѓВЈo a um dos santos mais queridos pelos baianos.</segment>
    <segment id="14">Гўв‚¬Е“Consegui minha aposentadoria e saГѓВ­ do hospital graГѓВ§as ao Senhor do Bonfim.</segment>
    <segment id="15">Vou fazer o percusso todo de muleta</segment>
    <segment id="16">, sem reclamar.</segment>
    <segment id="17">Mas essa ГѓВ© sГѓВі uma parte da promessa</segment>
    <segment id="18">, porque</segment>
    <segment id="19">porque em outubro vou pagar a outra metade</segment>
    <segment id="20">, que ГѓВ© ir para a missa de Bom Jesus da Lapa</segment>
    <segment id="21">, irmГѓВЈo do Senhor do BonfimГўв‚¬</segment>
    <segment id="22">, afirma AntГѓВґnio Santos</segment>
    <segment id="23">, 48 anos.</segment>
    <segment id="24">Acompanhe</segment>
    <segment id="25">, nestas pГѓВЎginas</segment>
    <segment id="26">, as mais interessantes histГѓВіrias que a equipe de reportagem ouviu ao longo da caminhada - toda a emoГѓВ§ГѓВЈo</segment>
    <segment id="27">, alegria</segment>
    <segment id="28">, sacrifГѓВ­cio e demonstraГѓВ§ГѓВЈo de fГѓ</segment>
    <segment id="29">В© de alguns dos  personagens que fazem essa festa</segment>
    <segment id="30">ser ГѓВєnica em todo mundo.</segment>
    <segment id="31">Personagens</segment>
    <segment id="32">O pedreiro Denivaldo Nascimento</segment>
    <segment id="33">, 56 anos</segment>
    <segment id="34">, nГѓВЈo fez nenhuma promessa para o Senhor do Bonfim</segment>
    <segment id="35">, masmas nГѓВЈo deixa de participar do cortejo hГѓВЎ 35 anos.</segment>
    <segment id="36">Para provar a devoГѓВ§ГѓВЈo</segment>
    <segment id="37">, ele enfeitou sua bicicleta com fitas do Senhor do Bonfim.</segment>
    <segment id="38">Гўв‚¬Е“Demoro trГѓВЄs dias para fazer.</segment>
    <segment id="39">FaГѓВ§o isso</segment>
    <segment id="40">porque</segment>
    <segment id="41">porque gostoГўв‚¬</segment>
    <segment id="42">, garante.
Dilsinho</segment>
    <segment id="43">, 37, ГѓВ© o atual Rei Momo de Feira de Santana e um dos candidatos</segment>
    <segment id="44">ГѓВ  conquista do tГѓВ­tulo de Salvador.</segment>
    <segment id="45">E foi este o seu principal pedido ao Senhor do Bonfim: Гўв‚¬Е“HГѓВЎ seis anos que tento faturar o tГѓВ­tulo da capital.</segment>
    <segment id="46">Fui duas vezes eleito por Alagoinhas e 4 por Feira</segment>
    <segment id="47">, este ano quero o daqui!Гўв‚¬</segment>
    <segment id="48">Estreando na festa do Bonfim</segment>
    <segment id="49">, a professora Cristiane GonГѓВ§alves</segment>
    <segment id="50">, que comemorou seu 43Г‚Вє aniversГѓВЎrio</segment>
    <segment id="51">, decidiu</segment>
    <segment id="52">sese dar</segment>
    <segment id="53">comocomo presente a ida ГѓВ  Lavagem.</segment>
    <segment id="54">Maravilhada com tudo</segment>
    <segment id="55">, ele era sГѓВі alegria durante a caminhada.</segment>
    <segment id="56">Гўв‚¬Е“ComeГѓВ§ar o dia dessa forma</segment>
    <segment id="57">ГѓВ© uma maravilha!</segment>
    <segment id="58">JГѓВЎ estou satisfeitaГўв‚¬.
JosГѓВ© LazГѓВЎro</segment>
    <segment id="59">, 68, ГѓВ© um atleta da terceira idade.</segment>
    <segment id="60">E, este ano</segment>
    <segment id="61">, a subida do Bonfim teve um sabor especial: o tГѓВ­tulo do atletismo na faixa de 65 a 69.</segment>
    <segment id="62">O vovГѓВґ exibe boa forma e confessa ser privilegiado: Гўв‚¬Е“HГѓВЎ 30 anos que venho no Bonfim e este ano vim celebrar minha conquista e a vidaГўв‚¬.
Гўв‚¬Е“Pedi para voltar a andar.</segment>
    <segment id="63">Cai de uma laje e perdi os movimentos.</segment>
    <segment id="64">Se acontecer</segment>
    <segment id="65">, prometo fazer todo o percusso</segment>
    <segment id="66">, ajoelhadoГўв‚¬</segment>
    <segment id="67">, disse  Tiago Henrique dos Santos</segment>
    <segment id="68">, 32 anos.</segment>
    <segment id="69">Ele foi ajudado pela mГѓВЈe</segment>
    <segment id="70">, Maria InГѓВЄs</segment>
    <segment id="71">, e a cunhada</segment>
    <segment id="72">, Dirlene AnunciaГѓВ§ГѓВЈo</segment>
    <segment id="73">, numa cadeira de rodas.</segment>
    <segment id="74">Гўв‚¬Е“Com fГѓВ©</segment>
    <segment id="75">, ele vai conseguirГўв‚¬</segment>
    <segment id="76">, disse a mГѓВЈe.</segment>
    <segment id="77">Adailton Santana</segment>
    <segment id="78">, 43, mora em Tancredo Neves e vai ao Bonfim hГѓВЎ</segment>
    <segment id="79">mais de dez anos.</segment>
    <segment id="80">PorГѓВ©m</segment>
    <segment id="81">, hГѓВЎ dois anos ele resolveu mudar o estilo.</segment>
    <segment id="82">Ele passou a ir ГѓВ  caminhada da Lavagem vestido de PierrГѓВґ.</segment>
    <segment id="83">Гўв‚¬Е“Desde de pequeno que venho ao Bonfim</segment>
    <segment id="84">, e de um ano para cГѓВЎ</segment>
    <segment id="85">eu resolvi vir fantasiadoГўв‚¬.
Agradecer nunca</segment>
    <segment id="86">ГѓВ© demais</segment>
    <segment id="87">, ainda mais quando</segment>
    <segment id="88">sese trata de um grande sonho.</segment>
    <segment id="89">ГѓвЂ° o caso</segment>
    <segment id="90">caso da gerente comercial Alessandra Valle</segment>
    <segment id="91">, 42.</segment>
    <segment id="92">Ele conta que pediu ao Senhor do Bonfim prosperidade e foi imediatamente atendida.</segment>
    <segment id="93">Гўв‚¬Е“Assim que pedi</segment>
    <segment id="94">, no mesmo ano</segment>
    <segment id="95">, consegui comprar uma linda casa.</segment>
    <segment id="96">Era meu propГѓВіsitoГўв‚¬.
*</segment>
