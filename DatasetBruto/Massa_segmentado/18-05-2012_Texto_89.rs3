  <rst>
    <segment id="1">Pedro, filho do cantor Leonardo</segment>
    <segment id="2">, acorda de coma</segment>
    <segment id="3">O cantor Pedro Leonardo</segment>
    <segment id="4">, filho do cantor sertanejo Leonardo</segment>
    <segment id="5">, acordou do coma em que</segment>
    <segment id="6">sese encontrava há um mês</segment>
    <segment id="7">, depois de um acidente de carro</segment>
    <segment id="8">, e está consciente no Hospital Sírio-Libanês</segment>
    <segment id="9">, em São Paulo.</segment>
    <segment id="10">A informação foi confirmada na noite deste domingo por Ede Cury</segment>
    <segment id="11">, assessora do cantor Leonardo</segment>
    <segment id="12">, e pela equipe médica do hospital.</segment>
    <segment id="13">Apesar de Pedro ainda</segment>
    <segment id="14">sese encontrar internado na Unidade de Terapia Intensiva (UTI)</segment>
    <segment id="15">, onde deve permanecer até a próxim quarta-feira</segment>
    <segment id="16">, quando passa por nova cirurgia</segment>
    <segment id="17">, ele está consciente e até respondeu corretamente a algumas perguntas dos médicos</segment>
    <segment id="18">, como</segment>
    <segment id="19">como quem é seu pai.</segment>
    <segment id="20">Segundo o médico Roberto Kalil Filho</segment>
    <segment id="21">, que coordena a equipe</segment>
    <segment id="22">, o tratamento do cantor vai entrar em uma nova fase</segment>
    <segment id="23">, masmas que ainda não é possível saber</segment>
    <segment id="24">sese ele ficará com sequelas.</segment>
    <segment id="25">O cantor Leonardo fazia show na cidade de Aurilândia</segment>
    <segment id="26">, no interior de Goiás</segment>
    <segment id="27">, quando foi informado da melhora do quadro de saúde do filho</segment>
    <segment id="28">, segundo Ede Cury.

Pedro</segment>
    <segment id="29">, que sofreu um acidente de carro no último dia 20</segment>
    <segment id="30">, deu entrada no Sírio-Libanês transferido por uma UTI aérea de Goiânia.</segment>
    <segment id="31">Ele respirava com a ajuda de aparelhos.</segment>
    <segment id="32">No último dia 12</segment>
    <segment id="33">, o jovem passou por uma cirurgia no abdômen</segment>
    <segment id="34">, para ressutura da parede abdominal.</segment>
    <segment id="35">Assim que sofreu o acidente</segment>
    <segment id="36">, Pedro havia passado por uma operação para retirada de parte do baço em um hospital de Itumbiara (GO).</segment>
    <segment id="37">A cirurgia de emergência realizada no dia 12 pela equipe do médico Raul Cutait no Hospital Sírio Libanês</segment>
    <segment id="38">, em São Paulo</segment>
    <segment id="39">, tratou de ressuturar os pontos dessa região abdominal.</segment>
    <segment id="40">Antes, ele também havia traqueostomia</segment>
    <segment id="41">, procedimento comum em pacientes que ficam muito tempo internados</segment>
    <segment id="42">, com respirador</segment>
    <segment id="43">, e que visava ajudar a preservar as cordas vocais do cantor e reduzir o risco de infecções.</segment>
    <segment id="44">O veículo que ele dirigia após um show em Uberlândia</segment>
    <segment id="45">, Minas Gerais</segment>
    <segment id="46">, capotou próximo à cidade de Itumbiara</segment>
    <segment id="47">, Goiás.</segment>
    <segment id="48">O rapaz voltava de show para sua casa em Goiânia e estava sozinho no carro.</segment>
    <segment id="49">Ele forma uma dupla com o primo Thiago.</segment>
    <segment id="50">O pai tem visitado o filho diariamente</segment>
    <segment id="51">, além da mulher</segment>
    <segment id="52">, a arquiteta Thaís</segment>
    <segment id="53">, que tem contado com apoio e orações de fãs.</segment>
  </rst>
</analysis>