  <rst>
    <segment id="1">Reforço para trazer paz ao carnaval</segment>
    <segment id="2">De acordo com o governador</segment>
    <segment id="3">, o planejamento para a folia está mantido</segment>
    <segment id="4">O governador Jaques Wagner disse ontem (13) que a cidade voltou ao normal após o término da greve da PM</segment>
    <segment id="5">, que durou 12 dias.</segment>
    <segment id="6">"Feliz não dá para ficar</segment>
    <segment id="7">, estou satisfeito.</segment>
    <segment id="8">Já dá para ver que tudo voltou ao normal</segment>
    <segment id="9">, está ficando tranquilo.</segment>
    <segment id="10">"</segment>
    <segment id="11">Em coletiva</segment>
    <segment id="12">, Wagner disse que a folia de Momo vai contar com o trabalho de 19.727 PMs</segment>
    <segment id="13">, além do efetivo da Polícia Civil</segment>
    <segment id="14">, Força Nacional e Exército</segment>
    <segment id="15">, vão trabalhar ao longo dos circuitos.</segment>
    <segment id="16">No total</segment>
    <segment id="17">, foram investidos R$ 56</segment>
    <segment id="18">,2 milhões.</segment>
    <segment id="19">Já o secretário de Segurança Pública</segment>
    <segment id="20">, Maurício Barbosa</segment>
    <segment id="21">, disse que não teme a mudança de comportamento dos PMs durante a festa.

"</segment>
    <segment id="22">A maioria serviu</segment>
    <segment id="23">comocomo massa de manobra do grupo que radicalizou".</segment>
    <segment id="24">De acordo com ele</segment>
    <segment id="25">, vários policiais que cometeram atos ilícitos foram identificados e continuarão sendo investigados.</segment>
    <segment id="26">Wagner  criticou a Corregedoria da PM e disse que pretende melhorar a estrutura do órgão.</segment>
    <segment id="27">"</segment>
    <segment id="28">Precisamos reforçar a Corregedoria</segment>
    <segment id="29">, que não tem estrutura para separar o bom policial do ruim”.</segment>
    <segment id="30">Para o governador</segment>
    <segment id="31">, a vinda de reforço da Força Nacional durante o período da greve foi acertada e fundamental.</segment>
    <segment id="32">“Se nós não tivéssemos feito o chamamento com a rapidez que nós fizemos</segment>
    <segment id="33">, não sei</segment>
    <segment id="34">sese essa crise teria sido resolvida até o momento”</segment>
    <segment id="35">, disse.</segment>
    <segment id="36">“</segment>
    <segment id="37">Com o apoio da Força Nacional</segment>
    <segment id="38">, da Polícia Federal</segment>
    <segment id="39">, das Forças Armadas e também do Ministério Público e Judiciário</segment>
    <segment id="40">, nós conseguimos pelo menos impor uma derrota a essa metodologia de intimidação da população</segment>
    <segment id="41">, que não pode ser aceita para reivindicações salariais”.</segment>
    <segment id="42">Turistas na folia 2012</segment>
    <segment id="43">Para o governador</segment>
    <segment id="44">, o impacto da greve e os episódios de violência não afetam a imagem da Bahia</segment>
    <segment id="45">,  para os turistas é passageiro.</segment>
    <segment id="46">"</segment>
    <segment id="47">É óbvio que assusta</segment>
    <segment id="48">, masmas no geral as pessoas sabem que isso é pontual</segment>
    <segment id="49">, a imagem da Bahia continua sendo a da gente hospitaleira</segment>
    <segment id="50">, que recebe bem os visitantes"</segment>
    <segment id="51">, frisa.</segment>
    <segment id="52">Já segundo Domingos Leonelli</segment>
    <segment id="53">, secretário de Turismo</segment>
    <segment id="54">, as principais operadoras de viagens do Estado não relataram cancelamentos de pacotes para o Carnaval.</segment>
  </rst>
</analysis>