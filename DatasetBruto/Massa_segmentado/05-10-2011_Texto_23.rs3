  <rst>
    <segment id="1">Mataram sem a vítima ter reagido
Poucos dias após a morte do marido</segment>
    <segment id="2">, Rosa foi assassinada por assaltantes</segment>
    <segment id="3">A comerciante Rosineide Bispo dos Santos</segment>
    <segment id="4">, 50 anos</segment>
    <segment id="5">, conhecida</segment>
    <segment id="6">comocomo Rosa</segment>
    <segment id="7">, foi assassinada com um tiro na nuca por dois homens que estavam em uma moto</segment>
    <segment id="8">, por volta das 8h da manhã de ontem</segment>
    <segment id="9">, na rua Gengibirra do Meio</segment>
    <segment id="10">, na Liberdade</segment>
    <segment id="11">, perto do Largo do Tanque.</segment>
    <segment id="12">No momento do crime</segment>
    <segment id="13">, a vítima estava com a nora</segment>
    <segment id="14">, uma mulher de 27 anos.</segment>
    <segment id="15">Aos familiares</segment>
    <segment id="16">, a jovem contou que os criminosos pediram a bolsa da vítima</segment>
    <segment id="17">, que entregou sem resistência.</segment>
    <segment id="18">Mesmo assim</segment>
    <segment id="19">, os bandidos atiraram.</segment>
    <segment id="20">Segundo o vendedor Marcelo Pita</segment>
    <segment id="21">, 31, irmão da testemunha</segment>
    <segment id="22">, Rosineide passou na casa da nora momentos antes do ocorrido.</segment>
    <segment id="23">De acordo com ele</segment>
    <segment id="24">, as duas seguiam para o bairro São Caetano</segment>
    <segment id="25">, onde Rosa pretendia olhar um imóvel</segment>
    <segment id="26">, pois</segment>
    <segment id="27">pois ela queria mudar de residência.</segment>
    <segment id="28">Rosineide Bispo dos Santos morreu na rua Gengibirra</segment>
    <segment id="29">, perto de onde morava</segment>
    <segment id="30">, na rua São Lourenço</segment>
    <segment id="31">Tentou sacar dinheiro</segment>
    <segment id="32">“</segment>
    <segment id="33">Há menos de 15 dias</segment>
    <segment id="34">, ela perdeu o marido</segment>
    <segment id="35">, de quem gostava muito.</segment>
    <segment id="36">Ele morreu de diabetes e problemas renais.</segment>
    <segment id="37">Como a casa não lhe trazia boas recordações</segment>
    <segment id="38">, ela queria</segment>
    <segment id="39">sese mudar”</segment>
    <segment id="40">, informou Marcelo.</segment>
    <segment id="41">De acordo com o delegado do Departamento de Homicídios (DHPP)</segment>
    <segment id="42">, Alex Schramm</segment>
    <segment id="43">, a polícia trabalha inicialmente com a hipótese de latrocínio (matar para roubar).</segment>
    <segment id="44">“Não houve nem tempo de ela reagir ao assalto”</segment>
    <segment id="45">, disse Schramm.</segment>
    <segment id="46">Segundo o delegado</segment>
    <segment id="47">, Rosa havia passado em uma agência bancária para tirar dinheiro</segment>
    <segment id="48">, minutos antes de ser morta</segment>
    <segment id="49">, masmas não conseguiu sacar a grana.</segment>
    <segment id="50">A polícia investiga</segment>
    <segment id="51">sese os assassinos seguiram a vítima após a saída dela do banco.</segment>
  </rst>
</analysis>