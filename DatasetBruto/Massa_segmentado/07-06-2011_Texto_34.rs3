  <rst>
    <segment id="1">Camisa 9 amarela não será a mesma</segment>
    <segment id="2">Com dois títulos mundiais (1994 e 2002)</segment>
    <segment id="3">, Ronaldo hoje dá adeus à canarinho</segment>
    <segment id="4">Em 1994</segment>
    <segment id="5">, o menino-prodígio do Cruzeiro ganhou de presente uma convocação para a Copa do Mundo dos Estados Unidos.</segment>
    <segment id="6">Deu sorte</segment>
    <segment id="7">, pois</segment>
    <segment id="8">pois foi campeão mundial sem entrar uma vez em campo.</segment>
    <segment id="9">De lá para cá foram 12 anos de dedicação à Seleção Brasileira</segment>
    <segment id="10">, com 15 gols em Copas do Mundo (o maior artilheiro da história) e dois títulos mundiais (94 e 2002).</segment>
    <segment id="11">Hoje à noite</segment>
    <segment id="12">, Ronaldo</segment>
    <segment id="13">sese despede da amarelinha em um amistoso contra a Romênia</segment>
    <segment id="14">, no Pacaembu</segment>
    <segment id="15">, e o Fenômeno pediu de presente um pênalti aos companheiros</segment>
    <segment id="16">, pois</segment>
    <segment id="17">pois quer dar adeus comemorando.</segment>
    <segment id="18">“É lógico que seria um sonho me despedir fazendo gol e para isso eu já comentei com os meus colegas da Seleção:</segment>
    <segment id="19">‘Chegou dentro da área é para cair’.</segment>
    <segment id="20">E ainda tenho que fazer o pênalti</segment>
    <segment id="21">, o que não é fácil...</segment>
    <segment id="22">”, disse o craque.</segment>
    <segment id="23">Ronaldo vai entrar em campo aos 30 minutos do primeiro tempo e não volta para a etapa final</segment>
    <segment id="24">, pois</segment>
    <segment id="25">pois está longe dos gramados desde o início de fevereiro</segment>
    <segment id="26">, quando aposentou-</segment>
    <segment id="27">sese no Corinthians.</segment>
    <segment id="28">Tudo começou contra os hermanos em 1994</segment>
    <segment id="29">O primeiro jogo de Ronaldo pela Seleção Brasileira ocorreu num amistoso contra a Argentina no dia 23 de março de 1994.</segment>
    <segment id="30">Aos 17 anos</segment>
    <segment id="31">, ele não fez gol</segment>
    <segment id="32">, masmas o Brasil venceu por 2 a 0</segment>
    <segment id="33">, com dois gols do baiano Bebeto</segment>
    <segment id="34">, a quem o Fenômeno substituiu.</segment>
    <segment id="35">O jogo foi no Arruda</segment>
    <segment id="36">, em Recife.</segment>
    <segment id="37">Seu primeiro gol foi na vitória por 3 a 0 contra a Islândia</segment>
    <segment id="38">, dia 4 de maio do mesmo ano</segment>
    <segment id="39">, na Ressacada</segment>
    <segment id="40">, em Florianópolis.</segment>
    <segment id="41">CBF dá  relógio de ouro de presente</segment>
    <segment id="42">O atacante Ronaldo recebeu ontem um relógio suíço de ouro e outros afagos da CBF.</segment>
    <segment id="43">"</segment>
    <segment id="44">Na minha gestão</segment>
    <segment id="45">, você foi o melhor jogador que passou pela Seleção Brasileira"</segment>
    <segment id="46">, disse Ricardo Teixeira</segment>
    <segment id="47">, presidente da entidade desde 1989.</segment>
  </rst>
