  <rst>
    <segment id="1">RJX é campeão estadual de vôlei</segment>
    <segment id="2">O RJX conquistou na noite desta quinta-feira seu primeiro título estadual de vôlei ao derrotar o Volta Redonda por 3 sets a 1 (20/25</segment>
    <segment id="3">, 25/19</segment>
    <segment id="4">, 26/24 e 25/17)</segment>
    <segment id="5">, no Maracanãzinho.</segment>
    <segment id="6">Sábado</segment>
    <segment id="7">, às 18h30m</segment>
    <segment id="8">, a equipe carioca volta ao ginásio para enfrentar o Vivo/Minas</segment>
    <segment id="9">, pela sexta rodada da Superliga masculina.</segment>
    <segment id="10">Apresentado em julho do ano passado</segment>
    <segment id="11">, o RJX</segment>
    <segment id="12">, do ponteiro Dante</segment>
    <segment id="13">, do central Lucão e do levantador Marlon</segment>
    <segment id="14">, todos da seleção brasileira</segment>
    <segment id="15">, é o primeiro time masculino de vôlei do Rio após 13 anos.</segment>
  </rst>
