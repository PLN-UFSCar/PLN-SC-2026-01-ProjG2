  <rst>
    <segment id="1">Tours de Jeep e van pela Rocinha temporariamente suspensos
RIO - Procuradas na manhã de sábado</segment>
    <segment id="2">, operadoras que levam turistas em passeios de Jeep e van pela Rocinha não estavam agendando tours para a comunidade neste final de semana.</segment>
    <segment id="3">Apesar da situação aparentemente calma no início da manhã na comunidade</segment>
    <segment id="4">, operadoras</segment>
    <segment id="5">sese mostram receosas ante o clima de incerteza causado pela ocupação prevista para amanhã.

- Estamos agendando passeios à Rocinha só para a partir de segunda-feira - disse a atendente de uma das operadoras.</segment>
    <segment id="6">- Estamos sem gente no escritório.</segment>
    <segment id="7">Algumas operadoras transferiram temporariamente os passeios para outras comunidades da Zona Sul</segment>
    <segment id="8">, como</segment>
    <segment id="9">como a favela das Canoas e a do morro de Santa Marta.</segment>
    <segment id="10">A rotina da Rocinha</segment>
    <segment id="11">sese mantém praticamente inalterada na manhã de hoje</segment>
    <segment id="12">, desde a madrugada.</segment>
    <segment id="13">Estabelecimentos</segment>
    <segment id="14">sese mantêm abertos e as pessoas circulam normalmente</segment>
    <segment id="15">, apesar das blitzes feitas pelo Batalhão de Choque nos acessos da favela.</segment>
  </rst>
