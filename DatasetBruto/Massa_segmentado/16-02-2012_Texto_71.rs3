  <rst>
    <segment id="1">As Porretes pedem passagem em Itapuã</segment>
    <segment id="2">As Porretes tomaram conta das ruas de Itapuã ontem</segment>
    <segment id="3">, pelo segundo ano
Depois do tradicional</segment>
    <segment id="4">“esquenta” no barzinho</segment>
    <segment id="5">, As Porretes tomaram conta das ruas de Itapuã ontem</segment>
    <segment id="6">, pelo segundo ano.</segment>
    <segment id="7">Com  alegria e descontração</segment>
    <segment id="8">, as “meninas” arrasaram.</segment>
    <segment id="9">Com o tema “As Porretes nas Estrelas”</segment>
    <segment id="10">, cerca de 100 rapazes desfilaram em minúsculas saias azuis</segment>
    <segment id="11">, blusas frente- -única</segment>
    <segment id="12">, com o grito de guerra: “Ai</segment>
    <segment id="13">, como</segment>
    <segment id="14">como sou bandido”.</segment>
    <segment id="15">A plateia adorou.</segment>
    <segment id="16">Aiii, eu quero o motoqueiro</segment>
    <segment id="17">A “Porrete Alessandra” ou “Loira Poderosa” estava</segment>
    <segment id="18">sese achando.</segment>
    <segment id="19">“Eu não sabia que era tão bom</segment>
    <segment id="20">, todos me olham</segment>
    <segment id="21">,buzinam...</segment>
    <segment id="22">Aiii, como</segment>
    <segment id="23">como sou bandido</segment>
    <segment id="24">, esse motoqueiro não me escapa!</segment>
    <segment id="25">”.</segment>
    <segment id="26">E assim seguiu para atacar o cara com um beijo.</segment>
  </rst>
