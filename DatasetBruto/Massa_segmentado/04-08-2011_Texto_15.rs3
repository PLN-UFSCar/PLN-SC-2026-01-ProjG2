  <rst>
    <segment id="1">Vinte animais aparecem mortos</segment>
    <segment id="2">Os corpos começaram a surgir há oito dias</segment>
    <segment id="3">, deixando preocupada a população de Ichu</segment>
    <segment id="4">A população do município de Ichu</segment>
    <segment id="5">, a 188 km de Salvador</segment>
    <segment id="6">, está intrigada com a morte misteriosa de mais de 20 animais</segment>
    <segment id="7">, de diversas espécies</segment>
    <segment id="8">, na região.</segment>
    <segment id="9">De acordo com populares</segment>
    <segment id="10">, os animais começaram a morrer há cerca de oito dias</segment>
    <segment id="11">, depois que um cachorro morto foi comido por urubus</segment>
    <segment id="12">, que também apareceram mortos.</segment>
    <segment id="13">"</segment>
    <segment id="14">Há relatos de mortes em povoados próximos ao município"</segment>
    <segment id="15">, completou André Luiz</segment>
    <segment id="16">, blogueiro da região.</segment>
    <segment id="17">Segundo informações do G1</segment>
    <segment id="18">, a ambientalista Telma Lobão</segment>
    <segment id="19">, que acompanha o</segment>
    <segment id="20">casocaso</segment>
    <segment id="21">, diz que a quantidade de animais mortos é o que mais surpreende.</segment>
    <segment id="22">Ela não acredita na possibilidade de envenenamento.</segment>
    <segment id="23">"</segment>
    <segment id="24">Na região em que os corpos foram encontrados não há água (rios ou lagos) nem cultivos.</segment>
    <segment id="25">Minha suspeita inicial é a de que seja algo no solo"</segment>
    <segment id="26">,  avalia.</segment>
    <segment id="27">Ainda de acordo com a ambientalista Telma Lobão</segment>
    <segment id="28">, nessas situações o ideal é recolher os animais mortos e fazer uma análise química da composição do corpo</segment>
    <segment id="29">, além de avaliar o solo.</segment>
    <segment id="30">O veterinário especialista em aves</segment>
    <segment id="31">, Pedro Lima</segment>
    <segment id="32">, diz que está acompanhando o</segment>
    <segment id="33">casocaso  pelo relato de conhecidos.</segment>
    <segment id="34">"</segment>
    <segment id="35">Tenho parceria com o Ministério da Saúde para monitorar casos de doenças de aves na região e o acionei para averiguar a situação"</segment>
    <segment id="36">, conta Pedro.

 

Providências: Coleta de amostras</segment>
    <segment id="37">A secretária da Saúde de Ichu</segment>
    <segment id="38">, Graça Almeida</segment>
    <segment id="39">, diz que foi acionada ontem sobre o</segment>
    <segment id="40">casocaso e que já tomou providências.</segment>
    <segment id="41">"</segment>
    <segment id="42">Ligamos imediatamente para a Secretaria de Saúde do Estado</segment>
    <segment id="43">, que solicitou que coletássemos amostras dos animais.</segment>
    <segment id="44">Estamos fazendo o possível para isso</segment>
    <segment id="45">, pois</segment>
    <segment id="46">pois não temos a infraestrutura necessária</segment>
    <segment id="47">, como</segment>
    <segment id="48">como um veterinário para fazer a coleta ou freezers para armazenar o material"</segment>
    <segment id="49">, diz.</segment>
    <segment id="50">A Sesab deve mandar alguém a Ichu.</segment>
    <segment id="51">A lenda do “chupa-cabra”

Volta e meia</segment>
    <segment id="52">, crendices populares ligam a morte misteriosa de animais em ambientes rurais à ação de uma criatura imaginária apelidada de “chupa-cabra”.</segment>
    <segment id="53">O nome deve-</segment>
    <segment id="54">sese à descoberta de várias cabras mortas em Porto Rico com marcas de dentadas no pescoço</segment>
    <segment id="55">, que teriam tido o sangue supostamente drenado.</segment>
    <segment id="56">A lenda sobre o “chupa cabra” chegou a várias regiões da América</segment>
    <segment id="57">, como</segment>
    <segment id="58">como Chile</segment>
    <segment id="59">, México e Brasil.</segment>
    <segment id="60">Embora o assunto tenha sido explorado pela mídia</segment>
    <segment id="61">, por ter caído no gosto popular</segment>
    <segment id="62">, os rumores sobre a existência do “chupa cabra” foram desaparecendo.</segment>
  </rst>
</analysis>