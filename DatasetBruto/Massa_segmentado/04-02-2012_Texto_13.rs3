  <rst>
    <segment id="1">Artistas cancelam eventos no finde
Ninguém quer sair de casa para</segment>
    <segment id="2">sese divertir por causa da greve dos policiais</segment>
    <segment id="3">"</segment>
    <segment id="4">Salvador City!</segment>
    <segment id="5">Que Deus nos acompanhe e abençoe!</segment>
    <segment id="6">Pois o clima aqui tá tenso demais"</segment>
    <segment id="7">, falou no Twitter o cantor Léo Santana</segment>
    <segment id="8">, vocalista da banda Parangolé.</segment>
    <segment id="9">E ele não foi o único artista que ficou assustado com a greve da Polícia Militar na Bahia.</segment>
    <segment id="10">Preta Gil</segment>
    <segment id="11">, Manno Góes (Jammil) e Xandy (Harmonia do Samba) também usaram as redes sociais para falar sobre os acontecimentos ruins em Salvador.</segment>
    <segment id="12">Apesar de toda a situação de violência</segment>
    <segment id="13">, a ex-BBB Anamara</segment>
    <segment id="14">, que era policial militar antes de entrar no programa</segment>
    <segment id="15">,  falou  que estava preocupada com a cidade</segment>
    <segment id="16">, masmas que</segment>
    <segment id="17">sese solidarizava com os PMs grevistas.</segment>
    <segment id="18">"</segment>
    <segment id="19">Estou preocupada com a segurança nas ruas</segment>
    <segment id="20">, masmas entendo os motivos destes profissionais que ganham míseros salários"</segment>
    <segment id="21">, disse.</segment>
    <segment id="22">Por causa da greve da PM</segment>
    <segment id="23">,  17 eventos foram cancelados .</segment>
    <segment id="24">Ontem, não aconteceram os shows de Fredd Moura (Padaria Bar)</segment>
    <segment id="25">, Marcela Bellas  (Teatro Sesc-Senac)</segment>
    <segment id="26">,  Filhos de Jorge (Mercado Modelo)</segment>
    <segment id="27">, Saiddy Bamba  (The Best Beach)</segment>
    <segment id="28">, Leva Noiz (Bali Beach) e Mariene de Castro (Espaço Cultural Barroquinha)</segment>
    <segment id="29">, adiado para o dia 10.</segment>
    <segment id="30">Entre as peças teatrais canceladas ontem</segment>
    <segment id="31">estão 7 Conto (Teatro Jorge Amado)</segment>
    <segment id="32">,</segment>
    <segment id="33">A Bofetada</segment>
    <segment id="34">,  (Teatro do ISBA)</segment>
    <segment id="35">,  Cabaré da Rrrrrrrraça (Teatro Vila Velha) e Os Donos do Riso (Praça Aquários).</segment>
    <segment id="36">Confira os eventos que não vão mais acontecer no sábado e no domingo.</segment>
    <segment id="37">O que não vai rolar na cidade...

SÁBADO (4/2)</segment>
    <segment id="38">Ensaio do Ilê Ayiê (Liberdade) - Cancelado</segment>
    <segment id="39">Show do Palavra Cantada (Barra Salvador Hall) - Adiado para 10 de março
Cerveja &amp; Cia Folia (Espaço Praia do Forte) - Ainda não há nova data para o evento

DOMINGO (5/2)</segment>
    <segment id="40">Ensaio do Olodum (Pelourinho) - Cancelado
República do Reggae  (Wet’n Wild) -adiado para 12 de fevereiro</segment>
    <segment id="41">Ensaio da Timbalada (Comércio) - Adiado para dia 10 de fevereiro</segment>
    <segment id="42">Praia do Nana (Ondina) - Cancelado
Bailinho de Quinta (Parque da Cidade) - Cancelado</segment>
  </rst>
