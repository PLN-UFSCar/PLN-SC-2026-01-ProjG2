  <rst>
    <segment id="1">Cinquentões formam fã-clube só para discutir suas Harleys-Davidson</segment>
    <segment id="2">No passado</segment>
    <segment id="3">, liberdade era uma calça velha e desbotada.</segment>
    <segment id="4">Agora é uma motocicleta reluzente e estradeira.</segment>
    <segment id="5">De segunda a quinta-feira</segment>
    <segment id="6">, os PhDs</segment>
    <segment id="7">sese reúnem na Zona Sul do Rio</segment>
    <segment id="8">, na Barra e em Niterói para bater papo</segment>
    <segment id="9">, trocar experiências e programar as viagens do fim de semana para o interior e</segment>
    <segment id="10">, eventualmente</segment>
    <segment id="11">, para o exterior do país.</segment>
    <segment id="12">Os PhDs em questão são Proprietários de Harleys-Davidson</segment>
    <segment id="13">, conhecidos</segment>
    <segment id="14">comocomo "harleyros"</segment>
    <segment id="15">, aficionados pela marca de motocicleta mais cultuada no mundo.</segment>
    <segment id="16">Cinquentões - ou até sessentões - bem-sucedidos formam um grupo cada vez maior.

- Ao pilotar uma Harley</segment>
    <segment id="17">, você curte um estilo de vida</segment>
    <segment id="18">, uma paixão com fidelidade incrível - diz o motociclista Roberto Schumburg</segment>
    <segment id="19">, de 63 anos</segment>
    <segment id="20">, que herdou a paixão pelas possantes do avô e do pai.</segment>
    <segment id="21">No mês passado</segment>
    <segment id="22">, a marca inaugurou sua concessionária na Barra da Tijuca</segment>
    <segment id="23">, substituindo o antigo (e problemático) representante local por uma subsidiária da matriz americana.</segment>
    <segment id="24">Outra novidade é a nacionalização da produção das máquinas: a HD assumiu completamente a montagem de alguns modelos na Zona Franca de Manaus</segment>
    <segment id="25">, reduzindo os preços em até 30% para tornar a marca mais competitiva.</segment>
    <segment id="26">Os valores das motocicletas variam bastante.</segment>
    <segment id="27">Um modelo mais simples - de 800 cilindradas- custa R$ 30 mil.</segment>
    <segment id="28">Já a top de linha</segment>
    <segment id="29">, a Ultra Classic</segment>
    <segment id="30">, de 1.800 cilidradas</segment>
    <segment id="31">, sai por R$ 80 mil.</segment>
    <segment id="32">O advogado Aloísio Braz</segment>
    <segment id="33">, presidente da Associação dos Motociclistas do Rio de Janeiro (AMO-RJ)</segment>
    <segment id="34">, lembra que o custo do seguro das motos</segment>
    <segment id="35">, criadas em 1903</segment>
    <segment id="36">, é barato.

- Como não há comércio de peças</segment>
    <segment id="37">, o índice de roubo é zero - explica.</segment>
    <segment id="38">Estima-</segment>
    <segment id="39">sese que existam cerca de 20 mil motos do tipo no Brasil</segment>
    <segment id="40">, das quais 1.500 no Rio.</segment>
  </rst>
</analysis>