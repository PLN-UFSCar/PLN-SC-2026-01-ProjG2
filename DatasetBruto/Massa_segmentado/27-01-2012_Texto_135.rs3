  <rst>
    <segment id="1">Briga acirrada na web
Irmã de Rianne fala mal de Cissa Chaggas e arma confusão na internet</segment>
    <segment id="2">A modelo Rianne Ferreira</segment>
    <segment id="3">sese envolveu em mais uma confusão</segment>
    <segment id="4">, desta vez pelas mãos da própria irmã</segment>
    <segment id="5">, Emmi Pereira</segment>
    <segment id="6">, que administra a página da gata no Facebook.</segment>
    <segment id="7">Ao pedir votos para a loira ganhar “</segment>
    <segment id="8">O Trio - Reality”</segment>
    <segment id="9">, ela não foi feliz ao fazer comentários sobre a dançarina Cissa Chaggas.</segment>
    <segment id="10">Bastou para</segment>
    <segment id="11">sese criar uma confusão com os fãs da Mulher Maravilha</segment>
    <segment id="12">, especialmente Bruno Chaggas.</segment>
    <segment id="13">Troca de ofensas e um “disse me disse” sem fim tomaram conta do perfil de Rianne.</segment>
    <segment id="14">Pelo jeito</segment>
    <segment id="15">, o bafafá ainda vai dar muito pano para a manga.</segment>
    <segment id="16">Aguardem!</segment>
  </rst>
