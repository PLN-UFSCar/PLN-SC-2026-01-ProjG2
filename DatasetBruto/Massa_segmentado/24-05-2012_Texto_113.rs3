  <rst>
    <segment id="1">Nos pênaltis</segment>
    <segment id="2">, Santos passa por Vélez e está na semifinal</segment>
    <segment id="3">Foi dramático.</segment>
    <segment id="4">Após vencer um jogo duríssimo por 1 a 0 no tempo normal</segment>
    <segment id="5">, o Santos venceu o Vélez Sarsfield</segment>
    <segment id="6">, da Argentina</segment>
    <segment id="7">, por 4 a 2 nos pênaltis e está nas semifinais da Libertadores.</segment>
    <segment id="8">Por força de regulamento</segment>
    <segment id="9">, a tabela será alterada e os santistas vão enfrentar o Corinthians em duas partidas.</segment>
    <segment id="10">O time da capital terá o mando de campo do segundo jogo.</segment>
    <segment id="11">Um panorama assustador</segment>
    <segment id="12">sese apresentou ao torcedor do Santos no primeiro tempo.</segment>
    <segment id="13">Contra um adversário fechado</segment>
    <segment id="14">, faltavam espaços.</segment>
    <segment id="15">O time paulista não criava</segment>
    <segment id="16">, em especial</segment>
    <segment id="17">porque</segment>
    <segment id="18">porque Ganso tinha participações esparsas no jogo e Neymar sofria muitas faltas.</segment>
    <segment id="19">O Vélez era organizado.</segment>
    <segment id="20">Após criar só uma chance perigosa</segment>
    <segment id="21">, em chute de Neymar após rebatida errada da zaga argentina</segment>
    <segment id="22">, o Santos achou o lance que poderia decidir o jogo.</segment>
    <segment id="23">Num lançamento de Elano</segment>
    <segment id="24">, Neymar deu um toque de cabeça para driblar o goleiro Barovero e sofrer falta.</segment>
    <segment id="25">O goleiro foi expulso</segment>
    <segment id="26">, aos 39 minutos.</segment>
    <segment id="27">Mas o jogo continuou muito duro e</segment>
    <segment id="28">, mesmo com dez</segment>
    <segment id="29">, foi o Vélez que teve as melhores chances do início do segundo tempo.</segment>
    <segment id="30">Martínez acertou o ângulo quase do meio-campo</segment>
    <segment id="31">, masmas Rafael salvou.</segment>
    <segment id="32">Depois</segment>
    <segment id="33">, aos 19</segment>
    <segment id="34">, Martínez recebeu na área e chutou para fora.</segment>
    <segment id="35">Muricy Ramalho lançou um terceiro atacante</segment>
    <segment id="36">, com Rentería na vaga de Adriano.</segment>
    <segment id="37">Mas mudou mesmo o jogo com Léo no lugar de Juan</segment>
    <segment id="38">, aos 27.</segment>
    <segment id="39">O Santos cresceu e passou a criar chances.</segment>
    <segment id="40">Aos 29</segment>
    <segment id="41">, Alan Kardec entrou livre</segment>
    <segment id="42">, diante de Montoya</segment>
    <segment id="43">, masmas chutou em cima do goleiro.</segment>
    <segment id="44">Aos 32</segment>
    <segment id="45">, Léo fez bela tabela com Ganso e tocou para o mesmo Alan Kardec.</segment>
    <segment id="46">Desta vez</segment>
    <segment id="47">, o chute foi preciso:</segment>
    <segment id="48">1 a 0.</segment>
    <segment id="49">Nos pênaltis</segment>
    <segment id="50">, os quatro santistas que cobraram acertaram:</segment>
    <segment id="51">Alan Kardec</segment>
    <segment id="52">, Ganso</segment>
    <segment id="53">, Elano e Léo.</segment>
    <segment id="54">Rafael defendeu a cobrança de Papa</segment>
    <segment id="55">, Canteros chutou para fora o Santos venceu por 4 a 2.

Santos 1 (4) x 0 (2) Vélez Sarsfield

Santos: Rafael</segment>
    <segment id="56">, Henrique (Maranhão)</segment>
    <segment id="57">, Durval</segment>
    <segment id="58">, Edu Dracena e Juan (Léo)</segment>
    <segment id="59">;</segment>
    <segment id="60">Adriano (Rentería)</segment>
    <segment id="61">, Arouca</segment>
    <segment id="62">, Elano e Ganso</segment>
    <segment id="63">; Neymar e Alan Kardec

Vélez Sarsfield: Barovero</segment>
    <segment id="64">, Peruzzi</segment>
    <segment id="65">, Ortiz</segment>
    <segment id="66">, Sebá e Papa</segment>
    <segment id="67">; Cubero</segment>
    <segment id="68">, Zapata</segment>
    <segment id="69">, Fernández (Cantros) e Cabral (Bella)</segment>
    <segment id="70">; Martínez e Obolo (Montoya)

Juiz: Roberto Silvera (Uruguai)

Cartões amarelos: Alan Kardec</segment>
    <segment id="71">, Adriano</segment>
    <segment id="72">, Arouca</segment>
    <segment id="73">, Neymar</segment>
    <segment id="74">, Cabral e Fernández

Cartão vermelho: Barovero.</segment>
  </rst>
</analysis>