  <rst>
    <segment id="1">Qualidade certa é Sem Retoque</segment>
    <segment id="2">A inspiração dos músicos vem de sertanejos</segment>
    <segment id="3">comocomo Eduardo Costa e Zezé de Camargo</segment>
    <segment id="4">Para os apaixonados de plantão</segment>
    <segment id="5">, nada melhor do que dançar agarradinho ao som de um bom arrocha.</segment>
    <segment id="6">Sabendo disso</segment>
    <segment id="7">, a banda Sem Retoque capricha na hora em que o hit “Loucura de Amor” toca em seus shows.</segment>
    <segment id="8">A  música de trabalho faz parte do segundo CD do grupo</segment>
    <segment id="9">, que tem 22 faixas</segment>
    <segment id="10">, 13 delas autorais</segment>
    <segment id="11">, que já correm as estradas do interior do estado há um ano e meio e agradam em cheio ao público</segment>
    <segment id="12">, que se</segment>
    <segment id="13">se encanta com o ritmo genuinamente baiano.</segment>
    <segment id="14">“</segment>
    <segment id="15">O arrocha fala a linguagem do povo</segment>
    <segment id="16">, sem apelação.</segment>
    <segment id="17">Além de não estimular a violência</segment>
    <segment id="18">, que é o melhor”</segment>
    <segment id="19">, declara o vocalista Jaldo Rodrigues.</segment>
    <segment id="20">O rapaz saiu da cidade de Gandu para investir na carreira musical.</segment>
    <segment id="21">“</segment>
    <segment id="22">Sempre cantei e tocava violão e cavaquinho</segment>
    <segment id="23">, até que conheci Nozio e resolvi me mudar para Salvador e investir na banda”</segment>
    <segment id="24">, conta.</segment>
    <segment id="25">Nozio Neto é o tecladista do grupo e aportou na Soterópolis com o mesmo objetivo do parceiro.</segment>
    <segment id="26">“Sou do município de Tanquinho e fazia voz e teclado até conhecer Jaldo”</segment>
    <segment id="27">, lembra o rapaz.</segment>
    <segment id="28">Nessa pegada de paixão pela música</segment>
    <segment id="29">, os dois acabaram criando não só a banda</segment>
    <segment id="30">, masmas uma bela amizade.</segment>
    <segment id="31">“Somos parceiros e amigos.</segment>
    <segment id="32">Admiro muito o trabalho de Nozio.</segment>
    <segment id="33">É por isso que a banda dá tão certo”</segment>
    <segment id="34">, elogia Jaldo.</segment>
    <segment id="35">Para o companheiro</segment>
    <segment id="36">, a recíproca é muito verdadeira.</segment>
    <segment id="37">“Ele (Jaldo) tem uma influência do sertanejo e canta bem demais quando usa isso para fazer arrocha</segment>
    <segment id="38">, que é tão romântico quanto”</segment>
    <segment id="39">, completa o tecladista.</segment>
    <segment id="40">Com toda a rasgação de seda</segment>
    <segment id="41">, os rapazes contam que até o final deste ano vão lançar o terceiro CD.</segment>
    <segment id="42">E como</segment>
    <segment id="43">como sempre</segment>
    <segment id="44">, com muito cuidado.</segment>
    <segment id="45">Sem precisar de retoques!</segment>
    <segment id="46">Assista aos shows</segment>
    <segment id="47">A banda Sem Retoque toca todas as sextas</segment>
    <segment id="48">, sempre com convidados especiais</segment>
    <segment id="49">, no espaço Língua de Prata</segment>
    <segment id="50">, Itapuã</segment>
    <segment id="51">, a partir das 21H.</segment>
    <segment id="52">Entrada: R$ 10.</segment>
    <segment id="53">Depois</segment>
    <segment id="54">, a galera embarca para agitar o interior do estado.</segment>
    <segment id="55">Dia 30 tem show em Ubaitaba.</segment>
    <segment id="56">Em seguida</segment>
    <segment id="57">, a banda continua a viagem para Laje</segment>
    <segment id="58">, onde fará uma festa na praça principal.</segment>
    <segment id="59">A cidade pode apostar que terá um feriado do Dia do Trabalhador inesquecível!</segment>
  </rst>
</analysis>