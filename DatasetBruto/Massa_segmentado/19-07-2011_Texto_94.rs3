  <rst>
    <segment id="1">Bocão abriu espaço para kelly
Apresentador diz que não era ligado a dançarina</segment>
    <segment id="2">Em entrevista</segment>
    <segment id="3">, em abril</segment>
    <segment id="4">, ao programa “Se liga Bocão!</segment>
    <segment id="5">”</segment>
    <segment id="6">,  Kelly Cyclone negou envolvimento com o tráfico.</segment>
    <segment id="7">Ela estava acompanhada da mãe</segment>
    <segment id="8">, Cida Sales</segment>
    <segment id="9">, ex-vereadora de Lauro de Freitas</segment>
    <segment id="10">, e revelou o plano de também</segment>
    <segment id="11">sese candidatar ao posto</segment>
    <segment id="12">, masmas não chegou a</segment>
    <segment id="13">sese filiar.</segment>
    <segment id="14">A jovem disse que sua bandeira seria o combate às drogas.</segment>
    <segment id="15">“</segment>
    <segment id="16">A morte dela é lamentável.</segment>
    <segment id="17">Não tinha vínculo com Kelly</segment>
    <segment id="18">, apenas dei oportunidade para ela falar  no programa”</segment>
    <segment id="19">, frisou o apresentador Zé Eduardo (o Bocão)</segment>
  </rst>
