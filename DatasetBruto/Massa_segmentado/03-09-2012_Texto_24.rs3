  <rst>
    <segment id="1">Artesanato sempre ГѓВ© uma boa opГѓВ§ГѓВЈo!</segment>
    <segment id="2">Cursos e feiras de trabalhos desse gГѓВЄnero podem ser uma chance de faturar uma grana</segment>
    <segment id="3">Quem deseja faturar uma renda com arte manual deve aproveitar  os cursos de artesanato oferecidos por algumas  instituiГѓВ§ГѓВµes na cidade.</segment>
    <segment id="4">A principal delas ГѓВ© o Instituto de Artesanato Visconde de MauГѓВЎ</segment>
    <segment id="5">, que alГѓВ©m de oferecer cursos em diversas modalidades</segment>
    <segment id="6">, realiza feiras nos fins de semaque comercializam  trabalhos artesanais.</segment>
    <segment id="7">O instituto sГѓВі abrirГѓВЎ novas turmas no prГѓВіximo ano</segment>
    <segment id="8">, no entanto</segment>
    <segment id="9">, quem jГѓВЎ desenvolve peГѓВ§as artesanais pode</segment>
    <segment id="10">sese cadastrar na feira DelГѓВ­cias do Porto</segment>
    <segment id="11">, que oc orre toda sexta-feira no Porto da Barra e nГѓВЈo tem prazo para terminar.</segment>
    <segment id="12">Dedicar-</segment>
    <segment id="13">sese ao artesanato era um sonho de adolescГѓВЄncia que Edna Castro</segment>
    <segment id="14">, 57, estГѓВЎ realizando no Instituto MauГѓВЎ.</segment>
    <segment id="15">Ela mora em Dias DГўв‚¬в„ўГѓВЎvila</segment>
    <segment id="16">, a 56 Km de Salvador</segment>
    <segment id="17">, masmas faz questГѓВЈo de  ir ГѓВ s aulas de cerГѓВўmica escultГѓВіrica todas as terГѓВ§as e quintas.</segment>
    <segment id="18">A instituiГѓВ§ГѓВЈo oferece tambГѓВ©m aulas de tecelagem</segment>
    <segment id="19">, arte em retalho</segment>
    <segment id="20">, bordado a mГѓВЈo</segment>
    <segment id="21">, pintura de tecido</segment>
    <segment id="22">, bordado ГѓВ  mГѓВЎquina e cerГѓВўmica no torno.</segment>
    <segment id="23">De acordo com Arnaldo Filardi</segment>
    <segment id="24">, coordenador dos cursos no Pelourinho</segment>
    <segment id="25">, algumas pessoas acabam descobrindo que tГѓВЄm dom para a arte apenas no decorrer do curso.</segment>
    <segment id="26">Com Gleidson dos Santos</segment>
    <segment id="27">, a situaГѓВ§ГѓВЈo foi parecida.</segment>
    <segment id="28">Ele acabou descobrindo por meio de um curso de decoraГѓВ§ГѓВЈo de sandГѓВЎlias</segment>
    <segment id="29">, na Casa do Trabalhador</segment>
    <segment id="30">, em Cajazeiras</segment>
    <segment id="31">,  uma oportunidade de ganhar uma grana extra.</segment>
    <segment id="32">Hoje,  aproveita as horas vagas para vender as sandГѓВЎlias decoradas na praia de ItapuГѓВЈ e complementar a renda.</segment>
    <segment id="33">Outras instituiГѓВ§ГѓВµes</segment>
    <segment id="34">, como</segment>
    <segment id="35">como o Centro de ProfissionalizaГѓВ§ГѓВЈo da Mulher (Ceprom) e o Senac</segment>
    <segment id="36">, tambГѓВ©m oferecem cursos de artesanato gratuitos.</segment>
    <segment id="37">O ideal ГѓВ© entrar em contato e ficar atento</segment>
    <segment id="38">ГѓВ  abertura de novas vagas.</segment>
    <segment id="39">Comercialize seus trabalhos</segment>
    <segment id="40">A partir do mГѓВЄs de setembro</segment>
    <segment id="41">,  novas feiras de artesanato serГѓВЈo promovidas pelo Instituto MauГѓВЎ</segment>
    <segment id="42">, no Jardim dos Namorados.</segment>
    <segment id="43">Para participar</segment>
    <segment id="44">, basta fazer gratuitamente a carteira de identidade profissional do artesГѓВЈo no Largo do Porto da Barra</segment>
    <segment id="45">, nГ‚Вє 2</segment>
    <segment id="46">, 4Г‚Вє andar</segment>
    <segment id="47">, na  sede da Barra.</segment>
    <segment id="48">Todo domingo</segment>
    <segment id="49">ГѓВ© possГѓВ­vel conferir tambГѓВ©m as feiras do Parque de PituaГѓВ§u</segment>
    <segment id="50">, onde sГѓВЈo comercializados trabalhos artesanais.</segment>
    <segment id="51">A feira acontece das 7h</segment>
    <segment id="52">ГѓВ s 19hs e expГѓВµe produtos</segment>
    <segment id="53">comocomo</segment>
    <segment id="54">, bolsas e vasГѓВ­lias decoradas</segment>
    <segment id="55">, toalhas bordadas e tapeГѓВ§aria</segment>
    <segment id="56">, entre outros.</segment>
