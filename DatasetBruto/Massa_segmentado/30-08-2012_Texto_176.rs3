  <rst>
    <segment id="1">Homem 횄짤 baleado em saidinha banc횄징ria</segment>
    <segment id="2">A pol횄짯cia ainda n횄짙o tem informa횄짠횄쨉es sobre os homens que teriam realizado o assalto</segment>
    <segment id="3">O aposentado Nilo Batista dos Santos</segment>
    <segment id="4">, de 63 anos</segment>
    <segment id="5">, foi baleado no final da manh횄짙 desta quarta-feira</segment>
    <segment id="6">, 29, em uma suposta saidinha banc횄징ria em S횄짙o Caetano</segment>
    <segment id="7">, bairro perif횄짤rico de Salvador.</segment>
    <segment id="8">De acordo com a 4횂짧 Delegacia Territorial (DT)</segment>
    <segment id="9">, Nilo dos Santos</segment>
    <segment id="10">, que estava acompanhado da esposa</segment>
    <segment id="11">, havia sacodo cerda de R$ 800 no banco Ita횄쨘 do bairro e</segment>
    <segment id="12">, ap횄쨀s sair da ag횄짧ncia</segment>
    <segment id="13">, entrou em uma loja de eletrodom횄짤sticos.</segment>
    <segment id="14">Ao sair do estabelecimento</segment>
    <segment id="15">, Nilo foi surpreendido por dois homens em uma moto.</segment>
    <segment id="16">Ainda segundo a pol횄짯cia</segment>
    <segment id="17">, um dos bandidos entrou na porta traseira do ve횄짯culo e anunciou o assalto.</segment>
    <segment id="18">O aposentado teria</segment>
    <segment id="19">sese negado a entregar o dinheiro e foi baleado nas costas.</segment>
    <segment id="20">Os criminosos n횄짙o conseguiram levar o dinheiro</segment>
    <segment id="21">, masmas roubaram o celular da v횄짯tima.</segment>
    <segment id="22">Nilo dos Santos foi socorrido por uma ambul횄짖ncia do Servi횄짠o M횄쨀vel de Urg횄짧ncia (Samu) e encaminhado para o Hospital Geral do Estado (HGE)</segment>
    <segment id="23">, ainda n횄짙o h횄징 informa횄짠횄쨉es sobre o seu estado de sa횄쨘de.</segment>
    <segment id="24">A pol횄짯cia ainda n횄짙o tem informa횄짠횄쨉es sobre os homens que teriam realizado o assalto.</segment>
    <segment id="25">O crime est횄징 sendo investigado pela  4횂짧 DT.</segment>
  </rst>
