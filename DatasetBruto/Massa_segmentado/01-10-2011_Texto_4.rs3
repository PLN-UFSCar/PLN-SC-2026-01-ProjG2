  <rst>
    <segment id="1">Flamengo enfrenta o São Paulo neste domingo</segment>
    <segment id="2">, no Morumbi</segment>
    <segment id="3">Na véspera do importante jogo deste domingo contra o São Paulo</segment>
    <segment id="4">, às 16h</segment>
    <segment id="5">, no Morumbi</segment>
    <segment id="6">, o Flamengo viveu inesperada crise fora de campo.</segment>
    <segment id="7">Após ter discutido</segment>
    <segment id="8">, na sexta-feira</segment>
    <segment id="9">, com o diretor-executivo de futebol</segment>
    <segment id="10">, Luiz Augusto Veloso</segment>
    <segment id="11">, o gerente de futebol</segment>
    <segment id="12">, Isaías Tinoco</segment>
    <segment id="13">, não compareceu ao treino de sábado pela manhã</segment>
    <segment id="14">, no Ninho do Urubu</segment>
    <segment id="15">, em Vargem Grande</segment>
    <segment id="16">, nem viajou com a delegação para São Paulo</segment>
    <segment id="17">, como</segment>
    <segment id="18">como costuma fazer em todos os jogos fora de casa.</segment>
    <segment id="19">A ausência alimenta a hipótese de que ele estaria de saída do clube.</segment>
    <segment id="20">A presidente Patrícia Amorim decidiu que só procurará Isaías segunda-feira.</segment>
    <segment id="21">No treino no Ninho do Urubu</segment>
    <segment id="22">, a dirigente conversou com Luiz Augusto Veloso e foi informada de que o motivo da briga não tem relação com o trabalho de ambos no Departamento de Futebol.</segment>
    <segment id="23">Isaías Tinoco é padrinho da filha de Luiz Augusto Veloso e o forte desentendimento teria ocorrido por motivos pessoais.</segment>
    <segment id="24">O sábado rubro-negro</segment>
    <segment id="25">, porém</segment>
    <segment id="26">porém, não foi apenas de problemas.</segment>
    <segment id="27">O volante Willians</segment>
    <segment id="28">, que havia sofrido uma torção no joelho esquerdo na última sexta-feira</segment>
    <segment id="29">, participou normalmente do treino recreativo e foi confirmado para a partida contra o São Paulo.</segment>
    <segment id="30">Enfrentar um dos principais candidatos ao título</segment>
    <segment id="31">, fora de casa</segment>
    <segment id="32">, com o rival super motivado pela reestreia do ídolo Luís Fabiano pode ser o termômetro ideal para o Flamengo mostrar</segment>
    <segment id="33">sese já deixou para trás a má fase dos dez jogos sem vitória ou</segment>
    <segment id="34">sese o triunfo sobre o América-MG</segment>
    <segment id="35">, no último sábado</segment>
    <segment id="36">, foi um suspiro.</segment>
    <segment id="37">A torcida tricolor esgotou os 63.939 ingressos.</segment>
    <segment id="38">Se a euforia predomina no lado paulista</segment>
    <segment id="39">, o Flamengo tenta tirar um caráter de decisão da partida.</segment>
    <segment id="40">Com a sequência ruim que o deixou a oito pontos do líder Vasco</segment>
    <segment id="41">, o rubro-negro adotou a vaga na Libertadores do ano que vem</segment>
    <segment id="42">comocomo o primeiro objetivo.</segment>
    <segment id="43">Depois do São Paulo</segment>
    <segment id="44">, há os clássicos contra o Fluminense e o Palmeiras</segment>
    <segment id="45">, rivais pela vaga</segment>
    <segment id="46">, ambos no Engenhão.</segment>
    <segment id="47">Por isso</segment>
    <segment id="48">, Vanderlei Luxemburgo diz que o jogo de hoje não é tão decisivo.</segment>
    <segment id="49">SÃO PAULO X FLAMENGO

São Paulo: Rogério Ceni</segment>
    <segment id="50">, Wellington</segment>
    <segment id="51">, João Filipe</segment>
    <segment id="52">, Rhodolfo e Juan</segment>
    <segment id="53">; Denílson</segment>
    <segment id="54">, Carlinhos Paraíba</segment>
    <segment id="55">, Casemiro e Lucas</segment>
    <segment id="56">; Dagoberto e Luís Fabiano.

Flamengo: Felipe</segment>
    <segment id="57">, Galhardo</segment>
    <segment id="58">, Alex Silva</segment>
    <segment id="59">, Welinton e Júnior César</segment>
    <segment id="60">; Aírton</segment>
    <segment id="61">, Willians</segment>
    <segment id="62">, Renato e Thiago Neves</segment>
    <segment id="63">;</segment>
    <segment id="64">Ronaldinho Gaúcho e Deivid.

Juiz: Fabrício Neves Correia (RS).</segment>
  </rst>
