  <rst>
    <segment id="1">Rebeldes em Salvador</segment>
    <segment id="2">Megashow leva os fãs à loucura no Wet´n Wild
Mesmo antes de o grupo que faz sucesso na tela da TV Record subir ao palco</segment>
    <segment id="3">, o público já demonstrava muita emoção.</segment>
    <segment id="4">“Eu não perco um capítulo da novela.</segment>
    <segment id="5">Eu amo eles e até chorei quando entrei”</segment>
    <segment id="6">, disse João Gabriel</segment>
    <segment id="7">, de 11 anos</segment>
    <segment id="8">, que assistiu o show em uma cadeira de rodas devido a uma disfunção muscular que impede o movimento das pernas.</segment>
    <segment id="9">Para a mãe dele</segment>
    <segment id="10">, Simone</segment>
    <segment id="11">, valeu o esforço para ver o filho feliz.</segment>
    <segment id="12">“Vim de lá de Simões Filho com ele desde cedo para garantir um bom lugar.</segment>
    <segment id="13">É muito bom ver ele assim tão contente”</segment>
    <segment id="14">, disse ela</segment>
    <segment id="15">, emocionada.</segment>
    <segment id="16">Quando o momento tão esperado chegou</segment>
    <segment id="17">, só se</segment>
    <segment id="18">se ouvia gritos histéricos.</segment>
    <segment id="19">O grupo entrou no palco ao som da canção “Rebelde</segment>
    <segment id="20">Pra Sempre”.</segment>
    <segment id="21">Os fãs foram à loucura!</segment>
  </rst>
</analysis>