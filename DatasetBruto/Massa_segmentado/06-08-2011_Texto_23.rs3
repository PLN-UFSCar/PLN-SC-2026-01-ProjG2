  <rst>
    <segment id="1">Em Sete Lagoas</segment>
    <segment id="2">, Flu vai em busca de sequência inédita
Depois da saída de Antônio Lopes</segment>
    <segment id="3">, o América estreará novo técnico</segment>
    <segment id="4">, Givanildo.</segment>
    <segment id="5">A situação do time é tão complicada que</segment>
    <segment id="6">, mesmo em</segment>
    <segment id="7">casocaso de vitória hoje</segment>
    <segment id="8">, não sairá da zona de rebaixamento.</segment>
    <segment id="9">Até agora</segment>
    <segment id="10">, o América só venceu uma partida</segment>
    <segment id="11">, logo na estreia do Brasileiro</segment>
    <segment id="12">, contra o Bahia: 1 a 0.</segment>
    <segment id="13">Mas o Fluminense tomará cuidados para evitar a armadilha em Minas Gerais.</segment>
    <segment id="14">Desfalcado de Fred</segment>
    <segment id="15">, Diguinho e Carlinhos</segment>
    <segment id="16">, o time terá nos substitutos Rafael Moura</segment>
    <segment id="17">, Fernando Bob e Júlio César a esperança de dias melhores depois da semana turbulenta.</segment>
    <segment id="18">Abel está "maravilhado"</segment>
    <segment id="19">A decisão de poupar Fred partiu da diretoria</segment>
    <segment id="20">, que não viu no jogador as condições físicas e psicológicas ideais para a partida.</segment>
    <segment id="21">Rafael Moura</segment>
    <segment id="22">, que estava ao lado do capitão no dia que foram abordados pelos torcedores</segment>
    <segment id="23">, tem a missão dos gols.</segment>
    <segment id="24">Com 14</segment>
    <segment id="25">, já ultrapassou Fred na artilharia do time na temporada.</segment>
    <segment id="26">No meio-campo</segment>
    <segment id="27">, Fernando Bob terá uma chance</segment>
    <segment id="28">comocomo titular.</segment>
    <segment id="29">Volante que costuma sair bem para o jogo</segment>
    <segment id="30">, tem o defeito de chutar pouco a gol quando aparece a oportunidade.</segment>
    <segment id="31">O próprio Abel Braga já pediu para ele ser mais ousado.</segment>
    <segment id="32">Ainda assim</segment>
    <segment id="33">, não poupa elogios para o jogador.

- Estou maravilhado com Fernando Bob - disse.</segment>
    <segment id="34">Na lateral esquerda</segment>
    <segment id="35">, a saída de Carlinhos</segment>
    <segment id="36">, suspenso</segment>
    <segment id="37">, deverá ter mais impacto.</segment>
    <segment id="38">Depois de um começo de ano irregular</segment>
    <segment id="39">, o jogador esteve bem nas duas últimas partidas.</segment>
    <segment id="40">Mas Júlio César tem treinado bem nos últimos dias e também chamou a atenção de Abel.</segment>
    <segment id="41">É a chance de o jogador</segment>
    <segment id="42">, que já foi até titular</segment>
    <segment id="43">, recuperar espaço no time.</segment>
    <segment id="44">Do outro lado do campo estará o lateral-direito Mariano</segment>
    <segment id="45">, ansioso pela terceira vitória seguida:

- É o que a gente mais precisa.</segment>
    <segment id="46">Conseguimos a segunda vitória dentro de casa.</segment>
    <segment id="47">Agora, temos de buscar fora.</segment>
    <segment id="48">Fluminense:</segment>
    <segment id="49">Diego Cavalieri</segment>
    <segment id="50">, Mariano</segment>
    <segment id="51">, Gum, Márcio Rosário e Júlio César</segment>
    <segment id="52">;</segment>
    <segment id="53">Edinho</segment>
    <segment id="54">, Fernando Bob</segment>
    <segment id="55">, Souza e Marquinho</segment>
    <segment id="56">; Rafael Sóbis e Rafael Moura.</segment>
    <segment id="57">América-MG: Neneca</segment>
    <segment id="58">; Marcos Rocha</segment>
    <segment id="59">, Otávio</segment>
    <segment id="60">, Micão e Carleto</segment>
    <segment id="61">; Dudu</segment>
    <segment id="62">, Leandro Ferreira (Fábio Júnior)</segment>
    <segment id="63">, Amaral e Rodriguinho</segment>
    <segment id="64">; Léo (Fábio Júnior) e Alessandro.</segment>
    <segment id="65">Juiz: Sandro Meira Ricci (DF-Fifa).</segment>
  </rst>
