  <rst>
    <segment id="1">Poderosa</segment>
    <segment id="2">, gata abre o jogo e conta tudo</segment>
    <segment id="3">O público gostou tanto de Rosiane em “</segment>
    <segment id="4">O Trio”</segment>
    <segment id="5">, da TV Aratu</segment>
    <segment id="6">, que levou-a à vitória</segment>
    <segment id="7">O que não falta na carioca mais baiana do pedaço é talento.</segment>
    <segment id="8">Rosiane Pinheiro nasceu há 37 anos em Niterói</segment>
    <segment id="9">, município do estado do Rio de Janeiro</segment>
    <segment id="10">, masmas aos dois anos aportou em Salvador</segment>
    <segment id="11">, onde aprendeu a gingar.

E que gingado!</segment>
    <segment id="12">Entretanto</segment>
    <segment id="13">, a vida de artista não começou com a dança.</segment>
    <segment id="14">“Aos 14 fiz aula de canto e trabalhei</segment>
    <segment id="15">comocomo vocalista em uma banda de axé</segment>
    <segment id="16">, a Água de Cheiro”</segment>
    <segment id="17">, lembra.</segment>
    <segment id="18">Logo depois</segment>
    <segment id="19">, por conta da altura</segment>
    <segment id="20">, foi parar nas passarelas e ganhou concursos de beleza regionais.</segment>
    <segment id="21">Até que</segment>
    <segment id="22">, em 2007</segment>
    <segment id="23">, a gata mostrou seus 1</segment>
    <segment id="24">,70m de pura sensualidade nas páginas da revista “Playboy”.</segment>
    <segment id="25">Arrasou e foi eleita</segment>
    <segment id="26">, na época</segment>
    <segment id="27">, como</segment>
    <segment id="28">como musa da capa.</segment>
    <segment id="29">O reconhecimento na carreira artística veio mesmo em 2008</segment>
    <segment id="30">, quando os marmanjos de plantão puderam conferir as generosas curvas de Rosiane nos palcos do pagode baiano.</segment>
    <segment id="31">“Quando entrei na banda Gang do Samba minha vida mudou e passei a ser mais reconhecida”</segment>
    <segment id="32">, revela.</segment>
    <segment id="33">O sucesso nos palcos levou-a a</segment>
    <segment id="34">sese arriscar e mostrar seu lado atriz.</segment>
    <segment id="35">Na TV, a gata participou de programas da Globo</segment>
    <segment id="36">, como</segment>
    <segment id="37">como o “Casseta &amp; Planeta”.</segment>
    <segment id="38">Também deu seu ar da graça na minissérie global “Pastores da Noite” e</segment>
    <segment id="39">, por último</segment>
    <segment id="40">, contracenou com a atriz Luiza Tomé no longa-metragem “Terra Payayá”</segment>
    <segment id="41">, gravado em Jacobina</segment>
    <segment id="42">, interior da Bahia.</segment>
    <segment id="43">Este último poderá ser conferido em agosto</segment>
    <segment id="44">, quando chega às telonas.</segment>
    <segment id="45">E não para por aí.</segment>
    <segment id="46">Inquieta</segment>
    <segment id="47">, ela voltou a cantar e formou</segment>
    <segment id="48">, em parceria com o marido</segment>
    <segment id="49">, a banda de pagode</segment>
    <segment id="50">O Bumm.</segment>
    <segment id="51">“Mas continuo aberta às propostas para atuar”</segment>
    <segment id="52">, revela</segment>
    <segment id="53">, empolgada</segment>
    <segment id="54">, a gatíssima.

Evangélica</segment>
    <segment id="55">, a moça conta que</segment>
    <segment id="56">sese encontrou na religião e hoje está mais tranquila e feliz.</segment>
    <segment id="57">“Sou uma mulher realizada”</segment>
    <segment id="58">, comemora.</segment>
    <segment id="59">Tudo o que Rosiane gosta

FETICHE - Nada melhor do que o alto-mar.</segment>
    <segment id="60">“Sonho em ficar em um iate chiquérrimo</segment>
    <segment id="61">, no meio do oceano.</segment>
    <segment id="62">Tem que ter muita fruta e leite condensado</segment>
    <segment id="63">, para brincar”.</segment>
    <segment id="64">TIPO DE HOMEM -</segment>
    <segment id="65">Nada de músculos.</segment>
    <segment id="66">A atração rola por carecas e magros.</segment>
    <segment id="67">“Mas tem de ser alto”.</segment>
    <segment id="68">PERFUME - De cheiro adocicado para a noite e fragrância cítrica de dia.

BRINQUEDINHOS -  Apimentam a transa.</segment>
    <segment id="69">“Adoro me fantasiar</segment>
    <segment id="70">, usar umas bolinhas que derretem e dados que dizem qual posição devemos fazer”.</segment>
    <segment id="71">ONDE NAMORAR -  Na cama!

NO SEXO -</segment>
    <segment id="72">Aposta nas preliminares.</segment>
    <segment id="73">“Preciso ficar relaxada antes do ato”.</segment>
  </rst>
</analysis>