  <rst>
    <segment id="1">Polﾃδｭcia ligada nos comparsas de Flor
Soldado do lﾃδｭder do trﾃδ｡fico no Bairro da Paz ﾃδｩ preso.</segment>
    <segment id="2">Chefﾃδ｣o nﾃδ｣o tem dado as caras</segment>
    <segment id="3">O lﾃδｭder do trﾃδ｡fico no Bairro da Paz</segment>
    <segment id="4">, Florisvaldo dos Santos Costa</segment>
    <segment id="5">, 23 anos</segment>
    <segment id="6">, o Flor</segment>
    <segment id="7">, nﾃδ｣o tem dado as caras por lﾃδ｡ hﾃδ｡ cerca de dois meses.</segment>
    <segment id="8">Mas, anteontem ﾃδ tarde</segment>
    <segment id="9">, investigadores da 12ﾃつｪ Delegacia Territorial (Itapuﾃδ｣) prenderam um de seus soldados: Samuel Santana da Silva</segment>
    <segment id="10">, 21 anos.</segment>
    <segment id="11">Ele  escapou</segment>
    <segment id="12">, no ﾃδｺltimo dia 27 de junho</segment>
    <segment id="13">, do cerco policial que prendeu trﾃδｪs comparsas de Flor.</segment>
    <segment id="14">Um quarto suspeito morreu em confronto.</segment>
    <segment id="15">Segundo a titular da 12ﾃつｪ DT</segment>
    <segment id="16">, Aymara Bandeira</segment>
    <segment id="17">, Samuel participava dos assassinatos praticados por Juliano Costa Menezes</segment>
    <segment id="18">, 31, o Brunﾃδ｣o</segment>
    <segment id="19">, matador da gangue de Flor.</segment>
    <segment id="20">ﾃ｢竄ｬﾅ鄭s mortes eram com requintes de crueldade.</segment>
    <segment id="21">Brunﾃδ｣o decepava os membros das vﾃδｭtimasﾃ｢竄ｬ</segment>
    <segment id="22">, conta a delegada.</segment>
    <segment id="23">ﾃ｢竄ｬﾅ滴ﾃδ｡ um cemitﾃδｩrio clandestino no Bairro da Paz</segment>
    <segment id="24">, masmas ainda nﾃδ｣o encontramosﾃ｢竄ｬ</segment>
    <segment id="25">, completa.</segment>
    <segment id="26">Brunﾃδ｣o foi preso em junho junto com Cristiano Cﾃδ｢ndido dos Santos</segment>
    <segment id="27">, 33, o Chocho</segment>
    <segment id="28">, e Pablo dos Santos Barbosa</segment>
    <segment id="29">, 26.</segment>
    <segment id="30">Reinaldo Ramﾃδ｡rio Alves Santos Filho</segment>
    <segment id="31">, 21, o Nanau</segment>
    <segment id="32">, morreu na mesma operaﾃδｧﾃδ｣o durante troca de tiros.</segment>
    <segment id="33">Samuel disse  nﾃδ｣o pertencer mais ao bando de Flor.</segment>
    <segment id="34">Ele disse que estava com o grupo hﾃδ｡ dois meses chamando o pessoal para ir ﾃδ igreja.</segment>
    <segment id="35">Sﾃδｳ baratino</segment>
    <segment id="36">Para Aymara Bandeira</segment>
    <segment id="37">, o argumento de Samuel de que nﾃδ｣o ﾃδｩ mais do bando de Flor nﾃδ｣o convence.</segment>
    <segment id="38">ﾃ｢竄ｬﾅ摘le acabou entrando em contradiﾃδｧﾃδ｣o.</segment>
    <segment id="39">Uma hora ele disse que entrou na igreja hﾃδ｡ trﾃδｪs semanas</segment>
    <segment id="40">, masmas</segment>
    <segment id="41">, quando questionado sobre o que fazia com os comparsas no mﾃδｪs de junho</segment>
    <segment id="42">, ele disse que estava chamando o pessoal para ir ﾃδ igrejaﾃ｢竄ｬ</segment>
    <segment id="43">, explica.</segment>
    <segment id="44">Samuel foi preso com 25 pedras crack</segment>
    <segment id="45">, seis papelotes de cocaﾃδｭna e 29 trouxinhas de maconha</segment>
    <segment id="46">, alﾃδｩm de seis muniﾃδｧﾃδｵes de revﾃδｳlver calibre 38.</segment>
    <segment id="47">Flor tem um mandado de prisﾃδ｣o em aberto por homicﾃδｭdio.</segment>
    <segment id="48">Hﾃδ｡ um boato de que ele estﾃδ｡ escondido em Muritiba (a 114 km de Salvador).</segment>
