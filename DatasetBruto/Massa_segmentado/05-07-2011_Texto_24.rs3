  <rst>
    <segment id="1">Contra a baixaria</segment>
    <segment id="2">Projeto de Lei quer acabar com os pagodes polêmicos</segment>
    <segment id="3">“Mulher é igual a lata</segment>
    <segment id="4">, um chuta e o outro cata”.</segment>
    <segment id="5">Na Bahia</segment>
    <segment id="6">, composições musicais</segment>
    <segment id="7">comocomo essa</segment>
    <segment id="8">, da banda Black Style</segment>
    <segment id="9">, podem estar com os dias contados.</segment>
    <segment id="10">Os músicos que</segment>
    <segment id="11">, em suas letras ou coreografias</segment>
    <segment id="12">, incentivarem a violência ou expuserem as mulheres em situação de constrangimento poderão não ser contratados com recursos públicos.</segment>
    <segment id="13">Isso é o que propõe o Projeto de Lei da deputada Luiza Maia</segment>
    <segment id="14">, que tramita na Assembleia Legislativa.</segment>
    <segment id="15">Mas a iniciativa</segment>
    <segment id="16">, apoiada por toda a bancada feminina</segment>
    <segment id="17">, vem encontrando resistência de alguns segmentos do pagode baiano.</segment>
    <segment id="18">“Se isso passar</segment>
    <segment id="19">, vai tirar a comida da mesa de muitos músicos de origem pobre.</segment>
    <segment id="20">O pagode é o que gera renda na periferia”</segment>
    <segment id="21">, diz a vereadora Léo Kret do Brasil</segment>
    <segment id="22">, que  ainda é dançarina na banda Kapa Fixa.</segment>
    <segment id="23">O músico Robsão</segment>
    <segment id="24">, do grupo Black Style</segment>
    <segment id="25">, autor dos hits “Vaza Canhão” e “Perereca Pisca”</segment>
    <segment id="26">, não concorda com a lei.</segment>
    <segment id="27">“</segment>
    <segment id="28">A gente brinca com  situações de nosso cotidiano.</segment>
    <segment id="29">Talvez seja por isso que nossas músicas são muito consumidas</segment>
    <segment id="30">, inclusive pelas mulheres”</segment>
    <segment id="31">, diz.</segment>
    <segment id="32">Já na opinião da deputada Luiza Maia</segment>
    <segment id="33">, algumas letras de pagode abreviam a mulher apenas a “peito</segment>
    <segment id="34">, bunda e genitália”.</segment>
    <segment id="35">“</segment>
    <segment id="36">O poder público não pode financiar a reprodução do preconceito e a violência contra as mulheres”</segment>
    <segment id="37">, argumenta.</segment>
    <segment id="38">Segundo ela</segment>
    <segment id="39">, é a naturalização de costumes impróprios para a infância que constrói “mulheres também machistas”.
Falcão</segment>
    <segment id="40">, vocalista da banda Rapina</segment>
    <segment id="41">, admite que é preciso repensar as referências que fazem à figura feminina.</segment>
    <segment id="42">“</segment>
    <segment id="43">O pagode está muito além do rótulo de baixaria e sexualidade”</segment>
    <segment id="44">, defende.</segment>
  </rst>
</analysis>