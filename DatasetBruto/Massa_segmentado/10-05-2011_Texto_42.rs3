  <rst>
    <segment id="1">Andrea Rincón</segment>
    <segment id="2">Gata é o amuleto da sorte do craque argentino Messi</segment>
    <segment id="3">A modelo colombiana Andrea Rincón</segment>
    <segment id="4">, que teve um</segment>
    <segment id="5">casocaso com Messi no ano passado antes do amistoso entre Argentina e Espanha</segment>
    <segment id="6">, afirma que é o amuleto da sorte do craque.</segment>
    <segment id="7">“Ele me disse que eu trazia sorte</segment>
    <segment id="8">, me chamou antes da partida e depois fez um gol”</segment>
    <segment id="9">, revelou.</segment>
  </rst>
