  <rst>
    <segment id="1">Preços de produtos sobem</segment>
    <segment id="2">, masmas consumidor gasta mais
Preços de produtos sobem</segment>
    <segment id="3">, masmas consumidor gasta mais
RIO - Num ano em que a inflação não deu trégua aos consumidores</segment>
    <segment id="4">, muitos</segment>
    <segment id="5">sese queixaram do aumento dos preços</segment>
    <segment id="6">, principalmente nos brinquedos</segment>
    <segment id="7">, como</segment>
    <segment id="8">como atestou Eliane D'Ávila</segment>
    <segment id="9">, ao comprar o presente de sua netinha Luiza.</segment>
    <segment id="10">Mas os preços mais altos não afugentaram os consumidores</segment>
    <segment id="11">, que, com suas listas de presentes nas mãos</segment>
    <segment id="12">, foram ontem às compras e encheram os shoppings.</segment>
    <segment id="13">Pauliran da Costa e Silva Filho e Dândara Sily fizeram uma pausa para almoçar no Shopping Nova América</segment>
    <segment id="14">, pois</segment>
    <segment id="15">pois, segundo ela</segment>
    <segment id="16">, ainda faltava mais da metade das compras.

- Este ano</segment>
    <segment id="17">, com certeza vou comprar mais do que o ano passado</segment>
    <segment id="18">porque</segment>
    <segment id="19">porque virei engenheiro e fui promovido.</segment>
    <segment id="20">Com mais dinheiro no bolso</segment>
    <segment id="21">, vou aproveitar.</segment>
    <segment id="22">Foi a primeira vez que viemos neste shopping e estamos gostando dos preços.</segment>
    <segment id="23">Tem várias opções e os preços são bons - afirmou Pauliran Filho.</segment>
    <segment id="24">Na loja Taco</segment>
    <segment id="25">, Cosme Henrique Teixeira e Isabella Teixeira também estavam esperando gastar mais este ano:

- Agora temos a Luiza e o presente mais caro foi o dela.</segment>
    <segment id="26">Ao todo</segment>
    <segment id="27">, vamos gastar mais de R$ 300</segment>
    <segment id="28">, masmas a média dos presentes é de R$ 60.</segment>
    <segment id="29">Eu sou mais chato</segment>
    <segment id="30">, acho tudo muito caro</segment>
    <segment id="31">, mais do que a minha esposa.</segment>
    <segment id="32">A partir de hoje</segment>
    <segment id="33">, lojas abertas até meia-noite

Luciana Gomes</segment>
    <segment id="34">, gerente da lojas de calçados Conexão Original</segment>
    <segment id="35">, afirma que o movimento vem aumentando dia a dia</segment>
    <segment id="36">, masmas sua grande esperança está depositada na semana que vem</segment>
    <segment id="37">, quando muitos shoppings passam a funcionar até meia-noite.

- As sandálias Havaianas e as Crocs são as mais vendidas.</segment>
    <segment id="38">A média de vendas por cliente é de R$ 200.</segment>
    <segment id="39">Mas tenho certeza de que</segment>
    <segment id="40">, na semana que vem</segment>
    <segment id="41">, com a loja ficando aberta até meia noite</segment>
    <segment id="42">, vamos vender mais - afirma Luciana.</segment>
    <segment id="43">Eliane D'Ávila</segment>
    <segment id="44">, que lanchava em um intervalo entre as compras</segment>
    <segment id="45">, reclamou dos preços dos brinquedos.</segment>
    <segment id="46">A neta</segment>
    <segment id="47">, Luiza</segment>
    <segment id="48">, de 4 anos</segment>
    <segment id="49">, encomendou ao Papai Noel uma boneca Baby Alive.

- Tem que pesquisar</segment>
    <segment id="50">, eu encontrei diferença de R$ 8 nas sandálias Havaianas - afirmou Eliane.</segment>
    <segment id="51">Já para sua filha Liliane</segment>
    <segment id="52">, todos os preços estão mais altos este ano.</segment>
    <segment id="53">No Ponto Frio do Shopping Nova América</segment>
    <segment id="54">, o produto campeão de venda é a TV de 40 polegadas 3D.</segment>
    <segment id="55">Segundo o gerente</segment>
    <segment id="56">, eram vendidas cerca de duas unidades por dia.</segment>
    <segment id="57">Em dezembro</segment>
    <segment id="58">, essa média subiu para 15 unidades por dia.</segment>
    <segment id="59">Para não deixar consumidores decepcionados</segment>
    <segment id="60">, a loja aumentou o prazo de entrega</segment>
    <segment id="61">, que geralmente é de três a cinco dias</segment>
    <segment id="62">, para dez dias.</segment>
    <segment id="63">No sábado à tarde</segment>
    <segment id="64">, muitos cariocas saíram da praia direto para o shopping e</segment>
    <segment id="65">, ontem</segment>
    <segment id="66">, com o tempo fechado</segment>
    <segment id="67">, as lojas voltaram a ficar lotadas.</segment>
    <segment id="68">Segundo Daniela Paladini</segment>
    <segment id="69">, superintendente do Botafogo Praia Shopping</segment>
    <segment id="70">, o fluxo de clientes a partir das 13h está cada vez maior em lojas</segment>
    <segment id="71">comocomo Arezzo</segment>
    <segment id="72">, Empório Body Store</segment>
    <segment id="73">, O Boticário e outras:

- O movimento neste fim de semana foi 23% maior que na semana anterior.</segment>
    <segment id="74">Artigos eletrônicos</segment>
    <segment id="75">, entre eles</segment>
    <segment id="76">, tablets</segment>
    <segment id="77">, iPods e iPhones</segment>
    <segment id="78">, calçados e perfumes lideram as listas.</segment>
    <segment id="79">O Passeio Shopping</segment>
    <segment id="80">, em Campo Grande</segment>
    <segment id="81">, espera ter tido neste fim de semana um aumento em 17% nas vendas</segment>
    <segment id="82">, e um público 13% maior para as compras de Natal.</segment>
    <segment id="83">Já a estimativa do Santa Cruz Shopping é de que tanto o fluxo de pessoas quanto as vendas aumentem em 15% no sábado e domingo.</segment>
    <segment id="84">O sol quente no início do sábado encheu o Saara anteontem</segment>
    <segment id="85">, que, segundo seu presidente</segment>
    <segment id="86">, Ênio Bittencourt</segment>
    <segment id="87">, reuniu mais de um milhão de pessoas.</segment>
    <segment id="88">Lá, o tíquete médio das compras não superava os R$ 40.</segment>
    <segment id="89">Evandro da Silva Conceição calculava gastar R$ 75 no presente de seus três filhos:

- Têm várias opções e os preços estão bons por aqui.</segment>
  </rst>
