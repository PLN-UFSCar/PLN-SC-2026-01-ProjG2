  <rst>
    <segment id="1">Silvio Santos quer a sua felicidade</segment>
    <segment id="2">Com os prejuízos causados pelo Panamericano</segment>
    <segment id="3">, o grupo precisou reforçar o caixa</segment>
    <segment id="4">O primeiro sinal negativo foi o escândalo envolvendo seu ex-banco</segment>
    <segment id="5">, o Panamericano</segment>
    <segment id="6">, e ontem</segment>
    <segment id="7">, o empresário e apresentador de televisão</segment>
    <segment id="8">Silvio Santos  anunciou que vai vender</segment>
    <segment id="9">, dentro de 60 a 90 dias</segment>
    <segment id="10">, o Baú da Felicidade</segment>
    <segment id="11">, uma rede com 137 lojas em São Paulo e no Paraná.</segment>
    <segment id="12">A venda de algumas das 30 companhias do grupo é uma tentativa de reestruturar os negócios.</segment>
    <segment id="13">“</segment>
    <segment id="14">O nosso plano de reestruturação inclui a venda dessas duas empresas no curto prazo.</segment>
    <segment id="15">Queremos focar em apenas três segmentos que nos interessam”</segment>
    <segment id="16">, afirmou o vice-presidente do grupo Silvio Santos</segment>
    <segment id="17">, Lásaro do Carmo.</segment>
    <segment id="18">Com a saída da rede Baú</segment>
    <segment id="19">, o grupo pretende alcançar uma receita de R$ 2</segment>
    <segment id="20">,3 bilhões em 2011.</segment>
    <segment id="21">O patrão só vai fortalecer os negócios da Jequiti Cosméticos</segment>
    <segment id="22">, das 14 emissoras de televisão</segment>
    <segment id="23">, entre elas o SBT</segment>
    <segment id="24">, e da Liderança Capitalização</segment>
    <segment id="25">, responsável pela Tele Sena.</segment>
    <segment id="26">O Baú da Felicidade</segment>
    <segment id="27">, que foi um dos principais negócios de Silvio Santos</segment>
    <segment id="28">, hoje é uma empresa que dá preju.</segment>
    <segment id="29">O empresário assumiu o Baú em 1958</segment>
    <segment id="30">, antes mesmo de fundar o SBT.</segment>
    <segment id="31">A rede ficou famosa  com a venda dos “carnês do Baú”</segment>
    <segment id="32">, que permitiam que os clientes retirassem um produto na loja no fim do pagamento e participassem de sorteios.

R$ 2</segment>
    <segment id="33">,3 bilhões
é a receita que o Grupo SS pretende alcançar em 2011 com a venda do Baú</segment>
