  <rst>
    <segment id="1">Público enfrentou trânsito intenso para chegar ao Engenhão</segment>
    <segment id="2">O público que seguiu para o Estádio do Engenhão</segment>
    <segment id="3">, onde acontece o show do ex-Beatle Paul McCartney</segment>
    <segment id="4">, enfrentou trânsito intenso na Rua 24 de Maio e em outras vias de acesso ao local</segment>
    <segment id="5">, informou a Companhia de Engenharia de Tráfego do Rio de Janeiro (CET-Rio).</segment>
    <segment id="6">Segundo a central</segment>
    <segment id="7">, não há registro de acidentes.</segment>
    <segment id="8">De acordo com o Centro de Operações</segment>
    <segment id="9">, motoristas encontraram grande fluxo de veículos na Avenida Dom Hélder Câmara</segment>
    <segment id="10">, na altura do Viaduto de Pilares</segment>
    <segment id="11">, na Rua 24 de Maio</segment>
    <segment id="12">, entre as ruas Cônego Tobias e Bela Vista</segment>
    <segment id="13">, e no Viaduto Todos os Santos.</segment>
    <segment id="14">O tráfego chegou a ficar lento na Rua Aristides Caire.</segment>
    <segment id="15">Na Ponte Rio-Niterói</segment>
    <segment id="16">, o trânsito é lendo no acesso à Avenida Brasil.</segment>
    <segment id="17">Nas outras vias liberadas para o trânsito</segment>
    <segment id="18">, os motoristas não encontram dificuldades.</segment>
    <segment id="19">Para evitar possíveis congestionamentos de ônibus</segment>
    <segment id="20">, os pontos normalmente situados no entorno do estádio foram transferidos</segment>
    <segment id="21">, segundo o Centro de Operações da Prefeitura do Rio.</segment>
    <segment id="22">Trens extras com ar-condicionado partem da Central do Brasil para o Engenho de Dentro a cada meia hora.</segment>
    <segment id="23">O último saiu às 20h30</segment>
    <segment id="24">m.</segment>
    <segment id="25">A poucas horas do primeiro show do ex-Beatle Paul McCartney</segment>
    <segment id="26">, a estação de trem de Engenho de Dentro</segment>
    <segment id="27">, no subúrbio</segment>
    <segment id="28">, ficou lotada devido ao grande fluxo de pessoas a caminho do espetáculo.</segment>
    <segment id="29">Apesar disso não houve registro de tumultos</segment>
    <segment id="30">, informo a Supervia.</segment>
    <segment id="31">Paul McCartney entrou no palco com 14 minutos de atraso e começou o primeiro show no Engenhão com o clássico "Hello Goodbye"</segment>
    <segment id="32">, mantendo o setlist em relação aos shows anteriores na América Latina neste ano.</segment>
    <segment id="33">O ex-beatle chegou cedo ao estádio</segment>
    <segment id="34">, onde</segment>
    <segment id="35">, por volta das 16h</segment>
    <segment id="36">, deu início à última passagem de som no Engenhão antes do primeiro show no Rio.</segment>
    <segment id="37">Apesar de aberto somente para as 200 pessoas de um dos camarotes</segment>
    <segment id="38">, o ensaio empolgou os fãs que aguardavam ao redor de todo o estádio.</segment>
    <segment id="39">Algumas pessoas passaram a noite acampadas nas imediações do Engenhão</segment>
    <segment id="40">, a fim de garantir as melhores posições para assistir à apresentação do ex-Beatle.</segment>
  </rst>
</analysis>