  <rst>
    <segment id="1">Morto no porta-malas</segment>
    <segment id="2">Comerciante tinha a boca amarrada por uma camisa</segment>
    <segment id="3">O comerciante França Carvalho de Oliveira</segment>
    <segment id="4">, 30, foi encontrado morto no porta-malas  de um Ford Fiesta</segment>
    <segment id="5">, placa JPP-8383</segment>
    <segment id="6">, na rua das Mangueiras</segment>
    <segment id="7">, no bairro de Itinga</segment>
    <segment id="8">, em Lauro de Freitas</segment>
    <segment id="9">, na manhã de ontem.</segment>
    <segment id="10">Segundo José Araújo</segment>
    <segment id="11">, amigo da vítima</segment>
    <segment id="12">,  “Gordo”</segment>
    <segment id="13">, como</segment>
    <segment id="14">como era conhecido</segment>
    <segment id="15">, chegou em uma festa em sua residência</segment>
    <segment id="16">, por volta das 22h de sábado.</segment>
    <segment id="17">Ao perceber que seu carro havia quebrado</segment>
    <segment id="18">, pediu emprestado o veículo da mulher de Araújo   para buscar uma paquera</segment>
    <segment id="19">, afirmando que retornaria em seguida.</segment>
    <segment id="20">“Como ele demorou</segment>
    <segment id="21">, começamos a ligar e ele não atendeu.</segment>
    <segment id="22">Só viemos descobrir o que tinha acontecido após ver a notícia</segment>
    <segment id="23">,  na internet</segment>
    <segment id="24">, do carro abandonado”</segment>
    <segment id="25">, frisou o amigo.</segment>
    <segment id="26">Policias da  27ª Delegacia Territorial (DT/Itinga) informaram que o corpo estava amordaço com uma camisa e apresentava marcas de tiro na cabeça.</segment>
    <segment id="27">O caso</segment>
    <segment id="28">caso está sendo investigado pelo Departamento de Homicídios e Proteção à Pessoa (DHPP)</segment>
    <segment id="29">, masmas até o fechamento desta edição nenhuma informação foi passada.</segment>
    <segment id="30">Barulho de tiros: Moradores confirmam

Moradores da rua onde a vítima  foi encontrada</segment>
    <segment id="31">, que preferiram não</segment>
    <segment id="32">sese identificar</segment>
    <segment id="33">, disseram que por volta da meia-noite de domingo ouviram uma  forte zoada de carro</segment>
    <segment id="34">, como</segment>
    <segment id="35">como se</segment>
    <segment id="36">se estivesse atolando e</segment>
    <segment id="37">,  imediatamente</segment>
    <segment id="38">, o barulho de cinco disparos de arma de fogo.</segment>
    <segment id="39">Já Anilson Bezerra</segment>
    <segment id="40">, também morador</segment>
    <segment id="41">, afirma não ter ouvido nenhum tiro.</segment>
    <segment id="42">“</segment>
    <segment id="43">Quando eu acordei hoje pela manhã</segment>
    <segment id="44">, achei estranho este carro parado no meio da rua.</segment>
    <segment id="45">Nem olhei direito</segment>
    <segment id="46">, só sabia que deveria chamar a  polícia e liguei”.</segment>
  </rst>
</analysis>