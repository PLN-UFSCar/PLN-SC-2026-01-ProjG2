  <rst>
    <segment id="1">Gmaiúsculo: Nobel da guerra
Ellen Johnson</segment>
    <segment id="2">, presidente da Libéria tem o Nobel da Paz</segment>
    <segment id="3">, masmas quer agredir os gays</segment>
    <segment id="4">Uma declaração homofóbica de Ellen Johnson Sirleaf</segment>
    <segment id="5">, presidente da Libéria</segment>
    <segment id="6">, poderia passar despercebida</segment>
    <segment id="7">sese não fosse por um detalhe importante: além de representante de um país</segment>
    <segment id="8">, ela ganhou o Nobel da Paz por sua luta contra a violência em 2011.</segment>
    <segment id="9">Diante disso</segment>
    <segment id="10">, como</segment>
    <segment id="11">como uma pessoa que deveria prezar pela paz afirma que os gays devem ser punidos</segment>
    <segment id="12">comocomo</segment>
    <segment id="13">sese fossem “monstros”?</segment>
    <segment id="14">Esse ato</segment>
    <segment id="15">, no mínimo</segment>
    <segment id="16">, incita a violência contra a comunidade gay em seu país.</segment>
    <segment id="17">E mais: dá abertura</segment>
    <segment id="18">para que</segment>
    <segment id="19">para que</segment>
    <segment id="20">, em outros países</segment>
    <segment id="21">, o mesmo possa acontecer</segment>
    <segment id="22">, uma vez que o discurso é proferido por uma “representante da paz”.</segment>
    <segment id="23">O prêmio recebido por ela deveria ser cassado</segment>
    <segment id="24">, já que ela</segment>
    <segment id="25">sese mostra porta-voz da violência e não da paz.</segment>
  </rst>
</analysis>