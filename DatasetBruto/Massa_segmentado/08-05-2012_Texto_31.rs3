  <rst>
    <segment id="1">Do video game para o crime
Adolescente é pego ao tentar roubar ônibus com arma de brinquedo</segment>
    <segment id="2">As justificativas de um adolescente de 14 anos para roubar um ônibus usando uma arma de brinquedo apontam problemas na gestão da Saúde e Educação em  Salvador.</segment>
    <segment id="3">F.S.M foi detido</segment>
    <segment id="4">, na manhã de ontem</segment>
    <segment id="5">, pelo motorista e passageiros do micro-ônibus que fazia a linha Santa Cruz - Barroquinha.</segment>
    <segment id="6">O menor disse que o dinheiro do assalto era para comprar remédio para tratar  crises de epilepsia.</segment>
    <segment id="7">“Minha mãe foi no posto da Cardeal da Silva várias vezes</segment>
    <segment id="8">, masmas não tinha o remédio.</segment>
    <segment id="9">Anteontem</segment>
    <segment id="10">, eu dei crise</segment>
    <segment id="11">porque</segment>
    <segment id="12">porque estava sem tomar”</segment>
    <segment id="13">, conta.</segment>
    <segment id="14">O jovem pelo menos não está mentindo sobre a falta do remédio no Centro de Saúde São Gonçalo</segment>
    <segment id="15">, situado na Avenida Cardeal da Silva</segment>
    <segment id="16">, na Federação.</segment>
    <segment id="17">Em contato por telefone com a unidade</segment>
    <segment id="18">, uma atendente informou que ainda não chegou nenhum medicamento.</segment>
    <segment id="19">O problema na Educação</segment>
    <segment id="20">sese refere à  greve dos professores da rede estadual que  já dura 26 dias.</segment>
    <segment id="21">O adolescente disse que saía para roubar sempre pela manhã</segment>
    <segment id="22">, porque</segment>
    <segment id="23">porque estava sem aulas:</segment>
    <segment id="24">“Eu tinha até melhorado.</segment>
    <segment id="25">Estava estudando</segment>
    <segment id="26">, masmas esses dias aí sem aula...</segment>
    <segment id="27">”

Segundo a titular da Delegacia para o Adolescente Infrator (DAI)</segment>
    <segment id="28">, Claudenice Mayo</segment>
    <segment id="29">, o menor já possui duas passagens pela unidade por roubo e furto</segment>
    <segment id="30">, ambas em maio de 2011.</segment>
    <segment id="31">F.S.M admitiu ter feito outros sete assaltos  a ônibus nos últimos 26 dias.</segment>
    <segment id="32">“Ele será encaminhado ao Ministério Público</segment>
    <segment id="33">, que vai analisar qual medida será aplicada”</segment>
    <segment id="34">, informa a delegada.</segment>
    <segment id="35">Pegou a pistola do jogo</segment>
    <segment id="36">; usava também celular</segment>
    <segment id="37">F.B.S pegou a pistola do seu video game e enrolou com fita isolante preta para deixar parecida com uma arma verdadeira.</segment>
    <segment id="38">Foi a primeira vez que usou o truque e acabou sendo descoberto.</segment>
    <segment id="39">Nos sete assaltos anteriores</segment>
    <segment id="40">, ele usava o celular para fingir que estava armado.</segment>
    <segment id="41">“Pedi só o dinheiro do motorista</segment>
    <segment id="42">, masmas ele percebeu e me agarrou.</segment>
    <segment id="43">Ele me bateu com uma barra de ferro e outros passageiros me deram tapa.</segment>
    <segment id="44">Depois a polícia chegou”</segment>
    <segment id="45">, lembra o adolescente.</segment>
    <segment id="46">PMs do grupamento Gêmeos conseguiram interceptar o ônibus no Vale do Ogunjá.</segment>
    <segment id="47">O menor também agia na Avenida Bonocô e Estação da Lapa.</segment>
  </rst>
