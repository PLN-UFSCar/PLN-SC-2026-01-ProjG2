  <rst>
    <segment id="1">Botafogo leva 2 a 1 do Inter no Engenhão
RIO - O Botafogo desaprendeu a ganhar.</segment>
    <segment id="2">Na reta final do Brasileirão</segment>
    <segment id="3">, o time passou a acumular insucessos</segment>
    <segment id="4">, sese despediu da briga pelo título e agora já vê a vaga à Libertadores seriamente ameaçada.</segment>
    <segment id="5">Neste domingo</segment>
    <segment id="6">, o time dirigido interinamente por Flavio Tenius levou 2 a 1 do Internacional no Engenhão.</segment>
    <segment id="7">Esta foi a quarta derrota seguida do Botafogo - a sexta em sete jogos.</segment>
    <segment id="8">Depois de ficar invicto no Engenhão por quase todo o Brasileirão</segment>
    <segment id="9">, o alvinegro perdeu as últimas três em casa.</segment>
    <segment id="10">Leandro Damião e Oscar marcaram para os gaúchos</segment>
    <segment id="11">, que saltaram para a quarta posição.</segment>
    <segment id="12">Felipe Menezes descontou para o Botafogo.

- Ficou difícil</segment>
    <segment id="13">, masmas enquanto houver chances</segment>
    <segment id="14">, nós vamos buscar - disse Felipe Menezes.</segment>
    <segment id="15">O primeiro tempo começou muito disputado</segment>
    <segment id="16">, masmas com poucas chances.</segment>
    <segment id="17">O clima ficou tenso aos 34.</segment>
    <segment id="18">O Inter pôs a bola para fora para atendimento médico de Nei.</segment>
    <segment id="19">Na sequência</segment>
    <segment id="20">, faltou fairplay ao Botafogo</segment>
    <segment id="21">, que não a devolveu aos gaúchos.</segment>
    <segment id="22">Enquanto Elkeson sofria falta dura na entrada da área</segment>
    <segment id="23">, D'Alessandro foi cobrar de Alessandro rispidamente e a discussão tomou forma com vários jogadores dos dois times</segment>
    <segment id="24">sese empurrando ou tentando evitar confusão maior.</segment>
    <segment id="25">O árbitro Wilson Pereira Sampaio não</segment>
    <segment id="26">sese envolveu</segment>
    <segment id="27">, esperou os ânimos</segment>
    <segment id="28">sese acalmarem e deu apenas cartão amarelo para os dois.</segment>
    <segment id="29">Já nos acréscimos</segment>
    <segment id="30">, o Inter pressionou e conseguiu abrir o placar.</segment>
    <segment id="31">Aos 47 minutos</segment>
    <segment id="32">, D'Alessandro fez jogada individual pelo lado direito e chutou forte.</segment>
    <segment id="33">A bola desviou na zaga e explodiu no travessão.</segment>
    <segment id="34">Na sequência do lance</segment>
    <segment id="35">, o Inter atacou pela esquerda e</segment>
    <segment id="36">, após receber belo passe de Kléber</segment>
    <segment id="37">, Oscar cruzou rasteiro.</segment>
    <segment id="38">Jéfferson deu rebote e Leandro Damião</segment>
    <segment id="39">sese antecipou a Cortês para marcar.</segment>
    <segment id="40">O Botafogo voltou melhor na segunda etapa</segment>
    <segment id="41">, pressionando em busca de empate.</segment>
    <segment id="42">Flavio Tenius trocou Cortês e Herrera por Éverton e Caio</segment>
    <segment id="43">, masmas quem acabou ampliando foi o Inter.</segment>
    <segment id="44">Aos 28 minutos</segment>
    <segment id="45">, Andrezinho deu lindo passe para Oscar entrar livre na cara de Jéfferson e chutar colocado para fazer 2 a 0.</segment>
    <segment id="46">Felipe Menezes</segment>
    <segment id="47">, que entrou no lugar de Thiago Galhardo</segment>
    <segment id="48">, voltou a dar esperanças aos 32 minutos</segment>
    <segment id="49">, chutando rasteiro no canto de Muriel.</segment>
    <segment id="50">A partir daí</segment>
    <segment id="51">, a pressão alvinegra foi total</segment>
    <segment id="52">, masmas o goleiro colorado apareceu bem</segment>
    <segment id="53">, salvando o empate.</segment>
    <segment id="54">Na próxima rodada</segment>
    <segment id="55">, o Botafogo pega o Atlético-MG</segment>
    <segment id="56">, na Arena do Jacaré</segment>
    <segment id="57">, em Sete Lagoas.</segment>
    <segment id="58">O Internacional encara o Flamengo no Moacyrzão</segment>
    <segment id="59">, em Macaé.</segment>
    <segment id="60">BOTAFOGO 1</segment>
    <segment id="61">X 2 INTERNACIONAL

Local: Engenhão</segment>
    <segment id="62">, Rio de Janeiro (RJ)</segment>
    <segment id="63">Árbitro: Wilton Pereira Sampaio (DF)</segment>
    <segment id="64">Auxiliares: Marrubson Melo Freitas (DF) e José R. do Nascimento Júnior (RJ)

