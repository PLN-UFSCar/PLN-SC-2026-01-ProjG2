  <rst>
    <segment id="1">Levanta a 44ª taça</segment>
    <segment id="2">, Esquadrão!</segment>
    <segment id="3">Bahia empata com o Vitória em um clássico emocionante e conquista o Baianão 2012</segment>
    <segment id="4">“</segment>
    <segment id="5">O campeão voltou</segment>
    <segment id="6">, o campeão voltou</segment>
    <segment id="7">...”.</segment>
    <segment id="8">Foi com esse grito que a torcida do Bahia externava a alegria de ver seu time conquistar o 44º título baiano após dez anos de espera.</segment>
    <segment id="9">Em uma partida emocionante até o último minuto</segment>
    <segment id="10">, na tarde de ontem</segment>
    <segment id="11">, em Pituaçu</segment>
    <segment id="12">, o empate por 3 a 3 foi o suficiente para o Esquadrão dar um “presente de grego” no dia em que o Vitória completou 113 anos de fundação.</segment>
    <segment id="13">Como em todo Ba-Vi</segment>
    <segment id="14">, os nervos ficaram à flor da pele dos torcedores e também dos jogadores.</segment>
    <segment id="15">Uelliton e Vander foram expulsos depois de trocarem farpas.</segment>
    <segment id="16">Até o técnico Falcão foi para o chuveiro mais cedo depois de bater boca com o juiz.</segment>
    <segment id="17">Nos minutos finais</segment>
    <segment id="18">, Neto Baiano e outros jogadores do Vitória invadiram o gramado.</segment>
    <segment id="19">Entretanto</segment>
    <segment id="20">, os seis gols superaram isso.</segment>
    <segment id="21">Quem primeiro marcou foi o Vitória</segment>
    <segment id="22">, com Neto Baiano.</segment>
    <segment id="23">Fahel empatou com a colaboração de Douglas.</segment>
    <segment id="24">O camisa 1 falhou de novo na falta cobrada por Gabriel: 2 a 1.</segment>
    <segment id="25">Neto Baiano empatou</segment>
    <segment id="26">, aos 9 do segundo tempo.</segment>
    <segment id="27">Logo depois</segment>
    <segment id="28">, Dinei</segment>
    <segment id="29">, de cabeça</segment>
    <segment id="30">, virou: 3 a 2.</segment>
    <segment id="31">Contudo</segment>
    <segment id="32">, aos 26</segment>
    <segment id="33">, Rafael Donato cabeceou</segment>
    <segment id="34">, Douglas soltou e Diones fez o gol do título: 3 a 3 e muita festa em Pituaçu.</segment>
  </rst>
