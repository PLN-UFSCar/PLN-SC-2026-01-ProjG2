  <rst>
    <segment id="1">Pastor do diabo dopa e estupra fiel
Ivan Souza foi preso após abusar sexualmente de uma jovem de 16 anos</segment>
    <segment id="2">Acusado de estuprar uma adolescente de 16 anos</segment>
    <segment id="3">, na noite do último sábado</segment>
    <segment id="4">, em Itapetinga</segment>
    <segment id="5">, a 571 km de Salvador</segment>
    <segment id="6">, o pastor  Ivan Souza Silva</segment>
    <segment id="7">, 50 anos</segment>
    <segment id="8">, preso nesta segunda</segment>
    <segment id="9">, teve o flagrante remetido à Justiça na tarde de ontem.</segment>
    <segment id="10">Líder de congregações batistas nos municípios de Itororó</segment>
    <segment id="11">, Itati</segment>
    <segment id="12">, Dias D'Ávila e membro do Conselho Diretor Estadual das Igrejas Batistas do Brasil</segment>
    <segment id="13">, ele nega o crime.</segment>
    <segment id="14">A vítima foi atraída pelo criminoso e a amante dele</segment>
    <segment id="15">, Débora Sampaio Bispo</segment>
    <segment id="16">, 23 anos</segment>
    <segment id="17">, no sábado.</segment>
    <segment id="18">Segundo denúncia da mãe da adolescente</segment>
    <segment id="19">, na segunda</segment>
    <segment id="20">, Débora convenceu a mãe da vítima a permitir que a jovem dormisse na casa do pastor</segment>
    <segment id="21">, alegando estar sentindo-</segment>
    <segment id="22">sese mal.</segment>
    <segment id="23">“Ela dizia que temia passar mal e que precisava de uma companhia”</segment>
    <segment id="24">, contou o delegado plantonista de Itapetinga</segment>
    <segment id="25">, Jorge Luiz de Oliveira.</segment>
    <segment id="26">Débora tomou  três comprimidos sedativos e convenceu a vítima a tomar uma das pílulas.</segment>
    <segment id="27">Quando a jovem dormiu</segment>
    <segment id="28">, o pastor entrou no apartamento e</segment>
    <segment id="29">, segundo informações</segment>
    <segment id="30">, a estuprou pouco antes de ela acordar.</segment>
    <segment id="31">“Ela conseguiu fugir do pastor</segment>
    <segment id="32">, masmas a porta havia sido trancada por ele.</segment>
    <segment id="33">O celular da vítima também foi escondido”</segment>
    <segment id="34">, contou Jorge Luiz.</segment>
    <segment id="35">O pastor voltou para a casa onde mora com a esposa e filhos</segment>
    <segment id="36">, em Itororó</segment>
    <segment id="37">, por volta das 5h da manhã de domingo</segment>
    <segment id="38">, quando a vítima conseguiu fugir.</segment>
    <segment id="39">“</segment>
    <segment id="40">A adolescente foi ameaçada pelo casal no domingo e só na segunda teve coragem de contar o que havia acontecido para a mãe”</segment>
    <segment id="41">, diz o plantonista.</segment>
    <segment id="42">Abriu a boca</segment>
    <segment id="43">No depoimento</segment>
    <segment id="44">, a amante do pastor afirmou que essa não foi a primeira vez que ele tentou abusar da jovem.</segment>
    <segment id="45">"</segment>
    <segment id="46">Débora contou que</segment>
    <segment id="47">, em outra ocasião</segment>
    <segment id="48">, o pastor havia ficado sozinho com a vítima no apartamento e tentou agarrá-la</segment>
    <segment id="49">, masmas não chegou a abusar sexualmente dela.</segment>
    <segment id="50">Por esse motivo</segment>
    <segment id="51">, a adolescente não entrava no apartamento quando Ivan estava"</segment>
    <segment id="52">, explicou o delegado.</segment>
    <segment id="53">A polícia não descarta que o casal seja responsável por estupros contra fiéis de outros municípios.</segment>
    <segment id="54">“Mas ainda estamos investigando”</segment>
    <segment id="55">, disse.</segment>
    <segment id="56">O pastor foi preso em um ônibus a caminho de Itororó.</segment>
    <segment id="57">Ele ainda chegou a</segment>
    <segment id="58">sese apresentar com um nome falso</segment>
    <segment id="59">, masmas foi desmascarado ao ser solicitado aos passageiros documento de identificação.</segment>
    <segment id="60">Autuado em flagrante</segment>
    <segment id="61">, ele vai continuar à disposição da Justiça.</segment>
  </rst>
</analysis>