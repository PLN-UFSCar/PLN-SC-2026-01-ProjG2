  <rst>
    <segment id="1">Amante atrai PM para a morte</segment>
    <segment id="2">Tiago tinha apenas oito meses na PM.</segment>
    <segment id="3">Ele deixou mulher e um filho de 3 meses</segment>
    <segment id="4">A polícia já sabe que uma adolescente de 16 anos foi a pivô da morte do soldado PM Tiago Serra Gonçalves</segment>
    <segment id="5">, 24 anos</segment>
    <segment id="6">, e está em busca dos autores e o mandante do crime.</segment>
    <segment id="7">Todos já estão identificados.</segment>
    <segment id="8">A mando de um traficante conhecido</segment>
    <segment id="9">comocomo Nilson</segment>
    <segment id="10">, o Gordo</segment>
    <segment id="11">,  a menor A.S.B marcou um encontro com o soldado para informar o fim do relacionamento.</segment>
    <segment id="12">Quando o policial chegou à Vila Laurino</segment>
    <segment id="13">, em Vilas de Abrantes</segment>
    <segment id="14">, foi executado com 4 tiros no rosto e posto na mala do próprio carro.</segment>
    <segment id="15">O veículo foi abandonado em Catu de Abrantes</segment>
    <segment id="16">, no município de Camaçari (Grande Salvador).</segment>
    <segment id="17">Segundo o major PM Ricardo Passos</segment>
    <segment id="18">, o soldado tinha um relacionamento com a adolescente A.S.B. há um ano.</segment>
    <segment id="19">“Ela já namorou com o traficante  Gordo.</segment>
    <segment id="20">Ele mandou ela  terminar o relacionamento com Tiago</segment>
    <segment id="21">porque</segment>
    <segment id="22">porque não queria polícia andando na área dele”</segment>
    <segment id="23">, explica o major</segment>
    <segment id="24">, que é comandante da 40ª CIPM e coordenador das Bases Comunitárias de Segurança do Nordeste de Amaralina</segment>
    <segment id="25">, onde Tiago era lotado.</segment>
    <segment id="26">De acordo com o major</segment>
    <segment id="27">, o soldado  recebia mensagens constantemente da menor pedindo</segment>
    <segment id="28">para que</segment>
    <segment id="29">para que ele matasse o traficante Gordo.</segment>
    <segment id="30">“</segment>
    <segment id="31">O traficante falou que mataria a jovem e a família dela</segment>
    <segment id="32">sese ela não terminasse o namoro com Tiago”</segment>
    <segment id="33">, conta.</segment>
    <segment id="34">Foto: Álbum de Família / Divulgação</segment>
    <segment id="35">O policial Tiago tinha apenas oito meses na PM.</segment>
    <segment id="36">Ele deixou mulher e um filho de 3 meses</segment>
    <segment id="37">“</segment>
    <segment id="38">A esposa de Tiago me informou que ele conheceu essa menina quando eles tiveram uma briga em janeiro do ano passado.</segment>
    <segment id="39">Em dezembro</segment>
    <segment id="40">, ela descobriu as mensagens no celular dele”</segment>
    <segment id="41">, completa.</segment>
    <segment id="42">Investigações:</segment>
    <segment id="43">Mais de 15 pessoas ouvidas</segment>
    <segment id="44">Na noite de quarta-feira</segment>
    <segment id="45">, o soldado foi encontrar a jovem após o serviço e acabou caindo em uma emboscada.</segment>
    <segment id="46">Segundo o Major Ricardo</segment>
    <segment id="47">, Gil, Carcunda e Macaquito executaram o PM a mando do traficante Gordo.</segment>
    <segment id="48">O Serviço de Inteligência da PM e a 26ª Delegacia Territorial (Vilas de Abrantes) investigam o</segment>
    <segment id="49">casocaso.</segment>
    <segment id="50">Mais de 15 pessoas foram ouvidas pelo titular da 26ª DT</segment>
    <segment id="51">, Marcos Tebaldi</segment>
    <segment id="52">, desde a noite do crime.</segment>
    <segment id="53">Cinco permanecem detidas</segment>
    <segment id="54">, entre elas a adolescente</segment>
    <segment id="55">A.S.B.</segment>
    <segment id="56">O delegado informou que só hoje pode fornecer mais informações.</segment>
    <segment id="57">“</segment>
    <segment id="58">Acredito que ele morreu</segment>
    <segment id="59">porque</segment>
    <segment id="60">porque era policial.</segment>
    <segment id="61">Os bandidos descobriram e mataram”</segment>
    <segment id="62">, afirma Marcos Tebaldi.

 

Foto: Luciano da Matta / Ag.</segment>
    <segment id="63">A TARDE</segment>
    <segment id="64">O carro do soldado será periciado</segment>
    <segment id="65">, nos próximos dias</segment>
    <segment id="66">, pelo Departamento de Polícia Técnica</segment>
    <segment id="67">A dor da despedida</segment>
    <segment id="68">O corpo do soldado Tiago Serra Gonçalves foi enterrado ontem no cemitério Quinta dos Lázaros.</segment>
    <segment id="69">Familiares</segment>
    <segment id="70">, amigos e colegas de farda</segment>
    <segment id="71">sese emocionaram.</segment>
    <segment id="72">A mãe, Elta Joaquina Carvalho Serra</segment>
    <segment id="73">, gritava aos prantos a perda de um dos quatro filhos.</segment>
    <segment id="74">“</segment>
    <segment id="75">O inimigo arrebatou meu menino.</segment>
    <segment id="76">Meu filho não era vagabundo.</segment>
    <segment id="77">Por que levaram ele?</segment>
    <segment id="78">”, questionava.</segment>
    <segment id="79">Enquanto isso</segment>
    <segment id="80">, Raimundo Gonçalves</segment>
    <segment id="81">, pai do soldado</segment>
    <segment id="82">, recebia os pesames</segment>
    <segment id="83">, masmas não conseguia pronunciar uma palavra.</segment>
    <segment id="84">A irmã de Tiago</segment>
    <segment id="85">, Rosicleide Serra Gonçalves</segment>
    <segment id="86">, 21, lembrou o caminho trilhado pelo irmão.</segment>
    <segment id="87">“</segment>
    <segment id="88">Ele foi do exército.</segment>
    <segment id="89">Fez o concurso da PM e passou.</segment>
    <segment id="90">Estava no sangue.</segment>
    <segment id="91">Temos orgulho dele”</segment>
    <segment id="92">, destacou.</segment>
    <segment id="93">“</segment>
    <segment id="94">Ao mesmo tempo há o sentimento de revolta.</segment>
    <segment id="95">Queremos Justiça”</segment>
    <segment id="96">, completou.</segment>
    <segment id="97">Durante o sepultamento</segment>
    <segment id="98">, policiais do Batalhão de Choque cantaram um hino do grupamento do qual Tiago foi integrante.</segment>
    <segment id="99">“Era um excelente profissional.</segment>
    <segment id="100">Não era da banda podre”</segment>
    <segment id="101">, afirmou o Major Ricardo Passos.</segment>
  </rst>
</analysis>