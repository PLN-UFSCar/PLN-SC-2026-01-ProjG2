  <rst>
    <segment id="1">Presentes e diversão garantida no Natal da Ilha Ilha do Governador</segment>
    <segment id="2">O shopping Ilha Plaza está diferente</segment>
    <segment id="3">, e, ao menos por lá</segment>
    <segment id="4">, Papai Noel já chegou.</segment>
    <segment id="5">O centro comercial inaugurou no último dia 16 sua decoração natalina</segment>
    <segment id="6">, na qual não faltam atrativos para a criançada.</segment>
    <segment id="7">Além de receber o Bom Velhinho</segment>
    <segment id="8">, o Ilha Plaza montou um trenzinho elétrico e criou uma praça cenográfica</segment>
    <segment id="9">, pela qual pode-</segment>
    <segment id="10">sese caminhar entre duendes e bonecos de neve.</segment>
    <segment id="11">O Papai Noel está no shopping para fotos de segunda a sábado</segment>
    <segment id="12">, das 10h às 22h</segment>
    <segment id="13">, e aos domingos</segment>
    <segment id="14">, das 15h às 21h.</segment>
    <segment id="15">As fotografias 10cm x 15cm custam R$ 17 e as 15cm x 20cm saem por R$ 22.</segment>
    <segment id="16">A caneca com foto é vendida por R$ 22.</segment>
    <segment id="17">Já um passeio de trenzinho custa R$ 10.</segment>
    <segment id="18">O brinquedo funciona todos os dias</segment>
    <segment id="19">, das 10h às 22h.</segment>
    <segment id="20">Para os adultos</segment>
    <segment id="21">, a atração é a promoção "</segment>
    <segment id="22">Viagem dos sonhos".</segment>
    <segment id="23">A cada R$ 250 em compras com cartões MasterCard</segment>
    <segment id="24">, o cliente recebe um cupom para concorrer a uma viagem no valor de R$ 8 mil.</segment>
    <segment id="25">O destino pode ser escolhido pelo ganhador do sorteio.</segment>
    <segment id="26">O Papai Noel está no shopping para fotos de segunda a sábado</segment>
    <segment id="27">, das 10h às 22h</segment>
