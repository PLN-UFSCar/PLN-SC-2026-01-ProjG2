    <segment id="16">, diz.</segment>
    <segment id="17">Segundo a moﾃδｧa</segment>
    <segment id="18">, a ideia da mﾃδ｡scara foi uma decisﾃδ｣o da produﾃδｧﾃδ｣o que deu muito certo.</segment>
    <segment id="19">ﾃ｢竄ｬﾅ鉄empre que faﾃδｧo shows</segment>
    <segment id="20">, o pﾃδｺblico pede para tirar a mﾃδ｡scara.</segment>
    <segment id="21">Todo mundo quer saber quem ﾃδｩﾃ｢竄ｬ</segment>
    <segment id="22">, conta aos risos.</segment>
    <segment id="23">Hoje, na The Best Beach</segment>
    <segment id="24">, na Ribeira</segment>
    <segment id="25">, ﾃδs 22h</segment>
    <segment id="26">, o La Fﾃδｺria promete fazer uma retrospectiva para os fﾃδ｣s</segment>
