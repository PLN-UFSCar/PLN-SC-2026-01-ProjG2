  <rst>
    <segment id="1">Marquinhos para frear o Tremendão
Toninho</segment>
    <segment id="2">Cerezo deve escalar o atacante para tentar acabar com o Bahia de Feira
“</segment>
    <segment id="3">A equipe deles é boa</segment>
    <segment id="4">, não é?</segment>
    <segment id="5">” Essa pergunta/afirmação foi  feita pelo técnico do Vitória</segment>
    <segment id="6">, Toninho Cerezo</segment>
    <segment id="7">, para alguns repórteres que acompanhavam o treino de ontem.</segment>
    <segment id="8">Ele se</segment>
    <segment id="9">se refere ao Bahia de Feira</segment>
    <segment id="10">, adversário do Leão</segment>
    <segment id="11">, amanhã</segment>
    <segment id="12">, às 5h da tarde.</segment>
    <segment id="13">O Tremendão é um  bom time</segment>
    <segment id="14">, Cerezo.</segment>
    <segment id="15">Não é à toa que  está na liderança</segment>
    <segment id="16">, com cinco triunfos em cinco jogos.</segment>
    <segment id="17">Mas para derrubar o moral da equipe feirense</segment>
    <segment id="18">, o professor  do bigodão já tem a arma:</segment>
    <segment id="19">Marquinhos para cima deles.</segment>
    <segment id="20">O atacante foi relacionado pela primeira vez este ano e pode começar jogando.</segment>
    <segment id="21">“Marquinhos ainda não está bem fisicamente</segment>
    <segment id="22">, masmas está com vontade e isso é o mais importante”</segment>
    <segment id="23">, disse Cerezo.</segment>
    <segment id="24">O atacante treinou normalmente e confirmou  as palavras do chefe.</segment>
    <segment id="25">Questionado</segment>
    <segment id="26">sese aceitaria jogar apenas o primeiro tempo</segment>
    <segment id="27">, Marquinhos respondeu:</segment>
    <segment id="28">“Eu jogo”.</segment>
    <segment id="29">Se o xodó da torcida rubro-negra entrar em campo</segment>
    <segment id="30">, Cerezo certamente ficará mais tranquilo</segment>
    <segment id="31">, afinal</segment>
    <segment id="32">, ele conhece a pedreira que vai encarar.</segment>
    <segment id="33">“</segment>
    <segment id="34">O Bahia de Feira está mais entrosado que o Vitória.</segment>
    <segment id="35">É  um time muito organizado e que joga para a frente”</segment>
    <segment id="36">, elogiou.</segment>
    <segment id="37">Só para lembrar: O Bahia de Feira foi campeão ano passado</segment>
    <segment id="38">, em pleno Barradão.</segment>
    <segment id="39">Esse jogo promete!</segment>
  </rst>
</analysis>