  <rst>
    <segment id="1">Pão e circo nas esquinas cariocas
RIO - O colombiano Andrés Neira</segment>
    <segment id="2">, de 25 anos</segment>
    <segment id="3">, joga malabares desde os três.</segment>
    <segment id="4">Autodidata nas artes circenses</segment>
    <segment id="5">, aos 22 ele desistiu de ganhar dinheiro formalmente</segment>
    <segment id="6">, largou o restaurante onde trabalhava e começou a viajar pela América Latina.
- Solo falta conocer Chile</segment>
    <segment id="7">, Uruguai e Venezuela - diz ele</segment>
    <segment id="8">, há quatro meses no Rio.</segment>
    <segment id="9">- Assim</segment>
    <segment id="10">, consigo fazer o que gosto e viajar</segment>
    <segment id="11">, conocer gente e lugares diferentes.</segment>
    <segment id="12">A vida nômade</segment>
    <segment id="13">, conta ele</segment>
    <segment id="14">, num portunhol ainda precário</segment>
    <segment id="15">, atrai muito.</segment>
    <segment id="16">Do Rio</segment>
    <segment id="17">ele</segment>
    <segment id="18">"adora" a praia</segment>
    <segment id="19">, o samba e o clima de alegria.</segment>
    <segment id="20">Mas o seu dia a dia é nos sinais da cidade</segment>
    <segment id="21">, onde consegue ganhar entre R$ 100 e R$ 300 por dia.</segment>
    <segment id="22">Além disso</segment>
    <segment id="23">, vez por outra</segment>
    <segment id="24">, ainda tira um extra:

- Também somos chamados para jogar malabares em festas e eventos.</segment>
    <segment id="25">É muito bom quando rola:</segment>
    <segment id="26">já me apresentei em aniversários de crianças</segment>
    <segment id="27">, e pagam bem.</segment>
    <segment id="28">Neira é o retrato de uma boa parcela da nova onda migratória que tem chegado ao Brasil nos últimos anos.</segment>
    <segment id="29">São colombianos</segment>
    <segment id="30">, bolivianos</segment>
    <segment id="31">, peruanos</segment>
    <segment id="32">, argentinos e chilenos</segment>
    <segment id="33">, que vêm tentar a sorte entre malabares</segment>
    <segment id="34">, fogo</segment>
    <segment id="35">, bolas e outros artefatos circenses</segment>
    <segment id="36">, nos sinais ou em praças da cidade.</segment>
    <segment id="37">Como a maioria desses artistas</segment>
    <segment id="38">, ele é desconfiado.</segment>
    <segment id="39">Prefere falar pouco</segment>
    <segment id="40">, não revelar muitos detalhes sobre a vida e não declarar que está há mais de três meses no país - o prazo de validade do visto de turista</segment>
    <segment id="41">, com o qual muitos deles entram no Brasil.</segment>
    <segment id="42">Mas revela que já morou na favela de Manguinhos e que foi uma "ótima experiência".</segment>
    <segment id="43">O colombiano não trabalha fantasiado ou maquiado: exibe</segment>
    <segment id="44">, no máximo</segment>
    <segment id="45">, um ou outro adereço</segment>
    <segment id="46">, devido ao forte calor e à transpiração.</segment>
    <segment id="47">O colombiano conta que segunda-feira é o dia em que as pessoas estão mais "mão fechada".

- Nos fins de semana</segment>
    <segment id="48">, as pessoas ficam felizes por não estarem trabalhando</segment>
    <segment id="49">, e aí pagam melhor.</segment>
    <segment id="50">Até sorriem mais - brinca Neira</segment>
    <segment id="51">, que mora com mais três estrangeiros</segment>
    <segment id="52">, de mesma ocupação</segment>
    <segment id="53">, na Lapa.</segment>
    <segment id="54">Um deles é o colombiano Jose Usuga</segment>
    <segment id="55">, de 27 anos</segment>
    <segment id="56">, que chama a atenção de motoristas num sinal da zona portuária</segment>
    <segment id="57">, ao fazer dançar uma bola de acrílico transparente nos braços e nas mãos.</segment>
    <segment id="58">De Medellín</segment>
    <segment id="59">, ele está há cinco meses no Rio</segment>
    <segment id="60">, depois de já ter passado um em São Paulo.</segment>
    <segment id="61">Veio chamado por um conterrâneo</segment>
    <segment id="62">, que já atuava com malabares em sinais de trânsito.

- Sempre quis conhecer o Brasil</segment>
    <segment id="63">, masmas o tamanho do país e o idioma assustavam.</segment>
    <segment id="64">Quando meu amigo falou que a coisa estava boa</segment>
    <segment id="65">, e que tinha onde ficar</segment>
    <segment id="66">, me animei - conta Usuga</segment>
    <segment id="67">, que garante ser tratado "</segment>
    <segment id="68">comocomo irmão" pelos colegas brasileiros.</segment>
    <segment id="69">Um país de dimensões continentais e de idioma difícil são os dois aspectos apontados por esses estrangeiros</segment>
    <segment id="70">comocomo inibidores</segment>
    <segment id="71">, na hora de vir para o Brasil.</segment>
    <segment id="72">Embora alguns relutem em dizer abertamente</segment>
    <segment id="73">, o fato de o país ter</segment>
    <segment id="74">sese tornado uma grande potência econômica</segment>
    <segment id="75">, com moeda forte</segment>
    <segment id="76">, pesa muito na decisão de imigrar.</segment>
    <segment id="77">Rio e São Paulo</segment>
    <segment id="78">, dizem</segment>
    <segment id="79">, estão entre as cidades onde mais</segment>
    <segment id="80">sese ganha dinheiro em sinais</segment>
    <segment id="81">, em toda a América do Sul.</segment>
    <segment id="82">Seja para passar uns meses ou para ficar de vez</segment>
    <segment id="83">, os "artistas callejeros" (de calles</segment>
    <segment id="84">, ruas em espanhol) vêm atraídos também por um intercâmbio cultural informal que tem acontecido com mais frequência</segment>
    <segment id="85">, especialmente com a realização anual da Convenção Brasileira de Malabares e Circo</segment>
    <segment id="86">, que teve sua primeira edição há 13 anos e é feita em diferentes cidades do país.

- Me gusta conhecer outras culturas fazendo arte na rua.</segment>
    <segment id="87">Já passei por uns 15 estados do Brasil.</segment>
    <segment id="88">Viagem maneiro</segment>
    <segment id="89">, cara!</segment>
    <segment id="90">- conta</segment>
    <segment id="91">, num portunhol com ginga</segment>
    <segment id="92">, o malabarista peruano George Coco</segment>
    <segment id="93">, de 21 anos</segment>
    <segment id="94">, que mostra sua habilidade com tochas e facas no cruzamento da Rua de Santana com a Avenida Presidente Vargas</segment>
    <segment id="95">, no Centro.</segment>
    <segment id="96">No país há pouco mais de quatro meses</segment>
    <segment id="97">, ele paga suas despesas de hospedagem</segment>
    <segment id="98">, alimentação e transporte com o dinheiro que ganha nos sinais.

- A economia brasileira está entre as sete principais do mundo.</segment>
    <segment id="99">Sua moeda tem muito valor lá fora - diz Coco</segment>
    <segment id="100">, que manda dinheiro para a família.</segment>
    <segment id="101">- E a arte faz o mundo não ser tão mau.</segment>
    <segment id="102">Espero que as pessoas colaborem de coração</segment>
    <segment id="103">, sem miséria.</segment>
    <segment id="104">Bem perto dele</segment>
    <segment id="105">, em meio ao caos do trânsito e aos zumbidos das buzinas</segment>
    <segment id="106">, a faixa de pedestres vira palco para o jovem argentino Eduardo Miranda.</segment>
    <segment id="107">Ele brinca com uma bola de cristal</segment>
    <segment id="108">, que desliza sobre os braços</segment>
    <segment id="109">, cabeça</segment>
    <segment id="110">, peito e mãos</segment>
    <segment id="111">, parecendo flutuar no ar.</segment>
    <segment id="112">Miranda conta que começou</segment>
    <segment id="113">comocomo palhaço</segment>
    <segment id="114">, logo depois de estudar pintura na universidade de Rosário Central.</segment>
    <segment id="115">Também fez teatro e artesanato.</segment>
    <segment id="116">Um dia</segment>
    <segment id="117">, juntou-</segment>
    <segment id="118">sese a um grupo que jogava malabares na rua.

- Hoje</segment>
    <segment id="119">, viajo fazendo circo - diz ele</segment>
    <segment id="120">, que, em um ano e meio</segment>
    <segment id="121">, passou pelo Sul</segment>
    <segment id="122">, por São Paulo e por Goiânia.</segment>
    <segment id="123">- Consigo pagar as despesas</segment>
    <segment id="124">, conhecer as pessoas e os lugares.</segment>
    <segment id="125">Com a mesma intenção</segment>
    <segment id="126">, o chileno Rafael Flores</segment>
    <segment id="127">, de 26 anos</segment>
    <segment id="128">, chegou ao Brasil há quatro.</segment>
    <segment id="129">Pronunciando os erres com sotaque do interior paulista e com trejeitos de rapper</segment>
    <segment id="130">, ele conta que está no Rio desde novembro de 2011 e que já morou em diferentes cidades de 18 estados.</segment>
    <segment id="131">Já viveu na favela de Manguinhos e hoje mora no edifício conhecido</segment>
    <segment id="132">comocomo "</segment>
    <segment id="133">Balança</segment>
    <segment id="134">masmas não cai"</segment>
    <segment id="135">, próximo à Central do Brasil.

- Vocês são muito patriotas.</segment>
    <segment id="136">Já ouvi muito "este é o meu país".</segment>
    <segment id="137">E quem disse que não é?</segment>
    <segment id="138">- conta ele</segment>
    <segment id="139">, que já enfrentou algumas situações parecidas.</segment>
    <segment id="140">- Existe muito preconceito contra a gente</segment>
    <segment id="141">, masmas gosto daqui</segment>
    <segment id="142">, já me acostumei.</segment>
    <segment id="143">Segundo Flores</segment>
    <segment id="144">, nas outras cidades por onde passou nunca teve tanto "problema</segment>
    <segment id="145">" de ser retirado de sinais</segment>
    <segment id="146">comocomo no Rio</segment>
    <segment id="147">, onde a Guarda Municipal atua nesse sentido.</segment>
    <segment id="148">Os únicos lugares onde ainda é possível trabalhar sem ser incomodado são sinais no Centro e nas proximidades</segment>
    <segment id="149">, além de Tijuca e Vila Isabel.</segment>
    <segment id="150">É em bares do Boulevard 28 de Setembro que os malabaristas peruanos Alejandro Rodriguez e Percy David mostram suas habilidades e ganham a vida.</segment>
    <segment id="151">Equilibrado num monociclo de quase dois metros de altura e atirando malabares com fogo</segment>
    <segment id="152">, Alejandro está há cinco anos no Brasil e já em situação legal</segment>
    <segment id="153">, pois</segment>
    <segment id="154">pois se</segment>
    <segment id="155">se beneficiou da anistia dada em 2009 pelo então presidente Lula (lei 11.961)</segment>
    <segment id="156">, para estrangeiros que estavam ilegais no país.</segment>
    <segment id="157">Ele incentivou o amigo Percy - que tem formação pela Escola Nacional de Circo do Peru - a vir fazer um curso de reciclagem na Escola Nacional de Circo daqui</segment>
    <segment id="158">, além de umas audições.

- Aqui tenho uma qualidade de vida bem melhor e mais oportunidades de me desenvolver profissionalmente - diz Rodriguez</segment>
    <segment id="159">, num português carregado de sotaque espanhol</segment>
    <segment id="160">, masmas bem claro.</segment>
    <segment id="161">- Sempre fui fascinado pela natureza do Rio</segment>
    <segment id="162">, com essa combinação de montanhas e mar.</segment>
    <segment id="163">E também com as mulheres daqui</segment>
    <segment id="164">, as mais lindas.</segment>
    <segment id="165">Aos 20 e poucos anos de idade</segment>
    <segment id="166">, Alejandro mostra um cartão de visitas que foi muito bem-feito</segment>
    <segment id="167">, no qual</segment>
    <segment id="168">sese lê "Alejandro Rodriguez</segment>
    <segment id="169">, artista e produtor de eventos circenses"</segment>
    <segment id="170">, em português e em inglês.</segment>
    <segment id="171">Tido como</segment>
    <segment id="172">como "fera no monociclo com fogo" pelos colegas</segment>
    <segment id="173">, também capricha no profissionalismo.</segment>
    <segment id="174">Em meio a uma vida cheia de altos e baixos</segment>
    <segment id="175">, eles encontram espaço para treinar</segment>
    <segment id="176">, trocar experiências e interagir na Praça São Salvador</segment>
    <segment id="177">, em Laranjeiras.</segment>
    <segment id="178">Toda as segundas-feiras à noite</segment>
    <segment id="179">, o local é tomado por artistas circenses sul-americanos.</segment>
    <segment id="180">Cena comum são as crianças</segment>
    <segment id="181">sese aproximando</segment>
    <segment id="182">, pedindo para brincar com as claves e as bolinhas</segment>
    <segment id="183">, indo e vindo com os artefatos.</segment>
    <segment id="184">Sempre há curiosos por perto e gente que</segment>
    <segment id="185">sese arrisca a tentar aprender alguns números de circo.

- Esta reunião é muito bacana para todos nós.</segment>
    <segment id="186">Começamos há quase dez anos</segment>
    <segment id="187">, na Lapa</segment>
    <segment id="188">, e agora estamos aqui - diz o argentino Martín Torchiana</segment>
    <segment id="189">, pioneiro que hoje</segment>
    <segment id="190">sese profissionalizou e tem a própria empresa</segment>
    <segment id="191">, produtora de artefatos de circo e promotora de shows e realiza oficinas até para crianças.</segment>
    <segment id="192">Mais um da tribo que quer pão e circo entre os encantos da Cidade Maravilhosa.</segment>
  </rst>
</analysis>