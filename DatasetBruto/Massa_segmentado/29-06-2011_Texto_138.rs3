  <rst>
    <segment id="1">Eles só queriam charlar de carrão</segment>
    <segment id="2">Ambos já tinham a ficha suja</segment>
    <segment id="3">A prisão de Agnaldo Oliveira de Assis Filho</segment>
    <segment id="4">, 33 anos</segment>
    <segment id="5">, o Guido</segment>
    <segment id="6">, pelo roubo de quatro carros importados</segment>
    <segment id="7">, na noite de quarta-feira (27)</segment>
    <segment id="8">, foi uma surpresa para os policiais da Delegacia de Repressão a Furtos e Roubos de Veículos (DRFRV).</segment>
    <segment id="9">Isso porque</segment>
    <segment id="10">porque o cara foi reconhecido por três das quatro vítimas</segment>
    <segment id="11">comocomo participante de roubos.</segment>
    <segment id="12">Até então</segment>
    <segment id="13">, a polícia acreditava que o envolvimento dele</segment>
    <segment id="14">sese limitava ao transporte dos carros para o interior do Estado.</segment>
    <segment id="15">Guido  foi preso com o comparsa Jeferson Maurício da Silva Conceição</segment>
    <segment id="16">, dentro de um carro Corolla</segment>
    <segment id="17">, no estacionamento do Atacadão</segment>
    <segment id="18">, na Avenida Barros Reis.</segment>
    <segment id="19">Se deram mal
O carro Toyota Corolla possuía placa clonada.</segment>
    <segment id="20">De acordo com o delegado Maurício Maradillo</segment>
    <segment id="21">, da DRFRV</segment>
    <segment id="22">, o veículo foi roubado</segment>
    <segment id="23">, no último dia 21</segment>
    <segment id="24">, perto de Praia do Forte.</segment>
    <segment id="25">A polícia recuperou dois carros modelo Honda City e um Sportage</segment>
    <segment id="26">, todos roubados pela dupla</segment>
    <segment id="27">, segundo o delegado.</segment>
    <segment id="28">A dupla foi indiciada por roubo</segment>
    <segment id="29">, receptação e adulteração de sinal identificador de veículo.</segment>
  </rst>
</analysis>