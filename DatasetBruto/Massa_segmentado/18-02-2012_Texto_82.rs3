  <rst>
    <segment id="1">Dançarina não esquece assalto</segment>
    <segment id="2">“Comecei a tremer demais e um deles falou:</segment>
    <segment id="3">– Calma galêga"</segment>
    <segment id="4">, diz Carlinha</segment>
    <segment id="5">A dançarina da banda Cavaleiros do Forró</segment>
    <segment id="6">, Carlinha Havashy</segment>
    <segment id="7">, não esquecerá os momentos vividos durante o assalto ao ônibus do grupo na madrugada do último sábado.</segment>
    <segment id="8">“</segment>
    <segment id="9">Nunca vou esquecer a cena daqueles homens de metralhadora entrando no ônibus”</segment>
    <segment id="10">, lembra Carlinha</segment>
    <segment id="11">, que disse ter desmaiado de nervoso minutos após os bandidos terem terminado a ação.</segment>
    <segment id="12">“Comecei a tremer demais e um deles falou:</segment>
    <segment id="13">– Calma galêga.</segment>
    <segment id="14">Ninguém vai fazer nada com você</segment>
    <segment id="15">, não”</segment>
    <segment id="16">, relata Carlinha.</segment>
    <segment id="17">Os bandidos não agrediram ninguém durante o assalto e mandaram os 37 passageiros do ônibus ficarem de cabeça baixa.</segment>
    <segment id="18">Eles só mudaram de ideia ao ver as dançarinas da banda.</segment>
    <segment id="19">“Olha quanta mulher bonita.</segment>
    <segment id="20">Levanta a cabeça para eu te ver.</segment>
    <segment id="21">Agora pode baixar”</segment>
    <segment id="22">, conta Carlinha sobre a ordem dada pelos assaltantes.</segment>
    <segment id="23">O momento mais dramático durante o assalto foi quando o bandido que estava armado com uma metralhadora engatilhou a arma em direção ao percussionista da banda só</segment>
    <segment id="24">porque</segment>
    <segment id="25">porque o rapaz estava olhando para ele.</segment>
    <segment id="26">No camarim: Ladrões têm coleção de DVDs</segment>
    <segment id="27">Os assaltantes só descobriram que ônibus alvo do assalto era da banda</segment>
    <segment id="28">Cavaleiros</segment>
    <segment id="29">do Forró</segment>
    <segment id="30">quando</segment>
    <segment id="31">sese dirigiram ao camarim do veículo onde estavam os cantores.</segment>
    <segment id="32">“Eita, danou-</segment>
    <segment id="33">sese.</segment>
    <segment id="34">É banda”</segment>
    <segment id="35">, contou Carlinha</segment>
    <segment id="36">, ao lembrar o que um dos bandidos disse ao reconhecer Jailson Santos</segment>
    <segment id="37">, o Véio</segment>
    <segment id="38">, vocalista.</segment>
    <segment id="39">“</segment>
    <segment id="40">Tenho uma coleção de DVDs da banda.</segment>
    <segment id="41">Sou seu  fã.</segment>
    <segment id="42">Minha mulher não vai acreditar que roubamos vocês”</segment>
    <segment id="43">, completou o ladrão cara de pau.</segment>
  </rst>
</analysis>