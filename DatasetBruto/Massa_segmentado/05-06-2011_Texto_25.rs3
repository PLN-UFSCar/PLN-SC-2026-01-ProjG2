  <rst>
    <segment id="1">Flamengo e Corinthians empatam na despedida de Petkovic
RIO - Na tarde da despedida de Petkovic</segment>
    <segment id="2">, Flamengo e Corinthians fizeram um jogo movimentado e acabaram empatando em 1 a 1 na tarde deste domingo</segment>
    <segment id="3">, no Engenhão.</segment>
    <segment id="4">William e Renato Abreu marcaram os gols no primeiro tempo</segment>
    <segment id="5">, que teve boa participação do meia sérvio</segment>
    <segment id="6">, substituído no intervalo.
FOTOGALERIA:</segment>
    <segment id="7">Mais imagens da partida
TEMPO REAL:</segment>
    <segment id="8">Como foi o jogo no lance a lance
CLASSIFICAÇÃO: Confira</segment>
    <segment id="9">comocomo está a tabela
BLOG:</segment>
    <segment id="10">'O Mais Querido'
Com o empate</segment>
    <segment id="11">, o Flamengo chegou a cinco pontos na tabela.</segment>
    <segment id="12">O Corinthians tem sete.</segment>
    <segment id="13">No próximo domingo o Flamengo pega o Atlético-PR</segment>
    <segment id="14">, na Arena da Baixada.</segment>
    <segment id="15">O Flamengo entrou em campo puxado por Petkovic</segment>
    <segment id="16">, que recebeu uma homenagem emocionante da torcida.</segment>
    <segment id="17">Um mosaico foi formado com as cores da bandeira da Sérvia e o nome de Petkovic escrito - depois o mosaico ganhou as cores rubro-negras.
-</segment>
    <segment id="18">A torcida foi maravilhosa.</segment>
    <segment id="19">Obrigado</segment>
    <segment id="20">, masmas agora acaba</segment>
    <segment id="21">, agora é jogo à vera.</segment>
    <segment id="22">Vamos lá buscar os três pontos - avisou Petkovic.</segment>
    <segment id="23">O começo do jogo fez jus aos grandes duelos entre Flamengo e Corinthians.</segment>
    <segment id="24">Com grande movimentação</segment>
    <segment id="25">, os dois times produziam um bom espetáculo</segment>
    <segment id="26">, com o Timão levando mais perigo.</segment>
    <segment id="27">Felipe trabalhou logo no primeiro minuto e Jorge Henrique acertou a rede pelo lado de fora aos seis.</segment>
    <segment id="28">Petkovic apareceu bem</segment>
    <segment id="29">, com boa movimentação e acertando belos passes.</segment>
    <segment id="30">Quando a partida ameçava dar uma esfriada</segment>
    <segment id="31">, o Corinthians marcou.</segment>
    <segment id="32">Aos 18 minutos</segment>
    <segment id="33">, Weldinho fez bela jogada pela direita</segment>
    <segment id="34">, passou por Egídio e cruzou rasteiro.</segment>
    <segment id="35">William apareceu bem na área e desviou para abrir o placar.</segment>
    <segment id="36">O Flamengo sentiu o gol e a torcida começou a ficar impaciente no Engenhão.</segment>
    <segment id="37">Mas o Fla conseguiu chegar ao empate ainda antes do intervalo.</segment>
    <segment id="38">Aos 39</segment>
    <segment id="39">, Renato cobrou uma falta no melhor estilo Petkovic: forte e colocado</segment>
    <segment id="40">, com perfeição</segment>
    <segment id="41">, fora do alcance do goleiro Júlio César.</segment>
    <segment id="42">Golaço e 1 a 1 no placar.</segment>
    <segment id="43">O fim do primeiro tempo deu início à festa particular de Pet.</segment>
    <segment id="44">O meia sérvio foi abraçado pelos jogadores do Flamengo</segment>
    <segment id="45">, deu a volta olímpica no Engenhão</segment>
    <segment id="46">, recebeu uma placa de Patrícia Amorim e teve o nome gritado pela torcida.</segment>
    <segment id="47">- É muito emocionante.</segment>
    <segment id="48">Jogo difícil</segment>
    <segment id="49">, estamos jogando a valer.</segment>
    <segment id="50">Obrigado à torcida e obrigado ao Flamengo por ter preparado essa homenagem - disse Pet.</segment>
    <segment id="51">Negueba voltou no lugar do meia sérvio para a segunda etapa.</segment>
    <segment id="52">E logo aos quatro minutos o apoiador cabeceou bem após cobrança de escanteio.</segment>
    <segment id="53">Júlio César fez boa defesa.</segment>
    <segment id="54">A partida estava aberta</segment>
    <segment id="55">, masmas aos poucos o ritmo foi caindo.</segment>
    <segment id="56">A rede só balançou quando acertada pelo lado de fora</segment>
    <segment id="57">, em chutes de Diego Maurício e William.</segment>
    <segment id="58">Ronaldinho Gaúcho ainda acertou a trave em bom chute de fora da área e Felipe fez ótima defesa em cabeçada de Leandro Castan.</segment>
    <segment id="59">No fim</segment>
    <segment id="60">, o empate acabou sendo justo para os dois lados.</segment>
    <segment id="61">FLAMENGO 1 x 1 CORINTHIANS
Local: Engenhão</segment>
    <segment id="62">, no Rio de Janeiro (RJ)
Árbitro: Heber Roberto Lopes (PR)</segment>
    <segment id="63">Assistentes: Gilson Bento Coutinho (SP) e Ivan Carlos Bohn (PR)
