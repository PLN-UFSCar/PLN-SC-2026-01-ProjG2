  <rst>
    <segment id="1">Pedestres expulsos da calçada
RIO - A obra de uma construtora vem atrapalhando - e muito - a vida dos pedestres que passam pela Rua Marquês de Abrantes</segment>
    <segment id="2">, no Flamengo.</segment>
    <segment id="3">A construção ocupa parte da calçada</segment>
    <segment id="4">, na altura do número 170.</segment>
    <segment id="5">Nesta quarta-feira</segment>
    <segment id="6">, a calçada chegou a ficar totalmente interditada pela obra</segment>
    <segment id="7">, da Concal.</segment>
    <segment id="8">Por esse motivo</segment>
    <segment id="9">, os pedestres precisaram passar pela pista de rolamento</segment>
    <segment id="10">, dividindo</segment>
    <segment id="11">, perigosamente</segment>
    <segment id="12">, espaço com os veículos.</segment>
    <segment id="13">Muitos deles atravessavam a via com medo.</segment>
    <segment id="14">De acordo com a Secretaria municipal de Urbanismo</segment>
    <segment id="15">, "o tapume</segment>
    <segment id="16">, o barracão e a galeria coberta fazem parte da execução da obra durante a construção do prédio</segment>
    <segment id="17">, garantindo assim uma segurança maior aos pedestres".</segment>
    <segment id="18">A secretaria acrescentou ainda que as instalações estão licenciadas e dentro da lei.</segment>
    <segment id="19">No entanto</segment>
    <segment id="20">, o presidente da construtora</segment>
    <segment id="21">, Conde Caldas</segment>
    <segment id="22">, considerou</segment>
    <segment id="23">comocomo foi um fato isolado a calçada ter sido completamente interditada em frente à construção e</segment>
    <segment id="24">, segundo ele</segment>
    <segment id="25">, aconteceu devido à necessidade de</segment>
    <segment id="26">sese instalar o telhado do barracão que também está sendo erguido.</segment>
    <segment id="27">O presidente da empresa afirma ainda que a lei permite que a parte debaixo da construção ocupe até 50% da calçada</segment>
    <segment id="28">, deixando no máximo até 1</segment>
    <segment id="29">,20 metro livre</segment>
    <segment id="30">, enquanto a parte de cima da obra pode ir até 50 centímetros no meio-fio.

- Não tem</segment>
    <segment id="31">comocomo fazer o telhado sem colocar um andaime.</segment>
    <segment id="32">Se a área não estivesse interditada poderia cair</segment>
    <segment id="33">, por exemplo</segment>
    <segment id="34">, uma telha e atingir um pedestre.</segment>
    <segment id="35">É uma medida de segurança</segment>
    <segment id="36">, não tenho intenção nenhuma de avançar sobre a pista - disse Caldas.</segment>
    <segment id="37">Segundo ele</segment>
    <segment id="38">, a calçada será completamente interditada novamente apenas daqui a 15 meses</segment>
    <segment id="39">, para a retirada das telhas.</segment>
    <segment id="40">Apesar de a obra estar dentro da lei</segment>
    <segment id="41">, segundo a Secretaria de Urbanismo</segment>
    <segment id="42">, a falta de espaço incomoda quem passa pelo local .</segment>
    <segment id="43">- É um absurdo.</segment>
    <segment id="44">Fora o transtorno</segment>
    <segment id="45">, é perigoso.</segment>
    <segment id="46">Passo lá diariamente e acompanho a evolução da obra</segment>
    <segment id="47">, e agora invadiu toda calçada - reclama Antônio Gonçalves</segment>
    <segment id="48">, vice-presidente da Associação de Moradores do Flamengo.</segment>
  </rst>
</analysis>