  <rst>
    <segment id="1">Garotada baiana é porreta
Juniores de Bahia e Vitória estão a um empate das oitavas da Copa São Paulo</segment>
    <segment id="2">Com três empates na primeira fase</segment>
    <segment id="3">, o Flamengo</segment>
    <segment id="4">, atual campeão da Copa São Paulo de Futebol Júnior</segment>
    <segment id="5">, deu adeus à competição deste ano de forma precoce.</segment>
    <segment id="6">Com menos um favorito na disputa</segment>
    <segment id="7">, a dupla Ba-Vi ganha ainda mais fôlego para  buscar este título inédito.</segment>
    <segment id="8">Afinal</segment>
    <segment id="9">, Esquadrãozinho e Leãozinho estão com 100% de aproveitamento em seus respectivos grupos e hoje dependem apenas de um empate para garantir a classificação às oitavas de final e o primeiro lugar .

Tricolores e rubro-negros entram em campo no mesmo horário</segment>
    <segment id="10">, às 4 da tarde.</segment>
    <segment id="11">O Bahia encara o saco de pancadas da chave</segment>
    <segment id="12">, o Nacional</segment>
    <segment id="13">, no Estádio Comendador  Souza</segment>
    <segment id="14">,  em São Paulo.</segment>
    <segment id="15">Já o Vitória está atuando em Campo Limpo Paulista</segment>
    <segment id="16">, no Estádio General Aldévio de Lemos</segment>
    <segment id="17">, e enfrenta o Red Bull.</segment>
    <segment id="18">O Esquadrãozinho tem 6 pontos</segment>
    <segment id="19">, duas vitórias e 8 gols de saldo</segment>
    <segment id="20">, enquanto o Leãozinho está com 6 pontos</segment>
    <segment id="21">, dois triunfos e saldo positivo de 6 gols.</segment>
    <segment id="22">Willie é a arma do Leão na Copinha</segment>
    <segment id="23">A boa campanha do Vitória na Copa São Paulo é fruto do conjunto.</segment>
    <segment id="24">Tanto a defesa quanto o ataque estão cumprindo seus papéis.</segment>
    <segment id="25">Em dois jogos</segment>
    <segment id="26">, o Leão não sofreu gols e balançou as redes adversárias em seis oportunidades.</segment>
    <segment id="27">No entanto</segment>
    <segment id="28">, toda equipe tem jogadores que fazem a diferença.</segment>
    <segment id="29">No rubro-negro sub-18 quem está com a bola toda é Willie.</segment>
    <segment id="30">O atacante marcou gol nas duas partidas do Vitória e</segment>
    <segment id="31">, com dois tentos</segment>
    <segment id="32">, divide a artilharia da equipe ao lado do versátil Mauri</segment>
    <segment id="33">, que joga de meia e de lateral-direito.</segment>
  </rst>
