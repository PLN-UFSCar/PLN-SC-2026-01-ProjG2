  <rst>
    <segment id="1">Jobgol avisa que vai depenar o Galo
Jogador está familiarizado com as redes de Pituaçu e quer ir para a galera</segment>
    <segment id="2">“</segment>
    <segment id="3">Eles [dirigentes do Atlético-MG] estão com medo que eu jogue</segment>
    <segment id="4">, pois</segment>
    <segment id="5">pois eu prometi fazer três gols neles quando os enfrentasse”</segment>
    <segment id="6">, disse Jobson</segment>
    <segment id="7">, que treinou na equipe titular ontem</segment>
    <segment id="8">, empolgado com a chance de enfrentar o seu ex-clube</segment>
    <segment id="9">, no próximo domingo</segment>
    <segment id="10">, em Pituaçu.</segment>
    <segment id="11">A vontade do atacante em participar da partida contagiou a diretoria tricolor</segment>
    <segment id="12">, que já decidiu: Jobson vai enfrentar o Galo Mineiro e ponto!</segment>
    <segment id="13">O clube afirma que</segment>
    <segment id="14">, como</segment>
    <segment id="15">como ele pertence ao Botafogo e não tem mais vínculo algum com o Atlético-MG</segment>
    <segment id="16">, não há motivo</segment>
    <segment id="17">para que</segment>
    <segment id="18">para que o jogador não enfrente o Galo.</segment>
    <segment id="19">Porém, segundo Antenor Joaquim</segment>
    <segment id="20">, empresário de Jobson</segment>
    <segment id="21">, o Atlético</segment>
    <segment id="22">, time para o qual o atleta estava emprestado</segment>
    <segment id="23">, só aceitou rescindir o contrato de empréstimo com o atacante e liberá-lo para o Bahia</segment>
    <segment id="24">casocaso ele não pudesse pegar o clube mineiro.</segment>
    <segment id="25">“Essa cláusula está no contrato</segment>
    <segment id="26">, masmas já estamos conversando com o Atlético e creio que não teremos problema e o Jobson jogará.</segment>
    <segment id="27">O Bahia teria que pagar uma multa</segment>
    <segment id="28">, masmas parece que não será necessário”</segment>
    <segment id="29">, acredita.</segment>
    <segment id="30">Jobson é o destaque do tricolor no Brasileiro e</segment>
    <segment id="31">, segundo a assessoria do Esquadrão</segment>
    <segment id="32">, “para ter o atleta em campo vale a pena comprar briga com o Galo”</segment>
    <segment id="33">, caso</segment>
    <segment id="34">caso eles não liberem o jogador.</segment>
    <segment id="35">Recentemente</segment>
    <segment id="36">, o Bahia</segment>
    <segment id="37">sese envolveu numa briga entre Atlético-MG e Vitória por Nikão.</segment>
    <segment id="38">O jogador</segment>
    <segment id="39">, que estava no Leão</segment>
    <segment id="40">,  como</segment>
    <segment id="41">como represália</segment>
    <segment id="42">, foi  emprestado ao Bahia.</segment>
    <segment id="43">Mas agora a diretoria do Galo ameaça  pegar Nikão de volta ou até emprestá-lo novamente ao Vitória</segment>
    <segment id="44">casocaso Jobson jogue domingo.</segment>
    <segment id="45">Diones pronto para deixar Bahia bem tremendão</segment>
    <segment id="46">Com Marcone sentindo a coxa direita e entregue ao Departamento Médico</segment>
    <segment id="47">, um dos principais destaques do Bahia de Feira no Campeonato Baiano</segment>
    <segment id="48">, o volante Diones finalmente terá a sua chance de estrear com a camisa do Esquadrão.</segment>
    <segment id="49">O jogador</segment>
    <segment id="50">sese mostrou empolgado e afirmou estar pronto para honrar o manto tricolor.</segment>
    <segment id="51">“Estou esperando essa oportunidade há bastante tempo e espero agarrar essa chance.</segment>
    <segment id="52">Tenho quase um mês aqui e já estou bastante entrosado”</segment>
    <segment id="53">, disse.</segment>
    <segment id="54">Segundo ele</segment>
    <segment id="55">, a camisa não vai pesar.</segment>
    <segment id="56">“Já vim para o Bahia sabendo das responsabilidades</segment>
    <segment id="57">, da pressão da torcida.</segment>
    <segment id="58">Espero ajudar o time a conquistar os três primeiros pontos”.</segment>
    <segment id="59">Diones aproveitou para falar sobre a sua função no time.</segment>
    <segment id="60">“René já conversou comigo e disse que era para eu dar prioridade à marcação.</segment>
    <segment id="61">Mas quando tivermos a bola</segment>
    <segment id="62">, devo procurar armar as jogadas e ajudar lá na frente”</segment>
    <segment id="63">, contou.</segment>
  </rst>
</analysis>