  <rst>
    <segment id="1">Empolgante</segment>
    <segment id="2">, Bahia atropela mais um</segment>
    <segment id="3">Com toque de bola refinado</segment>
    <segment id="4">, tricolor goleia o Camaçari de virada e recebe aplausos</segment>
    <segment id="5">Na volta do Caveirão</segment>
    <segment id="6">, que alcançou a marca de onze gols no Campeonato Baiano</segment>
    <segment id="7">, o Bahia deu mais um show de bola no estádio de Pituaçu.</segment>
    <segment id="8">Dessa vez</segment>
    <segment id="9">, o time de Falcão fez uma de suas melhores partidas da atual temporada na noite de ontem</segment>
    <segment id="10">, com uma sonora goleada de virada sobre o Camaçari: 5 a 1</segment>
    <segment id="11">, sem piedade!</segment>
    <segment id="12">O primeiro jogo do returno do Baianão começou de forma estranha.</segment>
    <segment id="13">Logo aos dois minutos</segment>
    <segment id="14">, Omar falhou após cruzamento na área e viu Gilberto mandar para o gol e abrir o placar para os visitantes.</segment>
    <segment id="15">Só que o Esquadrão não</segment>
    <segment id="16">sese abateu e partiu para cima</segment>
    <segment id="17">, principalmente com Gabriel</segment>
    <segment id="18">, que chegou a acertar o travessão em bela jogada.</segment>
    <segment id="19">Aos 24 minutos</segment>
    <segment id="20">, o Camaça não resistiu: Magno lançou William Matheus</segment>
    <segment id="21">, que cruzou para Júnior estufar a rede de cabeça e empatar o jogo.</segment>
    <segment id="22">A virada veio aos 33 minutos</segment>
    <segment id="23">, quando Gabriel</segment>
    <segment id="24">, o garçom</segment>
    <segment id="25">, deixou Magno na cara do gol: 2 a 1.</segment>
    <segment id="26">No início do segundo tempo</segment>
    <segment id="27">, Rafael Donato aproveitou sobra de bola na área e cabeceou para marcar o terceiro.</segment>
    <segment id="28">Aos dez</segment>
    <segment id="29">, a zaga do Camaçari falhou e Magno serviu para Souza</segment>
    <segment id="30">, que marcou o quarto.</segment>
    <segment id="31">O Caveirão ainda brocou mais um</segment>
    <segment id="32">, aos 31</segment>
    <segment id="33">, com um chute na saída do goleiro Rodrigo.</segment>
    <segment id="34">Com o triunfo</segment>
    <segment id="35">, o Bahia segue isolado na liderança do Estadual</segment>
    <segment id="36">, com 29 pontos conquistados.</segment>
    <segment id="37">Neste domingo</segment>
    <segment id="38">, o tricolor enfrenta o Fluminense em Feira de Santana para seguir soberano na ponta da tabela.</segment>
  </rst>
</analysis>