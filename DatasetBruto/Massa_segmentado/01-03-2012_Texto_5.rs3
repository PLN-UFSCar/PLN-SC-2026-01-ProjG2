  <rst>
    <segment id="1">Mirella quer ser chique</segment>
    <segment id="2">Focada na carreira de repórter e prestes a subir ao altar a moça quer</segment>
    <segment id="3">sese consertar</segment>
    <segment id="4">Quando Mirella Santos resolveu tirar as lentes azuis</segment>
    <segment id="5">, o comentário foi que a loira estaria disposta a</segment>
    <segment id="6">sese livrar de algumas ‘marcas’.</segment>
    <segment id="7">Focada na carreira de repórter e prestes a subir ao altar com o humorista Ceará</segment>
    <segment id="8">, ela disse ao jornal “Extra” que não quer ter um estilo.</segment>
    <segment id="9">“Por que não posso ser</segment>
    <segment id="10">comocomo a Adriane Galisteu</segment>
    <segment id="11">, que posa para a ‘Playboy’</segment>
    <segment id="12">, masmas sabe ser chique?</segment>
    <segment id="13">".</segment>
