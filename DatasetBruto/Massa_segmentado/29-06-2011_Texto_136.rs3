  <rst>
    <segment id="1">Regina Casé será cidadã soteropolitana</segment>
    <segment id="2">A atriz vira e mexe divulga a cultura do estado pelos quatro cantos do mundo</segment>
    <segment id="3">A Bahia está na vida da apresentadora do “Esquenta” há muito tempo.</segment>
    <segment id="4">Amiga de longa data de Gilberto Gil e Caetano Veloso</segment>
    <segment id="5">, a atriz vira e mexe divulga a cultura do estado pelos quatro cantos do mundo.</segment>
    <segment id="6">Por conta disso</segment>
    <segment id="7">, ela  receberá o título de Cidadã Soteropolitana.</segment>
    <segment id="8">Segundo o site oficial de Regina</segment>
    <segment id="9">, a solenidade vai rolar em janeiro</segment>
    <segment id="10">, quando ela e a família vêm de férias para Salvador.</segment>
