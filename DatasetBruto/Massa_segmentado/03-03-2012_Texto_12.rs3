  <rst>
    <segment id="1">Viúvas também querem a GAP</segment>
    <segment id="2">Deputados votaam proejeto de reajuste.</segment>
    <segment id="3">Pensionistas reclamam</segment>
    <segment id="4">porque</segment>
    <segment id="5">porque ficaram de fora
Não fosse a ajuda dos cinco filhos</segment>
    <segment id="6">, a pensionista  Eunice Ferreira Pinto</segment>
    <segment id="7">, 90 anos</segment>
    <segment id="8">, passaria por maus bocados.</segment>
    <segment id="9">Os R$ 860</segment>
    <segment id="10">, salário bruto</segment>
    <segment id="11">, que recebe de pensão do marido que era soldado da PM</segment>
    <segment id="12">, pagam as contas e os remédios.</segment>
    <segment id="13">Só com medicação</segment>
    <segment id="14">, Eunice gasta R$ 278 por mês para tratar de hipertensão e problemas de  circulação.</segment>
    <segment id="15">Assim, os filhos precisam ajudar nas despesas com a  alimentação.</segment>
    <segment id="16">Apesar da idade</segment>
    <segment id="17">, Eunice está lúcida e opina sobre a exclusão dos pensionistas no projeto  da Gratificação de Atividade Policial (GAP) 4 e 5.</segment>
    <segment id="18">“É uma injustiça.</segment>
    <segment id="19">Quando meu marido era

vivo</segment>
    <segment id="20">, o dinheiro dava para viver sem  aperto”</segment>
    <segment id="21">, afirma ela</segment>
    <segment id="22">,  pensionista há 46 anos.</segment>
    <segment id="23">Já Cecília Jesus das Virgens</segment>
    <segment id="24">, 40, perdeu o marido em outubro de 2011.</segment>
    <segment id="25">O soldado Robério das Virgens morreu em tiroteio com traficantes em Canabrava.</segment>
    <segment id="26">“Só quem passa é quem sabe.</segment>
    <segment id="27">É uma perda irreparável.</segment>
    <segment id="28">Além da dor</segment>
    <segment id="29">, vêm as dificuldades financeiras”</segment>
    <segment id="30">, lamenta.</segment>
    <segment id="31">Cecília conta que o marido</segment>
    <segment id="32">, que serviu à PM por 23 anos</segment>
    <segment id="33">, recebia R$ 4.463</segment>
    <segment id="34">, masmas a pensão  é de R$ 2.400.</segment>
    <segment id="35">“</segment>
    <segment id="36">A gente aperta de um lado e aperta do outro para não passar fome.</segment>
    <segment id="37">Um dos cortes que tive que fazer foi tirar minha filha do transporte escolar”</segment>
    <segment id="38">, conta a mãe de três filhos: dois rapazes de 18 e  19 anos  e a garota de 13.</segment>
    <segment id="39">Cecília está  indignada com  a exclusão dos pensionistas do projeto.</segment>
    <segment id="40">“É um absurdo!</segment>
    <segment id="41">Meu marido já tinha direito a essa gratificação desde 1997.</segment>
    <segment id="42">Por que a gente vai ficar de fora?</segment>
    <segment id="43">”, questiona.</segment>
    <segment id="44">A lei que criou a GAP é de 1997.</segment>
    <segment id="45">Hoje, o governo só paga  até a GAP 3.</segment>
    <segment id="46">Luta persiste há 23 anos</segment>
    <segment id="47">A presidente da Associação dos Pensionistas Reservas e Aposentados dos Servidores Públicos da Bahia (Apraspeba)</segment>
    <segment id="48">, Maria da Paixão</segment>
    <segment id="49">, reclama da ausência de representante da categoria na elaboração dos projetos de reajuste dos servidores.</segment>
    <segment id="50">“</segment>
    <segment id="51">Ninguém convoca as pensionistas daqueles que deram a vida para servir à sociedade”</segment>
    <segment id="52">, desabafa.</segment>
    <segment id="53">Para ela</segment>
    <segment id="54">, a inclusão dos pensionistas e policiais da reserva no projeto de pagamento da GAP 4 e 5 é a chance de corrigir os baixos salários.</segment>
    <segment id="55">“Buscamos a correção dos benefícios na Justiça</segment>
    <segment id="56">, masmas demora muito”</segment>
    <segment id="57">, afirma Maria</segment>
    <segment id="58">, que busca uma revisão da pensão há 23 anos</segment>
    <segment id="59">, desde quando fundou a associação.</segment>
  </rst>
</analysis>