  <rst>
    <segment id="1">Bolsa de bebê levava pasta base de coca</segment>
    <segment id="2">A casa caiu: X-9 entregou Shirley e Karina</segment>
    <segment id="3">Uma mochilinha de bebê.</segment>
    <segment id="4">Esse foi o disfarce usado por Shirley Santana de Araújo</segment>
    <segment id="5">, 26 anos</segment>
    <segment id="6">, para esconder três tabletes de pasta base de cocaína.</segment>
    <segment id="7">Shirley foi presa na tarde da última sexta-feira</segment>
    <segment id="8">, no bairro da Boca do Rio</segment>
    <segment id="9">, perto do Multishop.</segment>
    <segment id="10">Cada tablete pesa cerca de 1 kg.</segment>
    <segment id="11">Policiais civis da Delegacia de Repressão a Tóxicos e Entorpecentes (DTE) conseguiram prender Shirley após denúncia de que uma mulher teria embarcado em um táxi com uma sacola cheia de droga</segment>
    <segment id="12">, rumo à avenida Pinto de Aguiar.</segment>
    <segment id="13">Após a prisão da jovem</segment>
    <segment id="14">, os policiais localizaram a casa de Karina da Silva Bonfim</segment>
    <segment id="15">, 25, na Vila São Jorge</segment>
    <segment id="16">, bairro de São Rafael</segment>
    <segment id="17">, em uma região conhecida</segment>
    <segment id="18">comocomo Casinhas da Chesf.</segment>
    <segment id="19">Na residência de Karina</segment>
    <segment id="20">, foram apreendidos mais sete tabletes de pasta base de cocaína</segment>
    <segment id="21">, em uma mochila.</segment>
    <segment id="22">Na delegacia</segment>
    <segment id="23">, Shirley disse que “Karina é inocente”.</segment>
    <segment id="24">Traficantes ficaram no preju!</segment>
    <segment id="25">Droga vale R$ 200 mil

Shirley e Karina disseram que não têm filhos.</segment>
    <segment id="26">Elas não quiseram informar onde adquiriram a mochila de bebê.</segment>
    <segment id="27">De acordo com Odair Carneiro</segment>
    <segment id="28">, chefe de investigação da DTE</segment>
    <segment id="29">, os maridos de Shirley e Karina são irmãos.</segment>
    <segment id="30">Segundo ele</segment>
    <segment id="31">, um quilo de pasta base produz 5 quilos de cocaína.</segment>
    <segment id="32">Como cada tablete apreendido vale R$ 20 mil</segment>
    <segment id="33">, os traficantes sofreram um prejuízo de R$ 200 mil.</segment>
    <segment id="34">Shirley foi presa em 2008</segment>
    <segment id="35">, acusada de roubo a coletivo.</segment>
  </rst>
</analysis>