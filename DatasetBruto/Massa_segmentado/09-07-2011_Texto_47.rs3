  <rst>
    <segment id="1">Grupo de 34 universitários visita três favelas pacificadas e cria blog
RIO - Algo mais consistente do que apenas curiosidade move um novo perfil de turistas estrangeiros que têm visitado favelas cariocas</segment>
    <segment id="2">, especialmente as comunidades Cantagalo</segment>
    <segment id="3">, em Ipanema</segment>
    <segment id="4">, e Pavão e Pavãozinho</segment>
    <segment id="5">, em Copacabana</segment>
    <segment id="6">, já pacificadas.</segment>
    <segment id="7">São universitários americanos</segment>
    <segment id="8">, de diferentes estados</segment>
    <segment id="9">, interessados em conhecer de perto a realidade dos moradores.</segment>
    <segment id="10">O grupo mais recente</segment>
    <segment id="11">, com 34 jovens</segment>
    <segment id="12">, ainda está no Rio</segment>
    <segment id="13">, para uma estada de seis semanas</segment>
    <segment id="14">, quando embarca para a Flórida.</segment>
    <segment id="15">Agora, a viagem da turma (18 rapazes e 16 moças) servirá de ponto de partida para o lançamento do projeto "Understanding a favela"</segment>
    <segment id="16">, um blog permanente que reunirá os depoimentos dos estudantes que</segment>
    <segment id="17">, a partir de agora</segment>
    <segment id="18">, visitarem as três comunidades.</segment>
    <segment id="19">A ideia é que os relatos sirvam de estímulo</segment>
    <segment id="20">para que</segment>
    <segment id="21">para que outros turistas queiram</segment>
    <segment id="22">, além de conhecer</segment>
    <segment id="23">, até se</segment>
    <segment id="24">se hospedar nestas áreas.</segment>
    <segment id="25">Entusiasmados com a visita ao Pavão</segment>
    <segment id="26">, Pavãozinho e Cantagalo</segment>
    <segment id="27">, alguns deles já deixaram suas impressões por e-mail</segment>
    <segment id="28">, que serão lançadas no blog (no ar em agosto)</segment>
    <segment id="29">, sob os cuidados de um grupo de moradores.</segment>
    <segment id="30">"</segment>
    <segment id="31">Sem dúvida</segment>
    <segment id="32">, foi a minha parte favorita da viagem.</segment>
    <segment id="33">Ver o cotidiano de homens</segment>
    <segment id="34">, mulheres e crianças que vivem nas favelas me ajudou a perceber as coisas importantes da vida.</segment>
    <segment id="35">Nos Estados Unidos</segment>
    <segment id="36">, é tão fácil para esquecermos as coisas simples da vida</segment>
    <segment id="37">, que trazem felicidade</segment>
    <segment id="38">, não dinheiro ou bens materiais.</segment>
    <segment id="39">De longe</segment>
    <segment id="40">, a parte mais memorável da visita foi quando nosso grupo dançou com pessoas que vivem na favela"</segment>
    <segment id="41">, relatou Taylor Conway</segment>
    <segment id="42">, da Universidade de Illinois.</segment>
    <segment id="43">A impressão de Dana DeSutter</segment>
    <segment id="44">, também de Illinois</segment>
    <segment id="45">, foi semelhante</segment>
    <segment id="46">, segundo o que escreveu:</segment>
    <segment id="47">"</segment>
    <segment id="48">Quero agradecer a maravilhosa oportunidade de conhecer a favela.</segment>
    <segment id="49">Primeiro</segment>
    <segment id="50">, estava um pouco nervosa e cética sobre a visita.</segment>
    <segment id="51">Eu não sabia o que esperar.</segment>
    <segment id="52">Tinha lido um pouco sobre as favelas cariocas na universidade e tinha ouvido falar que havia muita violência.</segment>
    <segment id="53">Isso me assustou.</segment>
    <segment id="54">Mas minhas opiniões mudaram e meu medo desapareceu.</segment>
    <segment id="55">Minha parte favorita foi ver as crianças tocando música e falando frases em inglês.</segment>
    <segment id="56">Eu, realmente</segment>
    <segment id="57">, abri meus olhos e agora vejo a favela de forma diferente do que via antes de ter ido lá.</segment>
    <segment id="58">Foi uma experiência incrível.</segment>
    <segment id="59">"
Maioria dos visitantes estuda ciências sociais nos EUA</segment>
    <segment id="60">Os jovens</segment>
    <segment id="61">, que permanecem no Rio até 5 de agosto</segment>
    <segment id="62">, pertencem a diferentes universidades americanas e a maioria cursa ciências sociais.</segment>
    <segment id="63">Eles se</segment>
    <segment id="64">se inscreveram nos programas das universidades da Flórida e de Washington (Georgetown)</segment>
    <segment id="65">, que mantêm parceria com o curso de inglês Ibeu</segment>
    <segment id="66">para que</segment>
    <segment id="67">para que os alunos tenham aulas de português durante a estada no Rio.</segment>
    <segment id="68">Para isso</segment>
    <segment id="69">, eles precisam cursar pelo menos um ano do idioma em suas instituições.</segment>
    <segment id="70">No Rio</segment>
    <segment id="71">, além do curso</segment>
    <segment id="72">, a coordenadora educacional do Ibeu</segment>
    <segment id="73">, Libby Ginway</segment>
    <segment id="74">, conta que decidiu introduzir a favela</segment>
    <segment id="75">comocomo tema múltiplo de discussões durante as aulas.
- A favela pode ser debatida sob a ótica de urbanismo</segment>
    <segment id="76">, antropologia</segment>
    <segment id="77">, ciências sociais e políticas</segment>
    <segment id="78">, religião</segment>
    <segment id="79">, arquitetura</segment>
    <segment id="80">, história e administração de negócios</segment>
    <segment id="81">, por exemplo.</segment>
    <segment id="82">Como os alunos têm muito interesse no tema</segment>
    <segment id="83">, incluímos visitas</segment>
    <segment id="84">para que</segment>
    <segment id="85">para que conhecessem as comunidades de perto - conta a professora</segment>
    <segment id="86">, que transforma a experiência de ter visitado uma favela também em apresentações individuais dos alunos em sala de aula.</segment>
    <segment id="87">A visita teve o incentivo do empresário Daniel Plá</segment>
    <segment id="88">, diretor da Associação Comercial do Rio e professor universitário.</segment>
    <segment id="89">Como já realiza trabalho voluntário no Cantagalo</segment>
    <segment id="90">, ensinando inglês para crianças</segment>
    <segment id="91">, ele organizou uma programação para os estudantes americanos</segment>
    <segment id="92">, que fizeram um passeio de cinco horas às três áreas pacificadas</segment>
    <segment id="93">, onde comeram feijoada</segment>
    <segment id="94">, conversaram com moradores</segment>
    <segment id="95">, percorreram ruas</segment>
    <segment id="96">, becos e uma trilha</segment>
    <segment id="97">, além de assistir a apresentações de funk e samba.</segment>
    <segment id="98">Subiram em táxis e desceram pelo elevador.
- Queríamos que andassem pelas ruas</segment>
    <segment id="99">, conversassem com os moradores e tiveram contato com a realidade da comunidade</segment>
    <segment id="100">, mesmo que por poucas horas - contou Plá</segment>
    <segment id="101">, que esta semana levará o grupo ao Morro Dona Marta</segment>
    <segment id="102">, em Botafogo.</segment>
    <segment id="103">Mas os americanos não estiveram apenas em áreas pacificadas.</segment>
    <segment id="104">O grupo visitou a Rocinha</segment>
    <segment id="105">, onde o esquema de entrada foi bem diferente.</segment>
    <segment id="106">Eles percorreram a área dentro de vans</segment>
    <segment id="107">, das quais desceram apenas na parte baixa da favela</segment>
    <segment id="108">, que não tem UPP.</segment>
    <segment id="109">O passeio teve cerca de duas horas de duração.</segment>
    <segment id="110">Apesar do tempo reduzido</segment>
    <segment id="111">, Alex Honjiyo</segment>
    <segment id="112">, de 20 anos</segment>
    <segment id="113">, de Washington</segment>
    <segment id="114">, percebeu diferenças</segment>
    <segment id="115">, uma delas foi ter visto um traficante armado com um fuzil na Rocinha.
- Na área pacificada</segment>
    <segment id="116">, pudemos ter contato com os moradores e não vi a presença do tráfico</segment>
    <segment id="117">, masmas acho que o projeto UPP ainda pode fazer mais pelos moradores do que apenas segurança</segment>
    <segment id="118">, atuando na questão social - diz ele</segment>
    <segment id="119">, que acompanhava os discursos de Dilma</segment>
    <segment id="120">, ainda candidata</segment>
    <segment id="121">, pela internet - Ela dizia que a UPP mudaria tudo.</segment>
    <segment id="122">Ainda não é bem assim.</segment>
    <segment id="123">Já Devin Oliver</segment>
    <segment id="124">, de 20</segment>
    <segment id="125">, que estuda geografia em Ohio</segment>
    <segment id="126">, disse que o tour rompeu com seus preconceitos:
- Só ouvia falar sobre os perigos e nada sobre a cultura.</segment>
    <segment id="127">Ache que seria recebido</segment>
    <segment id="128">comocomo forasteiro</segment>
    <segment id="129">, masmas isso não ocorreu no Cantagalo.</segment>
    <segment id="130">Já na Rocinha</segment>
    <segment id="131">, me senti um turista.</segment>
  </rst>
</analysis>