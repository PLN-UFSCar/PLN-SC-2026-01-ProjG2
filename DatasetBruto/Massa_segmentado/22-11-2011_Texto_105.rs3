  <rst>
    <segment id="1">Próximo passo de Giane
Reynaldo Gianecchini vai fazer autotransplante de medula óssea para tentar</segment>
    <segment id="2">sese curar</segment>
    <segment id="3">O ator Reynaldo Gianecchini  vai passar por um tratamento especial em dezembro</segment>
    <segment id="4">, chamado autotransplante de medula óssea.</segment>
    <segment id="5">De acordo com o médico hematologista Vítor Hugo Souza</segment>
    <segment id="6">, o procedimento é válido no</segment>
    <segment id="7">casocaso do ator</segment>
    <segment id="8">, que possui um câncer nos gânglios linfáticos</segment>
    <segment id="9">, o chamado linfoma.</segment>
    <segment id="10">“</segment>
    <segment id="11">Este processo consiste na retirada da medula óssea do próprio paciente</segment>
    <segment id="12">, que contém células-tronco.</segment>
    <segment id="13">A pessoa faz isso para poder passar por uma quimioterapia mais forte que as sessões normais.</segment>
    <segment id="14">Depois disso</segment>
    <segment id="15">, as células da medula são novamente injetadas no corpo e o organismo volta a produzir sangue normalmente”</segment>
    <segment id="16">, explica o médico.</segment>
    <segment id="17">O procedimento é diferente do transplante de medula feito em pacientes com doenças</segment>
    <segment id="18">comocomo a leucemia.</segment>
    <segment id="19">Nesses casos</segment>
    <segment id="20">, é retirada a medula de uma pessoa e colocada no paciente.</segment>
    <segment id="21">“</segment>
    <segment id="22">O transplante alopático -</segment>
    <segment id="23">comocomo é chamado - é bastante eficiente no tratamento da leucemia</segment>
    <segment id="24">, podendo até curar a doença.</segment>
    <segment id="25">Mas no tratamento do linfoma</segment>
    <segment id="26">, o mais comum é fazer o autotransplante</segment>
    <segment id="27">, que  não dá certeza de cura do câncer</segment>
    <segment id="28">, masmas pode garantir  até 5 anos sem a doença voltar”.</segment>
    <segment id="29">Segundo o médico</segment>
    <segment id="30">, apenas 3% dos pacientes que fazem o autotransplante  de medula morrem após o procedimento.</segment>
    <segment id="31">O que vem depois:</segment>
    <segment id="32">Corpo fica sem defesa</segment>
    <segment id="33">Depois de passar pelo autotransplante de medula óssea</segment>
    <segment id="34">,  Gianecchini vai  ser acompanhado pelos médicos</segment>
    <segment id="35">, pois</segment>
    <segment id="36">pois todo o sistema de defesa do corpo voltará a ser</segment>
    <segment id="37">comocomo o de um bebê.</segment>
    <segment id="38">“</segment>
    <segment id="39">O paciente perde toda a resistência às doenças que já teve na vida</segment>
    <segment id="40">, como</segment>
    <segment id="41">como gripe  e catapora.</segment>
    <segment id="42">Somente depois de  um tempo de resguardo e uma série de vacinas e adaptações ele ficará com um corpo mais resistente”</segment>
    <segment id="43">, diz o hematologista Vítor Hugo Souza.</segment>
    <segment id="44">Procedimento é feito na Bahia</segment>
    <segment id="45">Na capital baiana</segment>
    <segment id="46">, o Hospital das Clínicas é referência no tratamento do câncer por meio de implantes de medula óssea.</segment>
    <segment id="47">“</segment>
    <segment id="48">Existe uma equipe preparada que tem obtido sucesso nos transplantes</segment>
    <segment id="49">, feitos pelo SUS e acessíveis à população”</segment>
    <segment id="50">, diz doutor Vítor.</segment>
  </rst>
</analysis>