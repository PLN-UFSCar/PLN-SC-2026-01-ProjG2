  <rst>
    <segment id="1">Festa de gala aos craques da bola!</segment>
    <segment id="2">Federação organiza festa dos melhores do Baiano e o Bahia de Feira brilha

Depois de 114 jogos emocionantes</segment>
    <segment id="3">, 316 gols</segment>
    <segment id="4">, e um campeão inédito</segment>
    <segment id="5">, a Federação Bahiana de Futebol realizou ontem à noite uma festa de gala para comemorar o encerramento do Campeonato Baiano 2011</segment>
    <segment id="6">, na Casa do Comércio</segment>
    <segment id="7">, no Caminho das Árvores.</segment>
    <segment id="8">Os melhores do Estadual entre jogadores</segment>
    <segment id="9">, técnicos e árbitros foram as estrelas da noite</segment>
    <segment id="10">, que contou com a presença de  dirigentes</segment>
    <segment id="11">, torcedores e ilustres baianos.
Campeões pela primeira vez</segment>
    <segment id="12">, os atletas do Bahia de Feira estavam bem alinhados e chegaram juntos</segment>
    <segment id="13">, de buzu</segment>
    <segment id="14">, para a noite especial.</segment>
    <segment id="15">Arnaldo Lira</segment>
    <segment id="16">, que além do título foi eleito o melhor treinador do Baianão</segment>
    <segment id="17">, era só sorrisos e estava cheio de pompa</segment>
    <segment id="18">, em uma beca azul</segment>
    <segment id="19">, vermelha e branca</segment>
    <segment id="20">, ao lado da mulher</segment>
    <segment id="21">, Patricia.</segment>
    <segment id="22">Os campeões esperaram calmamente todas as premiações da noite até serem chamados juntos para uma inesquecível comemoração no palco.</segment>
    <segment id="23">Teve entrega de troféu para árbitros</segment>
    <segment id="24">, torcidas organizadas (Bamor</segment>
    <segment id="25">, Imbatíveis e Criptonita)</segment>
    <segment id="26">, vários prêmios individuais para jogadores</segment>
    <segment id="27">, muita emoção e brincadeira em meio aos ilustres que compareceram</segment>
    <segment id="28">, como</segment>
    <segment id="29">como os cantores Xanddy e Tatau</segment>
    <segment id="30">, e o ex-jogador Maílson.</segment>
    <segment id="31">Teve ainda a escolha da revelação e do craque</segment>
    <segment id="32">, até que os heróis do Baianão foram chamados para receber o merecido troféu de campeões da Primeira Divisão do Baiano</segment>
    <segment id="33">, com direito a Olodum cantando o hino do Tremendão</segment>
    <segment id="34">,  para  coroar a  incrível história que eles escreveram!</segment>
    <segment id="35">Seleção do Baiano</segment>
    <segment id="36">Goleiro
Jair: Bahia de Feira</segment>
    <segment id="37">Lateral-direito</segment>
    <segment id="38">Nino: Vitória</segment>
    <segment id="39">Zagueiro
Alison: Vitória</segment>
    <segment id="40">Zagueiro
Titi: Bahia
Lateral-esquerdo
Ávine: Bahia
Volante
Marcone: Bahia
Volante
Uelliton: Vitória</segment>
    <segment id="41">Meia
Nikão:</segment>
    <segment id="42">Vitória
Meia
Bruninho: Bahia de Feira
Atacante
Sassá: Ipitanga
Atacante
João Neto: Bahia/FS

Melhor técnico tem folga longa até a Série D</segment>
    <segment id="43">A CBF divulgou ontem a tabela da Série D do Brasileiro.</segment>
    <segment id="44">E Arnaldo Lira tem até 17 de julho  para a estreia do Bahia de Feira</segment>
    <segment id="45">, que  caiu no grupo com Vitória da Conquista</segment>
    <segment id="46">, Coruripe-AL e  dois clubes a serem definidos</segment>
    <segment id="47">, um sergipano e outro da Paraíba.</segment>
    <segment id="48">Craque e revelação são do Leão</segment>
    <segment id="49">O escolhido</segment>
    <segment id="50">comocomo craque do Baianão foi o zagueiro Alison</segment>
    <segment id="51">, do Vitória</segment>
    <segment id="52">, que recebeu bonita homenagem.</segment>
    <segment id="53">A revelação foi  Mineiro.</segment>
    <segment id="54">Só bola na rede</segment>
    <segment id="55">Os artilheiros foram Sassá (Ipitanga) e Geovanni (Vitória)</segment>
    <segment id="56">, com 10 gols cada.</segment>
    <segment id="57">Felipe Adão</segment>
    <segment id="58">, do Vitória da Conquista</segment>
    <segment id="59">, foi o autor do gol mais bonito!</segment>
  </rst>
</analysis>