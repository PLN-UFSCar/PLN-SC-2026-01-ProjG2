  <rst>
    <segment id="1">Botafogo perde para o Santos por 2 a 0 e não assume a liderança do Brasileiro
RIO - O Botafogo desperdiçou sua melhor chance de assumir a liderança no Brasileiro.</segment>
    <segment id="2">Com falhas na defesa</segment>
    <segment id="3">, muitos erros de passe e sem conseguir criar jogadas para a conclusão de Loco Abreu</segment>
    <segment id="4">, o time de Caio Júnior perdeu por 2 a 0 para o Santos</segment>
    <segment id="5">, na Vila Belmiro.</segment>
    <segment id="6">Os dois gols foram marcados no primeiro tempo</segment>
    <segment id="7">, com Neymar e Borges.</segment>
    <segment id="8">O jogo isolado do Brasileiro foi válido pela 21ª rodada do campeonato.</segment>
    <segment id="9">Com o resultado</segment>
    <segment id="10">, o Botafogo permanece na terceira posição com 52 pontos.</segment>
    <segment id="11">O Santos fica com 41 pontos e a três pontos de não correr risco de ser rebaixado.</segment>
    <segment id="12">No sábado</segment>
    <segment id="13">, o Botafogo pega o Avaí</segment>
    <segment id="14">, em Santa Catarina.</segment>
    <segment id="15">No domingo</segment>
    <segment id="16">, o Santos viaja ao Rio para enfrentar o Flamengo.</segment>
    <segment id="17">O Botafogo precisava vencer o Santos para alcançar a liderança</segment>
    <segment id="18">, masmas Caio Júnior optou por dois jogadores que são menos ofensivos que os titulares habituais.</segment>
    <segment id="19">Alessandro começou no lugar de Lucas e Herrera saiu para a entrada de Felipe Menzes.</segment>
    <segment id="20">Além deles</segment>
    <segment id="21">, Bruno Tiago substituiu Renato</segment>
    <segment id="22">, suspenso pelo terceiro cartão amarelo.</segment>
    <segment id="23">E Bruno Tiago foi o grande personagens dos primeiros 20 minutos.</segment>
    <segment id="24">Encarregado de marcar</segment>
    <segment id="25">Neymar</segment>
    <segment id="26">, o volante levou cartão amarelo em sua primeira falta</segment>
    <segment id="27">, logos aos três minutos.</segment>
    <segment id="28">Nervoso</segment>
    <segment id="29">, Bruno Tiago errava passes curtos.</segment>
    <segment id="30">Aos 16</segment>
    <segment id="31">, Neymar avançou sob os cuidados de três jogadores do Botafogo.</segment>
    <segment id="32">O atacante santista não tomou conhecimento de Bruno Tiago e o driblou duas vezes antes de chutar no canto de Jefferson.</segment>
    <segment id="33">Um golaço.</segment>
    <segment id="34">Três minutos depois</segment>
    <segment id="35">, Caio Júnior tirou Bruno Tiago para a entrada de Léo.</segment>
    <segment id="36">O gol acordou o Botafogo</segment>
    <segment id="37">, que passou a pressionar.</segment>
    <segment id="38">Maicosuel teve duas oportunidades livre na área</segment>
    <segment id="39">, masmas não conseguiu matar a bola ou chutar para o gol.</segment>
    <segment id="40">Do outro lado</segment>
    <segment id="41">, o Santos era eficiente.</segment>
    <segment id="42">Borges recebeu de costas e girou sobre Fábio Ferreira</segment>
    <segment id="43">, ele chutou forte de muito longe e a bola bateu na trave antes de entrar.</segment>
    <segment id="44">Mais um golaço do Santos: 2 a 0.</segment>
    <segment id="45">Com 22 gols no Brasileiro</segment>
    <segment id="46">, Borges</segment>
    <segment id="47">sese tornou o maior goleador do Santos em Brasileiros ao lado de Serginho</segment>
    <segment id="48">, na campanha de 1983.</segment>
    <segment id="49">Logo depois</segment>
    <segment id="50">, Borges sentiu uma pancada e foi substituído.</segment>
    <segment id="51">Ao deixar o campo</segment>
    <segment id="52">, ele levou o cartão amarelo e está suspenso para a partida contra o Flamengo</segment>
    <segment id="53">, no próximo domingo.</segment>
    <segment id="54">O Botafogo voltou em campo sem Elkeson</segment>
    <segment id="55">, que esteve apagado no primeiro tempo.</segment>
    <segment id="56">Em seu lugar entrou Herrera.</segment>
    <segment id="57">Apesar de melhorar</segment>
    <segment id="58">, foi o Santos quem teve as duas primeiras boas chances de gol.</segment>
    <segment id="59">Aos 7, Arouca cruzou e Allan Kardec cabeceou muito bem.</segment>
    <segment id="60">Jefferson faz grande defesa.</segment>
    <segment id="61">Aos 14</segment>
    <segment id="62">, Rentería puxou contra-ataque e tocou para Neymar na área</segment>
    <segment id="63">, que chutou cruzado e a bola passou muito perto do gol.</segment>
    <segment id="64">O Botafogo ainda melhorou e teve chances em chutes de Felipe Menezes de fora da área</segment>
    <segment id="65">, aos 15 e 17</segment>
    <segment id="66">, e em cabeçada da Fábio Ferreira</segment>
    <segment id="67">, aos 30</segment>
    <segment id="68">, masmas não conseguiu fazer o gol de honra.</segment>
    <segment id="69">Santos 2 x 0</segment>
    <segment id="70">Botafogo

Local: Vila Belmiro</segment>
    <segment id="71">,em Santos (SP)

Santos: Rafael</segment>
    <segment id="72">;Danilo</segment>
    <segment id="73">, Edu Dracena</segment>
    <segment id="74">, Bruno Rodrigo e Durval</segment>
    <segment id="75">;</segment>
    <segment id="76">Adriano (Ibson)</segment>
    <segment id="77">, Henrique e Arouca</segment>
    <segment id="78">; Borges (Rentería)</segment>
    <segment id="79">, Alan Kardec e Neymar.

Botafogo:Jefferson</segment>
    <segment id="80">; Alessandro</segment>
    <segment id="81">, Antônio Carlos</segment>
    <segment id="82">, Fábio Ferreira e Cortês</segment>
    <segment id="83">; Marcelo Mattos (Caio)</segment>
    <segment id="84">,Bruno (Léo)</segment>
    <segment id="85">, Elkeson</segment>
    <segment id="86">, Maicosuel e Felipe Menezes</segment>
    <segment id="87">;</segment>
    <segment id="88">Loco Abreu</segment>
  </rst>
