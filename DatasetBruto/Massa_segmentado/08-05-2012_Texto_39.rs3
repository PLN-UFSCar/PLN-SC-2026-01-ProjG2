  <rst>
    <segment id="1">IED muda projeto para dar fim a briga judicial com moradores da Urca
RIO - Uma solução estratégica para pôr fim ao impasse entre a direção do Instituto Europeo di Design (IED) e a Associação de Moradores da Urca (Amour).</segment>
    <segment id="2">Assim define o diretor do instituto</segment>
    <segment id="3">, Fábio Palma</segment>
    <segment id="4">, o projeto de dividir as atividades do IED.</segment>
    <segment id="5">Nas próximas semanas</segment>
    <segment id="6">, a instituição apresenta à Justiça a proposta de instalar os cursos de graduação em arquitetura e design na Universidade Santa Úrsula</segment>
    <segment id="7">, em Botafogo</segment>
    <segment id="8">, e manter no antigo prédio do Cassino da Urca o Centro Latino Americano de Pesquisa e Desenvolvimento</segment>
    <segment id="9">, conforme informou Joaquim Ferreira dos Santos</segment>
    <segment id="10">, na coluna Gente Boa</segment>
    <segment id="11">, do GLOBO.</segment>
    <segment id="12">A briga entre o IED e a Amour já</segment>
    <segment id="13">sese arrasta há mais cinco anos.</segment>
    <segment id="14">O projeto inicial para o Cassino da Urca era de que o local abrigaria todos os cursos.</segment>
    <segment id="15">A batalha judicial foi iniciada</segment>
    <segment id="16">porque</segment>
    <segment id="17">porque os moradores temiam que os carros dos estudantes atravancassem as estreitas ruas do bairro.</segment>
    <segment id="18">A ação civil pública</segment>
    <segment id="19">, por ato de improbidade</segment>
    <segment id="20">, solicita a anulação da cessão do imóvel por falta de licitação e de publicidade.</segment>
    <segment id="21">Desde 2009</segment>
    <segment id="22">, a Justiça impediu o funcionamento do IED</segment>
    <segment id="23">, masmas a direção pôde continuar no imóvel até o julgamento final.</segment>
    <segment id="24">Segundo Fábio Palma</segment>
    <segment id="25">, durante esse período</segment>
    <segment id="26">, a direção estudou várias maneiras de manter o IED no local</segment>
    <segment id="27">, masmas evitar o impacto no trânsito do pacato bairro da Urca.</segment>
    <segment id="28">Chegaram então ao projeto "IED sem carro".</segment>
    <segment id="29">Além de levar a maioria dos estudantes para a Santa Úrsula</segment>
    <segment id="30">, o projeto proíbe que os frequentadores da unidade da Urca usem carro.</segment>
    <segment id="31">-</segment>
    <segment id="32">Não vai ultrapassar o limite de 200 pessoas.</segment>
    <segment id="33">Além disso</segment>
    <segment id="34">, todos terão que usar transporte público ou bicicleta.</segment>
    <segment id="35">Ninguém poderá entrar no bairro com carro particular - afirmou Fábio Palma.</segment>
    <segment id="36">Instituto começa a funcionar este ano</segment>
    <segment id="37">Para entrar em funcionamento</segment>
    <segment id="38">, o IED ainda depende da decisão judicial.</segment>
    <segment id="39">Mas, segundo a direção</segment>
    <segment id="40">, as obras já estão quase prontas e</segment>
    <segment id="41">, sese for autorizado</segment>
    <segment id="42">, o instituto começa a funcionar este ano.</segment>
    <segment id="43">Referência no ensino de design</segment>
    <segment id="44">, o Instituto Europeo di Design surgiu em Milão</segment>
    <segment id="45">, na Itália.</segment>
    <segment id="46">Atuando em todas as áreas do design</segment>
    <segment id="47">, o IED hoje tem 12 unidades de ensino em Milão</segment>
    <segment id="48">, Roma</segment>
    <segment id="49">, Turim</segment>
    <segment id="50">, Veneza</segment>
    <segment id="51">, Madri</segment>
    <segment id="52">, Barcelona e São Paulo.</segment>
    <segment id="53">O imóvel</segment>
    <segment id="54">, que até hoje é um marco na Urca</segment>
    <segment id="55">, funcionou</segment>
    <segment id="56">comocomo cassino entre 1934 e 1946</segment>
    <segment id="57">, quando foi desativado por conta da proibição do jogo no país.</segment>
    <segment id="58">Por lá</segment>
    <segment id="59">, passaram Carmen Miranda e Walt Disney.</segment>
    <segment id="60">A partir de 1950</segment>
    <segment id="61">, o prédio abrigou a TV Tupi</segment>
    <segment id="62">, que encerrou suas atividades por ali em 1980.</segment>
    <segment id="63">Por mais de 20 anos</segment>
    <segment id="64">, o imóvel ficou abandonado.</segment>
    <segment id="65">Deteriorado</segment>
    <segment id="66">, ele serviu a alguns projetos frustrados até que</segment>
    <segment id="67">, em 2006</segment>
    <segment id="68">, a prefeitura deu concessão para o IED.</segment>
    <segment id="69">Procurada pelo GLOBO</segment>
    <segment id="70">, a direção da Amour não falou sobre a mudança do projeto.</segment>
  </rst>
</analysis>