  <rst>
    <segment id="1">Jobson chega a Salvador indignado
“</segment>
    <segment id="2">Não preciso de tratamento</segment>
    <segment id="3">, não sou drogado”</segment>
    <segment id="4">, diz ele</segment>
    <segment id="5">O atacante Jobson já chegou ao Fazendão na manhã desta quarta-feira</segment>
    <segment id="6">, 4, onde deve ser anunciado oficialmente nas próximas horas</segment>
    <segment id="7">comocomo novo contratado do Bahia para a disputa da Série A.</segment>
    <segment id="8">Na chegada em Salvador</segment>
    <segment id="9">, o jogador disse ter ficado incomodado com o “clima chato” e o desgaste durante as últimas semanas</segment>
    <segment id="10">, quando não foi aceito de volta no Botafogo após sair do Atlético-MG por ter</segment>
    <segment id="11">sese recusado a passar por uma clínica de tratamento de dependência química.</segment>
    <segment id="12">“</segment>
    <segment id="13">Nunca fiz e nunca vou fazer (um tratamento).</segment>
    <segment id="14">Não sou nenhum drogado.</segment>
    <segment id="15">Por isso</segment>
    <segment id="16">, não quis ficar no Botafogo e também eles não me quiseram lá”.</segment>
    <segment id="17">Perguntado</segment>
    <segment id="18">sese chega com fama de atleta indisciplinado</segment>
    <segment id="19">, Jobson rechaçou ser encarado assim e afirmou que foi contratado pelo Bahia “</segment>
    <segment id="20">comocomo uma grande jogador”.</segment>
    <segment id="21">Sobre o Bahia</segment>
    <segment id="22">, Jobson disse que conhece poucos jogadores do elenco</segment>
    <segment id="23">, como</segment>
    <segment id="24">como o zagueiro Titi</segment>
    <segment id="25">, com quem já conversou sobre o clube.</segment>
    <segment id="26">O atacante disse que gosta de jogar em clubes</segment>
    <segment id="27">comocomo o tricolor baiano</segment>
    <segment id="28">, que tem uma torcida fanática.</segment>
    <segment id="29">Jobson ainda aproveitou para dar uma pequena alfinetada no rival Vitória.</segment>
    <segment id="30">“Dá última vez que estive em Salvador pelo Botafogo</segment>
    <segment id="31">, joguei contra o Vitória e fiz dois gols”.
*</segment>
    <segment id="32">Com informações de Daniel Dórea</segment>
    <segment id="33">, de A TARDE</segment>
    <segment id="34">, e Marta Erhardt</segment>
    <segment id="35">, da TV</segment>
    <segment id="36">A TARDE.</segment>
  </rst>
