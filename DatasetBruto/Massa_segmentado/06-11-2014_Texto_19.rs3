    <segment id="36">, extravio ou roubo de documento</segment>
    <segment id="37">, o candidato deve levar Boletim de Ocorr횄짧ncia com data de</segment>
    <segment id="38">, no m횄징ximo</segment>
    <segment id="39">, 90 dias.</segment>
    <segment id="40">Acesse enem.inep.gov.br e veja mais dicas.</segment>
    <segment id="41">Mais coisas pra serem levadas
Caneta:</segment>
    <segment id="42">Deve</segment>
    <segment id="43">ser esferogr횄징fica de tinta preta</segment>
    <segment id="44">, fabricada em material transparente.
Cart횄짙o informativo:</segment>
    <segment id="45">Apesar de n횄짙o ser obrigat횄쨀ria a sua apresenta횄짠횄짙o no dia do exame</segment>
    <segment id="46">, ele auxilia o candidato na busca do endere횄짠o do local de prova e do n횄쨘mero de sala.</segment>
    <segment id="47">Lanche:</segment>
