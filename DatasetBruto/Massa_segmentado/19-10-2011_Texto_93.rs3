  <rst>
    <segment id="1">Primeira velinha: Todos numa só energia
Que esta data</segment>
    <segment id="2">sese multiplique</segment>
    <segment id="3">Sopramos ontem nossa primeira velinha.</segment>
    <segment id="4">Neste dia  especial comemoramos nosso sucesso juntos</segment>
    <segment id="5">, não só com os nossos leitores</segment>
    <segment id="6">, masmas com toda a equipe de trabalho</segment>
    <segment id="7">, desde quem produz nossas páginas</segment>
    <segment id="8">, até quem distribui e vende nossos exemplares nas ruas.</segment>
    <segment id="9">Em Lauro de Freitas</segment>
    <segment id="10">, Adilson Magalhães</segment>
    <segment id="11">, 37, nosso distribuidor na cidade</segment>
    <segment id="12">, resolveu nos dar uma festa de presente.</segment>
    <segment id="13">Ele convocou todos seus 70 vendedores para</segment>
    <segment id="14">sese divertir</segment>
    <segment id="15">, ao som do Afoxé Korin Nagô</segment>
    <segment id="16">, com danças</segment>
    <segment id="17">, bingos e muitos brindes.</segment>
    <segment id="18">“</segment>
    <segment id="19">Esta confraternização é a prova de que o MASSA!</segment>
    <segment id="20">é o maior sucesso”</segment>
    <segment id="21">, frisou Adilson.</segment>
    <segment id="22">Já na  redação</segment>
    <segment id="23">, uma onda vermelha dominou o espaço.</segment>
    <segment id="24">Todos os colaboradores vestiram a nossa cor.</segment>
    <segment id="25">Até o cantor  Alex Max</segment>
    <segment id="26">, do  Saiddy Bamba</segment>
    <segment id="27">, veio festejar nosso primeiro aninho e cortar o bolo.</segment>
    <segment id="28">Reconhecimento: MASSA!</segment>
    <segment id="29">sese filia ao IVC</segment>
    <segment id="30">O aniversário do MASSA!</segment>
    <segment id="31">foi coroado por um presentaço.</segment>
    <segment id="32">O Instituto Verificador de Circulação (IVC)</segment>
    <segment id="33">, entidade que certifica as métricas de desempenho de veículos impressos e digitais</segment>
    <segment id="34">, aceitou a filiação do jornal.</segment>
    <segment id="35">Com isso</segment>
    <segment id="36">, todos vão conhecer o sucesso do jornal e os baianos vão poder mostrar que têm um veículo que é a cara da Bahia!</segment>
  </rst>
</analysis>