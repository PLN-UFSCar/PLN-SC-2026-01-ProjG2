  <rst>
    <segment id="1">Clássico sem graça levanta suspeitas</segment>
    <segment id="2">Após empate no Ba-Vi</segment>
    <segment id="3">, times precisam comprovar que são favoritos no Baianão 2012</segment>
    <segment id="4">O Ba-Vi do domingo</segment>
    <segment id="5">, em Pituaçu</segment>
    <segment id="6">, foi um dos piores dos últimos anos.</segment>
    <segment id="7">Tanto é que terminou em um  empate sem gols que não teve graça.</segment>
    <segment id="8">O torcedor deve ter ficado com sono no estádio</segment>
    <segment id="9">, já que os goleiros praticamente não trabalharam.</segment>
    <segment id="10">Se o resultado teve algum ponto positivo</segment>
    <segment id="11">, foi para o Bahia</segment>
    <segment id="12">, que segue na segunda posição</segment>
    <segment id="13">, com 17 pontos</segment>
    <segment id="14">, quatro à frente do rival Vitória</segment>
    <segment id="15">, que pareceu jogar com medo - quatro jogadores de marcação no meio de campo -</segment>
    <segment id="16">, e caiu na tabela: agora é o quarto colocado</segment>
    <segment id="17">, com 13 pontos.</segment>
    <segment id="18">No entanto</segment>
    <segment id="19">, assim</segment>
    <segment id="20">comocomo o Leão</segment>
    <segment id="21">, o Bahia fez um jogo abaixo do esperado.</segment>
    <segment id="22">O que não é novidade</segment>
    <segment id="23">, já que os dois times tropeçaram nas primeiras rodadas do Baianão: o Esquadrão também empatou com o Atlético</segment>
    <segment id="24">, além de perder para o Bahia de Feira</segment>
    <segment id="25">; já o rubro-negro ficou no empate com Itabuna</segment>
    <segment id="26">, Fluminense e Feirense e perdeu para o Juazeirense.</segment>
    <segment id="27">Os tropeços da dupla Ba-Vi deixam uma pergunta:</segment>
    <segment id="28">será que os dois são os principais favoritos ou o Bahia de Feira tem mais chances?</segment>
  </rst>
</analysis>