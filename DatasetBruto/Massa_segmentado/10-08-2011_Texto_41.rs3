  <rst>
    <segment id="1">Polícia confirma a morte de 9 operários</segment>
    <segment id="2">Os trabalhadores estavam no elevador quando o equipamento despencou do 20º andar</segment>
    <segment id="3">Nove operários morreram</segment>
    <segment id="4">, segundo a polícia</segment>
    <segment id="5">, em um acidente em uma obra na região do Iguatemi por volta das 7h30 desta terça-feira (9).</segment>
    <segment id="6">As primeiras informações dão conta de que um elevador despencou com pelo menos nove pessoas a bordo da altura do 20º andar de um prédio residencial em construção</segment>
    <segment id="7">, localizado nas imediações do Hiper Posto.</segment>
    <segment id="8">De acordo com informações da Superintendência de Telecomunicações das Polícias Civil e Militar (Stelecom)</segment>
    <segment id="9">, várias equipes do Corpo de Bombeiros foram enviadas ao local</segment>
    <segment id="10">, além doSalvar</segment>
    <segment id="11">, da Polícia Militar</segment>
    <segment id="12">, de equipes do IML e do Serviço de Atendimento Móvel de Urgência (Samu).</segment>
    <segment id="13">Conforme explicou o engenheiro responsável pela obra</segment>
    <segment id="14">, Manoel Segura</segment>
    <segment id="15">, ainda não</segment>
    <segment id="16">sese sabe</segment>
    <segment id="17">sese oito ou nove operários morreram</segment>
    <segment id="18">, porque</segment>
    <segment id="19">porque não há certeza sobre o número de operários que estava no elevador.</segment>
    <segment id="20">“</segment>
    <segment id="21">Eles estavam subindo para ir trabalhar.</segment>
    <segment id="22">O cabo soltou</segment>
    <segment id="23">, masmas não sabemos o porquê.</segment>
    <segment id="24">O elevador era seguro</segment>
    <segment id="25">, eu mesmo usava ele todos os dias.</segment>
    <segment id="26">Não sabemos</segment>
    <segment id="27">comocomo aconteceu”</segment>
    <segment id="28">, lamentou.</segment>
    <segment id="29">O operário Adailton dos Santos</segment>
    <segment id="30">, de 44 anos</segment>
    <segment id="31">, escapou por pouco.</segment>
    <segment id="32">Ele iria entrar no elevador</segment>
    <segment id="33">, quando o operador informou que a cabine estava lotada.</segment>
    <segment id="34">“</segment>
    <segment id="35">O elevador estava mais ou menos na 20ª laje quando a gente viu o fogo”</segment>
    <segment id="36">, disse o operário</segment>
    <segment id="37">, que completou 44 anos ontem.</segment>
    <segment id="38">“Poderia estar morto”</segment>
    <segment id="39">, disse.</segment>
    <segment id="40">O presidente do Sindicato dos Trabalhadores na Indústria da Construção Civil e da Madeira do Estado da Bahia (Sintracom-BA)</segment>
    <segment id="41">, José Ribeiro</segment>
    <segment id="42">, afirmou que a categoria lamenta e está abalada com o acidente.</segment>
    <segment id="43">“Ainda não dá para saber quantos operários estavam no elevador</segment>
    <segment id="44">, vamos aguardar as informações da Polícia Técnica”</segment>
    <segment id="45">, disse.</segment>
    <segment id="46">O tráfego segue interditado no local</segment>
    <segment id="47">, a partir da Rua Saturnino</segment>
    <segment id="48">, para facilitar o trabalho das equipes de resgate.</segment>
    <segment id="49">O Sindicato dos Trabalhadores na Indústria da Construção e da Madeira no Estado da Bahia divulgou os nomes dos operários mortos na obra

Antonio Reis do Carmo (armador)</segment>
    <segment id="50">Antonio Elias da Silva (carpinteiro)
Antonio Luis Alves dos Reis (carpinteiro)
Elio Sampaio (pedreiro)
José Roque dos Santos (pedreiro)</segment>
    <segment id="51">Jairo de Almeira Correia (ajudante prático)
Lourival Ferreira (armador)
Martinho Fernandes dos Santos (carpineteiro)</segment>
    <segment id="52">Manoel Bispo Pereira (ajudante prático)</segment>
  </rst>
</analysis>