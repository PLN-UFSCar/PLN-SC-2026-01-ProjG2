  <rst>
    <segment id="1">Roberto Carlos</segment>
    <segment id="2">sese aprochega</segment>
    <segment id="3">O MASSA!</segment>
    <segment id="4">vai levar você para bem pertinho do Rei
Ele não dava as caras em Salvador desde 2009.</segment>
    <segment id="5">Agora, ele volta e fica mais perto do que você pode imaginar.</segment>
    <segment id="6">Pela estrutura do local da apresentação - a Concha Acústica -</segment>
    <segment id="7">, quem for assistir ao Rei vai poder vê-lo bem de perto.</segment>
    <segment id="8">Somente 2</segment>
    <segment id="9">,5 metros vão separar você do seu ídolo.</segment>
    <segment id="10">O MASSA!</segment>
    <segment id="11">não quer deixar seus leitores fora do show e</segment>
    <segment id="12">, por isso</segment>
    <segment id="13">, abriu o concurso cultural que vai premiar o responsável pela resposta mais criativa para a pergunta “Por que Roberto Carlos é o meu rei”?</segment>
    <segment id="14">Para participar</segment>
    <segment id="15">, basta mandar uma mensagem de texto do seu celular para o número 50098</segment>
    <segment id="16">, começando com a palavra Massa e</segment>
    <segment id="17">, em seguida</segment>
    <segment id="18">, a resposta.</segment>
    <segment id="19">Mas fique atento ao limite de caracteres: 140</segment>
    <segment id="20">, no máximo!</segment>
    <segment id="21">O envio do torpedo custa R$ 0</segment>
    <segment id="22">,31, mais impostos.</segment>
    <segment id="23">O prazo de envio das respostas é até sábado.</segment>
    <segment id="24">Ligue o celular e coloque a mente para trabalhar.</segment>
    <segment id="25">Assim, além de ouvir as belas canções</segment>
    <segment id="26">, você poderá disputar uma das rosas vermelhas que o Rei tem para lhe dar.</segment>
  </rst>
