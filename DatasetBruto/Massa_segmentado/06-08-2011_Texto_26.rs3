  <rst>
    <segment id="1">Briga em boate na Zona Portuária do Rio acaba com policial civil morto
RIO - Uma troca de tiros entre dois policiais terminou em morte na boate The Week</segment>
    <segment id="2">, na Gamboa</segment>
    <segment id="3">, na madrugada deste sábado.</segment>
    <segment id="4">O policial civil Marcelo Bittencourt</segment>
    <segment id="5">, agente da 13ª DP (Ipanema)</segment>
    <segment id="6">, morreu no local após</segment>
    <segment id="7">sese desentender com o sargento da PM Marco Oliveira Caetano Ferreira na saída da casa noturna</segment>
    <segment id="8">, por volta das 5h30</segment>
    <segment id="9">m.</segment>
    <segment id="10">O sargento</segment>
    <segment id="11">, lotado no 5º BPM (Saúde)</segment>
    <segment id="12">, foi atingido no rosto</segment>
    <segment id="13">, operado no Hospital da Polícia Militar e passa bem.</segment>
    <segment id="14">Mas ele não consegue falar.</segment>
    <segment id="15">No fim da tarde</segment>
    <segment id="16">, o titular da Delegacia de Homicídios</segment>
    <segment id="17">, Felipe Ettori</segment>
    <segment id="18">, informou que o policial civil pode ter sido atingido por outra pessoa ainda não identificada.</segment>
    <segment id="19">Câmeras de segurança dentro da boate registraram a confusão</segment>
    <segment id="20">, masmas por um problema técnico ainda não foram examinadas pela polícia.</segment>
    <segment id="21">No momento do tiroteio</segment>
    <segment id="22">, estava sendo comemorado um aniversário.</segment>
    <segment id="23">Atendente de bar da boate</segment>
    <segment id="24">, Otávio Ferreira contou que os funcionários não viram</segment>
    <segment id="25">comocomo a confusão começou.</segment>
    <segment id="26">Segundo testemunhas</segment>
    <segment id="27">, a briga aconteceu perto do balcão de pagamentos.

- Não vimos</segment>
    <segment id="28">comocomo começou toda essa confusão</segment>
    <segment id="29">, apenas ouvimos os disparos - disse Otávio</segment>
    <segment id="30">, na saída da casa noturna</segment>
    <segment id="31">, bastante frequentada pelo público gay.</segment>
    <segment id="32">Segundo o gerente da The Week</segment>
    <segment id="33">, Antônio Milani</segment>
    <segment id="34">, o policial civil acautelou a arma ao chegar na festa</segment>
    <segment id="35">, masmas ele também informou que o PM entrou armado na casa.</segment>
    <segment id="36">Na noite de sexta</segment>
    <segment id="37">, acontecia na The Week uma festa aberta na qual a promoter Renata Beyruth comemorava seu aniversário.</segment>
    <segment id="38">A briga aconteceu pouco antes do amanhecer</segment>
    <segment id="39">, quando ainda havia cerca cem clientes na boate.</segment>
    <segment id="40">Por volta das 12h</segment>
    <segment id="41">, a boate foi interditada sem previsão de liberação.</segment>
  </rst>
