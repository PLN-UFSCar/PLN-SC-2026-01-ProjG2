  <rst>
    <segment id="1">Tráfico leva prejuízo de R$ 500 mil</segment>
    <segment id="2">Policiais estouraram um depósito com cerca de 50 quilos de drogas</segment>
    <segment id="3">, na Pela Porco</segment>
    <segment id="4">Um depósito de drogas foi descoberto na tarde de ontem por investigadores da 6ª Delegacia Territorial (Brotas)</segment>
    <segment id="5">, na comunidade do Pela Porco – entre os bairros do Barbalho e Sete Portas.</segment>
    <segment id="6">Conforme a delegada Maria Dail Sá Barreto</segment>
    <segment id="7">, titular da 6ª DT</segment>
    <segment id="8">, pelo menos 50 quilos de drogas foram apreendidos.</segment>
    <segment id="9">O estoque inclui tabletes de cocaína</segment>
    <segment id="10">, crack</segment>
    <segment id="11">, maconha prensada e até oxi – uma variante do crack</segment>
    <segment id="12">, misturada a outras substâncias químicas</segment>
    <segment id="13">, com efeitos ainda mais nocivos ao organismo.</segment>
    <segment id="14">Duas balanças de precisão e farto material para embalar drogas também foram encontrados.</segment>
    <segment id="15">Os investigadores ainda encontraram duas cadernetas com anotações que indicariam a movimentação financeira do negócio ilícito contabilizada pelos traficantes.</segment>
    <segment id="16">Pelos manuscritos achados</segment>
    <segment id="17">, os policiais deduziram que</segment>
    <segment id="18">, entre os dias 18 e 30 (supostamente de outubro)</segment>
    <segment id="19">, houve movimentação de 53 quilos de drogas e de um montante de R$ 110 mil.</segment>
    <segment id="20">“</segment>
    <segment id="21">O prejuízo causado aos traficantes com essa operação pode chegar a R$ 500 mil</segment>
    <segment id="22">, uma vez que</segment>
    <segment id="23">, com o refino e a mistura com outros produtos</segment>
    <segment id="24">, eles certamente iriam multiplicar a quantidade de drogas para a venda”</segment>
    <segment id="25">, observou a delegada Maria Dail Sá Barreto</segment>
    <segment id="26">, titular da Delegacia de Brotas.</segment>
    <segment id="27">Traficantes filmados

Quatro suspeitos</segment>
    <segment id="28">, que estavam em frente ao sobrado que abrigava as drogas</segment>
    <segment id="29">, conseguiram fugir ao perceber a aproximação dos policiais.</segment>
    <segment id="30">Buscas foram realizadas</segment>
    <segment id="31">, masmas ninguém foi preso.</segment>
    <segment id="32">Segundo Maria Dail</segment>
    <segment id="33">, as investigações foram iniciadas há dois meses</segment>
    <segment id="34">, inclusive com filmagens da movimentação de suspeitos de tráfico no local.</segment>
    <segment id="35">Os policiais confirmaram que as drogas pertenciam a um traficante identificado apenas</segment>
    <segment id="36">comocomo Edvaldo.</segment>
    <segment id="37">Ele seria o responsável por fornecer as substâncias proibidas não só na Pela Porco</segment>
    <segment id="38">, como</segment>
    <segment id="39">como também no Matatu</segment>
    <segment id="40">, Vila Laura e Engenho Velho.</segment>
    <segment id="41">Praga do tráfico</segment>
    <segment id="42">“</segment>
    <segment id="43">Continuaremos combatendo o tráfico de drogas</segment>
    <segment id="44">, pois</segment>
    <segment id="45">pois ele é o que move outros crimes</segment>
    <segment id="46">, principalmente os homicídios.</segment>
    <segment id="47">Posso dizer que 90% dos assassinatos têm ligação com o tráfico”</segment>
    <segment id="48">, concluiu a delegada de Brotas.</segment>
  </rst>
</analysis>