  <rst>
    <segment id="1">Policial mata mulher a chutes</segment>
    <segment id="2">João fingiu que a mulher tinha morrido em um acidente de carro</segment>
    <segment id="3">O agente civil João dos Santos Macedo</segment>
    <segment id="4">, 40 anos</segment>
    <segment id="5">, foi preso na última terça-feira</segment>
    <segment id="6">, em Senhor do Bonfim (a 375 km de Salvador)</segment>
    <segment id="7">, acusado de  ter matado a esposa</segment>
    <segment id="8">, Márcia Regina de Sousa Macedo</segment>
    <segment id="9">, 29 – em 29 de outubro –</segment>
    <segment id="10">, e de ter forjado um acidente de carro para encobrir o crime.</segment>
    <segment id="11">Segundo o delegado de Senhor do Bonfim</segment>
    <segment id="12">, Felipe Nery</segment>
    <segment id="13">, a história do policial era cheia de contradições.</segment>
    <segment id="14">O agente não apresentava ferimentos</segment>
    <segment id="15">, o carro estava em perfeito estado</segment>
    <segment id="16">, o rastro do veículo no capim à margem da pista era reto e uniforme e o corpo de Márcia estava a cerca de 45 metros distante do carro – quando não deveria ter ficado a mais de 5 m</segment>
    <segment id="17">, de acordo com o relato de</segment>
    <segment id="18">comocomo teria sido o acidente.</segment>
    <segment id="19">“</segment>
    <segment id="20">Além disso</segment>
    <segment id="21">, dentro do carro havia sangue e cabelo da vítima.</segment>
    <segment id="22">O médico do Samu disse à polícia que o corpo de Márcia já apresentava  rigidez cadavérica”</segment>
    <segment id="23">, disse o delegado.</segment>
    <segment id="24">A necropsia detectou vários hematomas no corpo da vítima</segment>
    <segment id="25">, como</segment>
    <segment id="26">como marcas nos pulsos</segment>
    <segment id="27">, mostrando que ela havia sido amarrada ou algemada.</segment>
    <segment id="28">Família em choque</segment>
    <segment id="29">João e Márcia eram casados há quase 13 anos e tinham dois filhos (de 11 e 5 anos).</segment>
    <segment id="30">Na polícia civil há dois anos</segment>
    <segment id="31">, ele já havia sido soldado da PM e tinha bons antecedentes profissionais.</segment>
    <segment id="32">Ela era estagiária na Justiça Federal.</segment>
    <segment id="33">Segundo a mãe de Márcia</segment>
    <segment id="34">, Ivone Maria de Souza</segment>
    <segment id="35">, a filha apanhava do marido e sempre aparecia com hematomas pelo corpo.</segment>
    <segment id="36">Ela conta que João foi ao enterro</segment>
    <segment id="37">, visitou o túmulo no Dia de Finados e foi à missa de 7º dia.</segment>
    <segment id="38">“É um dissimulado.</segment>
    <segment id="39">Dizia que ele era quem mais sentia falta de minha filha”</segment>
    <segment id="40">, desabafou Ivone.</segment>
    <segment id="41">Encenação: João foi ao velório</segment>
    <segment id="42">, ao enterro</segment>
    <segment id="43">, visitou o túmulo de Márcia no Dia de Finados e foi à missa de 7º dia

 

Confissão:</segment>
    <segment id="44">Vítima foi golpeada na cabeça e pescoço

“</segment>
    <segment id="45">Quando ele viu que não podia mais esconder</segment>
    <segment id="46">, admitiu tudo.</segment>
    <segment id="47">Disse que</segment>
    <segment id="48">sese desentendeu com Márcia e que ela teria batido nele</segment>
    <segment id="49">, o que o levou a algemá-la”</segment>
    <segment id="50">, disse Nery.</segment>
    <segment id="51">João disse ainda</segment>
    <segment id="52">, segundo a polícia</segment>
    <segment id="53">, que havia bebido vinho e cerveja e que bateu nela chutando seu pescoço e cabeça.</segment>
    <segment id="54">“</segment>
    <segment id="55">Ele não admite</segment>
    <segment id="56">, masmas deve ter sido ajudado por pelo menos três pessoas para conseguir montar a cena</segment>
    <segment id="57">, levar o corpo ao carro</segment>
    <segment id="58">, ir ao local do acidente (próximo da cidade de Antônio Gonçalves)</segment>
    <segment id="59">, retirar o corpo do veículo e colocá-lo no ponto onde foi encontrado”</segment>
    <segment id="60">, frisou Nery</segment>
    <segment id="61">, que representou pela prisão preventiva do acusado</segment>
    <segment id="62">, que foi preso na casa da mãe.</segment>
    <segment id="63">João está na Corregedoria da Polícia Civil</segment>
    <segment id="64">, em Salvador</segment>
    <segment id="65">, e deve responder por homicídio qualificado e passar por um processo administrativo disciplinar.</segment>
  </rst>
</analysis>