  <rst>
    <segment id="1">Camarote desaba em show de Ivete Sangalo</segment>
    <segment id="2">Cerca de três mil pessoas estavam na área vip quando a estrutura cedeu</segment>
    <segment id="3">Um camarote desabou durante show da cantora Ivete Sangalo na noite do último sábado</segment>
    <segment id="4">, na Arena Anhembi</segment>
    <segment id="5">, em São Paulo.</segment>
    <segment id="6">Segundo a organização da festa</segment>
    <segment id="7">, 48 pessoas ficaram feridas.</segment>
    <segment id="8">Por volta das 21h30</segment>
    <segment id="9">, cinco delas ainda estavam sendo atendidas.</segment>
    <segment id="10">As outras vítimas foram socorridas por brigadistas da empresa responsável pela segurança no local</segment>
    <segment id="11">, pelo Samu (Serviço de Atendimento Móvel de Urgência) e pelo próprio ambulatório do evento.</segment>
    <segment id="12">Os bombeiros informaram que as vítimas não tiveram ferimentos graves.</segment>
    <segment id="13">De acordo com testemunhas</segment>
    <segment id="14">, o camarote cedeu durante a primeira música da cantora.</segment>
    <segment id="15">Amon Borges</segment>
    <segment id="16">, de 24 anos</segment>
    <segment id="17">, estava a cinco metros da área VIP no momento da queda.</segment>
    <segment id="18">“No show do Inimigos da HP a estrutura já balançava.</segment>
    <segment id="19">No início do show da Ivete</segment>
    <segment id="20">, o público começou a pular e o chão cedeu”</segment>
    <segment id="21">, contou.</segment>
    <segment id="22">O show era parte do festival</segment>
    <segment id="23">“</segment>
    <segment id="24">Todo Mundo</segment>
    <segment id="25">Vai”.</segment>
    <segment id="26">Além de Ivete Sangalo</segment>
    <segment id="27">, Exaltasamba e Inimigos da HP também tocaram.</segment>
    <segment id="28">No Twitter</segment>
    <segment id="29">, Ivete deixou uma mensagem de solidariedade aos fãs.</segment>
    <segment id="30">“Quero deixar o meu beijo e as minhas orações àqueles estavam em meio ao que aconteceu no camarote.</segment>
    <segment id="31">Meu respeito e carinho’</segment>
    <segment id="32">, afirmou.</segment>
    <segment id="33">Perícia: Sobrecarga provocou desabamento</segment>
    <segment id="34">A primeira análise feita pela perícia no camarote em que parte da estrutura desabou durante o show de Ivete Sangalo</segment>
    <segment id="35">, indica que houve sobrecarga na estrutura de ferro.</segment>
    <segment id="36">A informação é do engenheiro Lourenço Trapé Neto</segment>
    <segment id="37">, do núcleo de engenharia do Instituto de Criminalística de São Paulo.</segment>
    <segment id="38">Por 40 minutos</segment>
    <segment id="39">, ele vistoriou ontem a área danificada do camarote.</segment>
    <segment id="40">De acordo com a empresa organizadora do evento</segment>
    <segment id="41">, quatro pessoas foram removidas para atendimento médico com suspeita de fratura.</segment>
    <segment id="42">O acidente não interrompeu o show.</segment>
    <segment id="43">“Não tinham irregularidades.</segment>
    <segment id="44">Mas estamos levando as peças para exame</segment>
    <segment id="45">, masmas o que parece ter havido é sobrecarga</segment>
    <segment id="46">porque</segment>
    <segment id="47">porque todo mundo veio para o mesmo canto”</segment>
    <segment id="48">, contou o engenheiro.</segment>
  </rst>
</analysis>