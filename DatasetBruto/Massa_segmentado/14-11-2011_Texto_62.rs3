  <rst>
    <segment id="1">Bahia sonha com a Sul-Americana
Vencer o Atlético-GO por 1 a 0 faz o tricolor</segment>
    <segment id="2">sese distanciar da zona de rebaixamento</segment>
    <segment id="3">De fato</segment>
    <segment id="4">, o tricolor pode chamar o Serra Dourada de segunda casa.</segment>
    <segment id="5">Ou pelo menos de terceira</segment>
    <segment id="6">, vá lá.</segment>
    <segment id="7">Ontem, chegou ao quinto triunfo nos últimos sete jogos no principal estádio de Goiânia.</segment>
    <segment id="8">E este 1 a 0 sobre o Atlético-GO foi crucial para o atual objetivo do tricolor</segment>
    <segment id="9">, que é não voltar à Série B. Agora</segment>
    <segment id="10">, com sete pontos de distância para a zona</segment>
    <segment id="11">, o torcedor já</segment>
    <segment id="12">sese dá ao direito de respirar aliviado.</segment>
    <segment id="13">E ousa ainda sonhar com voos mais altos</segment>
    <segment id="14">, afinal</segment>
    <segment id="15">, o Bahia voltou a figurar na zona de classificação para a Sul-Americana.</segment>
    <segment id="16">Ultrapassou Atlético-MG e Palmeiras</segment>
    <segment id="17">, pulando para a 13ª colocação.</segment>
    <segment id="18">Na etapa inicial</segment>
    <segment id="19">, o Bahia estava bem postado atrás e contando com a boa fase de Souza na frente.</segment>
    <segment id="20">Aos 10 minutos</segment>
    <segment id="21">, Marcos teve esperteza ao roubar a bola de Thiago Feltri e precisão para colocá-la no pé esquerdo de Souza</segment>
    <segment id="22">, que cutucou para o fundo do gol.</segment>
    <segment id="23">Aos 32 minutos</segment>
    <segment id="24">, após discussão</segment>
    <segment id="25">, o zagueiro atleticano Gilson e o atacante tricolor Souza foram expulsos.</segment>
    <segment id="26">O Bahia perdeu seu melhor jogador e</segment>
    <segment id="27">, como</segment>
    <segment id="28">como não tinha mais ninguém no ataque</segment>
    <segment id="29">, ficou acanhado lá atrás.</segment>
    <segment id="30">A pressão continuou forte até os 12 minutos do segundo tempo</segment>
    <segment id="31">, quando Júnior substituiu Lulinha e levou perigo ao time goiano.</segment>
  </rst>
</analysis>