  <rst>
    <segment id="1">Botafogo vence mais uma na Copa São Paulo
RIO - O Botafogo venceu mais uma partida na Copa São Paulo.</segment>
    <segment id="2">Dessa vez</segment>
    <segment id="3">, a vítima foi o Vila Nova-GO</segment>
    <segment id="4">, que perdeu por 2 a 0</segment>
    <segment id="5">, neste sábado</segment>
    <segment id="6">, em São José dos Campos</segment>
    <segment id="7">, em São Paulo.</segment>
    <segment id="8">Os gols foram marcados por Gilberto e Dória.</segment>
    <segment id="9">Com a vitória</segment>
    <segment id="10">, o Botafogo assumiu a liderança isolada do Grupo W.</segment>
    <segment id="11">Na última rodada da fase de grupo</segment>
    <segment id="12">, o Botafogo pega o São José-SP</segment>
    <segment id="13">, segundo colocado com quatro pontos</segment>
    <segment id="14">, na próxima terça-feira.</segment>
    <segment id="15">O Botafogo precisa apenas de um empate para garantir a classificação.</segment>
  </rst>
