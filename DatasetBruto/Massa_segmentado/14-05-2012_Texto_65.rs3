  <rst>
    <segment id="1">Mais uma vítima de furto de mala no Galeão
RIO - Da alegria de uma viagem a um prejuízo de cerca de US$ 2 mil (R$ 3.900).</segment>
    <segment id="2">A dona de casa Cláudia Ferreira Silva Lavouras teve uma notícia ruim ao desembarcar de Miami</segment>
    <segment id="3">, nos Estados Unidos</segment>
    <segment id="4">, com três filhos e a babá no último dia 10</segment>
    <segment id="5">, no Aeroporto Internacional Tom Jobim (Galeão):</segment>
    <segment id="6">as suas oito malas haviam</segment>
    <segment id="7">sese extraviado.</segment>
    <segment id="8">No dia seguinte</segment>
    <segment id="9">, quando a bagagem foi entregue em sua casa</segment>
    <segment id="10">, na Barra da Tijuca</segment>
    <segment id="11">, a esperança</segment>
    <segment id="12">sese transformou em decepção: das oito malas</segment>
    <segment id="13">, três tinham sido violadas e</segment>
    <segment id="14">, entre elas</segment>
    <segment id="15">, uma estava danificada.</segment>
    <segment id="16">Para piorar</segment>
    <segment id="17">, haviam sido furtados vários produtos</segment>
    <segment id="18">, como</segment>
    <segment id="19">como itens de perfumaria</segment>
    <segment id="20">, tênis</segment>
    <segment id="21">, roupas usadas e bolas.
- Tudo isso é muito triste - disse Cláudia</segment>
    <segment id="22">, que registrou o furto na TAM</segment>
    <segment id="23">, na Polícia Federal</segment>
    <segment id="24">, na Agência Nacional de Aviação Civil (Anac) e na Delegacia do Aeroporto Internacional (Dairj).</segment>
    <segment id="25">- A decepção das crianças foi terrível.</segment>
    <segment id="26">Vou até o fim dessa história.</segment>
    <segment id="27">Isso não pode acontecer.</segment>
    <segment id="28">Sei de várias histórias semelhantes</segment>
    <segment id="29">, e ninguém faz nada.</segment>
    <segment id="30">É um absurdo acontecer isso bem debaixo dos olhos da companhia.</segment>
    <segment id="31">A empresa</segment>
    <segment id="32">, no caso</segment>
    <segment id="33">caso a TAM</segment>
    <segment id="34">, tem responsabilidades.</segment>
    <segment id="35">Não há registro de filmagens.</segment>
    <segment id="36">Em nota</segment>
    <segment id="37">, a TAM informou que já entrou em contato com a passageira "para apresentar uma proposta de indenização com base nas diretrizes da Convenção de Montreal" - o conjunto de normas que rege a compensação em casos</segment>
    <segment id="38">comocomo esse em voos internacionais.</segment>
    <segment id="39">Segundo a Infraero</segment>
    <segment id="40">, as empresas aéreas devem devolver as bagagens aos passageiros nas mesmas condições em que foram despachadas.</segment>
    <segment id="41">Isso está previsto na portaria 676/GC-5</segment>
    <segment id="42">, de 13 de novembro de 2000</segment>
    <segment id="43">, do Comando da Aeronáutica</segment>
    <segment id="44">, que estabelece ainda que "o transportador responde pelos danos aos passageiros</segment>
    <segment id="45">, bagagem e carga ocorridos durante a execução do contrato de transporte".</segment>
    <segment id="46">A orientação a quem for lesado é registrar o</segment>
    <segment id="47">casocaso na companhia aérea e na Dairj.</segment>
    <segment id="48">Mais informações podem ser obtidas no site www.infraero.gov.br/fiquepordentro/#/guia.</segment>
    <segment id="49">Cláudia contou que</segment>
    <segment id="50">, no dia 9 passado</segment>
    <segment id="51">, saiu de Orlando</segment>
    <segment id="52">, no voo AA125</segment>
    <segment id="53">, com destino a Miami</segment>
    <segment id="54">, onde pegou uma conexão para o Rio</segment>
    <segment id="55">, no voo JJ8057.

- Após um atraso inexplicável e sem informações em terra sobre a conexão</segment>
    <segment id="56">, o que foi terrível</segment>
    <segment id="57">, principalmente com três crianças</segment>
    <segment id="58">, chegamos ao Rio no dia 10</segment>
    <segment id="59">, por volta das 7h20</segment>
    <segment id="60">m.</segment>
    <segment id="61">Ao esperar as oito malas</segment>
    <segment id="62">, tive a triste informação de que elas tinham sido extraviadas e que só as receberia no dia seguinte</segment>
    <segment id="63">, para frustração das crianças</segment>
    <segment id="64">, pois</segment>
    <segment id="65">pois todos os brinquedos comprados nos parques da Disney estavam nas malas - afirmou.</segment>
    <segment id="66">Ela lembrou a decepção ao receber a bagagem no dia seguinte:

- Logo verifiquei que as malas haviam sido danificadas.</segment>
    <segment id="67">Duas estavam sem cadeados</segment>
    <segment id="68">, apesar de eu ter embarcado com eles.</segment>
    <segment id="69">Devolveram com lacre.</segment>
    <segment id="70">Em janeiro passado</segment>
    <segment id="71">, O GLOBO noticiou que muitos passageiros acabam não registrando na Dairj o furto de bagagens</segment>
    <segment id="72">, preferindo comunicar os casos às empresas de aviação</segment>
    <segment id="73">, à Anac e à Infraero.</segment>
    <segment id="74">A Delegacia do Aeroporto Internacional confirmou que é baixo o número de casos registrados.</segment>
    <segment id="75">No primeiro trimestre do ano passado</segment>
    <segment id="76">, houve 46</segment>
    <segment id="77">, contra 47 no mesmo período de 2010.</segment>
    <segment id="78">Já o número de ações de indenização contra as companhias aéreas vem crescendo.</segment>
    <segment id="79">Recentemente</segment>
    <segment id="80">, a advogada Mônica Kimelblat</segment>
    <segment id="81">, especialista em direito do consumidor</segment>
    <segment id="82">, informou que tinham sido abertos cerca de cem processos contra empresas aéreas nos últimos dois anos.</segment>
    <segment id="83">Segundo ela</segment>
    <segment id="84">, as companhias são sempre as responsáveis pelo transporte de passageiros e de seus pertences em segurança.</segment>
    <segment id="85">A advogada esclareceu que</segment>
    <segment id="86">, para pedir compensação por danos materiais</segment>
    <segment id="87">, é importante que o passageiro junte notas e extratos de cartão de crédito comprovando as compras.</segment>
    <segment id="88">Segundo Mônica</segment>
    <segment id="89">, a indenização por dano moral é subjetiva e fica em torno de R$ 3 mil a R$ 4 mil.</segment>
    <segment id="90">Um caso</segment>
    <segment id="91">caso parecido com o de Cláudia aconteceu com a aposentada Mônica Fonseca Ribas.</segment>
    <segment id="92">Depois de comprar vários brinquedos eletrônicos em Orlando para presentear os dois netos no Natal de 2010</segment>
    <segment id="93">, ela teve uma surpresa ao receber em casa a mala que havia</segment>
    <segment id="94">sese extraviado: objetos de valor tinham desaparecido.</segment>
    <segment id="95">Mônica processou a companhia aérea e teve direito a cerca de R$10 mil por danos materiais e morais.</segment>
    <segment id="96">Além dos brinquedos</segment>
    <segment id="97">, os criminosos furtaram também perfumes e roupas.</segment>
    <segment id="98">Em janeiro passado</segment>
    <segment id="99">, a Infraero anunciou a compra de 3.150 câmeras para intensificar a segurança nos 17 quilômetros quadrados do Aeroporto Internacional Tom Jobim</segment>
    <segment id="100">, visando à Copa de 2014 e aos Jogos Olímpicos de 2016.</segment>
    <segment id="101">Pelo aeroporto circularam 14</segment>
    <segment id="102">,9 milhões de passageiros em 2011</segment>
    <segment id="103">, 18% a mais do que no ano anterior.</segment>
  </rst>
</analysis>