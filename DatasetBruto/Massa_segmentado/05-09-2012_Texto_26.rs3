  <rst>
    <segment id="1">Justin Bieber do pagode faz 19 anos</segment>
    <segment id="2">Dudu Martins</segment>
    <segment id="3">, cantor da New Hit</segment>
    <segment id="4">, passou o aniversГѓВЎrio na prisГѓВЈo</segment>
    <segment id="5">O cantor da banda New Hit</segment>
    <segment id="6">, Eduardo Martins</segment>
    <segment id="7">, completou ontem 19 anos e passou o aniversГѓВЎrio   no PresГѓВ­dio Regional de Feira de Santana (a 108 Km de Salvador) com mais oito integrantes da banda.</segment>
    <segment id="8">Todos  estГѓВЈo presos acusados de estuprar duas adolescentes de 16 anos no ГѓВґnibus do grupo</segment>
    <segment id="9">, apГѓВіs um show na cidade de Ruy Barbosa (a 321 Km de Salvador).</segment>
    <segment id="10">A vida de Eduardo</segment>
    <segment id="11">, conhecido</segment>
    <segment id="12">comocomo Dudu</segment>
    <segment id="13">, comeГѓВ§ou a mudar hГѓВЎ um ano e meio</segment>
    <segment id="14">, quando foi convidado pelo empresГѓВЎrio Jorge Sacramento para capitanear a banda New Hit.</segment>
    <segment id="15">Depois do vocalista</segment>
    <segment id="16">, a produГѓВ§ГѓВЈo realizou testes para recrutar os mГѓВєsicos e danГѓВ§arinos.</segment>
    <segment id="17">A ideia era associar a  figura de Dudu</segment>
    <segment id="18">ГѓВ  de Justin Bieber</segment>
    <segment id="19">, jovem ГѓВ­cone da mГѓВєsica pop internacional.</segment>
    <segment id="20">Гўв‚¬Е“Sacramento assistiu a um ensaio de Dudu na antiga banda dele e decidiu convidГѓВЎ-lo.</segment>
    <segment id="21">Viu nele um Justin Bieber do pagode baiano</segment>
    <segment id="22">, pelo jeito e aparГѓВЄncia fГѓВ­sicaГўв‚¬</segment>
    <segment id="23">, explica Nilmara Souza</segment>
    <segment id="24">, produtora da New Hit.</segment>
    <segment id="25">A ideia deu certo e Dudu comeГѓВ§ou a ser chamado de Justin Bieber pelas fГѓВЈs</segment>
    <segment id="26">, em sua maioria adolescentes.</segment>
    <segment id="27">Em uma das mГѓВєsicas do grupo</segment>
    <segment id="28">, o cantor faz referГѓВЄncia ao  apelido.</segment>
    <segment id="29">Гўв‚¬Е“Empina o bumbum pro Dudu</segment>
    <segment id="30">, que o Justin aqui espancaГўв‚¬</segment>
    <segment id="31">, diz um dos versos da canГѓВ§ГѓВЈo Гўв‚¬ЛњEspancaГўв‚¬в„ў.</segment>
    <segment id="32">A banda ganhou espaГѓВ§o na cena do pagode baiano.</segment>
    <segment id="33">Os ensaios do grupo</segment>
    <segment id="34">, denominados Гўв‚¬ЛњNoite da ApertadinhaГўв‚¬в„ў</segment>
    <segment id="35">, passaram a lotar.</segment>
    <segment id="36">Гўв‚¬Е“TГѓВ­nhamos uma mГѓВ©dia de oito shows por mГѓВЄsГўв‚¬</segment>
    <segment id="37">, revela Nilmara.</segment>
    <segment id="38">Com o cantor</segment>
    <segment id="39">, trГѓВЄs danГѓВ§arinos</segment>
    <segment id="40">, dois percussionistas e o backing vocal preso</segment>
    <segment id="41">, o futuro da New Hit ГѓВ© incerto.</segment>
    <segment id="42">A trilha agora ГѓВ© para tentar provar na JustiГѓВ§a a inocГѓВЄncia dos acusados.
Veja quem estГѓВЎ no xadrez</segment>
    <segment id="43">A New Hit ГѓВ© composta por 23 pessoas</segment>
    <segment id="44">, incluindo produtores</segment>
    <segment id="45">, seguranГѓВ§as e empresГѓВЎrio.</segment>
    <segment id="46">Entre mГѓВєsicos e danГѓВ§arinos sГѓВЈo 15.</segment>
    <segment id="47">Destes</segment>
    <segment id="48">, sete estГѓВЈo presos: o cantor Eduardo Martins Daltro de Castro Sobrinho</segment>
    <segment id="49">, 19, o trio de danГѓВ§arinos Guilherme Augusto Campos Silva</segment>
    <segment id="50">,19, Weslen Danilo Borges Lopes</segment>
    <segment id="51">, 19, e Alan AragГѓВЈo Trigueiros</segment>
    <segment id="52">, 24; os percussionistas John Ghendow de Souza Silva</segment>
    <segment id="53">, 19, e Michel Melo de Almeida</segment>
    <segment id="54">, 18; e o backing vocal Willian Ricardo de Farias</segment>
    <segment id="55">, 19.</segment>
    <segment id="56">O produtor tГѓВ©cnico Jefferson Pinto dos Santos</segment>
    <segment id="57">, 24,  Edson Bomfim Berhends Santos e o seguranГѓВ§a Carlos Frederico Santos de AragГѓВЈo</segment>
    <segment id="58">, que ГѓВ© policial militar</segment>
    <segment id="59">, tambГѓВ©m estГѓВЈo entre os presos.
Apoio de parentes
Amigos e parentes acreditam no carГѓВЎter dos jovens que formam a linha de frente da New Hit</segment>
    <segment id="60">, apesar do resultado das investigaГѓВ§ГѓВµes.</segment>
    <segment id="61">Aline Trigueiro</segment>
    <segment id="62">, irmГѓВЈ do danГѓВ§arino Alan</segment>
    <segment id="63">, conta que ele danГѓВ§a desde os 15 anos e dГѓВЎ aulas de swing baiano em trГѓВЄs academias de musculaГѓВ§ГѓВЈo.</segment>
    <segment id="64">Гўв‚¬Е“Ele</segment>
    <segment id="65">ГѓВ© uma pessoa extremamente carinhosa</segment>
    <segment id="66">, humana.</segment>
    <segment id="67">Ele nГѓВЈo permitiria o estuproГўв‚¬</segment>
    <segment id="68">, declara Aline.</segment>
    <segment id="69">Raimunda Borges</segment>
    <segment id="70">, tia do danГѓВ§arino Weslen Danilo</segment>
    <segment id="71">, fala que o sobrinho encontrou na danГѓВ§a sua vocaГѓВ§ГѓВЈo.</segment>
    <segment id="72">Гўв‚¬Е“Ele danГѓВ§a desde os 17 anos.</segment>
    <segment id="73">ГѓвЂ° muito dolorosa essa situaГѓВ§ГѓВЈo.</segment>
    <segment id="74">Ele jurou por Deus que nГѓВЈo teve nada com as meninasГўв‚¬</segment>
    <segment id="75">, relata a tia de Weslen</segment>
    <segment id="76">, que recebia R$ 60 por show.</segment>
    <segment id="77">TauГѓВЈ Oliveira</segment>
    <segment id="78">, 22, amigo do danГѓВ§arino Guilherme</segment>
    <segment id="79">, disse nГѓВЈo acreditar no estupro.</segment>
    <segment id="80">Гўв‚¬Е“Um monte de menina dava em cima dele.</segment>
    <segment id="81">NГѓВЈo tinha necessidade de estuprarГўв‚¬</segment>
    <segment id="82">, destaca.</segment>
    <segment id="83">O comerciante Raul Daltro</segment>
    <segment id="84">, pai de Dudu</segment>
    <segment id="85">, preferiu nГѓВЈo falar.</segment>
