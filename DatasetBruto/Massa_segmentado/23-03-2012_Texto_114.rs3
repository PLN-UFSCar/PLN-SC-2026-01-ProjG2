  <rst>
    <segment id="1">Raulzito nas telonas</segment>
    <segment id="2">Filme mostra a vida do roqueiro baiano</segment>
    <segment id="3">, Raul Seixas
Foram quatro anos de produção</segment>
    <segment id="4">, muitas viagens</segment>
    <segment id="5">, horas de entrevistas em tudo quanto é canto do mundo e R$ 2</segment>
    <segment id="6">,5 milhões</segment>
    <segment id="7">, masmas valeu a pena.</segment>
    <segment id="8">O público</segment>
    <segment id="9">, agora</segment>
    <segment id="10">, vai conhecer todas as facetas do “maluco beleza” por meio do documentário “Raul Seixas –</segment>
    <segment id="11">O início</segment>
    <segment id="12">, o fim e o meio”</segment>
    <segment id="13">, que chega hoje aos cinemas.</segment>
    <segment id="14">“</segment>
    <segment id="15">O processo foi longo.</segment>
    <segment id="16">Foram mais de 400 horas de depoimentos gravados.</segment>
    <segment id="17">Entrevistamos alguns baianos para conhecer melhor quem foi o Raul”</segment>
    <segment id="18">, afirma o diretor Walter Carvalho</segment>
    <segment id="19">, que esteve em Salvador para a pré-estreia do filme.</segment>
    <segment id="20">Apesar de ser o maestro</segment>
    <segment id="21">, Walter na verdade só fez concretizar um sonho acalentado por sete anos pelo produtor executivo do longa</segment>
    <segment id="22">, Denis Feijão.</segment>
    <segment id="23">“Sou fã do Raul Seixas desde os meus 15 anos”</segment>
    <segment id="24">, revela.</segment>
    <segment id="25">O sonho de Denis saiu melhor do que a encomenda.</segment>
    <segment id="26">Não faltaram artistas ilustres para falar do roqueiro baiano.</segment>
    <segment id="27">Entre os conterrâneos</segment>
    <segment id="28">, Caetano Veloso e Tom Zé</segment>
    <segment id="29">, além do amigo de fé Waldir Serrão</segment>
    <segment id="30">, concordam: o cara é uma lenda!</segment>
    <segment id="31">Raul tem cada uma...

TAL Vô... TAL NETO! - Durante entrevista com Sky Key</segment>
    <segment id="32">, segunda mulher de Raul</segment>
    <segment id="33">, todos da equipe paralisaram diante de um figura idêntica ao ídolo baiano: Dakota Seixas</segment>
    <segment id="34">, seu neto.</segment>
    <segment id="35">EU SOU</segment>
    <segment id="36">A MOSCA - Na hora em que Paulo Coelho começou a falar sobre Raul</segment>
    <segment id="37">, uma mosca pousou em seu braço.</segment>
    <segment id="38">Ele disse que nunca tinha visto uma mosca na Suíça</segment>
    <segment id="39">, onde mora...</segment>
    <segment id="40">Havia sopa no cardápio?</segment>
    <segment id="41">ROQUEIRO DE RESPONSA -</segment>
    <segment id="42">Waldir Serrão mostrou à equipe de filmagem o local de Salvador onde foi criado</segment>
    <segment id="43">, por ele e Raul</segment>
    <segment id="44">, o primeiro fã clube de Elvis Pres-
ley do Brasil</segment>
    <segment id="45">, o Elvis Rock Club.</segment>
    <segment id="46">Roqueiro que é roqueir0...</segment>
  </rst>
