  <rst>
    <segment id="1">No lugar errado e na hora errada
Adolescente é morto a tiros por suposto segurança de shopping</segment>
    <segment id="2">O crime aconteceu debaixo de uma das passarelas do Salvador Shopping</segment>
    <segment id="3">, quando Tarsis foi atraído por uma confusão.</segment>
    <segment id="4">No local</segment>
    <segment id="5">, um bandido tentava assaltar uma mulher que gritou.</segment>
    <segment id="6">Os gritos chamaram a atenção de um homem que estava no local e sacou uma arma e atirou aleatoriamente.</segment>
    <segment id="7">Um dos tiros atingiu Tarsis</segment>
    <segment id="8">, que tinha apenas 17 anos.</segment>
    <segment id="9">Ele chegou a dar entrada no Hospital Roberto Santos</segment>
    <segment id="10">, masmas não resistiu.</segment>
