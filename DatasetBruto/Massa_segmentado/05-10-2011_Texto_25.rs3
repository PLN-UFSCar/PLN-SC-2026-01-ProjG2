  <rst>
    <segment id="1">Família de babalu vai fazer protesto</segment>
    <segment id="2">O protesto está marcado para o dia 9</segment>
    <segment id="3">, a partir do meio-dia</segment>
    <segment id="4">, no bairro Cajazeira VI
Familiares e amigos do tocador de cavaquinho Sandro dos Santos</segment>
    <segment id="5">, 28 anos</segment>
    <segment id="6">, conhecido</segment>
    <segment id="7">comocomo Babalu</segment>
    <segment id="8">, irão realizar um protesto no próximo domingo</segment>
    <segment id="9">, dia 9</segment>
    <segment id="10">, a partir do meio-dia</segment>
    <segment id="11">, no bairro Cajazeira VI</segment>
    <segment id="12">, onde o músico da banda No Styllo foi assassinado a tiros</segment>
    <segment id="13">, na última sexta-feira</segment>
    <segment id="14">, 30.</segment>
    <segment id="15">“</segment>
    <segment id="16">Faremos essa manifestação por meu irmão e também por todas as famílias que passaram pelo que estamos passando agora.</segment>
    <segment id="17">Essa violência tem de acabar"</segment>
    <segment id="18">, desabafa Sérgio Santana</segment>
    <segment id="19">, 30, irmão de Sandro.</segment>
    <segment id="20">Um amigo do músico</segment>
    <segment id="21">, que esteve com ele horas antes do crime</segment>
    <segment id="22">, revela que Sandro demonstrava felicidade.</segment>
    <segment id="23">"</segment>
    <segment id="24">Ele estava muito bem</segment>
    <segment id="25">, animado.</segment>
    <segment id="26">Era um cara  respeitador</segment>
    <segment id="27">, nunca</segment>
    <segment id="28">sese envolveu com drogas"</segment>
    <segment id="29">, diz o amigo</segment>
    <segment id="30">, pedindo anonimato.</segment>
    <segment id="31">De acordo com a delegada Ana Cláudia</segment>
    <segment id="32">, do Departamento de Homicídios</segment>
    <segment id="33">, ainda não existe uma linha de investigação definida na apuração da morte.</segment>
    <segment id="34">"</segment>
    <segment id="35">Tomamos as providências iniciais</segment>
    <segment id="36">, que é ouvir as testemunhas e aguardar a perícia do celular</segment>
    <segment id="37">, para depois darmos um direcionamento à investigação".

ó elogios:</segment>
    <segment id="38">“Estamos com o coração apertado</segment>
    <segment id="39">, masmas não podemos parar de tocar”</segment>
    <segment id="40">, diz Bull Dog
 

Marcelo Bull Dog:</segment>
    <segment id="41">Cantor lamenta a perda</segment>
    <segment id="42">O vocalista da banda No Styllo</segment>
    <segment id="43">, Marcelo Bull Dog</segment>
    <segment id="44">, conta que conviveu pouco tempo com Babalu.</segment>
    <segment id="45">Porém, esse período foi o suficiente para perceber que o músico era um bom profissional e amigo.</segment>
    <segment id="46">“Passávamos quase todos os dias juntos.</segment>
    <segment id="47">Ele era sempre alegre.</segment>
    <segment id="48">Estamos tocando para cumprir agenda</segment>
    <segment id="49">, masmas</segment>
    <segment id="50">, todos nós sentimos muito a morte de Sandro”.</segment>
  </rst>
