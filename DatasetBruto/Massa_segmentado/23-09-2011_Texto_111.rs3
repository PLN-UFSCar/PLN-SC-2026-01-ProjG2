  <rst>
    <segment id="1">Terror imposto pela bandidagem
Moradores do Nordeste sofrem com os traficantes.</segment>
    <segment id="2">Governo promete UPP na outra semana</segment>
    <segment id="3">Faltando poucos dias para a implantação das Bases Comunitárias de Segurança no bairro</segment>
    <segment id="4">, a população do Nordeste de Amaralina continua sofrendo com as ações da bandidagem.</segment>
    <segment id="5">Segundo a polícia</segment>
    <segment id="6">, diariamente são registradas denúncias de tráfico de drogas e violência.</segment>
    <segment id="7">Um dos criminosos que mais vem aterrorizando a população é Luis Carlos Santos Costa</segment>
    <segment id="8">, 23 anos</segment>
    <segment id="9">, conhecido</segment>
    <segment id="10">comocomo Belisco</segment>
    <segment id="11">, considerado um dos chefes do tráfico na região do Boqueirão e Serra Verde.</segment>
    <segment id="12">A polícia afirma que Belisco costuma andar pelas ruas fortemente armado</segment>
    <segment id="13">, ameaçando os moradores.</segment>
    <segment id="14">Se acontece uma briga de vizinho</segment>
    <segment id="15">, a população é proibida de registrar queixa na delegacia</segment>
    <segment id="16">, para evitar a presença policial na área.</segment>
    <segment id="17">O conflito tem de ser resolvido no tribunal do crime</segment>
    <segment id="18">, com as leis impostas pelos traficantes.</segment>
    <segment id="19">Por causa disso</segment>
    <segment id="20">, uma mulher que era espancada quase todos os dias pelo marido tinha medo de ir na delegacia.</segment>
    <segment id="21">Os traficantes chegaram para ela e perguntaram qual  punição ela queria para o marido: a morte</segment>
    <segment id="22">, espancamento</segment>
    <segment id="23">, tiro em alguma parte do corpo.</segment>
    <segment id="24">Horrorizada</segment>
    <segment id="25">, a mulher acabou indo na delegacia.</segment>
    <segment id="26">Há relatos de criminosos que obrigam moradores e comerciantes honestos a esconderem drogas e dinheiro no próprio imóvel</segment>
    <segment id="27">, durante operações policiais.</segment>
    <segment id="28">Para a polícia</segment>
    <segment id="29">, o grande gerente das bocas de fumo no Nordeste é Marcelo Henrique Menezes dos Santos</segment>
    <segment id="30">, o Elias ou Pinto</segment>
    <segment id="31">, que assumiu a carta Ás de Ouros no Baralho do Crime</segment>
    <segment id="32">, depois da prisão do traficante Fagner Souza</segment>
    <segment id="33">, o “Fal”.</segment>
    <segment id="34">Bandidagem na internet:</segment>
    <segment id="35">Contra as bases comunitárias</segment>
    <segment id="36">No Orkut</segment>
    <segment id="37">, existem comunidades onde internautas</segment>
    <segment id="38">sese expressam contrários às bases comunitárias.</segment>
    <segment id="39">“Jamais vai pacificar aqui dentro da favela</segment>
    <segment id="40">, presente pra tua família é um pacote de velas</segment>
    <segment id="41">, quem pode acabar com a guerra não quer que a guerra acabe”.</segment>
    <segment id="42">Esse é o texto que consta na descrição da comunidade “Buqueirão</segment>
    <segment id="43">, Nordeste”.</segment>
    <segment id="44">Entre as comunidades relacionadas à “Buqueirão</segment>
    <segment id="45">, Nordeste”</segment>
    <segment id="46">, pelo menos duas chamam a atenção:</segment>
    <segment id="47">“UPP é o c....</segment>
    <segment id="48">É bala neles!</segment>
    <segment id="49">” e uma outra em homenagem ao traficante Luis Fernando Anunciação da Cruz</segment>
    <segment id="50">, o Camisinha</segment>
    <segment id="51">, morto em operação da polícia</segment>
    <segment id="52">, no mês de março.</segment>
  </rst>
</analysis>