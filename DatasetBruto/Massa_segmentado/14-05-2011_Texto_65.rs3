  <rst>
    <segment id="1">Rio tem previsão de céu nublado e pancadas de chuva nas próximas 24h</segment>
    <segment id="2">Na noite deste sábado</segment>
    <segment id="3">, chove fraca e isoladamente em pontos da cidade do Rio</segment>
    <segment id="4">, que terá máxima de 25ºC e mínima de 16ºC nas próximas 24h.</segment>
    <segment id="5">Para o domingo</segment>
    <segment id="6">, a previsão é de sol entre nuvens e pancadas de chuva.</segment>
    <segment id="7">As informações são do sistema Alerta Rio.</segment>
    <segment id="8">A Defesa Civil do município registrou 20 ocorrências sem gravidade das 10h30m às 17h45m deste sábado</segment>
    <segment id="9">, conforme boletim do Centro de Operações da Prefeitura.</segment>
  </rst>
