    <segment id="17">Sentindo-</segment>
    <segment id="18">sese incompreendido</segment>
    <segment id="19">, Demﾃδｩtrius abriu o coraﾃδｧﾃδ｣o em uma entrevista exclusiva para o MASSA!</segment>
    <segment id="20">Ele mora na Suﾃδｭﾃδｧa.</segment>
    <segment id="21">Algumas pessoas nﾃδ｣o entenderam a letra</segment>
    <segment id="22">, que ﾃδｩ altamente descritiva</segment>
    <segment id="23">, e me julgaram.</segment>
    <segment id="24">Eu esperava uma crﾃδｭtica</segment>
    <segment id="25">, porﾃδｩm</segment>
    <segment id="26">, relacionada ﾃδ minha ousadia de jogar algumas verdades no ventilador e nﾃδ｣o pela falta de interpretaﾃδｧﾃδ｣o</segment>
    <segment id="27">, diz.</segment>
    <segment id="28">Segundo o cantor</segment>
    <segment id="29">, a intenﾃδｧﾃδ｣o foi de fazer um protesto.</segment>
    <segment id="30">Quis comparar um vﾃδｭrus altamente contagioso com a superficialidade em que algumas pessoas vivem no Brasil e tambﾃδｩm chamar a atenﾃδｧﾃδ｣o do povo brasileiro para esse problema mundial que ﾃδｩ o vﾃδｭrus ebola.</segment>
    <segment id="31">Algumas pessoas valorizam mais coisas fﾃδｺteis</segment>
