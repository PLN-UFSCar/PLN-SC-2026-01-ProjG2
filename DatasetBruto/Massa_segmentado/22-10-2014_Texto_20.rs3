    <segment id="33">, e assim</segment>
    <segment id="34">, ingenuinamente</segment>
    <segment id="35">, destruindo o Brasil</segment>
    <segment id="36">, explica.</segment>
    <segment id="37">Demﾃδｩtrius iniciou a carreira musical ainda pequeno e evita os rﾃδｳtulos.</segment>
    <segment id="38">Eu nﾃδ｣o posso me limitar dizendo que tenho um estilo musical.</segment>
    <segment id="39">Eu componho desde crianﾃδｧa nos mais variados estilos e canto o que a minha garganta deixa.</segment>
