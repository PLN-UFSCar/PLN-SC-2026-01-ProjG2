  <rst>
    <segment id="1">Baiano faz som sobre o vﾃδｭrus</segment>
    <segment id="2">Demﾃδｩtrius compﾃδｴs mﾃδｺsica que compara ostentaﾃδｧﾃδ｣o com ebola e recebe crﾃδｭticas</segment>
    <segment id="3">Uma comparaﾃδｧﾃδ｣o entre o vﾃδｭrus ebola e o estilo musical ostentaﾃδｧﾃδ｣o foi a tentativa do mﾃδｺsico Demﾃδｩtrius Sena de alﾃδｧar a fama.</segment>
    <segment id="4">Ele publicou no Youtube o Axﾃδｩ ebola que</segment>
    <segment id="5">, para ele</segment>
    <segment id="6">, poderia ser o hit do verﾃδ｣o no Brasil.</segment>
    <segment id="7">Mas nﾃδ｣o foi o que aconteceu.</segment>
    <segment id="8">Se toca!</segment>
