  <rst>
    <segment id="1">Homicídio provoca pânico em Conquista</segment>
    <segment id="2">Em instantes</segment>
    <segment id="3">, uma multidão</segment>
    <segment id="4">sese formou ao redor do corpo</segment>
    <segment id="5">Homens ainda não identificados</segment>
    <segment id="6">,</segment>
    <segment id="7">que estavam em uma picape Fiat Strada cor branca</segment>
    <segment id="8">, de placa não anotada</segment>
    <segment id="9">, mataram Silvano dos Santos Achy</segment>
    <segment id="10">, 48 anos</segment>
    <segment id="11">, com seis disparos de arma de fogo</segment>
    <segment id="12">, provavelmente pistola 9 milímetros</segment>
    <segment id="13">, em pleno centro comercial de Vitória da Conquista</segment>
    <segment id="14">, a 509 km de Salvador</segment>
    <segment id="15">, por volta das 8h30 desta segunda-feira (14).</segment>
    <segment id="16">Os disparos provocaram pânico em dezenas de pessoas que acabavam de chegar à cidade em vans e ônibus intermunicipais.</segment>
    <segment id="17">Em instantes</segment>
    <segment id="18">, uma multidão</segment>
    <segment id="19">sese formou ao redor do corpo</segment>
    <segment id="20">, provocando tumulto no trânsito.</segment>
    <segment id="21">Uma funcionária de um posto de combustível disse ter presenciado a cena.</segment>
    <segment id="22">“</segment>
    <segment id="23">Os caras chegaram e começaram a atirar.</segment>
    <segment id="24">Foi horrível”.</segment>
    <segment id="25">Segundo outras testemunhas</segment>
    <segment id="26">, que estavam em frente a uma padaria</segment>
    <segment id="27">, onde ocorreu o crime</segment>
    <segment id="28">, a vítima estava acompanhada de uma mulher.</segment>
    <segment id="29">Ela conseguiu correr e fugir dos disparos</segment>
    <segment id="30">, masmas Achy não teve chance e morreu no local.</segment>
    <segment id="31">De acordo com parentes da vítima</segment>
    <segment id="32">, que não quiseram</segment>
    <segment id="33">sese identificar</segment>
    <segment id="34">, o homem mais conhecido</segment>
    <segment id="35">comocomo “Catingueiro”</segment>
    <segment id="36">, tinha envolvimento com atividades ilícitas</segment>
    <segment id="37">, como</segment>
    <segment id="38">como roubo de cargas e assaltos.</segment>
    <segment id="39">A polícia começou a ouvir os parentes ainda no local</segment>
    <segment id="40">, masmas não informou sobre suspeitos.</segment>
    <segment id="41">"</segment>
    <segment id="42">Eu cansei de aconselhar.</segment>
    <segment id="43">Moço, arrume suas coisas</segment>
    <segment id="44">, pegue sua família e some daqui”</segment>
    <segment id="45">, contou um primo</segment>
    <segment id="46">, que acabara de estar com a vítima</segment>
    <segment id="47">, numa lanchonete.</segment>
    <segment id="48">“Catingueiro” era casado e tinha dois filhos.</segment>
  </rst>
