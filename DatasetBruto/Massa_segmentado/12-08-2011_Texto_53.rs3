  <rst>
    <segment id="1">Irregularidades no lugar da tragédia</segment>
    <segment id="2">Superintendência do Trabalho</segment>
    <segment id="3">e Emprego achou outros problemas no canteiro de obras</segment>
    <segment id="4">As obras do edifício Empresarial Paulo VI</segment>
    <segment id="5">, no Iguatemi</segment>
    <segment id="6">, onde nove operários morreram após o elevador onde estavam despencar do 26ª andar</segment>
    <segment id="7">, na terça-feira</segment>
    <segment id="8">, estão paradas e continuarão assim até que a Construtora Segura</segment>
    <segment id="9">, responsável pelo empreendimento</segment>
    <segment id="10">, adote as medidas de segurança exigidas pelos auditores fiscais da Superintendência Regional do Trabalho e Emprego (SRTE).</segment>
    <segment id="11">Uma equipe esteve no canteiro de obras e identificou outras irregularidades</segment>
    <segment id="12">, como</segment>
    <segment id="13">como aberturas no piso e falta de proteção em torno dos andares.</segment>
    <segment id="14">“Se uma pessoa tropeçar em uma das aberturas</segment>
    <segment id="15">, existe a possibilidade de ela cair aqui embaixo”</segment>
    <segment id="16">, justifica o auditor fiscal e chefe do Setor de Segurança e Saúde do Trabalho da SRTE</segment>
    <segment id="17">, Flávio Oliveira Nunes.</segment>
    <segment id="18">“Amanhã (hoje) será realizada  fiscalização normal</segment>
    <segment id="19">, que já é feita rotineiramente pela SRTE.</segment>
    <segment id="20">Mas estamos com foco nos elevadores.</segment>
    <segment id="21">Já exigimos o laudo do teste de carga do sistema de freio</segment>
    <segment id="22">, que evita a queda do elevador em</segment>
    <segment id="23">casocaso de quebra do eixo (peça que teria rompido e causado o acidente)”</segment>
    <segment id="24">, explica.</segment>
    <segment id="25">O  laudo de teste do sistema de freio e os laudos dos ensaios não destrutivos dos eixos dos elevadores não foram solicitados antes</segment>
    <segment id="26">porque</segment>
    <segment id="27">porque passaram a integrar a legislação somente em maio deste ano.</segment>
    <segment id="28">Além disso</segment>
    <segment id="29">, quando uma lei entra em vigor</segment>
    <segment id="30">, é necessário respeitar o prazo de  90 dias  para as empresas tomarem   conhecimento e</segment>
    <segment id="31">sese adequarem às  novas exigências.</segment>
    <segment id="32">Uma equipe do Departamento de Polícia Técnica (DPT) também esteve ontem no canteiro de obras do prédio  para recolher peças do elevador para  investigação.</segment>
    <segment id="33">“</segment>
    <segment id="34">Hoje (ontem) estivemos  apenas no poço do elevador</segment>
    <segment id="35">, e colhemos  peças para a análise do mecanismo do sistema de freio”</segment>
    <segment id="36">, informou o perito do DPT</segment>
    <segment id="37">, Jackson Roberto.</segment>
    <segment id="38">Foco total: Atenção com elevadores</segment>
    <segment id="39">Em nota</segment>
    <segment id="40">, a Construtora Segura disse que  irá colaborar</segment>
    <segment id="41">, no que for necessário</segment>
    <segment id="42">, para que</segment>
    <segment id="43">para que as causas da tragédia sejam esclarecidas.</segment>
    <segment id="44">As empresas da construção civil têm até 5 de setembro para apresentar à SRTE os laudos dos ensaios não destrutivos dos eixos dos elevadores (testes de resistência do eixo).</segment>
    <segment id="45">Nesse dia</segment>
    <segment id="46">, cerca de 30 auditores fiscais vão fiscalizar os elevadores dos 300 canteiros de obras de Salvador.</segment>
    <segment id="47">De acordo com  SRTE</segment>
    <segment id="48">, o laudo de testes do eixo está sendo exigido</segment>
    <segment id="49">porque</segment>
    <segment id="50">porque</segment>
    <segment id="51">, a princípio</segment>
    <segment id="52">, o acidente foi causado pelo rompimento desta peça.</segment>
    <segment id="53">Assustados: Operários com medo</segment>
    <segment id="54">Operários da construção civil estão assustados com o acidente.</segment>
    <segment id="55">“Estava tomando café quando  soube do acidente.</segment>
    <segment id="56">Horas depois</segment>
    <segment id="57">, tive que usar o elevador e senti um frio na barriga</segment>
    <segment id="58">, senti medo e pensei que poderia ter ocorrido com qualquer um.</segment>
    <segment id="59">É muito triste”</segment>
    <segment id="60">, relatou um operário que não quis</segment>
    <segment id="61">sese identificar.</segment>
    <segment id="62">Já o auxiliar de produção</segment>
    <segment id="63">Uilson dos Santos (foto)</segment>
    <segment id="64">, 23, disse que pensou em mudar de área quando soube da tragédia.</segment>
    <segment id="65">“Sinto também pelas famílias.</segment>
    <segment id="66">Penso o dia todo no meu filho</segment>
    <segment id="67">, que tem 2 anos.</segment>
    <segment id="68">Deixo ele em casa e quero voltar para encontrá-lo todos os dias”</segment>
    <segment id="69">, disse.</segment>
  </rst>
</analysis>