  <rst>
    <segment id="1">Mulher morre após agressão do filho</segment>
    <segment id="2">Deficiente auditivo tinha histórico de brigas com a mãe

Aos 93 anos</segment>
    <segment id="3">, Maria Pereira Conceição morreu após ser agredida pelo filho de criação</segment>
    <segment id="4">, Alírio José Conceição Santos</segment>
    <segment id="5">, 57 anos</segment>
    <segment id="6">, que é deficiente auditivo e asmático.</segment>
    <segment id="7">O acusado empurrou a vítima</segment>
    <segment id="8">, que bateu com a cabeça no chão.</segment>
    <segment id="9">Mas, segundo laudo da autópsia do Instituto Médico Legal</segment>
    <segment id="10">, a morte da idosa teria sido provocada por um ataque cardíaco.</segment>
    <segment id="11">O fato aconteceu por volta das 17h do último sábado</segment>
    <segment id="12">, 30, na Rua Souza Góes</segment>
    <segment id="13">, Caminho 10</segment>
    <segment id="14">, na terceira etapa de Castelo Branco.</segment>
    <segment id="15">Segundo relato do sobrinho de criação da vítima</segment>
    <segment id="16">, Jorge Luiz de Jesus</segment>
    <segment id="17">, 33, que entregou o acusado à polícia</segment>
    <segment id="18">, Alírio teria quebrado a bengala da idosa e a empurrado com força</segment>
    <segment id="19">, fazendo-a cair com a cabeça no chão.</segment>
    <segment id="20">Uma das delegadas de plantão na Delegacia de Homicídio</segment>
    <segment id="21">, Celina de Cássia</segment>
    <segment id="22">, até a noite de ontem tentava colher o depoimento de Alírio</segment>
    <segment id="23">, que é surdo- -mudo.</segment>
    <segment id="24">“Depois de interrogado</segment>
    <segment id="25">, ele será liberado</segment>
    <segment id="26">porque</segment>
    <segment id="27">porque a princípio foi morte natural</segment>
    <segment id="28">, masmas pode ser aberto um inquérito para apurar</segment>
    <segment id="29">sese a agressão provocou a morte.</segment>
    <segment id="30">Vamos aguardar os laudos”</segment>
    <segment id="31">, afirmou a delegada.</segment>
    <segment id="32">Pela dificuldade em colher o depoimento</segment>
    <segment id="33">, Celina de Cássia levantou a possibilidade de liberar Alírio e depois intimá-lo para ser ouvido junto com um especialista em tratar com deficiente auditivo.</segment>
  </rst>
</analysis>