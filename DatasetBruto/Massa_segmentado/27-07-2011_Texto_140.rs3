  <rst>
    <segment id="1">Ronaldinho faz três gols e Fla vence Santos por 5 a 4 em jogo histórico
RIO - O encontro da juventude de Neymar e a experiência de Ronaldinho Gaúcho terminou em uma partida histórica com grande atuação dos dois jogadores.</segment>
    <segment id="2">O Santos esteve a maior parte do tempo na frente</segment>
    <segment id="3">, com dois gols de Neymar e dois de Borges</segment>
    <segment id="4">, masmas foi Ronaldinho que saiu</segment>
    <segment id="5">comocomo o personagem da partida.</segment>
    <segment id="6">Ele marcou três gols na vitória por 5 a 4</segment>
    <segment id="7">, na Vila Belmiro</segment>
    <segment id="8">, na noite desta quarta-feira</segment>
    <segment id="9">, pela 12ª rodada do Campeonato Brasileiro.</segment>
    <segment id="10">Os primeiros minutos já mostraram</segment>
    <segment id="11">comocomo seria o jogo.</segment>
    <segment id="12">Aos 5, Borges recebeu de Elano</segment>
    <segment id="13">, invadiu a área com facilidade e chutou no canto esquerdo de Felipe para marcar.</segment>
    <segment id="14">Aos 10</segment>
    <segment id="15">, o Flamengo quase empatou com Ronaldinho Gaúcho.</segment>
    <segment id="16">Ele fez bonita jogada</segment>
    <segment id="17">, chutou no canto e Rafael espalmou para fora.</segment>
    <segment id="18">Aos 17</segment>
    <segment id="19">, o segundo gol do Santos.</segment>
    <segment id="20">Neymar recebeu na área</segment>
    <segment id="21">, chutou por cima de Felipe</segment>
    <segment id="22">, que defendeu.</segment>
    <segment id="23">Na sobra</segment>
    <segment id="24">, Neymar deu passe de bicileta e Borges marcou.</segment>
    <segment id="25">O Flamengo também atacava.</segment>
    <segment id="26">Em uma das jogadas de ataque</segment>
    <segment id="27">, Luiz Antonio chutou pela direita e a bola cruzou a área.</segment>
    <segment id="28">Sozinho</segment>
    <segment id="29">, a alguns centímetros do gol vazio</segment>
    <segment id="30">, Deivid conseguiu chutar para fora.</segment>
    <segment id="31">Aos 26 Neymar não desperdiçou e fez um golaço.</segment>
    <segment id="32">Ele recebeu de Borges</segment>
    <segment id="33">, driblou Ronaldo Angelim com facilidade e chutou com categoria para marcar Santos 3 a 0.</segment>
    <segment id="34">O Flamengo continuou acreditando.</segment>
    <segment id="35">Aos 29</segment>
    <segment id="36">, Luiz Antonio cruzou pela direita</segment>
    <segment id="37">, Rafael falhou e Ronaldinho só teve o trabalho de tocar para o gol vazio para dimunuir.</segment>
    <segment id="38">Três minutos depois</segment>
    <segment id="39">, Leonardo Moura cruzou pela direita e Thiago Neves subiu sem marcação e marcou de cabeça o segundo gol do Flamengo.</segment>
    <segment id="40">O empate veio ainda no primeiro tempo</segment>
    <segment id="41">, aos 44</segment>
    <segment id="42">, Ronaldinho Gaúcho bateu cruzamento fechado</segment>
    <segment id="43">, Deivid tocou de cabeça e marcou.</segment>
    <segment id="44">No segundo tempo</segment>
    <segment id="45">, os dois principais nomes do jogo continuaram a brilhar.</segment>
    <segment id="46">Aos 7, Neymar recebeu na área pelo lado esquerdo</segment>
    <segment id="47">, avançou e tocou com categoria por cima do goleiro do Flamengo para marcar o quarto gol do Flamengo.</segment>
    <segment id="48">Em grande partida</segment>
    <segment id="49">, Ronaldinho usou usa experiência para empatar.</segment>
    <segment id="50">Ele bateu falta rasteira</segment>
    <segment id="51">, por baixo da barreira</segment>
    <segment id="52">, e a bola foi no canto vazio do gol de Rafael.</segment>
    <segment id="53">Aos 36</segment>
    <segment id="54">, Ronaldinho recebeu de Thiago Neves em contra-ataque e chutou cruzado para marcar o gol da virada.</segment>
  </rst>
</analysis>