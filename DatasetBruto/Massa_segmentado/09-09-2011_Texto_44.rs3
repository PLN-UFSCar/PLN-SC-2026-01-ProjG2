  <rst>
    <segment id="1">Hollyfield</segment>
    <segment id="2">, um eterno lutador</segment>
    <segment id="3">O ex-pugilista ganhou muitas lutas</segment>
    <segment id="4">, porém</segment>
    <segment id="5">porém desperdiçou dinheiro e hoje está numa pior</segment>
    <segment id="6">O baiano Reginaldo da Silva Andrade precisou anexar o apelido “Hollyfield” – uma referência ao norte-americano Evander Hollyfield</segment>
    <segment id="7">, campeão mundial dos pesos pesados – para</segment>
    <segment id="8">sese tornar conhecido no mundo do boxe.</segment>
    <segment id="9">Conquistou muitas lutas e títulos</segment>
    <segment id="10">, masmas vacilou ao não fazer seu pé-de-meia e hoje atravessa um momento difícil.</segment>
    <segment id="11">Desempregado</segment>
    <segment id="12">, ele está internado no Hospital Geral do Estado</segment>
    <segment id="13">, após sofrer graves queimaduras no corpo (veja a reportagem completa nas páginas 3 e 4).</segment>
    <segment id="14">Figura folclórica</segment>
    <segment id="15">, um grandalhão de riso fácil</segment>
    <segment id="16">, Reginaldo Hollyfield  nasceu em Salvador  no dia 9 de abril de 1966.</segment>
    <segment id="17">Apesar do pouco reconhecimento</segment>
    <segment id="18">, Hollyfield foi campeão brasileiro</segment>
    <segment id="19">, sul-americano e mundial dos supermédios.</segment>
    <segment id="20">Depois que parou de lutar profissionalmente</segment>
    <segment id="21">,  Hollyfield ganhou uma oportunidade do então apresentador da TV Aratu (afiliada da SBT)</segment>
    <segment id="22">, José Eduardo</segment>
    <segment id="23">,  para fazer reportagens bem-humoradas no programa</segment>
    <segment id="24">Se Liga Bocão</segment>
    <segment id="25">, hoje na TV Record.</segment>
    <segment id="26">Trabalhou também</segment>
    <segment id="27">comocomo segurança do supermercado Mercantil  Rodrigues</segment>
    <segment id="28">, na Calçada.</segment>
    <segment id="29">Reginaldo tem seis títulos de campeão brasileiro e quatro cinturões sul-americanos</segment>
    <segment id="30">, além de campeão das Américas e Pan-Americano.</segment>
    <segment id="31">Das 47 lutas em sua carreira</segment>
    <segment id="32">, Hollyfield venceu 33 delas por nocaute.</segment>
    <segment id="33">O baiano também é conhecido pela rixa dentro e fora dos ringues com o boxeador pernambucano Luciano “Todo Duro” Torres.</segment>
    <segment id="34">Em 1998 durante uma coletiva de imprensa</segment>
    <segment id="35">, que antecedia uma disputa na categoria meio-pesado</segment>
    <segment id="36">, Todo Duro deu um tapão no peito de Hollyfield</segment>
    <segment id="37">, que reagiu com um murraço e engargelou o desafeto.</segment>
    <segment id="38">O técnico Luis Dórea e outras pessoas conseguiram com esforço desapartar os brigões.</segment>
  </rst>
</analysis>