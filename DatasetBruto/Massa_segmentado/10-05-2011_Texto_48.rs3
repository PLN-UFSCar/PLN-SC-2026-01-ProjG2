  <rst>
    <segment id="1">Thiago Galhardo</segment>
    <segment id="2">, do Botafogo</segment>
    <segment id="3">, trocou emprego em estatal pelo amor à bola

ZAGA:</segment>
    <segment id="4">Caio Júnior define a defesa para amistoso
ATAQUE: Botafogo tenta empréstimo de Ciro</segment>
    <segment id="5">, do Sport
BLOG:</segment>
    <segment id="6">'É Por Ti Fogo'
-</segment>
    <segment id="7">Meu pai sempre brinca comigo que quando nasci a primeira palavra que falei foi bola</segment>
    <segment id="8">, e não</segment>
    <segment id="9">"papai</segment>
    <segment id="10">" ou "mamãe</segment>
    <segment id="11">", então...</segment>
    <segment id="12">- diz.</segment>
    <segment id="13">Mineiro de São João del Rey</segment>
    <segment id="14">, atualmente com 21 anos</segment>
    <segment id="15">, Thiago Galhardo sempre foi federado no futebol local.</segment>
    <segment id="16">Chegou a fazer testes quando garoto em Atlético-MG</segment>
    <segment id="17">, Palmeiras e Flamengo</segment>
    <segment id="18">, em 2002.</segment>
    <segment id="19">Neste último</segment>
    <segment id="20">, uma breve lembrança
- Era muito novo e me lembro de ter feito amizade com o Camacho (atualmente no Bahia).</segment>
    <segment id="21">Mas o time do Flamengo era muito unido e fechado.</segment>
    <segment id="22">A decisão foi voltar para São João del Rey e continuar estudando e jogando futebol.</segment>
    <segment id="23">Em 2008 decidiu fazer o concurso para a Petrobras e passou.
- Lembro que o salário na época era de R$ 4.500.</segment>
    <segment id="24">Mas um mês depois veio uma proposta para treinar no Bangu e arrisquei.</segment>
    <segment id="25">Vim com mais dois amigos de São João.</segment>
    <segment id="26">Com dois treinos fui contratado.</segment>
    <segment id="27">No Bangu</segment>
    <segment id="28">, teve altos e baixos em 2009.</segment>
    <segment id="29">Em 2010</segment>
    <segment id="30">, sese destacou</segment>
    <segment id="31">masmas percebeu uma coisa importante.
- Um apoiador não pode passar uma competição sem marcar.</segment>
    <segment id="32">Eu tive boas atuações</segment>
    <segment id="33">masmas prometi que ia mudar em 2011- afirma o jogador.</segment>
    <segment id="34">Passou a ser o primeiro a entrar em campo e o último a sair.</segment>
    <segment id="35">Treinou finalizações e passes.</segment>
    <segment id="36">O resultado foram cinco gols no Estadual</segment>
    <segment id="37">, boas atuações e a contratação pelo Botafogo.</segment>
    <segment id="38">Agora, novo desafio.
- Não vim</segment>
    <segment id="39">comocomo uma contratação de peso.</segment>
    <segment id="40">Mas vou treinar forte e chegar lá.</segment>
    <segment id="41">Loco de visual novo
Quem apareceu nesta terça-feira de visual novo foi Loco Abreu</segment>
    <segment id="42">, com cabelos mais curtos e lisos.</segment>
    <segment id="43">O corte lhe rendeu o apelido de Marta (por lembrar um pouco o jogadora brasileira)</segment>
    <segment id="44">, dado por companheiros.</segment>
    <segment id="45">Foi neste clima de seriedade e bom ambiente que Caio Júnior dirigiu um treino tático em que os titulares formaram com Jéfferson</segment>
    <segment id="46">, Lucas</segment>
    <segment id="47">, Antônio Carlos</segment>
    <segment id="48">, Fábio Ferreira e Cortês</segment>
    <segment id="49">; Arévalo</segment>
    <segment id="50">, Marcelo Mattos</segment>
    <segment id="51">, Thiago Galhardo (Bruno Thiago) e Cidinho</segment>
    <segment id="52">;</segment>
    <segment id="53">Caio e Alex.</segment>
  </rst>
</analysis>