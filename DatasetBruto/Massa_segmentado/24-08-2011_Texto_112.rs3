  <rst>
    <segment id="1">Famílias abaladas esperam os corpos</segment>
    <segment id="2">Quatro já foram liberados pelo IML de Salvador</segment>
    <segment id="3">; resta apenas o de Maione Alves</segment>
    <segment id="4">No pequeno povoado de Tabua</segment>
    <segment id="5">, região de Várzea Nova</segment>
    <segment id="6">, as famílias de Ana Paula Oliveira e de Maione Alves estavam  inconsoláveis.</segment>
    <segment id="7">Sentada no sofá em sua casa</segment>
    <segment id="8">, a tia de Ana Paula</segment>
    <segment id="9">, Irene Amorim de Souza</segment>
    <segment id="10">, 71, não continha o choro:</segment>
    <segment id="11">“Ela era</segment>
    <segment id="12">comocomo uma filha para mim.</segment>
    <segment id="13">Foi criada aqui com toda a família”.</segment>
    <segment id="14">O marido de Ana Paula</segment>
    <segment id="15">, Leandro Rodrigues dos Santos não falava muito</segment>
    <segment id="16">, masmas disse que a mulher  precisava ir a cada oito dias para Salvador levar a filha  para tratamento fisioterápico.</segment>
    <segment id="17">“Ela nasceu com uma deficiência nas pernas e só tinha tratamento lá”</segment>
    <segment id="18">, disse emocionado.</segment>
    <segment id="19">A amiga Maione foi junto para ajudar Ana Paula</segment>
    <segment id="20">, que estava com um problema no ombro e não conseguia segurar a filha com firmeza.</segment>
    <segment id="21">As casas dos parentes são todas próximas e eles</segment>
    <segment id="22">sese reuniram na residência de d. Irene.</segment>
    <segment id="23">Segundo a prima de Ana Paula</segment>
    <segment id="24">, Julieta Amorim de Souza</segment>
    <segment id="25">, eles souberam do acidente por um  programa de rádio de Jacobina.</segment>
    <segment id="26">O pai de Maione</segment>
    <segment id="27">, Juarez dos Santos</segment>
    <segment id="28">, foi para Salvador e a mãe Rosana Alves</segment>
    <segment id="29">, muito abalada</segment>
    <segment id="30">, ficou em casa com  parentes.</segment>
    <segment id="31">Na cidade de Ourolândia</segment>
    <segment id="32">, faixas pretas foram colcadas na porta da prefeitura e dos demais prédios públicos em sinal de pesar e foi decretado luto oficial de dois dias.</segment>
    <segment id="33">O motorista Inácio de Jesus Alves</segment>
    <segment id="34">, 46, trabalhava na prefeitura há seis anos.</segment>
    <segment id="35">“Ele era muito experiente e querido por todos aqui”</segment>
    <segment id="36">, afirmou a secretária de Saúde</segment>
    <segment id="37">, Josicléia Rebouças.</segment>
    <segment id="38">A prefeitura enviou carros para transportar os corpos</segment>
    <segment id="39">, que serão enterrados hoje.</segment>
    <segment id="40">Tratamento médico:</segment>
    <segment id="41">Prefeitura prestava assistência</segment>
    <segment id="42">Como o povoado de Tabua fica mais longe de Várzea Nova</segment>
    <segment id="43">, a assistência de saúde é oferecida pela Prefeitura de Ourolândia</segment>
    <segment id="44">, que ofereceu transporte para levar Leonarda à fisioterapia e Caíque</segment>
    <segment id="45">, 4 anos</segment>
    <segment id="46">, para fazer quimioterapia em Salvador.</segment>
    <segment id="47">O garotinho morreu junto com a avó Neildes dos Santos.</segment>
    <segment id="48">Ele viajava para a capital a cada oito dias</segment>
    <segment id="49">, sempre com ela.</segment>
    <segment id="50">Segundo Maria de Lourdes Alves</segment>
    <segment id="51">, recepcionista da Unidade Avançada de Saúde de Ourolândia</segment>
    <segment id="52">, o clima na cidade é de comoção.</segment>
    <segment id="53">"</segment>
    <segment id="54">Eram pessoas queridas"</segment>
    <segment id="55">, conta.</segment>
    <segment id="56">Médica surpresa:</segment>
    <segment id="57">“Ela teve muita sorte”

Leonarda Oliveira dos Santos</segment>
    <segment id="58">, de 7 meses</segment>
    <segment id="59">, sofreu uma fratura no fêmur da perna esquerda e está bem.</segment>
    <segment id="60">O bebê passou por todos os exames e a única lesão foi a fratura</segment>
    <segment id="61">, além de um pequeno hematoma na testa.</segment>
    <segment id="62">“</segment>
    <segment id="63">Essa criança teve muita sorte por ser a única sobrevivente em um acidente dessa proporção”</segment>
    <segment id="64">, afirma a pediatra Maria Bethânia Pinto</segment>
    <segment id="65">, que acompanhou o bebê no Hospital do Subúrbio.</segment>
    <segment id="66">O bebê foi imobilizado.</segment>
    <segment id="67">“Em 15 dias</segment>
    <segment id="68">, ela deve</segment>
    <segment id="69">sese recuperar da fratura”</segment>
    <segment id="70">, completa.</segment>
    <segment id="71">Segundo a médica</segment>
    <segment id="72">, Leandra tem uma má-formação nos pés e nas mãos.</segment>
  </rst>
</analysis>