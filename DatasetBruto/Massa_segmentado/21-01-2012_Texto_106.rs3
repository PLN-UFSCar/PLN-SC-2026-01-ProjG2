  <rst>
    <segment id="1">Timão estreia com a base do penta</segment>
    <segment id="2">Hoje contra o Mirassol</segment>
    <segment id="3">, o Corinthians inicia o estadual com 11 campeões brasileiros</segment>
    <segment id="4">O Corinthians está escalado para sua estreia no Campeonato Paulista hoje</segment>
    <segment id="5">, contra o Mirassol</segment>
    <segment id="6">, com 11 campeões brasileiros.</segment>
    <segment id="7">O duelo das 5h da tarde</segment>
    <segment id="8">, no Pacaembu</segment>
    <segment id="9">, marca o início de uma temporada de afirmação e desafios para o time alvinegro</segment>
    <segment id="10">, que jura estar  disposto a brigar  tanto pelo título estadual quanto pela inédita taça da Libertadores.</segment>
    <segment id="11">“</segment>
    <segment id="12">Quando existem duas competições interligadas</segment>
    <segment id="13">, conjuntas</segment>
    <segment id="14">, uma empresta à outra confiança</segment>
    <segment id="15">, ritmo e qualidade.</segment>
    <segment id="16">Não dá para dizer que vai desligar a tomada em uma e produzir bem na outra.</segment>
    <segment id="17">É um desafio de inteligência e humildade para sabermos que precisamos buscar aquilo que tivemos no ano passado”</segment>
    <segment id="18">, discursa o técnico Tite.</segment>
    <segment id="19">O comandante optou por escalar seu time com Alex solitário na articulação e um trio ofensivo composto por Willian</segment>
    <segment id="20">, Emerson e Liedson.</segment>
    <segment id="21">Com a base vitoriosa mantida</segment>
    <segment id="22">, Tite acredita que  entrosamento não será problema na largada.</segment>
    <segment id="23">O Corinthians vai a campo com Julio Cesar</segment>
    <segment id="24">, Alessandro</segment>
    <segment id="25">, Paulo André</segment>
    <segment id="26">, Leandro Castán e Fábio Santos</segment>
    <segment id="27">; Ralf</segment>
    <segment id="28">, Paulinho e Alex</segment>
    <segment id="29">; Willian</segment>
    <segment id="30">, Emerson e Liedson.</segment>
    <segment id="31">Nos outros jogos de hoje</segment>
    <segment id="32">, o atual campeão Santos enfrenta fora de casa o XV de Piracicaba</segment>
    <segment id="33">, além de Portuguesa  x Paulista</segment>
    <segment id="34">, Ituano x Guaratinguetá</segment>
    <segment id="35">, Guarani x Oeste e Comercial x Linense.</segment>
  </rst>
</analysis>