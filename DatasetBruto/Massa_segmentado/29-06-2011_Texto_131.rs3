  <rst>
    <segment id="1">Agora falta arrancar Flor da malvadeza</segment>
    <segment id="2">Polícia prende três membros da quadrilha do traficante Flor</segment>
    <segment id="3">Apesar de ter o apelido de Flor</segment>
    <segment id="4">, o traficante Florisvaldo dos Santos Costa</segment>
    <segment id="5">, 23 anos</segment>
    <segment id="6">, não tem nada de delicado.</segment>
    <segment id="7">Ele lidera o tráfico de drogas no Bairro da Paz</segment>
    <segment id="8">, impondo o medo e oprimindo os moradores.</segment>
    <segment id="9">Mas os policiais da 12ª Delegacia Territorial (Itapuã)</segment>
    <segment id="10">, dispostos a mudar essa história</segment>
    <segment id="11">,  prenderam três  membros da quadrilha dele anteontem.</segment>
    <segment id="12">Um quarto bandido morreu em confronto.</segment>
    <segment id="13">Entre os presos está Juliano Costa Menezes</segment>
    <segment id="14">, 31, o Brunão</segment>
    <segment id="15">, o matador da quadrilha.</segment>
    <segment id="16">Segundo a titular da 12ª DT</segment>
    <segment id="17">, Aymara Bandeira</segment>
    <segment id="18">, Brunão foi beneficiado pela saída temporária da Páscoa em 2011 e não retornou à Colonia Penal Lafayete Coutinho</segment>
    <segment id="19">, onde cumpria pena por homicídio.</segment>
    <segment id="20">Ele ficou preso sete anos.</segment>
    <segment id="21">“Brunão é cruel.</segment>
    <segment id="22">Temos informações de que ele arranca os membros das vítimas”</segment>
    <segment id="23">, afirma a delegada.</segment>
    <segment id="24">Também foram presos Cristiano Cândido dos Santos</segment>
    <segment id="25">, 33, o Chocho</segment>
    <segment id="26">, e Pablo dos Santos Barbosa</segment>
    <segment id="27">, 26.</segment>
    <segment id="28">Reinaldo Ramário Alves  Santos Filho</segment>
    <segment id="29">, 21, o Nanau</segment>
    <segment id="30">, foi baleado no embate e encaminhado ao Hospital Menandro de Farias</segment>
    <segment id="31">, masmas não resistiu.</segment>
    <segment id="32">“</segment>
    <segment id="33">Os policiais estavam a 150 metros da casa onde o grupo</segment>
    <segment id="34">sese reúne e foi recebido a tiros por quatro homens”</segment>
    <segment id="35">, conta a delegada.</segment>
    <segment id="36">Ele quer abrigo na tora</segment>
    <segment id="37">Após a prisão do traficante</segment>
    <segment id="38">Roberto dos Santos</segment>
    <segment id="39">, 29, o Betão</segment>
    <segment id="40">, em novembro de 2010</segment>
    <segment id="41">, Flor assumiu o comando do tráfico no Bairro da Paz.</segment>
    <segment id="42">Os líderes têm estilos diferentes de tocar os negócios.</segment>
    <segment id="43">“Betão era tido</segment>
    <segment id="44">comocomo benfeitor.</segment>
    <segment id="45">Não admitia assassinatos e roubos no bairro”</segment>
    <segment id="46">, conta a delegada Aymara Bandeira.</segment>
    <segment id="47">Mas Flor prefere ganhar o respeito da comunidade disseminando o terror.</segment>
    <segment id="48">“</segment>
    <segment id="49">A cada dia ele dorme em uma casa diferente obrigando os moradores a lhe oferecer abrigo e comida por quanto tempo ele achar necessário.</segment>
    <segment id="50">Por isso</segment>
    <segment id="51">, a dificuldade de prendê-lo”</segment>
    <segment id="52">, conta a delegada.</segment>
    <segment id="53">“Nossa intenção é combater”</segment>
    <segment id="54">Após dois meses de investigação</segment>
    <segment id="55">, a polícia conseguiu a informação sobre onde os bandidos</segment>
    <segment id="56">sese reuniam.</segment>
    <segment id="57">O grupo foi preso no Morro da Parnaque.</segment>
    <segment id="58">“Nossa intenção é combater o tráfico.</segment>
    <segment id="59">Está provado de que não existe essa história da polícia civil não entrar no Bairro da Paz”</segment>
    <segment id="60">, destaca Aymara Bandeira.</segment>
    <segment id="61">Os bandidos estavam com uma mochila onde havia 76 dolões e 42 balinhas de maconha</segment>
    <segment id="62">, metade de um tablete da erva prensada</segment>
    <segment id="63">, e uma quantidade não especificada de cocaína e crack.</segment>
    <segment id="64">Os policiais ainda apreenderam um revólver calibre 38.</segment>
  </rst>
</analysis>