  <rst>
    <segment id="1">Acabou vida de rainha de Brigiane</segment>
    <segment id="2">Ela vivia no bem-bom às custas de um gringo.</segment>
    <segment id="3">Casa própria</segment>
    <segment id="4">, carro novo e todas as despesas pagas.</segment>
    <segment id="5">Parece até prêmio de loteria</segment>
    <segment id="6">, masmas Brigiane Lima do Carmo</segment>
    <segment id="7">, 31 anos</segment>
    <segment id="8">, conseguiu tudo isso a partir de um relacionamento com um alemão.</segment>
    <segment id="9">Porém, toda mordomia dela veio abaixo com a prisão anteontem à noite com mais três jovens.</segment>
    <segment id="10">Eles foram autuados em flagrante por roubo</segment>
    <segment id="11">, tráfico de drogas e formação de quadrilha.</segment>
    <segment id="12">O castelo de areia do grupo começou a desmanchar depois que eles assaltaram uma veterinária que estava em um ponto de ônibus no bairro do Costa Azul.</segment>
    <segment id="13">Daniel Vaz dos Santos</segment>
    <segment id="14">, 19, Gabriel dos Santos Nascimento</segment>
    <segment id="15">, 18, e Michel Ferreira dos Santos</segment>
    <segment id="16">, 19, desceram do Volkswagen Gol prata e levaram a bolsa da veterinária.</segment>
    <segment id="17">A vítima anotou a placa do carro e prestou queixa na 9ª Delegacia (Boca do Rio).</segment>
    <segment id="18">Após pesquisas sobre os dados do veículo</segment>
    <segment id="19">, os policiais do Serviço de Investigação (SI) descobriram o endereço e o nome do proprietário: Thomaz Michael Glowig</segment>
    <segment id="20">, o alemão com quem Brigiane tem dois filhos gêmeos de três anos.</segment>
    <segment id="21">Ao chegar no endereço</segment>
    <segment id="22">, em uma travessa em Itapuã</segment>
    <segment id="23">, os policiais encontraram Brigiane na janela e perceberam a movimentação dentro da casa.</segment>
    <segment id="24">Os outros três tentaram</segment>
    <segment id="25">sese esconder</segment>
    <segment id="26">, masmas foram descobertos.</segment>
    <segment id="27">Além da bolsa e dois celulares da veterinária</segment>
    <segment id="28">, a polícia achou outros dois celulares</segment>
    <segment id="29">, um revólver calibre 38 e cerca de 400 g de maconha.</segment>
    <segment id="30">Os agentes interromperam uma festinha</segment>
    <segment id="31">, já que havia vestígios de cocaína na mesa e cervejas espalhadas  pela casa.</segment>
    <segment id="32">Era garota de programa e</segment>
    <segment id="33">sese envolveu com malandros</segment>
    <segment id="34">Segundo vizinhos</segment>
    <segment id="35">, que preferiram não</segment>
    <segment id="36">sese identificar</segment>
    <segment id="37">, Brigiane era garota de programa antes de namorar com o alemão.</segment>
    <segment id="38">“</segment>
    <segment id="39">Há cinco anos ele construiu o prédio</segment>
    <segment id="40">, masmas nunca morou com ela.</segment>
    <segment id="41">Só aparecia uma vez no mês.</segment>
    <segment id="42">Às vezes levava três meses”</segment>
    <segment id="43">, diz um deles.</segment>
    <segment id="44">Os vizinhos informaram que Thomaz trabalha em uma empresa americana no ramo de petróleo.</segment>
    <segment id="45">Brigiane disse na delegacia que  Thomaz viajou na última quarta-feira para a Arábia Saudita.</segment>
    <segment id="46">Os vizinhos ainda disseram que ela costumava levar outros namorados para casa quando o alemão estava viajando</segment>
    <segment id="47">, masmas nos últimos dois meses começou a levar pessoas de má aparência.</segment>
    <segment id="48">Brigiane tinha um</segment>
    <segment id="49">casocaso com Gabriel</segment>
    <segment id="50">, um dos três homens presos com ela</segment>
    <segment id="51">, e que  foi reconhecido  pelo dono de um Ford Fiesta</segment>
    <segment id="52">,  roubado  semana passada em Itinga.</segment>
    <segment id="53">Ele e Michel não tinham passagem</segment>
    <segment id="54">, masmas Daniel possui seis inquéritos por roubo.</segment>
    <segment id="55">Os filhos de Brigiane estão sob os cuidados de uma vizinha</segment>
    <segment id="56">, masmas deverão ser encaminhados ao conselho tutelar.</segment>
    <segment id="57">Não tinha passagem</segment>
    <segment id="58">Brigiane disse em depoimento na 9ª DT que tinha um relacionamento com o alemão Thomas Michel</segment>
    <segment id="59">, masmas que estava separada há oito meses.</segment>
    <segment id="60">“Ela disse que o gringo pagava todas as despesas e era o dono do carro e do prédio em que mora</segment>
    <segment id="61">, onde aluga outros dois apartamentos”</segment>
    <segment id="62">, conta a delegada Fernanda Porfírio.</segment>
    <segment id="63">Brigiane não tinha passagem pela polícia.</segment>
    <segment id="64">Caso seja condenada</segment>
    <segment id="65">, poderá pegar até 12 anos de prisão.</segment>
    <segment id="66">Na casa</segment>
    <segment id="67">, também foi encontrado o documento de um Ford Fiesta.</segment>
    <segment id="68">Os policiais da 9ª DT verificaram que o carro era roubado e o grupo os levou até o local onde o veículo estava.</segment>
  </rst>
</analysis>