  <rst>
    <segment id="1">Mistério: Quem matou Babalu?</segment>
    <segment id="2">Pagodeiro foi morto a tiros e testemunhas acham que foi por causa de mulher</segment>
    <segment id="3">A morte de Sandro de Souza Santana</segment>
    <segment id="4">, 28, o Babalu</segment>
    <segment id="5">, cavaquinista da banda No Styllo</segment>
    <segment id="6">, assassinado a tiros na sexta feira em Cajazeiras  pouco depois da  21h</segment>
    <segment id="7">,  continua sem explicação.</segment>
    <segment id="8">Para conhecidos do músico</segment>
    <segment id="9">, a morte pode ter relação com alguma mulher.</segment>
    <segment id="10">De acordo com testemunhas que não quiseram</segment>
    <segment id="11">sese identificar</segment>
    <segment id="12">, antes de atirar</segment>
    <segment id="13">, os assassinos provocaram:</segment>
    <segment id="14">“Então é você que gosta de bulir com a mulher dos outros?</segment>
    <segment id="15">”.</segment>
    <segment id="16">Um dos produtores da banda</segment>
    <segment id="17">, Jorge Luiz Viveiros</segment>
    <segment id="18">, não acredita nesta versão.</segment>
    <segment id="19">“Sandro era  namorador</segment>
    <segment id="20">,  mas</segment>
    <segment id="21">mas muito trabalhador.</segment>
    <segment id="22">Ele era muito assediado</segment>
    <segment id="23">, namorava muito.</segment>
    <segment id="24">Ele era solteiro</segment>
    <segment id="25">, não é?</segment>
    <segment id="26">Mas trabalhava muito</segment>
    <segment id="27">comocomo vendedor</segment>
    <segment id="28">, das 8 às 18 horas</segment>
    <segment id="29">, e nas horas que sobravam</segment>
    <segment id="30">sese dedicava aos ensaios da banda”.</segment>
    <segment id="31">Já o ex-colega</segment>
    <segment id="32">, o dançarino Ícaro Coelho</segment>
    <segment id="33">, 19, não consegue entender o que aconteceu.</segment>
    <segment id="34">“Ele era um cara  daqueles que pedia desculpas quando alguém</segment>
    <segment id="35">sese esbarrava nele.</segment>
    <segment id="36">O boato  é que tem algo a ver com mulher.</segment>
    <segment id="37">Mas nunca ouvi essa conversa”.</segment>
    <segment id="38">O grupo homenageou o cavaquinista durante o show em Feira de Santana no sábado: fizeram 1 minuto de silêncio.</segment>
    <segment id="39">Mãe quer Justiça:</segment>
    <segment id="40">Família está  revoltada</segment>
    <segment id="41">Ontem pela manhã</segment>
    <segment id="42">, na casa da família em Águas Claras</segment>
    <segment id="43">, parentes e amigos ainda não acreditavam no que havia acontecido.</segment>
    <segment id="44">Elenilza de Souza Santana</segment>
    <segment id="45">, 54 anos</segment>
    <segment id="46">, mãe de Sandro</segment>
    <segment id="47">, tentava eternizar a carreira do músico fazendo álbuns de fotos na internet com a ajuda do neto.</segment>
    <segment id="48">Ela assistia ao DVD e mostrava a todos quando o filho aparecia em um show.</segment>
    <segment id="49">“Olha meu filho ali.</segment>
    <segment id="50">Ele era  bem.</segment>
    <segment id="51">Nunca se</segment>
    <segment id="52">se envolveu com nada ruim.</segment>
    <segment id="53">Ninguém acredita que isso aconteceu com ele”</segment>
    <segment id="54">, concluiu.</segment>
    <segment id="55">A família estava toda reunida ontem</segment>
    <segment id="56">, masmas preferiu não tirar fotos para a reportagem.</segment>
    <segment id="57">“Quem não o conhecia pode até achar que ele tinha envolvimento com drogas.</segment>
    <segment id="58">Pois quando morre alguém por aqui todo mundo pensa isso.</segment>
    <segment id="59">Mas, ele não.</segment>
    <segment id="60">Este crime não vai virar estatística”</segment>
    <segment id="61">, disse Márcia Meneses</segment>
    <segment id="62">, amiga da família.</segment>
    <segment id="63">Entenda o</segment>
    <segment id="64">casocaso</segment>
    <segment id="65">Os moradores da Rua do Campo</segment>
    <segment id="66">, em Cajazeiras 6</segment>
    <segment id="67">, local onde ocorreu o crime</segment>
    <segment id="68">, preferiram não</segment>
    <segment id="69">sese identificar.</segment>
    <segment id="70">Mas, segundo eles</segment>
    <segment id="71">, na noite de sexta-feira dois homens desceram de um Gol preto e abordaram Sandro e um amigo em um bar.</segment>
    <segment id="72">Ao agirem</segment>
    <segment id="73">comocomo</segment>
    <segment id="74">sese fossem realizar um revista policial</segment>
    <segment id="75">, os assassinos colocaram os amigos de costas e depois que identificaram Sandro</segment>
    <segment id="76">, dispararam três vezes na cabeça do jovem.</segment>
    <segment id="77">Os matadores fugiram com mais dois comparsas que os aguardavam no carro.</segment>
    <segment id="78">O crime será investigado pelo Departamento de Homicídios e Proteção à Pessoa (DHPP)</segment>
    <segment id="79">, que até o fechamento da edição não tinha informações sobre a investigação.</segment>
  </rst>
</analysis>