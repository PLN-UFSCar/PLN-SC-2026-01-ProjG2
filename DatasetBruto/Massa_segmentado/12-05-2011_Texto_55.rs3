  <rst>
    <segment id="1">Vasco empata em 1 a 1 com o Atlético-PR e está na semifinal da Copa do Brasil

Elton: 'Quem trabalha</segment>
    <segment id="2">, é recompensado'
FOTOGALERIA:</segment>
    <segment id="3">Veja as imagens da partida
BLOG:</segment>
    <segment id="4">'Meu Caldeirão'</segment>
    <segment id="5">, o blog do torcedor do Vasco
O Vasco fez um melhor primeiro tempo</segment>
    <segment id="6">, masmas o Atlético-PR também teve boas oportunidades.</segment>
    <segment id="7">Guerron quase marcou logo no primeiro minuto.</segment>
    <segment id="8">Em duas faltas</segment>
    <segment id="9">, aos 16 e 26</segment>
    <segment id="10">, Paulo Baier ficou perto de abrir o marcador.</segment>
    <segment id="11">Com Fellipe Bastos</segment>
    <segment id="12">, o Vasco também quase marcou de falta.</segment>
    <segment id="13">Aos 20</segment>
    <segment id="14">, o volante chutou de longe e a bola passou muito perto do travessão.</segment>
    <segment id="15">Depois de boa jogada de Branquinho</segment>
    <segment id="16">, Guerro driblou Prass</segment>
    <segment id="17">, masmas chutou para fora.</segment>
    <segment id="18">Aos 39</segment>
    <segment id="19">, Bernardo cobrou escanteio fechado.</segment>
    <segment id="20">A bola foi direto no travessão.</segment>
    <segment id="21">Na sobra</segment>
    <segment id="22">, Éder Luís arriscou e Renan defendeu.</segment>
    <segment id="23">No segundo tempo</segment>
    <segment id="24">, o Vasco voltou dominando a posse de bola</segment>
    <segment id="25">, masmas não levava perigo ao gol.</segment>
    <segment id="26">Com a entrada de Madson</segment>
    <segment id="27">, o Atlético-PR melhorou.</segment>
    <segment id="28">Foi ele que</segment>
    <segment id="29">, aos 28</segment>
    <segment id="30">, descobriu Nieto sozinho.</segment>
    <segment id="31">O atacante</segment>
    <segment id="32">, que também acabara de entrar</segment>
    <segment id="33">, invadiu a área e marcou 1 a 0.</segment>
    <segment id="34">O gol acordou a torcida</segment>
    <segment id="35">, que começou a cantar</segment>
    <segment id="36">, depois de ficar durante todo o segundo tempo em silêncio</segment>
    <segment id="37">, e o time reagiu.</segment>
    <segment id="38">Aos 33</segment>
    <segment id="39">, Élton dividiu com o goleiro Renan Rocha e houve discussão.</segment>
    <segment id="40">Os dois levaram cartão amarelo.</segment>
    <segment id="41">No minuto seguinte</segment>
    <segment id="42">, o atacante</segment>
    <segment id="43">sese saiu melhor sobre o goleiro.</segment>
    <segment id="44">Após cobrança de falta</segment>
    <segment id="45">, Élton escorou de cabeça no canto esquerdo de Renan.</segment>
    <segment id="46">Aos 40</segment>
    <segment id="47">, o Vasco quase ampliou em falta cobrada por Fellipe Bastos.</segment>
    <segment id="48">Renan tirou.</segment>
    <segment id="49">A dois minutos do fim</segment>
    <segment id="50">, o Atlético-PR quase marca.</segment>
    <segment id="51">Em confusão na área</segment>
    <segment id="52">, a bola sobrou para Nieto</segment>
    <segment id="53">, que fez falta em Dedé</segment>
    <segment id="54">, marcada pelo juiz.</segment>
    <segment id="55">FICHA TÉCNICA:
VASCO 1</segment>
    <segment id="56">X 1 ATLÉTICO-PR
Local: São Januário</segment>
    <segment id="57">, Rio de Janeiro (RJ)
Data/Hora: 12/5/2011
Árbitro: Elmo Alves Resende Cunha (GO)</segment>
    <segment id="58">Auxiliares: Cristhian Passos Sorence (GO) e Márcio Soares Maciel (GO)</segment>
    <segment id="59">Cartões amarelos: Eduardo Costa (VAS)</segment>
    <segment id="60">; Robston</segment>
    <segment id="61">, Paulo Roberto (APR)
VASCO: Fernando Prass</segment>
    <segment id="62">;</segment>
    <segment id="63">Allan (Fagner</segment>
    <segment id="64">, 26'/2ºT)</segment>
    <segment id="65">, Anderson Martins</segment>
    <segment id="66">, Dedé e Márcio Careca</segment>
    <segment id="67">; Eduardo Costa</segment>
    <segment id="68">, Fellipe Bastos</segment>
    <segment id="69">, Felipe e Bernardo</segment>
    <segment id="70">; Diego Souza (Elton</segment>
    <segment id="71">, 23'/2ºT) e Eder Luis - Técnico: Ricardo Gomes.</segment>
    <segment id="72">ATLÉTICO-PR: Renan Rocha</segment>
    <segment id="73">, Rômulo</segment>
    <segment id="74">, Manoel</segment>
    <segment id="75">, Rafael Santos e Paulinho</segment>
    <segment id="76">; Deivid</segment>
    <segment id="77">, Robston (Wendell</segment>
    <segment id="78">, intervalo)</segment>
    <segment id="79">, Paulo Roberto e Paulo Baier</segment>
    <segment id="80">; Guerrón (Nieto</segment>
    <segment id="81">, 23'/2ºT) e Branquinho (Madson</segment>
    <segment id="82">, 17'/2ºT) - Técnico: Adilson Batista.</segment>
