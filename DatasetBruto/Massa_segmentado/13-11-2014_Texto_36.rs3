  <rst>
    <segment id="1">Estupro revela bando de ladrﾃδｵes
Polﾃδｭcia prende segundo envolvido em assalto que acabou em violﾃδｪncia sexual</segment>
    <segment id="2">A polﾃδｭcia prendeu ontem o segundo homem envolvido no roubo ao carro de uma mulher no estacionamento do Salvador Norte Shopping e o posterior estupro dela.</segment>
    <segment id="3">Segundo a polﾃδｭcia</segment>
    <segment id="4">, Adriano Santana Silva</segment>
    <segment id="5">, 23 anos</segment>
    <segment id="6">, participou apenas do assalto.</segment>
    <segment id="7">Ele foi preso em uma fazenda em Ouriﾃδｧangas (a 143 km da capital)</segment>
    <segment id="8">, onde estava escondido apﾃδｳs o crime.</segment>
    <segment id="9">Josﾃδｩ</segment>
    <segment id="10">Aparecido da Conceiﾃδｧﾃδ｣o</segment>
    <segment id="11">, 35 anos</segment>
    <segment id="12">, preso desde o ﾃδｺltimo dia 31</segment>
    <segment id="13">, foi reconhecido pela vﾃδｭtima e confessou a violﾃδｪncia sexual.</segment>
    <segment id="14">Alﾃδｩm da dupla</segment>
    <segment id="15">, investigadores da Delegacia de Repressﾃδ｣o a Furtos e Roubos de Veﾃδｭculos (DRFRV) tambﾃδｩm prenderam Adnailton Oliveira dos Santos</segment>
    <segment id="16">, 23.</segment>
    <segment id="17">A polﾃδｭcia descobriu que o trio mais o ex-policial militar Adilson Oliveira Cerqueira</segment>
    <segment id="18">, 64 anos</segment>
    <segment id="19">, o ﾃ｢竄ｬﾋ彡aboﾃ｢竄ｬ邃｢ Adilson</segment>
    <segment id="20">, o qual estﾃδ｡ foragido</segment>
    <segment id="21">, integram uma quadrilha de roubo</segment>
    <segment id="22">, adulteraﾃδｧﾃδ｣o e venda dos veﾃδｭculos.</segment>
    <segment id="23">Um despachante responsﾃδ｡vel por providenciar documentos e placas para os veﾃδｭculos roubados tambﾃδｩm faz parte do grupo e terﾃδ｡ a prisﾃδ｣o solicitada ﾃδ Justiﾃδｧa</segment>
    <segment id="24">, conforme o titular da DRFRV</segment>
    <segment id="25">, Marcos Cﾃδｩsar da Silva.</segment>
    <segment id="26">ﾃ｢竄ｬﾅ摘ssa</segment>
    <segment id="27">, com certeza</segment>
    <segment id="28">, ﾃδｩ uma das maiores quadrilhas de roubo a carro com atuaﾃδｧﾃδ｣o em Salvador e Regiﾃδ｣o Metropolitana.</segment>
    <segment id="29">Eles atuam desde o roubo</segment>
    <segment id="30">, a adulteraﾃδｧﾃδ｣o e a venda dos veﾃδｭculos.</segment>
    <segment id="31">O ﾃ｢竄ｬﾋ彡aboﾃ｢竄ｬ邃｢ Adilson ﾃδｩ quem lidera o grupoﾃ｢竄ｬ</segment>
    <segment id="32">, afirma o delegado.</segment>
    <segment id="33">Marcos Cﾃδｩsar explica que</segment>
    <segment id="34">, apﾃδｳs a adulteraﾃδｧﾃδ｣o de documentaﾃδｧﾃδ｣o e placa</segment>
    <segment id="35">, os carros eram levados para a cidade de Entre Rios (a 128 Km da Capital)</segment>
    <segment id="36">, onde eram vendidos por valores entre R$ 2 a R$ 3 mil.</segment>
    <segment id="37">ﾃ｢竄ｬﾋ廛inheiro fﾃδ｡cilﾃ｢竄ｬ邃｢</segment>
    <segment id="38">Segundo o delegado</segment>
    <segment id="39">, Josﾃδｩ e Adriano sﾃδ｣o os responsﾃδ｡veis por roubar os carros e cada um ganhava R$ 500.</segment>
    <segment id="40">Adnailton era quem recebia os veﾃδｭculos e vendia em Entre Rios.</segment>
    <segment id="41">O ﾃ｢竄ｬﾋ彡aboﾃ｢竄ｬ邃｢ Adilson comandava o grupo e participava de algumas aﾃδｧﾃδｵes pessoalmente.</segment>
    <segment id="42">Adriano confessou participaﾃδｧﾃδ｣o na quadrilha e disse que foi convidado hﾃδ｡ mais de um ano pelo ﾃ｢竄ｬﾋ彡aboﾃ｢竄ｬ邃｢ Edilson para integrar o grupo.</segment>
    <segment id="43">ﾃ｢竄ｬﾅ鄭ntes trabalhava normal</segment>
    <segment id="44">, fichado.</segment>
    <segment id="45">Mas depois vi que o dinheiro era mais fﾃδ｡cil</segment>
    <segment id="46">, aﾃδｭ entrei nessaﾃ｢竄ｬ</segment>
    <segment id="47">, confessa.</segment>
    <segment id="48">Ele relatou que Josﾃδｩ</segment>
    <segment id="49">Aparecido sﾃδｳ contou a ele que estuprou a mulher roubada no shopping depois que a foto deles comeﾃδｧou a circular na imprensa.</segment>
    <segment id="50">Marcos Cﾃδｩsar disse que Adriano foi indiciado por roubo e associaﾃδｧﾃδ｣o criminosa</segment>
    <segment id="51">, enquanto Adnailton por receptaﾃδｧﾃδ｣o e tambﾃδｩm por associaﾃδｧﾃδ｣o.</segment>
