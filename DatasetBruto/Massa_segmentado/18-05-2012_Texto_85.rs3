  <rst>
    <segment id="1">Tricolores de toda a Terra na Bombonera
BUENOS AIRES - A torcida do Boca Juniors estende a faixa</segment>
    <segment id="2">comocomo cartão de visitas na Bombonera: "</segment>
    <segment id="3">Nunca hicimos amistades".</segment>
    <segment id="4">Enquanto o famoso time argentino exibe a hostilidade</segment>
    <segment id="5">comocomo forma de intimidação aos visitantes do seu estádio</segment>
    <segment id="6">, os torcedores do Fluminense usam a paixão para unir tricolores de coração por toda a terra.</segment>
    <segment id="7">Um avião e a esperança de conseguir outra vitória sobre os xeneizes (apelido dos torcedores do Boca) deixaram 174 homens</segment>
    <segment id="8">, mulheres</segment>
    <segment id="9">, crianças</segment>
    <segment id="10">, europeus</segment>
    <segment id="11">, brasileiros e um bebê de 9 meses em suspenso.</segment>
    <segment id="12">A vida parou por 24 horas</segment>
    <segment id="13">, tempo no qual só o Fluminense existiu.</segment>
    <segment id="14">A odisseia rumo ao mítico estádio no bairro da Boca começou na quinta-feira</segment>
    <segment id="15">, no Aeroporto Tom Jobim.</segment>
    <segment id="16">Organizado pelo Fluminense</segment>
    <segment id="17">, o pacote de viagens da agência Vou Ver o Flu é a chance de pessoas de diferentes estados</segment>
    <segment id="18">, países</segment>
    <segment id="19">, idades</segment>
    <segment id="20">, cores e credos compartilharem a emoção de acompanhar o time numa aventura que custa cerca de R$ 2 mil</segment>
    <segment id="21">, com direito a passagem aérea</segment>
    <segment id="22">, transporte terrestre</segment>
    <segment id="23">, alimentação</segment>
    <segment id="24">, hotel</segment>
    <segment id="25">, escolta policial e alguns luxos de torcedor</segment>
    <segment id="26">, como</segment>
    <segment id="27">como tocar na réplica da taça de campeão carioca - quase barrada no aeroporto -</segment>
    <segment id="28">, conversar com o presidente Peter Siemsen e ver de perto a emoção de uma mulher que jamais havia entrado num avião e a pureza no sorriso de Júlia Flu</segment>
    <segment id="29">, sobrenome que já abriu sua primeira porta na vida aos nove meses de idade.

- Viemos de São Luís do Maranhão e não trouxemos um documento com foto.</segment>
    <segment id="30">A Polícia Federal não queria deixar a Júlia embarcar de jeito nenhum.</segment>
    <segment id="31">A sorte é que uma delegada era Fluminense e</segment>
    <segment id="32">, quando viu a certidão de nascimento da Júlia Flu</segment>
    <segment id="33">, providenciou passaporte na hora - disse o empresário Roberto Araújo</segment>
    <segment id="34">, pai de Júlia</segment>
    <segment id="35">, tricolor até no nome</segment>
    <segment id="36">, estreante na Bombonera.</segment>
    <segment id="37">- Onde o time joga</segment>
    <segment id="38">, a gente vai.</segment>
    <segment id="39">Não tive receio de trazê-la para o jogo.</segment>
    <segment id="40">Vim com a minha esposa</segment>
    <segment id="41">, meu pai e minha mãe.</segment>
    <segment id="42">É um programa família.

'Bebê</segment>
    <segment id="43">, bebê'

Júlia virou mascote da comitiva.</segment>
    <segment id="44">A espera pela sua liberação levou uma hora com todos os passageiros embarcados.</segment>
    <segment id="45">Nada que aborrecesse.</segment>
    <segment id="46">Ao ouvirem os gritos de "bebê</segment>
    <segment id="47">, bebê"</segment>
    <segment id="48">, as aeromoças</segment>
    <segment id="49">, vestidas com a faixa de campeão carioca</segment>
    <segment id="50">, não sabiam</segment>
    <segment id="51">sese os torcedores queriam a criança ou mais cerveja</segment>
    <segment id="52">, liberada durante o voo.</segment>
    <segment id="53">Mas, quando a taça foi pedida</segment>
    <segment id="54">, todos entenderam que</segment>
    <segment id="55">sese tratava do troféu de campeão carioca.</segment>
    <segment id="56">Era a réplica</segment>
    <segment id="57">, masmas a empolgação foi legítima.</segment>
    <segment id="58">E a taça foi exposta</segment>
    <segment id="59">, junto com Júlia Flu</segment>
    <segment id="60">, que sorriu</segment>
    <segment id="61">, posou para fotos e quase derrubou o pesado objeto na cabeça do presidente do clube.</segment>
    <segment id="62">Criado há dois meses</segment>
    <segment id="63">, o projeto Tricolor por Toda a Terra rendeu R$ 50 mil para o Fluminense</segment>
    <segment id="64">, quantia ínfima</segment>
    <segment id="65">sese comparada às cifras milionárias do mundo do futebol.</segment>
    <segment id="66">Mas que poderá aumentar à medida que o time avançar na Libertadores.

- Este é um voo para o Japão (referência ao Mundial de Clubes da Fifa) com várias escalas.</segment>
    <segment id="67">A de agora foi Buenos Aires...</segment>
    <segment id="68">Oferecemos toda a facilidade e segurança</segment>
    <segment id="69">para que</segment>
    <segment id="70">para que eles só</segment>
    <segment id="71">sese preocupem em torcer - disse Bernardo Pontes</segment>
    <segment id="72">, coordenador de marketing do clube.</segment>
    <segment id="73">Ângela Maria de Oliveira não conhecia o projeto.</segment>
    <segment id="74">Funcionária de serviços gerais no centro de treinamento do Fluminense</segment>
    <segment id="75">, em Xerém</segment>
    <segment id="76">, ela foi sorteada entre 600 funcionários do clube.</segment>
    <segment id="77">Nunca tinha</segment>
    <segment id="78">"andado de avião"</segment>
    <segment id="79">, como</segment>
    <segment id="80">como disse.

- Eu fui guerreira</segment>
    <segment id="81">comocomo o time</segment>
    <segment id="82">, porque</segment>
    <segment id="83">porque</segment>
    <segment id="84">, no começo</segment>
    <segment id="85">, fiquei apavorada.</segment>
    <segment id="86">Estrangeiros no voo

Sueco</segment>
    <segment id="87">, Mikael Johansson vem de outra cultura e não mostra emoção.</segment>
    <segment id="88">A não ser quando fala da implicância familiar:

- A minha mulher é Flamengo.</segment>
    <segment id="89">Então, escolhi torcer pelo Fluminense.</segment>
    <segment id="90">Virou paixão.</segment>
    <segment id="91">Mando camisas para o meu neto em Gotemburgo.</segment>
    <segment id="92">Em contraste com Mikael</segment>
    <segment id="93">, o italiano Stefano Fioravante</segment>
    <segment id="94">, de Bolonha</segment>
    <segment id="95">, era só alegria.</segment>
    <segment id="96">Extrovertido</segment>
    <segment id="97">, chegou a cantar a tarantela</segment>
    <segment id="98">, masmas teve a voz abafada pelo grito de "Nense"</segment>
    <segment id="99">quando</segment>
    <segment id="100">, já em Buenos Aires</segment>
    <segment id="101">, o ônibus que levava o grupo chegou ao restaurante no bairro de Palermo.</segment>
    <segment id="102">Há alguns anos</segment>
    <segment id="103">, ir à Bombonera era um risco.</segment>
    <segment id="104">As ruas estreitas</segment>
    <segment id="105">, desertas e escuras da Boca eram uma armadilha.</segment>
    <segment id="106">Assaltos e confrontos faziam parte da rotina.</segment>
    <segment id="107">O estádio</segment>
    <segment id="108">, um tanto decadente na estrutura</segment>
    <segment id="109">, ainda é intimidador.</segment>
    <segment id="110">Antes de subirem os 170 degraus até a parte destinada à torcida do Fluminense</segment>
    <segment id="111">, os tricolores foram escoltados pela polícia pelas ruas de uma engarrafada Buenos Aires em dia de greve nos transportes ferroviários.</segment>
    <segment id="112">Apesar de toda a hostilidade na frase da barra brava La Doce</segment>
    <segment id="113">, dentro da Bombonera os torcedores do Fluminense só tiveram contato visual com os xeneizes.</segment>
    <segment id="114">Ao tentar diminuir o adversário</segment>
    <segment id="115">, o Boca quer dizer que é grande e não faz amizades.</segment>
    <segment id="116">Os tricolores pensam o contrário.</segment>
    <segment id="117">PUBLICADA NO VESPERTINO PARA TABLET "</segment>
    <segment id="118">O GLOBO</segment>
    <segment id="119">A MAIS"</segment>
  </rst>
</analysis>