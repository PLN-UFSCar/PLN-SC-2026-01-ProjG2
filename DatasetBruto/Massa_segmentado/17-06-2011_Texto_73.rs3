  <rst>
    <segment id="1">Para Erundina</segment>
    <segment id="2">, aliança entre PT e Maluf é 'desconfortável'</segment>
    <segment id="3">SÃO PAULO - A deputada federal Luiza Erundina (PSB)</segment>
    <segment id="4">, candidata a vice-prefeita na chapa do petista Fernando Haddad para a Prefeitura de São Paulo</segment>
    <segment id="5">,</segment>
    <segment id="6">disse que será "desconfortável" participar de atos de campanha ao lado do deputado Paulo Maluf (PP).</segment>
    <segment id="7">O deputado deve anunciar nesta segunda o apoio à candidatura de Haddad</segment>
    <segment id="8">, depois de ter tido um de seus aliados nomeado para comandar a Secretaria Nacional de Saneamento Ambiental do Ministério das Cidades no governo e Dilma Rousseff.</segment>
    <segment id="9">Para apoiar o tucano José Serra (PSDB)</segment>
    <segment id="10">, Maluf negociava mais espaço no governo de Geraldo Alckmin (PSDB).</segment>
    <segment id="11">Mas o PT teria sido mais ágil e</segment>
    <segment id="12">, por isso</segment>
    <segment id="13">, estaria mais perto de garantir o apoio de Maluf.</segment>
    <segment id="14">Em entrevista aos jornais "</segment>
    <segment id="15">Folha de S.Paulo" e "</segment>
    <segment id="16">O Estado de S. Paulo"</segment>
    <segment id="17">, Erundina disse que</segment>
    <segment id="18">, caso</segment>
    <segment id="19">caso tivesse sido consultada</segment>
    <segment id="20">, teria opinado contra o apoio de Maluf à candidatura.</segment>
    <segment id="21">Classificou a possibilidade de adesão de seu adversário histórico</segment>
    <segment id="22">comocomo um problema de governos de coalizão.</segment>
    <segment id="23">Ela disse acreditar que este "é um preço que não vale à pena pagar por ele (Maluf)"</segment>
    <segment id="24">, caso</segment>
    <segment id="25">caso o apoio resulte em restrição aos compromissos políticos de PT e PSB.
- Eu não acredito que Paulo Maluf participará de eventos públicos junto comigo e junto com Haddad</segment>
    <segment id="26">, isso é contraproducente do ponto de vista eleitoral.</segment>
    <segment id="27">Eu evitaria essa situação</segment>
    <segment id="28">porque</segment>
    <segment id="29">porque cria um certo mal-estar na relação com aquelas pessoas que tem mais ligação com o povo</segment>
    <segment id="30">, que sabem quem é Maluf</segment>
    <segment id="31">, que sabem quem é a direita nessa cidade - disse Erundina.</segment>
    <segment id="32">Ela foi oficialmente anunciada</segment>
    <segment id="33">comocomo vice na chapa de Fernando Haddad em evento na última sexta-feira.</segment>
    <segment id="34">Na ocasião</segment>
    <segment id="35">, a deputada disse que uma de suas tarefas será tentar trazer a senadora Marta Suplicy para a campanha petista em São Paulo.</segment>
    <segment id="36">Mas Marta também criticou a negociação do PT com Maluf.</segment>
    <segment id="37">Disse que seria um "pesadelo" maior que ter o respaldo do PSD de Gilberto Kassab.</segment>
    <segment id="38">Pesquisa Datafolha
Pesquisa Datafolha divulgada na noite deste domingo mostrou que Haddad subiu de 3% para 8% na intenção de voto: está agora em terceiro</segment>
    <segment id="39">, empatado com Soninha Francine (PPS).</segment>
    <segment id="40">Em primeiro vem Serra</segment>
    <segment id="41">, com 30%</segment>
    <segment id="42">, seguido de Celso Russomanno (PRB)</segment>
    <segment id="43">, com 21%.</segment>
  </rst>
</analysis>