  <rst>
    <segment id="1">Seleção brasileira feminina de futebol fica com a prata
RIO - A seleção feminina de futebol esteve a três minutos do tricampeonato nos Jogos Pan-Americanos de Guadalajara</segment>
    <segment id="2">, masmas acabou ficando com a medalha de prata.</segment>
    <segment id="3">Depois de abrir o placar logo aos três minutos</segment>
    <segment id="4">, com um golaço de Débora</segment>
    <segment id="5">, o Brasil permitiu o empate do Canadá aos 42 do segundo tempo: 1 a 1</segment>
    <segment id="6">, resultado que</segment>
    <segment id="7">sese manteve na prorrogação.</segment>
    <segment id="8">Nos pênaltis</segment>
    <segment id="9">, Graziele e Débora perderam suas cobranças</segment>
    <segment id="10">, e as canadenses venceram por 4 a 3.

- A gente lutou até o final</segment>
    <segment id="11">, e foi o que valeu.</segment>
    <segment id="12">A gente perdeu brigando</segment>
    <segment id="13">, e jogando com garra.</segment>
    <segment id="14">Temos que dar força para quem perdeu (pênaltis)</segment>
    <segment id="15">, estamos todos juntos nesta hora - afirmou em entrevista à TV a lateral-direita Maurine</segment>
    <segment id="16">, que viveu um drama pessoal durante o Pan: seu pai morreu no último domingo</segment>
    <segment id="17">, masmas ela decidiu permanecer até o fim na competição.</segment>
    <segment id="18">O começo do jogo não poderia ser melhor para o Brasil: aos três minutos</segment>
    <segment id="19">, Débora recuperou a bola no ataque e acertou um lindo chute no ângulo esquerdo da goleira Karina Leblanc.</segment>
    <segment id="20">No restante do primeiro tempo</segment>
    <segment id="21">, a seleção do técnico Kleiton Lima</segment>
    <segment id="22">sese limitou a segurar a pressão canadense.</segment>
    <segment id="23">No segundo tempo</segment>
    <segment id="24">, o Brasil melhorou</segment>
    <segment id="25">, principalmente a partir dos 20 minutos.</segment>
    <segment id="26">Mas abusou dos erros de finalização.</segment>
    <segment id="27">Aos 22</segment>
    <segment id="28">, Thaís recebeu de Débora e chutou de primeira</segment>
    <segment id="29">, masmas Leblanc fez grande defesa.</segment>
    <segment id="30">Aos 30</segment>
    <segment id="31">, a goleira do Canadá apareceu novamente em chute cruzado de Maurine.</segment>
    <segment id="32">Débora também parou em Leblanc</segment>
    <segment id="33">, e ainda desperdiçou o rebote.</segment>
    <segment id="34">Pouco depois</segment>
    <segment id="35">, aos 42 minutos</segment>
    <segment id="36">, veio o castigo:</segment>
    <segment id="37">após escanteio da esquerda</segment>
    <segment id="38">, Sinclair subiu sozinha e aproveitou saída errada da goleira Bárbara para empatar de cabeça.</segment>
    <segment id="39">Na prorrogação</segment>
    <segment id="40">, o Brasil tentou mostrar que ainda estava vivo na decisão</segment>
    <segment id="41">, apesar do baque do empate no fim.</segment>
    <segment id="42">Mas o cansaço falou mais alto</segment>
    <segment id="43">, e as jogadas de ataque não fluíam</segment>
    <segment id="44">comocomo antes.</segment>
    <segment id="45">O Canadá também atacou pouco</segment>
    <segment id="46">, e quando chegou com perigo</segment>
    <segment id="47">, aos nove minutos</segment>
    <segment id="48">, Bárbara fez boa defesa em chute cruzado.</segment>
    <segment id="49">Aos seis do segundo tempo</segment>
    <segment id="50">, Sinclair recebeu livre em contra-ataque</segment>
    <segment id="51">masmas também parou na goleira do Brasil</segment>
    <segment id="52">, que compensou a falha no empate canadense.</segment>
    <segment id="53">A três minutos do fim</segment>
    <segment id="54">, Ketlen foi lançada pela direita</segment>
    <segment id="55">masmas</segment>
    <segment id="56">, com duas brasileiras livres na entrada da área</segment>
    <segment id="57">, preferiu o chute</segment>
    <segment id="58">, por cima</segment>
    <segment id="59">, na melhor chance da equipe na prorrogação.</segment>
    <segment id="60">Na disputa de pênaltis</segment>
    <segment id="61">, Madson marcou o primeiro do Canadá</segment>
    <segment id="62">, Franciele empatou</segment>
    <segment id="63">, Sinclair fez o segundo</segment>
    <segment id="64">, Maurine igualou novamente</segment>
    <segment id="65">, e Booth converteu mais um para as campeãs da Concocaf.</segment>
    <segment id="66">A goleira Leblanc pegou o chute de Graziele e Smith ampliou para o Canadá.</segment>
    <segment id="67">Ketlen manteve a esperança brasileira fazendo o seu gol.</segment>
    <segment id="68">Chapman teve a bola do jogo</segment>
    <segment id="69">masmas chutou na trave</segment>
    <segment id="70">, dando chance para o empate do Brasil</segment>
    <segment id="71">, masmas Leblanc voltou a brilhar defendendo a cobrança de Débora.</segment>
  </rst>
</analysis>