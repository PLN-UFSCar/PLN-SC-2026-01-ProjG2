  <rst>
    <segment id="1">Fez dois jogos e embolsou R$ 15 milhões</segment>
    <segment id="2">Novo milionário baiano já resgatou a bolada e a lotérica onde ele fez o jogo bombou</segment>
    <segment id="3">Imagine poder comprar  536 carros populares</segment>
    <segment id="4">, 2.680 motos ou ter um redimento mensal de R$ 72 mil na poupança.</segment>
    <segment id="5">Estas são algumas opções</segment>
    <segment id="6">, listadas pela própria Caixa Econômica</segment>
    <segment id="7">, do sortudo baiano que ganhou  R$ 14.998.563</segment>
    <segment id="8">,50 no concurso 1.370 da Mega Sena</segment>
    <segment id="9">, no sábado.</segment>
    <segment id="10">Segundo a assessoria da  CEF</segment>
    <segment id="11">, dois jogos  acertaram  os números  02</segment>
    <segment id="12">, 04, 05</segment>
    <segment id="13">, 27, 49 e 59.</segment>
    <segment id="14">Acreditava-</segment>
    <segment id="15">sese, por isso</segment>
    <segment id="16">, que fossem duas pessoas.</segment>
    <segment id="17">Mas a CEF confirmou</segment>
    <segment id="18">, no fim da tarde de ontem</segment>
    <segment id="19">,  que foi apenas um  apostador</segment>
    <segment id="20">, que agora  vai levar  a bolada sozinho.</segment>
    <segment id="21">O sortudo fez a aposta na  casa lotérica Leite</segment>
    <segment id="22">, que fica no Pituba Parque Center</segment>
    <segment id="23">, no bairro do Itaigara</segment>
    <segment id="24">, e já retirou o montante em uma das agênciasda Caixa em Salvador.</segment>
    <segment id="25">Durante todo o dia de ontem</segment>
    <segment id="26">, o movimento na casa lotérica foi intenso.</segment>
    <segment id="27">Um cartaz no vidro da porta de entrada avisava:</segment>
    <segment id="28">“Saiu daqui o último vencedor da Mega Sena”.</segment>
    <segment id="29">O guardador de carros Ednaldo Campos</segment>
    <segment id="30">, 37,  já é tão conhecido na lotérica que a atendente pensou que ele fosse o sortudo.</segment>
    <segment id="31">“Faço o mesmo jogo há seis anos e sempre jogo aqui</segment>
    <segment id="32">porque</segment>
    <segment id="33">porque trabalho em frente.</segment>
    <segment id="34">No mês passado</segment>
    <segment id="35">, ganhei R$ 303 em uma Quadra</segment>
    <segment id="36">, aqui.</segment>
    <segment id="37">Faltaram apenas duas dezenas para eu levar a bolada.</segment>
    <segment id="38">Mas eu não desisto</segment>
    <segment id="39">, vou continuar".</segment>
    <segment id="40">Sonhar é de graça

Supersticioso</segment>
    <segment id="41">, o corretor de imóveis</segment>
    <segment id="42">, Aurélio Gouveia não pensou duas vezes em escolher a “pé quente lotérica Leite” para fazer suas apostas da semana.</segment>
    <segment id="43">Questionado sobre o que faria com o prêmio de quase R$ 15 milhões</segment>
    <segment id="44">, respondeu de imediato:</segment>
    <segment id="45">“Doava R$ 5 milhões para obras sociais.</segment>
    <segment id="46">O restante aplicaria na poupança e viveria de ‘patrão’”</segment>
    <segment id="47">, disse Aurélio</segment>
    <segment id="48">, sorridente.</segment>
    <segment id="49">Já o segurança Francisco Azevedo</segment>
    <segment id="50">, 35, empolgou-</segment>
    <segment id="51">sese e acabou desnorteado ao falar o que faria com a bolada:

“Rapaz</segment>
    <segment id="52">, eu compraria um carro.</segment>
    <segment id="53">Aliás, um só não.</segment>
    <segment id="54">Acho que dois.</segment>
    <segment id="55">Um apartamento.</segment>
    <segment id="56">Mas, perâe.</segment>
    <segment id="57">É muita grana</segment>
    <segment id="58">, não é?</segment>
    <segment id="59">Eu compraria logo um village</segment>
    <segment id="60">, botaria a família toda para morar.</segment>
    <segment id="61">Compraria também uma fazenda para criar umas vacas e uns bois.</segment>
    <segment id="62">Ih, rapaz!</segment>
    <segment id="63">Olhe, tenho que fazer uma listinha</segment>
    <segment id="64">, viu?</segment>
    <segment id="65">”.</segment>
  </rst>
</analysis>