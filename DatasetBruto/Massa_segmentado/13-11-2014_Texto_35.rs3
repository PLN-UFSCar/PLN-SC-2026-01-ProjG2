  <rst>
    <segment id="1">Menino baiano tem trﾃδｪs mﾃδ｣es na certidﾃδ｣o</segment>
    <segment id="2">Mﾃδ｣es adotivas que formam um casal conseguiram o direito na Justiﾃδｧa</segment>
    <segment id="3">Uma decisﾃδ｣o inﾃδｩdita da Justiﾃδｧa brasileira permitiu que uma crianﾃδｧa</segment>
    <segment id="4">, nascida na Bahia</segment>
    <segment id="5">, seja registrada com o nome de trﾃδｪs mﾃδ｣es.</segment>
    <segment id="6">Alﾃδｩm da mﾃδ｣e biolﾃδｳgica</segment>
    <segment id="7">, constarﾃδ｡</segment>
    <segment id="8">, no documento do menino</segment>
    <segment id="9">, os nomes das mﾃδ｣es adotivas</segment>
    <segment id="10">, que mantﾃδｪm um relacionamento homoafetivo.
Clﾃδ｡udio Daltro</segment>
    <segment id="11">, o juiz da Vara da Infﾃδ｢ncia e Juventude de Vitﾃδｳria da Conquista</segment>
    <segment id="12">, no sudoeste baiano</segment>
    <segment id="13">, a 509 quilﾃδｴmetros de Salvador</segment>
    <segment id="14">, determinou que a guarda da crianﾃδｧa ficarﾃδ｡ com o casal.</segment>
    <segment id="15">A decisﾃδ｣o foi tomada apﾃδｳs acordo entre as partes.</segment>
    <segment id="16">A mﾃδ｣e biolﾃδｳgica poderﾃδ｡ visitar regularmente o menino</segment>
    <segment id="17">, hoje com 3 anos.</segment>
    <segment id="18">A decisﾃδ｣o do juiz saiu no fim de outubro passado</segment>
    <segment id="19">, e o cartﾃδｳrio de Vitﾃδｳria da Conquista jﾃδ｡ foi notificado para incluir</segment>
    <segment id="20">, no registro de nascimento da crianﾃδｧa</segment>
    <segment id="21">, os nomes das mﾃδ｣es adotivas.</segment>
    <segment id="22">No documento atual</segment>
    <segment id="23">, consta apenas o nome da mﾃδ｣e biolﾃδｳgica.</segment>
    <segment id="24">Na decisﾃδ｣o</segment>
    <segment id="25">, o magistrado acatou os argumentos da defesa das mﾃδ｣es adotivas sobre a multiparentalidade</segment>
    <segment id="26">, que ﾃδｩ a possibilidade de inserﾃδｧﾃδ｣o de mais de um pai ou de uma mﾃδ｣e no registro civil.</segment>
    <segment id="27">Daltro nﾃδ｣o quis comentar a decisﾃδ｣o</segment>
    <segment id="28">, que gera polﾃδｪmica (leia acima a opiniﾃδ｣o dos entrevistados).</segment>
    <segment id="29">No Brasil</segment>
    <segment id="30">, hﾃδ｡ casos de multiparentalidade que envolvem dois pais e uma mﾃδ｣e ou duas mﾃδ｣es e um pai</segment>
    <segment id="31">, masmas este ﾃδｩ o primeiro com um casal homossexual.</segment>
    <segment id="32">ﾃ｢竄ｬﾅ擢oi um processo surpreendenteﾃ｢竄ｬ</segment>
    <segment id="33">, comentou o advogado Michael Farias</segment>
    <segment id="34">, que atuou na defesa do casal.</segment>
    <segment id="35">Vocﾃδｪ sabia?</segment>
    <segment id="36">O casal homoafetivo iniciou o processo de adoﾃδｧﾃδ｣o em 2012</segment>
    <segment id="37">, quando a crianﾃδｧa jﾃδ｡ morava com as duas havia mais de um ano.</segment>
    <segment id="38">A mﾃδ｣e biolﾃδｳgica havia doado o bebﾃδｪ com trﾃδｪs meses</segment>
    <segment id="39">ﾃδs mulheres</segment>
    <segment id="40">, que eram suas conhecidas</segment>
    <segment id="41">, por nﾃδ｣o ter</segment>
    <segment id="42">comocomo criﾃδ｡-lo.</segment>
    <segment id="43">Mas nﾃδ｣o queria ver o nome das duas na certidﾃδ｣o de nascimento do filho.</segment>
    <segment id="44">Rolou tensﾃδ｣o</segment>
    <segment id="45">Trﾃδｪs relatﾃδｳrios foram produzidos pela Vara da Infﾃδ｢ncia: dois favorﾃδ｡veis e um contra a adoﾃδｧﾃδ｣o.</segment>
    <segment id="46">Para o defensor pﾃδｺblico Pedro de Fialho</segment>
    <segment id="47">, que atuou na defesa da mﾃδ｣e biolﾃδｳgica</segment>
    <segment id="48">, a decisﾃδ｣o atende ﾃ｢竄ｬﾅ登 melhor interesse da crianﾃδｧaﾃ｢竄ｬ.</segment>
    <segment id="49">As mﾃδ｣es adotivas</segment>
    <segment id="50">, de 33 e 43 anos</segment>
    <segment id="51">, sese mudaram recentemente para Sﾃδ｣o Paulo.</segment>
    <segment id="52">A biolﾃδｳgica</segment>
    <segment id="53">, 19, quer fazer o mesmo ainda este ano para ficar perto do filho.</segment>
    <segment id="54">Na boca da galera!</segment>
    <segment id="55">"</segment>
    <segment id="56">Eu, como</segment>
    <segment id="57">como mﾃδ｣e e</segment>
    <segment id="58">comocomo pessoa</segment>
    <segment id="59">, acho que ele foi agraciado por ter trﾃδｪs mﾃδ｣es.</segment>
    <segment id="60">E acredito que serﾃδ｡ mais feliz ainda.</segment>
    <segment id="61">Apoio totalmente.</segment>
    <segment id="62">Nﾃδ｣o tenho preconceitos".</segment>
    <segment id="63">Maria Betﾃδ｢nia</segment>
    <segment id="64">, 47, Comerciante.</segment>
    <segment id="65">"</segment>
    <segment id="66">Sempre existiu um pai e uma mﾃδ｣e.</segment>
    <segment id="67">Nﾃδ｣o existe justificativa para um absurdo desses.</segment>
    <segment id="68">Isso prejudica o desenvolvimento da crianﾃδｧa em todos os sentidos".</segment>
    <segment id="69">Telwilson Bispo</segment>
    <segment id="70">, 37, Motorista.</segment>
    <segment id="71">"Nﾃδ｣o tenho nada contra quem</segment>
    <segment id="72">sese relaciona com pessoas do mesmo sexo.</segment>
    <segment id="73">Mas essa situaﾃδｧﾃδ｣o ﾃδｩ pesada para uma crianﾃδｧa.</segment>
    <segment id="74">Acho que a confunde.</segment>
    <segment id="75">E a figura masculina?</segment>
    <segment id="76">"</segment>
    <segment id="77">Viviane Macedo</segment>
    <segment id="78">, 30, Comerciante.</segment>
    <segment id="79">"</segment>
    <segment id="80">Pior seria</segment>
    <segment id="81">sese a crianﾃδｧa estivesse na rua ou</segment>
    <segment id="82">sese envolvendo com o mundo do crime.</segment>
    <segment id="83">A maioria dos homossexuais corre atrﾃδ｡s e tem condiﾃδｧﾃδｵes de cuidar bem".</segment>
    <segment id="84">Eddy Anderson</segment>
    <segment id="85">, 29, Motoboy.
"</segment>
    <segment id="86">O importante ﾃδｩ o amor.</segment>
    <segment id="87">Tanto faz</segment>
    <segment id="88">sese sﾃδ｣o trﾃδｪs mulheres ou dois homens.</segment>
    <segment id="89">O importante ﾃδｩ a crianﾃδｧa ser criada com amor.</segment>
    <segment id="90">A gente vﾃδｪ por aﾃδｭ pais e mﾃδ｣es que maltratam seus filhos".</segment>
    <segment id="91">Solange Rodrigues</segment>
    <segment id="92">, 55, Comerciante.</segment>
    <segment id="93">"</segment>
    <segment id="94">Nﾃδ｣o concordo de jeito nenhum com uma coisa dessas.</segment>
    <segment id="95">Deus deixou o homem e a mulher para serem os pais de uma crianﾃδｧa.</segment>
    <segment id="96">Uma situaﾃδｧﾃδ｣o dessas prejudica a crianﾃδｧa".</segment>
    <segment id="97">Tﾃδ｢nia Maria Simﾃδｵes</segment>
    <segment id="98">, 50, Serviﾃδｧos Gerais.</segment>
  </rst>
