  <rst>
    <segment id="1">Para eles</segment>
    <segment id="2">, achado não é roubado</segment>
    <segment id="3">Tentaram</segment>
    <segment id="4">sese defender afirmando que acharam a moto na rua</segment>
    <segment id="5">Os amigos Everaldo Silva Passos</segment>
    <segment id="6">, 22 anos</segment>
    <segment id="7">, e Éverton Oliveira Santos</segment>
    <segment id="8">, 21, combinaram de</segment>
    <segment id="9">sese encontrar</segment>
    <segment id="10">,  ontem</segment>
    <segment id="11">, no Shopping Iguatemi</segment>
    <segment id="12">, para comprar roupas.</segment>
    <segment id="13">Mas, uma moto Yamaha YBR</segment>
    <segment id="14">, estacionada com a chave engatada e os faróis ligados</segment>
    <segment id="15">, em frente ao Centro Empresarial Iguatemi</segment>
    <segment id="16">, chamou a atenção de Everaldo.</segment>
    <segment id="17">“Eu peguei a moto e dei carona a ele (Éverton)”</segment>
    <segment id="18">, afirmou Everaldo.</segment>
    <segment id="19">Os dois foram presos por policiais militares e indiciados por furto</segment>
    <segment id="20">, na Delegacia de Repressão a Furtos e Roubos de Veículos.</segment>
    <segment id="21">Everaldo já tem duas passagens por porte ilegal de arma pelas Delegacias de Periperi e Tancredo Neves.</segment>
    <segment id="22">Ele contou que</segment>
    <segment id="23">, atualmente</segment>
    <segment id="24">, trabalhava servindo café em um estabelecimento</segment>
    <segment id="25">, no Salvador Shopping</segment>
    <segment id="26">, e estava no horário de almoço quando foi preso.</segment>
    <segment id="27">Éverton é pintor e não tinha ficha na polícia.</segment>
  </rst>
