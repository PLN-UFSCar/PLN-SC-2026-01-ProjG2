  <rst>
    <segment id="1">No 'vai ou racha'</segment>
    <segment id="2">, Flamengo e Traffic têm reunião decisiva</segment>
    <segment id="3">Em crise desde agosto</segment>
    <segment id="4">, e ainda sem contratos que detalhem direitos e deveres de cada uma das partes</segment>
    <segment id="5">, a parceria entre Flamengo e Traffic terá um dia decisivo nesta quinta-feira</segment>
    <segment id="6">, em uma reunião entre o dono da empresa de marketing esportivo</segment>
    <segment id="7">, J. Hawilla</segment>
    <segment id="8">, e o vice-presidente de Finanças rubro-negro</segment>
    <segment id="9">, Michel Levy.</segment>
    <segment id="10">Insatisfeita pela demora na assinatura dos contratos e por não ter participado do acerto com o patrocinador master do uniforme</segment>
    <segment id="11">, a Traffic suspendeu há quatro meses o pagamento de sua parte (R$ 750 mil) dos salários de Ronaldinho.</segment>
    <segment id="12">Depois de meses de indefinição</segment>
    <segment id="13">, o encontro desta quinta deverá definir os rumos.</segment>
    <segment id="14">À espera da posição do Flamengo</segment>
    <segment id="15">, J. Hawilla não pode garantir que a parceria continuará:
- Não sei com que espírito o Flamengo virá para a reunião.</segment>
    <segment id="16">Se vem disposto a flexibilizar alguns pontos ou</segment>
    <segment id="17">sese vem com intenção de encerrar tudo.</segment>
    <segment id="18">O importante é encontrarmos uma solução.</segment>
    <segment id="19">Não podemos mais ficar sem contratos assinados.</segment>
    <segment id="20">Paguei oito meses sem contrato</segment>
    <segment id="21">, fiz um esforço olímpico para a parceria dar certo.</segment>
    <segment id="22">O Flamengo precisa flexibilizar um pouco - afirmou o empresário ao GLOBO</segment>
    <segment id="23">, sem detalhar em que pontos a Traffic quer que o clube ceda.</segment>
    <segment id="24">- Não vou entrar no mérito das coisas publicamente antes da reunião</segment>
    <segment id="25">, seria deselegante com o Flamengo.</segment>
    <segment id="26">Além de viabilizar a contratação de Ronaldinho</segment>
    <segment id="27">, a parceria prevê que a Traffic agencie patrocínios do uniforme e implante projetos de fidelidade e sócio-torcedor para o clube.</segment>
    <segment id="28">Um eventual rompimento entre Flamengo e Traffic não deve impedir a permanência de Ronaldinho</segment>
    <segment id="29">, que tem contrato assinado até 2014.</segment>
    <segment id="30">Mesmo se</segment>
    <segment id="31">se perder o apoio da Traffic</segment>
    <segment id="32">, o Flamengo arcará sozinho com o supersalário do craque ou buscará outro parceiro.</segment>
  </rst>
</analysis>