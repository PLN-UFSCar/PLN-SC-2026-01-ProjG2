  <rst>
    <segment id="1">Trilho virou pista</segment>
    <segment id="2">Bêbado faz besteira com carro na China</segment>
    <segment id="3">Um motorista bêbado causou problema na China: voltou para casa dirigindo sobre os trilhos do trem.</segment>
    <segment id="4">Lin Hen disse que a linha</segment>
    <segment id="5">, que passa bem atrás da casa</segment>
    <segment id="6">, seria a maneira mais segura de voltar</segment>
    <segment id="7">, masmas a aventura não deu certo: o carro do rapaz  quebrou.</segment>
    <segment id="8">Sorte dele que nenhum trem passou pelo local.</segment>
    <segment id="9">A remoção do veículo durou quatro horas.</segment>
