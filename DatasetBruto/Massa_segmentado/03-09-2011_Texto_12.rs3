  <rst>
    <segment id="1">Kadafi gosta de leite de dromedário e adora sexo com virgens</segment>
    <segment id="2">, conta ex-guarda-costas</segment>
    <segment id="3">TRÍPOLI - Muamar Kadafi - o ditador mais procurado hoje no mundo - deve estar tendo dificuldade de tomar seu leitinho: ele só bebe leite fresco de dromedário</segment>
    <segment id="4">, e havia anos os animais o acompanhavam a todos os cantos da Líbia.</segment>
    <segment id="5">Mas nestes tempos de revolução</segment>
    <segment id="6">, com seus desafetos - os rebeldes - à beira de conquistar todo o país</segment>
    <segment id="7">, o "rei dos reis da África"</segment>
    <segment id="8">, como</segment>
    <segment id="9">como Kadafi</segment>
    <segment id="10">sese autoproclamava</segment>
    <segment id="11">, sumiu.</segment>
    <segment id="12">E nas dezenas de túneis e esconderijos que ele construiu</segment>
    <segment id="13">, não há espaço para dromedários.
 - Havia sempre dromedários especiais do Kadafi</segment>
    <segment id="14">, onde quer que ele estivesse - conta Anis Lazer.</segment>
    <segment id="15">SAADI: Sapatos italianos e armas francesas 

ELOS: Documentos indicam colaboração da CIA com Líbia</segment>
    <segment id="16">Melhor não ter Anis</segment>
    <segment id="17">comocomo inimigo: ele era um dos guarda-costas do ditador e do seu filho mais poderoso</segment>
    <segment id="18">, Saif.</segment>
    <segment id="19">Trabalhava desde 2008 a serviço da família.</segment>
    <segment id="20">No discurso de Kadafi em Trípoli de 16 de fevereiro de 2011</segment>
    <segment id="21">, quando estourava a revolução na Líbia</segment>
    <segment id="22">, Anis apareceu na televisão bem atrás do dele</segment>
    <segment id="23">, impassível e assustador</segment>
    <segment id="24">, como</segment>
    <segment id="25">como "todo guarda-costas tem que ser"</segment>
    <segment id="26">, explica.</segment>
