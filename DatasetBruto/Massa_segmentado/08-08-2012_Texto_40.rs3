  <rst>
    <segment id="1">S횄징bado</segment>
    <segment id="2">횄짤 dia de garimpar ouro
Depois de duas pratas e dois bronzes</segment>
    <segment id="3">, o futebol brasileiro espera conquistar o ouro</segment>
    <segment id="4">O 횄징rbitro Pavel Kralovec</segment>
    <segment id="5">, da Rep횄쨘blica Tcheca</segment>
    <segment id="6">, poderia at횄짤 ter marcado o p횄짧nalti cometido por Sandro quando o placar estava 1 a 0 (gol de R횄쨈mulo)  para o Brasil.</segment>
    <segment id="7">Mas, mesmo assim</segment>
    <segment id="8">, a Coreia do Sul n횄짙o mostrou ontem futebol para superar a Sele횄짠횄짙o de Mano Menezes</segment>
    <segment id="9">, que ainda marcou mais dois gols</segment>
    <segment id="10">, com o artilheiro Leandro Dami횄짙o (tem seis gols na Olimp횄짯ada)</segment>
    <segment id="11">, e far횄징 no s횄징bado</segment>
    <segment id="12">, 횄혻s 11 horas</segment>
    <segment id="13">, contra o M횄짤xico</segment>
    <segment id="14">, sua terceira final ol횄짯mpica</segment>
    <segment id="15">, tentando a t횄짙o sonhada conquista da medalha de ouro</segment>
    <segment id="16">, 횄쨘nico t횄짯tulo que falta ao futebol brasileiro.</segment>
    <segment id="17">Para valorizar ainda mais o triunfo verde e amarelo</segment>
    <segment id="18">, a sele횄짠횄짙o asi횄징tica estava invicta h횄징 18 jogos.</segment>
    <segment id="19">Bem postado taticamente</segment>
    <segment id="20">, com a manuten횄짠횄짙o de Alex Sandro no meio-campo (Hulk ficou no banco) e apenas dois atacantes destacados (Leandro Dami횄짙o e Neymar)</segment>
    <segment id="21">, o Brasil suportou bem os poucos momentos de press횄짙o dos sul-coreanos e</segment>
    <segment id="22">, com autoridade</segment>
    <segment id="23">, construiu uma vit횄쨀ria tranquila.</segment>
    <segment id="24">H횄징 24 anos</segment>
    <segment id="25">, o Brasil fez sua 횄쨘ltima final dos Jogos Ol횄짯mpicos</segment>
    <segment id="26">, em Seul-1988</segment>
    <segment id="27">, quando o time que contava com Bebeto e Rom횄징rio perdeu da Uni횄짙o Sovi횄짤tica por 2 a 1 e ficou com a prata.
M횄짤xico vira jogo e 횄짤 pr횄쨀ximo alvo</segment>
    <segment id="28">O Jap횄짙o saiu na frente com um tiro de certeiro de Yuki Otsu de fora da 횄징rea aos 12 minutos</segment>
    <segment id="29">, masmas o M횄짤xico reagiu e chegou 횄혻 virada com gols deMarco Fabian</segment>
    <segment id="30">, Peralta e Javier Cort횄짤s</segment>
    <segment id="31">, classificando-</segment>
    <segment id="32">sese para enfrentar o Brasil na final do futebol masculino.</segment>
