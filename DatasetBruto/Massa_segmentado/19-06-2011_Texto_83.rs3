  <rst>
    <segment id="1">Polícia acaba com barril de pólvora</segment>
    <segment id="2">Sem alvará de funcionamento</segment>
    <segment id="3">, os donos das barracas de fogos de artifício dançaram</segment>
    <segment id="4">Os donos das 17 barracas da Feira de Fogos</segment>
    <segment id="5">, instalada na Av. Paralela há uma semana</segment>
    <segment id="6">, foram pegos de surpresa com a interdição do local</segment>
    <segment id="7">, ontem</segment>
    <segment id="8">, por falta de alvará de funcionamento.</segment>
    <segment id="9">A fiscalização</segment>
    <segment id="10">, que reuniu pela primeira vez Polícia Civil</segment>
    <segment id="11">, Exército e Procon-Ba</segment>
    <segment id="12">, foi iniciada no meio da manhã e</segment>
    <segment id="13">sese estendeu até o início da noite.</segment>
    <segment id="14">A delegada da Coordenação de Fiscalização de Produtos Controlados (CFPC)</segment>
    <segment id="15">, responsável por conceder o alvará</segment>
    <segment id="16">, Heloísa Simões</segment>
    <segment id="17">, acredita que na manhã de hoje o local volte a funcionar.</segment>
    <segment id="18">Ela aposta que os comerciantes não vão tentar burlar a interdição.</segment>
    <segment id="19">“Tivemos uma reunião com eles</segment>
    <segment id="20">, (ontem) à noite</segment>
    <segment id="21">, e eles estão bem conscientes”</segment>
    <segment id="22">, afirma.</segment>
    <segment id="23">Heloísa conta que esta foi a primeira vez que o local foi interditado</segment>
    <segment id="24">, apesar de serem detectadas irregularidades todos os anos.</segment>
    <segment id="25">Há um mês</segment>
    <segment id="26">, o  Departamento de Polícia Técnica havia feito a vistoria e os comerciantes tinham recebido a autorização para montar as barracas</segment>
    <segment id="27">, masmas a segunda fiscalização</segment>
    <segment id="28">, necessária à autorização de funcionamento</segment>
    <segment id="29">, ainda não havia sido realizada.</segment>
    <segment id="30">O presidente da  Associação dos Comerciantes de Fogos de Salvador (Acomfart)</segment>
    <segment id="31">, Marco Almeida</segment>
    <segment id="32">, alega que a presença do Circo Tihany no local até o fim de maio prejudicou a tomada dessas providências.</segment>
    <segment id="33">“Esperamos o circo sair e só tivemos informação sobre isso no dia 30”</segment>
    <segment id="34">, argumenta.</segment>
    <segment id="35">A delegada e coordenadora da CFPC conta que a fiscalização de ontem foi a segunda parte da Operação Volcano</segment>
    <segment id="36">, realizada em parceria entre Exército e Polícia Civil.</segment>
    <segment id="37">Há um mês</segment>
    <segment id="38">, houve esta ação nos municípios de Muniz Ferreira</segment>
    <segment id="39">, Cruz das Almas e Santo Antônio de Jesus para coibir a produção clandestina de fogos de artifício.</segment>
    <segment id="40">Quase cinco toneladas foram apreendidas.</segment>
    <segment id="41">Apreensão de 30.304 produtos
Algumas amostras serão conduzidas para a análise do DPT e o restante do material foi levado pela Polícia do Exército para posterior destruição.</segment>
    <segment id="42">O Procon-BA ainda autuou os comerciantes pela venda de produtos irregulares</segment>
    <segment id="43">, com ausência de prazo de validade</segment>
    <segment id="44">, validade vencida e instruções em língua estrangeira.</segment>
  </rst>
</analysis>