  <rst>
    <segment id="1">Delegacia tem romaria de fﾃδ｣s
Unidade policial vira palco e meninada fica na plateia conferindo a movimentaﾃδｧﾃδ｣o</segment>
    <segment id="2">Em clima de solidariedade</segment>
    <segment id="3">, fﾃδ｣s</segment>
    <segment id="4">, principalmente adolescentes</segment>
    <segment id="5">, gritam na porta da Delegacia de Ruy Barbosa (a 379 km de Salvador) que os integrantes da banda de pagode New Hit sﾃδ｣o inocentes.</segment>
    <segment id="6">Cartazes e cartas foram entregues aos familiares para serem repassados aos nove mﾃδｺsicos  presos.</segment>
    <segment id="7">Com gritos</segment>
    <segment id="8">comocomo ﾃ｢竄ｬﾅ鉄oltam os New Hitﾃ｢竄ｬ e ﾃ｢竄ｬﾅ哲ew Hit</segment>
    <segment id="9">, acreditamos na sua inocﾃδｪnciaﾃ｢竄ｬ</segment>
    <segment id="10">, elas</segment>
    <segment id="11">sese acotovelavam para tentar ver algum sinal do grupo.</segment>
    <segment id="12">ﾃ｢竄ｬﾅ鉄ei todas as mﾃδｺsicas deles e nﾃδ｣o acredito que eles fizeram isto.</segment>
    <segment id="13">Querem queimar a imagem deles</segment>
    <segment id="14">, masmas a verdade serﾃδ｡ provada e eu sempre serei fﾃδ｣ﾃ｢竄ｬ</segment>
    <segment id="15">, garantiu Isabela Melo</segment>
    <segment id="16">, 18 anos.</segment>
    <segment id="17">Quatro pessoas estiveram espontaneamente na delegacia para prestarem depoimentos a favor do grupo.</segment>
    <segment id="18">Uma delas</segment>
    <segment id="19">, G.S.</segment>
    <segment id="20">, 18, contou que as meninas estavam assanhadas e gritando que queriam fazer amor com os mﾃδｺsicos.</segment>
    <segment id="21">ﾃ｢竄ｬﾅ擢omos as primeiras a entrar no camarim deles e nﾃδ｣o fizeram nada com a gente.</segment>
    <segment id="22">Acredito que elas fizeram sexo</segment>
    <segment id="23">porque</segment>
    <segment id="24">porque quiseram e para aparecer</segment>
    <segment id="25">,  estﾃδ｣o fazendo esta acusaﾃδｧﾃδ｣o todaﾃ｢竄ｬ.</segment>
    <segment id="26">Durante o dia de ontem</segment>
    <segment id="27">, o clima na Delegacia de Ruy Barbosa foi de muita expectativa e movimentaﾃδｧﾃδ｣o de familiares</segment>
    <segment id="28">, produtores</segment>
    <segment id="29">, advogados e fﾃδ｣s dos integrantes do grupo New
Hit.</segment>
    <segment id="30">Tio sai em defesa</segment>
    <segment id="31">O grande objetivo de todos na porta da delegacia era saber sobre o destino dos nove mﾃδｺsicos:</segment>
    <segment id="32">sese seriam liberados ou transferidos para o Presﾃδｭdio Regional de Feira de Santana (a 108 km de Salvador).</segment>
    <segment id="33">O tio de um dos integrantes</segment>
    <segment id="34">, Valmir Bonfim</segment>
    <segment id="35">, informou que o sobrinho negou ter participado do ato e que as meninas teriam concordado com a relaﾃδｧﾃδ｣o.</segment>
    <segment id="36">ﾃ｢竄ｬﾅ摘las informaram que tinham 18 anos e saﾃδｭram normalmente do veﾃδｭculo</segment>
    <segment id="37">, sem ao menos demonstrar nada de anormalﾃ｢竄ｬ</segment>
    <segment id="38">, disse.</segment>
    <segment id="39">Agora ﾃδｩ com a juﾃδｭza</segment>
    <segment id="40">Segundo o delegado de Ruy Barbosa</segment>
    <segment id="41">, Marcelo Cavalcante</segment>
    <segment id="42">, os documentos do flagrante foram encaminhados para o Judiciﾃδ｡rio e Ministﾃδｩrio Pﾃδｺblico local para serem analisados.</segment>
    <segment id="43">ﾃ｢竄ｬﾅ摘les podem decidir pelo relaxamento da prisﾃδ｣o em flagrante</segment>
    <segment id="44">, liberdade provisﾃδｳria mediante pagamento de fianﾃδｧa ou decretar a prisﾃδ｣o preventiva.</segment>
    <segment id="45">Caso eles permaneﾃδｧam presos</segment>
    <segment id="46">, vamos pedir a transferﾃδｪncia</segment>
    <segment id="47">, jﾃδ｡ que a delegacia nﾃδ｣o tem condiﾃδｧﾃδｵes de abrigar o grupoﾃ｢竄ｬ</segment>
    <segment id="48">, frisou.</segment>
    <segment id="49">No inﾃδｭcio da noite de ontem</segment>
    <segment id="50">, o delegado avisou aos familiares que o Judiciﾃδ｡rio teria informado que sﾃδｳ</segment>
    <segment id="51">sese pronunciaria hoje.</segment>
    <segment id="52">ﾃ｢竄ｬﾅ典udo foi protocolado</segment>
    <segment id="53">, agora ﾃδｩ a juﾃδｭza dar a decisﾃδ｣oﾃ｢竄ｬ</segment>
    <segment id="54">, explicou o delegado.</segment>
    <segment id="55">Os nove integrantes estﾃδ｣o em uma cela improvisada no alojamento dos policiais civis.</segment>
    <segment id="56">Eles estﾃδ｣o recebendo visitas e alimentos dos familiares.</segment>
    <segment id="57">De acordo com o advogado Cleber Andrade</segment>
    <segment id="58">, que faz a defesa da banda</segment>
    <segment id="59">, ontem foi dada entrada na Justiﾃδｧa com um pedido de liberdade provisﾃδｳria.</segment>
    <segment id="60">ﾃ｢竄ｬﾅ鄭credito que conseguiremos liberﾃδ｡-los uma vez que atendem a todos os requisitos subjetivos exigidos por lei</segment>
    <segment id="61">, como</segment>
    <segment id="62">como residﾃδｪncia fixa</segment>
    <segment id="63">, rﾃδｩus primﾃδ｡rios</segment>
    <segment id="64">, entre outrosﾃ｢竄ｬ</segment>
    <segment id="65">, destaca o defensor.</segment>
