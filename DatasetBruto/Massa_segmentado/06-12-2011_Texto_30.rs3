  <rst>
    <segment id="1">Ivete está nova em folha</segment>
    <segment id="2">A cantora vai ficar quietinha em casa por 20 dias com supervisão médica</segment>
    <segment id="3">“</segment>
    <segment id="4">É preciso ter saúde para ficar doente</segment>
    <segment id="5">, viu gente?</segment>
    <segment id="6">”</segment>
    <segment id="7">, disparou com seu jeitão de sempre Ivete Sangalo</segment>
    <segment id="8">, da sacada do quarto do Hospital Aliança</segment>
    <segment id="9">, no Rio Vermelho</segment>
    <segment id="10">, ao receber alta ontem à tarde.</segment>
    <segment id="11">As palavras</segment>
    <segment id="12">, dirigidas à imprensa</segment>
    <segment id="13">, foram acompanhadas por beijos para um grupo de jovens fãs que montava  plantão desde a segunda-feira para tietagem à cantora</segment>
    <segment id="14">, que foi internada no domingo</segment>
    <segment id="15">, para tratar de uma meningite viral benigna.</segment>
    <segment id="16">Pela manhã</segment>
    <segment id="17">, o neurologista Elias Pimenta e os infectologistas  Antônio Bandeira e Claudilson Bastos  haviam previsto alta em até  72 horas</segment>
    <segment id="18">,  mas</segment>
    <segment id="19">mas decidiram  liberá-la por volta das 17 horas.</segment>
    <segment id="20">A última pendência</segment>
    <segment id="21">, citada pelo médico Claudilson Bastos</segment>
    <segment id="22">, eram   exames laboratoriais</segment>
    <segment id="23">, que deram resultado negativo.</segment>
    <segment id="24">“Mas ele ficará sob supervisão médica</segment>
    <segment id="25">, em casa</segment>
    <segment id="26">, por 20 dias”</segment>
    <segment id="27">, ressalvou o neurologista.</segment>
    <segment id="28">Ontem, Ivete recebeu carinho</segment>
    <segment id="29">, flores e telefonemas de vários artistas e ao chegar em casa</segment>
    <segment id="30">, a danada voltou para o vício da internet e postou uma mensagem no Twitter .</segment>
    <segment id="31">"</segment>
    <segment id="32">Já estou na minha casinha</segment>
    <segment id="33">, em paz</segment>
    <segment id="34">, e cheia de saúde.</segment>
    <segment id="35">Estou bem</segment>
    <segment id="36">, masmas ainda preciso repousar para ficar nos ‘trinks’.</segment>
    <segment id="37">Ficarei um pouquinho ausente</segment>
    <segment id="38">, masmas pensando em vocês todo o tempo"</segment>
    <segment id="39">, disse aos internautas.</segment>
  </rst>
</analysis>