  <rst>
    <segment id="1">Ela tomou carão de colega na Câmara</segment>
    <segment id="2">A vereadora Léo Kret do Brasil (PR) nem imaginou que um simples domingo na praia de Ipitanga e o seu vício no Twitter iriam lhe custar tão caro.</segment>
    <segment id="3">Ela postou fotos no microblog</segment>
    <segment id="4">, em companhia de amigos</segment>
    <segment id="5">, familiares e do amor</segment>
    <segment id="6">, o auxiliar-administrativo Ricardo Yamazaki</segment>
    <segment id="7">, 22 anos.</segment>
    <segment id="8">Léo Kret</segment>
    <segment id="9">sese animou tanto com os amigos que esqueceu de esconder o "peitinho" durante a foto</segment>
    <segment id="10">Uma das fotos causou polêmica entre colegas vereadores e a sociedade.</segment>
    <segment id="11">Na imagem</segment>
    <segment id="12">, Léo aparece “pagando peitinho”.</segment>
    <segment id="13">“</segment>
    <segment id="14">A alça da blusa escorregou e eu não vi.</segment>
    <segment id="15">O Twitter serve para a gente falar da nossa vida mesmo.</segment>
    <segment id="16">E não mostro só minha vida pessoal</segment>
    <segment id="17">, mostro meus trabalhos”</segment>
    <segment id="18">, diz a vereadora</segment>
    <segment id="19">, que postou ontem fotos dela em  uma operação tapa-buracos</segment>
    <segment id="20">, em Engenho Velho de Brotas.
hoje cedinhoo finalizando os tapa buracos no engenho velho de brotas.</segment>
    <segment id="21">agora a rua esta lindaaa corfira na ft galera.</segment>
    <segment id="22">Para rebater as críticas</segment>
    <segment id="23">, a vereadora colocou no twitter @Oficial_LeoKret fotos dela "trabalhando".</segment>
    <segment id="24">Já o vereador Paulo Câmara (PSDB)</segment>
    <segment id="25">, presidente da Comissão de Ética da Câmara Municipal</segment>
    <segment id="26">, não gostou nem um pouco das fotos de Léo e a mandou tomar juízo.</segment>
    <segment id="27">“Temos uma ótima relação</segment>
    <segment id="28">, masmas liguei para ela e pedi mais cautela.</segment>
    <segment id="29">Afinal</segment>
    <segment id="30">, sese ela quer ser vista e tratada</segment>
    <segment id="31">comocomo uma mulher</segment>
    <segment id="32">, tem que</segment>
    <segment id="33">sese comportar decentemente</segment>
    <segment id="34">comocomo outras vereadoras”</segment>
    <segment id="35">, avisou.</segment>
    <segment id="36">Segundo ele</segment>
    <segment id="37">, sese Léo Kret repetir  a dose</segment>
    <segment id="38">, pode ser processada e até perder o mandato.</segment>
    <segment id="39">Com ou sem peitinho</segment>
    <segment id="40">, Léo é querida pelos eleitores.</segment>
    <segment id="41">“</segment>
    <segment id="42">Se ela ajuda o povo</segment>
    <segment id="43">, para mim ela é mil.</segment>
    <segment id="44">Piores são esses políticos engravatados que não fazem nada”</segment>
    <segment id="45">, diz o vendedor Carlos Alves</segment>
    <segment id="46">, 38 anos.</segment>
    <segment id="47">Exibida</segment>
    <segment id="48">A vereadora Léo Kret é conhecida por sempre aparecer em festas e camarotes e não esconde nada do que faz na balada ou na Câmara dos seus seguidores no Twitter
OPINE:</segment>
    <segment id="49">Você concorda com a maneira com que a vereadora</segment>
    <segment id="50">Léo Kret expõe sua vida íntima?</segment>
    <segment id="51">Comente!</segment>
  </rst>
</analysis>