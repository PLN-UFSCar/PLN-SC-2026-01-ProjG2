  <rst>
    <segment id="1">Ceará derrota o Internacional em pleno Beira-Rio

RIO - O Internacional foi surpreendido no Beira-Rio pelo Ceará na noite deste sábado.</segment>
    <segment id="2">Numa dessas ironias do destino</segment>
    <segment id="3">, Iarley</segment>
    <segment id="4">, que já jogou no time gaúcho e foi homenageado com uma camisa e uma placa pelos serviços prestados ao Colorado</segment>
    <segment id="5">, antes do jogo</segment>
    <segment id="6">, marcou o gol da vitória do alvinegro cearense: 1 a 0.</segment>
    <segment id="7">O gol do jogo aconteceu aos 19 minutos do segundo tempo</segment>
    <segment id="8">, em cobrança de escanteio.</segment>
    <segment id="9">Fabrício desviou e Iarley emendou de cabeça</segment>
    <segment id="10">, um bonito 'peixinho'.</segment>
    <segment id="11">O gol obrigou o Inter a avançar ainda mais e o técnico Falcão</segment>
    <segment id="12">, contrariando a torcida que pedia Oscar</segment>
    <segment id="13">, promoveu a entrada de Gilberto no lugar de Bolatti.</segment>
    <segment id="14">Nos acréscimos</segment>
    <segment id="15">, o atacante Washington</segment>
    <segment id="16">, do Ceará</segment>
    <segment id="17">, ainda teve tempo de ser expulso.</segment>
    <segment id="18">Ele acertou uma cotovelada em Rodrigo e levou o cartão vermelho.</segment>
    <segment id="19">Falcão teve que descer para o vestiário ouvindo a torcida do Inter chamá-lo de burro.</segment>
    <segment id="20">O Ceará tem agora três pontos em dois jogos.</segment>
    <segment id="21">O Inter</segment>
    <segment id="22">, apenas um ponto (empatou na estreia com o Santos).</segment>
    <segment id="23">Confira a classificação da Série A.
INTERNACIONAL 0X1 CEARÁ
Local: Beira-Rio</segment>
    <segment id="24">, em Porto Alegre
Data/hora: 28/05</segment>
    <segment id="25">, às 18h30 (de Brasília)
Renda/público: R$ 185.605</segment>
    <segment id="26">,00 / 12.971 pagantes
Árbitro: Celio Amorim (SC)
Auxiliares: Kleber Lucio (SC) e Marco Antonio Martins (SC)
Cartões amarelos: Bolatti</segment>
    <segment id="27">, Daniel (INT)</segment>
    <segment id="28">, Eusébio</segment>
    <segment id="29">, João Marcos</segment>
    <segment id="30">, Osvaldo (CEA)</segment>
    <segment id="31">Cartões vermelhos: Washington (CEA)
Gols: Iarley 19'/2°</segment>
    <segment id="32">T (0-1)
INTERNACIONAL: Lauro</segment>
    <segment id="33">, Daniel (Glaydson</segment>
    <segment id="34">, 15'/2°T)</segment>
    <segment id="35">, Bolívar</segment>
    <segment id="36">, Rodrigo e Kleber</segment>
    <segment id="37">; Guiñazu</segment>
    <segment id="38">, Bolatti (Gilberto</segment>
    <segment id="39">, 20'/2°</segment>
