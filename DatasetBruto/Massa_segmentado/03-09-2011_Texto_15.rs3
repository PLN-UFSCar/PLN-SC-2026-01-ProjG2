  <rst>
    <segment id="1">Vasco busca rodada perfeita e liderança contra América-MG em Sete Lagoas
RIO - Levando-</segment>
    <segment id="2">sese em conta o nível dos adversários dos candidatos ao título</segment>
    <segment id="3">, é inevitável uma conclusão:o</segment>
    <segment id="4">Vasco tem uma rodada sob medida para chegar à liderança do Campeonato Brasileiro.</segment>
    <segment id="5">Após viver dias difíceis com o drama do técnico Ricardo Gomes</segment>
    <segment id="6">, internado com um acidente vascular encefálico</segment>
    <segment id="7">, o time enfrenta neste domingo</segment>
    <segment id="8">, às 16h</segment>
    <segment id="9">, na Arena do Jacaré</segment>
    <segment id="10">, em Sete Lagoas</segment>
    <segment id="11">, o América-MG</segment>
    <segment id="12">, lanterna do campeonato.</segment>
    <segment id="13">Se vencer e o Corinthians perder para o Coritiba</segment>
    <segment id="14">, fora de casa</segment>
    <segment id="15">, o Vasco terminará a rodada em primeiro.</segment>
    <segment id="16">O favoritismo do Vasco é inegável.</segment>
    <segment id="17">Afinal</segment>
    <segment id="18">, 24 pontos e 18 posições separam o time</segment>
    <segment id="19">, vice-líder do Brasileiro</segment>
    <segment id="20">, do América-MG.</segment>
    <segment id="21">Mas o técnico Cristóvão Borges</segment>
    <segment id="22">, que assumiu o time durante a internação de Ricardo Gomes</segment>
    <segment id="23">, faz um alerta.

- O América-MG tem bons jogadores e</segment>
    <segment id="24">, a partir de agora</segment>
    <segment id="25">, vai jogar decisões no campeonato - disse o treinador.</segment>
    <segment id="26">- A liderança</segment>
    <segment id="27">, neste momento</segment>
    <segment id="28">, confirmaria tudo o que o time tem feito de bom</segment>
    <segment id="29">, mesmo neste momento difícil.</segment>
    <segment id="30">Dá confiança.</segment>
    <segment id="31">E futebol é um jogo de moral.</segment>
    <segment id="32">Com o moral elevado</segment>
    <segment id="33">, você cresce e passa a jogar num nível maior.</segment>
    <segment id="34">Cristóvão não terá o lateral-esquerdo Jumar</segment>
    <segment id="35">, que está machucado</segment>
    <segment id="36">, assim</segment>
    <segment id="37">comocomo o atacante Alecsandro.</segment>
    <segment id="38">Além deles</segment>
    <segment id="39">, Felipe segue</segment>
    <segment id="40">sese recuperando de cirurgia</segment>
    <segment id="41">, e Dedé está na seleção.</segment>
    <segment id="42">Victor Ramos formará a zaga com Renato Silva</segment>
    <segment id="43">, Márcio Careca será o lateral-esquerdo e Élton</segment>
    <segment id="44">, artilheiro do time no Brasileiro</segment>
    <segment id="45">, será o atacante ao lado de Éder Luís.

- Sempre que precisamos mexer no time</segment>
    <segment id="46">, temos sido obrigados a mudar mais de duas posições.</segment>
    <segment id="47">É muita coisa.</segment>
    <segment id="48">Mas a resposta de quem entra tem sido boa - disse Cristóvão</segment>
    <segment id="49">, confiante no elenco vascaíno.

América-MG: Neneca</segment>
    <segment id="50">, Otávio</segment>
    <segment id="51">, Micão e William Rocha</segment>
    <segment id="52">; Marcos Rocha</segment>
    <segment id="53">, Dudu</segment>
    <segment id="54">, Amaral</segment>
    <segment id="55">, Rodriguinho (Ulisses) e Gílson</segment>
    <segment id="56">; Fábio Junior e Kempes.</segment>
    <segment id="57">Vasco: Fernando Prass</segment>
    <segment id="58">, Fágner</segment>
    <segment id="59">, Victor Ramos</segment>
    <segment id="60">, Renato Silva e Márcio Careca</segment>
    <segment id="61">; Rômulo</segment>
    <segment id="62">, Eduardo Costa</segment>
    <segment id="63">, Juninho Pernambucano e Diego Souz</segment>
    <segment id="64">; Éder Luís e Élton.</segment>
    <segment id="65">Juiz: Sandro Meira Ricci (DF).</segment>
  </rst>
