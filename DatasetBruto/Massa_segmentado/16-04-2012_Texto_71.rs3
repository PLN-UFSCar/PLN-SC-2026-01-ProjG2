  <rst>
    <segment id="1">Bebum mata criança e fica com amnésia</segment>
    <segment id="2">Jefferson foi preso em Mirangaba</segment>
    <segment id="3">, acusado de ter assassinado a facadas um garoto</segment>
    <segment id="4">Policiais civis do município de Mirangaba (a 356 km de Salvador) prenderam em flagrante o pintor Jefferson Marlos Mendes Oliveira</segment>
    <segment id="5">, 20 anos</segment>
    <segment id="6">, acusado de ter matado com um golpe de faca no pescoço o menino José Iarly Gonçalves Souza</segment>
    <segment id="7">, de  2 anos de idade.</segment>
    <segment id="8">O crime ocorreu no fim da tarde da última quinta</segment>
    <segment id="9">, no Conjunto Habitacional Viver Mirangaba</segment>
    <segment id="10">, na casa de Patrícia</segment>
    <segment id="11">, vizinha de Cláudia Campos Gonçalves</segment>
    <segment id="12">, mãe do garoto.</segment>
    <segment id="13">Embora alegue que não lembra de ter cometido o crime</segment>
    <segment id="14">, já que começou a consumir álcool às 10h e o assassinato ocorreu às 16h</segment>
    <segment id="15">, o acusado foi autuado em flagrante por homicídio.</segment>
    <segment id="16">“</segment>
    <segment id="17">Não tenho dúvidas de que foi ele que cometeu este crime.</segment>
    <segment id="18">Primeiro</segment>
    <segment id="19">porque</segment>
    <segment id="20">porque ele estava sozinho na casa onde aconteceu o fato e estava com as roupas sujas de sangue.</segment>
    <segment id="21">Além do histórico dele</segment>
    <segment id="22">, que  tentou ferir a mãe várias vezes sem motivo”</segment>
    <segment id="23">, informou o delegado Pedro Gonçalves da Silva</segment>
    <segment id="24">, titular da delegacia local.</segment>
    <segment id="25">O crime brutal aconteceu no momento em que a vizinha teria saído para buscar o filho na creche e deixado o acusado fazendo um serviço na casa.</segment>
    <segment id="26">Segundo informações de populares</segment>
    <segment id="27">, José teria entrado pela porta da cozinha da casa e</segment>
    <segment id="28">, passados alguns minutos</segment>
    <segment id="29">, os pais da criança foram chamados pelo próprio acusado.</segment>
    <segment id="30">“Ele chamou as pessoas avisando que meu filho estava ferido.</segment>
    <segment id="31">Ele (José) estava na cozinha e a faca utilizada no assassinato lavada em cima da pia”</segment>
    <segment id="32">, confirma Cláudia.</segment>
    <segment id="33">A Polícia Militar do município foi acionada imediatamente e levou o garoto para o Hospital Municipal</segment>
    <segment id="34">, masmas ele já chegou sem vida à emergência.</segment>
    <segment id="35">Com informações do site e da Rádio Mirangaba Notícia.

Maluco?</segment>
    <segment id="36">O corpo do menino foi encontrado vestido apenas com uma camiseta</segment>
    <segment id="37">, o que levantou a suspeita de que ele tivesse sido vítima de violência sexual.</segment>
    <segment id="38">“</segment>
    <segment id="39">A necropsia não constatou que houve estupro”</segment>
    <segment id="40">, afirmou o delegado</segment>
    <segment id="41">, acrescentando que Jefferson tem histórico de abuso sexual contra crianças.</segment>
    <segment id="42">“Acreditamos que ele tenha algum distúrbio mental</segment>
    <segment id="43">, já que a mãe revelou que ele dorme com duas facas.</segment>
    <segment id="44">As investigações  serão para descobrir o motivo do crime”</segment>
    <segment id="45">, frisou.</segment>
    <segment id="46">O corpo do garoto foi necropsiado no IML de Jacobina e sepultado na tarde de ontem no cemitério municipal de Mirangaba.</segment>
  </rst>
</analysis>