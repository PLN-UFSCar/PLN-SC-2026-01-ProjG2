  <rst>
    <segment id="1">Investimentos que podem virar ouro em 5 anos</segment>
    <segment id="2">RIO - As iniciativas para turbinar os investimentos em busca de atletas de alto rendimento já começaram a surtir efeito na rotina dos esportistas.</segment>
    <segment id="3">Integrante do conjunto (oito atletas que</segment>
    <segment id="4">, juntas</segment>
    <segment id="5">, fazem uma coreografia) e reserva do dueto (duas atletas que</segment>
    <segment id="6">sese apresentam) do nado sincronizado brasileiro</segment>
    <segment id="7">, Giovana Nunes Stephan</segment>
    <segment id="8">, de 21 anos</segment>
    <segment id="9">, já experimenta alterações significativas nos métodos de treinamento e na aparelhagem disponível durante sua preparação.</segment>
    <segment id="10">Além disso</segment>
    <segment id="11">, ela recebe cerca de R$ 1.700 por mês do Programa Bolsa Atleta</segment>
    <segment id="12">, do Ministério dos Esportes</segment>
    <segment id="13">, desde 2005.
- De 2006 para 2007</segment>
    <segment id="14">, os investimentos no nado sincronizado cresceram bastante.</segment>
    <segment id="15">Passamos a fazer mais viagens e a participar de clínicas com técnicos estrangeiro - exemplificou Giovana.</segment>
    <segment id="16">Sem grandes resultados em Jogos Olímpicos</segment>
    <segment id="17">, o conjunto de nado sincronizado do Brasil costuma figurar da 10 à 12 colocação</segment>
    <segment id="18">, entre 24 participantes.</segment>
    <segment id="19">O dueto jamais conseguiu</segment>
    <segment id="20">sese classificar</segment>
    <segment id="21">, já que a competição abriga apenas oito seleções.</segment>
    <segment id="22">Londres é um sonho distante para a dupla brasileira</segment>
    <segment id="23">, masmas</segment>
    <segment id="24">, em 2016</segment>
    <segment id="25">, quando o Rio será a cidade-sede</segment>
    <segment id="26">, nossas meninas estarão na piscina nas duas modalidades.</segment>
    <segment id="27">Até lá</segment>
    <segment id="28">, os recursos são mais do que bem-vindos</segment>
    <segment id="29">, para possibilitar um salto qualitativo das nadadoras.</segment>
    <segment id="30">E Giovana espera estar entre elas.

- O fato de treinarmos no Maria Lenk</segment>
    <segment id="31">, que fará parte do Centro Olímpico de Treinamento (complexo que será erguido na área do Autódromo Nelson Piquet</segment>
    <segment id="32">, em Jacarepaguá) já é muito importante.</segment>
    <segment id="33">Lá, temos sala de musculação e quartos para descansarmos depois dos treinos - $a nadadora do Flamengo.</segment>
    <segment id="34">Quando fala sobre a possibilidade de voltar a</segment>
    <segment id="35">sese apresentar para a torcida brasileira num grande evento - ela disputou os Jogos Pan-Americanos de 2007</segment>
    <segment id="36">, no Rio -</segment>
    <segment id="37">, a voz de Giovana muda:

- Penso em 2016 direto.</segment>
    <segment id="38">É um sonho.</segment>
    <segment id="39">Quero muito participar</segment>
    <segment id="40">, ver aquela torcida linda</segment>
    <segment id="41">, maravilhosa</segment>
    <segment id="42">, colorida...</segment>
    <segment id="43">Como no Pan</segment>
    <segment id="44">, nossa coreografia será um presente para a torcida.</segment>
    <segment id="45">Nem imagino</segment>
    <segment id="46">comocomo será a emoção!</segment>
  </rst>
</analysis>