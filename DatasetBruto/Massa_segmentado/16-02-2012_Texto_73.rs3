  <rst>
    <segment id="1">Tarado preso no dia do aniversário</segment>
    <segment id="2">Homem confessa que</segment>
    <segment id="3">sese masturbou e ejaculou em uma mulher</segment>
    <segment id="4">, dentro do buzu</segment>
    <segment id="5">Ao invés de presentes e festa para comemorar o aniversário</segment>
    <segment id="6">, o rodoviário José Carlos de Jesus Moura foi parar atrás das grades</segment>
    <segment id="7">, acusado de importunação ofensiva ao pudor</segment>
    <segment id="8">, na manhã de ontem</segment>
    <segment id="9">, dia em que completou 37 anos.</segment>
    <segment id="10">José confessou que</segment>
    <segment id="11">sese masturbou e ejaculou nas calças de uma vendedora de 34 anos</segment>
    <segment id="12">, dentro de um ônibus da empresa Vitral</segment>
    <segment id="13">, que fazia a linha Sussurana-Barra</segment>
    <segment id="14">, por volta das 9h da manhã de ontem.</segment>
    <segment id="15">Tudo começou quando o acusado entrou no buzu</segment>
    <segment id="16">, que passava pela região da Avenida Paralela.</segment>
    <segment id="17">“Eu entrei no ônibus</segment>
    <segment id="18">, que estava bem cheio.</segment>
    <segment id="19">Pedi licença a ela (a vítima) para passar.</segment>
    <segment id="20">Mas, acho que ela não me ouviu.</segment>
    <segment id="21">Aí fiquei atrás dela.</segment>
    <segment id="22">Ela continuou lá</segment>
    <segment id="23">, com a lupa dela</segment>
    <segment id="24">, sem reclamar.</segment>
    <segment id="25">Não é querendo me aproveitar</segment>
    <segment id="26">, masmas</segment>
    <segment id="27">sese ela não estivesse gostando ela falava</segment>
    <segment id="28">, ‘estarrava’.</segment>
    <segment id="29">Ela não disse nada.</segment>
    <segment id="30">Ela só viu quando uma outra mulher falou”</segment>
    <segment id="31">, argumenta José</segment>
    <segment id="32">, tentando</segment>
    <segment id="33">sese defender.</segment>
    <segment id="34">A vítima</segment>
    <segment id="35">, porém</segment>
    <segment id="36">porém, relata uma versão totalmente diferente.</segment>
    <segment id="37">“Ele é um safado</segment>
    <segment id="38">, e ainda é mentiroso.</segment>
    <segment id="39">Pode ter certeza de que</segment>
    <segment id="40">sese eu tivesse um canivete ou uma faca dentro da bolsa eu teria cortado ele.</segment>
    <segment id="41">As mulheres no ônibus ficaram revoltadas.</segment>
    <segment id="42">Os meus parentes também demoraram para chegar</segment>
    <segment id="43">, senão a coisa para ele iria ficar feia”</segment>
    <segment id="44">, diz a vítima</segment>
    <segment id="45">, que passou mal por causa do ocorrido.</segment>
    <segment id="46">Ela teve de ser internada</segment>
    <segment id="47">, no Hospital da Bahia</segment>
    <segment id="48">, onde iria passar a noite de ontem.</segment>
    <segment id="49">Vítima tomou um grande susto</segment>
    <segment id="50">A vítima afirma ainda que o acusado “deu sorte”</segment>
    <segment id="51">, pois</segment>
    <segment id="52">pois não havia muitos homens no buzu</segment>
    <segment id="53">, e os poucos que estavam não partiram para agredi-lo.</segment>
    <segment id="54">A vendedora prestou depoimento à delegada Simone Moutinho</segment>
    <segment id="55">, plantonista da Delegacia de Tancredo Neves.</segment>
    <segment id="56">Ela diz que</segment>
    <segment id="57">, como</segment>
    <segment id="58">como o buzu estava cheio e ela estava distraída</segment>
    <segment id="59">, nem percebeu a aproximação do tarado.</segment>
    <segment id="60">Porém, levou um susto quando uma passageira chamou a atenção</segment>
    <segment id="61">, denunciando que José estava</segment>
    <segment id="62">sese masturbando.</segment>
    <segment id="63">Foi então que ela virou e notou a calça suja de esperma.</segment>
    <segment id="64">Ficou excitado

Ele confessa que ficou excitado ao</segment>
    <segment id="65">sese encostar na vítima e ejaculou na calça da moça</segment>
    <segment id="66">, na região do bumbum.</segment>
    <segment id="67">José garante que não colocou o pênis para fora da bermuda.</segment>
    <segment id="68">Segundo ele</segment>
    <segment id="69">, a calça da vítima ficou melada</segment>
    <segment id="70">porque</segment>
    <segment id="71">porque o líquido teria escapado pela lateral da bermuda</segment>
    <segment id="72">, pois</segment>
    <segment id="73">pois estava sem cueca.</segment>
    <segment id="74">Moradora do bairro Sussuarana</segment>
    <segment id="75">, a vítima o desmente</segment>
    <segment id="76">, afirmando que ele colocou o membro sexual para fora.</segment>
    <segment id="77">“Ele derramou tudo em cima de mim.</segment>
    <segment id="78">Me melou toda.</segment>
    <segment id="79">Até o meu chinelo ficou melado”</segment>
    <segment id="80">, revolta-</segment>
    <segment id="81">sese a moça.</segment>
    <segment id="82">José trabalha na empresa Contrac</segment>
    <segment id="83">, que faz transporte alternativo entre o bairro Itapuã e Lauro de Freitas.</segment>
    <segment id="84">Ele mora em Itinga</segment>
    <segment id="85">, tem namorada e é pai de garota de 14 anos</segment>
    <segment id="86">Após a vítima perceber a atitude do tarado</segment>
    <segment id="87">, os outros passageiros do buzu seguraram ele</segment>
    <segment id="88">, que tentou fugir do ônibus pulando pela janela.</segment>
    <segment id="89">O motorista do buzu percebeu a movimentação estranha e a gritaria dos passageiros.</segment>
    <segment id="90">A vítima mostrou ao condutor a calça molhada.</segment>
    <segment id="91">Foi então que o motorista do buzu resolveu conduzir e parar o veículo no módulo da Polícia Militar</segment>
    <segment id="92">, localizado na Estação Rodoviária.</segment>
    <segment id="93">No local</segment>
    <segment id="94">, o acusado José foi preso pelos policiais militares da 1º CIPM (Pernambués) e conduzido para a Delegacia de Tancredo Neves.</segment>
    <segment id="95">Durante depoimento à delegada Simone Moutinho</segment>
    <segment id="96">, José confessou o delito.</segment>
    <segment id="97">Ele não tinha ficha na polícia.</segment>
    <segment id="98">O acusado mora no bairro de Itinga</segment>
    <segment id="99">, em Lauro de Freitas.</segment>
    <segment id="100">Ele tem namorada e uma filha de 14 anos.</segment>
  </rst>
