    <segment id="19">, segundo informaﾃδｧﾃδｵes da Central de Polﾃδｭcia (Centel).</segment>
    <segment id="20">Existe a versﾃδ｣o de que o assassino desceu do carro para atirar.</segment>
    <segment id="21">A polﾃδｭcia investiga a informaﾃδｧﾃδｵes de que a discussﾃδ｣o teve relaﾃδｧﾃδ｣o com a remuneraﾃδｧﾃδ｣o dos serviﾃδｧos da vﾃδｭtima.</segment>
    <segment id="22">Um dos projﾃδｩteis</segment>
