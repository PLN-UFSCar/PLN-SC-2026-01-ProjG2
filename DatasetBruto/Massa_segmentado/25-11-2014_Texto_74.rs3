    <segment id="4">comocomo denunciar o assassino</segment>
    <segment id="5">O homem de pele clara</segment>
    <segment id="6">, estatura mediana</segment>
    <segment id="7">, corpo franzino e aparﾃδｪncia de mais de 40 anos era conhecido por Maresia.</segment>
