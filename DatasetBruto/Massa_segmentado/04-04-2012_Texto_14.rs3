  <rst>
    <segment id="1">Feriadão terá seis ferries na atividade</segment>
    <segment id="2">A previsão é de que cerca de 90 mil pessoas cruzem a Baía de Todos-os-Santos</segment>
    <segment id="3">A TWB, concessionária do sistema ferryboat</segment>
    <segment id="4">, realiza a partir de hoje uma operação especial para transportar os cerca de 11 mil veículos e 90 mil pessoas que vão atravessar a Baía de Todos-os-Santos ao longo do feriadão da Semana Santa.</segment>
    <segment id="5">A empresa anuncia que vai contar com até seis ferries para fazer a travessia marítima entre hoje e a próxima segunda-feira</segment>
    <segment id="6">, período da operação especial.</segment>
    <segment id="7">A programação fixa de embarques será intercalada com horários extras enquanto houver demanda</segment>
    <segment id="8">, o que permitirá partidas em intervalos de até 30 minutos</segment>
    <segment id="9">, em média.</segment>
    <segment id="10">Por causa do grande fluxo de veículos concentrado neste feriado</segment>
    <segment id="11">,  o embarque de caminhões e ônibus será suspenso.</segment>
    <segment id="12">Esta medida é implantada a fim de aumentar a vazão dos carros que a concessionária estima transportar.</segment>
    <segment id="13">Como nos feriados anteriores</segment>
    <segment id="14">, o sistema ferryboat funcionará sem interrupção.</segment>
    <segment id="15">Hora marcada</segment>
    <segment id="16">Ontem a TWB liberou mais um lote de passagens para venda com hora marcada nos horários alternativos dos dias 5</segment>
    <segment id="17">, 6, 8 e 9/4.</segment>
    <segment id="18">Estes bilhetes podem ser adquiridos nas bilheterias dos terminais de São Joaquim e Bom Despacho ou pela internet</segment>
    <segment id="19">, através do Sibe –</segment>
    <segment id="20">Sistema de Bilhetagem Eletrônica para clientes já cadastrados.</segment>
  </rst>
</analysis>