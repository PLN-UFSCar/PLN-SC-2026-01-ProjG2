  <rst>
    <segment id="1">Exaltasamba: Mumuzinho pode ser vocal</segment>
    <segment id="2">A carreira de cantor de Mumuzinho está começando.</segment>
    <segment id="3">Ele lança em breve primeiro CD
Mumuzinho</segment>
    <segment id="4">, 28 anos</segment>
    <segment id="5">, que ficou conhecido por integrar o programa</segment>
    <segment id="6">“Esquenta!</segment>
    <segment id="7">” (Globo)</segment>
    <segment id="8">, é o  possível nome para ocupar a vaga de Thiaguinho no Exaltasamba.</segment>
    <segment id="9">“Fico honrado quando começam a falar meu nome</segment>
    <segment id="10">, masmas não houve nenhum contato oficial”</segment>
    <segment id="11">, diz o jovem cantor</segment>
    <segment id="12">, que acabou de gravar um CD.</segment>
    <segment id="13">No último sábado</segment>
    <segment id="14">, o outro vocalista do Exalta</segment>
    <segment id="15">, Péricles</segment>
    <segment id="16">, lançou carreira solo num show em Recife com casa cheia.</segment>
    <segment id="17">Na apresentação</segment>
    <segment id="18">, o gordinho mostrou novas canções e relembrou os sucessos.</segment>
  </rst>
