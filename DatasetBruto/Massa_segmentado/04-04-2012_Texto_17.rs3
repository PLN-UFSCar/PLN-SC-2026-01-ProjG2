  <rst>
    <segment id="1">Direto de Areia Branca Ory Beat vem aí</segment>
    <segment id="2">Em iorubá</segment>
    <segment id="3">, Ory quer dizer cabeça.</segment>
    <segment id="4">O beat é a batida.</segment>
    <segment id="5">Tudo para conscientizar</segment>
    <segment id="6">A hora de apagar a velinha está chegando e a banda de pagode baiana Ory Beat</segment>
    <segment id="7">sese prepara para comemorar os três anos com o lançamento do segundo CD</segment>
    <segment id="8">, no próximo mês.</segment>
    <segment id="9">Serão 15 faixas</segment>
    <segment id="10">, cinco delas autorais</segment>
    <segment id="11">, de muito suingue.</segment>
    <segment id="12">O grupo</segment>
    <segment id="13">, que saiu da localidade de Areia Branca</segment>
    <segment id="14">, em Lauro de Freitas</segment>
    <segment id="15">, tem 11 músicos que</segment>
    <segment id="16">sese conhecem desde a infância e começaram juntos a dar os primeiros acordes  musicais.</segment>
    <segment id="17">Tárcio Santana comanda os vocais</segment>
    <segment id="18">, enquanto Marquinhos detona na bateria</segment>
    <segment id="19">;</segment>
    <segment id="20">Dudu na guitarra</segment>
    <segment id="21">;</segment>
    <segment id="22">Rik no baixo</segment>
    <segment id="23">; Chagas no teclado</segment>
    <segment id="24">, e Edu no cavaco.</segment>
    <segment id="25">Luis, Nadsom</segment>
    <segment id="26">, Jean Ferraço e Negão fazem a percussão da quebradeira.</segment>
    <segment id="27">“</segment>
    <segment id="28">Antes dos 16 anos eu só cantava em chuveiro.</segment>
    <segment id="29">Mas quando a galera</segment>
    <segment id="30">sese reunia no bairro</segment>
    <segment id="31">, eu cantava pra caramba nas rodas de música.</segment>
    <segment id="32">Até que resolvemos montar nossa própria banda.</segment>
    <segment id="33">Hoje, a galera de Areia Branca é fãzona da gente”</segment>
    <segment id="34">, garante o vocalista.</segment>
    <segment id="35">Com todo esse gás</segment>
    <segment id="36">, a banda sacode a poeira de Lauro de Freitas</segment>
    <segment id="37">, misturando suingue e consciência social.</segment>
    <segment id="38">Prova disso é o sucesso dos hits  “Cursinho</segment>
    <segment id="39">, Gatinha” e “Olhe a Treta”</segment>
    <segment id="40">, feitas para alertar a galera sobre a importância dos estudos e do combate às drogas.</segment>
    <segment id="41">Agenda de shows</segment>
    <segment id="42">A galera da Ory Beat está agitando Lauro de Freitas.</segment>
    <segment id="43">No próximo dia 7/4</segment>
    <segment id="44">, a banda toca no Espaço Panela de Barro</segment>
    <segment id="45">, em Areia Branca</segment>
    <segment id="46">, às 17h.</segment>
    <segment id="47">Ingresso: R$ 3.</segment>
    <segment id="48">Depois</segment>
    <segment id="49">, segue para a Arena Cultural</segment>
    <segment id="50">, no Jambeiro</segment>
    <segment id="51">, em Lauro de Freitas</segment>
    <segment id="52">, às 19h.</segment>
    <segment id="53">Entrada: R$ 3.</segment>
    <segment id="54">Ainda rola o famoso arrastão</segment>
    <segment id="55">, conhecido</segment>
    <segment id="56">comocomo Jambeiro Massa</segment>
    <segment id="57">, no qual os meninos tocam em um trio pelas ruas do município</segment>
    <segment id="58">, a partir das 15h</segment>
    <segment id="59">, dias 15/4 e 27/5.</segment>
  </rst>
</analysis>