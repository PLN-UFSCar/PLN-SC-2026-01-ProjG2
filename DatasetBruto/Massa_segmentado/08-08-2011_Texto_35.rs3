  <rst>
    <segment id="1">Está soltinho</segment>
    <segment id="2">Mário Brasil é o Don Juan do pagodão
Ele quer todas.</segment>
    <segment id="3">Mesmo as mais insistentes que não param de ligar para seu celular e querem botar um chip na “fita” dele.</segment>
    <segment id="4">Mário Brasil</segment>
    <segment id="5">, vocalista da banda</segment>
    <segment id="6">O Troco</segment>
    <segment id="7">, está solto na pista.</segment>
    <segment id="8">Solteiríssimo</segment>
    <segment id="9">, como</segment>
    <segment id="10">como gosta de dizer.</segment>
    <segment id="11">“Terminei um relacionamento sério semana passada.</segment>
    <segment id="12">Estou curtindo a fase de solteiro</segment>
    <segment id="13">, masmas sei que não tenho mais 18 anos.</segment>
    <segment id="14">Preciso de um grande amor</segment>
    <segment id="15">, alguém que mude a minha vida”</segment>
    <segment id="16">, revela o cantor de 26 anos.</segment>
    <segment id="17">As fãs vibram com a disponibilidade amorosa do cantor</segment>
    <segment id="18">, que diz não fazer discriminação entre as mulheres ou candidatas.</segment>
    <segment id="19">“</segment>
    <segment id="20">Gosto de mulher.</segment>
    <segment id="21">Loira, morena ou ruiva</segment>
    <segment id="22">, não importa o tipo físico.</segment>
    <segment id="23">Apenas quero que ela saiba conversar</segment>
    <segment id="24">, que seja educada e que goste de mim de verdade”</segment>
    <segment id="25">, conta Mário</segment>
    <segment id="26">, que diz saber</segment>
    <segment id="27">comocomo tratar muito bem as mulheres.</segment>
    <segment id="28">Esse talento</segment>
    <segment id="29">, provavelmente</segment>
    <segment id="30">, adquiriu da mãe querida</segment>
    <segment id="31">, dona Berenice</segment>
    <segment id="32">, sua referência de vida.</segment>
    <segment id="33">O vocalista até fez uma tatuagem no braço com o nome dela para homenageá-la.</segment>
    <segment id="34">Cantor de uma das bandas mais bem-sucedidas do pagode</segment>
    <segment id="35">, Mário desperta o interesse das fãs.</segment>
    <segment id="36">“Ele andou bagunçando ultimamente</segment>
    <segment id="37">, masmas a gente sabe que ele quer um grande amor”</segment>
    <segment id="38">, fala a estudante Leidiane Santos</segment>
    <segment id="39">, 18 anos</segment>
    <segment id="40">, que acompanha os passos do vocalista desde os tempos em que ele era backing vocal da banda Suingue do P. Quem será a nova musa de O Troco?</segment>
  </rst>
</analysis>