  <rst>
    <segment id="1">PM é assassinado com a própria arma
Rinaldo e um desconhecido brigaram por causa da altura do som dos carros que dirigiam</segment>
    <segment id="2">O Dia dos Pais não teve  final feliz para o aposentado Miraldo Fernandes</segment>
    <segment id="3">, 66 anos.</segment>
    <segment id="4">No início da madrugada de ontem</segment>
    <segment id="5">, o filho dele</segment>
    <segment id="6">, o PM reformado Rinaldo de Oliveira Fernandes</segment>
    <segment id="7">, 33, foi assassinado a tiros</segment>
    <segment id="8">, dentro do próprio carro</segment>
    <segment id="9">, um GM Vectra de  cor prata (NIT 9652)</segment>
    <segment id="10">, no fim de linha de Fazenda Grande IV</segment>
    <segment id="11">, na região de Cajazeiras.</segment>
    <segment id="12">Segundo o rodoviário Rivaldo Fernandes</segment>
    <segment id="13">, 37, irmão do PM</segment>
    <segment id="14">, a vítima teria ido ao local levar uma prima</segment>
    <segment id="15">, quando</segment>
    <segment id="16">sese desentendeu com um desconhecido.</segment>
    <segment id="17">“Soube que os dois discutiram por causa do volume do som do carro de cada um”</segment>
    <segment id="18">, sustentou o irmão do PM assassinado</segment>
    <segment id="19">, ontem pela manhã</segment>
    <segment id="20">, no Instituto Médico-Legal Nina Rodrigues (IML).</segment>
    <segment id="21">Questionado</segment>
    <segment id="22">sese o PM tinha inimigos no bairro</segment>
    <segment id="23">, o rodoviário não soube informar.</segment>
    <segment id="24">“Era uma pessoa muito conhecida.</segment>
    <segment id="25">Que eu saiba</segment>
    <segment id="26">, não tinha inimigos”.</segment>
    <segment id="27">Ele acrescentou que o assassino utilizou a arma da vítima</segment>
    <segment id="28">, um revólver calibre 38</segment>
    <segment id="29">, para dar o tiro de misericórdia.</segment>
    <segment id="30">O rodoviário conta que o revólver e documentos do PM foram roubados.</segment>
    <segment id="31">O pai, Miraldo Fernandes</segment>
    <segment id="32">, disse que sentia um misto de tristeza e indignação.</segment>
    <segment id="33">“Cajazeiras está entregue aos bandidos”</segment>
    <segment id="34">, disparou inconformado.</segment>
    <segment id="35">Segundo o aposentado</segment>
    <segment id="36">, momentos antes da morte do policial</segment>
    <segment id="37">, familiares estavam reunidos em um bar próximo de casa</segment>
    <segment id="38">, em Cajazeira 11</segment>
    <segment id="39">, comemorando o Dia dos Pais.</segment>
    <segment id="40">“Quero saber até quando o governo do Estado vai prender os policiais e deixar os bandidos à solta”</segment>
    <segment id="41">, revoltou-</segment>
    <segment id="42">sese.</segment>
    <segment id="43">Segundo Rivaldo</segment>
    <segment id="44">, o irmão Rinaldo ingressou na Polícia Militar aos 19 anos e estava afastado da corporação</segment>
    <segment id="45">“por problemas de saúde”</segment>
    <segment id="46">, masmas ele não soube informar quais.</segment>
    <segment id="47">Testemunha: Vítima estava com a prima</segment>
    <segment id="48">Durante o exercício da profissão</segment>
    <segment id="49">, Rinaldo esteve lotado na 3ª CIPM (Fazenda Grande II / Cajazeiras).</segment>
    <segment id="50">O PM deixou mulher e uma filha de sete meses.</segment>
    <segment id="51">Rinaldo foi sepultado na tarde de ontem</segment>
    <segment id="52">, no Cemitério Bosque da Paz</segment>
    <segment id="53">, na Estrada Velha do Aeroporto</segment>
    <segment id="54">, sob forte comoção de familiares e amigos.</segment>
    <segment id="55">O crime será investigado pelo Departamento de Homicídios e Proteção à Pessoa (DHPP).</segment>
    <segment id="56">A principal testemunha do</segment>
    <segment id="57">casocaso é a prima que estava em companhia do PM no momento do crime.</segment>
    <segment id="58">A reportagem esteve ontem no DHPP</segment>
    <segment id="59">, na Pituba</segment>
    <segment id="60">, masmas não obteve informações sobre o conteúdo do depoimento que a prima do PM prestou na unidade.</segment>
  </rst>
</analysis>