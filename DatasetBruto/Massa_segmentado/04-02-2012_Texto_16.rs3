  <rst>
    <segment id="1">Guga chama Werles para sair na mão</segment>
    <segment id="2">Os foliões ficaram de cabeça quente e bateram boca no reality show</segment>
    <segment id="3">O fato de estar na segunda corda consecutiva parece que deixou o folião Guga bem irritado.</segment>
    <segment id="4">Após saber que foi o alvo da escolha do líder Werless</segment>
    <segment id="5">, o cantor não ficou nada satisfeito e resolveu tirar satisfações do colega.</segment>
    <segment id="6">O nível da conversa baixou tanto que Guga chegou a chamar o moço  para sair na  mão!</segment>
    <segment id="7">“Venha me bater</segment>
    <segment id="8">, venha!</segment>
    <segment id="9">”</segment>
    <segment id="10">, desafiou o folião estressado.</segment>
    <segment id="11">Na justificativa do voto</segment>
    <segment id="12">, Werless disse que fez apenas o que a cabeça dele mandou.</segment>
    <segment id="13">“Mandei você</segment>
    <segment id="14">porque</segment>
    <segment id="15">porque tenho certeza que me colocaria na corda</segment>
    <segment id="16">casocaso estivesse no meu lugar”</segment>
    <segment id="17">, afirmou.</segment>
    <segment id="18">A resposta veio ligeira.</segment>
    <segment id="19">“Você se</segment>
    <segment id="20">se enganou.</segment>
    <segment id="21">Eu colocaria Léo Kret</segment>
    <segment id="22">, pois</segment>
    <segment id="23">pois eu acho que ela é a única aqui que não precisa desse prêmio”</segment>
    <segment id="24">, argumentou Guga.</segment>
    <segment id="25">A temperatura subiu geral!</segment>
    <segment id="26">Será que é o valor do prêmio que está deixando os foliões tão perturbados?</segment>
  </rst>
</analysis>