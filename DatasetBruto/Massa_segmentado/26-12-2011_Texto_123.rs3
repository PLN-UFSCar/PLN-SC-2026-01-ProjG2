  <rst>
    <segment id="1">Marilson dos Santos prevê decisão nos metros finais da São Silvestre</segment>
    <segment id="2">SÃO PAULO - Uma prova aberta</segment>
    <segment id="3">, na qual o desafio será a descida da Avenida Brigadeiro Luiz Antônio</segment>
    <segment id="4">, a partir do quilômetro 13.</segment>
    <segment id="5">Para Marilson dos Santos</segment>
    <segment id="6">, de 32 anos</segment>
    <segment id="7">, atual campeão e dono de três títulos da São Silvestre</segment>
    <segment id="8">, a corrida de rua mais tradicional do país deverá ser decidida após a subida da Brigadeiro</segment>
    <segment id="9">, no ponto em que a avenida passa a ter declive acentuado.</segment>
    <segment id="10">Até a chegada no Obelisco</segment>
    <segment id="11">, no Parque do Ibirapuera</segment>
    <segment id="12">, faltarão cerca de dois quilômetros.</segment>
    <segment id="13">Segundo ele</segment>
    <segment id="14">, o novo percurso "iguala" os atletas de elite</segment>
    <segment id="15">, já que ninguém experimentou esse desafio ainda.
- Pretendo decidir a corrida antes da descida da Brigadeiro.</segment>
    <segment id="16">Acho que esse será o ponto crucial.</segment>
    <segment id="17">Antes, entrávamos na Paulista já com o coração na boca</segment>
    <segment id="18">, a poucos metros da chegada.</segment>
    <segment id="19">Não tenho ideia de</segment>
    <segment id="20">comocomo será a recepção no Ibirapuera.</segment>
    <segment id="21">Mas acho que o novo percurso fará com que todos estejam no mesmo barco.</segment>
    <segment id="22">Perdi a vantagem de conhecer todos os quilômetros - opinou Marilson</segment>
    <segment id="23">, que afirma que este ano a corrida estará mais forte e com possibilidade de melhora no tempo do recordista Paul Tergat (43m12s</segment>
    <segment id="24">, de 1995).</segment>
    <segment id="25">- Se a mudança no percurso favorecerá os quenianos</segment>
    <segment id="26">, eu não sei.</segment>
    <segment id="27">Não tenho ideia de quem poderá ser beneficiado.</segment>
    <segment id="28">É preciso correr primeiro.</segment>
    <segment id="29">Gostava da chegada na Paulista pela tradição.</segment>
    <segment id="30">Mas, se</segment>
    <segment id="31">se a mudança trará benefícios aos corredores</segment>
    <segment id="32">, tudo bem.</segment>
    <segment id="33">Dois quenianos fortes no caminho</segment>
    <segment id="34">O novo percurso da São Silvestre</segment>
    <segment id="35">, que agora cruza a Avenida Paulista pela Brigadeiro Luiz Antônio e que retirou o Minhocão</segment>
    <segment id="36">, onde há integração com o público</segment>
    <segment id="37">, já criou polêmica entre os amadores.</segment>
    <segment id="38">Ainda assim</segment>
    <segment id="39">, a edição 2011 terá o recorde de 25 mil corredores.</segment>
    <segment id="40">A largada continuará em frente ao Masp</segment>
    <segment id="41">, na Paulista</segment>
    <segment id="42">, e a distância está mantida (15km).

Marilson</segment>
    <segment id="43">, vencedor no ano passado (com 44m02)</segment>
    <segment id="44">, em 2003 e 2005</segment>
    <segment id="45">, não "testou"</segment>
    <segment id="46">o novo percurso da prova.</segment>
    <segment id="47">-</segment>
    <segment id="48">Nunca me preparo para a São Silvestre.</segment>
    <segment id="49">Mas entro sempre para ganhar (é o recordista brasileiro em títulos).</segment>
    <segment id="50">Temos noção pela altimetria</segment>
    <segment id="51">, masmas</segment>
    <segment id="52">, teste mesmo</segment>
    <segment id="53">, só na hora.</segment>
    <segment id="54">Até porque</segment>
    <segment id="55">porque o clima influencia muito e</segment>
    <segment id="56">, pelo visto</segment>
    <segment id="57">, estará bem quente - disse.</segment>
    <segment id="58">A missão dele não será fácil.</segment>
    <segment id="59">Os organizadores confirmaram a inscrição dos quenianos Kisorio Matthew e Martin Lel</segment>
    <segment id="60">, que já completaram os 21km em menos de uma hora.</segment>
    <segment id="61">Lel, que correrá a São Silvestre pela segunda vez (foi terceiro em 2003)</segment>
    <segment id="62">, é tricampeão da Maratona de Londres (2005</segment>
    <segment id="63">, 2007 e 2008)</segment>
    <segment id="64">, bicampeão de Nova York (2003 e 2007) e campeão mundial de meia maratona (2003).</segment>
    <segment id="65">Kisorio tem a terceira melhor marca em meia maratona da história e a segunda de 2011 (58m46s).</segment>
    <segment id="66">Marilson corre a distância em 59m34s.</segment>
    <segment id="67">Marilson</segment>
    <segment id="68">, também bicampeão da Maratona de Nova York (2006 e 2008)</segment>
    <segment id="69">, quer fechar o ano com chave de ouro.</segment>
    <segment id="70">Diz que a temporada foi excelente e que já</segment>
    <segment id="71">sese encontra em treinamento de base para 2012</segment>
    <segment id="72">, quando disputará a maratona olímpica em Londres.</segment>
    <segment id="73">Destacou</segment>
    <segment id="74">comocomo ponto alto de 2011 o fato de ter melhorado em mais de dois minutos o seu tempo pessoal nos 42 quilômetros (de 2h08m37s para 2h06m34s)</segment>
    <segment id="75">, quando ficou em quarto lugar na Maratona de Londres.

- Também foi o ano do Miguel.</segment>
    <segment id="76">Tive de me adaptar aos horários do meu filho.</segment>
    <segment id="77">É difícil?</segment>
    <segment id="78">Sim.</segment>
    <segment id="79">Mas acordava na madrugada feliz da vida.</segment>
    <segment id="80">Fui treinar e competir com mais vontade.</segment>
    <segment id="81">E sese não estiver muito quente</segment>
    <segment id="82">, o Miguel estará com a Juliana na linha de chegada da São Silvestre - afirmou.</segment>
    <segment id="83">Em 2010</segment>
    <segment id="84">, quando venceu a São Silvestre</segment>
    <segment id="85">, Miguel estava na barriga da mãe</segment>
    <segment id="86">, Juliana Gomes dos Santos</segment>
    <segment id="87">, recordista brasileira dos 1.500m rasos.</segment>
    <segment id="88">Ela "sofreu" ao ver a prova da área dos jornalistas.</segment>
    <segment id="89">Miguel nasceu em fevereiro.</segment>
    <segment id="90">Mudança garante vaga em Londres</segment>
    <segment id="91">Também em 2011</segment>
    <segment id="92">, Marilson finalmente conquistou uma medalha de ouro em Jogos Pan-Americanos</segment>
    <segment id="93">, em Guadalajara (10 mil metros)</segment>
    <segment id="94">, após duas tentativas frustradas em Santo Domingo (2003) e no Rio (2007).</segment>
    <segment id="95">O fim da "obsessão" representou também um ponto final para Marilson no Pan.</segment>
    <segment id="96">Ele descarta competir novamente em provas de pista em Toronto-2015.</segment>
    <segment id="97">O ano do fundista teve ainda os títulos da Meia Maratona de São Paulo e de Buenos Aires e um oitavo lugar na Meia Maratona de Nova York.</segment>
    <segment id="98">No segundo semestre ele não conseguiu concluir a Maratona de Chicago (passou mal e abandonou no quilômetro 33).</segment>
    <segment id="99">Mas assegurou vaga olímpica graças à mudança de regra de classificação adotada pela Confederação Brasileira de Atletismo.</segment>
    <segment id="100">Ele irá a Londres por estar entre os 30 melhores do ranking mundial.</segment>
  </rst>
</analysis>