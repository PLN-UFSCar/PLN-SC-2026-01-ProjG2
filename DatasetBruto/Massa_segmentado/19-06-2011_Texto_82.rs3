  <rst>
    <segment id="1">Grávida espancada até a morte</segment>
    <segment id="2">José Souza é acusado de assassinar a ex-mulher e o bebê
Será sepultado</segment>
    <segment id="3">, na manhã de hoje</segment>
    <segment id="4">, no Cemitério Municipal de Araci (a 210 km de Salvador)</segment>
    <segment id="5">, o corpo da doméstica Maria Rejane dos Santos</segment>
    <segment id="6">, 35 anos.</segment>
    <segment id="7">Grávida de 7 meses</segment>
    <segment id="8">, ela foi morta por espancamento praticado pelo ex-companheiro</segment>
    <segment id="9">, o mecânico José Souza Moura</segment>
    <segment id="10">, 38, o Zé de Bileu</segment>
    <segment id="11">, pai do bebê.</segment>
    <segment id="12">A vítima morreu</segment>
    <segment id="13">, na tarde de domingo</segment>
    <segment id="14">, no hospital da cidade</segment>
    <segment id="15">, para onde foi levada</segment>
    <segment id="16">, após a agressão ocorrida</segment>
    <segment id="17">, na noite de sábado.</segment>
    <segment id="18">O acusado do crime foi preso em flagrante e está custodiado na delegacia de Serrinha</segment>
    <segment id="19">, por medida de segurança.</segment>
    <segment id="20">Revoltada</segment>
    <segment id="21">, a população ameçava invadir a delegacia de Araci.</segment>
    <segment id="22">Janeclei dos Santos</segment>
    <segment id="23">, irmã da vítima</segment>
    <segment id="24">, contou que o casal conviveu  9 anos e eram constantes as agressões.</segment>
    <segment id="25">A Justiça havia decretado medida protetiva e o acusado teria de manter a distância de 100 metros da ex-mulher.</segment>
    <segment id="26">“</segment>
    <segment id="27">Eles estavam separados há cinco meses e ele não aceitava.</segment>
    <segment id="28">Sempre ia lá e  agredia ela”</segment>
    <segment id="29">, contou a irmã.</segment>
    <segment id="30">Usuário de drogas e de bebidas alcóolicas</segment>
    <segment id="31">, segundo  familiares</segment>
    <segment id="32">, o acusado aproveitava quando a vítima estava sozinha para  tentar reatar.</segment>
    <segment id="33">Matou e foi para o bar
No sábado à noite</segment>
    <segment id="34">, Zé de Bileu tentou entrar na casa.</segment>
    <segment id="35">Mas, como</segment>
    <segment id="36">como houve negativa da companheira</segment>
    <segment id="37">, ele teria arrombado a porta e a agredido.</segment>
    <segment id="38">A agressão foi presenciada pelo filho do casal</segment>
    <segment id="39">, de apenas 4 anos.</segment>
    <segment id="40">“Ele bebeu e consumiu drogas desde a sexta-feira.</segment>
    <segment id="41">Então, foi perturbá-la.</segment>
    <segment id="42">Após fazer tudo isto com ela</segment>
    <segment id="43">, voltou para o bar e ficou bebendo</segment>
    <segment id="44">comocomo</segment>
    <segment id="45">sese nada tivesse ocorrido”</segment>
    <segment id="46">, contou</segment>
    <segment id="47">, bastante indignado</segment>
    <segment id="48">, o primo da vítima</segment>
    <segment id="49">, Décio Rick Nilson Carvalho.</segment>
    <segment id="50">Acusado nega tudo</segment>
    <segment id="51">O tio da vítima</segment>
    <segment id="52">, Jorge dos Santos</segment>
    <segment id="53">, acrescentou que</segment>
    <segment id="54">, no dia do crime</segment>
    <segment id="55">, teria conversado com o acusado.</segment>
    <segment id="56">“Pedi que ele deixasse minha sobrinha em paz e que não voltasse a bater nela</segment>
    <segment id="57">, pois</segment>
    <segment id="58">pois estávamos cansados de tanta violência.</segment>
    <segment id="59">Mas, ele não deu ouvidos”</segment>
    <segment id="60">, frisou o familiar.</segment>
    <segment id="61">Policiais da delegacia de Araci prenderam o acusado na casa de familiares e ele negou ter agredido a ex-companheira.</segment>
    <segment id="62">“Ele alegou que</segment>
    <segment id="63">, no momento que empurrou a porta</segment>
    <segment id="64">, esta bateu na barriga da vítima</segment>
    <segment id="65">, que começou a sentir dores”</segment>
    <segment id="66">, relatou um policial da Delegacia de Araci.</segment>
  </rst>
</analysis>