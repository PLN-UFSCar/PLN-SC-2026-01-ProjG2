  <rst>
    <segment id="1">Mestre Lazinho</segment>
    <segment id="2">Lázaro</segment>
    <segment id="3">Ramos vira personagem de quadrinhos par ajudar comunidades carentes</segment>
    <segment id="4">O ator baiano ganhou contornos de HQ pelas mãos de Eduardo de Castro.</segment>
    <segment id="5">“</segment>
    <segment id="6">Lázaro gostou bastante.</segment>
    <segment id="7">Ele curtiu.</segment>
    <segment id="8">Se achou parecido”</segment>
    <segment id="9">, conta o publicitário da Agência ID</segment>
    <segment id="10">, a mesma que diagramou o livro escrito pelo ator</segment>
    <segment id="11">, “</segment>
    <segment id="12">A velha sentada”.</segment>
    <segment id="13">O personagem  faz parte de um projeto que pretende utilizar a imagem de celebridades no formato de histórias em quadrinhos para ajudar na educação da população mais carente.</segment>
    <segment id="14">A cantora Sandra de Sá e a atriz Solange Couto também terão seus personagens.</segment>
  </rst>
