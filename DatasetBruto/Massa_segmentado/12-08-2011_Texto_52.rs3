  <rst>
    <segment id="1">Galera quer acabar com a palhaçada
Moradores de Caja City e estudantes</segment>
    <segment id="2">sese uniram para ‘festejar’ 12 anos sem metrô</segment>
    <segment id="3">Cerca de 200 manifestantes fecharam ontem</segment>
    <segment id="4">, no fim da tarde</segment>
    <segment id="5">, uma das pistas da Av. Bonocô</segment>
    <segment id="6">, no sentido Iguatemi</segment>
    <segment id="7">, engrossando as filas dos congestionamentos comuns no horário.</segment>
    <segment id="8">O protesto foi iniciativa do estudante Cícero Cotrim</segment>
    <segment id="9">, 16, que mobilizou colegas e muitos desconhecidos pelo site de relacionamentos Facebook.</segment>
    <segment id="10">“</segment>
    <segment id="11">A gente quer que o metrô saia do papel</segment>
    <segment id="12">, para onde foram tantos milhões de reais?</segment>
    <segment id="13">”, questionava.</segment>
    <segment id="14">Aos estudantes</segment>
    <segment id="15">, somou-</segment>
    <segment id="16">sese um grupo de moradores de Cajazeiras</segment>
    <segment id="17">, que trouxe um bolo de aniversário em “comemoração” aos 12 anos das obras inacabadas.</segment>
    <segment id="18">Os representantes do maior “bairro da América Latina” exigiram extensão da linha dos trens até a região</segment>
    <segment id="19">, que concentra 800 mil pessoas.</segment>
    <segment id="20">Enquanto o metrô “calça curta” não vira realidade</segment>
    <segment id="21">, o da Paralela foi oficializado ontem.</segment>
    <segment id="22">Modelo de transporte:</segment>
    <segment id="23">Paralela nos trilhos</segment>
    <segment id="24">Agora é oficial: o modal de transporte para a Copa será o metrô.</segment>
    <segment id="25">O sistema de 22 km que ligará Lauro de Freitas à Rótula do Abacaxi pela Av. Paralela será alimentado por vias complementares (Pituba e Calçada-Retiro</segment>
    <segment id="26">, além das Av. 29 de Março e Gal Costa).</segment>
    <segment id="27">Melhorias no trem do subúrbio</segment>
    <segment id="28">, que liga Calçada a Paripe</segment>
    <segment id="29">, também foram anunciadas.</segment>
    <segment id="30">A obra tem custo estimado em R$ 2</segment>
    <segment id="31">,4 bilhões</segment>
    <segment id="32">, com recursos do PAC da Mobilidade.</segment>
    <segment id="33">Metrô até Cajazeiras</segment>
    <segment id="34">, região mais populosa da cidade</segment>
    <segment id="35">é, por enquanto</segment>
    <segment id="36">, para o governo</segment>
    <segment id="37">, apenas uma “intenção”.</segment>
  </rst>
</analysis>