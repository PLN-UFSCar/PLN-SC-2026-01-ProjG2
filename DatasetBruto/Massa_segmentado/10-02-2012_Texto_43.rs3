  <rst>
    <segment id="1">Golpe nos colegas em missão no Haiti</segment>
    <segment id="2">George Brito foi preso por usar dados de militares do Exército e comprar carros</segment>
    <segment id="3">Enquanto os colegas estavam em missão de paz</segment>
    <segment id="4">, no Haiti</segment>
    <segment id="5">, o sargento do Exército George de Brito Sena</segment>
    <segment id="6">, 41 anos</segment>
    <segment id="7">, estava  em Salvador usando os dados dos militares para falsificar documentos e comprar carros financiados</segment>
    <segment id="8">, além de contrair empréstimos bancários.</segment>
    <segment id="9">Dez oficiais e praças do Exército foram vítimas do golpe.</segment>
    <segment id="10">Segundo a polícia</segment>
    <segment id="11">, o sargento revendia os carros para cidades do interior da Bahia.</segment>
    <segment id="12">George falsificava carteiras do Exército a partir do próprio documento e colocava dados das vítimas.</segment>
    <segment id="13">Uma delas</segment>
    <segment id="14">, um cabo do Exército que preferiu não</segment>
    <segment id="15">sese identificar</segment>
    <segment id="16">, contou ter recebido uma carta do banco informando que as parcelas do financiamento de um Nissan Sentra estavam atrasadas e o nome dele incluído no SPC e Serasa.</segment>
    <segment id="17">“Cheguei em setembro do ano passado.</segment>
    <segment id="18">Há 20 dias</segment>
    <segment id="19">, recebi a carta e vim correndo registrar a queixa</segment>
    <segment id="20">, porque</segment>
    <segment id="21">porque outros colegas tinham sido vítimas”</segment>
    <segment id="22">, conta o cabo</segment>
    <segment id="23">, que passou sete meses no Haiti.</segment>
    <segment id="24">George foi preso por investigadores da Delegacia de Repressão a Estelionato e Outras Fraudes (Dreof).</segment>
    <segment id="25">Bandido tem 10 carros</segment>
    <segment id="26">O sargento George foi preso no bairro Comércio</segment>
    <segment id="27">, com várias cópias de documentos e uma pistola ponto 40.</segment>
    <segment id="28">O material estava no carro dele</segment>
    <segment id="29">, um jeep Troller</segment>
    <segment id="30">, com placa adulterada.</segment>
    <segment id="31">Ele possui outros nove veículos registrados no nome dele.</segment>
    <segment id="32">Com George</segment>
    <segment id="33">, também havia contas telefônicas</segment>
    <segment id="34">, contrato social de uma empresa e declaração do Imposto de Renda</segment>
    <segment id="35">, tudo em nome de Marcos Antônio Mourão Santana.</segment>
    <segment id="36">De acordo com o titular da Dreof</segment>
    <segment id="37">, Charles Leão</segment>
    <segment id="38">, Marcos é o fake (identidade falsa) que George usa para receber as encomendas em casa.</segment>
    <segment id="39">“</segment>
    <segment id="40">Ele disse que só falaria em juízo”</segment>
    <segment id="41">, afirma o delegado</segment>
    <segment id="42">, que o autuou em flagrante por estelionato</segment>
    <segment id="43">, falsidade ideológica e adulteração de sinal identificador de veículo.</segment>
  </rst>
</analysis>