  <rst>
    <segment id="1">Léo Kret dá esporro em Rianne no Trio</segment>
    <segment id="2">A proximidade da eliminação deixa os foliões com nervos à flor da pele</segment>
    <segment id="3">A temperatura em “</segment>
    <segment id="4">O Trio Reality” (TV Aratu) sobe a cada semana!</segment>
    <segment id="5">Ontem, um disse me disse sem fim provocou um estresse entre Léo Kret e Rianne.</segment>
    <segment id="6">A loira foi tirar satisfações com Rosiane por ter recebido seu voto</segment>
    <segment id="7">, segundo ela</segment>
    <segment id="8">, por influência de outras pessoas.</segment>
    <segment id="9">Cissa Chagas ouviu e bateu para a dançarina.</segment>
    <segment id="10">A vereadora pirou e foi para o quarto</segment>
    <segment id="11">sese meter na conversa das duas: “Licença</segment>
    <segment id="12">, posso me meter também?</segment>
    <segment id="13">Pois eu acho que você deve dar este conselho para Guga”</segment>
    <segment id="14">, disse.</segment>
    <segment id="15">Rianne ficou sem fala e Léo Kret continuou a  descascar</segment>
    <segment id="16">, dizendo que Rosiane não tinha sido influenciada</segment>
    <segment id="17">, masmas sim alertada para uma estratégia de jogo: a de acabar com o casal.</segment>
    <segment id="18">“</segment>
    <segment id="19">Ninguém tem que defender ninguém aqui”</segment>
    <segment id="20">, esbravejou.</segment>
    <segment id="21">Ficou parecendo uma defesa a Werles</segment>
    <segment id="22">, que anda de chamego com a vereadora.</segment>
    <segment id="23">Será?</segment>
  </rst>
</analysis>