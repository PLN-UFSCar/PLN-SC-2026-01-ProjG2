  <rst>
    <segment id="1">ABC:</segment>
    <segment id="2">Aqui</segment>
    <segment id="3">Baiano Classifica</segment>
    <segment id="4">A sala de aula do Barradão está pronta</segment>
    <segment id="5">para que</segment>
    <segment id="6">para que os alunos de Ricardo sejam aprovados</segment>
    <segment id="7">Em 2010</segment>
    <segment id="8">, o Vitória foi um aluno aplicado na Copa do Brasil e só não ganhou uma nota 10</segment>
    <segment id="9">porque</segment>
    <segment id="10">porque esbarrou numa escola mais talentosa: o Santos dos craques Ganso</segment>
    <segment id="11">, Robinho e Neymar</segment>
    <segment id="12">, que ficou com o título.</segment>
    <segment id="13">Ano passado</segment>
    <segment id="14">, o Leão deu uma de bagunceiro e foi reprovado logo na primeira fase pelo modesto Botafogo da Paraíba.</segment>
    <segment id="15">Nota zero.</segment>
    <segment id="16">Este ano</segment>
    <segment id="17">, o rubro-negro já despachou o sergipano São Domingos e hoje</segment>
    <segment id="18">, à noite</segment>
    <segment id="19">, na Universidade do Barradão</segment>
    <segment id="20">, só precisa fazer bem o dever de casa para eliminar o ABC.</segment>
    <segment id="21">Até um empate por 0 a 0 garante o time baiano nas oitavas de final</segment>
    <segment id="22">, masmas a torcida quer  ver os alunos do professor Ricardo Silva carimbando a vaga com uma nota azul.</segment>
    <segment id="23">Mas, em 2000</segment>
    <segment id="24">, o time potiguar impôs uma lição dolorosa ao Leão do então técnico Arturzinho</segment>
    <segment id="25">, como</segment>
    <segment id="26">como bem lembrou Ricardo Silva.</segment>
    <segment id="27">“É claro que a época e as equipes são outras</segment>
    <segment id="28">, masmas não deixa de ser um alerta para não sermos surpreendidos outra vez”</segment>
    <segment id="29">, falou o atual treinador do rubro-negro.</segment>
    <segment id="30">Também na segunda fase da Copa do Brasil</segment>
    <segment id="31">, o ABC bateu o Vitória nos dois jogos: 1 a 0</segment>
    <segment id="32">, no Machadão</segment>
    <segment id="33">, em Natal</segment>
    <segment id="34">, gol de Leonardo</segment>
    <segment id="35">, dia 29 de março</segment>
    <segment id="36">; e 2 a 1</segment>
    <segment id="37">, no Barradão</segment>
    <segment id="38">, em Salvador</segment>
    <segment id="39">, gols de Leonardo (2)</segment>
    <segment id="40">, descontando Manoel</segment>
    <segment id="41">, no dia 12 de abril.</segment>
    <segment id="42">No jogo em Salvador apenas 2.394 pagantes testemunharam o revés.</segment>
    <segment id="43">“</segment>
    <segment id="44">Agora precisamos contar com o apoio maciço do nosso torcedor</segment>
    <segment id="45">para que</segment>
    <segment id="46">para que ele faça a diferença.</segment>
    <segment id="47">O horário é um pouco tarde</segment>
    <segment id="48">, masmas creio que a boa exibição no jogo anterior [6 a 1 no Feirense</segment>
    <segment id="49">, pelo Baianão] deixou a galera satisfeita.</segment>
    <segment id="50">Respeitamos o ABC</segment>
    <segment id="51">, masmas vamos procurar manter o ritmo</segment>
    <segment id="52">, jogando com disposição e procurando a vitória”</segment>
    <segment id="53">, disse Ricardo.</segment>
  </rst>
</analysis>