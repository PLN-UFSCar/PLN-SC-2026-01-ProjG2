  <rst>
    <segment id="1">Comeu e bebeu</segment>
    <segment id="2">, masmas depois matou o gay
Sérgio dá facada em homossexual enquanto ele dormia
Era um domingo regado a comida</segment>
    <segment id="3">, bebida e sexo</segment>
    <segment id="4">, em uma casa de praia em Arembepe (a 30 km de Salvador).</segment>
    <segment id="5">Três homossexuais</segment>
    <segment id="6">, entre eles Antônio Carlos Oliveira Filho</segment>
    <segment id="7">, 25 anos</segment>
    <segment id="8">, convidaram cinco rapazes (que</segment>
    <segment id="9">sese apresentam socialmente</segment>
    <segment id="10">comocomo héteros) para um churrasco à beira da piscina</segment>
    <segment id="11">, masmas o prazer virou tormento.</segment>
    <segment id="12">Antonio foi assassinado por um dos convidados com duas facadas no pescoço</segment>
    <segment id="13">, enquanto dormia.</segment>
    <segment id="14">O crime foi no dia 29 de abril.</segment>
    <segment id="15">Na manhã de ontem</segment>
    <segment id="16">, policiais da Delegacia de  Abrantes (26ª DT) prenderam quatro dos cinco jovens.</segment>
    <segment id="17">A vítima morreu enquanto dormia</segment>
    <segment id="18">, no sofá da sala</segment>
    <segment id="19">, onde estavam três dos convidados.</segment>
    <segment id="20">O restante dos homossexuais e dos jovens dormiam no quarto.</segment>
    <segment id="21">Segundo o titular da 26ª DT</segment>
    <segment id="22">, Marcos Tebaldi</segment>
    <segment id="23">, não houve um motivo aparente para o homicídio.</segment>
    <segment id="24">“</segment>
    <segment id="25">O autor foi induzido e instigado pelo adolescente.</segment>
    <segment id="26">Mataram a troco de nada.</segment>
    <segment id="27">Não houve briga antes”</segment>
    <segment id="28">, afirma o delegado.</segment>
    <segment id="29">O ajudante de pedreiro Sérgio Souza de Santana</segment>
    <segment id="30">, 24, admitiu o crime e disse que foi influenciado por T.M.A</segment>
    <segment id="31">, 17, o único que não foi localizado.</segment>
    <segment id="32">“</segment>
    <segment id="33">A cerveja acabou e começamos a beber álcool de cozinha com acerola e açúcar.</segment>
    <segment id="34">Aí, o menor pegou uma faca e ficou fazendo inferno</segment>
    <segment id="35">, dizendo que eu não tinha coragem de meter  no cara”</segment>
    <segment id="36">, conta.</segment>
    <segment id="37">Machismo e ódio</segment>
    <segment id="38">Para o antropólogo e fundador do Grupo Gay da Bahia (GGB)</segment>
    <segment id="39">, Luiz Mott</segment>
    <segment id="40">, o assassinato de Antônio Carlos é um</segment>
    <segment id="41">casocaso típico de homofobia cultural.</segment>
    <segment id="42">“Do norte ao sul do Brasil</segment>
    <segment id="43">, há o ditado de que ‘veado’ tem mais é que morrer.</segment>
    <segment id="44">Para provar que é macho</segment>
    <segment id="45">, o homofóbico lava a honra com o sangue do gay”</segment>
    <segment id="46">, declara.</segment>
    <segment id="47">Segundo dados do antropólogo</segment>
    <segment id="48">, de janeiro até ontem</segment>
    <segment id="49">, 13 homossexuais foram assassinados na Bahia.</segment>
    <segment id="50">De 2007 a 2011</segment>
    <segment id="51">, o Estado foi líder no ranking de crimes de homofobia</segment>
    <segment id="52">, com 122 assassinatos.</segment>
    <segment id="53">O site do GGB (www.ggb.org.br)  apresenta dicas de segurança para evitar  riscos durante os relacionamentos.</segment>
    <segment id="54">Luiz ligou e  marcou o churrasco macabro</segment>
    <segment id="55">Depois de pedir a prisão dos cinco jovens que estavam na casa e fugiram após o crime</segment>
    <segment id="56">, o delegado irá indiciar apenas</segment>
    <segment id="57">Sérgio Santana e o adolescente T.M.A</segment>
    <segment id="58">, 17, que tiveram participação direta.</segment>
    <segment id="59">Cosme Pinheiro de Brito</segment>
    <segment id="60">, 25, e W.S.A</segment>
    <segment id="61">, 17, dormiam no quarto com os homossexuais.</segment>
    <segment id="62">Já Luiz Claudio Deiró</segment>
    <segment id="63">, 18, (foto) estava na sala</segment>
    <segment id="64">, na hora do crime.</segment>
    <segment id="65">Mas, de acordo com o delegado</segment>
    <segment id="66">, não teve participação.</segment>
    <segment id="67">Luiz e os dois menores conheceram o trio de homossexuais na Lavagem de Arembepe</segment>
    <segment id="68">, no mês de março.</segment>
    <segment id="69">“</segment>
    <segment id="70">Luiz manteve contato com os homossexuais por telefone</segment>
    <segment id="71">, aí marcaram o churrasco no feriadão de 1º de maio”</segment>
    <segment id="72">, conta o delegado.</segment>
  </rst>
</analysis>