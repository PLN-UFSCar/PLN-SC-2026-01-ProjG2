  <rst>
    <segment id="1">Arquiteta é encontrada morta com corte no pescoço em sua chácara
RIO - Um crime ocorrido no último dia 10 numa chácara em Guapimirim</segment>
    <segment id="2">, na Baixada Fluminense</segment>
    <segment id="3">, intriga a polícia.</segment>
    <segment id="4">A arquiteta Joselena de Moura Bezerra</segment>
    <segment id="5">, de 61 anos</segment>
    <segment id="6">, foi encontrada morta dentro de uma das casas da chácara</segment>
    <segment id="7">, que ela comprou há cerca de dez anos.</segment>
    <segment id="8">A vítima tinha cortes no pescoço e em umas das mãos.</segment>
    <segment id="9">A 67ª DP (Guapimirim) já tomou o depoimento de pessoas ligadas à arquiteta</segment>
    <segment id="10">, incluindo seus dois irmãos</segment>
    <segment id="11">, que estiveram no local assim que o corpo foi encontrado.</segment>
    <segment id="12">O advogado Alexandre Dumans</segment>
    <segment id="13">, primo da vítima</segment>
    <segment id="14">, disse que havia alertado Joselena</segment>
    <segment id="15">para que</segment>
    <segment id="16">para que ela não ficasse num lugar tão isolado.</segment>
    <segment id="17">Ela tinha um apartamento em Ipanema</segment>
    <segment id="18">, masmas gostava de passar mais tempo na chácara.</segment>
    <segment id="19">A polícia aguarda os laudos de necropsia e da perícia do local do crime.</segment>
    <segment id="20">Para investigadores</segment>
    <segment id="21">, há indícios de homicídio doloso</segment>
    <segment id="22">Um policial informou que há indícios de homicídio doloso</segment>
    <segment id="23">masmas</segment>
    <segment id="24">, como</segment>
    <segment id="25">como os laudos ainda não chegaram à delegacia</segment>
    <segment id="26">, não se</segment>
    <segment id="27">se tem certeza sobre as causas da morte.</segment>
    <segment id="28">No local onde o corpo foi encontrado havia uma porta de vidro quebrada.</segment>
    <segment id="29">Os investigadores evitam especular sobre o</segment>
    <segment id="30">casocaso</segment>
    <segment id="31">, masmas a possibilidade de ter havido um acidente doméstico</segment>
    <segment id="32">, em que a arquiteta poderia ter sofrido uma queda sobre a vidraça</segment>
    <segment id="33">, está praticamente descartada.</segment>
    <segment id="34">As hipóteses mais prováveis apontam para uma queda forçada sobre a porta e cortes feitos no corpo com o vidro quebrado</segment>
    <segment id="35">, segundo a polícia.</segment>
    <segment id="36">A princípio</segment>
    <segment id="37">, segundo informação de um parente da vítima</segment>
    <segment id="38">, não há sinais de que houve estupro</segment>
    <segment id="39">, embora</segment>
    <segment id="40">embora a mulher tenha sido encontrada nua.</segment>
    <segment id="41">Também não há</segment>
    <segment id="42">comocomo afirmar</segment>
    <segment id="43">sese foi latrocínio</segment>
    <segment id="44">, pois</segment>
    <segment id="45">pois, aparentemente</segment>
    <segment id="46">, nada foi levado.</segment>
  </rst>
