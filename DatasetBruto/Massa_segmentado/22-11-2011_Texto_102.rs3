  <rst>
    <segment id="1">Um pecado!</segment>
    <segment id="2">Alê é uma diabinha retada</segment>
    <segment id="3">A gatíssima Alessandra Halyn</segment>
    <segment id="4">, de 23 anos</segment>
    <segment id="5">, tem o apelido de “diabinha”</segment>
    <segment id="6">, que ganhou na infância</segment>
    <segment id="7">, quando aprontava no colégio onde estudava.</segment>
    <segment id="8">O sonho de</segment>
    <segment id="9">sese formar em arquitetura teve que ser interrompido</segment>
    <segment id="10">, pois</segment>
    <segment id="11">pois Alessandra precisou cuidar da mãe</segment>
    <segment id="12">, que ficou doente.</segment>
    <segment id="13">Agora, passado o susto</segment>
    <segment id="14">, ela quer retomar a faculdade.</segment>
    <segment id="15">“Quero voltar a trabalhar</segment>
    <segment id="16">comocomo modelo e terminar os  estudos”</segment>
    <segment id="17">, sonha.</segment>
    <segment id="18">E diversão é com ela mesma.</segment>
    <segment id="19">A gata não perde um fim de semana de praia e adora cuidar do corpo.</segment>
    <segment id="20">“</segment>
    <segment id="21">A parte que eu mais gosto de malhar é o bumbum</segment>
    <segment id="22">, que chama muita atenção” conta a moradora do Stiep.</segment>
    <segment id="23">Sarada

“Diabinha” exibe toda orgulhosa sua tatuagem e garante que mantém o corpão com muita malhação.</segment>
    <segment id="24">A gata pega pesado na academia para deixar tudo em cima.</segment>
  </rst>
