  <rst>
    <segment id="1">Final feliz para a menina de Stella</segment>
    <segment id="2">Após cinco dias no cativeiro</segment>
    <segment id="3">, menina de 15 anos foi libertada pelos sequestradores</segment>
    <segment id="4">A adolescente B.V.</segment>
    <segment id="5">, 15 anos</segment>
    <segment id="6">, foi libertada na manhã de ontem depois de ter sido sequestrada na última quinta-feira</segment>
    <segment id="7">, quando caminhava em direção à escola</segment>
    <segment id="8">, no bairro de Stella Maris.</segment>
    <segment id="9">Amigos e familiares disseram que a vítima não sofreu violência sexual</segment>
    <segment id="10">, nem física.</segment>
    <segment id="11">Mas, como</segment>
    <segment id="12">como a própria adolescente contou na internet</segment>
    <segment id="13">, ela estava faminta</segment>
    <segment id="14">porque</segment>
    <segment id="15">porque recebeu pouca comida no cativeiro.</segment>
    <segment id="16">Apesar de a polícia e a família manterem sigilo sobre as investigações</segment>
    <segment id="17">, uma fonte informou que os sequestradores começaram exigindo R$ 200 mil</segment>
    <segment id="18">, valor de uma suposta indenização recebida por um parente da garota.</segment>
    <segment id="19">“</segment>
    <segment id="20">O último contato foi feito no domingo</segment>
    <segment id="21">, quando eles pediram R$ 18 mil”</segment>
    <segment id="22">, conta um policial</segment>
    <segment id="23">, que preferiu não</segment>
    <segment id="24">sese identificar.</segment>
    <segment id="25">As chamadas foram feitas a partir de diferentes pontos da cidade</segment>
    <segment id="26">, o que  dificultava a localização dos bandidos.</segment>
    <segment id="27">Após diversas negociações</segment>
    <segment id="28">, a garota acabou sendo libertada</segment>
    <segment id="29">, próximo de casa</segment>
    <segment id="30">, sem o pagamento do resgate.</segment>
    <segment id="31">A Polícia Civil informou pela assessoria de imprensa que as buscas aos sequestradores continuam e que detalhes sobre o</segment>
    <segment id="32">casocaso serão apresentados com o desfecho das investigações.</segment>
    <segment id="33">O local do cativeiro já foi periciado e seria em Mussurunga.</segment>
    <segment id="34">Hoje tem nova celebração:</segment>
    <segment id="35">Pastor fez culto na escola</segment>
    <segment id="36">O encontro da manhã de hoje terá a presença do pastor Ivan Dias</segment>
    <segment id="37">, da Missão Mundial do Trono de Deus.</segment>
    <segment id="38">Ele é pai de dois jovens que estudaram no Colégio Ômega</segment>
    <segment id="39">, e ainda tem o caçula na instituição.</segment>
    <segment id="40">Na segunda-feira</segment>
    <segment id="41">, o pastor reuniu os estudantes</segment>
    <segment id="42">, cerca de 400</segment>
    <segment id="43">, na quadra do colégio.</segment>
    <segment id="44">“Eu deixei uma palavra profética: ´</segment>
    <segment id="45">Acredito que a criança será resgatada com vida´ e então rezamos o Pai Nosso”.</segment>
    <segment id="46">O pastor</segment>
    <segment id="47">, que  na década de 1980 foi cantor da banda Laranja Mecânica</segment>
    <segment id="48">, disse que será um “ato de reconhecimento</segment>
    <segment id="49">, para que</segment>
    <segment id="50">para que as pessoas conheçam o poder da oração”.</segment>
  </rst>
</analysis>