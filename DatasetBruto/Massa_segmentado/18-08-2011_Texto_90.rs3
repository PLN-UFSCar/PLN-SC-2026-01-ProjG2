  <rst>
    <segment id="1">Operação Alquimia:</segment>
    <segment id="2">Metade dos detidos confessa participação em fraudes fiscais
BRASÍLIA - A situação dos irmãos Paulo Sérgio Costa Pinto Cavalcanti e Ismael César Cavalcanti Neto</segment>
    <segment id="3">, donos da Sasil e da Triflex</segment>
    <segment id="4">, complicou-</segment>
    <segment id="5">sese ainda mais depois da série de depoimentos colhidos pela Polícia Federal (PF) desde o início da Operação Alquimia</segment>
    <segment id="6">, na quarta-feira.</segment>
    <segment id="7">Pelo menos 12 investigados confessaram a participação em supostas fraudes fiscais de empresas dos dois irmãos.</segment>
    <segment id="8">Ismael</segment>
    <segment id="9">, um dos 23 presos</segment>
    <segment id="10">, negou os crimes atribuídos a ele.</segment>
    <segment id="11">Paulo Sérgio está foragido na Europa.</segment>
    <segment id="12">O grupo é acusado de sonegar um valor que</segment>
    <segment id="13">, com multas e juros</segment>
    <segment id="14">, pode ser superior a R$ 1 bilhão.</segment>
    <segment id="15">Foram 12 depoimentos bombásticos.</segment>
    <segment id="16">Eles não apenas confessaram a existência do esquema criminoso</segment>
    <segment id="17">, como</segment>
    <segment id="18">como também reconheceram a prática dos crimes - disse uma autoridade que está acompanhando o</segment>
    <segment id="19">casocaso de perto.</segment>
    <segment id="20">Os 12 "arrependidos"</segment>
    <segment id="21">faziam papel de laranja em algumas empresas do grupo dos irmãos Cavalcanti.</segment>
    <segment id="22">Eles disseram que apareciam</segment>
    <segment id="23">comocomo sócios de algumas delas</segment>
    <segment id="24">, masmas não tinham nenhum poder de comando.</segment>
    <segment id="25">Disseram também que</segment>
    <segment id="26">, na condição de sócios fictícios</segment>
    <segment id="27">, assinavam documentos e cheques.</segment>
    <segment id="28">Pelas investigações da polícia</segment>
    <segment id="29">, o grupo criava empresas de fachada para assumir dívidas fiscais de outras companhias e</segment>
    <segment id="30">, em seguida</segment>
    <segment id="31">, decretavam falência.</segment>
    <segment id="32">Com isso</segment>
    <segment id="33">, outras empresas do grupo</segment>
    <segment id="34">sese apropriavam do dinheiro dos impostos e seguiam em negócios lícitos.

FOTOGALERIA:</segment>
    <segment id="35">Veja imagens da Operação Alquimia

VÍDEO:</segment>
    <segment id="36">Conheça a ilha na Bahia confiscada na operação da PF

LEIA</segment>
    <segment id="37">MAIS: CPF de faxineira foi usado para fazer doação</segment>
  </rst>
