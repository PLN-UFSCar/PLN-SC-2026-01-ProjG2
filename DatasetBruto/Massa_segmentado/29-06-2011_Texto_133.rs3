  <rst>
    <segment id="1">Mãe queima e esconde a filhinha em casa</segment>
    <segment id="2">Neilda Fonseca de Souza entocou a criança por mais de oito dias</segment>
    <segment id="3">Os moradores da 5ª Travessa da Rua Ubatã</segment>
    <segment id="4">, no Bairro da Paz</segment>
    <segment id="5">, estranharam o sumiço de uma das gêmeas filhas de Neilda Fonseca de Souza.</segment>
    <segment id="6">Fazia mais de oito dias que a mulher saía à rua apenas com uma das meninas e não permitia a entrada de ninguém em sua residência.</segment>
    <segment id="7">Mas eles não imaginavam que o motivo do sumiço da criança eram as queimaduras feitas pela própria mãe.</segment>
    <segment id="8">A agressão só foi descoberta na última terça-feira (26)</segment>
    <segment id="9">, quando o pai das meninas de dois meses</segment>
    <segment id="10">, Alex Dias da Silva</segment>
    <segment id="11">, foi visitá-las.</segment>
    <segment id="12">O homem</segment>
    <segment id="13">, que atualmente reside em Camaçari</segment>
    <segment id="14">, encontrou uma das filhas com queimaduras na boca</segment>
    <segment id="15">, bochecha e nos dois joelhos.</segment>
    <segment id="16">Segundo os moradores</segment>
    <segment id="17">, ao ser questionada pelo ex-marido sobre a origem das agressões</segment>
    <segment id="18">, Neilda disse que a menina</segment>
    <segment id="19">sese feriu engatinhando – mesmo a criança tendo apenas dois meses de vida.</segment>
    <segment id="20">“</segment>
    <segment id="21">O pessoal sempre perguntava a ela sobre a outra menina</segment>
    <segment id="22">, masmas ela dizia que estava dormindo”</segment>
    <segment id="23">, disse um morador sem</segment>
    <segment id="24">sese identificar.</segment>
    <segment id="25">Conforme relatos</segment>
    <segment id="26">, Alex tentou pegar a filha agredida</segment>
    <segment id="27">, masmas a Neilda relutava em entregar</segment>
    <segment id="28">, até que bradou:</segment>
    <segment id="29">“Tome sua desgraça”</segment>
    <segment id="30">, referindo-</segment>
    <segment id="31">sese à gêmea agredida.</segment>
    <segment id="32">A mulher ainda tentou fugir com a outra filha</segment>
    <segment id="33">, masmas foi contida por moradores armados com  madeiras e pedras.</segment>
    <segment id="34">Filhas continuam internadas</segment>
    <segment id="35">As gêmeas foram levadas ao HGE.</segment>
    <segment id="36">Mesmo não sendo agredida pela mãe</segment>
    <segment id="37">, a outra criança também foi internada</segment>
    <segment id="38">porque</segment>
    <segment id="39">porque estava desnutrida.</segment>
    <segment id="40">A previsão era que ela tivesse alta médica ontem</segment>
    <segment id="41">, masmas até o início da noite</segment>
    <segment id="42">, as duas permaneciam internadas.</segment>
    <segment id="43">Em depoimento à polícia</segment>
    <segment id="44">, o pai contou que Neilda é ex-usuária de drogas e já foi internada no Hospital Juliano Moreira.</segment>
    <segment id="45">Ela está foragida</segment>
    <segment id="46">, segundo a delegada da Derca</segment>
    <segment id="47">, Ana Crissia Almeida.</segment>
  </rst>
</analysis>