  <rst>
    <segment id="1">Caneta e microfone</segment>
    <segment id="2">Robbyssão mostra seu talento</segment>
    <segment id="3">comocomo escritor
Robyssão</segment>
    <segment id="4">, vocalista do grupo Black Style</segment>
    <segment id="5">, está escrevendo um livro</segment>
    <segment id="6">, masmas engana-</segment>
    <segment id="7">sese quem pensa que</segment>
    <segment id="8">sese trata de um romance ou autobiografia.</segment>
    <segment id="9">Ele afirma que</segment>
    <segment id="10">sese baseou na publicação</segment>
    <segment id="11">“1984</segment>
    <segment id="12">”</segment>
    <segment id="13">, de George Oswel</segment>
    <segment id="14">, que inspirou o “Big Brother Brasil”.</segment>
    <segment id="15">“Será um livro que retrata a influência da mídia sobre o povo.</segment>
    <segment id="16">Vou falar sobre os dois lados: o construtivo e o destrutivo</segment>
    <segment id="17">, e farei reflexões sobre</segment>
    <segment id="18">comocomo será a sociedade daqui a 20 anos sendo dominada dessa forma”</segment>
    <segment id="19">, diz Robyssão</segment>
    <segment id="20">, que ainda não definiu o nome da obra.</segment>
    <segment id="21">O cantor garante que</segment>
    <segment id="22">, apesar do interesse pela literatura</segment>
    <segment id="23">, não trocará o microfone pela caneta.</segment>
    <segment id="24">Para realizar a façanha</segment>
    <segment id="25">, o artista conta com a ajuda de uma amiga de São Paulo</segment>
    <segment id="26">, a escritora Regina Lanza.</segment>
    <segment id="27">O cantor também está investindo em política.</segment>
    <segment id="28">Ele confirmou sua filiação ao Partido da República (PR)</segment>
    <segment id="29">, masmas negou que vá</segment>
    <segment id="30">sese candidatar a vereador em 2012.</segment>
    <segment id="31">“Estou filiado</segment>
    <segment id="32">, masmas só vou pensar</segment>
    <segment id="33">sese serei candidato no ano que vem”</segment>
    <segment id="34">, afirma.</segment>
    <segment id="35">A banda</segment>
    <segment id="36">, claro</segment>
    <segment id="37">, vai de vento em popa.</segment>
    <segment id="38">“</segment>
    <segment id="39">Em dezembro</segment>
    <segment id="40">, começam nossos ensaios de verão</segment>
    <segment id="41">, com participações de mulheres-fruta”</segment>
    <segment id="42">, revela.</segment>
  </rst>
</analysis>