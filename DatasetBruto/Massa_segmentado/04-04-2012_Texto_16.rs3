  <rst>
    <segment id="1">Rihanna brasuca muda visual de novo
Atriz pediu para seu cabeleireiro inovar.</segment>
    <segment id="2">Ele radicalizou e</segment>
    <segment id="3">sese deu bem</segment>
    <segment id="4">A atriz abandonou o visual lisinho - que já teve suas versões curtíssimo</segment>
    <segment id="5">, chanel e longos - e apostou  no black power.</segment>
    <segment id="6">Acertou na mosca!</segment>
    <segment id="7">Ganhou beleza</segment>
    <segment id="8">, atitude e a aprovação do maridão</segment>
    <segment id="9">, o cantor Felipe Dylon.</segment>
    <segment id="10">O cabeleireiro Flávio Priscott não nega:</segment>
    <segment id="11">sese inspirou na camaleoa  Rihanna para construir o novo look da gata.</segment>
    <segment id="12">“Já queria ter feito isso para o dia do casamento dela</segment>
    <segment id="13">, masmas ela preferiu casar com cabelo de noiva mesmo”</segment>
    <segment id="14">, revelou o hair stylist.</segment>
    <segment id="15">Aparecida gostou do resultado</segment>
    <segment id="16">, que ainda ganhou reflexos mais claros nas madeixas</segment>
    <segment id="17">, e não pretende abandonar a nova cabeleira tão cedo.</segment>
    <segment id="18">Vida longa ao black power!</segment>
  </rst>
</analysis>