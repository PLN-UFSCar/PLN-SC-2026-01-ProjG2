  <rst>
    <segment id="1">Advogada devolveu jóia</segment>
    <segment id="2">, após ser advertida por vendedora</segment>
    <segment id="3">Após ser vista</segment>
    <segment id="4">, anteontem</segment>
    <segment id="5">, colocando um colar na bolsa</segment>
    <segment id="6">, a advogada Renata Maria Carvalho de Fonseca</segment>
    <segment id="7">, 36 anos</segment>
    <segment id="8">, devolveu a peça de R$ 69 à funcionária da loja Trudys</segment>
    <segment id="9">, no Salvador Shopping</segment>
    <segment id="10">, para</segment>
    <segment id="11">sese livrar da acusação de furto.</segment>
    <segment id="12">Os funcionários</segment>
    <segment id="13">, porém</segment>
    <segment id="14">porém, perceberam o sumiço de um par de brincos de zircônia</segment>
    <segment id="15">, no valor de R$ 149</segment>
    <segment id="16">, masmas a advogada negou que tivesse pego.</segment>
    <segment id="17">“</segment>
    <segment id="18">Mesmo com o sumiço dos brincos</segment>
    <segment id="19">, nós a liberamos.</segment>
    <segment id="20">Mas ela disse que sofreu constrangimento  e só sairia de lá para a delegacia.</segment>
    <segment id="21">Ainda ameaçou processar a loja”</segment>
    <segment id="22">, conta a gerente do estabelecimento</segment>
    <segment id="23">, Patrícia Freire.</segment>
    <segment id="24">Ao ser revistada pela delegada de plantão na Delegacia da Pituba (16ª DT)</segment>
    <segment id="25">, Renata acabou cuspindo os brincos.</segment>
    <segment id="26">“Ela (Renata) disse que alguém colocou os brincos nas vestes dela e</segment>
    <segment id="27">, para</segment>
    <segment id="28">sese proteger</segment>
    <segment id="29">, colocou a bijuteria na boca”</segment>
    <segment id="30">, relata Jussara Souza</segment>
    <segment id="31">, titular da 16ª DT.</segment>
    <segment id="32">A advogada foi autuada em flagrante por furto.</segment>
    <segment id="33">Ela não tinha passagem.</segment>
    <segment id="34">A pena para o crime varia de 1 a 4 anos</segment>
    <segment id="35">, masmas o delito é passível de fiança.</segment>
    <segment id="36">Acusada já foi vista na Trudys</segment>
    <segment id="37">Funcionários da Trudys disseram já ter visto a advogada na loja</segment>
    <segment id="38">, masmas nunca deram falta de produtos.</segment>
    <segment id="39">“Mesmo com dois seguranças e seis câmeras de segurança</segment>
    <segment id="40">, é comum as situações de furto</segment>
    <segment id="41">porque</segment>
    <segment id="42">porque os produtos ficam expostos”</segment>
    <segment id="43">, conta Patrícia Freire.</segment>
    <segment id="44">Nem a delegacia nem a loja cedeu as imagens para a imprensa.</segment>
    <segment id="45">“Se fosse um criminoso contumaz</segment>
    <segment id="46">, que respondesse a processo</segment>
    <segment id="47">, eu apresentaria</segment>
    <segment id="48">para que</segment>
    <segment id="49">para que outras vítimas o identificasse</segment>
    <segment id="50">, masmas não é o</segment>
    <segment id="51">casocaso dela”</segment>
    <segment id="52">, justificou a delegada.</segment>
    <segment id="53">Renata é  solteira</segment>
    <segment id="54">, não tem filhos</segment>
    <segment id="55">, possui carro e mora em Brotas.</segment>
  </rst>
</analysis>