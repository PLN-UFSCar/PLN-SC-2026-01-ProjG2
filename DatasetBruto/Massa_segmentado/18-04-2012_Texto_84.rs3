  <rst>
    <segment id="1">Mulheres e confusão</segment>
    <segment id="2">Conheça as histórias dos dois amigos que matam e morrem para defender as companheiras</segment>
    <segment id="3">Bruno Dias Garrido Ribeiro</segment>
    <segment id="4">, 21 anos</segment>
    <segment id="5">, conhecido</segment>
    <segment id="6">comocomo Cabeludo</segment>
    <segment id="7">, e Danilo Santana dos Santos</segment>
    <segment id="8">, 22, o Estepe</segment>
    <segment id="9">, foram presos por policiais militares da 18ª CIPM (Periperi)</segment>
    <segment id="10">, anteontem</segment>
    <segment id="11">, após serem flagrados com várias pedras de crack.</segment>
    <segment id="12">Os dois foram detidos em ruas diferentes</segment>
    <segment id="13">, em operações distintas.</segment>
    <segment id="14">Porém, o que une as histórias dos dois amigos moradores do bairro Pirajá é o fato de eles relatarem episódios que têm o mesmo enredo</segment>
    <segment id="15">comocomo pano de fundo: tanto Bruno quanto Danilo viveram situações parecidas</segment>
    <segment id="16">, de enorme confusão</segment>
    <segment id="17">, após tentarem defender as mulheres com quem são casados.</segment>
    <segment id="18">Na Delegacia de Periperi</segment>
    <segment id="19">, os policiais descobriram que Danilo é o autor de uma tentativa de homicídio ocorrida no dia 10 de abril</segment>
    <segment id="20">, em Pirajá.</segment>
    <segment id="21">“Ele mexeu com a minha mulher.</segment>
    <segment id="22">Me retei e dei quatro tiros nele.</segment>
    <segment id="23">Só dois pegaram”</segment>
    <segment id="24">, admite Danilo.</segment>
    <segment id="25">O alvo permanece vivo.</segment>
    <segment id="26">Já Bruno conta que um traficante de Pirajá</segment>
    <segment id="27">, conhecido</segment>
    <segment id="28">comocomo Skol</segment>
    <segment id="29">, teria agredido a mulher dele.</segment>
    <segment id="30">Bruno foi tirar satisfação e Skol disparou 16 tiros contra ele.</segment>
    <segment id="31">Quatro balaços o atingiram.</segment>
    <segment id="32">Foi grave.</segment>
    <segment id="33">Três dias internado no HGE

“</segment>
    <segment id="34">Os tiros atingiram a minha barriga</segment>
    <segment id="35">, o peito e o cotovelo.</segment>
    <segment id="36">Fiquei três dias internado no HGE”</segment>
    <segment id="37">, relembra Bruno.</segment>
    <segment id="38">O fato ocorreu em agosto de 2011.</segment>
    <segment id="39">Danilo foi autuado em flagrante por tráfico de drogas e também pela tentativa de homicídio praticada no último dia 10.</segment>
    <segment id="40">Segundo ele</segment>
    <segment id="41">, a arma usada para atingir o homem que mexeu com a sua mulher foi um revólver calibre 32.</segment>
    <segment id="42">Estepe garante que a droga encontrada com ele seria para consumo próprio e não para traficar.</segment>
    <segment id="43">Ele diz trabalhar</segment>
    <segment id="44">comocomo pintor.</segment>
    <segment id="45">Capturado na Cracolândia

Danilo já havia sido conduzido a uma delegacia</segment>
    <segment id="46">, como</segment>
    <segment id="47">como suspeito de roubo</segment>
    <segment id="48">, há três anos.</segment>
    <segment id="49">Bruno foi preso pelos PMs na Rua das Pedrinhas</segment>
    <segment id="50">, no bairro Periperi</segment>
    <segment id="51">, anteontem.</segment>
    <segment id="52">Danilo foi capturado numa região conhecida</segment>
    <segment id="53">comocomo Cracolândia.</segment>
    <segment id="54">Bruno afirma que é “apenas usuário de drogas”.</segment>
    <segment id="55">Ele tem uma filha de seis meses e diz trabalhar</segment>
    <segment id="56">comocomo coletor de lixo.</segment>
    <segment id="57">Em 2009</segment>
    <segment id="58">, Bruno foi preso durante o carnaval acusado de roubar uma corrente de ouro</segment>
    <segment id="59">, no circuito Avenida.</segment>
  </rst>
</analysis>