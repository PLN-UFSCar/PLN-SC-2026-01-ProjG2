  <rst>
    <segment id="1">Ladrão de som fica pendurado na árvore</segment>
    <segment id="2">Ao descer dos galhos</segment>
    <segment id="3">, ele é flagrado pela vítima e acaba preso</segment>
    <segment id="4">A ideia de José Wellington Moreira Pinto</segment>
    <segment id="5">, 37 anos</segment>
    <segment id="6">, de se</segment>
    <segment id="7">se esconder em uma árvore para despistar a polícia</segment>
    <segment id="8">, quase ia ser totalmente bem-sucedida.</segment>
    <segment id="9">O problema é que ele foi  flagrado</segment>
    <segment id="10">, bem na hora que deixava o esconderijo</segment>
    <segment id="11">, pela vítima que teve o carro arrombado e o aparelho de som levado</segment>
    <segment id="12">, no condomínio Solar das Árvores</segment>
    <segment id="13">, no bairro Luís Anselmo.</segment>
    <segment id="14">Segundo o síndico do  condomínio</segment>
    <segment id="15">, Marcos Brandão</segment>
    <segment id="16">, a polícia passou uma hora vasculhando o local</segment>
    <segment id="17">, em busca do meliante.</segment>
    <segment id="18">“Cinco minutos depois que os policiais foram</segment>
    <segment id="19">embora</segment>
    <segment id="20">embora</segment>
    <segment id="21">, o morador viu um vulto e ouviu o barulho de uma pessoa pulando da árvore”</segment>
    <segment id="22">, lembra o síndico.</segment>
    <segment id="23">Os policiais ainda estavam próximos e conseguiram alcançar José Wellington</segment>
    <segment id="24">, a cerca de 300 metros do condomínio.</segment>
    <segment id="25">“</segment>
    <segment id="26">O morador viu a fuga</segment>
    <segment id="27">porque</segment>
    <segment id="28">porque estava na varanda do apartamento com dificuldade para dormir</segment>
    <segment id="29">, após o arrombamento”</segment>
    <segment id="30">, conta Brandão.</segment>
    <segment id="31">O criminoso admite o furto.</segment>
    <segment id="32">“</segment>
    <segment id="33">O portão estava aberto</segment>
    <segment id="34">, eu  entrei.</segment>
    <segment id="35">O carro estava aberto</segment>
    <segment id="36">, aí eu fui e peguei o som”</segment>
    <segment id="37">, relata.</segment>
    <segment id="38">Mas, a história não foi bem assim</segment>
    <segment id="39">, diz o síndico.</segment>
    <segment id="40">“</segment>
    <segment id="41">Um morador me ligou dizendo que viu um homem arrombando um carro.</segment>
    <segment id="42">Aí, eu liguei para a polícia e chamei o dono do veículo”</segment>
    <segment id="43">, recorda-</segment>
    <segment id="44">sese



Começou cedo

José Wellington</segment>
    <segment id="45">, 37 anos</segment>
    <segment id="46">, coleciona passagens pela Delegacia de Repressão a Furtos e Roubos</segment>
    <segment id="47">, Delegacia da Barra</segment>
    <segment id="48">, do Rio Vermelho</segment>
    <segment id="49">, dos Barris</segment>
    <segment id="50">, da Pituba e de Brotas.</segment>
    <segment id="51">“Comecei a furtar aos 10 anos.</segment>
    <segment id="52">Levei um farol de milha do carro”</segment>
    <segment id="53">, lembra José.</segment>
    <segment id="54">Ele diz que perdeu a mãe aos cinco anos</segment>
    <segment id="55">, estudou até a 8ª série e nunca aprendeu uma profissão.</segment>
    <segment id="56">Os anos na prisão parecem não ter ensinado a José que o crime não compensa.</segment>
    <segment id="57">Questionado sobre quantos anos da vida já passou na cadeia</segment>
    <segment id="58">, ele disse não</segment>
    <segment id="59">sese lembrar.</segment>
    <segment id="60">“Mas, sei que essa foi a última vez.</segment>
    <segment id="61">Vou trabalhar quando sair daqui”</segment>
    <segment id="62">, afirma.</segment>
    <segment id="63">Tinha saído da prisão no mesmo dia

José Wellington foi autuado em flagrante por furto qualificado</segment>
    <segment id="64">, pelo delegado plantonista da 2ª Delegacia Territorial (Lapinha)</segment>
    <segment id="65">, José Sálvio Martins.</segment>
    <segment id="66">O crime aconteceu na noite da última sexta-feira.</segment>
    <segment id="67">Com dores nas duas pernas</segment>
    <segment id="68">, José foi atendido no HGE.</segment>
    <segment id="69">Ele alega ter apanhado dos PMs.</segment>
    <segment id="70">José voltou à cadeia no mesmo dia em que ganhou a liberdade da Colônia Penal de Simões Filho</segment>
    <segment id="71">, onde cumpriu pena por furto</segment>
    <segment id="72">, durante três anos.</segment>
    <segment id="73">“Ele já tem mais de sete passagens por furto”</segment>
    <segment id="74">, informa o delegado.</segment>
    <segment id="75">“</segment>
    <segment id="76">Quando sair daqui</segment>
    <segment id="77">, vou lavar carro</segment>
    <segment id="78">, catar material reciclável”</segment>
    <segment id="79">, promete.</segment>
  </rst>
</analysis>