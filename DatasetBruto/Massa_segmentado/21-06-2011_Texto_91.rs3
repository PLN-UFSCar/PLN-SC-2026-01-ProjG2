  <rst>
    <segment id="1">Ô, dó!</segment>
    <segment id="2">Victor está magoado com Nicole</segment>
    <segment id="3">O jogador disse ontem que não tinha visto o vídeo</segment>
    <segment id="4">, masmas que deve terminar o namoro
Coitadinho de Victor Ramos!</segment>
    <segment id="5">O rapaz</segment>
    <segment id="6">, que dormiu colocando a mão no fogo por Nicole Bahls</segment>
    <segment id="7">, acordou ontem devido ao cheiro forte de carne queimada.</segment>
    <segment id="8">E o pior: o moço nem imaginava que o aroma de churrasco vinha dele mesmo.</segment>
    <segment id="9">A culpada de tudo é uma peoa que</segment>
    <segment id="10">, até poucos dias</segment>
    <segment id="11">, jurava amor eterno ao jogador (não é</segment>
    <segment id="12">, Nicole?).</segment>
    <segment id="13">Mas ela</segment>
    <segment id="14">, Victor</segment>
    <segment id="15">, infelizmente não resistiu à sua versão masculina</segment>
    <segment id="16">, o ator marrento Théo Becker.</segment>
    <segment id="17">Como ela mesmo tinha falado</segment>
    <segment id="18">, ele era muito parecido com a gata (será que é no quesito fogo no...?).</segment>
    <segment id="19">Por isso</segment>
    <segment id="20">, acredito</segment>
    <segment id="21">, ela não deve ter resistido às investidas de Théo</segment>
    <segment id="22">, que, desde segunda</segment>
    <segment id="23">, tentava lhe dar uma bolada nas costas.</segment>
    <segment id="24">E olha que a moça resistiu bem (48 horas)</segment>
    <segment id="25">, antes de ceder aos encantos.</segment>
    <segment id="26">Do lado de fora</segment>
    <segment id="27">, Victor treinou ontem cabisbaixo por conta do próximo jogo.</segment>
    <segment id="28">Não quis falar sobre Nicole.</segment>
    <segment id="29">Apenas afirmou que não assistiu ao vídeo.</segment>
    <segment id="30">Mais tarde</segment>
    <segment id="31">, ele comentou</segment>
    <segment id="32">, antes de assistir às imagens</segment>
    <segment id="33">, que estava “muito magoado” (que meigo!) com a amadinha.</segment>
    <segment id="34">“É bom para vermos quem está ao nosso lado.</segment>
    <segment id="35">Se faz isso em rede nacional</segment>
    <segment id="36">, imagina nas minhas costas?</segment>
    <segment id="37">Ela agiu com comportamento errado e não gostei.</segment>
    <segment id="38">Eu me valorizo</segment>
    <segment id="39">comocomo homem e tenho postura”</segment>
    <segment id="40">, disse Victor (muito bem!) ao site “Ego”.</segment>
    <segment id="41">E aí, vai ficar com ela ou não?</segment>
    <segment id="42">“</segment>
    <segment id="43">Por enquanto sim</segment>
    <segment id="44">, pois</segment>
    <segment id="45">pois não vi as cenas.</segment>
    <segment id="46">Primeiro</segment>
    <segment id="47">, vou procurar saber o que aconteceu  para depois tomar uma decisão.</segment>
    <segment id="48">Mas, provavelmente</segment>
    <segment id="49">, quando ela sair</segment>
    <segment id="50">, vou terminar”</segment>
    <segment id="51">, finalizou.</segment>
    <segment id="52">Zagueiro é motivo de piadas nas redes socais</segment>
    <segment id="53">Nas redes sociais</segment>
    <segment id="54">, o beijo que Théo deu em Nicole virou motivo de piadas.</segment>
    <segment id="55">Os internautas postaram</segment>
    <segment id="56">, inclusive</segment>
    <segment id="57">, essa montagem com o jogador com chifres e tudo.</segment>
    <segment id="58">Segundo os humoristas da net</segment>
    <segment id="59">, ele está furando todas as bolas com o novo acessório.</segment>
    <segment id="60">O assunto</segment>
    <segment id="61">, por sinal</segment>
    <segment id="62">, foi um dos mais comentados no Twitter ontem.</segment>
  </rst>
</analysis>