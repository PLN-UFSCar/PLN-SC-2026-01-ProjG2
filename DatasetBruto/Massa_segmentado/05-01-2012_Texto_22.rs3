  <rst>
    <segment id="1">Polícia invade o Forno e torra dois</segment>
    <segment id="2">Alvo da ação era um grupo acusado de assaltar o Banco do Brasil</segment>
    <segment id="3">Dois homens foram mortos</segment>
    <segment id="4">, três suspeitos presos e um policial militar ferido na perna durante ação conjunta das Polícias Militar e Civil</segment>
    <segment id="5">, ontem pela manhã</segment>
    <segment id="6">, na localidade conhecida</segment>
    <segment id="7">comocomo Forno</segment>
    <segment id="8">, perto da região da Baixa da Égua</segment>
    <segment id="9">, bairro do Engenho Velho da Federação.</segment>
    <segment id="10">A operação contou com a participação de policiais da Rondesp (Rondas Especiais)</segment>
    <segment id="11">, 41ª Companhia Independente e da 7ª Delegacia Territorial do Rio Vermelho.</segment>
    <segment id="12">O alvo foi um grupo acusado de assaltar a agência do Banco do Brasil do Largo do Tamarineiro</segment>
    <segment id="13">, no bairro do Pau Miúdo</segment>
    <segment id="14">, na última terça-feira</segment>
    <segment id="15">, dia 3.</segment>
    <segment id="16">Atingido na perna</segment>
    <segment id="17">, o PM foi conduzido por uma viatura da Rondesp ao Hospital Geral do Estado (HGE)</segment>
    <segment id="18">, onde recebeu atendimento e foi liberado.</segment>
    <segment id="19">Valnei Batista de Jesus</segment>
    <segment id="20">, 28 anos</segment>
    <segment id="21">, e outro suspeito não identificado (aparentando 28 anos e 1</segment>
    <segment id="22">,90 m de altura)</segment>
    <segment id="23">, foram baleados na operação.</segment>
    <segment id="24">Feridos</segment>
    <segment id="25">, eles foram levados pelos policiais ao Hospital Geral do Estado (HGE)</segment>
    <segment id="26">, masmas não resistiram aos ferimentos e morreram.</segment>
    <segment id="27">De acordo com a polícia</segment>
    <segment id="28">, outros dois suspeitos fugiram pelas ruelas estreitas da região do Forno.</segment>
    <segment id="29">Mulheres no crime

Foram presos pela polícia Diego Fernandes de Jesus</segment>
    <segment id="30">, 24, Maiana Priscila Santos</segment>
    <segment id="31">, 22, e Noêmia Felipe de Jesus</segment>
    <segment id="32">, 31.</segment>
    <segment id="33">O trio foi autuado em flagrante por associação para o tráfico</segment>
    <segment id="34">, pelo delegado Omar Andrade</segment>
    <segment id="35">, titular da Delegacia do Rio Vermelho.</segment>
    <segment id="36">Segundo o delegado</segment>
    <segment id="37">, Maiana era mulher de Valnei.</segment>
    <segment id="38">Ela já tinha sido presa</segment>
    <segment id="39">, em uma outra ocasião</segment>
    <segment id="40">, ao tentar transportar cocaína para o Ceará.</segment>
    <segment id="41">O delegado afirma que está investigando a participação dos acusados no assalto ao banco.</segment>
    <segment id="42">Na operação</segment>
    <segment id="43">, houve apreensão de  200 trouxinhas de maconha</segment>
    <segment id="44">, já prontas para a venda</segment>
    <segment id="45">, além de balança de precisão</segment>
    <segment id="46">, cerca de R$ 1</segment>
    <segment id="47">,7 mil</segment>
    <segment id="48">, rádio de comunicação e duas armas de calibre 40 e 380.</segment>
  </rst>
</analysis>