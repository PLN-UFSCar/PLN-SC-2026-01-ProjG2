    <segment id="16">, queda de cabelo</segment>
    <segment id="17">, doen횄짠as neurol횄쨀gicas</segment>
    <segment id="18">, card횄짯acas e outros.</segment>
    <segment id="19">O problema</segment>
    <segment id="20">, 횄짤 que alguns portadores podem n횄짙o apresentar sintomas</segment>
    <segment id="21">, o que causa a maior dor de cabe횄짠a para a gr횄징vida e o beb횄짧. A transmiss횄짙o vertical</segment>
    <segment id="22">, das m횄짙es para os filhos</segment>
    <segment id="23">, pode ocorrer em qualquer per횄짯odo da gesta횄짠횄짙o.</segment>
    <segment id="24">Por isso</segment>
    <segment id="25">횄짤 importante</segment>
    <segment id="26">o acompanhamento do pr횄짤-natal</segment>
    <segment id="27">, recomenda a especialista.
Se ignorada</segment>
    <segment id="28">, a s횄짯filis pode causar aborto</segment>
    <segment id="29">, morte intrauterina</segment>
    <segment id="30">, 횄쨀bito neonatal</segment>
    <segment id="31">, m횄징 forma횄짠횄짙o etc.</segment>
    <segment id="32">O bom, 횄짤 que o dian횄쨀stico  횄짤 f횄징cil e o tratamento tamb횄짤</segment>
    <segment id="33">m. Dispomos de todas as tecnologias para n횄짙o termos mais casos de s횄짯filis</segment>
    <segment id="34">, afirma Jeane.</segment>
    <segment id="35">A falta de prote횄짠횄짙o durante o sexo 횄짤 o grande problema.</segment>
    <segment id="36">O n횄쨘mero de casos ainda cresce</segment>
    <segment id="37">porque</segment>
