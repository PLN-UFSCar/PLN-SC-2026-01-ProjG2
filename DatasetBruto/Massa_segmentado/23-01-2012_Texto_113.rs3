  <rst>
    <segment id="1">Show de Margary atrai mais de 6 mil
Sensação do verão</segment>
    <segment id="2">, ele conseguiu o maior público da história no Parque da Cidade</segment>
    <segment id="3">O Parque da Cidade mais parecia um formigueiro humano ontem</segment>
    <segment id="4">, durante o show de Margary Lord</segment>
    <segment id="5">, a grande sensação do verão de Salvador.</segment>
    <segment id="6">Segundo a assessoria do Projeto Música no Parque</segment>
    <segment id="7">, cerca de seis mil pessoas foram ao local para conferir de perto o show do cantor no anfiteatro Dorival Caymmi</segment>
    <segment id="8">, no primeiro show do projeto neste ano</segment>
    <segment id="9">, que bateu recorde de público.</segment>
    <segment id="10">Com irreverência</segment>
    <segment id="11">, Margary subiu no palco 11 horas em ponto e agitou o público com duas horas de black semba</segment>
    <segment id="12">, como</segment>
    <segment id="13">como ele mesmo define seu estilo musical.</segment>
    <segment id="14">“Inventando Moda”</segment>
    <segment id="15">, “Joelho” e “Circulou”</segment>
    <segment id="16">, sua maior aposta</segment>
    <segment id="17">, foram as músicas que mais empolgaram o público.</segment>
    <segment id="18">As pessoas mostravam já conhecer as canções e participaram ativamente do show.</segment>
    <segment id="19">O turismólogo Milton Muniz tem em casa os dois CDs gravados por Magary.</segment>
    <segment id="20">“Eu gosto</segment>
    <segment id="21">porque</segment>
    <segment id="22">porque ele faz algo diferente com irreverência e percussão de raiz africana”</segment>
    <segment id="23">, afirma.</segment>
    <segment id="24">Já o médico Ulysses Factum confessa conhecer poucas músicas</segment>
    <segment id="25">, masmas o que o agrada é a diversidade sonora que o artista imprime no seu som.</segment>
    <segment id="26">Para Magary</segment>
    <segment id="27">, esse diferencial que o público percebe está no seu repertório</segment>
    <segment id="28">, em que predomina as canções próprias.</segment>
    <segment id="29">“</segment>
    <segment id="30">A gente diverte o público com nossas músicas que falam do cotidiano</segment>
    <segment id="31">, expressam nossa verdade</segment>
    <segment id="32">, nossa cultura e resgata nossas raízes”</segment>
    <segment id="33">, conta</segment>
    <segment id="34">, feliz.</segment>
  </rst>
</analysis>