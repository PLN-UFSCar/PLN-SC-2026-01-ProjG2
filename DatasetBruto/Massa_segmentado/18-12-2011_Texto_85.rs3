  <rst>
    <segment id="1">Corpo de Cesária Évora será sepultado na terça</segment>
    <segment id="2">, em Cabo Verde
RIO - Cesária Évora morreu neste sábado</segment>
    <segment id="3">, aos 70 anos</segment>
    <segment id="4">, em Cabo Verde</segment>
    <segment id="5">, seu país natal.</segment>
    <segment id="6">Apelidada de "diva dos pés descalços"</segment>
    <segment id="7">, a cantora encerrou sua carreira no último dia 23 de setembro depois de cancelar uma série de shows devido a fragilidade de seu estado de saúde.</segment>
    <segment id="8">O funeral será realizado na terça-feira à tarde no Mindelo</segment>
    <segment id="9">, Ilha de São Vicente</segment>
    <segment id="10">, terra natal da cantora</segment>
    <segment id="11">, segundo informaram familiares à agência Inforpress.</segment>
    <segment id="12">O governo de Cabo Verde decretou dois dias de luto oficial</segment>
    <segment id="13">, em vigor até segunda-feira</segment>
    <segment id="14">, com bandeira hasteada a meio-pau em embaixadas</segment>
    <segment id="15">, consulados e outras representações de Cabo Verde no exterior.</segment>
    <segment id="16">De acordo com o veículo português "Jornal de Notícias"</segment>
    <segment id="17">, Cesária Évora deu entrada no hospital Baptista de Sousa</segment>
    <segment id="18">, em São Vicente</segment>
    <segment id="19">, Cabo Verde</segment>
    <segment id="20">, na sexta-feira</segment>
    <segment id="21">, onde esteve internada no CTI "com um quadro muito complexo".</segment>
    <segment id="22">"</segment>
    <segment id="23">Durante este período</segment>
    <segment id="24">, ela alternou momentos de lucidez com momentos de inconsciência e esteve sempre acompanhada do seu empresário José da Silva"</segment>
    <segment id="25">, disse o diretor do hospital</segment>
    <segment id="26">, Alcides Gonçalves.</segment>
    <segment id="27">Cesária Évora começou a trabalhar</segment>
    <segment id="28">comocomo cantora em bares e hotéis de Mindelo</segment>
    <segment id="29">, em Cabo Verde</segment>
    <segment id="30">, aos 16 anos.</segment>
    <segment id="31">Jovem, já cantava amores desfeitos e o isolamento das ilhas de seu país de origem.</segment>
    <segment id="32">O reconhecimento mundial de Cesária só viria aos 47 anos</segment>
    <segment id="33">, no fim dos da década de 1980</segment>
    <segment id="34">, ao gravar</segment>
    <segment id="35">, em Paris</segment>
    <segment id="36">, o disco "La diva aux pied nus".</segment>
    <segment id="37">Em 2004</segment>
    <segment id="38">, Cesária conquistou um prêmio Grammy de melhor álbum de world music contemporânea</segment>
    <segment id="39">, batendo o concorrente Caetano Veloso.</segment>
    <segment id="40">Há dois anos</segment>
    <segment id="41">, o presidente francês Nicolas Sarkozy a condecorou com a medalha da Legião da Honra.</segment>
    <segment id="42">As informações são do site português "</segment>
    <segment id="43">Jornal de Notícias".</segment>
    <segment id="44">Consagrada pelas coladeras</segment>
    <segment id="45">, canções dançantes</segment>
    <segment id="46">, ou mornas (o blues caboverdiano)</segment>
    <segment id="47">, a cantora sofreu um acidente vascular cerebral (AVC) em 2008</segment>
    <segment id="48">, durante uma turnê pela Austrália.</segment>
    <segment id="49">Seu último disco</segment>
    <segment id="50">, "</segment>
    <segment id="51">Nha sentimento"</segment>
    <segment id="52">, foi lançado em 2009.</segment>
  </rst>
</analysis>