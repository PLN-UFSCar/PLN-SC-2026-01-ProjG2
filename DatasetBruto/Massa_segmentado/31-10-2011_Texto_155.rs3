  <rst>
    <segment id="1">Edcity retorna à cidade para ver família</segment>
    <segment id="2">No campinho da Travessa Santa Rita ele bateu o baba com a garotada catuense
Depois da família e da música</segment>
    <segment id="3">, com certeza a grande paixão de Ed é o futebol.</segment>
    <segment id="4">Por isso</segment>
    <segment id="5">, na visita a Catu</segment>
    <segment id="6">, ele se</segment>
    <segment id="7">se jogou no baba da gurizada.</segment>
    <segment id="8">“Fiquei emocionado em estar aqui de novo.</segment>
    <segment id="9">É um lugar especial da minha infância”.</segment>
    <segment id="10">Ed teve uma infância cercada de amor e proteção</segment>
    <segment id="11">, com a família sempre o incentivando a buscar pelos sonhos dele.</segment>
    <segment id="12">Desde os 18 anos que os pais de Ed são separados</segment>
    <segment id="13">, masmas isso não atrapalhou em nada a relação.</segment>
    <segment id="14">Hoje, dona Géssi mora em Salvador.</segment>
    <segment id="15">“Ele vem me visitar todos os dias.</segment>
    <segment id="16">Não há nada que ele faça que não me conte”</segment>
    <segment id="17">, diz a mãe e melhor amiga do cantor.</segment>
    <segment id="18">Volta às origens:</segment>
    <segment id="19">Mesmo com o sucesso</segment>
    <segment id="20">, Edcity não esquece as raízes do interior</segment>
    <segment id="21">Seu Jonas trabalha em uma plataforma de petróleo e ainda está em Catu.</segment>
    <segment id="22">“Não nos vemos com muita frequência</segment>
    <segment id="23">, masmas sempre telefono para dizer o quanto eu o amo”</segment>
    <segment id="24">, sese derrete o filhão.</segment>
  </rst>
