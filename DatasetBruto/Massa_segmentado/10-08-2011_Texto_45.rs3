  <rst>
    <segment id="1">Famílias apontam descaso da empresa</segment>
    <segment id="2">Parentes dizem que Segura não informou sobre acidente</segment>
    <segment id="3">, que ocorreu às 7h30</segment>
    <segment id="4">No Instituto Médico-Legal (IML)</segment>
    <segment id="5">Nina Rodrigues</segment>
    <segment id="6">, ontem</segment>
    <segment id="7">, durante os trabalhos de reconhecimento e liberação dos corpos</segment>
    <segment id="8">, além da dor da perda</segment>
    <segment id="9">, familiares e amigos das nove vítimas reclamaram do que eles consideram uma falta de consideração da construtora.</segment>
    <segment id="10">Washington Santana dos Santos</segment>
    <segment id="11">, filho de Martinho</segment>
    <segment id="12">, acompanhou o resgate.</segment>
    <segment id="13">“Só queria sair daqui com meu pai”</segment>
    <segment id="14">, disse.</segment>
    <segment id="15">Segundo ele</segment>
    <segment id="16">, outros operários já haviam reclamado da segurança do elevador.</segment>
    <segment id="17">O operário José do Espírito Santo</segment>
    <segment id="18">, 63, que trabalha há um ano na obra estava no elevador ao lado do que caiu e disse que o trabalho na construção civil é "um campo de batalha que cheira a morte".</segment>
    <segment id="19">A maioria dos trabalhadores tem uma história de acidentes para contar.</segment>
    <segment id="20">Como é o</segment>
    <segment id="21">casocaso de  Edijan Boaventura da Silva</segment>
    <segment id="22">, 30, que trabalha na obra onde ocorreu o acidente há 7 meses.</segment>
    <segment id="23">Ele sofreu  fraturou uma falange.</segment>
    <segment id="24">“</segment>
    <segment id="25">Os trabalhadores sempre</segment>
    <segment id="26">sese machucam</segment>
    <segment id="27">, masmas nunca tinha visto um acidente igual a este”.</segment>
    <segment id="28">Construtora no local:</segment>
    <segment id="29">Pagará enterro</segment>
    <segment id="30">No início da tarde de ontem</segment>
    <segment id="31">, familiares reclamavam</segment>
    <segment id="32">porque</segment>
    <segment id="33">porque ainda não haviam sido procurados por representantes da construtora</segment>
    <segment id="34">, no IML.</segment>
    <segment id="35">Porém, por volta das 15h30</segment>
    <segment id="36">, o auxiliar de escritório da Segura</segment>
    <segment id="37">, Ramon Santos</segment>
    <segment id="38">, já acertava com os familiares detalhes dos funerais</segment>
    <segment id="39">, que serão bancados pela Segura.</segment>
    <segment id="40">Uma assistente social de prenome Juliana também foi ao IML.</segment>
    <segment id="41">Ela disse que não é funcionária da construtora</segment>
    <segment id="42">, masmas estava no local para prestar apoio aos familiares</segment>
    <segment id="43">, a pedido dos amigos que possui na empresa.</segment>
    <segment id="44">Amigos das vítimas desabafam: Trabalho na obra é</segment>
    <segment id="45">“matador de peão”</segment>
    <segment id="46">Sem revelar a identidade</segment>
    <segment id="47">, um amigo do pedreiro Hélio relatou que o companheiro costumava chamar o canteiro de obras da Segura de “matador de peão”.</segment>
    <segment id="48">Os corpos de Antônio Elias</segment>
    <segment id="49">, Lourival Ferreira e José Roque serão enterrados hoje no Cemitério Bosque da Paz</segment>
    <segment id="50">, a partir das 10h.</segment>
    <segment id="51">Hélio Sampaio será sepultado no Campo Santo</segment>
    <segment id="52">, às 15h.</segment>
    <segment id="53">Os outros serão enterrados em cidades do interior: Jairo Correia (Irará)</segment>
    <segment id="54">;</segment>
    <segment id="55">Martinho dos Santos (Conceição de Feira)</segment>
    <segment id="56">; Antônio Luiz (Conceição do Jacuípe)</segment>
    <segment id="57">;  Antônio Reis do Carmo (Nazaré do Jacuípe)</segment>
    <segment id="58">;</segment>
    <segment id="59">Manoel Bispo Pereira (São Miguel das Matas).</segment>
  </rst>
</analysis>