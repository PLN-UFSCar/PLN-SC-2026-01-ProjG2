  <rst>
    <segment id="1">Mãe morre no lugar do filho</segment>
    <segment id="2">Elizângela foi atingida por um tiro na cabeça enquanto seu cunhado Jervásio</segment>
    <segment id="3">, no rosto
Policiais da 66ª Companhia Independente da Polícia Militar prenderam em flagrante</segment>
    <segment id="4">, ontem</segment>
    <segment id="5">, José Vinícius Pires Ribeiro</segment>
    <segment id="6">, o Buraco</segment>
    <segment id="7">, 20 anos</segment>
    <segment id="8">, acusado de ter matado a cozinheira Elizângela dos Santos Dias</segment>
    <segment id="9">, 32 anos</segment>
    <segment id="10">, e de ter atirado em Jervásio Dias Xavier</segment>
    <segment id="11">, 40, na manhã de ontem</segment>
    <segment id="12">, no bairro Rocinha em Feira de Santana</segment>
    <segment id="13">O acusado foi preso no distrito feirense de Maria Quitéria</segment>
    <segment id="14">, quando tentava fugir em uma van do transporte alternativo de passageiros e com ele foi encontrada a arma do crime</segment>
    <segment id="15">, um revólver calibre 32.</segment>
    <segment id="16">De acordo com a delegada  da DH</segment>
    <segment id="17">, Milena Calmon</segment>
    <segment id="18">, o acusado teria ido à casa das vítima à procura de Rafael</segment>
    <segment id="19">, filho de Elizângela</segment>
    <segment id="20">, e como</segment>
    <segment id="21">como este conseguiu fugir</segment>
    <segment id="22">, ele atirou em quem encontrou pela frente.</segment>
    <segment id="23">“</segment>
    <segment id="24">Este crime foi motivado por acerto de contas entre o tráfico de drogas"</segment>
    <segment id="25">Sem arrependimento</segment>
    <segment id="26">Elizângela foi atingida por um tiro na cabeça enquanto seu cunhado Jervásio</segment>
    <segment id="27">, com um tiro no rosto.</segment>
    <segment id="28">Eles foram encaminhados pelo Samu para o HGCA</segment>
    <segment id="29">, onde a cozinheira morreu logo após dar entrada.</segment>
    <segment id="30">Jervásio foi submetido a intervenção cirúrgica e encontra-</segment>
    <segment id="31">sese em observação em estado estável.</segment>
    <segment id="32">Na delegacia</segment>
    <segment id="33">, Buraco informou que estava sendo ameaçado por traficantes e que resolveu</segment>
    <segment id="34">sese vingar.</segment>
    <segment id="35">“</segment>
    <segment id="36">Como cheguei à casa e ele correu</segment>
    <segment id="37">, atirei sem ver para onde pegava</segment>
    <segment id="38">, e acabou acontecendo isto tudo”</segment>
    <segment id="39">, falou sem demonstrar arrependimento.</segment>
    <segment id="40">Ele foi autuado em flagrante por homicídio e tentativa de homicídio e encaminhado para o Presídio Regional de Feira de Santana.</segment>
  </rst>
</analysis>