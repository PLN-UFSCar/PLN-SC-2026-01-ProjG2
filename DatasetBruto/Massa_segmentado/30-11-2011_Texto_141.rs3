  <rst>
    <segment id="1">Justiceiro do mal e querido pelo povo
Moradores de Cosme de Farias acreditam que estavam mais seguros com Miseravão solto</segment>
    <segment id="2">O que faz as pessoas preferirem que um assassino</segment>
    <segment id="3">, responsável por mais de 35 mortes</segment>
    <segment id="4">, esteja livre?</segment>
    <segment id="5">Segurança.</segment>
    <segment id="6">Esta é a resposta da maior parte dos moradores e comerciantes de Cosme de Farias ouvidos sobre a prisão de Gílson Ferreira Carneiro</segment>
    <segment id="7">, 32 anos</segment>
    <segment id="8">, o Gílson Miseravão ou Justiceiro.</segment>
    <segment id="9">Ele oferecia serviço de segurança no bairro</segment>
    <segment id="10">, masmas foi preso na última sexta-feira.</segment>
    <segment id="11">Miseravão era  caçado pela polícia desde janeiro.</segment>
    <segment id="12">“</segment>
    <segment id="13">Ele só matava traficante e ladrão.</segment>
    <segment id="14">Com gente honesta ele nem bulia.</segment>
    <segment id="15">Acredito que o tráfico vai aumentar aqui no bairro.</segment>
    <segment id="16">Ele dava segurança à comunidade”</segment>
    <segment id="17">, acredita um morador</segment>
    <segment id="18">, que preferiu não</segment>
    <segment id="19">sese identificar.</segment>
    <segment id="20">Uma comerciante acredita que a segurança não vai mudar</segment>
    <segment id="21">porque</segment>
    <segment id="22">porque outros homens que trabalham para Gílson continuam prestando serviço.</segment>
    <segment id="23">“Quase todos os comerciantes do final de linha pagam pela segurança.</segment>
    <segment id="24">Aqui, a gente paga R$ 50 por semana.</segment>
    <segment id="25">Gílson era tranquilo</segment>
    <segment id="26">comocomo pessoa</segment>
    <segment id="27">, masmas era temido</segment>
    <segment id="28">porque</segment>
    <segment id="29">porque era matador.</segment>
    <segment id="30">Foi melhor para todos ele ser preso”</segment>
    <segment id="31">, declara uma comerciante</segment>
    <segment id="32">, a única das pessoas ouvidas que prefere que Miseravão esteja preso.</segment>
    <segment id="33">Outro comerciante explica</segment>
    <segment id="34">porque</segment>
    <segment id="35">porque seria melhor que Gílson estivesse solto.</segment>
    <segment id="36">“</segment>
    <segment id="37">O policiamento não dá conta</segment>
    <segment id="38">, aí os comerciantes têm que recorrer a ele (Gílson)  mesmo”</segment>
    <segment id="39">, opina</segment>
    <segment id="40">, preferindo não identificar-</segment>
    <segment id="41">sese.</segment>
    <segment id="42">A gerente de um frigorífico que paga pelo serviço de segurança do grupo de Miseravão disse que não sabia que ele era autor de tantas mortes.</segment>
    <segment id="43">“Não conheço ele</segment>
    <segment id="44">, só o segurança daqui”</segment>
    <segment id="45">, conta.</segment>
    <segment id="46">Descrença nas instituições e desespero da população</segment>
    <segment id="47">Para Ceci Vilar</segment>
    <segment id="48">, coordenadora do Laboratório de Estudos em Violência</segment>
    <segment id="49">, Saúde e Sociedade (Laviss) da Ufba</segment>
    <segment id="50">, na medida em que as pessoas não confiam na polícia e na Justiça</segment>
    <segment id="51">, elas aprovam o compartamento de indivíduos</segment>
    <segment id="52">comocomo Gílson Miseravão</segment>
    <segment id="53">, que faz justiça paralela.</segment>
    <segment id="54">“Isso é uma coisa inaceitável em sociedades modernas.</segment>
    <segment id="55">O Estado deve</segment>
    <segment id="56">sese fazer mais presente tanto com a polícia quanto com políticas de inclusão social”</segment>
    <segment id="57">, explica.</segment>
    <segment id="58">Ceci Vilar lembrou que a população avaliou mal as instituições ligadas à Justiça e segurança pública em uma pesquisa feita em Salvador e Região Metropolitana em 1996.</segment>
    <segment id="59">“</segment>
    <segment id="60">A população quando</segment>
    <segment id="61">sese desespera perde o sentido crítico dos direitos humanos e apoia soluções ilegais”</segment>
    <segment id="62">, afirma.</segment>
    <segment id="63">Promessa de melhora</segment>
    <segment id="64">O comandante da PM</segment>
    <segment id="65">, coronel Alfredo Castro</segment>
    <segment id="66">, disse que a corporação dará uma resposta à população de Cosme de Farias.</segment>
    <segment id="67">“Acredito que seja a minoria dos moradores que concordem com a ação de Gílson Miseravão.</segment>
    <segment id="68">Vamos incrementar o policiamento a partir de hoje (ontem).</segment>
    <segment id="69">A população vai ter segurança e não pavor que tinha de Gílson”</segment>
    <segment id="70">, afirma.</segment>
    <segment id="71">O comandante afirmou que</segment>
    <segment id="72">casocaso as investigações da polícia civil confirmem a participação de PMs nas ações de Gilson</segment>
    <segment id="73">, os envolvidos serão expulsos da corporação.</segment>
    <segment id="74">“Vamos cortar na própria carne.</segment>
    <segment id="75">Não vamos admitir lobos vestidos com a pele de cordeiro”</segment>
    <segment id="76">, afirma.</segment>
    <segment id="77">Para o coronel Castro</segment>
    <segment id="78">, o apoio de algumas pessoas ao comportamento de Gílson Miseravão é uma inversão de valores.</segment>
    <segment id="79">“Isso é instituir a pena de morte.</segment>
    <segment id="80">Esse fato de matar marginal dá poder a ele de matar qualquer um.</segment>
    <segment id="81">Marginal também é pessoa.</segment>
    <segment id="82">No mundo atual</segment>
    <segment id="83">, essa atitude não é cabível”</segment>
    <segment id="84">, declara.</segment>
  </rst>
</analysis>