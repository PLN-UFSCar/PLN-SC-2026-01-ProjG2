  <rst>
    <segment id="1">Aqui se</segment>
    <segment id="2">se faz</segment>
    <segment id="3">, aqui</segment>
    <segment id="4">sese paga</segment>
    <segment id="5">Homem mata a mulher e paga o erro com a vida</segment>
    <segment id="6">O profissional de reciclagem Cláudio dos Santos Almeida</segment>
    <segment id="7">, 33, desferiu golpes de faca contra Rosemeri Bispo dos Santos</segment>
    <segment id="8">, 26, que morreu antes de chegar ao hospital.</segment>
    <segment id="9">Os golpes atingiram o peito e as costas da mulher.</segment>
    <segment id="10">Logo depois do o crime</segment>
    <segment id="11">, ele tentou fugir da Rua Paranaguá</segment>
    <segment id="12">, em Simões Filho</segment>
    <segment id="13">, no último sábado à noite</segment>
    <segment id="14">, masmas não foi longe.</segment>
    <segment id="15">O assassino caiu em um buraco e morreu com arame farpado enrolado no pescoço.</segment>
    <segment id="16">O casal chegou a cidade há cerca de três meses.</segment>
    <segment id="17">Eles eram de Alagoinhas e</segment>
    <segment id="18">, por causa de uma proposta de emprego para Cláudio</segment>
    <segment id="19">, na empresa Reciclal</segment>
    <segment id="20">, resolveram mudar para a cidade com o filho de Rosemeri.</segment>
    <segment id="21">Para os familiares</segment>
    <segment id="22">, ele não era violento e</segment>
    <segment id="23">, aparentemente</segment>
    <segment id="24">, viviam bem</segment>
    <segment id="25">, apesar das brigas.</segment>
    <segment id="26">“</segment>
    <segment id="27">No dia</segment>
    <segment id="28">, ele estava bebendo e só vi quando ela saiu correndo e ele atrás com a faca"</segment>
    <segment id="29">, disse José Carlos</segment>
    <segment id="30">, que prestou socorro à  vítima.</segment>
    <segment id="31">Quis matar o filho da  mulher:</segment>
    <segment id="32">A criança saiu correndo</segment>
    <segment id="33">O aposentado Antônio Barbosa de Almeida</segment>
    <segment id="34">, 71, lamenta o ocorrido com o filho.</segment>
    <segment id="35">"</segment>
    <segment id="36">Ele não era violento nem gostava de confusão.</segment>
    <segment id="37">Era um rapaz bom.</segment>
    <segment id="38">Olhe o que ele foi fazer.</segment>
    <segment id="39">E ainda deixou um filho"</segment>
    <segment id="40">, contou.</segment>
    <segment id="41">A família diz que o profissional de reciclagem gostava de beber</segment>
    <segment id="42">, masmas que não</segment>
    <segment id="43">sese envolvia em brigas.</segment>
    <segment id="44">Vizinhos contaram que antes de esfaquear a mulher</segment>
    <segment id="45">, Cláudio ameaçou matar o filho dela de 11 anos</segment>
    <segment id="46">, que saiu correndo quando a mãe foi assassinada.</segment>
  </rst>
</analysis>