    <segment id="5">Em Praia Grande</segment>
    <segment id="6">, SubГѓВєrbio FerroviГѓВЎrio</segment>
    <segment id="7">, eles vГѓВЈo ГѓВЎs Ruas Pedro Lopes e Carlos Gomes</segment>
