  <rst>
    <segment id="1">"</segment>
    <segment id="2">Concordo inteiramente com o rapaz”</segment>
    <segment id="3">Aguinaldo Silva sai em defesa do ator de sua novela</segment>
    <segment id="4">Caio Castro tem preconceito contra gays?</segment>
    <segment id="5">A questão deixou encucados os fãs do jovem galã que interpreta Antenor na novela “Fina Estampa” (Globo).</segment>
    <segment id="6">Ele esclareceu no Twitter</segment>
    <segment id="7">, na tarde de ontem</segment>
    <segment id="8">, a polêmica em que</segment>
    <segment id="9">sese envolveu após uma declaração sua publicada na revista QUEM!</segment>
    <segment id="10">, em que diz:</segment>
    <segment id="11">“Se você não tem fama de pegador e é solteiro</segment>
    <segment id="12">, fica com fama de veado.</segment>
    <segment id="13">Então, antes pegador que veado</segment>
    <segment id="14">, né?</segment>
    <segment id="15">”.</segment>
    <segment id="16">No microblog</segment>
    <segment id="17">, Caio Castro quis</segment>
    <segment id="18">sese defender.</segment>
    <segment id="19">“Gostaria de esclarecer que eu NÃO tenho nenhum preconceito</segment>
    <segment id="20">, inclusive tenho grandes amigos gays.</segment>
    <segment id="21">O que foi publicado não passou de uma infeliz interpretação de uma jornalista de uma frase fora do contexto do que eu disse”</segment>
    <segment id="22">, completou.</segment>
    <segment id="23">Com o bafão</segment>
    <segment id="24">, o nome do ator foi um dos assuntos mais comentados no Twitter.</segment>
    <segment id="25">Aguinaldo Silva</segment>
    <segment id="26">, autor da novela Fina Estampa</segment>
    <segment id="27">, foi em defesa do ator:</segment>
    <segment id="28">“Concordo inteiramente com o rapaz”.</segment>
    <segment id="29">Segundo ele</segment>
    <segment id="30">, "prum galã de tevê</segment>
    <segment id="31">, é melhor ter fama de pegador que de viado...</segment>
    <segment id="32">Ou ele não arranja mais trabalho”.</segment>
    <segment id="33">Ele ainda falou que qui na Bahia</segment>
    <segment id="34">, já tem gente louquinha para acabar com o suposto preconceito do ator global.</segment>
    <segment id="35">A vereadora Léo Kret do Brasil é uma delas.</segment>
    <segment id="36">“</segment>
    <segment id="37">Se Caio der mole</segment>
    <segment id="38">, tiro todo o preconceito do rapaz!</segment>
    <segment id="39">”, brinca Léo</segment>
    <segment id="40">, que também acredita que a declaração do bonitão à revista foi infeliz</segment>
    <segment id="41">.</segment>
    <segment id="42">“</segment>
    <segment id="43">Caio deve ter dito isso sem pensar.</segment>
    <segment id="44">Pelo que conheço</segment>
    <segment id="45">, ele é amigo de gays e convive muito bem com os homossexuais"</segment>
    <segment id="46">, defende Léo Kret.</segment>
  </rst>
