  <rst>
    <segment id="1">Delegado avalia que modelo Nicole Bahls</segment>
    <segment id="2">, que atropelou um italiano</segment>
    <segment id="3">, não fez 'nada de errado'
RIO - Na avaliação do delegado Gilberto Ribeiro</segment>
    <segment id="4">, titular da 14 DP (Leblon)</segment>
    <segment id="5">, a modelo Nicole Bahls</segment>
    <segment id="6">, que atropelou um turista italiano na madrugada da quarta-feira</segment>
    <segment id="7">, "não fez nada de errado".</segment>
    <segment id="8">A assistente de palco do programa "Pânico na TV"</segment>
    <segment id="9">, da Rede TV!</segment>
    <segment id="10">, prestou socorro à vítima e procurou espontaneamente a polícia</segment>
    <segment id="11">, segundo ele.</segment>
    <segment id="12">A vítima</segment>
    <segment id="13">, por sua vez</segment>
    <segment id="14">, não compareceu à delegacia para prestar queixa.
- A princípio</segment>
    <segment id="15">, não aconteceu nada de errado.</segment>
    <segment id="16">Não temos informações de que ela estava embriagada.</segment>
    <segment id="17">Tudo correu bem - disse Ribeiro.</segment>
    <segment id="18">A modelo de 24 anos atropelou o turista italiano Christian Rizzin</segment>
    <segment id="19">, na madrugada desta quarta-feira</segment>
    <segment id="20">, no Leblon.</segment>
    <segment id="21">O acidente aconteceu entre as ruas Rainha Guilhermina e Dias Ferreira.</segment>
    <segment id="22">A vítima foi encaminhada para o Hospital Miguel Couto e liberado algumas horas depois com escoriações leves.</segment>
    <segment id="23">Na delegacia</segment>
    <segment id="24">, Nicole contou que acabara de sair do Fashion Rio</segment>
    <segment id="25">, na Zona Portuária.</segment>
    <segment id="26">Ela estava indo jantar com um amigo no restaurante Sushi Leblon.</segment>
    <segment id="27">Segundo o amigo que estava com a modelo</segment>
    <segment id="28">, eles vinham pela Rua Rainha Guilhermina e</segment>
    <segment id="29">, quando dobraram à esquerda</segment>
    <segment id="30">, na Dias Ferreira</segment>
    <segment id="31">, atropelaram o italiano</segment>
    <segment id="32">, que tinha feito sinal para um táxi e</segment>
    <segment id="33">sese preparava para entrar no carro.</segment>
    <segment id="34">A modelo chegou a bater no táxi.</segment>
    <segment id="35">Muito nervosa</segment>
    <segment id="36">, Nicole disse a policiais que não bebe.</segment>
    <segment id="37">E mais: assustada com o atropelamento</segment>
    <segment id="38">, revelou que não pretende mais dirigir o seu carro</segment>
    <segment id="39">, um Hyundai Veracruz.</segment>
    <segment id="40">Após prestar depoimento</segment>
    <segment id="41">, Nicole saiu pelos fundos da delegacia e pegou um táxi</segment>
    <segment id="42">, sem falar com a imprensa.</segment>
  </rst>
</analysis>