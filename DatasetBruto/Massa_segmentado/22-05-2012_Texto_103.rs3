  <rst>
    <segment id="1">Alerj desiste do prédio da Bolsa e agora quer</segment>
    <segment id="2">sese mudar para o Porto
RIO - A Assembleia Legislativa do Rio (Alerj) desistiu da desapropriação do antigo prédio da Bolsa de Valores na Praça Quinze</segment>
    <segment id="3">, no Centro.</segment>
    <segment id="4">A decisão foi tomada na última sexta-feira após a apresentação de um estudo preliminar da Procuradoria Geral do Estado</segment>
    <segment id="5">, que avaliou o imóvel em aproximadamente R$ 300 milhões</segment>
    <segment id="6">, valor considerado muito alto.</segment>
    <segment id="7">O governo pretendia desapropriar o edifício</segment>
    <segment id="8">, para onde seria transferida a Alerj.</segment>
    <segment id="9">O presidente da assembleia</segment>
    <segment id="10">, Paulo Melo (PMDB)</segment>
    <segment id="11">, já busca outras alternativas mais em conta.</segment>
    <segment id="12">Ele tenta</segment>
    <segment id="13">, junto ao governo do estado</segment>
    <segment id="14">, a liberação de um terreno na Zona Portuária.</segment>
    <segment id="15">Estudos para a desapropriação de outros imóveis que possam abrigar os parlamentares também estão em andamento.</segment>
    <segment id="16">Maioria dos gabinetes fica no prédio anexo</segment>
    <segment id="17">Hoje, além do Palácio Tiradentes</segment>
    <segment id="18">, na Praça Quinze</segment>
    <segment id="19">, os parlamentares ocupam um prédio anexo</segment>
    <segment id="20">, onde fica a maioria dos gabinetes.</segment>
    <segment id="21">Segundo a Alerj</segment>
    <segment id="22">, esse edifício não pode ser ampliado</segment>
    <segment id="23">porque</segment>
    <segment id="24">porque fica no Corredor Cultural.</segment>
    <segment id="25">De acordo com a presidência da assembleia</segment>
    <segment id="26">, a atual estrutura dos prédios não atende mais às necessidades da Casa.</segment>
    <segment id="27">Existe ainda uma proposta de demolir o prédio anexo</segment>
    <segment id="28">, caso</segment>
    <segment id="29">caso seja feita a mudança dos gabinetes para um novo endereço.</segment>
    <segment id="30">O edifício onde ficava a antiga sede da Bolsa de Valores tem 41 mil metros quadrados</segment>
    <segment id="31">, 13 andares com 35 salas e estacionamento para 124 carros</segment>
    <segment id="32">, além de auditório para 250 pessoas.</segment>
    <segment id="33">O imóvel pertence atualmente à Bolsa de Valores de São Paulo e a outros dez proprietários.</segment>
    <segment id="34">As salas encontram-</segment>
    <segment id="35">sese ocupadas por 31 empresas</segment>
    <segment id="36">, entre escritórios de multinacionais</segment>
    <segment id="37">, bancos</segment>
    <segment id="38">, corretoras do mercado financeiro e um escritório de advocacia.</segment>
  </rst>
</analysis>