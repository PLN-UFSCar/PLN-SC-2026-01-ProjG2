  <rst>
    <segment id="1">Ratos fazem a festa em posto de saГѓВєde
Mesmo com limpeza</segment>
    <segment id="2">, animais insistem em nГѓВЈo sair do local</segment>
    <segment id="3">O forte odor de chorume e a proliferaГѓВ§ГѓВЈo de ratos na praГѓВ§a do Alto das Pombas</segment>
    <segment id="4">, provocados pelo vazamento em um compressor de lixo instalado no bairro</segment>
    <segment id="5">, vГѓВЄm incomodando e causando transtornos aos moradores.</segment>
    <segment id="6">Por causa de uma possГѓВ­vel infestaГѓВ§ГѓВЈo de roedores</segment>
    <segment id="7">, a Unidade de SaГѓВєde da FamГѓВ­lia da comunidade completou</segment>
    <segment id="8">, ontem</segment>
    <segment id="9">, cinco dias sem funcionar plenamente.</segment>
    <segment id="10">Apenas a distribuiГѓВ§ГѓВЈo de medicamentos</segment>
    <segment id="11">, a mediГѓВ§ГѓВЈo de pressГѓВЈo arterial</segment>
    <segment id="12">, a marcaГѓВ§ГѓВЈo de consultas mГѓВ©dicas e os trabalhos externos estГѓВЈo sendo realizados.</segment>
    <segment id="13">Segundo a Secretaria Municipal de SaГѓВєde (SMS)</segment>
    <segment id="14">, o atendimento na unidade volta ao normal hoje.</segment>
    <segment id="15">Agentes do Centro de Controle de Zoonoses (CCZ) farГѓВЈo uma vistoria no local</segment>
    <segment id="16">, para verificar</segment>
    <segment id="17">sese hГѓВЎ infestaГѓВ§ГѓВЈo de ratos.</segment>
    <segment id="18">Caso a hipГѓВіtese seja confirmada</segment>
    <segment id="19">, o prГѓВ©dio da unidade passarГѓВЎ por um processo de dedetizaГѓВ§ГѓВЈo.</segment>
    <segment id="20">De acordo com o morador Wilson Almeida</segment>
    <segment id="21">, 59 anos</segment>
    <segment id="22">, alГѓВ©m de ratos</segment>
    <segment id="23">, baratas e moscas</segment>
    <segment id="24">sese tornaram constantes no bairro apГѓВіs a instalaГѓВ§ГѓВЈo</segment>
    <segment id="25">, hГѓВЎ um mГѓВЄs</segment>
    <segment id="26">, da caixa de compressГѓВЈo com vazamento.</segment>
    <segment id="27">Projeto dГѓВЎ esperanГѓВ§a</segment>
    <segment id="28">SoluГѓВ§ГѓВЈo alternativa ao problema</segment>
    <segment id="29">, um projeto de educaГѓВ§ГѓВЈo em descarte de lixo</segment>
    <segment id="30">, reciclagem e meio-ambiente Гўв‚¬</segment>
    <segment id="31">вЂњ elaborado por alunos da Escola PolitГѓВ©cnica da Universidade Federal da Bahia (Ufba) junto ГѓВ  AssociaГѓВ§ГѓВЈo de Moradores do Alto das Pombas Гўв‚¬</segment>
    <segment id="32">вЂњ poderГѓВЎ ser apresentado nos prГѓВіximos dias ГѓВ  prefeitura.</segment>
    <segment id="33">Segundo o presidente da entidade</segment>
    <segment id="34">, Derval Pereira</segment>
    <segment id="35">, levar a ideia atГѓВ© a gestГѓВЈo municipal sГѓВі depende da aprovaГѓВ§ГѓВЈo dos moradores.</segment>
    <segment id="36">Гўв‚¬Е“ГѓвЂ° um projeto sobretudo sobre educaГѓВ§ГѓВЈo ambientalГўв‚¬</segment>
    <segment id="37">, diz.</segment>
    <segment id="38">Cheiro incomoda a todos</segment>
    <segment id="39">A reportagem tentou entrar em contato com a presidente da Empresa de Limpeza Urbana de Salvador (Limpurb)</segment>
    <segment id="40">, KГѓВЎtia Alves</segment>
    <segment id="41">, masmas nГѓВЈo conseguiu atГѓВ© o fechamento.</segment>
    <segment id="42">Devido ao problema</segment>
    <segment id="43">, atГѓВ© missas na ParГѓВіquia Divino EspГѓВ­rito Santo</segment>
    <segment id="44">, na praГѓВ§a do Alto das Pombas</segment>
    <segment id="45">, foram canceladas.</segment>
    <segment id="46">Segundo o ministro da igreja</segment>
    <segment id="47">, Joselito Souza</segment>
    <segment id="48">, o cheiro incomoda os fiГѓВ©is</segment>
    <segment id="49">, o que impede a realizaГѓВ§ГѓВЈo dos cultos.</segment>
    <segment id="50">Гўв‚¬Е“O cheiro chega atГѓВ© na sacristiaГўв‚¬</segment>
    <segment id="51">, diz.</segment>
    <segment id="52">Mesmo com limpeza</segment>
    <segment id="53">, fedor insiste em nГѓВЈo sair do local</segment>
    <segment id="54">No meio da tarde de ontem</segment>
    <segment id="55">, funcionГѓВЎrios da Limpurb realizaram uma lavagem das ruas do bairro com um caminhГѓВЈo-pipa e detergente.</segment>
    <segment id="56">Mesmo assim</segment>
    <segment id="57">, o fedor de chorume persistiu.</segment>
    <segment id="58">Na ocasiГѓВЈo</segment>
    <segment id="59">, tГѓВ©cnicos da Diretoria de AtenГѓВ§ГѓВЈo</segment>
    <segment id="60">ГѓВ  SaГѓВєde da SMS tambГѓВ©m visitaram a unidade de saГѓВєde local.</segment>
    <segment id="61">Segundo um deles</segment>
    <segment id="62">, identificado ГѓВ  reportagem</segment>
    <segment id="63">comocomo Anselmo Campos</segment>
    <segment id="64">, a Limpurb garantiu que trocaria a caixa de compressГѓВЈo quebrada por uma nova hoje e taparia o buraco aberto pelo chorume debaixo do equipamento de coleta.</segment>
    <segment id="65">Гўв‚¬Е“O vazamento estГѓВЎ sendo causado por causa de um problema na borracha de vedaГѓВ§ГѓВЈo da caixaГўв‚¬</segment>
    <segment id="66">, explicou Campos.</segment>
