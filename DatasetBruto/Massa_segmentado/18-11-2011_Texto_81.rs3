  <rst>
    <segment id="1">Bandido taca pedra na boca de mulher</segment>
    <segment id="2">Pedagoga teve dois dentes quebrados e ficou com os lábios inchados</segment>
    <segment id="3">Na noite desta quinta-feira (17)</segment>
    <segment id="4">, enquanto conversava com a reportagem</segment>
    <segment id="5">, a pedagoga  J.A.</segment>
    <segment id="6">, 57 anos</segment>
    <segment id="7">, ainda mostrava dificuldade em falar.</segment>
    <segment id="8">A boca permanecia inchada</segment>
    <segment id="9">, resultado da pancada que lhe quebrou dois dentes da frente.</segment>
    <segment id="10">Por volta das 17h30 de quarta-feira (16)</segment>
    <segment id="11">, ela foi surpreendida por um assaltante próximo ao Parque da Cidade</segment>
    <segment id="12">, no Itaigara</segment>
    <segment id="13">, que estraçalhou com uma pedrada o vidro do carona do Ford Fiesta da vítima.</segment>
    <segment id="14">“</segment>
    <segment id="15">O bandido</segment>
    <segment id="16">, um branquelo</segment>
    <segment id="17">, passou por trás do meu carro</segment>
    <segment id="18">, chegou no meu vidro e gritou ‘perdeu</segment>
    <segment id="19">, perdeu’!</segment>
    <segment id="20">Eu consegui esconder a bolsa.</segment>
    <segment id="21">Ele atirou um pedregulho que quebrou o vidro e atingiu minha boca.</segment>
    <segment id="22">Fiquei toda ensanguentada”</segment>
    <segment id="23">, contou J.

Ela não chegou a registrar ocorrência</segment>
    <segment id="24">, porque</segment>
    <segment id="25">porque achou desnecessário</segment>
    <segment id="26">, uma vez que a bolsa não foi levada.</segment>
    <segment id="27">Mas lembra que “naquele local é recorrente acontecer essas ações de bandido”.</segment>
    <segment id="28">Maldade: Marginais arremessam no rosto

“</segment>
    <segment id="29">O impacto causado por essas ocorrências é sempre forte</segment>
    <segment id="30">, pois</segment>
    <segment id="31">pois os marginais arremessam as pedras na direção do rosto das vítimas para evitar que elas sigam dirigindo”</segment>
    <segment id="32">, detalhou o oficial.</segment>
    <segment id="33">A pedagoga contou que vai precisar de implantes.</segment>
    <segment id="34">“Tive até sorte.</segment>
    <segment id="35">Poderia ter ficado cega ou mesmo sofrer um traumatismo craniano.</segment>
    <segment id="36">Aí, nem estaria conversando com vocês”.</segment>
  </rst>
