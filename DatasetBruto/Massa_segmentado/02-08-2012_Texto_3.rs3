  <rst>
    <segment id="1">Carrascos detonam NegГѓВЈo do FacГѓВЈo</segment>
    <segment id="2">Ajudante de pedreiro pode ter morrido devido a uma disputa por um terreno em Ipitanga</segment>
    <segment id="3">O ajudante de pedreiro Osvaldo da ConceiГѓВ§ГѓВЈo</segment>
    <segment id="4">, 45 anos</segment>
    <segment id="5">, foi assassinado</segment>
    <segment id="6">, na noite da ГѓВєltima terГѓВ§a-feira</segment>
    <segment id="7">, quando chegava ao seu barraquinho de madeira construГѓВ­do em um terreno na Rua Dr. HГѓВ©lio de Brito</segment>
    <segment id="8">, Praia de Ipitanga</segment>
    <segment id="9">, em Lauro de Freitas (Grande Salvador).</segment>
    <segment id="10">Osvaldo</segment>
    <segment id="11">, mais conhecido</segment>
    <segment id="12">comocomo NegГѓВЈo do FacГѓВЈo</segment>
    <segment id="13">, tomava conta desse terreno e realizava serviГѓВ§os gerais nas casas do bairro.</segment>
    <segment id="14">Ele ganhou esse apelido</segment>
    <segment id="15">porque</segment>
    <segment id="16">porque sempre andava com um facГѓВЈo na cintura</segment>
    <segment id="17">, que utilizava para o trabalho.</segment>
    <segment id="18">Segundo informaГѓВ§ГѓВµes do ServiГѓВ§o de InvestigaГѓВ§ГѓВЈo da 23Г‚ВЄ DT (Lauro de Freitas)</segment>
    <segment id="19">, dois homens aguardavam a vГѓВ­tima chegar em casa e efetuaram vГѓВЎrios disparos contra ela.</segment>
    <segment id="20">Гўв‚¬Е“Ouvi uns dez tiros depois teve um barulho de fogueteГўв‚¬</segment>
    <segment id="21">, conta o morador Marcos Oliveira.</segment>
    <segment id="22">Para a polГѓВ­cia</segment>
    <segment id="23">, dois episГѓВіdios recentes podem ter motivado o crime.</segment>
    <segment id="24">Havia uma disputa pela posse do terreno que NegГѓВЈo tomava conta e morava.</segment>
    <segment id="25">Ele entrou com uma aГѓВ§ГѓВЈo na JustiГѓВ§a trabalhista cobrando os pagamentos atrasados.</segment>
    <segment id="26">O dono ГѓВ© um italiano e a mulher dele estava ГѓВ  frente das discussГѓВµes.</segment>
    <segment id="27">Outro motivo para o crime seria vinganГѓВ§a.</segment>
    <segment id="28">No ГѓВєltimo domingo</segment>
    <segment id="29">, NegГѓВЈo brigou com um homem que estaria dizendo que ele queria roubar uma casa na Praia de Ipitanga.</segment>
    <segment id="30">Os dois trocaram socos e NegГѓВЈo pegou o facГѓВЈo e meteu no rosto do rapaz.</segment>
    <segment id="31">Moradores separaram a briga e  levaram o ferido</segment>
    <segment id="32">, sem gravidade</segment>
    <segment id="33">, para o hospital.</segment>
    <segment id="34">O cara era valente e corajoso</segment>
    <segment id="35">Um colega da vГѓВ­tima contou</segment>
    <segment id="36">, sob anonimato</segment>
    <segment id="37">, que a mulher do italiano</segment>
    <segment id="38">, dono do terreno</segment>
    <segment id="39">, acertou que pagaria meio salГѓВЎrio mГѓВ­nimo a NegГѓВЈo do FacГѓВЈo</segment>
    <segment id="40">, para ele tomar conta da ГѓВЎrea.</segment>
    <segment id="41">Mas a mulher sГѓВі pagou o primeiro mГѓВЄs.</segment>
    <segment id="42">HГѓВЎ alguns anos</segment>
    <segment id="43">, o ajudante de pedreiro mora no local.</segment>
    <segment id="44">Гўв‚¬Е“HГѓВЎ trГѓВЄs meses</segment>
    <segment id="45">, essa dona veio e tentou tirar ele a forГѓВ§a do terreno.</segment>
    <segment id="46">Quebraram os fios de eletricidade</segment>
    <segment id="47">, masmas ele espantou o pessoal.</segment>
    <segment id="48">Antes, jГѓВЎ tinham derrubado o muroГўв‚¬</segment>
    <segment id="49">, relata.</segment>
    <segment id="50">Ele ainda conta que  Osvaldo era natural de Santo EstГѓВЄvГѓВЈo (a 148 Km de Salvador).</segment>
    <segment id="51">Гўв‚¬Е“Era um cara batalhador.</segment>
    <segment id="52">NГѓВЈo mexia com ninguГѓВ©m</segment>
    <segment id="53">, nГѓВЈo usava drogasГўв‚¬.</segment>
