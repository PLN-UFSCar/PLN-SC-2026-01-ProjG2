  <rst>
    <segment id="1">Ex-vereador</segment>
    <segment id="2">sese joga de aeronave
Agnaldo Pereira entrou em desespero quando o avião deu pane</segment>
    <segment id="3">Uma equipe do Centro de Investigação e Prevenção de Acidentes da Aeronáutica (Cenipa)</segment>
    <segment id="4">, regional Recife</segment>
    <segment id="5">, deve chegar esta semana a Condeúba</segment>
    <segment id="6">, a 642 km de Salvador</segment>
    <segment id="7">, para fazer uma avaliação técnica do monomotor que matou o ex-vereador do município</segment>
    <segment id="8">, Agnaldo José Pereira</segment>
    <segment id="9">, 44 anos</segment>
    <segment id="10">, após enfrentar problemas no pouso.</segment>
    <segment id="11">O incidente ocorreu na noite de segunda-feira</segment>
    <segment id="12">, 14,  quando o avião</segment>
    <segment id="13">, modelo PR VCM-RV 10</segment>
    <segment id="14">, apresentou pane minutos antes de aterrissar na pista particular da fazenda Cajueiro</segment>
    <segment id="15">, pertencente à vítima.</segment>
    <segment id="16">A pista de pouso</segment>
    <segment id="17">, construída há dois anos e meio</segment>
    <segment id="18">, é coberta de cascalho e não possui iluminação.</segment>
    <segment id="19">Pereira</segment>
    <segment id="20">, que viajava em companhia de um primo e do piloto e irmão</segment>
    <segment id="21">, entrou em desespero após a pane e pulou.</segment>
    <segment id="22">O ex-vereador teria</segment>
    <segment id="23">sese jogado da aeronave já na área da pista</segment>
    <segment id="24">, depois de conseguir abrir a porta</segment>
    <segment id="25">, sendo atingido pela hélice do avião.</segment>
    <segment id="26">Ele morreu na hora.</segment>
    <segment id="27">Os demais ocupantes não sofreram ferimentos.</segment>
    <segment id="28">Testemunhas dizem que o avião começou a perder altura a poucos metros da pista</segment>
    <segment id="29">, masmas ainda assim conseguiu pousar com pequenas avarias na fuselagem.</segment>
    <segment id="30">As causas da morte ainda estão sendo apuradas por peritos do Departamento de Polícia Técnica (DPT).</segment>
    <segment id="31">O laudo deve ser apresentado em até 30 dias.</segment>
    <segment id="32">O corpo de Pereira foi enterrado ontem</segment>
    <segment id="33">, no povoado de Alegre</segment>
    <segment id="34">, a 40 km da sede municipal.</segment>
    <segment id="35">A polícia civil abriu uma investigação paralela para apurar responsabilidades.</segment>
    <segment id="36">Tragédia: Morria de medo de voar

Pereira</segment>
    <segment id="37">, segundo um primo que não quis</segment>
    <segment id="38">sese identificar</segment>
    <segment id="39">, tinha medo de avião</segment>
    <segment id="40">, masmas mesmo assim aceitou o convite do irmão para voar.</segment>
    <segment id="41">O ex-vereador era membro da ONG Voluntários do Sertão</segment>
    <segment id="42">, que prestava assistência a famílias no interior baiano.</segment>
    <segment id="43">Ele ocupou vaga na Câmara em 2000 a 2008.</segment>
    <segment id="44">Era casado e tinha três filhos.

 
Investigação: De quem é a culpa?</segment>
    <segment id="45">Uma das questões a serem respondidas pelo Cenipa é</segment>
    <segment id="46">sese as falhas que contribuíram para o incidente foram humanas ou mecânicas.</segment>
    <segment id="47">O resultado servirá</segment>
    <segment id="48">comocomo base para recomendações de segurança a envolvidos na atividade de voo.</segment>
  </rst>
</analysis>