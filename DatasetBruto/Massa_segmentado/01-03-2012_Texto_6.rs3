  <rst>
    <segment id="1">Rafa saiu da casa com moral baixa</segment>
    <segment id="2">O eliminado desta semana não levou o R$ 1</segment>
    <segment id="3">,5 milhão e ainda ganhou fama de cafajeste
Finalmente Camila Pastorini</segment>
    <segment id="4">, ex- namorada de Rafa</segment>
    <segment id="5">, conseguiu conquistar o objetivo de eliminá-lo da casa mais vigiada do Brasil com uma porcentagem bem alta: ele recebeu 92% dos votos de rejeição do público</segment>
    <segment id="6">, no último paredão.</segment>
    <segment id="7">Depois de ter dito</segment>
    <segment id="8">, durante a festa em que ficou com Renata pela primeira vez</segment>
    <segment id="9">, que queria trair a namorada</segment>
    <segment id="10">, agora</segment>
    <segment id="11">Rafa demostra arrependimento do corno que deu em rede nacional.</segment>
    <segment id="12">Durante um bate-papo promovido pelo site oficial do BBB 12</segment>
    <segment id="13">, ele assistiu a um vídeo da ex-namorada  lhe desejando boa-sorte no programa e afirmando que não o julgava por ter ficado com Renata.</segment>
    <segment id="14">"</segment>
    <segment id="15">Só quero te desejar boa-sorte</segment>
    <segment id="16">, que tu aproveites muito esse momento que ele é só seu.</segment>
    <segment id="17">Não estou aqui para te julgar"</segment>
    <segment id="18">, afirmou Camila.</segment>
    <segment id="19">O Shrek - apelido que ele ganhou do apresentador Pedro Bial -  ficou surpreso e emocionado com a gravação.</segment>
    <segment id="20">"</segment>
    <segment id="21">Lá fora me perguntaram</segment>
    <segment id="22">sese eu me arrependia de ter entrado no programa</segment>
    <segment id="23">, eu disse que não</segment>
    <segment id="24">, masmas agora  começo a ter minhas dúvidas</segment>
    <segment id="25">sese não estou arrependido".</segment>
    <segment id="26">Será que depois de tudo o que passou e da campanha para retirada de Rafa do BBB 12</segment>
    <segment id="27">, Camila  volta para ele?</segment>
    <segment id="28">‘</segment>
    <segment id="29">Ex’ celebrou eliminação com champanhe</segment>
    <segment id="30">Na noite de paredão no BBB 12 - que estava sendo disputado por Yuri e Rafa - Camila Pastorini</segment>
    <segment id="31">,  ex- namorada dele</segment>
    <segment id="32">, fez questão de colocar o melhor traje!</segment>
    <segment id="33">A gaúcha usou um vestido de gala bem coladinho  e brindou a eliminação do brother com champanhe entre amigos e familiares.</segment>
    <segment id="34">Em sua conta no Twitter</segment>
    <segment id="35">, ela chegou a postar fotos do seu look.</segment>
    <segment id="36">Depois de ter sido traída</segment>
    <segment id="37">, a gata resolveu fazer campanha para eliminá-lo e conseguiu o que tanto queria!</segment>
  </rst>
