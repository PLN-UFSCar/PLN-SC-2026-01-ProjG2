  <rst>
    <segment id="1">Bandidos fogem da cadeia</segment>
    <segment id="2">A cela superlotada ajudou que 11 presos dessem no pé na madruga</segment>
    <segment id="3">Onze presos fugiram da carceragem da 1ª Delegacia Territorial (DT/Barris)</segment>
    <segment id="4">, ontem de madrugada.</segment>
    <segment id="5">Até a noite de ontem nenhum dos fugitivos havia sido recapturados.</segment>
    <segment id="6">A custódia</segment>
    <segment id="7">, até o episódio</segment>
    <segment id="8">, era ocupada por 81 internos</segment>
    <segment id="9">, 118% a mais que a capacidade permitida de 37 criminosos.</segment>
    <segment id="10">“</segment>
    <segment id="11">A carceragem da 1ª DT é exemplo da superlotação que existe nas delegacias do Estado”</segment>
    <segment id="12">, afirma  o diretor do Sindicato dos Policiais Civis</segment>
    <segment id="13">, Cláudio Lima.</segment>
    <segment id="14">Entre os foragidos</segment>
    <segment id="15">, presos por assaltos</segment>
    <segment id="16">, tráfico de drogas</segment>
    <segment id="17">, falsidade ideológica</segment>
    <segment id="18">, lesão corporal e furtos.</segment>
    <segment id="19">A evasão aconteceu pouco depois das 3 horas</segment>
    <segment id="20">, quando seis internos tiveram acesso ao pátio do Complexo de Delegacias dos Barris</segment>
    <segment id="21">, serrando uma das celas.</segment>
    <segment id="22">O restante deixou a unidade com o apoio do primeiro grupo.</segment>
    <segment id="23">Utilizando uma teresa (corda feita com lençóis</segment>
    <segment id="24">, camisetas e toalhas)</segment>
    <segment id="25">, os bandidos conseguiram pular  o muro</segment>
    <segment id="26">, tendo acesso à rua.</segment>
    <segment id="27">A ação foi flagrada por policiais de plantão na 1ª DT e Delegacia de Tóxicos e Entorpecentes (DTE) que impediram uma fuga em massa.</segment>
    <segment id="28">Na manhã de ontem</segment>
    <segment id="29">, equipes da 1ª</segment>
    <segment id="30">DT iniciaram as buscas aos presos</segment>
    <segment id="31">, masmas até noite de ontem.</segment>
    <segment id="32">Uma equipe do Departamento de Polícia Técnica (DPT) esteve na delegacia</segment>
    <segment id="33">, onde periciaram as celas.</segment>
    <segment id="34">“</segment>
    <segment id="35">As equipes estão na rua à procura dos fugitivos”</segment>
    <segment id="36">, disse a delegada Jamila Carvalho.</segment>
    <segment id="37">Eles estão soltos por aí:</segment>
    <segment id="38">Os fugitivos
Erenilton Souza Santos (falsidade ideológica)</segment>
    <segment id="39">, Leonardo Santana de Araújo (tráfico de drogas)</segment>
    <segment id="40">, Erielson Mota Pereira Silva (assalto)</segment>
    <segment id="41">, Gilmar de Jesus Santos (lesão corporal)</segment>
    <segment id="42">, Manuel da Hora Lopes (assalto</segment>
    <segment id="43">, Rubens Antônio Silva Costa (furto)</segment>
    <segment id="44">, Leonardo Silva da Lima (assalto)</segment>
    <segment id="45">, Paulo Vítor Conceição Oliveira (assalto)</segment>
    <segment id="46">, Gilvan Pereira dos Santos (assalto)</segment>
    <segment id="47">, Edmar Menezes de Carvalho (furto)</segment>
    <segment id="48">, Paulo de Jesus Santos (assalto) conseguiram deixar a unidade por um buraco de aproximadamente  40 x 20 centímetros.</segment>
  </rst>
</analysis>