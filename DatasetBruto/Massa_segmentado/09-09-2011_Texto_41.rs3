  <rst>
    <segment id="1">Incêndio em Escada</segment>
    <segment id="2">Mais da metade das 367 moradias de madeira foram destruídas</segment>
    <segment id="3">Um cenário de horror tomou conta da invasão Quilombo de Escada</segment>
    <segment id="4">, no bairro de Escada</segment>
    <segment id="5">, no subúrbio ferroviário</segment>
    <segment id="6">, na noite de ontem</segment>
    <segment id="7">, quando um incêndio de grandes proporções</segment>
    <segment id="8">sese alastrou pelo local</segment>
    <segment id="9">, por volta de 21 horas.</segment>
    <segment id="10">Segundo a líder comunitária Mira Alves</segment>
    <segment id="11">, 52 anos</segment>
    <segment id="12">, pelo menos 367 famílias</segment>
    <segment id="13">, todas vivendo em barracos de madeira</segment>
    <segment id="14">, moram na comunidade.</segment>
    <segment id="15">Às 22h</segment>
    <segment id="16">, um terço das moradias já havia sido consumida pelo fogo.</segment>
    <segment id="17">Responsável pela operação</segment>
    <segment id="18">, o  tenente Guedes</segment>
    <segment id="19">, do Corpo de Bombeiros do 10º GBM de Simões Filho</segment>
    <segment id="20">, afirmou que o difícil acesso ao local dificultou o trabalho das equipes.</segment>
    <segment id="21">Moradores corriam para retirar seus pertences de dentro dos barracos</segment>
    <segment id="22">, masmas as chamas avançavam rapidamente.</segment>
    <segment id="23">Algumas pessoas que vivem na invasão disseram acreditar que uma panela esquecida no fogo teria causado o incêndio.</segment>
    <segment id="24">Até o fechamento desta edição</segment>
    <segment id="25">, não havia informações sobre mortos ou feridos.</segment>
    <segment id="26">A comerciante Ângela Maria dos Santos</segment>
    <segment id="27">, 31, foi uma das vítima da tragédia.</segment>
    <segment id="28">Ela estava descalça</segment>
    <segment id="29">, só com a roupa do corpo.</segment>
    <segment id="30">“Só deu tempo de salvar minhas duas crianças”</segment>
    <segment id="31">, disse.</segment>
  </rst>
</analysis>