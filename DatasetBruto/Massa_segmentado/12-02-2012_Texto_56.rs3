  <rst>
    <segment id="1">Blacktum: sangue novo na música</segment>
    <segment id="2">Para definir o estilo próprio</segment>
    <segment id="3">, a banda</segment>
    <segment id="4">sese inspirou no axé da banda Eva
Formada em 2010</segment>
    <segment id="5">, a Blacktum surgiu no cenário musical baiano para bombar em ritmo de axé.</segment>
    <segment id="6">E bombou mesmo.</segment>
    <segment id="7">Logo no primeiro ano de estrada lançou o CD</segment>
    <segment id="8">, que coloca entre as faixas aquela que dá nome ao grupo</segment>
    <segment id="9">, composto por oito integrantes.</segment>
    <segment id="10">Agora, no segundo CD</segment>
    <segment id="11">, com 26 faixas</segment>
    <segment id="12">, três delas autorais</segment>
    <segment id="13">, a galera</segment>
    <segment id="14">sese prepara para produzir o DVD da banda até o final deste ano.</segment>
    <segment id="15">No vocal</segment>
    <segment id="16">, Fúlvio Martins</segment>
    <segment id="17">, 26, que apesar da pouca idade já possui experiência de 11 anos de estrada.</segment>
    <segment id="18">“Comecei a cantar na escola.</segment>
    <segment id="19">Formamos um grupo de axé e tocamos em muitas casas de show da cidade.</segment>
    <segment id="20">Também fiz voz e violão em bares”</segment>
    <segment id="21">, conta ele.</segment>
    <segment id="22">Na batalha pela profissionalização</segment>
    <segment id="23">, o rapaz</segment>
    <segment id="24">sese empenha nos estudos para tocar seu violão com maestria.</segment>
    <segment id="25">“</segment>
    <segment id="26">Minha praia sempre foi cantar</segment>
    <segment id="27">, masmas quero me aprofundar mais nas possibilidades da música e tocar um instrumento é importante”</segment>
    <segment id="28">, acredita.</segment>
    <segment id="29">Preocupado em levar um som de qualidade para o público</segment>
    <segment id="30">, o vocalista garante que “Há Muito Tempo” e “Chuva de Desejo”</segment>
    <segment id="31">, do novo álbum da banda</segment>
    <segment id="32">, foram trabalhadas com muito cuidado.</segment>
    <segment id="33">Confira em www.blacktum.com.br.</segment>
  </rst>
</analysis>