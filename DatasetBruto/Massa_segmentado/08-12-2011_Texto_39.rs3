  <rst>
    <segment id="1">Mayer Hawthorne quer voltar ao Rio com a ajuda dos fãs
RIO - Mayer Hawthorne quer voltar ao Rio e</segment>
    <segment id="2">, para isso</segment>
    <segment id="3">, espera contar com a ajuda dos fãs.</segment>
    <segment id="4">Mais uma vez.</segment>
    <segment id="5">Uma das primeiras atrações do projeto de crowdfunding
Queremos</segment>
    <segment id="6">, o cantor americano pode</segment>
    <segment id="7">sese apresentar novamente no Circo Voador</segment>
    <segment id="8">casocaso 240 cariocas</segment>
    <segment id="9">sese empolguem a pagar pelos ingressos reembolsáveis de R$ 200.</segment>
    <segment id="10">A mobilização começa à meia-noite desta sexta-feira e segue até o dia 14.</segment>
    <segment id="11">Se confirmado</segment>
    <segment id="12">, o show acontece no dia 3 de fevereiro</segment>
    <segment id="13">, pouco mais de um ano depois da vinda do músico ao Brasil.

- Mayer Hawthorne foi um dos melhores shows que fizemos</segment>
    <segment id="14">, o público adorou.</segment>
    <segment id="15">Muita gente que não conhecia pediu para ele voltar.</segment>
    <segment id="16">Ele também gostou muito da experiência toda e</segment>
    <segment id="17">, no ano passado mesmo</segment>
    <segment id="18">, disse que gostaria de participar novamente do Queremos.</segment>
    <segment id="19">Como ele acabou de lançar seu segundo disco ("How do you do"</segment>
    <segment id="20">, de outubro)</segment>
    <segment id="21">, tudo</segment>
    <segment id="22">sese encaixou e ele pode vir novamente - explica Bruno Natal</segment>
    <segment id="23">, um dos homens por trás do Queremos</segment>
    <segment id="24">, que já agendou 16 atrações internacionais na cidade</segment>
    <segment id="25">, além de promover um show dos Paralamas do Sucesso tocando o disco "Selvagem?</segment>
    <segment id="26">" na íntegra.</segment>
    <segment id="27">Como sempre acontece no Queremos</segment>
    <segment id="28">, os 240 "acionistas" podem receber reembolso total do valor inicial</segment>
    <segment id="29">casocaso 1.660 pessoas paguem os R$ 60 do ingresso convencional - que não dá direito a reembolso e só começa a ser vendido após a confirmação do show.</segment>
    <segment id="30">Se houver patrocínio</segment>
    <segment id="31">, o número de ingressos necessários para possibilitar o reembolso diminui.</segment>
    <segment id="32">Caso o show não seja confirmado</segment>
    <segment id="33">, todos os que compraram os ingressos reembolsáveis recebem o valor de volta</segment>
    <segment id="34">, integralmente.</segment>
  </rst>
</analysis>