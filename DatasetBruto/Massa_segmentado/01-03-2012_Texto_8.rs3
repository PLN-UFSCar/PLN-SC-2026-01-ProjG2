  <rst>
    <segment id="1">Dois hospitais pedem socorro</segment>
    <segment id="2">Aristides Maltez corre o risco de fechar e Martagão Gesteira está todo endividado</segment>
    <segment id="3">Os hospitais Aristides Maltez e Martagão Gesteira</segment>
    <segment id="4">, que são referência no atendimento gratuito a pacientes de todas as cidades baianas</segment>
    <segment id="5">, passam por dificuldades.</segment>
    <segment id="6">O presidente da Liga Bahiana</segment>
    <segment id="7">Contra o Câncer</segment>
    <segment id="8">, o médico Aristides Maltez Filho</segment>
    <segment id="9">, alerta que</segment>
    <segment id="10">, sese a Secretaria Municipal de Saúde não pagar</segment>
    <segment id="11">, o hospital corre o risco de fechar em 25 dias.</segment>
    <segment id="12">Ele afirma que o atendimento continua normal</segment>
    <segment id="13">, masmas já há dificuldade para sanar dívidas com fornecedores e pagar a folha salarial.</segment>
    <segment id="14">Por meio de nota</segment>
    <segment id="15">, a SMS afirma que vem honrando o pagamento dos valores pactuados</segment>
    <segment id="16">, ressaltando que “o que o HAM alega estar em aberto refere-</segment>
    <segment id="17">sese à produção extrateto</segment>
    <segment id="18">, ou seja</segment>
    <segment id="19">, ao que foi produzido acima do previsto no convênio</segment>
    <segment id="20">, inclusive com serviços prestados a outras cidades do Estado”.</segment>
    <segment id="21">Maltez Filho acusa o secretário Gilberto José de “tergiversar”.</segment>
    <segment id="22">“</segment>
    <segment id="23">Parece que estão falando de matemática.</segment>
    <segment id="24">O extrateto significa pessoas</segment>
    <segment id="25">, não são espantalhos</segment>
    <segment id="26">, não são ETs</segment>
    <segment id="27">, são pessoas que chegam com câncer</segment>
    <segment id="28">, às quais não negamos o atendimento”</segment>
    <segment id="29">, explica.</segment>
    <segment id="30">Campanha nas redes sociais</segment>
    <segment id="31">Ontem, nas redes sociais</segment>
    <segment id="32">, campanhas foram lançadas para salvar o Aristides Maltez.</segment>
    <segment id="33">A cantora Cláudia Leitte</segment>
    <segment id="34">, por exemplo</segment>
    <segment id="35">, pediu aos quatro milhões de seguidores no Twitter que cada um doe R$ 1.  "</segment>
    <segment id="36">Oi muchachos</segment>
    <segment id="37">, estou de férias</segment>
    <segment id="38">, com saudades e feliz!</segment>
    <segment id="39">Mas, hoje</segment>
    <segment id="40">, algo me tirou a paz...</segment>
    <segment id="41">Preciso da ajuda de vocês"</segment>
    <segment id="42">, postou.</segment>
    <segment id="43">Depósitos podem ser feitos no Banco do Brasil</segment>
    <segment id="44">, agência 3025-2</segment>
    <segment id="45">, conta 157.364-0.</segment>
    <segment id="46">A SMS informou que pleiteia junto à União a recomposição do teto de média e alta complexidades</segment>
    <segment id="47">, beneficiando não somente o HAM</segment>
    <segment id="48">, masmas também Martagão e outros.</segment>
    <segment id="49">Hoje o déficit seria de R$ 4 milhões por mês.</segment>
    <segment id="50">Refinanciamento</segment>
    <segment id="51">O Hospital Martagão Gesteira tem cerca de R$ 400 mil a receber da SMS por procedimentos acima do teto contratado</segment>
    <segment id="52">, além de outra dívida de R$ 18 milhões que busca refinanciar junto à Caixa Econômica em 36 meses.</segment>
    <segment id="53">O débito total</segment>
    <segment id="54">, adquirido em 2009</segment>
    <segment id="55">, era de R$ 26 milhões</segment>
    <segment id="56">, com fornecedores e ações trabalhistas</segment>
    <segment id="57">, dentre outras.</segment>
    <segment id="58">De 120 processos</segment>
    <segment id="59">, o Martagão ainda responde a seis.</segment>
  </rst>
</analysis>