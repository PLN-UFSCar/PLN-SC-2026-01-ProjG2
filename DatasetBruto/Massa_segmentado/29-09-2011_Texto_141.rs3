  <rst>
    <segment id="1">Botafogo joga mal e só empata com Santa Fé-COL pela Sul-Americana
Botafogo 1</segment>
    <segment id="2">X 1 Independiente Santa Fé-COL
RIO - Em partida onde entrou com apenas dois titulares</segment>
    <segment id="3">e não mostrou nenhum traço da equipe que faz boa campanha no Brasileiro</segment>
    <segment id="4">, o Botafogo arrancou empate depois de sair perdendo para o Independiente Santa Fé</segment>
    <segment id="5">, da Colômbia</segment>
    <segment id="6">, na noite desta quinta-feira</segment>
    <segment id="7">, no Engenhão</segment>
    <segment id="8">, pelas oitavas de finais da Copa Sul-Americana.</segment>
    <segment id="9">A partida de volta será disputada em 25 de outubro</segment>
    <segment id="10">, em Bogotá.</segment>
    <segment id="11">O alvinegro precisa de um vitória simples para</segment>
    <segment id="12">sese classificar.</segment>
    <segment id="13">Outro empate em 1 a 1 leva o confronto para os pênaltis.</segment>
    <segment id="14">Um empate sem gols classifica o Santa Fé.</segment>
    <segment id="15">BLOG: 'É Por Ti</segment>
    <segment id="16">, Fogo'</segment>
    <segment id="17">, o blog do torcedor do Botafogo</segment>
    <segment id="18">Em um primeiro tempo muito ruim do time de Caio Júnior</segment>
    <segment id="19">, a equipe mostrou diversas fragilidades</segment>
    <segment id="20">, principalmente pelo lado esquerdo</segment>
    <segment id="21">, onde Márcio Azevedo não conseguiu acertar jogadas na defesa ou no ataque.</segment>
    <segment id="22">Vaiado pela torcida</segment>
    <segment id="23">, ele parecia nervoso e inseguro em campo.</segment>
    <segment id="24">E foi pelo seu lado que saiu o gol do Santa Fé</segment>
    <segment id="25">, logo aos oito minutos de jogos.</segment>
    <segment id="26">Após grande arrancada</segment>
    <segment id="27">, Bernal invadiu a área pela direita e cruzou para Pérez</segment>
    <segment id="28">, livre na área</segment>
    <segment id="29">, marcar.</segment>
    <segment id="30">O Botafogo só levou perigo uma vez ao gol do Santa Fé.</segment>
    <segment id="31">Aos 20</segment>
    <segment id="32">, Gustavo tentou de cabeça após cruzamento pela direita.</segment>
    <segment id="33">O goleiro defendeu.</segment>
    <segment id="34">Em outra jogada parecida</segment>
    <segment id="35">, Gustavo ajeitou para Alex</segment>
    <segment id="36">, que tinha Loco ao seu lado</segment>
    <segment id="37">, masmas preferiu chutar.</segment>
    <segment id="38">A bola subiu.</segment>
    <segment id="39">No último minuto do primeiro tempo</segment>
    <segment id="40">, o time colombiano quase marca outro gol.</segment>
    <segment id="41">Antônio Carlos foi driblado por Copete</segment>
    <segment id="42">, que cruzou.</segment>
    <segment id="43">Lucas Zen cortou mal e a bola sobrou para Pérez</segment>
    <segment id="44">, que, sozinho</segment>
    <segment id="45">, chutou por cima do gol.</segment>
    <segment id="46">No segundo tempo</segment>
    <segment id="47">, Caio Júnior voltou com Elkeson - que não entrou na partida da seleção brasileira contra a Argentina na quarta - no lugar de Márcio Azevedo.</segment>
    <segment id="48">A substituição melhorou o rendimento da equipe</segment>
    <segment id="49">, masmas</segment>
    <segment id="50">, apesar da pressão</segment>
    <segment id="51">, pouco conseguia assustar.</segment>
    <segment id="52">Com a defesa alvinegra aberta</segment>
    <segment id="53">, o Santa Fé levava perigo nos contra-ataques.</segment>
    <segment id="54">Aos 12</segment>
    <segment id="55">, Elkeson tentou de cabeça após cruzamento e Vargas fez grande defesa.</segment>
    <segment id="56">O gol de empate veio aos 21.</segment>
    <segment id="57">Elkeson fez ótimo passe para Caio</segment>
    <segment id="58">, que entrara quatro minutos antes no lugar de Felipe Menezes - que também deixou o campo sob vaias.</segment>
    <segment id="59">Ele chutou de primeira por cima do goleiro e marcou.</segment>
    <segment id="60">O Botafogo continuou pressionando</segment>
    <segment id="61">, masmas não conseguiu virar o placar no Engenhão.</segment>
    <segment id="62">Botafogo 1</segment>
    <segment id="63">X 1 Independiente Santa Fé-COL

Árbitro: Enrique Osses (CHI)

Renda e público: R$ 26.950</segment>
    <segment id="64">,00 / 1.890 pagantes</segment>
    <segment id="65">Botafogo: Renan</segment>
    <segment id="66">; Alessandro</segment>
    <segment id="67">, Antônio Carlos</segment>
    <segment id="68">, Gustavo e Marcio Azevedo (Elkeson)</segment>
    <segment id="69">; Lucas Zen</segment>
    <segment id="70">, Somália</segment>
    <segment id="71">, Everton e Felipe Menezes (Caio)</segment>
    <segment id="72">;</segment>
    <segment id="73">Alex (Thiago Galhardo) e Loco Abreu.</segment>
    <segment id="74">Técnico: Caio Junior.

Independiente Santa Fé-COL: Vargas</segment>
    <segment id="75">; Bernal (Quintero)</segment>
    <segment id="76">, Centurión</segment>
    <segment id="77">, Meza e Acosta</segment>
    <segment id="78">; Roa, Anchico (Rodas)</segment>
    <segment id="79">, Bedoya e Copete</segment>
    <segment id="80">; Pérez e Galván (Vélez).</segment>
    <segment id="81">Técnico: Wilson Gutiérrez.</segment>
  </rst>
