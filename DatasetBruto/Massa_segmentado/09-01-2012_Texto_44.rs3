  <rst>
    <segment id="1">Em desfile intimista</segment>
    <segment id="2">, Patricia Vieira mostra seu inverno luxuoso
RIO - De cinzento</segment>
    <segment id="3">, só o tempo que encobria parte da bela vista para a Praia de Ipanema.</segment>
    <segment id="4">O que a estilista Patricia Vieira trouxe para a abertura da temporada de desfiles é um inverno de muita cor e brilho.</segment>
    <segment id="5">E luxo.</segment>
    <segment id="6">A começar pelo local do desfile: uma cobertura de mais de dois mil metros quadrados na Vieira Souto.</segment>
    <segment id="7">Enquanto aguardavam a apresentação</segment>
    <segment id="8">, os convidados</segment>
    <segment id="9">sese deliciavam com champanhe</segment>
    <segment id="10">, bem-casados e bombons.</segment>
    <segment id="11">Um clima perfeito para uma coleção inspirada na riqueza e nos exageros de Los Angeles.</segment>
    <segment id="12">Modelos magérrimas</segment>
    <segment id="13">, como</segment>
    <segment id="14">como Viviane Orth</segment>
    <segment id="15">, Lais Ribeiro</segment>
    <segment id="16">, Fabiana Capra e Talytha Pugliesi mostraram peças de silhueta bem marcada</segment>
    <segment id="17">, com costas nuas</segment>
    <segment id="18">, fendas</segment>
    <segment id="19">, decotes e cintura alta.</segment>
    <segment id="20">Tudo em tons de verde garrafa</segment>
    <segment id="21">, berinjela</segment>
    <segment id="22">, rosa</segment>
    <segment id="23">, azul cobalto</segment>
    <segment id="24">, prata e dourado</segment>
    <segment id="25">, muito dourado.</segment>
    <segment id="26">O preto estava presente</segment>
    <segment id="27">, masmas sempre acompanhado de pedrarias.</segment>
    <segment id="28">Além dos bordados</segment>
    <segment id="29">, o couro</segment>
    <segment id="30">, com textura de vinil</segment>
    <segment id="31">, apareceu com aplicações: tudo feito à mão em parceria com a grife mineira Vivaz.

- O couro já está num patamar</segment>
    <segment id="32">comocomo o do jeans.</segment>
    <segment id="33">Ele está presente há umas quatro estações.</segment>
    <segment id="34">É um material de primeira</segment>
    <segment id="35">, masmas difícil de trabalhar.</segment>
    <segment id="36">Usamos uma tecnologia nova e buscamos passar uma sensação de tecido - explica Patricia.</segment>
    <segment id="37">A calça</segment>
    <segment id="38">, segundo a estilista</segment>
    <segment id="39">, vai ser o hit da estação:

- A era do short com blusa de manga já passou.</segment>
    <segment id="40">Foi uma calça</segment>
    <segment id="41">, aliás</segment>
    <segment id="42">, e dourada</segment>
    <segment id="43">, que despertou paixões nas convidadas.</segment>
    <segment id="44">A empresária Flávia Sampaio</segment>
    <segment id="45">, a amada de Eike Batista</segment>
    <segment id="46">, sese encantou pela peça e já reservou a sua:

-</segment>
    <segment id="47">O desfile foi deslumbrante</segment>
    <segment id="48">, de tirar o fôlego.</segment>
    <segment id="49">A calça dourada é maravilhosa e vai fazer parte do meu guarda-roupa.</segment>
    <segment id="50">Sou uma mulher de cores</segment>
    <segment id="51">, e adorei as cores que a Patricia trabalhou.</segment>
    <segment id="52">Quem também amou a calça dourada foi a ex-modelo e irmã da estilista</segment>
    <segment id="53">, Andrea Dellal</segment>
    <segment id="54">, que veio passar o Ano Novo no Rio junto com a família:

- Natal é bom passar no frio.</segment>
    <segment id="55">Mas, Ano Novo é aqui - afirmou ela</segment>
    <segment id="56">, acompanhada da filha Charlotte Dellal.</segment>
    <segment id="57">Felipe Veloso</segment>
    <segment id="58">, que assina o styling do desfile</segment>
    <segment id="59">, garante que não há regras para usar a calça dourada e que tudo é uma questão de estado de espírito:

- Uma menina mais cool coloca com uma blusa velha.</segment>
    <segment id="60">Já quem quer fazer a linha mais chique</segment>
    <segment id="61">, joga um paletó.</segment>
    <segment id="62">É simples - diz ele</segment>
    <segment id="63">, que amou as rendas metálicas da abertura.</segment>
    <segment id="64">A apresentadora Regina Casé saiu de lá com uns cinco modelos encomendados para o figurino do seu programa "Esquenta":

- As pessoas acham que eu me visto daquele jeito.</segment>
    <segment id="65">Aquilo é figurino</segment>
    <segment id="66">, igual aqui</segment>
    <segment id="67">, onde tudo é teatral.</segment>
    <segment id="68">Mas, o desfile foi incrível: todo mundo me parou para dizer que os looks estão a cara do programa.</segment>
    <segment id="69">Se depender das roupas que Patricia apresentou no Senac Rio Fashion Business</segment>
    <segment id="70">, o inverno vai ser mesmo</segment>
    <segment id="71">, uma estação quente e sensual.</segment>
    <segment id="72">A cara de Los Angeles</segment>
    <segment id="73">, e de Ipanema.</segment>
  </rst>
</analysis>