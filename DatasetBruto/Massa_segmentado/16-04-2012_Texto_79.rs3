  <rst>
    <segment id="1">Vovô do tráfico atrás das grades
Senhor é acusado e preso dentro de casa com cocaína e maconha</segment>
    <segment id="2">Após denúncia anônima</segment>
    <segment id="3">, policiais militares da 58ª CIPM (Cosme de Farias) prenderam Antônio Carlos Vieira</segment>
    <segment id="4">, de 58 anos</segment>
    <segment id="5">, conhecido</segment>
    <segment id="6">comocomo Cachaça</segment>
    <segment id="7">, acusado de ser traficante de drogas.</segment>
    <segment id="8">Cachaça foi preso dentro da própria casa</segment>
    <segment id="9">, na Travessa Salustiano</segment>
    <segment id="10">, no bairro Cosme de Farias</segment>
    <segment id="11">,  por volta das 13h de ontem.</segment>
    <segment id="12">O imóvel fica atrás do Colégio Estadual João Pedro dos Santos.</segment>
    <segment id="13">Com o suspeito</segment>
    <segment id="14">, os PMs apreenderam cerca de 20 gramas de cocaína</segment>
    <segment id="15">, 50g de maconha</segment>
    <segment id="16">, vários sacos para embalar a droga e restos de munição calibre 38 deflagradas.</segment>
    <segment id="17">Foi encontrado ainda um pó usado para a mistura de cocaína.</segment>
    <segment id="18">De acordo com os policiais da 58ª CIPM</segment>
    <segment id="19">, Cachaça é um dos braços da quadrilha liderada pelo bandido conhecido</segment>
    <segment id="20">comocomo Tripa</segment>
    <segment id="21">, considerado o chefão do tráfico na Travessa Salustiano.</segment>
    <segment id="22">“Eu não sou traficante.</segment>
    <segment id="23">As drogas estavam no mesmo beco onde eu moro.</segment>
    <segment id="24">Um bocado de malandro fica na frente da minha porta</segment>
    <segment id="25">, bagunçando</segment>
    <segment id="26">, e não posso fazer nada.</segment>
    <segment id="27">As drogas são desses marginais”</segment>
    <segment id="28">, defende-</segment>
    <segment id="29">sese Cachaça.</segment>
    <segment id="30">Ele mora sozinho</segment>
    <segment id="31">, está solteiro</segment>
    <segment id="32">, tem uma filha de 30 anos e três netos.</segment>
    <segment id="33">A PM afirma que Antônio</segment>
    <segment id="34">, além de traficar</segment>
    <segment id="35">, usa a casa onde mora para facilitar a fuga dos aliados</segment>
    <segment id="36">, que escapam dos policiais  pelos fundos do terreno.</segment>
    <segment id="37">Origem do apelido</segment>
    <segment id="38">Antônio Carlos admite que é usuário de maconha.</segment>
    <segment id="39">Ele afirma que trabalha</segment>
    <segment id="40">comocomo guardador de carros na Rua Portugal</segment>
    <segment id="41">, no bairro Comércio.</segment>
    <segment id="42">Ele explica a origem do apelido Cachaça.</segment>
    <segment id="43">“</segment>
    <segment id="44">Meus amigos antigos do baba achavam que eu tinha cara de beberrão”.</segment>
    <segment id="45">Antônio Carlos já tinha ficha na polícia por agressão</segment>
    <segment id="46">, em maio de 2006.</segment>
    <segment id="47">Em 1974</segment>
    <segment id="48">, ele também foi detido na Delegacia de Furtos e Roubos.</segment>
    <segment id="49">“</segment>
    <segment id="50">Se eu fosse traficante iria morar num quatro e sala de alvenaria?</segment>
    <segment id="51">”, tenta</segment>
    <segment id="52">sese defender.</segment>
  </rst>
</analysis>