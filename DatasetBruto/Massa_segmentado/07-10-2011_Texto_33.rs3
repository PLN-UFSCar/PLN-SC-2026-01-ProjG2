  <rst>
    <segment id="1">Zói renega a chefona</segment>
    <segment id="2">Nem Gorda</segment>
    <segment id="3">Edvanilson Silva dos Santos</segment>
    <segment id="4">, 21 anos</segment>
    <segment id="5">, afirmou que não é traficante
Durante apresentação à imprensa</segment>
    <segment id="6">, ontem</segment>
    <segment id="7">, na 5ª DT (Periperi)</segment>
    <segment id="8">, Edvanilson Silva dos Santos</segment>
    <segment id="9">, 21 anos</segment>
    <segment id="10">, o Zói</segment>
    <segment id="11">, simplesmente afirmou que não é traficante e que não conhece Maria Lúcia dos Santos Gomes</segment>
    <segment id="12">, 36 anos</segment>
    <segment id="13">, a Nem Gorda</segment>
    <segment id="14">, acusada de liderar o tráfico no Rio Sena.

Zói</segment>
    <segment id="15">, que é  morador da localidade do Inferninho</segment>
    <segment id="16">, no bairro Mata Escura</segment>
    <segment id="17">, disse que conheceu apenas o marido de Nem Gorda</segment>
    <segment id="18">, Alex Brito das Neves</segment>
    <segment id="19">, o Grilinho</segment>
    <segment id="20">, quando estavam presos no Complexo Penitenciário  da Mata Escura.</segment>
    <segment id="21">“Grilinho mandou eu ir para o Subúrbio para vender drogas.</segment>
    <segment id="22">Vim para ver minha mulher que mora aqui.</segment>
    <segment id="23">Não vendo</segment>
    <segment id="24">, só uso  maconha”.</segment>
    <segment id="25">A mulher dele é uma jovem de 16 anos conhecida</segment>
    <segment id="26">comocomo Dredock</segment>
    <segment id="27">, que, segundo denúncias</segment>
    <segment id="28">, integraria o Bonde da Nem.</segment>
    <segment id="29">Delegado diz:</segment>
    <segment id="30">Nem não foi substituída</segment>
    <segment id="31">Para o delegado titular de Periperi</segment>
    <segment id="32">, Antônio Carlos Magalhães Santos</segment>
    <segment id="33">, não há ninguém no posto de líder antes ocupado por Nem Gorda.</segment>
    <segment id="34">Segundo o delegado</segment>
    <segment id="35">, o que incrimina Zói é o fato de ele ter sido preso na Associação de Moradores  do Alto do Tanque</segment>
    <segment id="36">, comandada por Nem.</segment>
    <segment id="37">Além disso</segment>
    <segment id="38">, com ele</segment>
    <segment id="39">, foram encontradas drogas</segment>
    <segment id="40">, fotografias de Nem Gorda e família e documentos de veículos no nome da chefona e do marido Grilinho.</segment>
    <segment id="41">Zói nega.</segment>
  </rst>
