  <rst>
    <segment id="1">Prefeitura de Vassouras gasta mais de R$ 600 mil em galpão que está sem uso

RIO e VASSOURAS (RJ) - Um galpão erguido no distrito de Massambará</segment>
    <segment id="2">, em Vassouras</segment>
    <segment id="3">, interior do Rio</segment>
    <segment id="4">, foi erguido ao custo de R$ 606 mil oriundos dos cofres do município para ser usado no beneficiamento de tomates</segment>
    <segment id="5">, masmas está parado.</segment>
    <segment id="6">A prefeitura diz que o projeto</segment>
    <segment id="7">, iniciado na gestão anterior</segment>
    <segment id="8">, não era "viável".
PARTICIPE:
FACEBOOK:</segment>
    <segment id="9">Acompanhe o GLOBO na rede social</segment>
    <segment id="10">Viu alguma obra pública sem uso?</segment>
    <segment id="11">Envie seu relato</segment>
    <segment id="12">, fotos e vídeos 
"</segment>
    <segment id="13">Desperdício de dinheiro público em Massambará</segment>
    <segment id="14">, distrito de Vassouras</segment>
    <segment id="15">, RJ.</segment>
    <segment id="16">Uma galpão para beneficiar tomates custou R$ 606.667</segment>
    <segment id="17">,00 e encontra-</segment>
    <segment id="18">sese totalmente abandonado"</segment>
    <segment id="19">, protesta o leitor Roberto Porto em seu relato ao Eu-Repórter.</segment>
    <segment id="20">Em nota</segment>
    <segment id="21">, o secretário de Obras e Serviços Públicos de Vassouras</segment>
    <segment id="22">, Radouviler Teixeira Coelho</segment>
    <segment id="23">, informou que o galpão não está em funcionamento</segment>
    <segment id="24">porque</segment>
    <segment id="25">porque o projeto de beneficiamento de tomate "não era viável para o município".</segment>
    <segment id="26">Ainda de acordo com Coelho</segment>
    <segment id="27">, a cidade estuda propostas de empresas interessadas na utilização do espaço.</segment>
    <segment id="28">No entanto</segment>
    <segment id="29">, até a noite de quinta-feira (26)</segment>
    <segment id="30">, nem a secretaria</segment>
    <segment id="31">, nem a assessoria de imprensa da Prefeitura de Vassouras</segment>
    <segment id="32">sese manifestaram sobre uma possível data para o início do uso do galpão.</segment>
  </rst>
