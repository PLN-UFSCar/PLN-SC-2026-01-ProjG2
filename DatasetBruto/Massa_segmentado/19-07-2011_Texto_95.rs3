  <rst>
    <segment id="1">Pagode chora morte de Kelly
Artistas falam sobre o assassinato no Twitter e dizem que estão de luto pela morte
Muito conhecida no mundo do pagode</segment>
    <segment id="2">, a morte de Kelly foi lamentada ontem pelos artistas.</segment>
    <segment id="3">“Ficamos muito tristes.</segment>
    <segment id="4">Ela era muito querida na banda.</segment>
    <segment id="5">Apesar do pouco tempo</segment>
    <segment id="6">, ela nos ajudou muito nesse início de carreira</segment>
    <segment id="7">, pois</segment>
    <segment id="8">pois todos queriam ver Kelly Cyclone”</segment>
    <segment id="9">,   lamenta o vocalista Diego Souza</segment>
    <segment id="10">, da banda Beat da Onda</segment>
    <segment id="11">, em que Kelly dançava há um mês.</segment>
    <segment id="12">No Twitter</segment>
    <segment id="13">, artistas</segment>
    <segment id="14">comocomo Tierry  Fantasmão e Mário Brasil postaram mensagens de indignação.</segment>
    <segment id="15">A vereadora e dançarina da banda Kapa Fixa Léo Kret ficou triste com a morte da jovem.</segment>
    <segment id="16">“</segment>
    <segment id="17">Fico muito triste com o que aconteceu</segment>
    <segment id="18">,</segment>
    <segment id="19">poispois sabia que ela era uma boa pessoa</segment>
    <segment id="20">, que estava determinada a mudar de vida e mudar a visão que as pessoas tinham dela</segment>
    <segment id="21">comocomo uma marginal.</segment>
    <segment id="22">Ela queria mostrar o que a periferia tinha de bom”.</segment>
    <segment id="23">Já Carla Minhoca</segment>
    <segment id="24">, dançarina do Fantasmão</segment>
    <segment id="25">, encontrou com Kelly no Salvador Fest.</segment>
    <segment id="26">“Ela sempre frequentou os shows do Fantasmão e era uma pessoa ótima</segment>
    <segment id="27">, engraçada.</segment>
    <segment id="28">Eu a vi no Salvador Fest</segment>
    <segment id="29">, no domingo</segment>
    <segment id="30">, muito rapidamente</segment>
    <segment id="31">, pois</segment>
    <segment id="32">pois ela estava com pressa de ir para o palco Pagodaço”.</segment>
    <segment id="33">Igor Kanário</segment>
    <segment id="34">, da Bronkka</segment>
    <segment id="35">, disse no Twitter que ficou muito sentido com a morte de Kelly.</segment>
    <segment id="36">“</segment>
    <segment id="37">A família</segment>
    <segment id="38">A Bronkka está de luto!</segment>
    <segment id="39">Independentemente de quaisquer padrões</segment>
    <segment id="40">, respeitamos muito todos os nossos fãs.</segment>
    <segment id="41">Kelly sempre presente".</segment>
  </rst>
</analysis>