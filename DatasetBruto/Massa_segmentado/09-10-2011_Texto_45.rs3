  <rst>
    <segment id="1">Carnaval 2012:</segment>
    <segment id="2">começa a escolha dos sambas
RIO - Desde o fim de semana</segment>
    <segment id="3">, os foliões mais afoitos</segment>
    <segment id="4">, que ficam contando os dias para a chegada da festa de Momo</segment>
    <segment id="5">, começaram a ter uma prévia do carnaval 2012.</segment>
    <segment id="6">Mangueira e Renascer de Jacarepaguá saíam na frente e</segment>
    <segment id="7">, no último sábado</segment>
    <segment id="8">, realizaram a disputa final de seus sambas-enredo.</segment>
    <segment id="9">A verde e rosa</segment>
    <segment id="10">, que contará a história do Cacique de Ramos na Avenida</segment>
    <segment id="11">, escolheu a parceria de Igor Leal</segment>
    <segment id="12">, Lequinho</segment>
    <segment id="13">, Junior Fionda e Paulinho Carvalho numa noite em que famosos</segment>
    <segment id="14">comocomo a cantora Alcione e o estilista Jean Paul Gaultier prestigiaram a quadra.</segment>
    <segment id="15">Na Renascer</segment>
    <segment id="16">, o pintor Romero Britto</segment>
    <segment id="17">, homenageado da escola</segment>
    <segment id="18">, festejou o aniversário de 48 anos assistindo à escolha da obra de Cláudio Russo</segment>
    <segment id="19">, Adriano Cesário</segment>
    <segment id="20">, Fábio Costa e Isaac.</segment>
    <segment id="21">A maioria das 13 escolas do Grupo Especial vai escolher os sambas-enredo esta semana.</segment>
    <segment id="22">O Salgueiro deve ser o próximo: a eleição do samba acontece amanhã.</segment>
    <segment id="23">Na sexta-feira</segment>
    <segment id="24">, dia 14</segment>
    <segment id="25">, é a vez de Portela</segment>
    <segment id="26">, Porto da Pedra</segment>
    <segment id="27">, e São Clemente elegerem os compositores campeões.</segment>
    <segment id="28">E no sábado</segment>
    <segment id="29">, Vila Isabel</segment>
    <segment id="30">, Unidos da Tijuca e Grande Rio já deverão ter suas músicas escolhidas.</segment>
    <segment id="31">Algumas escolas preferiram deixar a decisão para a última hora.</segment>
    <segment id="32">O prazo máximo estabelecido pela Liga Independente das Escolas de Samba (Liesa) é 17 deste mês</segment>
    <segment id="33">, na próxima segunda-feira.</segment>
    <segment id="34">Duas escolas deixaram para eleger o samba na véspera.</segment>
    <segment id="35">Mocidade Independente de Padre Miguel e União da Ilha estão entre as que preferiram manter o suspense até domingo</segment>
    <segment id="36">, véspera da data limite.</segment>
    <segment id="37">Já a Imperatriz Leopoldinense e a Beija-Flor de Nilópolis vão tomar a decisão no próprio dia 17.</segment>
    <segment id="38">Segundo Jorge Castanheira</segment>
    <segment id="39">, presidente da Liesa</segment>
    <segment id="40">, o esquema será o mesmo adotado no ano passado.</segment>
    <segment id="41">O CD será gravado ao vivo e as escolas deverão levar coros formados por moradores da comunidade</segment>
    <segment id="42">, vestidos com as cores de suas agremiações.</segment>
    <segment id="43">O coro vai para a gravação</segment>
    <segment id="44">, as imagens ainda serão um teste para o próximo ano.</segment>
  </rst>
</analysis>