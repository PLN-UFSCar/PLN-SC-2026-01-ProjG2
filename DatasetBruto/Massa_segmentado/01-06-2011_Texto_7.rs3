  <rst>
    <segment id="1">Vasco vence e leva vantagem para decidir a Copa do Brasil em Curitiba</segment>
    <segment id="2">Com destaque para Diego Souza</segment>
    <segment id="3">, o Vasco jogou bem e dominou quase todo a partida</segment>
    <segment id="4">, apesar de sentir falta de Éder Luís</segment>
    <segment id="5">, por não ter outro jogador que jogasse aberto pelas pontas.</segment>
    <segment id="6">O time de Ricardo Gomes já acumula uma sequência de 20 jogos sem derrota e o técnico contabiliza apenas uma derrota em 23 partidas no comando da equipe.</segment>
    <segment id="7">TEMPO REAL:
Confira o jogo lance a lance
FOTOGALERIA:
Confira as imagens da partida
PARA REPETIR</segment>
    <segment id="8">O PASSADO:
Marcelinho Carioca</segment>
    <segment id="9">, símbolo do título de 2003
Antes da partida</segment>
    <segment id="10">, os torcedores enfrentaram alguns problemas para entrar no estádio.</segment>
    <segment id="11">Alguns conseguiram entrar no estádio sem apresentar os ingressos</segment>
    <segment id="12">, enquanto outros formavam longas filas no portão 5</segment>
    <segment id="13">, onde apenas três roletas estavam funcionando.</segment>
    <segment id="14">O jogo começou corrido</segment>
    <segment id="15">, com os dois times pressionando e chegando na área adversária.</segment>
    <segment id="16">Aos 12 minutos</segment>
    <segment id="17">, após cobrança de falta de Felipe</segment>
    <segment id="18">, Dedé chutou forte</segment>
    <segment id="19">, masmas a bola explodiu em Leo Gago.</segment>
    <segment id="20">Alguns minutos depois.</segment>
    <segment id="21">Bill dominou na entrada da área</segment>
    <segment id="22">, girou e chutou forte</segment>
    <segment id="23">, masmas Fernando Prass defendeu.</segment>
    <segment id="24">A partir de então o Vasco passou a dominar a partida e pressionar mais</segment>
    <segment id="25">, mantendo a bola no campo do adversário.</segment>
    <segment id="26">O Coritba tentava o contra-ataque</segment>
    <segment id="27">, masmas não conseguia finalizar.</segment>
    <segment id="28">Aos 20 minutos</segment>
    <segment id="29">, Felipe tocou para Diego Souza na entrada da área</segment>
    <segment id="30">, o meia driblou a zaga e arriscou no cantinho</segment>
    <segment id="31">, masmas Edson Bastos defendeu.</segment>
    <segment id="32">No fim da primeira etapa</segment>
    <segment id="33">, o Coritiba teve a sua melhor chance.</segment>
    <segment id="34">Após pelo drible de Anderson Aquino em Eduardo Costa</segment>
    <segment id="35">, a bola sobrou para Rafinha lançar Jonas pela direita.</segment>
    <segment id="36">O lateral cruzou na área para Bill</segment>
    <segment id="37">, que por pouco não chegou a tempo de marcar.</segment>
    <segment id="38">Logo no início do segundo tempo</segment>
    <segment id="39">, o Vasco abriu o placar.</segment>
    <segment id="40">Bernardo tabelou com Diego Souza</segment>
    <segment id="41">, que tocou para Allan cruzar na medida para Alecsandro marcar de cabeça.</segment>
    <segment id="42">Na comemoração</segment>
    <segment id="43">, uma homenagem ao pai Lela</segment>
    <segment id="44">, ex-jogador e ídolo do Coritba.</segment>
    <segment id="45">Depois do gol</segment>
    <segment id="46">, o time carioca esfriou.</segment>
    <segment id="47">O Coritiba passou a pressionar</segment>
    <segment id="48">, mantendo a posse de bola no campo de ataque e obrigando o Vasco a recuar a marcação.</segment>
    <segment id="49">Apesar do espaço dado pelo adversário</segment>
    <segment id="50">, o Coxa só conseguiu levar perigo ao gol de Fernando Prass em um lance.</segment>
    <segment id="51">Bill aproveitou a sobra de bola na área e chutou forte</segment>
    <segment id="52">, para bela defesa do goleiro vascaíno.</segment>
    <segment id="53">Aos 39 minutos</segment>
    <segment id="54">, Bernardo ainda teve uma chance de ampliar o placar ao bater uma falta colocada por cima do travessão.</segment>
    <segment id="55">O Coritiba ainda pressionou muito no fim do jogo</segment>
    <segment id="56">, mantendo a bola na área vascaína</segment>
    <segment id="57">, masmas sem conseguir marcar.</segment>
    <segment id="58">Coincidentemente</segment>
    <segment id="59">, os dois times voltam a</segment>
    <segment id="60">sese enfrentam no próximo domingo</segment>
    <segment id="61">, às 16h</segment>
    <segment id="62">, no Couto Pereira</segment>
    <segment id="63">, pela terceira rodada do Campeonato Brasileiro.</segment>
  </rst>
</analysis>