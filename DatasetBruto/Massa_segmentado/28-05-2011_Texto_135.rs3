  <rst>
    <segment id="1">Zagueiros viram atacantes e levam Atlético-MG à virada sobre o Avaí na Ressacada

RIO - O Atlético-MG conseguiu um ótimo resultado fora de casa na noite deste sábado.</segment>
    <segment id="2">Diante do Avaí</segment>
    <segment id="3">, na Ressacada</segment>
    <segment id="4">, a equipe mineira venceu por 3 a 1 e chegou aos seis pontos em dois jogos</segment>
    <segment id="5">, já que na estreia tinha superado o Atlético-PR por 3 a 0.</segment>
    <segment id="6">No jogo válido pela segunda rodada</segment>
    <segment id="7">, o destaque foi a dupla de zaga do Galo.</segment>
    <segment id="8">Leonardo Silva</segment>
    <segment id="9">, duas vezes</segment>
    <segment id="10">, e Réver marcaram os gols da virada.</segment>
    <segment id="11">Para o Avaí quem marcou foi Fábio Santos.</segment>
    <segment id="12">A equipe catarinense</segment>
    <segment id="13">, eliminada na semifinal da Copa do Brasil pelo Vasco no meio de semana</segment>
    <segment id="14">, também dentro da Ressacada</segment>
    <segment id="15">, acumula a segunda derrota em dois jogos.</segment>
    <segment id="16">Na primeira rodada o Avaí tinha atuado com os reservas contra o Flamengo</segment>
    <segment id="17">, em Macaé</segment>
    <segment id="18">, e foi goleado por 4 a 0.</segment>
    <segment id="19">O time está na lanterna da Série A do Brasileirão 2011.</segment>
    <segment id="20">O Avaí volta a campo no dia 5</segment>
    <segment id="21">, contra o Santos</segment>
    <segment id="22">, na Vila Belmiro.</segment>
    <segment id="23">O Atlético-MG recebe o São Paulo</segment>
    <segment id="24">, no próximo dia 8</segment>
    <segment id="25">, na Arena do Jacaré.
AVAÍ 1</segment>
    <segment id="26">X 3 ATLÉTICO-MG
Local: Ressacada</segment>
    <segment id="27">, em Florianópolis (SC)
Data/Hora:</segment>
    <segment id="28">28/5/2011 às 18h30 (horário de Brasília)
Árbitro: Marcelo de Lima Henrique (RJ)
Auxiliares: Dibert Pedrosa Moises (RJ) e Bruno Boschilia (PR)
Público e Renda: R$ 40.600</segment>
    <segment id="29">,00 - 4.561 pagantes.</segment>
    <segment id="30">Cartões amarelos: Gustavo Bastos (AVA)</segment>
    <segment id="31">;</segment>
    <segment id="32">Patric e Guilherme (ATL)</segment>
    <segment id="33">Cartões vermelhos:</segment>
    <segment id="34">Não houve.</segment>
    <segment id="35">Gols: Fábio Santos</segment>
    <segment id="36">, aos 7'1T(1-0)</segment>
    <segment id="37">;</segment>
    <segment id="38">Leonardo Silva</segment>
    <segment id="39">, aos 15'1T(1-1)</segment>
    <segment id="40">; Réver</segment>
    <segment id="41">, aos 2'2T(1-2) e Leonardo Silva</segment>
    <segment id="42">, aos 24'2T(1-3).
