  <rst>
    <segment id="1">Colégio na Pavuna terá o nome do jornalista Rodolfo Fernandes e será inaugurado em fevereiro</segment>
    <segment id="2">RIO - A escola estadual em construção na Rua Leonardo Annibal Tonini</segment>
    <segment id="3">, na Pavuna</segment>
    <segment id="4">, renderá uma homenagem ao jornalista Rodolfo Fernandes</segment>
    <segment id="5">, diretor de redação do GLOBO</segment>
    <segment id="6">, que morreu no último dia 27.</segment>
    <segment id="7">Como antecipou ontem a coluna de Ancelmo Gois</segment>
    <segment id="8">, o governador Sérgio Cabral resolveu batizar a nova unidade</segment>
    <segment id="9">, prevista para ser inaugurada em fevereiro de 2012</segment>
    <segment id="10">, como</segment>
    <segment id="11">como Colégio Estadual Rodolfo Fernandes.</segment>
    <segment id="12">Com capacidade para 800 alunos</segment>
    <segment id="13">, a escola</segment>
    <segment id="14">, a princípio</segment>
    <segment id="15">, estará voltada ao ensino médio.</segment>
    <segment id="16">Mas, a Secretaria de Educação vai fazer estudos sobre a necessidade de vagas para estudantes de outras faixas etárias na região.</segment>
    <segment id="17">Dependendo da demanda</segment>
    <segment id="18">, a unidade poderá ter também turmas do 6 ao 9 ano do Ensino Fundamental.</segment>
    <segment id="19">Prédio terá três andares e 20 salas de aula</segment>
    <segment id="20">A previsão da secretaria é que a construção do colégio termine em janeiro de 2012 - antes do começo do ano letivo</segment>
    <segment id="21">, em fevereiro.</segment>
    <segment id="22">O terreno na Pavuna</segment>
    <segment id="23">, de quatro mil metros quadrados</segment>
    <segment id="24">, já está preparado para o início da montagem da estrutura pré-moldada da futura escola</segment>
    <segment id="25">, orçada em cerca de R$ 11 milhões.</segment>
    <segment id="26">O prédio terá três andares</segment>
    <segment id="27">, com 20 salas de aula</segment>
    <segment id="28">, com 40 alunos cada.</segment>
    <segment id="29">O Colégio Estadual Rodolfo Fernandes será equipado ainda com dois laboratórios e uma sala de artes (todos com capacidade para 40 estudantes)</segment>
    <segment id="30">, uma biblioteca</segment>
    <segment id="31">, um auditório (para 80 pessoas)</segment>
    <segment id="32">, uma quadra coberta e vestiários.</segment>
  </rst>
</analysis>