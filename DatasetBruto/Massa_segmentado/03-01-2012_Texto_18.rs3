  <rst>
    <segment id="1">Ator da Record é acusado de agressão</segment>
    <segment id="2">A suposta vítima registrou ocorrência na polícia
Rômulo Arantes Neto é acusado de agredir um homem em plena festa de réveillon em Angra dos Reis</segment>
    <segment id="3">, no Rio de Janeiro.</segment>
    <segment id="4">Segundo o rapaz</segment>
    <segment id="5">, que teve que levar nove pontos no sobrancelha</segment>
    <segment id="6">, o ator o agrediu</segment>
    <segment id="7">porque</segment>
    <segment id="8">porque ele pediu um isqueiro a namorada de Rômula</segment>
    <segment id="9">, a atriz Maria Pinna.</segment>
    <segment id="10">Nesta hora</segment>
    <segment id="11">, de acordo com o homem que</segment>
    <segment id="12">sese identifica</segment>
    <segment id="13">comocomo Lucas</segment>
    <segment id="14">, o ator deu o soco nele.</segment>
    <segment id="15">Rômulo</segment>
    <segment id="16">, por sua vez</segment>
    <segment id="17">, admite a agressão</segment>
    <segment id="18">, masmas diz que o fez para</segment>
    <segment id="19">sese defender.</segment>
    <segment id="20">Conforme relato do ator</segment>
    <segment id="21">, ele apenas</segment>
    <segment id="22">sese defendeu de uma agressão.</segment>
    <segment id="23">“Estava curtindo a festa na casa de um amigo de infância e percebi que minha namorada estava desconfortável com uma situação.</segment>
    <segment id="24">Perguntei o que havia acontecido e ela me disse que um cara tinha passado a mão na perna dela por duas vezes"</segment>
    <segment id="25">, contou o ator</segment>
    <segment id="26">, acrescentando que "ele (o homem que estava assediando Maria) e o amigo foram para cima de mim para tentar me agredir e eu apenas me defendi</segment>
    <segment id="27">, dando um soco em um deles”.</segment>
    <segment id="28">O homem agredido prestou queixa na polícia.</segment>
    <segment id="29">"</segment>
    <segment id="30">Pedi um isqueiro para Maria e ela disse que não tinha.</segment>
    <segment id="31">Aí pedi o cigarro dela para acender o meu e ela me deu.</segment>
    <segment id="32">De repente chegou o Rômulo falando que</segment>
    <segment id="33">sese pedisse um cigarro para ela de novo ele iria me bater.</segment>
    <segment id="34">Aí a Maria Pinna me jogou um copo de bebida e quando abaixei a cabeça para secar meu rosto</segment>
    <segment id="35">, o Rômulo me deu o soco"</segment>
    <segment id="36">, disse a suposta vítima.</segment>
    <segment id="37">As informações são do site Ego.</segment>
  </rst>
</analysis>