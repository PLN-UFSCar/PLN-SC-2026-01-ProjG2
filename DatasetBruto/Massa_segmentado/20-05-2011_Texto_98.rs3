  <rst>
    <segment id="1">Fred é dúvida e Diguinho está fora da estreia do Fluminense

BLOG: 'Orgulho de Ser Tricolor'</segment>
    <segment id="2">, o blog do torcedor do Fluminense
Antes</segment>
    <segment id="3">, era uma gripe.</segment>
    <segment id="4">Mas o diagnóstico recente tirou Fred do treino da manhã desta sexta-feira</segment>
    <segment id="5">, em Teresópolis.</segment>
    <segment id="6">Ele correu e fez reforço muscular.</segment>
    <segment id="7">A comissão técnica não confirma que ele tenha sofrido uma lesão muscular.</segment>
    <segment id="8">Diguinho formou dupla com Fred.</segment>
    <segment id="9">O volante também saiu às escondidas da concentração na Granja Comary para fazer o exame na noite desta sexta-feira.</segment>
    <segment id="10">Seu caso</segment>
    <segment id="11">caso é mais grave.</segment>
    <segment id="12">Com lesão na coxa esquerda</segment>
    <segment id="13">, ele está fora da primeira e segunda rodadas.</segment>
    <segment id="14">Souza pode jogar de volante
Otimista</segment>
    <segment id="15">, o técnico interino trata</segment>
    <segment id="16">comocomo passageiro o problema de Fred.</segment>
    <segment id="17">Como tem sido praxe nestas situações</segment>
    <segment id="18">, Enderson Moreira não descartou a escalação do atacante.
- Vamos aguardar até o último minuto.</segment>
    <segment id="19">Quero contar com ele</segment>
    <segment id="20">, masmas foi o terceiro treinamento que ele não participou... - declarou Enderson.</segment>
    <segment id="21">Fred virou um problema para Enderson</segment>
    <segment id="22">, masmas a lesão de Diguinho pode ser a solução para um constrangimento causado por Souza.</segment>
    <segment id="23">Ao reivindicar uma vaga no time</segment>
    <segment id="24">, o meia pôs o treinador em uma situação difícil.</segment>
    <segment id="25">O desfalque do camisa 8 abriu espaço para Souza</segment>
    <segment id="26">, testado</segment>
    <segment id="27">comocomo segundo volante.</segment>
    <segment id="28">A vaga está entre ele e Diogo.</segment>
    <segment id="29">Edinho jogará</segment>
    <segment id="30">comocomo primeiro volante</segment>
    <segment id="31">, porque</segment>
    <segment id="32">porque Leandro Euzébio está de volta à zaga ao lado de Gum.</segment>
    <segment id="33">Se Fred não puder jogar</segment>
    <segment id="34">, Rodriguinho entrará no ataque ao lado de Rafael Moura.</segment>
    <segment id="35">No meio-campo</segment>
    <segment id="36">, Deco e Conca.</segment>
    <segment id="37">Dado como</segment>
    <segment id="38">como praticamente certo no Fluminense</segment>
    <segment id="39">, o atacante Ciro</segment>
    <segment id="40">, ex-Sport</segment>
    <segment id="41">, deu o primeiro passo</segment>
    <segment id="42">comocomo tricolor: fechou contrato com a mesma assessoria de imprensa de Fred e Rafael Moura.</segment>
    <segment id="43">O jogador acredita em um ciclo vitorioso no clube e quer trilhar os mesmos caminhos dos ídolos.</segment>
    <segment id="44">O atacante é esperado na segunda-feira.</segment>
    <segment id="45">O clube também tenta contratar o apoiador Elkeson</segment>
    <segment id="46">, do Vitória.</segment>
    <segment id="47">Depois da confusa negociação com Fabrício</segment>
    <segment id="48">, o Fluminense poderá acertar com Márcio Rosário</segment>
    <segment id="49">, ex-Botafogo.</segment>
    <segment id="50">Fabrício já havia feito exames médicos nas Laranjeiras e</segment>
    <segment id="51">, apesar de não ter sido anunciado oficialmente</segment>
    <segment id="52">, era aguardado para o treino de quarta-feira à tarde</segment>
    <segment id="53">, na Granja Comary.</segment>
    <segment id="54">Até aquele momento</segment>
    <segment id="55">, o zagueiro estava apto.</segment>
    <segment id="56">E o Fluminense</segment>
    <segment id="57">, empenhado em apresentá-lo.</segment>
    <segment id="58">Mas um suposto problema no ombro</segment>
    <segment id="59">, divulgado por um dirigente tricolor nos bastidores do lançamento dos novos uniformes</segment>
    <segment id="60">, nas Laranjeiras</segment>
    <segment id="61">, teria afastado o zagueiro.</segment>
    <segment id="62">O Cruzeiro negou o problema.</segment>
  </rst>
</analysis>