  <rst>
    <segment id="1">Toninho Cerezo fala em reforço gringo
Treinador diz que Leão jogará com muita vontade sob seu comando</segment>
    <segment id="2">Toninho</segment>
    <segment id="3">Cerezo foi apresentado ontem à tarde na Toca do Leão.</segment>
    <segment id="4">O novo treinador do Vitória sabe que a missão é colocar o rubro-negro na Séria A.

Para isso</segment>
    <segment id="5">, pediu reforços de qualidade</segment>
    <segment id="6">, e indicou que pode trazer um gringo</segment>
    <segment id="7">, sem revelar o nome:</segment>
    <segment id="8">“</segment>
    <segment id="9">Ao invés de contratar muito</segment>
    <segment id="10">, vamos contratar com qualidade.</segment>
    <segment id="11">Posso até sugerir nomes</segment>
    <segment id="12">, masmas o aspecto financeiro fica com a diretoria.</segment>
    <segment id="13">Sei que não temos lateral-esquerdo</segment>
    <segment id="14">, masmas temos bons zagueiros.</segment>
    <segment id="15">Posso até sugerir um jogador italiano para jogar aqui.</segment>
    <segment id="16">Mas, o importante é montar o grupo o quanto antes para subirmos”</segment>
    <segment id="17">, contou o comandante</segment>
    <segment id="18">, que também pretende usar a base rubro-negra.</segment>
    <segment id="19">Em 1999</segment>
    <segment id="20">, Toninho Cerezo fez o Vitória ser a terceira melhor equipe da Série</segment>
    <segment id="21">A em seu primeiro trabalho</segment>
    <segment id="22">comocomo  treinador.</segment>
    <segment id="23">Se conseguir repetir o feito</segment>
    <segment id="24">, só que na Série B</segment>
    <segment id="25">, o ex-jogador botará o Leão na elite.</segment>
    <segment id="26">“</segment>
    <segment id="27">Meu pensamento é a Série B. Minha intenção</segment>
    <segment id="28">, assim</segment>
    <segment id="29">comocomo em 99</segment>
    <segment id="30">, é alcançar os objetivos.</segment>
    <segment id="31">Acompanhei muito a Série B e sei das dificuldades.</segment>
    <segment id="32">Porém, o Vitória é grande e pertence à Série</segment>
    <segment id="33">A”, garantiu.</segment>
    <segment id="34">O caminho para a Primeira Divisão passa pelo elenco:</segment>
    <segment id="35">“Ainda não sei o material que tenho em mãos</segment>
    <segment id="36">, masmas acho que 18 jogadores competitivos</segment>
    <segment id="37">, com mais quatro ou cinco da base</segment>
    <segment id="38">, é um bom começo.</segment>
    <segment id="39">Um grupo compacto</segment>
    <segment id="40">, unido e com grande pegada dentro de campo.</segment>
    <segment id="41">A Série B é isso”</segment>
    <segment id="42">, justificou.</segment>
  </rst>
</analysis>