  <rst>
    <segment id="1">Baixo vira a nova Dama de Ouros
Luiz Cláudio Dacttes Magalhães substitui Paulo Escopeta</segment>
    <segment id="2">, preso no último dia 16</segment>
    <segment id="3">Um homem acusado de participar do assalto ao baterista Paulo César Perrone</segment>
    <segment id="4">, da Banda Estakazero</segment>
    <segment id="5">, durante uma “saidinha bancária”</segment>
    <segment id="6">, em julho</segment>
    <segment id="7">,  é o mais novo integrante do Baralho do Crime da polícia baiana.</segment>
    <segment id="8">Luiz Cláudio Dacttes Magalhães</segment>
    <segment id="9">, 34, mais conhecido</segment>
    <segment id="10">comocomo ‘Baixo’ ou ‘Dinho’</segment>
    <segment id="11">, assumiu a carta  ‘Dama de Ouros’</segment>
    <segment id="12">, substituindo o ex-PM Paulo César Alves Filgueira</segment>
    <segment id="13">, o ‘Paulo Escopeta’</segment>
    <segment id="14">, 43, preso no último dia 16.</segment>
    <segment id="15">Luiz Cláudio é o único bandido do assalto ao baterista que ainda está foragido.</segment>
    <segment id="16">Segundo a polícia</segment>
    <segment id="17">, ele seria o “olheiro” do bando</segment>
    <segment id="18">, ou seja</segment>
    <segment id="19">, entrava nos bancos e passava aos comparsas as informações das vítimas que sacavam dinheiro.</segment>
    <segment id="20">Segundo Dayse Dantas</segment>
    <segment id="21">, coordenadora do Disque Denúncia</segment>
    <segment id="22">, apesar de “dama” ser uma palavra feminina</segment>
    <segment id="23">, a polícia não tem a intenção de “esculachar” os bandidos que são escolhidos para representar tais cartas.</segment>
    <segment id="24">“</segment>
    <segment id="25">A ‘dama’ não representa gênero.</segment>
    <segment id="26">É uma carta de valor alto (no baralho) e é atribuída a  um indivíduo considerado de alta periculosidade</segment>
    <segment id="27">, independente do gênero.</segment>
    <segment id="28">Não existe nenhuma conotação de "esculacho e nem intenção”</segment>
    <segment id="29">, diz Dayse.</segment>
    <segment id="30">Escolha dos criminosos</segment>
    <segment id="31">Dayse</segment>
    <segment id="32">Dantas explica que a escolha dos bandidos segue a mesma lógica de importância das cartas do baralho convencional.</segment>
    <segment id="33">“</segment>
    <segment id="34">A graduação é feita pelas cartas de valor mais alto e depois em ordem decrescente</segment>
    <segment id="35">, de acordo com o crime praticado e os artigos penais pelos quais os indivíduos foram indiciados ou sentenciados”.</segment>
    <segment id="36">Quando um criminoso do baralho morre ou é preso</segment>
    <segment id="37">, normalmente ele é substituído por outro bandido que estava fora do baralho</segment>
    <segment id="38">, complementa a coordenadora.</segment>
    <segment id="39">Denuncie a bandidagem:</segment>
    <segment id="40">O sigilo do nome é garantido</segment>
    <segment id="41">Na ficha policial do novo Dama de Ouros</segment>
    <segment id="42">, ele informa que mora em São Caetano e atua</segment>
    <segment id="43">comocomo motoboy.</segment>
    <segment id="44">Baixo responde a processo por furto de veículos e já foi preso após assaltar uma farmácia</segment>
    <segment id="45">, em 2007.</segment>
    <segment id="46">A coordenadora Dayse Dantas afirma que o serviço Disque Denúncia recebeu 30% a mais de ligações da população após o lançamento do Baralho do Crime.</segment>
    <segment id="47">Mensalmente</segment>
    <segment id="48">, são cerca de 1</segment>
    <segment id="49">,6 mil telefonemas denunciando a bandidagem.</segment>
    <segment id="50">Ela disse que os erros na divulgação de bandidos presos e mortos ocorreram por causa da burocracia e da complexidade na checagem dos dados do baralho.</segment>
    <segment id="51">Em nota</segment>
    <segment id="52">, a Polícia Civil confirmou ontem que a pistola calibre 380 encontrada no último sábado com Márcio Rangel Xavier é a mesma arma que os bandidos usaram para atirar na cabeça do baterista da Estakazero</segment>
    <segment id="53">, Paulo César Perrone.</segment>
  </rst>
</analysis>