  <rst>
    <segment id="1">Estuprador faz rodízio com vítimas</segment>
    <segment id="2">Roni é acusado de estuprar duas mulheres</segment>
    <segment id="3">, além de atacar outra</segment>
    <segment id="4">, em Valéria</segment>
    <segment id="5">Na noite do último dia 6</segment>
    <segment id="6">, véspera de uma Sexta-Feira Santa</segment>
    <segment id="7">, Roni Peterson Mota Passos</segment>
    <segment id="8">, 23 anos</segment>
    <segment id="9">, transformou em um inferno as vidas de três mulheres.</segment>
    <segment id="10">Duas delas</segment>
    <segment id="11">, uma de 42 anos e outra de 17</segment>
    <segment id="12">, o acusam de estuprá-las</segment>
    <segment id="13">, no bairro de Valéria.</segment>
    <segment id="14">Outra moça</segment>
    <segment id="15">, também de 17 anos</segment>
    <segment id="16">, afirma que foi atacada por Roni</segment>
    <segment id="17">, no mesmo dia e no mesmo bairro</segment>
    <segment id="18">, masmas conseguiu escapar antes de o estupro ser consumado.</segment>
    <segment id="19">A casa de Roni caiu</segment>
    <segment id="20">, ontem</segment>
    <segment id="21">, após ele ser descoberto pela equipe de investigação comandada pela delegada Olveranda Oliveira</segment>
    <segment id="22">, titular da Delegacia Especializada de Atendimento à Mulher (Deam)</segment>
    <segment id="23">, localizada em Periperi.</segment>
    <segment id="24">A delegada recebeu a informação de que Roni já estava preso na Delegacia de Cajazeiras</segment>
    <segment id="25">, há oito dias</segment>
    <segment id="26">, após ser flagrado com uma arma de fabricação artesanal.</segment>
    <segment id="27">Conduzido à Deam</segment>
    <segment id="28">, ele foi autuado pelo crime de estupro.</segment>
    <segment id="29">As duas mulheres estupradas relatam que foram abordadas por volta das 23h</segment>
    <segment id="30">, em um ponto de ônibus de Valéria.</segment>
    <segment id="31">Roni disse a elas que estava com um revólver.</segment>
    <segment id="32">Iria arrancar a cabeça</segment>
    <segment id="33">Sob fortes ameaças</segment>
    <segment id="34">, as duas moças foram levadas a um matagal.</segment>
    <segment id="35">Lá, Roni fez uma espécie de rodízio sexual: ora amarrava as mãos de uma delas com um pano e estuprava a outra</segment>
    <segment id="36">, e vice-versa.</segment>
    <segment id="37">Depois</segment>
    <segment id="38">, trocava as posições.</segment>
    <segment id="39">“Ele dizia que iria pocar a nossa cabeça.</segment>
    <segment id="40">Ele abusou da gente durante 1 hora e 45 minutos.</segment>
    <segment id="41">Ele ameaçava que</segment>
    <segment id="42">sese soubesse que a gente registrou queixa contra ele</segment>
    <segment id="43">, iria arrancar a nossa cabeça</segment>
    <segment id="44">, dizendo que já tinha feito isso”</segment>
    <segment id="45">, contaram as mulheres</segment>
    <segment id="46">, uma de 42 e outra de 17 anos.

‘</segment>
    <segment id="47">Apenas roubei celulares’</segment>
    <segment id="48">, diz ele

Durante depoimento na Deam</segment>
    <segment id="49">, Roni Peterson negou ser estuprador.</segment>
    <segment id="50">Ele argumenta que “apenas roubou os celulares das mulheres”</segment>
    <segment id="51">, no ponto de ônibus.</segment>
    <segment id="52">Ele admite ser usuário de crack e que já foi detido acusado de roubo</segment>
    <segment id="53">, duas vezes.</segment>
  </rst>
</analysis>