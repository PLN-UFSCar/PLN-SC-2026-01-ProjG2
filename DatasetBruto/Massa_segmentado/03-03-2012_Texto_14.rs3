  <rst>
    <segment id="1">Jornal de Caja City é a cara da galera</segment>
    <segment id="2">Informe Cajazeiras revela o que há de melhor</segment>
    <segment id="3">, masmas também aponta os pepinos do bairro</segment>
    <segment id="4">O bairro de Cajazeiras é apontado</segment>
    <segment id="5">comocomo um dos maiores da América Latina.</segment>
    <segment id="6">Estima-</segment>
    <segment id="7">sese que mais de 600 mil pessoas morem no local.</segment>
    <segment id="8">Com esta imensa população</segment>
    <segment id="9">,  o bairro ganhou ares de cidade grande</segment>
    <segment id="10">, com direito a problemas sociais</segment>
    <segment id="11">, ausência do poder público e um jornal próprio</segment>
    <segment id="12">, o Informe Cajazeiras</segment>
    <segment id="13">, que surgiu justamente com o objetivo de mostrar a realidade de Caja City.</segment>
    <segment id="14">“Há 11 anos percebemos a necessidade de um jornal que falasse e divulgasse os assuntos do bairro.</segment>
    <segment id="15">Estamos aqui para mostrar o que a prefeitura e o governo fazem ou não fazem”</segment>
    <segment id="16">, revelou Carlos Alberto Figueiredo</segment>
    <segment id="17">, fundador do periódico</segment>
    <segment id="18">, morador do bairro</segment>
    <segment id="19">, agente de saúde e policial civil.</segment>
    <segment id="20">Distribuído gratuitamente</segment>
    <segment id="21">, o Informe Cajazeiras é publicado a cada dois meses.</segment>
    <segment id="22">Cerca de 20  mil exemplares são entregues nos ônibus</segment>
    <segment id="23">, nas portas das casas e pelas ruas.</segment>
    <segment id="24">“Entregamos em toda a Salvador.</segment>
    <segment id="25">Temos o maior orgulho de que as pessoas da Barra ou Itapuã possam saber o que está acontecendo por aqui”</segment>
    <segment id="26">, disse Carlos.</segment>
    <segment id="27">A dona de casa Janaína Miranda</segment>
    <segment id="28">,  43, disse que há anos fica na espectativa de cada nova edição.</segment>
    <segment id="29">“</segment>
    <segment id="30">Quando sei que  vai sair</segment>
    <segment id="31">, fico atenta.</segment>
    <segment id="32">Gosto de ler as coisas daqui</segment>
    <segment id="33">, masmas fico ligada mesmo é nos anúncios.</segment>
    <segment id="34">É bom porque</segment>
    <segment id="35">porque sei onde encontrar as mercadorias que quero comprar.</segment>
    <segment id="36">Há anúncios de funerárias</segment>
    <segment id="37">,  moda</segment>
    <segment id="38">, comida.</segment>
    <segment id="39">Tem de tudo.</segment>
    <segment id="40">Sinto-me muito bem informada”</segment>
    <segment id="41">, destacou.</segment>
  </rst>
