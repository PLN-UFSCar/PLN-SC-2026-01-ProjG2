  <rst>
    <segment id="1">Já em Sepetiba I</segment>
    <segment id="2">, casas tiveram projeto original alterado</segment>
    <segment id="3">O conjunto Nova Sepetiba I</segment>
    <segment id="4">, entregue há 11 anos</segment>
    <segment id="5">, hoje</segment>
    <segment id="6">sese parece pouco com a paisagem de pequenas casinhas enfileiradas da época da inauguração.</segment>
    <segment id="7">Líderes locais dizem que há hoje no local 5.600 residências</segment>
    <segment id="8">, sendo que a maioria foi modificada e aumentada</segment>
    <segment id="9">, deturpando o projeto original.</segment>
    <segment id="10">Já as ações do governo parecem ter parado no tempo.</segment>
    <segment id="11">Uma grande área dedicada a uma vila olímpica</segment>
    <segment id="12">, com praças e quadras</segment>
    <segment id="13">, está coberta pelo mato e com praticamente todos os equipamentos quebrados.</segment>
    <segment id="14">Um terreno que deveria abrigar uma escola começa a ser tomado por lixo.</segment>
    <segment id="15">O líder comunitário Marcelo Santos Dias calcula em mais de 30 mil o número de habitantes em Sepetiba I.</segment>
    <segment id="16">Quem mora lá diz que faltam vagas nas escolas da região e atendimento médico.</segment>
    <segment id="17">A pobreza chega ao extremo nas três favelas do conjunto</segment>
    <segment id="18">, onde vivem em barracos de madeira 350 famílias.</segment>
    <segment id="19">Elas participaram da ocupação ao Sepetiba II e aguardam receber casas do governo.</segment>
    <segment id="20">A cozinha e os banheiros são comunitários</segment>
    <segment id="21">, e há apenas uma fonte de água.</segment>
    <segment id="22">No ano passado</segment>
    <segment id="23">, os moradores enfrentaram um incêndio.</segment>
    <segment id="24">São mais de 400 crianças vivendo nessas condições e</segment>
    <segment id="25">, a cada barraco visitado</segment>
    <segment id="26">, mães contam histórias de filhos doentes.</segment>
    <segment id="27">Priscila Pereira da Cruz</segment>
    <segment id="28">, de 25 anos</segment>
    <segment id="29">, mora num único cômodo com três filhos pequenos</segment>
    <segment id="30">, entre 1 e 6 anos</segment>
    <segment id="31">, sendo que dois sofrem de asma.</segment>
    <segment id="32">Na quinta-feira</segment>
    <segment id="33">, o outro estava com febre.

- Maria Clara (de 1 ano) já teve mais de dez pneumonias.</segment>
    <segment id="34">No nosso barraco é tudo ao contrário do que os médicos recomendam.</segment>
    <segment id="35">Não tem piso</segment>
    <segment id="36">, nem ventilação.</segment>
    <segment id="37">Consegui comprar um umidificador</segment>
    <segment id="38">, masmas ele queimou</segment>
    <segment id="39">, porque</segment>
    <segment id="40">porque falta luz a toda hora - conta Priscila</segment>
    <segment id="41">, que sobrevive com R$ 200 do Bolsa Família.</segment>
    <segment id="42">- A única coisa que eu queria era uma casa.</segment>
    <segment id="43">O resto a gente</segment>
    <segment id="44">sese vira.</segment>
    <segment id="45">A Secretaria de Obras diz que</segment>
    <segment id="46">, quando prontas</segment>
    <segment id="47">, as casas de Sepetiba II serão entregues a famílias que vivem nas margens dos rios Iguaçu e Sarapuí</segment>
    <segment id="48">, na Baixada Fluminense.</segment>
  </rst>
</analysis>