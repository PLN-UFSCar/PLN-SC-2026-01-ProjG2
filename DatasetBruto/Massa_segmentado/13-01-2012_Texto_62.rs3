  <rst>
    <segment id="1">Atoladinha:</segment>
    <segment id="2">Celular na periquita</segment>
    <segment id="3">“</segment>
    <segment id="4">Detector</segment>
    <segment id="5">sempre acusa estas presenças estranhas”</segment>
    <segment id="6">, diz diretor do Conjunto Penal
Joseane Dias Nascimento</segment>
    <segment id="7">, 21 anos</segment>
    <segment id="8">, foi detida ao tentar entrar no Conjunto Penal da cidade de Feira de Santana (a 108 km de Salvador) com um celular</segment>
    <segment id="9">, um fone de ouvido e duas baterias escondidas dentro da vagina.</segment>
    <segment id="10">O flagrante aconteceu na última quinta-feira</segment>
    <segment id="11">, 5.</segment>
    <segment id="12">Ela foi levada para o Complexo Policial Investigador Bandeira.</segment>
    <segment id="13">Após prestar depoimento</segment>
    <segment id="14">, foi liberada e agora responderá a um processo em liberdade.</segment>
    <segment id="15">Em entrevista ao programa</segment>
    <segment id="16">Na Mira</segment>
    <segment id="17">, da TV Aratu</segment>
    <segment id="18">, ela desdenhou do repórter após ser questionada sobre</segment>
    <segment id="19">comocomo havia conseguido colocar tantos objetos nas partes íntimas.</segment>
    <segment id="20">Joseane ganhou o apelido de ‘Mulher Sacola’.</segment>
    <segment id="21">Ela foi flagrada pelo detector de metal.</segment>
    <segment id="22">De acordo com o diretor do Conjunto Penal</segment>
    <segment id="23">, Edmundo Memeri</segment>
    <segment id="24">, há cerca de duas semanas outra mulher tentou entrar no presídio com um celular dentro do ânus.</segment>
    <segment id="25">“A fiscalização eletrônica a denunciou”.</segment>
    <segment id="26">Ele revelou que</segment>
    <segment id="27">, no ano passado</segment>
    <segment id="28">, aconteceram cerca de 20 casos semelhantes a esses</segment>
    <segment id="29">, muitas vezes com drogas escondidas.</segment>
    <segment id="30">“</segment>
    <segment id="31">O detector sempre acusa estas presenças estranhas”</segment>
    <segment id="32">, afirma ele.</segment>
    <segment id="33">Mulher levava drogas em fralda de bebê</segment>
    <segment id="34">Quando há desconfiança de que uma mulher transporta drogas na vagina</segment>
    <segment id="35">, o procedimento é diferente.</segment>
    <segment id="36">“Pede-</segment>
    <segment id="37">sese que ela fique de cócoras</segment>
    <segment id="38">, nua, e observamos</segment>
    <segment id="39">sese o produto aparece”</segment>
    <segment id="40">, revelou o diretor.</segment>
    <segment id="41">Os visitantes também tentam levar drogas dentro de comida.</segment>
    <segment id="42">“</segment>
    <segment id="43">Já flagramos até em uma peruca e dentro de uma fralda descartável de bebê”</segment>
    <segment id="44">, afirmou Edmundo Memeri.</segment>
    <segment id="45">Tudo pelo amor bandido</segment>
    <segment id="46">O diretor destaca que as mulheres são orientadas pelos companheiros presos para tentar burlar a vigilância.</segment>
    <segment id="47">De acordo com Maurício</segment>
    <segment id="48">, as revistas em mulheres são feitas por agentes do sexo feminino.</segment>
    <segment id="49">“</segment>
    <segment id="50">Quando o detector faz o alerta</segment>
    <segment id="51">, a gente oferece a pessoa a chance de ela mesma tirar o objeto de dentro dela ou encaminhá-la à Polícia Técnica.</segment>
    <segment id="52">Elas optam pela primeira opção”</segment>
    <segment id="53">, afirma ele.</segment>
  </rst>
</analysis>