  <rst>
    <segment id="1">Sargento da Rondesp é enterrado</segment>
    <segment id="2">O policial foi morto com dois tiros na manhã de ontem</segment>
    <segment id="3">O sargento da Polícia Militar Fábio Nascimento Cintra</segment>
    <segment id="4">, de 35 anos</segment>
    <segment id="5">, foi enterrado na manhã desta sexta-feira (12) no cemitério do Campo Santo</segment>
    <segment id="6">, em Salvador.</segment>
    <segment id="7">O policial foi morto com dois tiros na manhã de ontem no apartamento onde morava</segment>
    <segment id="8">, no bairro de Tancredo Neves.</segment>
    <segment id="9">Parentes</segment>
    <segment id="10">, amigos e colegas do policial acompanharam o sepultamento.</segment>
    <segment id="11">Muito abalada</segment>
    <segment id="12">, a mãe do PM não quis falar sobre o crime.</segment>
    <segment id="13">O corpo de Cintra foi conduzido ao túmulo por policiais da Rondesp</segment>
    <segment id="14">, também bastante emocionados.</segment>
    <segment id="15">De acordo com o comerciante Hélio Oliveira</segment>
    <segment id="16">, de 48 anos</segment>
    <segment id="17">, amigo da vítima</segment>
    <segment id="18">, Fábio era numa pessoa tranquila.</segment>
    <segment id="19">“Ele era um cara bom</segment>
    <segment id="20">, foi uma coisa ruim o que aconteceu.</segment>
    <segment id="21">Ele era tranquilo</segment>
    <segment id="22">, não tinha comportamento agressivo”</segment>
    <segment id="23">, afirmou.

Também presente no sepultamento</segment>
    <segment id="24">, o tenente coronel da Rondesp</segment>
    <segment id="25">, Humberto Sturaro</segment>
    <segment id="26">, que trabalhava diretamente com Fábio Cintra</segment>
    <segment id="27">, afirmou acreditar em uma solução rápida para o crime.</segment>
    <segment id="28">“Estamos sentidos</segment>
    <segment id="29">, masmas não podemos nos abater.</segment>
    <segment id="30">Ele era um bom profissional</segment>
    <segment id="31">, dedicado ao serviço em 18 anos de trabalho.</segment>
    <segment id="32">Tudo leva a crer que foi uma situação pessoal.</segment>
    <segment id="33">Às vezes a gente escolhe viver com uma pessoa que não é o que a gente espera”</segment>
    <segment id="34">, declarou.</segment>
    <segment id="35">O tenente falou ainda sobre as cartas que o PM vinha recebendo e lembrou que ele havia prestado queixa na 11ª CP (Tancredo Neves).</segment>
    <segment id="36">Durante o registro da ocorrência</segment>
    <segment id="37">, Fábio teria explicado que brigou com um vizinho</segment>
    <segment id="38">porque</segment>
    <segment id="39">porque encontrou o portão do prédio aberto.</segment>
    <segment id="40">“Ele reclamou que estava sendo ameaçado por uma pessoa que morava no prédio e que vinha assediando sua mulher”</segment>
    <segment id="41">, disse.</segment>
    <segment id="42">O PM Fábio Cintra morreu por volta das 6h de ontem</segment>
    <segment id="43">, com dois tiros à queima-roupa</segment>
    <segment id="44">, na face e no abdômen.</segment>
    <segment id="45">Dois vizinhos ouviram os disparos</segment>
    <segment id="46">, masmas não viram movimentação.</segment>
    <segment id="47">Às 9h, a esposa de Fábio</segment>
    <segment id="48">, Cleide Cintra</segment>
    <segment id="49">, mandou que o filho de 6 anos</segment>
    <segment id="50">, enteado do PM</segment>
    <segment id="51">, fosse chamar um vizinho e amigo do casal.</segment>
  </rst>
</analysis>