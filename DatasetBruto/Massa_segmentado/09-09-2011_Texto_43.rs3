  <rst>
    <segment id="1">Hollyfield é derrubado pelo fogo
Ex-boxeador vira herói ao salvar sobrinhos do incêndio</segment>
    <segment id="2">Simplesmente um herói.</segment>
    <segment id="3">Assim os familiares  e vizinhos de Reginaldo “Hollyfield” Andrade</segment>
    <segment id="4">, 45,  definiram o ex-pugilista baiano após salvar a vida de dois sobrinhos de um incêndio</segment>
    <segment id="5">, ocorrido na Travessa Roberto Kennedy</segment>
    <segment id="6">, na Rua Lopes Travão</segment>
    <segment id="7">, em Massaranduba.</segment>
    <segment id="8">Ele  teve  30 % do corpo queimado.</segment>
    <segment id="9">“</segment>
    <segment id="10">Meu filho fez mais que um bombeiro.</segment>
    <segment id="11">Além de salvar as crianças ele salvou a família toda”</segment>
    <segment id="12">, disse Maria de Lourdes da Silva</segment>
    <segment id="13">, 85, mãe do ex-campeão</segment>
    <segment id="14">, afirmando que</segment>
    <segment id="15">sese ele não tivesse contido as chamas toda casa viria abaixo.</segment>
    <segment id="16">Segundo Elma de Andrade</segment>
    <segment id="17">, 27, sobrinha de Reginaldo</segment>
    <segment id="18">, a mãe dos meninos</segment>
    <segment id="19">, Almerinda de Andrade</segment>
    <segment id="20">, 41,   que mora na casa de cima</segment>
    <segment id="21">, saiu às 6h30  para o médico</segment>
    <segment id="22">, deixando os filhos  sobre os cuidados da avó.</segment>
    <segment id="23">“</segment>
    <segment id="24">Criança cega a gente</segment>
    <segment id="25">, quando percebemos já escutávamos os gritos desesperados de socorro que  Mariana</segment>
    <segment id="26">, 12, dava.</segment>
    <segment id="27">O menino de 4 anos pegou um fósforo na estante e pôs fogo no sofá</segment>
    <segment id="28">, que passou</segment>
    <segment id="29">, rapidamente</segment>
    <segment id="30">, para o colchão e para os outros móveis da casa”.</segment>
    <segment id="31">Ao ouvir os gritos das crianças</segment>
    <segment id="32">,  Reginaldo</segment>
    <segment id="33">,  que mora com a mãe no andar térreo</segment>
    <segment id="34">, subiu correndo para socorrê-las.</segment>
    <segment id="35">“</segment>
    <segment id="36">Meu tio Reginaldo arrombou a porta</segment>
    <segment id="37">, retirou os sobrinhos e retornou para apagar o fogo.</segment>
    <segment id="38">Ele escorregou</segment>
    <segment id="39">, bateu a cabeça no chão e desmaiou”</segment>
    <segment id="40">, detalhou.</segment>
    <segment id="41">“Foi nesse momento que ele sofreu as queimaduras”</segment>
    <segment id="42">, lamentou Elma.</segment>
    <segment id="43">Os  braços e os ombros foram os mais atingidos no incêndio</segment>
    <segment id="44">, masmas as pernas também sofreram queimaduras.</segment>
    <segment id="45">Segundo a Secretária de Saúde do Estado</segment>
    <segment id="46">, Sesab</segment>
    <segment id="47">, Hollyfield foi submetido a uma cirurgia</segment>
    <segment id="48">, está consciente</segment>
    <segment id="49">, internado no Centro de Tratamento de Queimados do HGE</segment>
    <segment id="50">, passa bem  e não corre risco de morte.</segment>
    <segment id="51">Entenda o</segment>
    <segment id="52">casocaso

Florisvaldo Jesus Santos</segment>
    <segment id="53">, 42, vizinho</segment>
    <segment id="54">, foi um  dos primeiros a chegar no local.</segment>
    <segment id="55">“Umas 7 horas da manhã senti o cheiro de fumaça e ouvi o  grito do povo.</segment>
    <segment id="56">Sai correndo para ver do que</segment>
    <segment id="57">sese tratava.</segment>
    <segment id="58">Quando cheguei na casa de baixo</segment>
    <segment id="59">, vi que o fogo vinha  do andar de cima.</segment>
    <segment id="60">Hollyfield já tinha arrombado a porta e tirado os dois sobrinhos da casa.</segment>
    <segment id="61">Ele estava tentando apagar o fogo com baldes de água</segment>
    <segment id="62">, masmas acho que pela quantidade de fumaça ele</segment>
    <segment id="63">sese sufocou</segment>
    <segment id="64">, escorregou</segment>
    <segment id="65">, caiu e bateu a cabeça.</segment>
    <segment id="66">Juntamos eu e mais uns quatro vizinhos</segment>
    <segment id="67">, pegamos ele</segment>
    <segment id="68">, consciente ainda</segment>
    <segment id="69">,  botamos em uma caminhonete e levamos para o HGE.</segment>
    <segment id="70">Deu pena</segment>
    <segment id="71">, ele estava muito queimado</segment>
    <segment id="72">, masmas  foi um guerreiro de verdade.</segment>
    <segment id="73">Não pensou nele hora nenhuma</segment>
    <segment id="74">, só em salvar os outros ”</segment>
    <segment id="75">, revelou.</segment>
  </rst>
</analysis>