  <rst>
    <segment id="1">Sem corda.</segment>
    <segment id="2">Artistas na onda do 0800
Bell e Moraes dão adeus à corda e garantem a folia da galera</segment>
    <segment id="3">Este Carnaval tem tudo para</segment>
    <segment id="4">sese tornar inesquecível para o folião pipoca.</segment>
    <segment id="5">É que muitos artistas resolveram presentear os fãs e vão levar seus trios para a avenida sem cordas.</segment>
    <segment id="6">Totalmente 0800.</segment>
    <segment id="7">Daniela Mercury já vinha fazendo isso no circuito Barra-Ondina  há alguns anos.</segment>
    <segment id="8">No ano passado foi a vez de  Saulo</segment>
    <segment id="9">, da Banda Eva.</segment>
    <segment id="10">Este ano</segment>
    <segment id="11">, vários outros seguirão seus exemplos.</segment>
    <segment id="12">Essa característica será tão forte em 2012</segment>
    <segment id="13">, que a primeira atração do Campo Grande será o Chiclete com Banana</segment>
    <segment id="14">, de graça</segment>
    <segment id="15">, para o povão.</segment>
    <segment id="16">Além de Bell</segment>
    <segment id="17">, Carlinhos Brown</segment>
    <segment id="18">, Timbalada</segment>
    <segment id="19">, Jammil</segment>
    <segment id="20">, É o Tchan</segment>
    <segment id="21">, Tuca Fernandes</segment>
    <segment id="22">, A Zorra</segment>
    <segment id="23">, Saiddy Bamba e Pablo</segment>
    <segment id="24">, do Arrocha</segment>
    <segment id="25">, também farão a alegria dos foliões.</segment>
    <segment id="26">Para não perder o hábito</segment>
    <segment id="27">, Daniela Mercury e Saulo Fernandes continuarão a</segment>
    <segment id="28">sese apresentar sem cordas.</segment>
    <segment id="29">Diante disso</segment>
    <segment id="30">, só resta ao folião curtir o  Carnaval  na paz.</segment>
    <segment id="31">Independentes</segment>
    <segment id="32">Além dos artistas que levarão seus próprios trios para a avenida</segment>
    <segment id="33">, outros sairão em trios independentes.</segment>
    <segment id="34">A novidade  do verão</segment>
    <segment id="35">, o cantor Magary Lord</segment>
    <segment id="36">, levará o black semba para as ruas.</segment>
    <segment id="37">Quem também</segment>
    <segment id="38">sese tornou figurinha certa no Carnaval a 0800 para o povão foi o cantor Moraes Moreira.</segment>
    <segment id="39">Esse ano</segment>
    <segment id="40">, ele sairá no Barra-Ondina</segment>
    <segment id="41">, na sexta</segment>
    <segment id="42">, às 18h e no domingo</segment>
    <segment id="43">, às 21h30.</segment>
    <segment id="44">Veja onde curtir o 0800

CHICLETE</segment>
    <segment id="45">COM BANANA</segment>
    <segment id="46">- abre o Carnaval do Campo Grande</segment>
    <segment id="47">, hoje</segment>
    <segment id="48">, às 19h30.</segment>
    <segment id="49">SAIDDY BAMBA - arrasta o povão hoje</segment>
    <segment id="50">, a partir da 0h20</segment>
    <segment id="51">, no circuito Barra-Ondina

DANIELA MERCURY - brilha amanhã</segment>
    <segment id="52">, às 19h</segment>
    <segment id="53">, no circuito  Barra-Ondina

MAGARY LORD - encanta no sábado</segment>
    <segment id="54">, dia 18</segment>
    <segment id="55">,  às 19h</segment>
    <segment id="56">, no circuito Barra-Ondina.</segment>
    <segment id="57">CARLINHOS BROWN E TIMBALADA - saem no domingo</segment>
    <segment id="58">, dia 19</segment>
    <segment id="59">, às 13h</segment>
    <segment id="60">, na Avenida.</segment>
    <segment id="61">É O TCHAN - mostra a quebradeira na terça</segment>
    <segment id="62">, dia 21</segment>
    <segment id="63">, às 15h</segment>
    <segment id="64">, na Avenida.</segment>
    <segment id="65">BANDA EVA - agita a terça</segment>
    <segment id="66">, dia 21</segment>
    <segment id="67">, às 16h</segment>
    <segment id="68">, na Avenida.

PABLO - arrocha na terça</segment>
    <segment id="69">, dia 21</segment>
    <segment id="70">, às 18h</segment>
    <segment id="71">, na Avenida.</segment>
  </rst>
