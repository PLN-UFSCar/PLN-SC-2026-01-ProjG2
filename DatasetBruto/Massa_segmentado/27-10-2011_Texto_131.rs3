  <rst>
    <segment id="1">Ô loco</segment>
    <segment id="2">, meu!</segment>
    <segment id="3">Domingão fica bem melhor com Carol Nakamura</segment>
    <segment id="4">A bela Carol Nakamura</segment>
    <segment id="5">, assistente de palco do Domingão do Faustão</segment>
    <segment id="6">, é a estrela da edição de 19 anos da revista  Sexy</segment>
    <segment id="7">, que chega às bancas hoje.</segment>
    <segment id="8">A carioca com ascendência nipônica posou peladinha nas praias do México.</segment>
    <segment id="9">Ela confessou que não teve problemas em tirar a roupa e adorou o resultado final:</segment>
    <segment id="10">“Senti um pouco de medo</segment>
    <segment id="11">, já que foi a primeira vez.</segment>
    <segment id="12">Assim que cheguei</segment>
    <segment id="13">, porém</segment>
    <segment id="14">porém, adorei”</segment>
    <segment id="15">, falou.</segment>
    <segment id="16">Em entrevista ao jornal “O Dia”</segment>
    <segment id="17">, Carol abriu a sua intimidade e falou que</segment>
    <segment id="18">, no sexo</segment>
    <segment id="19">, tem a hora da pegada mais forte.</segment>
    <segment id="20">“</segment>
    <segment id="21">Existe o momento em que quero algo mais agressivo</segment>
    <segment id="22">, mais ‘me joga na parede’</segment>
    <segment id="23">, tem o momento da coisa mais romântica e tem a mistura dos dois</segment>
    <segment id="24">, que é mais interessante”</segment>
    <segment id="25">, afirma.</segment>
    <segment id="26">Ciumenta

Carol confessa que é ciumenta e que o namorado sofre com ela.</segment>
    <segment id="27">“Sou um pouco descontrolada”</segment>
  </rst>
</analysis>