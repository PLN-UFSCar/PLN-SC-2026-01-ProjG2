  <rst>
    <segment id="1">Musas dos bairros</segment>
    <segment id="2">Gatas que arrasaram nas capas do MASSA!
Jéssica Reis</segment>
    <segment id="3">, 20

18/11/10 - Ela queria ser modelo e mandou uma carta para o MASSA!</segment>
    <segment id="4">“</segment>
    <segment id="5">Agradeço muito a oportunidade</segment>
    <segment id="6">poispois foi o meu primeiro trabalho de modelo fotográfica” disse Jéssica.</segment>
    <segment id="7">A gata atualmente cuida mais do corpo para conseguir novos trabalhos.</segment>
    <segment id="8">Fabiana Menezes</segment>
    <segment id="9">, 21

23/06/2011 - Até hoje a Faby Pimentinha escuta na rua:</segment>
    <segment id="10">“E essa pimenta arde mesmo?</segment>
    <segment id="11">”, diz o povo.</segment>
    <segment id="12">“Fiquei conhecida nos bairros de Salvador e sim</segment>
    <segment id="13">, continuo ardendo muito!</segment>
    <segment id="14">” afirma.</segment>
    <segment id="15">Atenção</segment>
    <segment id="16">, gatinhos!</segment>
    <segment id="17">Ela continua solteiríssima.</segment>
    <segment id="18">Maires Chaggas</segment>
    <segment id="19">, 19

31/01/11 - A dançarina da banda Miskuta recebeu várias propostas de outras bandas depois que posou para o MASSA!</segment>
    <segment id="20">“Mas eu recusei todas</segment>
    <segment id="21">porque</segment>
    <segment id="22">porque a Miskuta já é família” afirma.</segment>
    <segment id="23">A gata recebeu o carinho do público ao posar para o jornal.</segment>
    <segment id="24">Adriana Silva</segment>
    <segment id="25">, 25

28/06/2011 - Depois das fotos para o jornal</segment>
    <segment id="26">,</segment>
    <segment id="27">Adriana ficou tão popular que até ganhou concursos.</segment>
    <segment id="28">“Já ganhei um dia de princesa em um shopping da cidade</segment>
    <segment id="29">, um kit de beleza e um celular” conta.</segment>
    <segment id="30">Valeu a pena passar por aqui</segment>
    <segment id="31">, né Adriana?</segment>
    <segment id="32">Laís Costa</segment>
    <segment id="33">, 18

31/08/2011-</segment>
    <segment id="34">A amiga fez o cadastro no site na brincadeira</segment>
    <segment id="35">, masmas a beleza desta jovem de Brotas agradou e logo ela foi chamada para as fotos.</segment>
    <segment id="36">“Me ajudou a ficar mais popular e  arranjei um emprego”</segment>
    <segment id="37">, diz a promotora de vendas.</segment>
    <segment id="38">Suélen Lordello</segment>
    <segment id="39">, 19

08/09/2011 - Ao saber do concurso “Garota do Tempo MASSA!</segment>
    <segment id="40">”, Suélen não perdeu tempo e</segment>
    <segment id="41">sese inscreveu.</segment>
    <segment id="42">“</segment>
    <segment id="43">Depois que fiz a capa</segment>
    <segment id="44">, recebi convite para dançar em uma banda de funk”</segment>
    <segment id="45">, lembra ela</segment>
    <segment id="46">, que decidiu estudar e cursar radiologia.</segment>
    <segment id="47">Marise Anjos</segment>
    <segment id="48">, 23

17/09/2011 - Mesmo com a crise de ciúmes dos pais</segment>
    <segment id="49">, a gata do Nordeste de Amaralina aproveitou a fama depois que saiu em duas capas do MASSA!.</segment>
    <segment id="50">“</segment>
    <segment id="51">Meu sonho foi realizado.</segment>
    <segment id="52">Ainda sou reconhecida na rua e até me pediram autógrafo”</segment>
    <segment id="53">, diz ela.

 



Edilene Machado</segment>
    <segment id="54">, 21

03/10/2011 - A Eny Malvadinha do Nordeste de Amaralina não ligou para os comentários e arrasou nas fotos.</segment>
    <segment id="55">“Ser gordinha não é uma doença.</segment>
    <segment id="56">Temos o direito de nos sentir bonitas ”</segment>
    <segment id="57">, diz ela</segment>
    <segment id="58">, que é reconhecida por todos na região.</segment>
  </rst>
