  <rst>
    <segment id="1">Rosinha volta a a ser ré em ação de improbidade</segment>
    <segment id="2">RIO - A ex-governadora do Rio Rosinha Garotinho voltará a ser ré num processo por improbidade administrativa.</segment>
    <segment id="3">A decisão é da 8ª Câmara Cível do Rio</segment>
    <segment id="4">, atendendo a pedido do Ministério Público estadual.</segment>
    <segment id="5">Ajuizada em abril de 2010 pelo MP</segment>
    <segment id="6">, a ação civil pública apontava para Rosinha e mais nove réus</segment>
    <segment id="7">, entre eles pessoas físicas e jurídicas</segment>
    <segment id="8">, como</segment>
    <segment id="9">como responsáveis por atos de improbidade administrativa.</segment>
    <segment id="10">O estado teria autorizado uma operação ilegal</segment>
    <segment id="11">, que causou prejuízo aos cofres públicos.</segment>
    <segment id="12">Um imóvel teria sido aceito</segment>
    <segment id="13">comocomo pagamento para extinção de crédito tributário de ICMS.</segment>
    <segment id="14">Em primeira instância</segment>
    <segment id="15">, o juízo da 7ª Vara de Fazenda Pública excluíra</segment>
    <segment id="16">Rosinha do processo</segment>
    <segment id="17">, alegando que</segment>
    <segment id="18">, por ela ser governadora na época</segment>
    <segment id="19">, o mérito da ação caberia ao Superior Tribunal de Justiça (STJ).</segment>
    <segment id="20">O MP recorreu e conseguiu o efeito suspensivo da decisão que livrava a ex-governadora do processo.</segment>
    <segment id="21">A decisão foi da desembargadora Norma Suely.</segment>
  </rst>
</analysis>