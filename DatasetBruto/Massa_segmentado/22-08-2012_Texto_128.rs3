  <rst>
    <segment id="1">Cursos 0800 para deficientes</segment>
    <segment id="2">Projeto Novo</segment>
    <segment id="3">Olhar oferece capacitaГѓВ§ГѓВЈo profissional em diversas ГѓВЎreas</segment>
    <segment id="4">Portadores de deficiГѓВЄncia que tГѓВЄm interesse em</segment>
    <segment id="5">sese capacitar para ingressar no mercado de trabalho podem</segment>
    <segment id="6">sese inscrever em um dos cursos gratuitos oferecidos pelo projeto Novo Olhar</segment>
    <segment id="7">, vinculado</segment>
    <segment id="8">ГѓВ  Faculdade Ruy Barbosa.</segment>
    <segment id="9">Os cursos sГѓВЈo divididos em mГѓВіdulos bimestrais com conteГѓВєdo de administraГѓВ§ГѓВЈo</segment>
    <segment id="10">, gastronomia</segment>
    <segment id="11">, computaГѓВ§ГѓВЈo</segment>
    <segment id="12">, dentre outras ГѓВЎreas.</segment>
    <segment id="13">NГѓВЈo hГѓВЎ limite de vagas e as inscriГѓВ§ГѓВµes</segment>
    <segment id="14">, que nГѓВЈo tГѓВЄm prazo para terminar</segment>
    <segment id="15">, podem ser feitas na sede da faculdade</segment>
    <segment id="16">, no Rio Vermelho.</segment>
    <segment id="17">Гўв‚¬Е“NГѓВЈo pretendemos encerrar inscriГѓВ§ГѓВµes</segment>
    <segment id="18">, masmas desenvolver um trabalho permanente de entrevistasГўв‚¬</segment>
    <segment id="19">, declara a coordenadora do projeto</segment>
    <segment id="20">, Jaqueline Vianna.</segment>
    <segment id="21">As atividades</segment>
    <segment id="22">, que serГѓВЈo ministradas na sede da faculdade</segment>
    <segment id="23">, devem iniciar na prГѓВіxima segunda</segment>
    <segment id="24">, 27.</segment>
    <segment id="25">As turmas serГѓВЈo fechadas com</segment>
    <segment id="26">, no mГѓВЎximo</segment>
    <segment id="27">, 20 pessoas.</segment>
    <segment id="28">As aulas acontecerГѓВЈo das 14h</segment>
    <segment id="29">ГѓВ s 17h</segment>
    <segment id="30">, com duraГѓВ§ГѓВЈo mГѓВ©dia de seis semanas.</segment>
    <segment id="31">As atividades de cada curso acontecem uma vez por semana e</segment>
    <segment id="32">, por isso</segment>
    <segment id="33">, os interessados podem</segment>
    <segment id="34">sese inscrever em mais de um curso.</segment>
    <segment id="35">O coordenador de projetos de inclusГѓВЈo no mercado de trabalho da AssociaГѓВ§ГѓВЈo Baiana de Deficientes FГѓВ­sicos</segment>
    <segment id="36">, George Costa</segment>
    <segment id="37">, afirma que a iniciativa representa uma proposta de discussГѓВЈo sobre os diretos das pessoas com deficiГѓВЄncia na sociedade.</segment>
    <segment id="38">Гўв‚¬Е“Esta iniciativa tem potencial de diminuir o dГѓВ©ficit de qualificaГѓВ§ГѓВЈo e mostrar que temos sim pessoas qualificadasГўв‚¬</segment>
    <segment id="39">, salienta.</segment>
    <segment id="40">Se ligue!</segment>
    <segment id="41">No ato da inscriГѓВ§ГѓВЈo</segment>
    <segment id="42">, os interessados devem levar RG</segment>
    <segment id="43">, CPF e comprovante de residГѓВЄncia.</segment>
    <segment id="44">Na primeira etapa</segment>
    <segment id="45">, profissionais do curso de psicologia da faculdade realizarГѓВЈo uma entrevista com os interessados.</segment>
    <segment id="46">O objetivo ГѓВ© identificar qual a ГѓВЎrea de interesse dos inscritos.</segment>
    <segment id="47">Гўв‚¬Е“Ofertaremos mГѓВіdulos e formaremos turmas a partir da demanda.</segment>
    <segment id="48">Se muitos deles</segment>
    <segment id="49">, por exemplo</segment>
    <segment id="50">, tГѓВЄm interesse na ГѓВЎrea de vendas</segment>
    <segment id="51">, ofereceremos um mГѓВіdulo para esta ГѓВЎreaГўв‚¬</segment>
    <segment id="52">, diz Jaqueline.</segment>
