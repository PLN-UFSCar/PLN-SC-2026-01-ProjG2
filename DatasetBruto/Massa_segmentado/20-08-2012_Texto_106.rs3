    <segment id="54">para que desista da competiГѓВ§ГѓВЈo:</segment>
    <segment id="55">Гўв‚¬Е“Algumas meninas vieram falar que</segment>
    <segment id="56">sese eu concorrer</segment>
    <segment id="57">, elas nГѓВЈo terГѓВЈo chance.</segment>
