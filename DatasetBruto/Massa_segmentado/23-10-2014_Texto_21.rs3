    <segment id="40">Railan foi encontrado momentos depois</segment>
    <segment id="41">, agonizando dentro do banheiro do 2횂쨘 subsolo do pr횄짤dio da 횄rea 1.</segment>
    <segment id="42">"</segment>
    <segment id="43">Foi uma execu횄짠횄짙o prim횄징ria"</segment>
