  <rst>
    <segment id="1">Fim.</segment>
    <segment id="2">De novo?
Nicole Bahls fica de cama após término de namoro</segment>
    <segment id="3">Segundo a ex-panicat</segment>
    <segment id="4">, agora é para valer: o namoro com o zagueiro do Vitória acabou de vez.</segment>
    <segment id="5">“Ele me traiu</segment>
    <segment id="6">, eu tenho certeza”</segment>
    <segment id="7">, afirmou Nicole Bahls ao programa “Muito+”</segment>
    <segment id="8">, da Band.</segment>
    <segment id="9">“</segment>
    <segment id="10">Até agora eu estou de cama</segment>
    <segment id="11">, não consegui levantar”</segment>
    <segment id="12">, contou a gata.</segment>
    <segment id="13">Nicole descobriu</segment>
    <segment id="14">, por meio de uma amiga</segment>
    <segment id="15">, que o jogador de futebol saiu com outra garota.</segment>
    <segment id="16">Um repeteco do que aconteceu no mês passado</segment>
    <segment id="17">, quando os dois terminaram.</segment>
    <segment id="18">“Eu já tinha dado uma oportunidade”</segment>
    <segment id="19">, disse a bela</segment>
    <segment id="20">, que, agora</segment>
    <segment id="21">, só deseja ‘amor e paz'.</segment>
  </rst>
</analysis>