  <rst>
    <segment id="1">Maçã cheia de veneno e crueldade</segment>
    <segment id="2">Criminoso morto pela polícia usava métodos bárbaros contra as vítimas</segment>
    <segment id="3">Com 15 anos ele começou a matar e assim foi conquistando a confiança dos chefões do tráfico de drogas.</segment>
    <segment id="4">Para manter o status e continuar perto do poder</segment>
    <segment id="5">, ele cada vez mais agia com crueldade.</segment>
    <segment id="6">Nas horas de folga</segment>
    <segment id="7">, gostava de luxar em hotéis à beira-mar e frequentava shows de pagode.</segment>
    <segment id="8">Para a polícia</segment>
    <segment id="9">, esse é o resumo da vida de Tiago Costa Porto</segment>
    <segment id="10">, 18 anos</segment>
    <segment id="11">, conhecido</segment>
    <segment id="12">comocomo Tiago Maçã.</segment>
    <segment id="13">Após rápida ascensão no mundo do crime</segment>
    <segment id="14">, Tiago foi morto</segment>
    <segment id="15">, na madrugada de anteontem</segment>
    <segment id="16">, no Setor J</segment>
    <segment id="17">, bairro Mussurunga.</segment>
    <segment id="18">De acordo com a Polícia Civil</segment>
    <segment id="19">, Maçã morreu após trocar tiros com agentes da Delegacia do Nordeste de Amaralina e com PMs da Rondesp  Central.</segment>
    <segment id="20">Ele teria reagido à voz de prisão.</segment>
    <segment id="21">Segundo o delegado Odair Carneiro</segment>
    <segment id="22">, da Delegacia do Nordeste de Amaralina</segment>
    <segment id="23">, os métodos cruéis utilizados por Maçã durante os crimes chamaram bastante a atenção da polícia.</segment>
    <segment id="24">Após roubar um carro - modalidade que era uma das especialidades dele -</segment>
    <segment id="25">, Tiago mandava as vítimas correrem</segment>
    <segment id="26">, sem olhar para trás</segment>
    <segment id="27">, e logo depois começava a atirar.</segment>
    <segment id="28">“</segment>
    <segment id="29">As vítimas relatavam isso chorando</segment>
    <segment id="30">, aqui na delegacia.</segment>
    <segment id="31">Teve uma delas que</segment>
    <segment id="32">sese jogou embaixo de um veículo para não ser atingida”</segment>
    <segment id="33">, afirma Odair.</segment>
    <segment id="34">Outra tara de Maçã era estuprar mulheres.</segment>
    <segment id="35">Foram cerca de cinco vítimas.</segment>
    <segment id="36">As mulheres estupradas eram</segment>
    <segment id="37">, geralmente</segment>
    <segment id="38">, namoradas de bandidos rivais ou garotas com quem ele implicava</segment>
    <segment id="39">, por qualquer motivo.</segment>
    <segment id="40">Sol, piscina</segment>
    <segment id="41">, mulheres e gastança</segment>
    <segment id="42">Segundo o delegado Odair Carneiro</segment>
    <segment id="43">, há relatos de que Maçã convidava cerca de dez amigos para participar das sessões de estupro</segment>
    <segment id="44">, praticando diversas perversões sexuais contra as mulheres.</segment>
    <segment id="45">Conforme a polícia</segment>
    <segment id="46">, Tiago gostava de tirar onda de bon vivant.</segment>
    <segment id="47">Prova disso são as fotografias encontradas na casa onde ele estava morando</segment>
    <segment id="48">, em Mussurunga</segment>
    <segment id="49">, nas quais ele aparece na piscina de um apart hotel</segment>
    <segment id="50">, no bairro de Ondina.</segment>
    <segment id="51">O preço médio de hospedagem na região é R$ 250.</segment>
    <segment id="52">Segundo a polícia</segment>
    <segment id="53">, Maçã ficou seis dias hospedado no hotel.</segment>
  </rst>
</analysis>