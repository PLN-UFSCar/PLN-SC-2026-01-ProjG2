  <rst>
    <segment id="1">Pânico e desespero nas ruas do Rio</segment>
    <segment id="2">Cinco pessoas morreram e vinte e duas estão desaparecidas em desabamaento de prédios</segment>
    <segment id="3">Cinco corpos foram encontrados entre os escombros dos três prédios que desabaram na última quarta-feira no centro do Rio de Janeiro.</segment>
    <segment id="4">Segundo o IML (Instituto Médico Legal)</segment>
    <segment id="5">, foram reconhecidos os corpos de Cornélio Ribeiro Lopes</segment>
    <segment id="6">, 73, que era porteiro de um dos edifícios</segment>
    <segment id="7">,  Celso Renato Braga Cabral</segment>
    <segment id="8">, 44, e de Moisés Moraes da Silva</segment>
    <segment id="9">, catador de papel</segment>
    <segment id="10">, identificado pela prima.</segment>
    <segment id="11">Testemunhas disseram que o expediente já estava encerrado na grande maioria das empresas em funcionamento nos edifícios quando ocorreu o desabamento.</segment>
    <segment id="12">Houve pânico</segment>
    <segment id="13">, correria e desespero.</segment>
    <segment id="14">"</segment>
    <segment id="15">Parecia um terremoto.</segment>
    <segment id="16">Primeiro caíram blocos de concreto do prédio.</segment>
    <segment id="17">As pessoas começaram a correr.</segment>
    <segment id="18">Depois caiu tudo de uma vez"</segment>
    <segment id="19">, revelou uma testemunha que</segment>
    <segment id="20">sese identificou apenas</segment>
    <segment id="21">comocomo Gilberto.</segment>
    <segment id="22">“Eu tive sorte</segment>
    <segment id="23">, parecia o 11 de Setembro.</segment>
    <segment id="24">Parecia que estavam jogando entulho de cima do telhado.</segment>
    <segment id="25">Eu vi uma laje caindo e saí correndo.</segment>
    <segment id="26">Se ficasse</segment>
    <segment id="27">, ia cair em cima de mim”</segment>
    <segment id="28">, relatou Vicente Cruz</segment>
    <segment id="29">, entregador de água</segment>
    <segment id="30">, que estava em um dos prédios.</segment>
    <segment id="31">As equipes da prefeitura e do Corpo de Bombeiros continuam tentando localizar 22 desaparecidos – segundo relatos de testemunhas e familiares das possíveis vítimas do acidente.</segment>
    <segment id="32">Máquinas retro-escavadeiras</segment>
    <segment id="33">, cães farejadores e equipamentos hidráulicos ajudam os bombeiros na operação.</segment>
    <segment id="34">As causas do acidente ainda estão sendo apuradas</segment>
    <segment id="35">, masmas um dos edifícios passava por obras em alguns andares.</segment>
    <segment id="36">"</segment>
    <segment id="37">Não sabemos a causa</segment>
    <segment id="38">, masmas o mais provável é que não houve explosão"</segment>
    <segment id="39">, afirmou Eduardo Paes</segment>
    <segment id="40">, prefeito da cidade.</segment>
    <segment id="41">Obra não tinha autorização</segment>
    <segment id="42">As suspeitas de que uma obra irregular esteja ligada ao acidente  ganharam força na tarde de ontem.</segment>
    <segment id="43">Segundo funcionários e pessoas que frequentavam o edifício Liberdade</segment>
    <segment id="44">, paredes e colunas foram removidas no terceiro andar do prédio.</segment>
    <segment id="45">De acordo com o engenheiro civil Antônio Eulálio Pedrosa Araújo</segment>
    <segment id="46">, consultor do Conselho Regional de Engenharia e Agronomia (Crea)</segment>
    <segment id="47">, a obra era ilegal</segment>
    <segment id="48">, pois</segment>
    <segment id="49">pois não tinha autorização do conselho.</segment>
    <segment id="50">Ele descartou a explosão de gás</segment>
    <segment id="51">comocomo causa do acidente e apontou outras hipóteses para a queda do prédio de 20 andares: o corte de uma viga</segment>
    <segment id="52">, com ruptura brusca</segment>
    <segment id="53">, a corrosão e infiltração da laje da cobertura ou o entulho de obra</segment>
    <segment id="54">comocomo sacos de cimentos</segment>
    <segment id="55">, que provocou o excesso de peso e o rompimento da estrutura.</segment>
  </rst>
</analysis>