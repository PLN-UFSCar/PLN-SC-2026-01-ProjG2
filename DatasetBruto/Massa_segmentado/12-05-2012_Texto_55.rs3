  <rst>
    <segment id="1">Biólogo vende tudo que tinha na Grécia e</segment>
    <segment id="2">sese muda para o Brasil
ATENAS.</segment>
    <segment id="3">Constantin Costopoulos tem dois doutorados - na Grécia e na Holanda.</segment>
    <segment id="4">Aos 53 anos</segment>
    <segment id="5">, o biólogo</segment>
    <segment id="6">, um dos maiores especialistas em criação de peixes da Grécia</segment>
    <segment id="7">, e conhecido em vários países - acaba de virar um exilado da crise.</segment>
    <segment id="8">No sábado de manhã</segment>
    <segment id="9">, embarcou num avião rumo a Brasília</segment>
    <segment id="10">, com projetos para fazer do Brasil um grande criador e exportador de peixes.
- A Grécia acabou.</segment>
    <segment id="11">Não há mais esperança neste país - diz.</segment>
    <segment id="12">Costopoulos não apenas é um biólogo mundialmente conhecido</segment>
    <segment id="13">, como</segment>
    <segment id="14">como é um homem de bens.</segment>
    <segment id="15">E sua descrença na Grécia é tal que ele está vendendo tudo.</segment>
    <segment id="16">Por exemplo: seus quatro apartamentos em Atenas.</segment>
    <segment id="17">Só não decidiu ainda</segment>
    <segment id="18">sese vende sua casa na ilha idílica de Santorini</segment>
    <segment id="19">, um dos mais belos destinos turísticos da Grécia.</segment>
    <segment id="20">Sua mulher</segment>
    <segment id="21">, arquiteta</segment>
    <segment id="22">, vai esperar ele</segment>
    <segment id="23">sese instalar no Brasil para depois fechar as malas e o escritório.</segment>
    <segment id="24">O biólogo já teve sete empresas na Grécia:</segment>
    <segment id="25">exportava</segment>
    <segment id="26">, essencialmente</segment>
    <segment id="27">, seu enorme conhecimento na aquicultura para companhias que operam no exterior.</segment>
    <segment id="28">Com a Grécia afundando</segment>
    <segment id="29">, achou melhor apostar nos emergentes.</segment>
    <segment id="30">Excluiu China</segment>
    <segment id="31">, Rússia e Índia</segment>
    <segment id="32">, e optou pelo Brasil.</segment>
    <segment id="33">Viajou dois meses pelo país no fim do ano passado para escolher o lugar certo onde pudesse aplicar sua tecnologia.</segment>
    <segment id="34">Voltou para a Grécia convencido de que o Brasil</segment>
    <segment id="35">, que importa peixes</segment>
    <segment id="36">, "tem um enorme potencial de</segment>
    <segment id="37">sese tornar um dos maiores produtores e exportadores de espécies tropicais no mundo".</segment>
    <segment id="38">Neste domingo</segment>
    <segment id="39">, já em Brasília</segment>
    <segment id="40">, inicia uma série de encontros com funcionários do governo para apresentar seu projeto e começar uma nova vida.</segment>
  </rst>
