  <rst>
    <segment id="1">A dor da perda de um filho em vídeo
Novo clipe da banda Psirico retrata o sofrimento de mães que convivem com a saudade</segment>
    <segment id="2">Três mulheres</segment>
    <segment id="3">, moradoras do mesmo bairro (Jardim Lobato) e com histórias semelhantes participam do novo clipe da banda Psirico</segment>
    <segment id="4">, liderada por Márcio Victor.</segment>
    <segment id="5">Além de  serem vizinhas</segment>
    <segment id="6">, a dona de casa Maria José Rocha</segment>
    <segment id="7">, 57, a empregada doméstica Zulene Liberato</segment>
    <segment id="8">, 42 e a baiana de acarajé Eliana Santos</segment>
    <segment id="9">,35, vivem o mesmo drama: precisam conviver com a saudade de seus filhos</segment>
    <segment id="10">, que morreram precocemente.</segment>
    <segment id="11">Mãe de seis filhos</segment>
    <segment id="12">, Maria viu dois deles morrerem de forma brusca.</segment>
    <segment id="13">“</segment>
    <segment id="14">Primeiro</segment>
    <segment id="15">, foi minha filha</segment>
    <segment id="16">, vítima de um câncer de mama.</segment>
    <segment id="17">Um ano depois</segment>
    <segment id="18">, meu caçula foi assassinado quase na porta de casa.</segment>
    <segment id="19">Tudo muito recente</segment>
    <segment id="20">, tem apenas cinco meses que ele</segment>
    <segment id="21">sese foi”.</segment>
    <segment id="22">Já Zulene  convive com a saudade da filha Tatiane há exatos 11 anos.</segment>
    <segment id="23">A garota foi atropelada na rua principal do bairro</segment>
    <segment id="24">, quando voltava da escola.</segment>
    <segment id="25">“</segment>
    <segment id="26">Até hoje eu choro quando lembro dela.</segment>
    <segment id="27">Fico imaginando o que eu poderia ter feito para impedir a morte de minha filha”.</segment>
    <segment id="28">Um descuido enquanto brincava na laje do  prédio em que a família mora  foi o motivo da morte de Gleidson de Souza</segment>
    <segment id="29">, 16, filho de Eliana.</segment>
    <segment id="30">“Ele estava brincando</segment>
    <segment id="31">, pedi para  ter cuidado.</segment>
    <segment id="32">De repente</segment>
    <segment id="33">, perdeu o equilibrio e foi</segment>
    <segment id="34">sese parar no chão.</segment>
    <segment id="35">Tem quatro meses e eu lembro dele todos os dias”</segment>
    <segment id="36">, conta a mãe segurando o choro.</segment>
    <segment id="37">Sensação de que não aconteceu
“</segment>
    <segment id="38">Se dependesse de mim</segment>
    <segment id="39">, nenhuma mãe passaria pelo que passei.</segment>
    <segment id="40">Às vezes não acredito no que aconteceu.</segment>
    <segment id="41">Vi meu filho brincando e</segment>
    <segment id="42">, de repente</segment>
    <segment id="43">, ele tinha morrido.</segment>
    <segment id="44">Acho que só não morri junto com ele</segment>
    <segment id="45">porque</segment>
    <segment id="46">porque tenho outro filho</segment>
    <segment id="47">, que tem 12 anos e ainda precisa muito de mim.</segment>
    <segment id="48">É uma história sofrida</segment>
    <segment id="49">, eu daria tudo para ter ele aqui comigo de novo.</segment>
    <segment id="50">Me pego com Deus para não desistir</segment>
    <segment id="51">, é triste demais.</segment>
    <segment id="52">Prefiro acreditar que em algum momento vou me encontrar com ele novamente”.</segment>
    <segment id="53">, diz Eliana.</segment>
    <segment id="54">Uma mensagem de conforto para todas</segment>
    <segment id="55">É assim que Márcio Victor define a nova música de trabalho da banda Psirico.</segment>
    <segment id="56">No clipe</segment>
    <segment id="57">, mulheres que vivem o drama real da perda dos filhos</segment>
    <segment id="58">, sob as mais diversas formas</segment>
    <segment id="59">, contam suas histórias.</segment>
    <segment id="60">“Quero que essas mães</segment>
    <segment id="61">, quando me vejam</segment>
    <segment id="62">, sintam que eu sou um pouco filho delas também.</segment>
    <segment id="63">Que tenham  o alento que tanto precisam em Deus.</segment>
    <segment id="64">Se dependesse da nação Psirico</segment>
    <segment id="65">, nenhuma delas passaria por isso</segment>
    <segment id="66">, masmas vamos</segment>
    <segment id="67">, ao menos</segment>
    <segment id="68">, levar um pouco de felicidade sempre”</segment>
    <segment id="69">, disse o cantor.</segment>
  </rst>
</analysis>