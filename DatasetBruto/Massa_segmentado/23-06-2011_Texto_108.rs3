  <rst>
    <segment id="1">Fluminense em busca da pontuação de campeão
RIO - Ao vencer a Portuguesa na última rodada</segment>
    <segment id="2">, o Fluminense deu um passo em busca dos nove pontos em três jogos.</segment>
    <segment id="3">A segunda etapa precisará ser cumprida neste domingo</segment>
    <segment id="4">, às 18h30m</segment>
    <segment id="5">, contra o Atlético-GO</segment>
    <segment id="6">, em Goiânia.</segment>
    <segment id="7">Por fim</segment>
    <segment id="8">, na próxima semana</segment>
    <segment id="9">, o Náutico será o adversário e o obstáculo na busca de uma arrancada que colocaria o time na parte de cima da tabela e traria mais tranquilidade para o primeiro clássico regional do ano no Brasileiro</segment>
    <segment id="10">, o Fla-Flu do centenário</segment>
    <segment id="11">, no dia 8 de julho</segment>
    <segment id="12">, no Engenhão.</segment>
    <segment id="13">Dois clássicos pela frente</segment>
    <segment id="14">A sonhada arrancada</segment>
    <segment id="15">sese faz necessária diante de adversários considerados mais fracos.</segment>
    <segment id="16">E serve para o acúmulo de pontos para o futuro próximo.</segment>
    <segment id="17">Depois do Flamengo</segment>
    <segment id="18">, o Fluminense enfrentará o Botafogo.</segment>
    <segment id="19">Serão dois clássicos seguidos e</segment>
    <segment id="20">, em tese</segment>
    <segment id="21">, jogos mais difíceis.
-</segment>
    <segment id="22">A nossa ambição serão a vitória e a busca destes nove pontos.</segment>
    <segment id="23">Já conseguimos três.</segment>
    <segment id="24">Isto nos daria mais de 60% dos pontos até agora</segment>
    <segment id="25">, uma pontuação de campeão - declarou o técnico Abel Braga.</segment>
    <segment id="26">O Fluminense terá um desfalque importante</segment>
    <segment id="27">, O capitão Fred sentiu dores na coxa direita</segment>
    <segment id="28">, recuperada recentemente de um estiramento</segment>
    <segment id="29">, e foi vetado por Abel.</segment>
    <segment id="30">Para o lugar de Fred</segment>
    <segment id="31">, o treinador poderá escalar Marcos Júnior ou Samuel.</segment>
    <segment id="32">O primeiro dispensa apresentações.</segment>
    <segment id="33">O segundo não conseguiu</segment>
    <segment id="34">, até agora</segment>
    <segment id="35">, fazer uma boa partida e</segment>
    <segment id="36">, mesmo durantes os treinos nas Laranjeiras</segment>
    <segment id="37">, não exibiu um bom futebol.</segment>
    <segment id="38">Abel acredita que a ansiedade tem atrapalhado o atacante de 21 anos</segment>
    <segment id="39">, que chegou ao Fluminense em 2011</segment>
    <segment id="40">, vindo das categorias de base do Internacional.</segment>
    <segment id="41">Até agora</segment>
    <segment id="42">, não marcou gol.
- Ele está ansioso para fazer logo um gol e espero que seja agora.</segment>
    <segment id="43">Se tranquilo é difícil fazer gol</segment>
    <segment id="44">, ansioso é mais ainda - explicou Abel.</segment>
    <segment id="45">Atlético-GO x Fluminense
Local: Estádio Serra Dourada</segment>
    <segment id="46">, em Goiânia
Horário: 18h30m</segment>
    <segment id="47">Atlético-GO: Márcio</segment>
    <segment id="48">, Marcos</segment>
    <segment id="49">, Gílson</segment>
    <segment id="50">, Gustavo e Eron</segment>
    <segment id="51">; Carlos</segment>
    <segment id="52">, Joílson</segment>
    <segment id="53">, Ernandes e Bida</segment>
    <segment id="54">; Marcão e Ricardo Bueno
Fluminense:</segment>
    <segment id="55">Diego Cavalieri</segment>
    <segment id="56">, Bruno</segment>
    <segment id="57">, Gum, Anderson e Carlinhos</segment>
    <segment id="58">;</segment>
    <segment id="59">Edinho</segment>
    <segment id="60">, Jean</segment>
    <segment id="61">, Wagner e Deco</segment>
    <segment id="62">; Wellington Nem e Samuel (Marcos Júnior)
Juiz: Paulo Cesar Oliveira (SP-Fifa)</segment>
