  <rst>
    <segment id="1">Obras de urbanização da Praia Grande</segment>
    <segment id="2">, em Arraial do Cabo</segment>
    <segment id="3">, são inauguradas nesta quinta-feira
RIO - Conhecida por suas águas cristalinas</segment>
    <segment id="4">, a Praia Grande</segment>
    <segment id="5">, em Arraial do Cabo</segment>
    <segment id="6">, está com um novo visual.</segment>
    <segment id="7">O governador Sérgio Cabral inaugura nesta quinta-feira as obras de urbanização da praia mais procurada de Arraial do Cabo.</segment>
    <segment id="8">A orla ganhou 12 quiosques padronizados</segment>
    <segment id="9">, ciclovia</segment>
    <segment id="10">, banheiros públicos e iluminação com fiação subterrânea.</segment>
    <segment id="11">Os frequentadores também terão acesso gratuito à internet.</segment>
    <segment id="12">O local será palco de um festival gastronômico que vai até domingo com vários shows.</segment>
    <segment id="13">Os novos equipamentos foram instalados no local onde funcionavam antigos quiosques</segment>
    <segment id="14">, que foram derrubados pela prefeitura.</segment>
    <segment id="15">O projeto acabou com o estacionamento irregular sobre as dunas e abriu um estacionamento público fora da área protegida.</segment>
    <segment id="16">Também foi construído um mirante</segment>
    <segment id="17">, escadarias de acesso à praia</segment>
    <segment id="18">, deques e paisagismo em toda a orla com plantas típicas de áreas de restinga.</segment>
    <segment id="19">Segundo o prefeito de Arraial do Cabo</segment>
    <segment id="20">, Wanderson Cardoso de Brito</segment>
    <segment id="21">, a urbanização da Praia Grande é o primeiro passo do plano de revitalização de toda a orla de Arraial do Cabo</segment>
    <segment id="22">, que há anos vem lutando contra a favelização que aumentou após o fechamento da Companhia Álcalis</segment>
    <segment id="23">, a principal indústria do município.</segment>
    <segment id="24">A nova orla recebeu o nome de Flávia Alessandra</segment>
    <segment id="25">, em homenagem a atriz que nasceu na cidade.</segment>
    <segment id="26">Ao longo da orla foram instalados aparelhos de ginástica com design moderno</segment>
    <segment id="27">, feito em inox e que poderá ser usado gratuitamente pela população.</segment>
    <segment id="28">De acordo com o secretário de Esporte</segment>
    <segment id="29">, Henrique Barreto</segment>
    <segment id="30">, este é o primeiro equipamento a ser instalado</segment>
    <segment id="31">, com este material.</segment>
    <segment id="32">Os equipamentos também serão instalados em outras praias.</segment>
    <segment id="33">As obras custaram cerca de R$ 7 milhões</segment>
    <segment id="34">, com recursos do Governo do Estado</segment>
    <segment id="35">, através do Programa de Apoio ao Desenvolvimento dos Municípios (Padem).</segment>
  </rst>
</analysis>