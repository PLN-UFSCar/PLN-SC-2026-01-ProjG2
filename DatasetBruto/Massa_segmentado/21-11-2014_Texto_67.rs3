    <segment id="1">Posto em Plataforma serve de enfeite</segment>
    <segment id="2">A unidade nГѓВЈo abre as portas hГѓВЎ cinco anos</segment>
    <segment id="3">A Unidade de EmergГѓВЄncia de Plataforma</segment>
    <segment id="4">, que completou trГѓВЄs dГѓВ©cadas de existГѓВЄncia em 2014</segment>
