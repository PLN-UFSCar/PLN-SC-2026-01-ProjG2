  <rst>
    <segment id="1">Por dentro do que rola no presídio</segment>
    <segment id="2">Ex-detento conta um pouco do que viu em duas penitenciárias</segment>
    <segment id="3">A equipe do MASSA!</segment>
    <segment id="4">conversou com um ex-presidiário</segment>
    <segment id="5">,  que ganhou a liberdade condicional há poucos meses após passar três anos na cadeia</segment>
    <segment id="6">, para saber</segment>
    <segment id="7">comocomo é o dia a dia no presídio.</segment>
    <segment id="8">Ele diz ter sido condenado injustamente.</segment>
    <segment id="9">A identidade e o crime pelo qual ficou preso foram preservados</segment>
    <segment id="10">porque</segment>
    <segment id="11">porque ele teme sofrer represálias.</segment>
    <segment id="12">“</segment>
    <segment id="13">Eles avisam que têm informantes e sabem o que a gente faz aqui fora”</segment>
    <segment id="14">, explica.</segment>
    <segment id="15">Ele já passou pela Penitenciária Lemos de Brito e pelo Presídio de Lauro de Freitas.</segment>
    <segment id="16">Pergunta -  Como é a chegada ao presídio?</segment>
    <segment id="17">Resposta - Qualquer um chega com medo.</segment>
    <segment id="18">O agente penitenciário te coloca dentro do pavilhão.</segment>
    <segment id="19">Lá, você é recebido pelo “linha de frente”</segment>
    <segment id="20">, que é o presidiário líder do pavilhão.</segment>
    <segment id="21">Nomeu, era o pessoal de Perna (Genilson Lima da Silva</segment>
    <segment id="22">, um dos chefões do tráfico na Bahia</segment>
    <segment id="23">, que está no presídio de segurança máxima de Catanduvas desde 2008).</segment>
    <segment id="24">Só o “linha de frente” pode andar armado.</segment>
    <segment id="25">P - Quais são as orientações dele?</segment>
    <segment id="26">R - Ele diz que é para você</segment>
    <segment id="27">sese comportar bem</segment>
    <segment id="28">, não procurar briga e buscar sua posição.</segment>
    <segment id="29">P - Que posição?
R - Andar com os presos que cometeram o mesmo crime que o seu.</segment>
    <segment id="30">Lá, fica todo mundo misturado.</segment>
    <segment id="31">P - Você sofreu algum tipo de perseguição?</segment>
    <segment id="32">R - Não</segment>
    <segment id="33">, porque</segment>
    <segment id="34">porque eu não usava drogas e procurei minha posição.</segment>
    <segment id="35">Os caras que vivem do crime sofrem marcação cerrada.</segment>
    <segment id="36">Qualquer coisa</segment>
    <segment id="37">, eles pensam que o cara é “alemão” (membro da facção criminosa rival).</segment>
    <segment id="38">P - O que o ‘linha de frente’ faz?</segment>
    <segment id="39">R - Ele manda em tudo.</segment>
    <segment id="40">Providencia a entrada de tudo que não poderia entrar no presídio e controla a venda.</segment>
    <segment id="41">Não faltam drogas</segment>
    <segment id="42">, celulares e todo tipo de comida.</segment>
    <segment id="43">É o “linha de frente” que conversa com o diretor do presídio sobre os problemas também.</segment>
    <segment id="44">Faz pressão para cuidar dos internos doentes</segment>
    <segment id="45">, por exemplo.</segment>
    <segment id="46">P - Qual o preço das coisas lá dentro?</segment>
    <segment id="47">R - É cinco vezes a mais do que aqui fora.</segment>
    <segment id="48">Um celular na Lemos de Brito é R$ 3 mil.</segment>
    <segment id="49">No presídio de Lauro de Freitas</segment>
    <segment id="50">, R$ 500</segment>
    <segment id="51">, masmas dá para comprar um chip de R$ 30 e alugar o telefone.</segment>
    <segment id="52">P - Onde os produtos são vendidos?</segment>
    <segment id="53">R - Uma cela</segment>
    <segment id="54">, que chamamos de barraca</segment>
    <segment id="55">, é transformada em um mercadinho.</segment>
    <segment id="56">P - E  as drogas?</segment>
    <segment id="57">R - O “linha de frente” deixa a venda a cargo dos jóqueis (caras que negociam a droga dentro dos presídios).</segment>
    <segment id="58">A maioria dos presos fica o dia inteiro usando.</segment>
    <segment id="59">Teve gente que já deu a mulher por causa da dívida.</segment>
    <segment id="60">Já ouvi dizer que um agente penitenciário deixava passar uma certa quantidade de drogas senão a cadeia virava</segment>
    <segment id="61">, haveria rebelião.</segment>
    <segment id="62">P - Dá para a cadeia funcionar sem o ‘linha de frente’?</segment>
    <segment id="63">R - Sem ele</segment>
    <segment id="64">,  é cada um por si.</segment>
    <segment id="65">Fica sem comando.</segment>
    <segment id="66">Mas é ele também que oprime os presos.</segment>
    <segment id="67">Se invocar e quiser a mulher de alguém</segment>
    <segment id="68">, ele estupra.</segment>
    <segment id="69">Se o presídio for com cela individual dá  para funcionar sem um líder.</segment>
    <segment id="70">P - Qual sua avaliação do presídio?</segment>
    <segment id="71">R - A Justiça é falha</segment>
    <segment id="72">porque</segment>
    <segment id="73">porque aplica um castigo</segment>
    <segment id="74">, masmas o cara continua praticando o crime de  lá de dentro</segment>
    <segment id="75">, passando as ordens por celular.</segment>
    <segment id="76">No presídio</segment>
    <segment id="77">, o bandido está mais seguro do que na rua.</segment>
    <segment id="78">P - O que foi mais difícil para você?</segment>
    <segment id="79">R - A saudade da família e ficar misturado com bandidos perigosos.</segment>
  </rst>
</analysis>