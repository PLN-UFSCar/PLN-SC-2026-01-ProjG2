  <rst>
    <segment id="1">Policiais são recebidos à bala</segment>
    <segment id="2">A ação dos bandidos aconteceu no Vale das Pedrinhas</segment>
    <segment id="3">A ousadia dos bandidos do Nordeste de Amaralina continua em alta</segment>
    <segment id="4">, apesar dos projetos para garantir a segurança no bairro.</segment>
    <segment id="5">Na tarde de quarta-feira</segment>
    <segment id="6">, 6, Vinícius Caetano de Jesus Pereira</segment>
    <segment id="7">, 19 anos</segment>
    <segment id="8">, foi preso em flagrante por tentativa de homicídio e formação de quadrilha</segment>
    <segment id="9">, após atirar contra seis policiais civis que tinham ido entregar uma intimação na Rua Antenor Costa Nuno.</segment>
    <segment id="10">Com Vinícius</segment>
    <segment id="11">, foi apreendido um revólver calibre 38.</segment>
    <segment id="12">Cinco outros suspeitos conseguiram fugir</segment>
    <segment id="13">, após efetuarem cerca de dez tiros contra os policiais da Delegacia do Nordeste.</segment>
    <segment id="14">Vinícius nega as acusações</segment>
    <segment id="15">, masmas a polícia suspeita que os atiradores sejam do mesmo bando do traficante Belisco.</segment>
    <segment id="16">Os bandidos atiraram contra os policiais civis em uma região conhecida</segment>
    <segment id="17">comocomo Serra Verde</segment>
    <segment id="18">, no Vale das Pedrinhas.</segment>
    <segment id="19">Os seis policiais chegaram até o local em duas viaturas</segment>
    <segment id="20">, uma com placa “fria” e outra padronizada.</segment>
    <segment id="21">Foram achadas cápsulas de revólver calibre 38 e pistola 380.</segment>
    <segment id="22">Vinícius tem passagens por furto quando era adolescente.</segment>
    <segment id="23">O revólver encontrado com ele estava com três munições deflagradas e duas intactas.</segment>
    <segment id="24">Ele foi preso em um bar</segment>
    <segment id="25">, após fugir.</segment>
    <segment id="26">Vinícius Caetano Pereira</segment>
    <segment id="27">, 19 anos</segment>
    <segment id="28">, nega ter participado da ação</segment>
    <segment id="29">, masmas foi preso pelo ataque aos agentes.</segment>
  </rst>
