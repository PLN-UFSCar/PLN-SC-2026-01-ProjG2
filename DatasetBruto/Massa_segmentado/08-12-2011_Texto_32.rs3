  <rst>
    <segment id="1">Assaltantes de veículos levam a pior</segment>
    <segment id="2">Os dois primeiros assumiram os roubos e os outros dois o tráfico
Carros</segment>
    <segment id="3">, motos e drogas.</segment>
    <segment id="4">Este foi o material apreendido com uma quadrilha baseada no bairro de Vida Nova</segment>
    <segment id="5">, em Lauro de Freitas (Grande Salvador).</segment>
    <segment id="6">Após investigar  roubos de veículos na região</segment>
    <segment id="7">, policiais civis da 34ª Delegacia Territorial (Portão) e militares da 81ª CIPM (Itinga) chegaram ao grupo.</segment>
    <segment id="8">Três homens foram presos e um menor foi apreendido.</segment>
    <segment id="9">Davi dos Santos Cruz</segment>
    <segment id="10">, 28 anos</segment>
    <segment id="11">, o “Cara Rosa”</segment>
    <segment id="12">, é apontado</segment>
    <segment id="13">comocomo um dos líderes do tráfico em Vida Nova e dono de cerca de 500 gramas de cocaína apreendida.</segment>
    <segment id="14">Paulo Henrique dos Santos Fonseca</segment>
    <segment id="15">, 24, o “Gordo”</segment>
    <segment id="16">, guardava a droga e administrava o negócio junto com Davi.</segment>
    <segment id="17">Rodrigo Vieira Gouveia</segment>
    <segment id="18">, 18, e o adolescente L.M.F.</segment>
    <segment id="19">, 16, eram os responsáveis por assaltar os veículos.</segment>
    <segment id="20">Os dois confessaram ter roubado mais de 36 carros  em Vilas do Atlântico e Salvador.</segment>
    <segment id="21">A polícia encontrou estacionados nas ruas de Vida Nova um Citroen C3</segment>
    <segment id="22">, um Volkswagen Gol</segment>
    <segment id="23">, um Fiat Doblô</segment>
    <segment id="24">, três motos Dafra de 50 cilindradas</segment>
    <segment id="25">, além de outro Gol alugado pelo bando.</segment>
    <segment id="26">“Davi e Paulo foram autuados por tráfico e Rodrigo por receptação”</segment>
    <segment id="27">, afirmou o titular da 34ª DT</segment>
    <segment id="28">, Cláudio Meirelles.</segment>
    <segment id="29">Ainda falta gente</segment>
    <segment id="30">Dois veículos encontrados com o grupo tinham a placa clonada.</segment>
    <segment id="31">A identificação verdadeira é a seguinte: JRL-6804 (Citroen C3) e JSQ-8800 (Doblô).</segment>
    <segment id="32">“Esses veículos eram usados para cometer outros delitos.</segment>
    <segment id="33">O grupo é formado por em média 10 elementos.</segment>
    <segment id="34">Estamos em busca do restante”</segment>
    <segment id="35">, ressaltou Cláudio Meireles.</segment>
    <segment id="36">Quem tiver alguma informação sobre o bando pode ligar para os números 3379-6754 e  3235-0000.</segment>
    <segment id="37">Apenas Davi já tinha passagem na polícia.</segment>
    <segment id="38">Ele ficou preso 1 ano e 6 meses por assalto a transportadora de valores.</segment>
    <segment id="39">Há um mês ele sofreu uma tentativa de homicídio em Pau da Lima</segment>
    <segment id="40">, quando levou três tiros no abdômen</segment>
    <segment id="41">, de três homens que chegaram de carro.</segment>
  </rst>
</analysis>