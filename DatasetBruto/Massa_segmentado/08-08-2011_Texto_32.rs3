  <rst>
    <segment id="1">Carro da PM mata criança</segment>
    <segment id="2">Viatura perde controle e atinge mãe e filha.</segment>
    <segment id="3">Menina morreu na hora</segment>
    <segment id="4">A técnica em enfermagem do Hospital Santo Antônio da Osid</segment>
    <segment id="5">, Laildes dos Santos Lima</segment>
    <segment id="6">, 34, e a filha Vanessa dos Santos Cardoso Lima</segment>
    <segment id="7">, 5, iam para uma festa quando foram atingidas ontem por uma viatura da 9ª CIPM (placa NAD 8142 e número 9.0911) na Rua José Tibério</segment>
    <segment id="8">, em Boa Vista de São Caetano.</segment>
    <segment id="9">A menina morreu na hora.</segment>
    <segment id="10">Laildes foi levada para o HGE com um corte na nuca e escoriações.</segment>
    <segment id="11">Segundo familiares</segment>
    <segment id="12">, ela perguntava pela filha</segment>
    <segment id="13">, masmas até a noite de ontem não sabia da morte da menina.</segment>
    <segment id="14">Na viatura</segment>
    <segment id="15">, que  era dirigida pelo soldado PM Jacilando Silva de Araújo</segment>
    <segment id="16">, estavam também o sargento PM Valdomiro Almeida da Silva</segment>
    <segment id="17">, o  patrulheiro soldado José Carlos de Freitas e Cícera Sabino Trajano</segment>
    <segment id="18">, que iria prestar queixa na 4ª DT (São Caetano) .</segment>
    <segment id="19">“</segment>
    <segment id="20">A  criança foi jogada para cima e bateu a cabeça na pedra.</segment>
    <segment id="21">Elas estavam no passeio”</segment>
    <segment id="22">, contou uma testemunha que não informou o nome.</segment>
    <segment id="23">Versão do soldado Freitas:</segment>
    <segment id="24">Motorista apagou</segment>
    <segment id="25">A cerca de 200 metros do local onde as vítimas foram atingidas há um quebra-molas.</segment>
    <segment id="26">A velocidade máxima permitida é  40 km/h.</segment>
    <segment id="27">Até as 21h</segment>
    <segment id="28">, apenas o soldado José Carlos de Freitas e Cícera Trajano haviam prestado depoimento.</segment>
    <segment id="29">“</segment>
    <segment id="30">O soldado disse que o motorista desmaiou ao volante e que mãe e filha estavam na pista”</segment>
    <segment id="31">, falou o delegado do plantão metropolitano Luiz Coutinho.</segment>
    <segment id="32">“</segment>
    <segment id="33">Se ele desmaiou</segment>
    <segment id="34">, como</segment>
    <segment id="35">como saiu andando da viatura depois do acidente?</segment>
    <segment id="36">”</segment>
    <segment id="37">, questionou um morador.</segment>
  </rst>
</analysis>