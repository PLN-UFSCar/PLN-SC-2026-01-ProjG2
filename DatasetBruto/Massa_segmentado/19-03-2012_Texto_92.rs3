  <rst>
    <segment id="1">Leão tira onda com Superman</segment>
    <segment id="2">Vitória é superior em clássico no Barradão e derrota o Bahia por 3 a 2</segment>
    <segment id="3">O Ba-Vi de ontem</segment>
    <segment id="4">, no Barradão</segment>
    <segment id="5">, foi do jeito que a galera gosta.</segment>
    <segment id="6">Bem diferente daquele da 8ª rodada</segment>
    <segment id="7">, que teve empate sem gols</segment>
    <segment id="8">, Vitória e Bahia fizeram dois gols cada nos 25 primeiros minutos de jogo.</segment>
    <segment id="9">No final</segment>
    <segment id="10">, o Leão levou a melhor: 3 a 2.

Desta vez</segment>
    <segment id="11">, Toninho Cerezo não foi precavido</segment>
    <segment id="12">comocomo no primeiro clássico</segment>
    <segment id="13">, quando escalou quatro volantes.</segment>
    <segment id="14">E foram justamente os homens do meio que garantiram o triunfo.</segment>
    <segment id="15">Daqueles que jogam na “meiuca”</segment>
    <segment id="16">, apenas Geovanni fez gol.</segment>
    <segment id="17">Entretanto</segment>
    <segment id="18">, Uelliton</segment>
    <segment id="19">, Michel -que jogou muito - e Pedro Ken foram os destaques do Leão.</segment>
    <segment id="20">Todos os gols saíram no primeiro tempo.</segment>
    <segment id="21">O rubro-negro abriu o placar rapidinho</segment>
    <segment id="22">, logo aos cinco minutos.</segment>
    <segment id="23">Nino cruzou para o artilheiro Neto Baiano marcar de cabeça.</segment>
    <segment id="24">Dois minutos depois</segment>
    <segment id="25">, Gabriel Paulista também usou a “cuca” para ampliar.</segment>
    <segment id="26">Porém, o tricolor não queria ficar no “preju” e diminuiu com Souza</segment>
    <segment id="27">, cobrando pênalti</segment>
    <segment id="28">, aos 20.</segment>
    <segment id="29">O empate veio aos 22</segment>
    <segment id="30">,  com Gabriel</segment>
    <segment id="31">, que chutou cruzado.</segment>
    <segment id="32">Só que o Leão virou com um golaço de falta marcado por Gevanni.</segment>
    <segment id="33">O segundo tempo também começou  fervendo.</segment>
    <segment id="34">Neto Baiano tentou fazer outro de cabeça</segment>
    <segment id="35">, masmas Marcelo Lomba fez uma grande defesa.</segment>
    <segment id="36">O artilheiro saiu de campo sentindo e deu lugar a Dinei</segment>
    <segment id="37">, que teve chances de aumentar o placar</segment>
    <segment id="38">, masmas pecou nas finalizações.</segment>
    <segment id="39">No Bahia</segment>
    <segment id="40">, Ávine entrou para tentar imitar o gol de Geovanni</segment>
    <segment id="41">, masmas Renan impediu com uma boa defesa.</segment>
    <segment id="42">E ficou nisso: 3 a 2 e gozação rubro-negra.</segment>
    <segment id="43">Cerezo exalta futebol do time e elogia Nino Paraíba</segment>
    <segment id="44">O técnico do Vitória</segment>
    <segment id="45">, Toninho Cerezo</segment>
    <segment id="46">, confessou  que teve receio quando o Bahia empatou o jogo.</segment>
    <segment id="47">“</segment>
    <segment id="48">Depois do empate eu pensei que a nossa equipe iria sentir</segment>
    <segment id="49">, masmas nós continuamos na mesma pegada.</segment>
    <segment id="50">Acho que isso aí foi uma coisa fundamental.</segment>
    <segment id="51">O nosso segundo tempo foi excelente.</segment>
    <segment id="52">Com certeza</segment>
    <segment id="53">, bem melhor que o Bahia”</segment>
    <segment id="54">, disse o treinador.</segment>
    <segment id="55">Ele ainda aproveitou para elogiar a correria do lateral-direito Nino Paraíba</segment>
    <segment id="56">, que deu passe para o primeiro gol do rubro-negro.</segment>
    <segment id="57">“</segment>
    <segment id="58">O Nino aproveitou o que ele tem de melhor</segment>
    <segment id="59">, que é a sua dinâmica.</segment>
    <segment id="60">E também teve excelentes cruzamentos.</segment>
    <segment id="61">Ele ocupou bem aquele espaço na direita”</segment>
    <segment id="62">, pontuou.</segment>
  </rst>
</analysis>