  <rst>
    <segment id="1">Livros</segment>
    <segment id="2">, os melhores parceiros na rua</segment>
    <segment id="3">Alberto Pinho de Campos nГѓВЈo perde o gosto pela leitura.</segment>
    <segment id="4">Ele vive em ponto de buzu
Alberto Pinho de Campos</segment>
    <segment id="5">, 60 anos</segment>
    <segment id="6">, jГѓВЎ se</segment>
    <segment id="7">se tornou um personagem de Stella Maris.</segment>
    <segment id="8">Desde janeiro deste ano</segment>
    <segment id="9">, ele se</segment>
    <segment id="10">se instalou em um ponto de ГѓВґnibus da  Alameda Dilson Jatahy Fonseca e dedica a maior parte do tempo ГѓВ  leitura</segment>
    <segment id="11">, em especial de livros tГѓВ©cnicos de quГѓВ­mica</segment>
    <segment id="12">, fГѓВ­sica e desenho.
SimpГѓВЎtico e gentil com quem passa perto de sua Гўв‚¬Е“casaГўв‚¬</segment>
    <segment id="13">, Alberto pede a quem quiser colaborar com ele que leve alimentos e livros.</segment>
    <segment id="14">Diz que nГѓВЈo quer sair de onde estГѓВЎ a nГѓВЈo ser que seja para uma casa prГѓВіpria em um lugar nГѓВЈo muito distante.</segment>
    <segment id="15">Гўв‚¬Е“JГѓВЎ rodei essa cidade toda e jГѓВЎ morei atГѓВ© em Arembepe</segment>
    <segment id="16">, masmas decidi ficar</segment>
    <segment id="17">, porque</segment>
    <segment id="18">porque achei aqui um lugar seguro e tranquilo.</segment>
    <segment id="19">NinguГѓВ©m mexe comigoГўв‚¬</segment>
    <segment id="20">, diz o coroa</segment>
    <segment id="21">, que mesmo morando nas ruas desde 1975</segment>
    <segment id="22">, ainda guarda noГѓВ§ГѓВµes de</segment>
    <segment id="23">comocomo organizar uma casa.</segment>
    <segment id="24">No espaГѓВ§o que ocupa</segment>
    <segment id="25">, tem o local de guardar as roupas</segment>
    <segment id="26">, material de limpeza e atГѓВ© um sofГѓВЎ improvisado para receber as visitas.</segment>
    <segment id="27">Alberto conta que ГѓВ©  formado em desenho industrial pelo Senai e  jГѓВЎ trabalhou em grandes empresas da cidade.</segment>
    <segment id="28">Afirma ter sido desenhista do Instituto de OrientaГѓВ§ГѓВЈo de  Cooperativas Habitacionais da Bahia (Inocoop) e depois  da extinta FundaГѓВ§ГѓВЈo do Pelourinho</segment>
    <segment id="29">, onde assumiu o cargo de chefe de setor.</segment>
    <segment id="30">Гўв‚¬Е“Foram as perseguiГѓВ§ГѓВµes no meu trabalho e a de um senhor que minha mГѓВЈe colocou no mundo que me transformaram em um morador de rua.</segment>
    <segment id="31">Tenho casa</segment>
    <segment id="32">, herdei bens da minha famГѓВ­lia</segment>
    <segment id="33">, masmas estou aqui.</segment>
    <segment id="34">JГѓВЎ mandei cinco cartas para o ExГѓВ©rcito solicitando apoioГўв‚¬</segment>
    <segment id="35">, diz o morador de rua.</segment>
    <segment id="36">Apoio da galera</segment>
    <segment id="37">ГѓВ© tudo
Mesmo ocupando um ponto de ГѓВґnibus em uma das alamedas mais nobres do bairro de Stella Maris</segment>
    <segment id="38">, parece que Alberto Pinho caiu nas graГѓВ§as da comunidade.</segment>
    <segment id="39">SГѓВЈo os moradores que levam para ele alimentos para as refeiГѓВ§ГѓВµes diГѓВЎrias</segment>
    <segment id="40">, alГѓВ©m das doaГѓВ§ГѓВµes de roupas e dos livros que ele tanto gosta.</segment>
    <segment id="41">Гўв‚¬Е“O pessoal aqui ГѓВ© bacana.</segment>
    <segment id="42">Todo dia chega alguГѓВ©m</segment>
    <segment id="43">,  traz alguma coisa para eu comer ou um livro para mim.</segment>
    <segment id="44">Acho que eles gostam de mimГўв‚¬</segment>
    <segment id="45">, diz Alberto.</segment>
    <segment id="46">Ao ser questionado</segment>
    <segment id="47">sese quer apoio de algum ГѓВіrgГѓВЈo municipal</segment>
    <segment id="48">, ele ГѓВ© enfГѓВЎtico.</segment>
    <segment id="49">Гўв‚¬Е“Deus</segment>
    <segment id="50">ГѓВ© mais ir para um abrigo!</segment>
    <segment id="51">Aquilo lГѓВЎ</segment>
    <segment id="52">ГѓВ© um inferno e muitos que estГѓВЈo lГѓВЎ gostam de ter relaГѓВ§ГѓВµes pederastas.</segment>
    <segment id="53">Eu nГѓВЈo gosto disso</segment>
    <segment id="54">, nГѓВЈoГўв‚¬</segment>
    <segment id="55">, afirma.</segment>
    <segment id="56">Dividindo a falta de lar</segment>
    <segment id="57">Гўв‚¬Е“Sou um artista.</segment>
    <segment id="58">Tenho forГѓВ§a para trabalhar</segment>
    <segment id="59">, sГѓВі preciso de um apoio.</segment>
    <segment id="60">Mas ninguГѓВ©m quer ajudar um morador de ruaГўв‚¬. ГѓвЂ° assim que JosГѓВ©</segment>
    <segment id="61">Raimundo de Souza</segment>
    <segment id="62">, 46 anos</segment>
    <segment id="63">, faz uma autoavaliaГѓВ§ГѓВЈo da sua situaГѓВ§ГѓВЈo.</segment>
    <segment id="64">HГѓВЎ trГѓВЄs meses</segment>
    <segment id="65">, ele divide o espaГѓВ§o do ponto de ГѓВґnibus</segment>
    <segment id="66">, na Alameda Dilson Jatahy Fonseca</segment>
    <segment id="67">, em Stella Maris</segment>
    <segment id="68">, com Alberto Pinho</segment>
    <segment id="69">, o morador de rua leitor.</segment>
    <segment id="70">Assim como</segment>
    <segment id="71">como Alberto</segment>
    <segment id="72">, JosГѓВ©</segment>
    <segment id="73">Raimundo tem famГѓВ­lia e casa prГѓВіpria.</segment>
    <segment id="74">Гўв‚¬Е“Meus parentes moram aqui perto</segment>
    <segment id="75">, em SГѓВЈo CristГѓВіvГѓВЈo.</segment>
    <segment id="76">Eu tenho um irmГѓВЈ</segment>
    <segment id="77">, EdnГѓВ©ia Pereira Souza</segment>
    <segment id="78">, que ГѓВ© atГѓ</segment>
    <segment id="79">В© juГѓВ­za</segment>
    <segment id="80">, masmas devido</segment>
    <segment id="81">ГѓВ  perseguiГѓВ§ГѓВЈo vim parar na ruaГўв‚¬</segment>
    <segment id="82">, conta para em seguida completar:</segment>
    <segment id="83">Гўв‚¬Е“Eu atГѓ</segment>
    <segment id="84">В© jГѓВЎ tive um filho</segment>
    <segment id="85">, prefiro dizer que nГѓВЈo tenho mais.</segment>
    <segment id="86">Quem vai querer ter um pai morador de rua?</segment>
    <segment id="87">SГѓВі queria que ele soubesse que sou um artista de valor</segment>
    <segment id="88">, masmas as pessoas nГѓВЈo querem pagar por minhas obrasГўв‚¬</segment>
    <segment id="89">, lamenta.</segment>
