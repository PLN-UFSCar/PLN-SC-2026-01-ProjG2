  <rst>
    <segment id="1">Jogadores do Fluminense</segment>
    <segment id="2">sese calam nas Laranjeiras
RIO - Depois da estrondosa derrota de 3 a 0 para o Bahia</segment>
    <segment id="3">, que estava na zona de rebaixamento</segment>
    <segment id="4">, silêncio nas Laranjeiras.</segment>
    <segment id="5">Na reapresentação</segment>
    <segment id="6">, os jogadores do Fluminense não quiseram dar entrevistas.</segment>
    <segment id="7">Mas nem é preciso falar para saber que há pouco tempo para corrigir os erros da defesa</segment>
    <segment id="8">, meio-campo e ataque para reiniciar uma nova sequência de vitórias a partir desta quarta-feira</segment>
    <segment id="9">, contra o Avaí</segment>
    <segment id="10">, no Engenhão.</segment>
    <segment id="11">PAROU:</segment>
    <segment id="12">Fluminense lamenta erros que interromperam reação

BLOG: 'Orgulho de Ser Tricolor'</segment>
    <segment id="13">, o blog do torcedor do Fluminense</segment>
    <segment id="14">Na prática</segment>
    <segment id="15">, o técnico Abel Braga terá apenas esta terça-feira para treinar e tentar corrigir os erros.</segment>
    <segment id="16">No treino desta segunda entre reservas e juniores</segment>
    <segment id="17">, o Abel pôde observar a evolução dos jogadores recuperados recentemente de lesões:</segment>
    <segment id="18">Deco, Diguinho</segment>
    <segment id="19">, Valencia e Matheus Carvalho.</segment>
    <segment id="20">Na última sexta-feira</segment>
    <segment id="21">, o treinador disse que</segment>
    <segment id="22">, entre Diguinho e Deco</segment>
    <segment id="23">, um deverá ir para o banco nesta quarta e a tendência é relacionar Deco.

- Tenho que voltar com eles aos poucos e para quarta-feira a tendência é o Deco no banco - disse Abel.</segment>
    <segment id="24">O meia tem treinado bem e parece estar plenamente recuperado.</segment>
    <segment id="25">Mas o destaque</segment>
    <segment id="26">, como</segment>
    <segment id="27">como vem acontecendo há alguns treinos e jogos</segment>
    <segment id="28">, foi Rafael Moura</segment>
    <segment id="29">, que ontem marcou até um gol de bicicleta.</segment>
    <segment id="30">Para o lugar de Gum</segment>
    <segment id="31">, expulso contra o Bahia</segment>
    <segment id="32">, Abel deverá pôr Digão.</segment>
    <segment id="33">O Fluminense repetiu a sina de perder pontos para times ameaçados.</segment>
    <segment id="34">E Avaí e Atlético</segment>
    <segment id="35">, próximos adversários</segment>
    <segment id="36">, estão na zona de rebaixamento.</segment>
    <segment id="37">O clube reduziu o preço dos ingressos para R$ 30</segment>
    <segment id="38">, Setor Leste Superior</segment>
    <segment id="39">, e R$ 25</segment>
    <segment id="40">, Leste Inferior e Norte.</segment>
  </rst>
