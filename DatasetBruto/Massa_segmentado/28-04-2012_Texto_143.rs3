  <rst>
    <segment id="1">Donato: o gigante salvador</segment>
    <segment id="2">Com gol no final do jogo contra o Bode</segment>
    <segment id="3">, zagueiro bota o tricolor na final
Foi sofrido</segment>
    <segment id="4">, masmas o Bahia está na final do Baianão.</segment>
    <segment id="5">Com um gol salvador do zagueiro-artilheiro Rafael Donato</segment>
    <segment id="6">, o tricolor derrotou o Vitória da Conquista em Pituaçu</segment>
    <segment id="7">, na tarde de ontem</segment>
    <segment id="8">, por 1 a 0</segment>
    <segment id="9">, e enfrentará o Vitória na grande decisão.</segment>
    <segment id="10">A maioria dos torcedores já sacrificava Falcão por ter escalado o lateral Coelho – que sentiu a coxa e deixou o campo aos 20 do primeiro tempo – e não ter levado Madson para o banco.</segment>
    <segment id="11">O volante Fabinho entrou</segment>
    <segment id="12">, masmas não cumpriu bem a função.</segment>
    <segment id="13">Mesmo assim</segment>
    <segment id="14">, o Esquadrão foi para cima</segment>
    <segment id="15">, masmas  não adiantou: 0 a 0 no primeiro tempo.</segment>
    <segment id="16">Na etapa final</segment>
    <segment id="17">, a tensão aumentava a cada minuto a menos de jogo.</segment>
    <segment id="18">Mais ainda quando Maurício Pantera recebeu cruzamento</segment>
    <segment id="19">, chutou na trave e</segment>
    <segment id="20">, no rebote</segment>
    <segment id="21">, mandou para fora.</segment>
    <segment id="22">A chance perdida pelo Bode deixou a torcida tricolor gelada.</segment>
    <segment id="23">Porém, aos 44</segment>
    <segment id="24">, Gabriel cruzou na área e o herói Rafael Donato acalmou os tricolores:

cabeceio no canto para decretar a classificação: 1 a 0.</segment>
  </rst>
