  <rst>
    <segment id="1">Seu Maxixe no MartagГѓВЈo</segment>
    <segment id="2">Gesteira</segment>
    <segment id="3">Banda sertaneja visita crianГѓВ§as com cГѓВўncer e lanГѓВ§a o projeto Гўв‚¬ЛњSou Retado</segment>
    <segment id="4">, Seja TambГѓВ©m</segment>
    <segment id="5">Nada de ficar em leitos frios de hospitais</segment>
    <segment id="6">, nem das temidas agulhas.</segment>
    <segment id="7">Na manhГѓВЈ de ontem</segment>
    <segment id="8">,  parte das   100 crianГѓВ§as do setor de oncologia do Hospital MartagГѓВЈo Gesteira</segment>
    <segment id="9">,  no TororГѓВі</segment>
    <segment id="10">, pularam</segment>
    <segment id="11">, cantaram e sorriram ao som da banda</segment>
    <segment id="12">Seu  Maxixe e das brincadeiras da cantora GilmelГѓВўndia.</segment>
    <segment id="13">A aГѓВ§ГѓВЈo  deu inГѓВ­cio  a Campanha Гўв‚¬Е“Sou Retado</segment>
    <segment id="14">, Seja TambГѓВ©mГўв‚¬</segment>
    <segment id="15">, da rede de lanchonete Sandwich Hall</segment>
    <segment id="16">, que chama atenГѓВ§ГѓВЈo para o dia 27</segment>
    <segment id="17">, no qual diversos artistas estarГѓВЈo nas unidades da rede</segment>
    <segment id="18">, colaborando para venda do Гўв‚¬Е“Retado BurguerГўв‚¬ cujo a  renda</segment>
    <segment id="19">, nesse dia</segment>
    <segment id="20">, serГѓВЎ destinada  para o MartagГѓВЈo.</segment>
    <segment id="21">Ao som de sucessos da banda e de mГѓВєsicas que estГѓВЈo bombando</segment>
    <segment id="22">, as crianГѓВ§as</segment>
    <segment id="23">, pais e  funcionГѓВЎrios aprovaram a iniciativa e comemoraram o momento de descontraГѓВ§ГѓВЈo.</segment>
    <segment id="24">Com celulares  em mГѓВЈos a galerinha registrou todo o show exclusivo.</segment>
    <segment id="25">Contente</segment>
    <segment id="26">, Iasmyn Alves</segment>
    <segment id="27">, 9 anos</segment>
    <segment id="28">, comemorava a visita.</segment>
    <segment id="29">Гўв‚¬Е“Gosto de forrГѓВі</segment>
    <segment id="30">, masmas nunca fui ao show</segment>
    <segment id="31">, atГѓВ© agora (ontem).</segment>
    <segment id="32">Cantei</segment>
    <segment id="33">, tirei fotos e agora volto feliz para  fazer meu tratamento de quimioterapiaГўв‚¬</segment>
    <segment id="34">, diz.</segment>
    <segment id="35">JГѓВЎ o vocalista do Seu Maxixe</segment>
    <segment id="36">, Berguinho</segment>
    <segment id="37">, quer repetir a dose.</segment>
    <segment id="38">Гўв‚¬Е“Ficamos gratificados em trazer alegria.</segment>
    <segment id="39">Queremos  voltarГўв‚¬</segment>
    <segment id="40">, revela.</segment>
    <segment id="41">Grana jГѓВЎ tem destino certo</segment>
    <segment id="42">Com 5 mil atendimentos  infantis  mensais</segment>
    <segment id="43">, destes 70% sГѓВЈo  cirurgias  e 30%  clГѓВ­nicos</segment>
    <segment id="44">,  o Superintendente do MartagГѓВЈo Gesteira</segment>
    <segment id="45">, Carlos Emanuel Melo</segment>
    <segment id="46">, observa a  iniciativa com animaГѓВ§ГѓВЈo</segment>
    <segment id="47">, jГѓВЎ que a instituiГѓВ§ГѓВЈo nГѓВЈo tem verba suficiente para alguns investimentos necessГѓВЎrios para humanizaГѓВ§ГѓВЈo.</segment>
    <segment id="48">Гўв‚¬Е“Usaremos esse valor doado em aГѓВ§ГѓВµes  para  melhorar o  conforto dos acompanhantes</segment>
    <segment id="49">, adquirir mais peГѓВ§as de enxoval e contratar mais aГѓВ§ГѓВµes lГѓВєdicas para nosso pacientes e parentesГўв‚¬</segment>
    <segment id="50">, revela.</segment>
    <segment id="51">Ajuda bem-vinda</segment>
    <segment id="52">Em 2011</segment>
    <segment id="53">, a campanha conseguiu arrecadar cerca de  14 mil reais</segment>
    <segment id="54">, que foram utilizados na manutenГѓВ§ГѓВЈo da unidade de Neuro Oncologia PediГѓВЎtrica do hospital.</segment>
    <segment id="55">Neste ano</segment>
    <segment id="56">, sГѓВ©timo ediГѓВ§ГѓВЈo da aГѓВ§ГѓВЈo - hГѓВЎ dois anos de parceria com MartagГѓВЈo Gesteira -</segment>
    <segment id="57">, toda a renda adquirida na aГѓВ§ГѓВЈo serГѓВЎ revertida para melhor acomodaГѓВ§ГѓВЈo dos parentes dos pacientes</segment>
    <segment id="58">, atravГѓВ©s da compra de cadeiras reclinГѓВЎveis e acolchoadas para os cerca de 120 leitos.</segment>
    <segment id="59">AtГѓВ© lГѓВЎ</segment>
    <segment id="60">, quem faz a alegria sГѓВЈo os artistas.</segment>
  </rst>
