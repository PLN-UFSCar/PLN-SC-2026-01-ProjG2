  <rst>
    <segment id="1">Messi é o novo reforço... da torcida
Campeão brasileiro de 88 vai a Barcelona e presenteia craque com camisa do Bahia</segment>
    <segment id="2">Quem nunca imaginou em ver um dos maiores jogadores da atualidade com a camisa do clube do coração?</segment>
    <segment id="3">É mesmo o sonho de qualquer torcedor.</segment>
    <segment id="4">O craque Messi</segment>
    <segment id="5">, do Barcelona</segment>
    <segment id="6">, duas vezes melhor do mundo pela Fifa e favorito ao tricampeonato</segment>
    <segment id="7">, realizou a vontade da torcida do Esquadrão e posou para foto com o manto  tricolor.</segment>
    <segment id="8">Porém, para tristeza dos brasileiros</segment>
    <segment id="9">, o atacante argentino não vai defender as cores do Bahia.</segment>
    <segment id="10">Foi uma camisa de presente</segment>
    <segment id="11">, dada por João Marcelo</segment>
    <segment id="12">, zagueiro campeão brasileiro de  88</segment>
    <segment id="13">, que passou 20 dias do mês de outubro no CT do Barça</segment>
    <segment id="14">, a convite de Daniel Alves.</segment>
    <segment id="15">“</segment>
    <segment id="16">Ele é humilde</segment>
    <segment id="17">, tranquilão.</segment>
    <segment id="18">Fiz umas brincadeiras e</segment>
    <segment id="19">, depois que entreguei a camisa</segment>
    <segment id="20">, ele agradeceu bastante e foi o próprio quem sugeriu que eu tirasse a foto”</segment>
    <segment id="21">, contou João</segment>
    <segment id="22">, afirmando que Messi já conhecia o Bahia pela proximidade com Daniel Alves</segment>
    <segment id="23">, antes de sonhar com ele no Fazendão: “Do rebaixamento pelo menos ele salvava a gente”.</segment>
    <segment id="24">A longa visita também serviu</segment>
    <segment id="25">comocomo estágio.</segment>
    <segment id="26">“Foi uma experiência incrível.</segment>
    <segment id="27">Conversei sobre futebol com muita gente</segment>
    <segment id="28">, inclusive com o Guardiola (técnico do Barça).</segment>
    <segment id="29">Ele conhece do assunto”</segment>
    <segment id="30">, relatou o ex-jogador</segment>
    <segment id="31">, que jura ter visto alguns dos segredos para o clube ter</segment>
    <segment id="32">sese tornado o melhor time do mundo:</segment>
    <segment id="33">“Eles treinam de forma diferente.</segment>
    <segment id="34">O interessante é que os jogadores não fazem musculação</segment>
    <segment id="35">, a não ser quem precisa.</segment>
    <segment id="36">Pode ver que eles são muito leves.</segment>
    <segment id="37">Além disso</segment>
    <segment id="38">, é trabalho com bola o tempo todo</segment>
    <segment id="39">, mesmo físico”.</segment>
  </rst>
</analysis>