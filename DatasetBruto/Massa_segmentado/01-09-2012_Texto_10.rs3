  <rst>
    <segment id="1">Bandidos fazem arrast횄짙o na Linha Vermelha</segment>
    <segment id="2">, na Baixada
RIO - Cinco bandidos armados fizeram um arrast횄짙o na noite deste s횄징bado na Linha Vermelha</segment>
    <segment id="3">, pr횄쨀ximo</segment>
    <segment id="4">횄혻 divisa de Duque de Caxias e S횄짙o Jo횄짙o de Meriti</segment>
    <segment id="5">, na Baixada.</segment>
    <segment id="6">De acordo com a PM</segment>
    <segment id="7">, tr횄짧s ve횄짯culos foram roubados.</segment>
    <segment id="8">Policiais do Batalh횄짙o de Vias Expressas (BPVE) foram acionados</segment>
    <segment id="9">, masmas os bandidos fugiram.</segment>
    <segment id="10">O arrast횄짙o aconteceu por volta das 20h15m</segment>
    <segment id="11">, na pista sentido Centro.</segment>
    <segment id="12">Segundo a PM</segment>
    <segment id="13">, os ladr횄쨉es estavam num Gol preto</segment>
    <segment id="14">, quando desceram na pista</segment>
    <segment id="15">, na altura da comunidade da Prainha</segment>
    <segment id="16">, e abordaram os motoristas.</segment>
    <segment id="17">O caso</segment>
    <segment id="18">caso est횄징 sendo registrado na 59횂짧 DP (Duque de Caxias).</segment>
    <segment id="19">E o policiamento est횄징 refor횄짠ado naquele trecho da Linha Vermelha</segment>
    <segment id="20">, informou o BPVE.</segment>
    <segment id="21">No in횄짯cio da tarde</segment>
    <segment id="22">, policiais do 22횂쨘 BPM (Mar횄짤)</segment>
    <segment id="23">j횄징 tinham refor횄짠ado a seguran횄짠a na Avenida Brasil</segment>
    <segment id="24">, na altura da passarela 9</segment>
    <segment id="25">, e na Linha Vermelha</segment>
    <segment id="26">, nos acessos 횄혻 favela Nova Holanda</segment>
    <segment id="27">, para evitar que as vias fossem novamente fechadas</segment>
    <segment id="28">, como</segment>
    <segment id="29">como aconteceu pela manh횄짙</segment>
    <segment id="30">, quando moradores do Complexo da Mar횄짤 realizaram um protesto contra a횄짠횄쨉es da Pol횄짯cia Militar no conjunto de favelas.</segment>
    <segment id="31">Segundo o Centro de Opera횄짠횄쨉es da prefeitura do Rio</segment>
    <segment id="32">, a pista sentido Centro da Linha Vermelha ficou totalmente fechada por cerca de 20 minutos na altura do Batalh횄짙o da Mar횄짤.</segment>
    <segment id="33">O grupo invadiu a pista e chegou a atear fogo em objetos</segment>
    <segment id="34">, com o intuito de bloquear a via.</segment>
    <segment id="35">Segundo testemunhas</segment>
    <segment id="36">, os manifestantes tamb횄짤m atiraram pedras nos ve횄짯culos que passavam pela Linha Vermelha.</segment>
    <segment id="37">Um blindado da PM teve de ir ao local para dispersar os manifestantes.</segment>
    <segment id="38">O tr횄짖nsito ficou lento sentido</segment>
    <segment id="39">Centro da Linha Vermelha.</segment>
    <segment id="40">As reten횄짠횄쨉es chegaram at횄짤</segment>
    <segment id="41">a altura da Infraero</segment>
    <segment id="42">, e, no sentido Baixada</segment>
    <segment id="43">, at횄짤 a altura da Linha Amarela.</segment>
    <segment id="44">Em seguida</segment>
    <segment id="45">, os manifestantes</segment>
    <segment id="46">sese deslocaram para a Avenida Brasil.</segment>
    <segment id="47">O grupo incendiou caixotes de madeira para interditar a pista lateral</segment>
    <segment id="48">, sentido Zona Oeste.</segment>
    <segment id="49">Por cerca de 10 minutos</segment>
    <segment id="50">, a via ficou fechada na altura de Ramos.</segment>
    <segment id="51">Os manifestantes ainda ocuparam a passarela 9 da via.</segment>
    <segment id="52">Os manifestantes protestavam contra uma a횄짠횄짙o do Batalh횄짙o de Opera횄짠횄쨉es Especiais (Bope) realizada na comunidade neste s횄징bado.</segment>
    <segment id="53">Na a횄짠횄짙o</segment>
    <segment id="54">, dois suspeitos foram baleados e acabaram morrendo.</segment>
    <segment id="55">Fabricio de Souza Melo e Diones Nunes da Silva</segment>
    <segment id="56">, ambos de 25 anos</segment>
    <segment id="57">, chegaram a ser levados para o Hospital Geral de Bonsucesso.</segment>
    <segment id="58">Eles deram entrada no hospital</segment>
    <segment id="59">횄혻s 9h35m</segment>
    <segment id="60">, masmas j횄징 estavam mortos.</segment>
    <segment id="61">Fabr횄짯cio foi atingido por quatro tiros: um na regi횄짙o pubiana</segment>
    <segment id="62">, um nas costas</segment>
    <segment id="63">, um do lado esquerdo do t횄쨀rax e outro na cabe횄짠a.</segment>
    <segment id="64">Diones morreu com dois tiros no peito.</segment>
    <segment id="65">O Bope entrou na Favela Nova Holanda por volta das 8h e encontrou 15 homens armados reunidos</segment>
    <segment id="66">, o que motivou a troca de tiros.</segment>
    <segment id="67">De acordo com informa횄짠횄쨉es passadas ao jornal Extra pelo Bope</segment>
    <segment id="68">, a a횄짠횄짙o foi motivada por uma den횄쨘ncia de que homens comandados pelo traficante conhecido</segment>
    <segment id="69">comocomo "</segment>
    <segment id="70">Soldado" estariam reunidos para planejar um ataque contra diversas Unidades de Pol횄짯cia Pacificadoras (UPPs).</segment>
    <segment id="71">Duas pistolas foram apreendidas na opera횄짠횄짙o e levadas para a 21횂짧 DP (Bonsucesso).</segment>
    <segment id="72">O protesto durou cerca de 40 minutos e</segment>
    <segment id="73">, de acordo com o Centro de Opera횄짠횄쨉es da prefeitura</segment>
    <segment id="74">, a Linha Vermelha e a Avenida Brasil foram totalmente liberadas</segment>
    <segment id="75">횄혻s 10h.</segment>
  </rst>
