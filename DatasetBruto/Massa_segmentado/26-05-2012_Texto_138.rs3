  <rst>
    <segment id="1">Assaltantes enchem policial de bala</segment>
    <segment id="2">A bandidagem não respeita mais ninguém.</segment>
    <segment id="3">A nova vítima da violência é um PM</segment>
    <segment id="4">O soldado PM Leonildo Santana dos Santos</segment>
    <segment id="5">, 30, foi morto a tiros quando abastecia o carro</segment>
    <segment id="6">, por volta das 16h de ontem</segment>
    <segment id="7">, no Posto BR</segment>
    <segment id="8">, na Estrada Velha de Campinas de Pirajá</segment>
    <segment id="9">, em Pirajá.</segment>
    <segment id="10">De acordo com a polícia</segment>
    <segment id="11">, os bandidos levaram o carro do PM</segment>
    <segment id="12">, um Ford Fiesta grafite</segment>
    <segment id="13">,  e o abandonaram no Alto do Cabrito.</segment>
    <segment id="14">“</segment>
    <segment id="15">Aparentemente</segment>
    <segment id="16">, foi um assalto e ele teria reagido.</segment>
    <segment id="17">A ação pode ter sido direcionada a ele ou ao posto.</segment>
    <segment id="18">Ainda não sabemos”</segment>
    <segment id="19">, afirmou a delegada  de São Caetano</segment>
    <segment id="20">, Rogéria Araújo.</segment>
    <segment id="21">Um funcionário do posto contou que viu o soldado lutando com um homem.</segment>
    <segment id="22">“Ouvi o homem gritando: ‘</segment>
    <segment id="23">Dê as chaves.</segment>
    <segment id="24">Vou te matar’.</segment>
    <segment id="25">Em nenhum momento</segment>
    <segment id="26">, o soldado  puxou a arma.</segment>
    <segment id="27">Na luta</segment>
    <segment id="28">, a arma caiu e o outro   atirou na cabeça dele”.</segment>
    <segment id="29">“</segment>
    <segment id="30">Parece que havia um terceiro elemento os aguardando em um carro.</segment>
    <segment id="31">Os bandidos fugiram levando a arma do PM”</segment>
    <segment id="32">, afirmou o major  Romeu Nascimento</segment>
    <segment id="33">, da 9ª CIPM (Pirajá).</segment>
    <segment id="34">Leonildo estava na corporação há quatro anos.</segment>
    <segment id="35">Ele integrava  o Serviço de Investigação do  Comando de Policiamento Regional da Capital - Atlântico.</segment>
    <segment id="36">Leonildo tinha acabado de sair do trabalho.</segment>
    <segment id="37">Ele passou em Pirajá para deixar um amigo PM que estava sem carro.</segment>
    <segment id="38">Na volta</segment>
    <segment id="39">, parou para abastecer.</segment>
    <segment id="40">“</segment>
    <segment id="41">Provavelmente</segment>
    <segment id="42">, o preço baixo da gasolina  chamou a atenção  dele”</segment>
    <segment id="43">, emociona-</segment>
    <segment id="44">sese o amigo PM.</segment>
    <segment id="45">“É muito difícil perder um colega de trabalho dessa forma.</segment>
    <segment id="46">Meu Deus!</segment>
    <segment id="47">Meu Deus!</segment>
    <segment id="48">Como vou ficar sem o meu parceiro de guerra?</segment>
    <segment id="49">”, questionava</segment>
    <segment id="50">, aos prantos.</segment>
  </rst>
</analysis>