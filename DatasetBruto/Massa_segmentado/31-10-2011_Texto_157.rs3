  <rst>
    <segment id="1">Judô de olho nas Olimpíadas</segment>
    <segment id="2">Nos recém-encerrados Jogos Pan-Americanos de Guadalajara</segment>
    <segment id="3">, o judô brasileiro concluiu sua participação com seis ouros</segment>
    <segment id="4">, três pratas e quatro bronzes</segment>
    <segment id="5">, ou seja 13 pódios em 14 categorias</segment>
    <segment id="6">Os seis ouros foram no masculino</segment>
    <segment id="7">, na primeira vez que uma equipe nacional conseguiu tantos primeiros lugares no judô</segment>
    <segment id="8">, numa edição do Pan.</segment>
    <segment id="9">Entre as medalhas douradas</segment>
    <segment id="10">, uma foi obtida por uma promessa que poderá chegar até 2016: o paulistano Felipe Kitadai</segment>
    <segment id="11">, de 22 anos.

- Esta vitória aqui em Guadalajara me dá muito ânimo para meu futuro</segment>
    <segment id="12">, para Londres-2012</segment>
    <segment id="13">, Rio-2016</segment>
    <segment id="14">, etc.</segment>
    <segment id="15">Aqui, foi a conquista de um continente</segment>
    <segment id="16">, e mais para a frente</segment>
    <segment id="17">, espero buscar outros territórios - declarou</segment>
    <segment id="18">, comovido.</segment>
    <segment id="19">Revelado pelo Projeto Futuro</segment>
    <segment id="20">, no Ibirapuera</segment>
    <segment id="21">, e atualmente competindo pela Sogipa (RS)</segment>
    <segment id="22">, Kitadai ressaltou que a medalha é fruto do trabalho de todos os dias.</segment>
    <segment id="23">Com 22 anos</segment>
    <segment id="24">, ele poderá competir em 2016</segment>
    <segment id="25">, quando terá cerca de 27.

-</segment>
    <segment id="26">Quando você cai</segment>
    <segment id="27">, desanima</segment>
    <segment id="28">, masmas quando acerta</segment>
    <segment id="29">, tem forças para</segment>
    <segment id="30">sese esforçar ainda mais.</segment>
    <segment id="31">Vou estar em Londres-2012 e buscar a medalha.</segment>
    <segment id="32">Treinamos para ganhar e temos de superar várias coisas - disse.</segment>
    <segment id="33">- Tenho conversado muito com o professor Luiz Shinohara.</segment>
    <segment id="34">No último torneio</segment>
    <segment id="35">, ele me deu um puxão de orelhas e me advertiu</segment>
    <segment id="36">comocomo um pai.</segment>
    <segment id="37">Estava certo</segment>
    <segment id="38">, porque</segment>
    <segment id="39">porque realmente eu precisava ser mais agressivo.</segment>
    <segment id="40">Kitadai obteve o ouro dos ligeiros</segment>
    <segment id="41">, com a vitória sobre o mexicano Nabor Castillo.</segment>
    <segment id="42">O brasileiro vem crescendo.</segment>
    <segment id="43">Em 2009</segment>
    <segment id="44">, foi campeão dos Jogos da Lusofonia e</segment>
    <segment id="45">, em 2010</segment>
    <segment id="46">, obteve a medalha de ouro na Copa do Mundo</segment>
    <segment id="47">, em Roma.</segment>
    <segment id="48">Também ano passado</segment>
    <segment id="49">, foi bronze na Copa do Mundo de São Paulo e medalhista de prata no Campeonato Pan-Americano.</segment>
    <segment id="50">Na categoria ligeiro</segment>
    <segment id="51">, ele é</segment>
    <segment id="52">, de certa forma</segment>
    <segment id="53">, sucessor de nomes</segment>
    <segment id="54">comocomo João Derly</segment>
    <segment id="55">, que foi dessa classe no começo da carreira.</segment>
    <segment id="56">Ultimamente</segment>
    <segment id="57">, os ligeiros não vinham tendo tanto destaque</segment>
    <segment id="58">, desde que Fúlvio Miyata</segment>
    <segment id="59">, bronze no Mundial de 1997</segment>
    <segment id="60">, parou de integrar a seleção em 2005.

- De quatro ouros para cima</segment>
    <segment id="61">, seria muito bom.</segment>
    <segment id="62">Seis ouros foram algo ótimo.</segment>
    <segment id="63">Todos poderiam ter ganho o ouro</segment>
    <segment id="64">, inclusive o Rafael Silva (prata) - analisou.</segment>
    <segment id="65">- Há dois anos</segment>
    <segment id="66">, identificamos uma diferença física muito grande</segment>
    <segment id="67">, e Kitadai é o que mais evoluiu.</segment>
    <segment id="68">Além dele</segment>
    <segment id="69">, também subiram no topo do pódio no Pan Leandro Cunha</segment>
    <segment id="70">, Bruno Mendonça</segment>
    <segment id="71">, Leandro Guilheiro</segment>
    <segment id="72">, Tiago Camilo e Luciano Corrêa.</segment>
    <segment id="73">As pratas foram de Rafael Silva</segment>
    <segment id="74">, Érika Miranda e Rafaela Silva.</segment>
    <segment id="75">Ganharam bronzes</segment>
    <segment id="76">Sarah Meneses</segment>
    <segment id="77">, Maria Portella</segment>
    <segment id="78">, Mayra Aguiar e Maria Suellen.</segment>
    <segment id="79">No feminino</segment>
    <segment id="80">, uma das apostas é Sarah Meneses</segment>
    <segment id="81">, de 21 anos.

-</segment>
    <segment id="82">Meu primeiro objetivo é a medalha em Londres-2012</segment>
    <segment id="83">, e no Rio</segment>
    <segment id="84">, creio que a repercussão será ainda melhor.</segment>
    <segment id="85">Creio que em 2016 teremos o algo mais</segment>
    <segment id="86">, pelo fato de os Jogos serem no Brasil</segment>
    <segment id="87">, pela competição em casa - disse a piauiense.</segment>
    <segment id="88">Segundo a treinadora Rosicléia Campos</segment>
    <segment id="89">, para 2012 e 2016 não faltarão judocas.

- O nosso feminino está com uma renovação muito boa.</segment>
    <segment id="90">Temos reservas da atual geração na base e na fase de maturação.</segment>
    <segment id="91">Todas as meninas da atual seleção terão idade para chegar até o Rio-2016 - assegurou a técnica.</segment>
  </rst>
</analysis>