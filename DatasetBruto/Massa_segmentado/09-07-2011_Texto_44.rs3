  <rst>
    <segment id="1">Morre no Rio o ex-governador Faria Lima
RIO - O ex-governador do Rio Floriano Peixoto Faria Lima faleceu neste sábado no Hospital Naval Marcílio Dias</segment>
    <segment id="2">, no Lins do Vasconcelos</segment>
    <segment id="3">, aos 93 anos.</segment>
    <segment id="4">A causa da morte</segment>
    <segment id="5">, segundo sua filha Regina Maria Faria Lima</segment>
    <segment id="6">, foi apontada</segment>
    <segment id="7">comocomo infecção generalizada.</segment>
    <segment id="8">O corpo do ex-governador será cremado na próxima quarta-feira</segment>
    <segment id="9">, às 10h</segment>
    <segment id="10">, no Cemitério do Caju.</segment>
    <segment id="11">Faria Lima foi o primeiro governador do Estado do Rio depois da fusão com o Estado da Guanabara e assumiu o cargo em 1975.</segment>
    <segment id="12">Para ser governador</segment>
    <segment id="13">, ele deixou a presidência da Petrobras.</segment>
  </rst>
