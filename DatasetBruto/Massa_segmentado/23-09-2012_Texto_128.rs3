  <rst>
    <segment id="1">Menores no crime: perigosos e impunes</segment>
    <segment id="2">RIO - A participa횄짠횄짙o de menores em crimes violentos nas 횄쨘ltimas semanas no Rio</segment>
    <segment id="3">, como</segment>
    <segment id="4">como na morte de sete jovens na Favela da Chatuba</segment>
    <segment id="5">, em Nil횄쨀polis</segment>
    <segment id="6">, ou mesmo o assassinato de um taxista na Linha Amarela</segment>
    <segment id="7">, h횄징 duas semanas</segment>
    <segment id="8">, reacendeu o debate sobre a aplica횄짠횄짙o do Estatuto da Crian횄짠a e do Adolescente (ECA).</segment>
    <segment id="9">Criada h횄징</segment>
    <segment id="10">22 anos</segment>
    <segment id="11">, a legisla횄짠횄짙o que trata de medidas socioeducativas para menores em conflito com a lei estaria desatualizada</segment>
    <segment id="12">, sem condi횄짠횄쨉es de atender</segment>
    <segment id="13">횄혻s novas demandas?</segment>
    <segment id="14">Somente no primeiro semestre deste ano</segment>
    <segment id="15">, 2.975 menores foram apreendidos pela pol횄짯cia envolvidos em infra횄짠횄쨉es de todo tipo.</segment>
    <segment id="16">O n횄쨘mero representa um aumento de 52</segment>
    <segment id="17">,5% em rela횄짠횄짙o ao mesmo per횄짯odo do ano passado</segment>
    <segment id="18">, conforme revelou neste domingo</segment>
    <segment id="19">Ancelmo Gois em sua coluna no GLOBO.</segment>
    <segment id="20">O secret횄징rio estadual de Seguran횄짠a</segment>
    <segment id="21">, Jos횄짤</segment>
    <segment id="22">Mariano</segment>
    <segment id="23">Beltrame</segment>
    <segment id="24">,</segment>
    <segment id="25">diz que fac횄짠횄쨉es criminosas usam cada vez mais adolescentes</segment>
    <segment id="26">, especialmente no tr횄징fico</segment>
    <segment id="27">, seja em 횄징reas pacificadas ou n횄짙o.</segment>
    <segment id="28">Para o secret횄징rio</segment>
    <segment id="29">, essa t횄징tica acontece</segment>
    <segment id="30">porque</segment>
    <segment id="31">porque os menores</segment>
    <segment id="32">, quando s횄짙o apreendidos</segment>
    <segment id="33">, ficam pouco tempo cumprindo medidas socioeducativas:
- Mesmo em casos de assassinatos ou crimes hediondos</segment>
    <segment id="34">, no m횄징ximo</segment>
    <segment id="35">, o jovem ficar횄징 detido por algum tempo e voltar횄징</segment>
    <segment id="36">횄혻s ruas</segment>
    <segment id="37">, muitas vezes retornando ao crime.</segment>
    <segment id="38">Al횄짤m disso</segment>
    <segment id="39">, vemos cada vez mais adolescentes em posi횄짠횄쨉es de poder</segment>
    <segment id="40">, seja</segment>
    <segment id="41">comocomo gerentes de pontos de drogas</segment>
    <segment id="42">, seja</segment>
    <segment id="43">comocomo soldados do tr횄징fico</segment>
    <segment id="44">, com pistolas ou fuzis nas m횄짙os.</segment>
    <segment id="45">Outro dado que chama a aten횄짠횄짙o</segment>
    <segment id="46">횄짤 que esses menores</segment>
    <segment id="47">sese drogam muito</segment>
    <segment id="48">, inclusive com uso regular de crack</segment>
    <segment id="49">, o que afeta seus comportamentos</segment>
    <segment id="50">, tornando-os mais agressivos e inconsequentes.</segment>
    <segment id="51">Procurador defende interna횄짠횄짙o</segment>
    <segment id="52">Procurador de Justi횄짠a</segment>
    <segment id="53">, que j횄징 atuou</segment>
    <segment id="54">comocomo promotor da Vara da Inf횄짖ncia e da Juventude</segment>
    <segment id="55">, Marcio Moth횄짤</segment>
    <segment id="56">Fernandes defende a revis횄짙o do ECA.</segment>
    <segment id="57">Segundo ele</segment>
    <segment id="58">, a realidade hoje</segment>
    <segment id="59">횄짤 bem diferente de quando o estatuto foi criado</segment>
    <segment id="60">, e n횄짙o prev횄짧</segment>
    <segment id="61">, por exemplo</segment>
    <segment id="62">, a interna횄짠횄짙o de adolescentes por tr횄징fico de drogas.
- H횄징 aspectos que precisam ser rediscutidos</segment>
    <segment id="63">, como</segment>
    <segment id="64">como a interna횄짠횄짙o compuls횄쨀ria dos dependentes de crack e o tempo das medidas para os menores infratores.</segment>
    <segment id="65">Mas tem um aspecto mais grave</segment>
    <segment id="66">, que 횄짤 a impossibilidade de o adolescente apreendido por tr횄징fico de drogas ficar internado - diz ele.</segment>
    <segment id="67">Moth횄짤 lembra que uma s횄쨘mula do Superior Tribunal de Justi횄짠a</segment>
    <segment id="68">, editada em agosto</segment>
    <segment id="69">, estabelece que a pr횄징tica do tr횄징fico n횄짙o</segment>
    <segment id="70">횄짤 determinante</segment>
    <segment id="71">para que</segment>
    <segment id="72">para que o menor seja levado para interna횄짠횄짙o nos centros de ressocializa횄짠횄짙o.</segment>
    <segment id="73">A medida foi publicada</segment>
    <segment id="74">porque</segment>
    <segment id="75">porque o ECA n횄짙o trata de interna횄짠횄쨉es dos jovens por tr횄징fico.
- Quando o ECA foi elaborado</segment>
    <segment id="76">, o artigo 122</segment>
    <segment id="77">, que lista os motivos pelos quais o menor poderia ser internado</segment>
    <segment id="78">, n횄짙o inclu횄짯a o tr횄징fico.</segment>
    <segment id="79">Isso deveria ser reformulado.</segment>
    <segment id="80">N횄짙o h횄징 um instrumento jur횄짯dico para punir infratores.</segment>
    <segment id="81">Os traficantes arregimentam adolescentes com o discurso de que s횄짙o inimput횄징veis.</segment>
    <segment id="82">Isso 횄짤 muito urgente.</segment>
    <segment id="83">M횄짙es entregam os filhos 횄혻 pol횄짯cia para afast횄징-los do crime</segment>
    <segment id="84">, masmas o estado n횄짙o pode internar</segment>
    <segment id="85">poispois n횄짙o existe previs횄짙o legal - diz.</segment>
    <segment id="86">Tramitam no Senado tr횄짧s</segment>
    <segment id="87">Propostas de Emenda Constitucional (PEC) que prop횄쨉em a redu횄짠횄짙o da maioridade penal</segment>
    <segment id="88">, como</segment>
    <segment id="89">como forma de reduzir a criminalidade entre adolescentes.</segment>
    <segment id="90">O senador Aloysio Nunes Ferreira (PSDB-SP) 횄짤 um dos autores de uma das PECs.</segment>
    <segment id="91">Para ele</segment>
    <segment id="92">, o estatuto precisa ser revisto:
- Acho que o per횄짯odo m횄징ximo de interna횄짠횄짙o poderia ser maior.</segment>
    <segment id="93">H횄징 projetos com esse intuito.</segment>
    <segment id="94">Da mesma forma</segment>
    <segment id="95">, h횄징 alguns outros pontos que precisam ser revistos.</segment>
    <segment id="96">Mas acho que a estrutura do texto funciona.</segment>
    <segment id="97">A PEC 33/2012</segment>
    <segment id="98">, proposta por Nunes</segment>
    <segment id="99">, diferencia-</segment>
    <segment id="100">sese das demais</segment>
    <segment id="101">porque</segment>
    <segment id="102">porque mant횄짤m a inimputabilidade prevista no ECA</segment>
    <segment id="103">, masmas permite que a Justi횄짠a</segment>
    <segment id="104">, provocada pelo Minist횄짤rio P횄쨘blico</segment>
    <segment id="105">, abra exce횄짠횄쨉es.</segment>
    <segment id="106">Segundo ele</segment>
    <segment id="107">, a radicaliza횄짠횄짙o presente em outras propostas que passaram pela Casa desvirtuaram o debate e inviabilizaram qualquer acordo sobre a redu횄짠횄짙o da maioridade penal.</segment>
    <segment id="108">A discuss횄짙o sobre a redu횄짠횄짙o da maioridade penal ou a revis횄짙o do ECA n횄짙o 횄짤 uma unanimidade.</segment>
    <segment id="109">A soci횄쨀loga Julita Lemgruber</segment>
    <segment id="110">, coordenadora do Centro de Estudos de Seguran횄짠a e Cidadania</segment>
    <segment id="111">, 횄짤 contra.</segment>
    <segment id="112">Para ela</segment>
    <segment id="113">, levar mais adolescentes 횄혻 carceragem n횄짙o</segment>
    <segment id="114">reduzir횄징 a criminalidade.</segment>
    <segment id="115">Julita destaca que os jovens tamb횄짤m</segment>
    <segment id="116">s횄짙o as maiores v횄짯timas do crime.</segment>
    <segment id="117">Segundo ela</segment>
    <segment id="118">, os homic횄짯dios s횄짙o a principal causa de morte entre jovens de 12 e 18 anos (44% dos casos):
-</segment>
    <segment id="119">A pris횄짙o 횄짤 uma forma cara de tornar as pessoas piores.</segment>
