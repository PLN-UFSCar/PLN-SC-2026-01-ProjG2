  <rst>
    <segment id="1">Afrﾃδｳdromo perto de final feliz
Quarto circuito da folia</segment>
    <segment id="2">momesca jﾃδ｡ deve estrear no prﾃδｳximo ano</segment>
    <segment id="3">O ﾃ｢竄ｬﾅ殿frﾃδｳdromoﾃ｢竄ｬ</segment>
    <segment id="4">, como</segment>
    <segment id="5">como serﾃδ｡ apelidado o possﾃδｭvel quarto circuito  da festa momesca para o desfile de afoxﾃδｩs e blocos afros</segment>
    <segment id="6">, no Comﾃδｩrcio</segment>
    <segment id="7">,  deve ter suas estruturas montadas jﾃδ｡ no Carnaval de 2013 para receber 140 mil foliﾃδｵes</segment>
    <segment id="8">, destes</segment>
    <segment id="9">,  20 mil em arquibancadas.</segment>
    <segment id="10">Fruto de uma parceria entre a Pilar Produﾃδｧﾃδｵes e a Liga dos Blocos Afros</segment>
    <segment id="11">, o projeto</segment>
    <segment id="12">, alﾃδｩm de ter sido recebido de forma positiva pela prefeitura de Salvador e ﾃδｳrgﾃδ｣os estaduais e federais</segment>
    <segment id="13">, jﾃδ｡ tem o apoio de grandes marcas e estudos que estimam a geraﾃδｧﾃδ｣o de 25 mil empregos diretos e indiretos</segment>
    <segment id="14">; a movimentaﾃδｧﾃδ｣o de R$ 120 milhﾃδｵes e uma receita de tributos para o Estado da Bahia de cerca de R$ 7 milhﾃδｵes.</segment>
    <segment id="15">O estudo preliminar foi realizado pela empresa Hoffing</segment>
    <segment id="16">, contratada pela parceria entre a Pilar  e a Liga</segment>
    <segment id="17">, composta pelo Malﾃδｪ Debalﾃδｪ</segment>
    <segment id="18">, Timbalada</segment>
    <segment id="19">, Muzenza</segment>
    <segment id="20">, Cortejo Afro</segment>
    <segment id="21">, Ilﾃδｪ Aiyﾃδｪ</segment>
    <segment id="22">, Carlinhos Brown e Afoxﾃδｩ Filhos de Gandhi.</segment>
    <segment id="23">Ontem, Brown e o vice-presidente do Malﾃδｪ Debalﾃδｪ</segment>
    <segment id="24">, Miguel Arcanjo</segment>
    <segment id="25">, estiveram no jornal</segment>
    <segment id="26">A TARDE para apresentar o projeto e mostraram entusiasmo com o que chamam de ﾃ｢竄ｬﾅ途econduﾃδｧﾃδ｣o da questﾃδ｣o cultural</segment>
    <segment id="27">, no Carnaval</segment>
    <segment id="28">, com o foco afroﾃ｢竄ｬ.
ﾃ｢竄ｬﾅ鄭creditamos que isso nﾃδ｣o separa</segment>
    <segment id="29">, e sim avanﾃδｧa.</segment>
    <segment id="30">Precisamos acabar com a dicotomia de que o Carnaval ﾃδｩ problemﾃδ｡tico</segment>
    <segment id="31">porque</segment>
    <segment id="32">porque nﾃδ｣o valoriza suas matrizesﾃ｢竄ｬ</segment>
    <segment id="33">, disse Brown.</segment>
    <segment id="34">Projeto feito para ser inovador</segment>
    <segment id="35">O Afrﾃδｳdromo serﾃδ｡ um espaﾃδｧo cultural em uma ﾃδ｡rea delimitada pelo Mercado Modelo e a Feira de Sﾃδ｣o Joaquim.</segment>
    <segment id="36">As arquibancadas serﾃδ｣o montadas na Avenida Franﾃδｧa</segment>
    <segment id="37">, e os trios retornarﾃδ｣o pela Avenida Estados Unidos.</segment>
    <segment id="38">As tranversais servirﾃδ｣o de apoio</segment>
    <segment id="39">, com banheiros</segment>
    <segment id="40">, torres de controle</segment>
    <segment id="41">, espaﾃδｧo VIP</segment>
    <segment id="42">, parque para crianﾃδｧas.</segment>
    <segment id="43">Segundo Brown</segment>
    <segment id="44">,  o Afrﾃδｳdromo foi desenvolvido para ser um projeto inovador.</segment>
  </rst>
