  <rst>
    <segment id="1">Gêmeo morto seria pai no fim do ano
Leonardo e a mulher</segment>
    <segment id="2">Naiara já haviam começado a montar o enxoval do bebê</segment>
    <segment id="3">O corpo de  José Leonardo da Silva</segment>
    <segment id="4">, 22 anos</segment>
    <segment id="5">,  foi enterrado</segment>
    <segment id="6">, na tarde de ontem</segment>
    <segment id="7">, na cidade de Ibimirim</segment>
    <segment id="8">, no Estado de Pernambuco</segment>
    <segment id="9">, onde ele e o irmão gêmeo</segment>
    <segment id="10">, José Leandro da Silva</segment>
    <segment id="11">, 22, nasceram e os pais deles residem</segment>
    <segment id="12">, segundo familiares.</segment>
    <segment id="13">“</segment>
    <segment id="14">A gente fica sem querer acreditar.</segment>
    <segment id="15">Como é que acontece uma coisa dessa com um menino trabalhador?</segment>
    <segment id="16">Ele trabalhava de dia e de noite para arcar com as responsabilidades.</segment>
    <segment id="17">A vida desses meninos era do trabalho para casa”</segment>
    <segment id="18">, afirmou a avó da mulher de Leonardo</segment>
    <segment id="19">, a pensionista Francisca Maria Neto</segment>
    <segment id="20">, 67.</segment>
    <segment id="21">Segundo ela</segment>
    <segment id="22">, Leonardo estava feliz com a gravidez da mulher</segment>
    <segment id="23">, Naiara Gomes Neto</segment>
    <segment id="24">, 15, que está no terceiro mês de gestação.</segment>
    <segment id="25">Ele  planejava comprar um terreno para construir uma casa e morar com a família.</segment>
    <segment id="26">Outro desejo  era levar a mulher e a sogra para conhecerem a terra natal dele</segment>
    <segment id="27">, até o final do ano.</segment>
    <segment id="28">“Eu tenho 67 anos e nunca aconteceu uma coisa dessa na minha família.</segment>
    <segment id="29">Nunca precisei ir à delegacia.</segment>
    <segment id="30">Morte nenhuma é boa</segment>
    <segment id="31">, masmas essa é pior.</segment>
    <segment id="32">Está sendo muito difícil para todo mundo passar por isso.</segment>
    <segment id="33">Minha neta precisou ser hospitalizada”</segment>
    <segment id="34">, completou dona Francisca.</segment>
    <segment id="35">Naiara e Leonardo estavam juntos há quase dois anos.</segment>
    <segment id="36">Ela, os irmãos dele -  Leninha e Leandro - e outros familiares</segment>
    <segment id="37">, também foram para Pernambuco participar do enterro.</segment>
    <segment id="38">“Minha vida acabou”
José Leandro da Silva sobreviveu às agressões do bando</segment>
    <segment id="39">, masmas sofreu vários ferimentos</segment>
    <segment id="40">, principalmente no rosto.</segment>
    <segment id="41">Familiares e amigos contam que ele e Leonardo eram muito unidos e faziam questão até de usar roupas iguais.</segment>
    <segment id="42">“Ele chorava muito e dizia que a vida dele</segment>
    <segment id="43">, aqui em Camaçari</segment>
    <segment id="44">, acabou.</segment>
    <segment id="45">Tudo que ele ia fazer era com o irmão.</segment>
    <segment id="46">Sempre conversavam um com o outro sobre os planos”</segment>
    <segment id="47">, disse a vendedora Siméia Maria Neto</segment>
    <segment id="48">, 26, tia da mulher de Leonardo.</segment>
    <segment id="49">“</segment>
    <segment id="50">Os meninos não eram (gays).</segment>
    <segment id="51">Mas, se</segment>
    <segment id="52">se fossem</segment>
    <segment id="53">, não tinha nada a ver fazer o que fizeram”</segment>
    <segment id="54">, diz Francisca.</segment>
    <segment id="55">Ela salienta que a tragédia poderia ter sido maior</segment>
    <segment id="56">, caso</segment>
    <segment id="57">caso a neta Naiara não desistisse de ir à festa.</segment>
    <segment id="58">Leandro chegou a dizer que Leonardo era seu irmão</segment>
    <segment id="59">, masmas a revelação não conteve os agressores.</segment>
  </rst>
</analysis>