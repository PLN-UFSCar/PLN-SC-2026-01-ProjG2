    <segment id="35">, masmas a ter dignidade.</segment>
    <segment id="36">Гўв‚¬Е“Meu filho</segment>
    <segment id="37">sese envolveu nisto</segment>
    <segment id="38">porque</segment>
    <segment id="39">porque nГѓВЈo ouviu conselhos.</segment>
    <segment id="40">Agora, ele sabe o quanto dГѓВіi estar privado de sua liberdade.</segment>
    <segment id="41">Tenho certeza que ele agora darГѓВЎ valor</segment>
    <segment id="42">ГѓВ  profissГѓВЈo que aprendeuГўв‚¬.</segment>
    <segment id="43">Para o coordenador de EducaГѓВ§ГѓВЈo e Atividades Laborativas do presГѓВ­dio</segment>
