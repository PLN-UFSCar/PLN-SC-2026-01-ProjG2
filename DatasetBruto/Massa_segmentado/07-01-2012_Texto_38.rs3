  <rst>
    <segment id="1">O verde volta a brotar nas terras arrasadas
RIO - Nas primeiras semanas após a enxurrada</segment>
    <segment id="2">, o agricultor Eliseu Ramos da Cunha</segment>
    <segment id="3">, de 48 anos</segment>
    <segment id="4">, era o retrato do desânimo.</segment>
    <segment id="5">Dono de uma propriedade de sete alqueires em Sebastiana</segment>
    <segment id="6">, zona rural de Teresópolis</segment>
    <segment id="7">, ele teve toda a lavoura destruída pela enchente.</segment>
    <segment id="8">E ainda quebrou a perna na noite da tempestade</segment>
    <segment id="9">, quando uma barreira derrubou a parede de seu quarto.</segment>
    <segment id="10">Um ano depois</segment>
    <segment id="11">, a destruição deu lugar ao verde</segment>
    <segment id="12">, que voltou a fazer parte da paisagem.</segment>
    <segment id="13">Casado</segment>
    <segment id="14">, pai de seis filhos</segment>
    <segment id="15">, ele foi encontrado pelos repórteres do GLOBO no mesmo lugar onde estava em janeiro de 2011.</segment>
    <segment id="16">Desta vez</segment>
    <segment id="17">, no entanto</segment>
    <segment id="18">, negociava a venda da sua produção de alface</segment>
    <segment id="19">, coentro e rúcula.</segment>
    <segment id="20">Ele conta que o tempo da desolação passou.</segment>
    <segment id="21">Mas afirma que o caminho até a recuperação foi tortuoso:
- Foi difícil.</segment>
    <segment id="22">Fiquei quase quatro meses sem poder trabalhar e sem ganhar um tostão.</segment>
    <segment id="23">Tive que gastar mais de R$ 60 mil para refazer tudo.</segment>
    <segment id="24">De acordo com dados da Comissão Parlamentar de inquérito (CPI) conduzida pela Assembleia Legislativa do Rio para investigar as causas da tragédia e as responsabilidades dos agentes públicos</segment>
    <segment id="25">, cerca de 17 mil famílias</segment>
    <segment id="26">comocomo a de Elizeu</segment>
    <segment id="27">, que tiram seu sustento da atividade agropecuária</segment>
    <segment id="28">, foram afetadas pelas chuvas.</segment>
    <segment id="29">Números fornecidos pela secretaria estadual de Agricultura estimam um prejuízo de quase R$ 270 milhões para o setor.</segment>
    <segment id="30">Em Vieira</segment>
    <segment id="31">, outro distrito de Teresópolis</segment>
    <segment id="32">, a reconstrução ganhou força graças às iniciativas das próprias vítimas.</segment>
    <segment id="33">O lugar</segment>
    <segment id="34">, às margens do Rio Formiga</segment>
    <segment id="35">, foi duramente atingido por duas cabeças d'agua</segment>
    <segment id="36">, o que provocou o alagamento de dezenas de propriedades.</segment>
    <segment id="37">Além disso</segment>
    <segment id="38">, sofreu com deslizamentos que soterraram casas</segment>
    <segment id="39">, ruas e plantações</segment>
    <segment id="40">; quedas de pontes e fechamento de vias de acesso.</segment>
    <segment id="41">A localidade foi uma das últimas da cidade a receber ajuda oficial.</segment>
    <segment id="42">A tempestade deixou mais de 60 mortos em Vieira</segment>
    <segment id="43">, além de ter destruído a economia local.</segment>
    <segment id="44">Nas primeiras semanas após as chuvas</segment>
    <segment id="45">, um grupo de moradores</segment>
    <segment id="46">sese reuniu em busca de soluções.</segment>
    <segment id="47">Dois meses depois</segment>
    <segment id="48">, eles criaram uma cooperativa</segment>
    <segment id="49">, a CoopVieira</segment>
    <segment id="50">, de olho não só na recuperação</segment>
    <segment id="51">, masmas no que viria depois.

- A desorganização após o desastre era imensa.</segment>
    <segment id="52">Mas alguma coisa ali fez com que as pessoas</segment>
    <segment id="53">sese unissem de uma forma</segment>
    <segment id="54">comocomo nunca havia acontecido.</segment>
    <segment id="55">Não esperamos pela ajuda do governo</segment>
    <segment id="56">, da prefeitura ou de quem quer que seja.</segment>
    <segment id="57">Fomos atrás de parcerias e demos uma sorte enorme</segment>
    <segment id="58">, porque</segment>
    <segment id="59">porque encontramos todas as portas abertas - diz o professor Fabio Patron</segment>
    <segment id="60">, um dos que encabeçaram a iniciativa para criação da CoopVieira.</segment>
    <segment id="61">Ele conta que o grupo tem hoje cerca de cem pessoas.</segment>
    <segment id="62">E que dois terços vivem unicamente da agricultura.</segment>
    <segment id="63">Passada a tragédia</segment>
    <segment id="64">, segundo Patron</segment>
    <segment id="65">, o grupo</segment>
    <segment id="66">sese dedicou a melhorar as condições de trabalho para os cooperativados.

- Hoje estamos voltados para a capacitação e o desenvolvimento de tecnologia</segment>
    <segment id="67">, buscando agregar valor à produção local.</segment>
    <segment id="68">Um exemplo é a estufa que montamos em mutirão para a produção de mudas</segment>
    <segment id="69">, com certificação da Emater.</segment>
  </rst>
</analysis>