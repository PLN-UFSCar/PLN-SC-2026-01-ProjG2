  <rst>
    <segment id="1">Confusão acaba com amizade de infância</segment>
    <segment id="2">Paraibanas vão entrar com processo para reconhecer autoria de "</segment>
    <segment id="3">Ai sese eu te pego"</segment>
    <segment id="4">O bafafá sobre a autoria do refrão do hit que ganhou o mundo na voz de Michel Teló</segment>
    <segment id="5">, “Ai,</segment>
    <segment id="6">sese eu te pego”</segment>
    <segment id="7">, está longe de ter um fim.</segment>
    <segment id="8">Após sete meninas da Paraíba reclamarem a autoria do refrão</segment>
    <segment id="9">, Sharon Acioly</segment>
    <segment id="10">, até então autora do trecho musical</segment>
    <segment id="11">, enviou nota à imprensa declarando que “em nenhum momento o fato deixou de ser mencionado.</segment>
    <segment id="12">Os direitos autorais de todos são preservados por lei”.</segment>
    <segment id="13">No entanto</segment>
    <segment id="14">, parece que alguém não ficou satisfeito com o argumento.</segment>
    <segment id="15">Segundo Adelson Barbosa</segment>
    <segment id="16">, pai de Maria Eduarda</segment>
    <segment id="17">, uma das meninas da Paraíba</segment>
    <segment id="18">, uma mulher de prenome Caroline esteve em João Pessoa para negociar com as garotas.</segment>
    <segment id="19">“</segment>
    <segment id="20">Essa pessoa disse que representava a gravadora Pantanal e o cantor Michel Teló e ofereceu R$ 2 mil</segment>
    <segment id="21">para que</segment>
    <segment id="22">para que três das meninas desistissem do processo.</segment>
    <segment id="23">As meninas recusaram e logo depois o ‘lance’ subiu para R$ 33 mil</segment>
    <segment id="24">, com a condição de que elas abrissem mão da coautoria do refrão e dissessem à imprensa que tudo foi um equívoco”</segment>
    <segment id="25">, contou.</segment>
    <segment id="26">Procurada pelo MASSA!</segment>
    <segment id="27">, a suposta advogada</segment>
    <segment id="28">Caroline negou as informações</segment>
    <segment id="29">, apesar de admitir ser advogada  da gravadora Pantanal.</segment>
    <segment id="30">A história rendeu até um desentendimento entre as sete garotas</segment>
    <segment id="31">, pois</segment>
    <segment id="32">pois, segundo Adelson</segment>
    <segment id="33">, três delas negociaram às escondidas com a suposta advogada.</segment>
    <segment id="34">Outra, saiu da briga e agora restam três.</segment>
    <segment id="35">Maria Eduarda</segment>
    <segment id="36">, Marcela Ramalho e Amanda Cavalcanti continuam na luta pelos direitos autorais.</segment>
  </rst>
</analysis>