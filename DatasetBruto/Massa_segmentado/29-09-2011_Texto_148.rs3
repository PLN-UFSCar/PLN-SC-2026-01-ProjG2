  <rst>
    <segment id="1">Agora só falta a musa da Maionese
Manicure da cidade de Juazeiro publica vídeo no YouTube dizendo ser a Mulher-Mostarda
Depois das mulheres-frutas</segment>
    <segment id="2">, agora chegou  a vez das mulheres-condimentos.</segment>
    <segment id="3">Em pleno auge do sucesso da Mulher-Ketchup</segment>
    <segment id="4">, que viaja hoje para São Paulo</segment>
    <segment id="5">, onde deve participar do Programa do Ratinho</segment>
    <segment id="6">, no SBT</segment>
    <segment id="7">, surgiu na cidade de Juazeiro</segment>
    <segment id="8">, no norte da Bahia</segment>
    <segment id="9">, a Mulher-Mostarda.</segment>
    <segment id="10">“Se tem a Mulher- -Ketchup</segment>
    <segment id="11">, porque</segment>
    <segment id="12">porque eu não posso ser a mulher mostarda?</segment>
    <segment id="13">”.</segment>
    <segment id="14">A frase inicia o vídeo de 1min24s</segment>
    <segment id="15">, disponível no YouTube</segment>
    <segment id="16">, no qual a manicure Rosana Costa dos Santos</segment>
    <segment id="17">, 35, também simula uma morte.</segment>
    <segment id="18">Ela lambuzou o corpo com mostarda e colocou uma faca embaixo do braço.</segment>
    <segment id="19">“</segment>
    <segment id="20">Na onda da Mulher- -Ketchup</segment>
    <segment id="21">, estava mais do que na hora de trazer um molho que é menos favorecido e muito rejeitado nas lanchonetes de todo o país.</segment>
    <segment id="22">Nasce a Mulher-Mostarda e aqui ninguém contrata ninguém</segment>
    <segment id="23">, não mata.</segment>
    <segment id="24">É apenas uma brincadeira.</segment>
    <segment id="25">Nos divertimos muito.</segment>
    <segment id="26">Ela chega para abalar o Brasil</segment>
    <segment id="27">, deixando a maionese para as outras escorregarem”</segment>
    <segment id="28">, disse o cineastra Flávio  Fonseca</segment>
    <segment id="29">, 34, idealizador do vídeo</segment>
    <segment id="30">, que está virando sucesso.</segment>
    <segment id="31">Mulheres-condimentos unidas

“Gostei muito da fama dela.</segment>
    <segment id="32">Espero ter a mesma fama ou até mais.</segment>
    <segment id="33">Sucesso para ela”</segment>
    <segment id="34">, desejou Mostarda à Ketchup.</segment>
    <segment id="35">A Mulher-Mostarda revelou ainda que</segment>
    <segment id="36">, além do sucesso</segment>
    <segment id="37">, espera que essa história lhe traga  sorte</segment>
    <segment id="38">, amizades e um amor.</segment>
    <segment id="39">Engana-</segment>
    <segment id="40">sese quem pensou que a Mulher-Ketchup</segment>
    <segment id="41">, a dona de casa  Erenildes Aguiar de Araújo</segment>
    <segment id="42">, 32, iria</segment>
    <segment id="43">sese incomodar com a colega.</segment>
    <segment id="44">“Vejo que ela está tentando me homenagear.</segment>
    <segment id="45">Se ela conseguir a mesma fama que eu vai ser uma felicidade”</segment>
    <segment id="46">, disse.</segment>
    <segment id="47">“</segment>
    <segment id="48">Agora está faltando a Mulher-Maionese”</segment>
    <segment id="49">, brincou.</segment>
  </rst>
