  <rst>
    <segment id="1">Igor KannГѓВЎrio</segment>
    <segment id="2">ГѓВ© detido por trГѓВЎfico</segment>
    <segment id="3">Cantor foi detido com maconha</segment>
    <segment id="4">O ano do cantor Igor KannГѓВЎrio comeГѓВ§ou movimentado.</segment>
    <segment id="5">Na tarde de ontem</segment>
    <segment id="6">, ele foi preso por policiais militares do PelotГѓВЈo Emprego TГѓВЎtico Operacional (Peto) da 37Г‚ВЄ CIPM (Liberdade)</segment>
    <segment id="7">, com uma quantidade de maconha embalada em uma folha de caderno.</segment>
    <segment id="8">Conhecido</segment>
    <segment id="9">comocomo o Гўв‚¬ЛњPrГѓВ­ncipe do GuetoГўв‚¬в„ў</segment>
    <segment id="10">, ele foi abordado quando passava prГѓВіximo</segment>
    <segment id="11">ГѓВ  37Г‚ВЄ CIPM</segment>
    <segment id="12">, na rua Saldanha Marinho</segment>
    <segment id="13">, bairro  Caixa DГўв‚¬в„ўГѓgua.</segment>
    <segment id="14">Ele estava acompanhando do mГѓВєsico da banda JoГѓВЈo Pedro Laurentino</segment>
    <segment id="15">, 28, o Peu</segment>
    <segment id="16">, e do tГѓВ©cnico LГѓВЎzaro de Jesus</segment>
    <segment id="17">, 50.</segment>
    <segment id="18">Apenas Igor e Peu estavam com drogas e permanecerГѓВЈo presos.</segment>
    <segment id="19">Гўв‚¬Е“Vimos trГѓВЄs elementos em situaГѓВ§ГѓВЈo suspeita entrando em um beco.</segment>
    <segment id="20">Estavam de bonГѓВЄs e mochilas</segment>
    <segment id="21">, entГѓВЈo resolvemos abordГѓВЎ-losГўв‚¬</segment>
    <segment id="22">, diz um policial.</segment>
    <segment id="23">Ele diz que sГѓВі percebeu que era KannГѓВЎrio apГѓВіs a abordagem.</segment>
    <segment id="24">Segundo o PM</segment>
    <segment id="25">, o cantor assumiu a droga e garantiu que era para consumo prГѓВіprio.</segment>
    <segment id="26">Peu tentou dispensar em um matagal prГѓВіximo ao local.</segment>
    <segment id="27">Гўв‚¬Е“Ele agiu naturalmente</segment>
    <segment id="28">, ficou super tranquilo.</segment>
    <segment id="29">EstГѓВЎ acostumado a ser abordadoГўв‚¬</segment>
    <segment id="30">, revelou o policial</segment>
    <segment id="31">, afirmando que esta foi a terceira vez que enquadrou KannГѓВЎrio.</segment>
    <segment id="32">Conforme o titular da Delegacia da Liberdade</segment>
    <segment id="33">, Luiz Henrique Costa</segment>
    <segment id="34">, a quantidade encontrada com o cantor dГѓВЎ para fazer de 20 a 30 cigarros de maconha.</segment>
    <segment id="35">, Por conta disso</segment>
    <segment id="36">, KannГѓВЎrio e Peu foram autuados por trГѓВЎfico de drogas e ficarГѓВЈo detidos na Delegacia dos Barris.</segment>
    <segment id="37">Droga dada por um fГѓВЈ
Гўв‚¬Е“Ele disse que recebeu a droga de um fГѓВЈ e que estava indo ГѓВ  casa de LГѓВЎzaro pegar uns instrumentosГўв‚¬</segment>
    <segment id="38">, informa Costa.</segment>
    <segment id="39">Segundo o delegado</segment>
    <segment id="40">, nГѓВЈo existe uma quantidade especГѓВ­fica de drogas para</segment>
    <segment id="41">sese configurar</segment>
    <segment id="42">comocomo trГѓВЎfico.</segment>
    <segment id="43">Гўв‚¬Е“Depende da circunstГѓВўncia e do entendimento de cada um.</segment>
    <segment id="44">NГѓВЈo</segment>
    <segment id="45">ГѓВ© uma quantidade que</segment>
    <segment id="46">sese consuma em um dia</segment>
    <segment id="47">, dois ou trГѓВЄs cigarrosГўв‚¬</segment>
    <segment id="48">, diz ele.</segment>
    <segment id="49">Segundo o produtor Fagner Baqueta</segment>
    <segment id="50">, Igor tinha terminado de participar de uma reuniГѓВЈo com ele e com um artista que havia lhe convidado para cantar no Festival de VerГѓВЈo.</segment>
    <segment id="51">Ele nГѓВЈo revelou o nome do artista.</segment>
    <segment id="52">PolГѓВЄmicas do KannГѓВЎrio</segment>
    <segment id="53">Setembro de 2014 - Cantor tem smartphone e corrente de ouro roubados em estГѓВєdio de tatuagem no Bonfim.</segment>
    <segment id="54">Abril de 2013 - Flagrado pela 4Г‚ВЄ vez em blitz por dirigir sem carteira de motorista.</segment>
    <segment id="55">Janeiro de 2013 - Brigou com a mГѓВЈe e quebrou espelho do banheiro apГѓВіs ela perguntar sobre origem do cajado que ele levou pra casa.</segment>
    <segment id="56">Agosto de 2012 - Acusado de quebrar quarto do Hotel Riverside (Aracaju).</segment>
  </rst>
