  <rst>
    <segment id="1">Iñaki Urdangarin</segment>
    <segment id="2">, genro do rei da Espanha</segment>
    <segment id="3">, queria fazer negócios no Brasil
MADRI - O duque de Palma e genro do Rei Juan Carlos</segment>
    <segment id="4">, da Espanha</segment>
    <segment id="5">, Iñaki Urdangarin</segment>
    <segment id="6">, não abandonou seus negócios particulares em 2006</segment>
    <segment id="7">comocomo lhe ordenaraa a Casa do Rei.</segment>
    <segment id="8">Segundo reportagem do "El</segment>
    <segment id="9">País</segment>
    <segment id="10">"</segment>
    <segment id="11">, em 2009</segment>
    <segment id="12">, dos EUA</segment>
    <segment id="13">, ele continuou operando negócios particulares internacionais por meio de sua empresa Aizoon</segment>
    <segment id="14">, da qual é sócio junto com sua esposa</segment>
    <segment id="15">, a infanta Cristina.</segment>
    <segment id="16">A reportagem diz que o processo do</segment>
    <segment id="17">casocaso Palma Arena - que investiga a suposta malversação de fundos públicos em contratos</segment>
    <segment id="18">comocomo Instituto Nóos</segment>
    <segment id="19">, do qual era presidente</segment>
    <segment id="20">, com organismos oficiais no valor de mais de 5 milhões de euros</segment>
    <segment id="21">, e do qual está sendo acusado - contém uma ordem escrita por Urdangarin encaminhanda à Aizoon</segment>
    <segment id="22">para que</segment>
    <segment id="23">para que consiga um negócio no Brasil.</segment>
    <segment id="24">O duque tem uma importante atividade empresarial</segment>
    <segment id="25">, atuando</segment>
    <segment id="26">comocomo conselheiro da Telefónica.</segment>
    <segment id="27">No mail à empresa</segment>
    <segment id="28">, Urdangarin explica que MArio Sorribasserá contratado</segment>
    <segment id="29">comocomo seu representante</segment>
    <segment id="30">, especifica a remuneração e informa que "seu primeiro objetivo será a obtenção de um contrato no Brasil".</segment>
    <segment id="31">A prova avaliza a tese da Promotoria Anticorrupção</segment>
    <segment id="32">, segundo a qual</segment>
    <segment id="33">, o marido da infanta Cristina mantém projetos na sombra da Nóos</segment>
    <segment id="34">, apesar do veto imposto pelo rei Juan Carlos</segment>
    <segment id="35">, e não interrompeu a carreira de homem de negócios</segment>
    <segment id="36">, apesar do afastamento da empresa em junho de 2006.</segment>
  </rst>
