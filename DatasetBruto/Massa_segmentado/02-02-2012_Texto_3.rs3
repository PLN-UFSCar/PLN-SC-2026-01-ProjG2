  <rst>
    <segment id="1">Estudantes reclamam autoria do refrão
Paraibanas querem que Sharon as reconheça</segment>
    <segment id="2">comocomo compositoras</segment>
    <segment id="3">Enquanto o sucesso do momento "</segment>
    <segment id="4">Ai, se</segment>
    <segment id="5">se eu te pego" bomba pelo mundo afora</segment>
    <segment id="6">, a polêmica sobre quem compôs o refrão da música rola solta no eixo Bahia-Paraíba.</segment>
    <segment id="7">Sete garotas paraibanas afirmam que o refrão do hit surgiu numa brincadeira entre amigas durante viagem à Disney</segment>
    <segment id="8">,  nos Estados Unidos</segment>
    <segment id="9">, em 2006.</segment>
    <segment id="10">De acordo com a estudante de Direito Maria Eduarda Lucena</segment>
    <segment id="11">, uma das amigas paquerava um guia turístico.</segment>
    <segment id="12">As observações sobre o moço inspiraram o grupo na composição do refrão.</segment>
    <segment id="13">Dois anos depois</segment>
    <segment id="14">, parte do grupo foi a Porto Seguro</segment>
    <segment id="15">, quando Sharon convidou três delas para cantar no palco.</segment>
    <segment id="16">“De lá para cá</segment>
    <segment id="17">, ela se</segment>
    <segment id="18">se apropriou indevidamente do refrão.</segment>
    <segment id="19">Há um mês registramos a letra em cartório e reunimos provas para entrar com processo de reconhecimento pela autoria”</segment>
    <segment id="20">, afirma a moça.</segment>
    <segment id="21">A grande surpresa foi que</segment>
    <segment id="22">, após esbravejar pelos quatro cantos que era autora do refrão</segment>
    <segment id="23">, Sharon aparece em um  vídeo no YouTube e que foi exibido pela TV Tambaú</segment>
    <segment id="24">, afiliada do SBT em João Pessoa</segment>
    <segment id="25">, dando o crédito pelo refrão a três estudantes da Paraíba.</segment>
    <segment id="26">Confira o vídeo em que Sharon dá o crédito do refrão às estudantes em nossa página principal.</segment>
    <segment id="27">A novidade pegou todo mundo de surpresa.</segment>
    <segment id="28">Até a banda Cangaia de Jegue</segment>
    <segment id="29">, uma das primeiras a gravar o sucesso</segment>
    <segment id="30">, ficou pasma.</segment>
    <segment id="31">“Ainda estamos tentando entender”</segment>
    <segment id="32">, disse o assessor Liderico Neto.</segment>
    <segment id="33">A produção de Michel Teló</segment>
    <segment id="34">, o maior beneficiado</segment>
    <segment id="35">, não foi encontrada até o fechamento desta edição.</segment>
    <segment id="36">Teló tá de boa</segment>
    <segment id="37">Enquanto o couro come entre a mulherada</segment>
    <segment id="38">, Michel Teló continua aumentando sua poupança com o hit.</segment>
    <segment id="39">De bolso cheio</segment>
    <segment id="40">, ofereceu R$ 300 mil à organização de um evento para cancelar sua aparição.</segment>
    <segment id="41">A produção negou</segment>
    <segment id="42">, masmas ele não parece preocupado.</segment>
    <segment id="43">Dançou com Neymar e elegeu o jogador</segment>
    <segment id="44">comocomo o melhor bailarino de “Ai</segment>
    <segment id="45">, sese eu te pego”.</segment>
    <segment id="46">Dinheiro atrai dinheiro!</segment>
  </rst>
</analysis>