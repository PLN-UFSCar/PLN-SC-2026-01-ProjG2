  <rst>
    <segment id="1">Família não crê na versão da polícia
Parentes de Kelly Cyclone discordam de inquérito e dizem que Gustavinho é suspeito</segment>
    <segment id="2">A conclusão do inquérito sobre a morte de Kelly Cyclone</segment>
    <segment id="3">, 23 anos</segment>
    <segment id="4">, surpreendeu a família da jovem.</segment>
    <segment id="5">O motivo é a ausência de Carlos Gustavo Cohen de Alencar Braga</segment>
    <segment id="6">, 26, conhecido</segment>
    <segment id="7">comocomo Gustavinho</segment>
    <segment id="8">, entre os autores.</segment>
    <segment id="9">Ele é apontado desde o início pela família de Kelly</segment>
    <segment id="10">comocomo suspeito.</segment>
    <segment id="11">“</segment>
    <segment id="12">Todo mundo sabe que foi Gustavinho que matou Kelly.</segment>
    <segment id="13">O outro rapaz que estava com ele (Iago) confirmou que ele matou”</segment>
    <segment id="14">,  declara o comerciante Antonio Carlos Baptista</segment>
    <segment id="15">, pai de Kelly Cyclone.</segment>
    <segment id="16">Segundo Antonio Carlos</segment>
    <segment id="17">,  Gustavinho ligou  para uma amiga que esteve horas antes  com Kelly e mandou a menina ir ver a colega que estava morta.</segment>
    <segment id="18">“</segment>
    <segment id="19">Gustavinho quando bebe anda dizendo que mulher não bota banca com ele.</segment>
    <segment id="20">Ele é bandido</segment>
    <segment id="21">, traficante.</segment>
    <segment id="22">É suspeito de outros quatro assassinatos”</segment>
    <segment id="23">, afirmou o pai de Kelly.</segment>
    <segment id="24">O comerciante informou que irá até a Delegacia de Lauro de Freitas para ter mais informações sobre a conclusão do inquérito.</segment>
    <segment id="25">“Não entendo</segment>
    <segment id="26">porque</segment>
    <segment id="27">porque Gustavinho não disse antes quem foram os assassinos.</segment>
    <segment id="28">Ele tem participação no</segment>
    <segment id="29">casocaso”</segment>
    <segment id="30">, finalizou Antônio Carlos.</segment>
    <segment id="31">A irmã de Kelly Cyclone</segment>
    <segment id="32">, Karla Sales</segment>
    <segment id="33">, 26, entrega o</segment>
    <segment id="34">casocaso “nas mãos de Deus” e prefere não emitir opinião por temer represálias.</segment>
    <segment id="35">“Não sei</segment>
    <segment id="36">sese foram esses caras (Miminho e Véio).</segment>
    <segment id="37">Mas a polícia sabe quem são os culpados e faz muito rodeio”</segment>
    <segment id="38">, declara.</segment>
    <segment id="39">O pai de Gustavinho</segment>
    <segment id="40">, Antonio Carlos de Alencar Braga</segment>
    <segment id="41">, 50, diz que desde o dia do crime sabia quem eram os assassinos e que o filho era inocente.</segment>
    <segment id="42">Ele viu tudo: Gustavinho estava com Kelly</segment>
    <segment id="43">Em agosto</segment>
    <segment id="44">, Gustavinho disse em depoimento que Kelly Cyclone foi assassinada por um homem que estava com outros dois comparsas em um Ford Focus</segment>
    <segment id="45">, cor prata.</segment>
    <segment id="46">Ele disse ter ido ao Salvador Fest</segment>
    <segment id="47">, no Parque de Exposições</segment>
    <segment id="48">, no dia do crime</segment>
    <segment id="49">,  juntamente com Kelly</segment>
    <segment id="50">, a irmã dela</segment>
    <segment id="51">, Carla Souza</segment>
    <segment id="52">, 24, e mais duas amigas.</segment>
    <segment id="53">Após a festa</segment>
    <segment id="54">, Gustavinho disse que ele</segment>
    <segment id="55">, e Kelly e um amigo Yago estavam em um carro e foram fechados pelo Focus prata.</segment>
    <segment id="56">Um ocupante desceu e matou a dançarina.</segment>
    <segment id="57">Ele negou que teve um</segment>
    <segment id="58">casocaso amoroso com Kelly e acrescentou que conheceu a garota há cerca de 15 dias.</segment>
  </rst>
</analysis>