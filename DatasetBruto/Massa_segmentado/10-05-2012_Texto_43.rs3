  <rst>
    <segment id="1">Leão vence no Engenhão e</segment>
    <segment id="2">sese classifica</segment>
    <segment id="3">Com uma virada sensacional</segment>
    <segment id="4">, Vitória elimina o alvinegro carioca</segment>
    <segment id="5">Mesmo com o juiz ‘ajudando’ o Botafogo</segment>
    <segment id="6">, o Leão foi valente</segment>
    <segment id="7">, ontem à noite</segment>
    <segment id="8">, no Engenhão</segment>
    <segment id="9">, e venceu o alvinegro por 2 a 1</segment>
    <segment id="10">, de virada</segment>
    <segment id="11">, pelas oitavas de final da Copa do Brasil.</segment>
    <segment id="12">Agora é esperar o Coritiba</segment>
    <segment id="13">, adversário das quartas de final.</segment>
    <segment id="14">No início do jogo</segment>
    <segment id="15">, o Vitória esperava o  Botafogo para sair no contra-ataque.</segment>
    <segment id="16">E foi isso que aconteceu na maior parte do primeiro tempo.</segment>
    <segment id="17">Logo aos 11 minutos</segment>
    <segment id="18">, Loco Abreu recebeu o passe de Maicosuel e</segment>
    <segment id="19">, de cara</segment>
    <segment id="20">, mandou na rede</segment>
    <segment id="21">, masmas do lado de fora.</segment>
    <segment id="22">Dez minutos depois</segment>
    <segment id="23">, “El Loco” ganhou a disputa com Uelliton – com falta – e a bola sobrou para Elkeson tocar na saída de Douglas: 1 a 0.</segment>
    <segment id="24">Os jogadores do rubro-negro ganhavam todas nas jogadas aéreas.</segment>
    <segment id="25">Em escanteio</segment>
    <segment id="26">, Neto Baiano cabeceou e Lucas salvou em cima da linha.</segment>
    <segment id="27">No fim do primeiro tempo</segment>
    <segment id="28">, porém</segment>
    <segment id="29">porém, o lateral do Botafogo fez a mesma coisa em cabeçada de Uelliton</segment>
    <segment id="30">, masmas com as mãos.</segment>
    <segment id="31">A bola havia entrado</segment>
    <segment id="32">, masmas o árbitro Paulo César de Oliveira marcou pênalti e expulsou Lucas.</segment>
    <segment id="33">Na cobrança</segment>
    <segment id="34">, Jefferson</segment>
    <segment id="35">,  adiantado</segment>
    <segment id="36">,  defendeu o chute de Neto Baiano.</segment>
    <segment id="37">Na etapa final</segment>
    <segment id="38">, com um a mais</segment>
    <segment id="39">, o Leão voltou feroz.</segment>
    <segment id="40">Aos 11 minutos</segment>
    <segment id="41">, Pedro Ken limpou os marcadores e chutou no canto direito: 1 a 1.</segment>
    <segment id="42">O rubro-negro pressionava em busca da virada.</segment>
    <segment id="43">E ela veio aos 23</segment>
    <segment id="44">, quando Wellington Saci cruzou na cabeça do baixinho Tartá: 2 a 1.

Pedro Ken</segment>
    <segment id="45">, o cara do jogo</segment>
    <segment id="46">, ainda foi expulso</segment>
    <segment id="47">, masmas não deu para o Fogão</segment>
    <segment id="48">, que viu a comemoração dos guerreiros rubro-negros com as labaredas apagadas.</segment>
  </rst>
