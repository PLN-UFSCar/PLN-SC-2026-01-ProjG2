  <rst>
    <segment id="1">Com orçamento anual de R$ 1</segment>
    <segment id="2">,5 milhão</segment>
    <segment id="3">, Lula cria instituto e busca parcerias internacionais</segment>
    <segment id="4">SÃO PAULO - Sete meses depois de sair do Planalto</segment>
    <segment id="5">, o ex-presidente Luiz Inácio Lula da Silva cria nesta segunda-feira o Instituto Lula</segment>
    <segment id="6">, que substituirá o Instituto Cidadania</segment>
    <segment id="7">, sede do antigo governo paralelo e das caravanas do PT.</segment>
    <segment id="8">A nova entidade nasce com orçamento modesto</segment>
    <segment id="9">, de menos de R$ 1</segment>
    <segment id="10">,5 milhão por ano</segment>
    <segment id="11">, masmas até o fim de 2011</segment>
    <segment id="12">, o ex-presidente deve buscar verbas privadas e lançar projetos de cooperação com a África e a América Latina.</segment>
    <segment id="13">A diretoria</segment>
    <segment id="14">, mais enxuta</segment>
    <segment id="15">, será composta por gente próxima: Paulo Okamotto</segment>
    <segment id="16">, Clara Ant e José de Filippi vêm do Cidadania.</segment>
    <segment id="17">A eles</segment>
    <segment id="18">sese juntam Luiz Dulci e Paulo Vannuchi.</segment>
    <segment id="19">Lula também pretende montar um quadro técnico e político com cerca de 30 colaboradores</segment>
    <segment id="20">, reunidos numa espécie de conselhão.</segment>
    <segment id="21">A lista de sócios do instituto não está fechada</segment>
    <segment id="22">, masmas Lula já está fazendo convites.</segment>
    <segment id="23">Entre os confirmados estão os atuais conselheiros: Maria Victoria Benevides</segment>
    <segment id="24">, Pedro Paulo Martoni Branco</segment>
    <segment id="25">, João Felício e Flávio Jorge Rodrigues da Silva.</segment>
    <segment id="26">Outros cotados são a ex-primeira-dama</segment>
    <segment id="27">, Marisa Letícia</segment>
    <segment id="28">, o ex-ministro Antonio Palocci e o senador Lindberg Farias.

- A partir da criação do Instituto Lula</segment>
    <segment id="29">, começaremos a elaborar os pré-projetos de cooperação</segment>
    <segment id="30">, que irão permitir realizar os orçamentos de recursos financeiros e humanos.</segment>
    <segment id="31">Lula é o presidente de honra</segment>
    <segment id="32">, está emprestando seu nome e prestígio ao instituto - explicou Okamotto</segment>
    <segment id="33">, que será diretor-presidente do instituto e é sócio de Lula na empresa LILS Palestras</segment>
    <segment id="34">, Eventos e Publicações Ltda.</segment>
    <segment id="35">No ato de hoje</segment>
    <segment id="36">, uma reunião a portas fechadas em um hotel da capital paulista</segment>
    <segment id="37">, Lula conduzirá a transformação jurídica dos institutos</segment>
    <segment id="38">, um ato simbólico que pretende coroar os 20 anos do Instituto Cidadania.</segment>
    <segment id="39">Haverá uma homenagem que lembrará o governo paralelo (1990-1992)</segment>
    <segment id="40">, as caravanas da cidadania (1993-1996) e a formulação de políticas públicas (1999-2002)</segment>
    <segment id="41">, ligados à trajetória política de Lula.</segment>
    <segment id="42">Nos últimos anos</segment>
    <segment id="43">, o instituto esteve praticamente abandonado</segment>
    <segment id="44">, sobrevivendo à base de doações de indivíduos e sindicatos.

- O local passou por uma reforma</segment>
    <segment id="45">, até ajudei</segment>
    <segment id="46">comocomo engenheiro.</segment>
    <segment id="47">Continua financiado por doações de sindicatos e empresas</segment>
    <segment id="48">, masmas o custo é baixo.</segment>
    <segment id="49">O orçamento mensal</segment>
    <segment id="50">, desde janeiro</segment>
    <segment id="51">, com salários</segment>
    <segment id="52">, é de cerca de R$ 120 mil por mês</segment>
    <segment id="53">, não chegou a meio milhão em quatro meses de funcionamento - disse o deputado José de Filippi (PT-SP)</segment>
    <segment id="54">, ex-tesoureiro da campanha da presidente Dilma Rousseff e atual presidente do Instituto Cidadania.</segment>
  </rst>
</analysis>