  <rst>
    <segment id="1">Cantor vence corda e fica nu</segment>
    <segment id="2">Promessa é dívida!</segment>
    <segment id="3">Guga tirou a roupa e deixou Léo Kret de boca aberta</segment>
    <segment id="4">O folião Guga de Paula tinha feito uma promessa de que</segment>
    <segment id="5">, caso</segment>
    <segment id="6">caso sobrevivesse à segunda corda consecutiva</segment>
    <segment id="7">, ficaria pelado no reality.</segment>
    <segment id="8">O gato mostrou que é de palavra e cumpriu o prometido</segment>
    <segment id="9">, após a eliminação de sua rival Cissa Chagas</segment>
    <segment id="10">, com 65% dos votos.</segment>
    <segment id="11">Depois dessa</segment>
    <segment id="12">, ninguém pode duvidar mais dele!</segment>
    <segment id="13">Tudo bem que a promessa não foi  exatamente</segment>
    <segment id="14">comocomo Guga disse que seria</segment>
    <segment id="15">, pois</segment>
    <segment id="16">pois ele não saiu andando.</segment>
    <segment id="17">Mas só pelo fato de ter ficado nu</segment>
    <segment id="18">, já valeu a pena!</segment>
    <segment id="19">A atitude do folião deixou a dançarina Léo Kret de boca aberta e</segment>
    <segment id="20">, desesperada</segment>
    <segment id="21">, ela só fazia gritar!</segment>
    <segment id="22">A mulherada que viu a cena no momento deve ter gostado muito.</segment>
    <segment id="23">Imagine</segment>
    <segment id="24">sese os outros confinados resolverem adotar a atitude de Guga!</segment>
    <segment id="25">Faz sentido</segment>
    <segment id="26">, pois</segment>
    <segment id="27">pois, pelo sonhado prêmio de R$ 30 mil e um carro</segment>
    <segment id="28">, - muita gente faria promessas bem doidas</segment>
    <segment id="29">comocomo essa.</segment>
  </rst>
</analysis>