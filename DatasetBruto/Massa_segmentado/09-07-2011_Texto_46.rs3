  <rst>
    <segment id="1">Marta tenta aliar talento com resultados para superar traumas do passado na partida contra os EUA
DRESDEN</segment>
    <segment id="2">, Alemanha - Junto com a derrota da seleção brasileira na Copa de 1986</segment>
    <segment id="3">, no México</segment>
    <segment id="4">, havia um choro que trazia esperança.</segment>
    <segment id="5">Enquanto a geração de Zico lamentava a impossibilidade de conciliar futebol-arte com bons resultados</segment>
    <segment id="6">, uma menina nascida no início daquele ano começava a crescer disposta a rever conceitos no futebol.</segment>
    <segment id="7">Reconhecida</segment>
    <segment id="8">comocomo a melhor jogadora do mundo mesmo sem um título de expressão</segment>
    <segment id="9">, Marta tem nova chance de redimir a camisa amarela dos traumas do passado.</segment>
    <segment id="10">Depois de perder as duas últimas finais olímpicas para as americanas</segment>
    <segment id="11">, a seleção brasileira feminina enfrenta as rivais neste domingo</segment>
    <segment id="12">, às 12h30m (de Brasília)</segment>
    <segment id="13">, em Dresden</segment>
    <segment id="14">, por vaga numa das semifinais do Mundial.
- Trata-</segment>
    <segment id="15">sese de uma equipe de alto nível</segment>
    <segment id="16">, masmas também não é um bicho de sete cabeças.</segment>
    <segment id="17">A gente já jogou contra elas e sabe a forma</segment>
    <segment id="18">comocomo</segment>
    <segment id="19">sese comportam - disse a camisa 10</segment>
    <segment id="20">, que joga no New York Flash da liga americana.</segment>
    <segment id="21">- Não escolhemos adversário.</segment>
    <segment id="22">Tenho muito respeito pelos Estados Unidos.</segment>
    <segment id="23">À ESPERA:
França passa pela Inglaterra nos pênaltis e aguarda Brasil ou EUA</segment>
    <segment id="24">Disposta a mudar o fim de uma história que começa em 1986</segment>
    <segment id="25">, Marta não precisa fazer tudo diferente.</segment>
    <segment id="26">Embora as americanas tenham vencido as finais olímpicas de Atenas-2004 e Pequim-2008</segment>
    <segment id="27">, na prorrogação</segment>
    <segment id="28">, por 2 a 1 e 1 a 0</segment>
    <segment id="29">, respectivamente</segment>
    <segment id="30">, a Copa do Mundo</segment>
    <segment id="31">sese anuncia mais favorável.</segment>
    <segment id="32">Na semifinal do último Mundial</segment>
    <segment id="33">, Marta comandou o baile que terminou com goleada por 4 a 0 e a eliminação dos EUA.</segment>
    <segment id="34">Na final contra Alemanha</segment>
    <segment id="35">, no entanto</segment>
    <segment id="36">, ao perder pênalti quando o jogo estava 0 a 0</segment>
    <segment id="37">, a camisa 10 reviveu o drama da época em que nasceu.</segment>
    <segment id="38">Além de Zico ter desperdiçado penalidade máxima no tempo normal de um jogo que estava 1 a 1</segment>
    <segment id="39">, Sócrates e Júlio César erraram suas cobranças na disputa que classificou à França.</segment>
    <segment id="40">Quatro anos antes</segment>
    <segment id="41">, o Brasil havia feito o mundo rir e chorar pela beleza de seu futebol e a contundência de sua eliminação na Copa da Espanha.</segment>
    <segment id="42">Mesmo que a associação seja também um elogio</segment>
    <segment id="43">, ser tratada</segment>
    <segment id="44">comocomo uma representante da era Zico de saias é um peso do qual Marta quer</segment>
    <segment id="45">sese livrar com orgulho.</segment>
    <segment id="46">Para isso</segment>
    <segment id="47">, precisa vencer as americanas e a desconfiança que acompanha a beleza do futebol desde que o encanto terminou em lágrimas.</segment>
    <segment id="48">Emotiva</segment>
    <segment id="49">, incapaz de conter o choro na alegria ou na tristeza</segment>
    <segment id="50">, Marta transforma dores em esperança para mostrar que resultado</segment>
    <segment id="51">, técnica</segment>
    <segment id="52">, vigor físico e delicadeza podem andar juntos.</segment>
    <segment id="53">E que 1986 ainda pode ser celebrado</segment>
    <segment id="54">comocomo o ano do renascimento do melhor futebol brasileiro.</segment>
    <segment id="55">BRASIL x ESTADOS UNIDOS
Brasil: Andréia</segment>
    <segment id="56">, Aline</segment>
    <segment id="57">, Renata Costa e Erika</segment>
    <segment id="58">; Maurine</segment>
    <segment id="59">, Ester</segment>
    <segment id="60">, Formiga</segment>
    <segment id="61">, Rosana e Maurine</segment>
    <segment id="62">; Marta e Cristiane.</segment>
    <segment id="63">EUA: Solo</segment>
    <segment id="64">, Rampone</segment>
    <segment id="65">, Le Peilbert</segment>
    <segment id="66">, Boxx e Rodríguez</segment>
    <segment id="67">; Lloyd</segment>
    <segment id="68">, Kriegger</segment>
    <segment id="69">, Cheney e Rapinoe</segment>
    <segment id="70">; Buehler e Wambach.
TRANSMISSÃO: Sportv</segment>
    <segment id="71">, Sportv HD e Band</segment>
  </rst>
