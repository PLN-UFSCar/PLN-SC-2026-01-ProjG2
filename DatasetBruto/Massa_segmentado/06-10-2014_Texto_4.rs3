    <segment id="21">รโฐ a nossa sรยฉtima vitรยณria</segment>
    <segment id="22">, sendo duas na primeira eleiรยงรยฃo de Lula</segment>
    <segment id="23">, mais duas na segunda eleiรยงรยฃo de Lula</segment>
    <segment id="24">, mais duas na minha primeira eleiรยงรยฃo e esta agora.</segment>
    <segment id="25">Quero agradecer aos eleitores anรยดnimos</segment>
    <segment id="26">, de quem eu sinto ter recebido a mensagem de que devo seguir em frenteรขโฌ</segment>
    <segment id="27">, falou.</segment>
    <segment id="28">Hoje, Dilma Rousseff permanece em Brasรยญlia</segment>
