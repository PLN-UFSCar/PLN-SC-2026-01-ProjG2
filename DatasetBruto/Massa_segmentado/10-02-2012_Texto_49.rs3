  <rst>
    <segment id="1">Comando dá ultimato a movimento grevista</segment>
    <segment id="2">A partir de hoje</segment>
    <segment id="3">, quem faltar ao trabalho terá o dia descontado no salário</segment>
    <segment id="4">O comandante da Polícia Militar (PM)</segment>
    <segment id="5">, coronel Alfredo Castro</segment>
    <segment id="6">, deu um ultimato nesta sexta-feira (10)</segment>
    <segment id="7">para que</segment>
    <segment id="8">para que os PMs retornem ao trabalho.

"</segment>
    <segment id="9">A partir de hoje a ausência ao trabalho não vai ser mais vista</segment>
    <segment id="10">comocomo adesão ao movimento grevista.</segment>
    <segment id="11">A ausência está sendo vista</segment>
    <segment id="12">comocomo uma falta ao serviço</segment>
    <segment id="13">, que,</segment>
    <segment id="14">sese confirmada</segment>
    <segment id="15">, será punida com o rigor da lei".</segment>
    <segment id="16">De acordo com ele</segment>
    <segment id="17">, os policiais faltosos podem ter o dia não trabalhado descontado do salário ou até mesmo ser preso em unidade militar.</segment>
    <segment id="18">O coronel afirmou ainda que a greve da corporação</segment>
    <segment id="19">, que hoje completa 11 dias</segment>
    <segment id="20">, terminou.</segment>
    <segment id="21">Segundo ele</segment>
    <segment id="22">, 85% do efetivo já está trabalhando em toda Bahia.</segment>
    <segment id="23">Ele não especificou a situação em Salvador.</segment>
    <segment id="24">As afirmações foram feitas em entrevista coletiva realizada no Quartel dos Aflitos.</segment>
    <segment id="25">Apesar da informação do comandante</segment>
    <segment id="26">, a assembleia dos policiais grevistas está mantida para esta tarde</segment>
    <segment id="27">, às 16 horas</segment>
    <segment id="28">, no Ginásio do Sindicato dos Bancários</segment>
    <segment id="29">, no Largo dos Aflitos.</segment>
    <segment id="30">Nesta manhã</segment>
    <segment id="31">, não foram vistos manifestantes no local</segment>
    <segment id="32">, masmas a estratégia do grupo mudou desde que eles desocuparam a Assembleia Legislativa da Bahia nesta quinta.</segment>
    <segment id="33">Eles decidiram só</segment>
    <segment id="34">sese reunir para votar o rumo do movimento.</segment>
    <segment id="35">De acordo com o comandante</segment>
    <segment id="36">, mesmo com o retorno dos PMs ao trabalho</segment>
    <segment id="37">, ainda há bairros vulneráveis.</segment>
    <segment id="38">"</segment>
    <segment id="39">Há dificuldade de policiamento na Suburbana e Cajazeiras</segment>
    <segment id="40">, masmas isso não é motivo</segment>
    <segment id="41">para que</segment>
    <segment id="42">para que as pessoas tenham medo de ir para a rua.</segment>
    <segment id="43">O policiamento está cada vez mais</segment>
    <segment id="44">sese normalizando"</segment>
    <segment id="45">, disse.</segment>
  </rst>
</analysis>