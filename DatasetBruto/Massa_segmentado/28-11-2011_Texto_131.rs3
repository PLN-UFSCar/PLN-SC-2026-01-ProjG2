  <rst>
    <segment id="1">Elevador fica enguiçado na primeirona</segment>
    <segment id="2">Com boa exibição diante do Santos</segment>
    <segment id="3">, na Vila Belmiro</segment>
    <segment id="4">, o Esquadrão de Aço segura</segment>
    <segment id="5">Neymar</segment>
    <segment id="6">Ontem foi o Dia do Fico para o Bahia.</segment>
    <segment id="7">Depois de passar toda a temporada com riscos de retorno à Série B</segment>
    <segment id="8">, o tricolor mostrou que é time de Primeira</segment>
    <segment id="9">, arrancou um  1 a 1 com o Santos</segment>
    <segment id="10">, na Vila Belmiro</segment>
    <segment id="11">, e garantiu a permanência na elite.</segment>
    <segment id="12">O resultado deixou o Esquadrão - 15º</segment>
    <segment id="13">, com 43 pontos -</segment>
    <segment id="14">, sem chances de ser alcançado pelas equipes do Z-4: Avaí</segment>
    <segment id="15">, América–MG - já rebaixados -</segment>
    <segment id="16">, Ceará e Atlético-PR.</segment>
    <segment id="17">Logo no início do jogo</segment>
    <segment id="18">, o Bahia tentou fisgar o Peixe.</segment>
    <segment id="19">Souza, da entrada da área</segment>
    <segment id="20">, finalizou bem para abrir o placar.</segment>
    <segment id="21">Porém, não é fácil passar por um  time que tem Neymar.</segment>
    <segment id="22">Mesmo bem marcado</segment>
    <segment id="23">, o craque conseguiu espaço e</segment>
    <segment id="24">, com um chute da entrada da área</segment>
    <segment id="25">, venceu Lomba ainda na primeira etapa: 1 a 1.</segment>
    <segment id="26">No segundo tempo</segment>
    <segment id="27">, o Santos teve mais posse de bola</segment>
    <segment id="28">, só que o Bahia marcou forte e garantiu o empate</segment>
    <segment id="29">, que emocionou Papai Joel.</segment>
    <segment id="30">Além da salvação</segment>
    <segment id="31">, o resultado dá esperanças ao Bahia de disputar a Sul-Americana.</segment>
    <segment id="32">Para isso</segment>
    <segment id="33">, bater o Ceará</segment>
    <segment id="34">, em Pituaçu</segment>
    <segment id="35">, na última rodada</segment>
    <segment id="36">, é obrigação</segment>
    <segment id="37">, sem falar que a torcida precisa torcer por derrota de Atlético-MG ou Atlético-GO</segment>
    <segment id="38">, que estão com 45 pontos e enfrentam Cruzeiro e América-MG</segment>
    <segment id="39">, respectivamente.</segment>
  </rst>
</analysis>