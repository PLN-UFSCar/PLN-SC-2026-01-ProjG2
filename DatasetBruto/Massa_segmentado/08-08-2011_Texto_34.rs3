  <rst>
    <segment id="1">População vai para luta pela paz
Participantes levaram faixas e cartazes às ruas para alertar as autoridades políticas</segment>
    <segment id="2">Aos 6 anos</segment>
    <segment id="3">, Letícia Silva Santos perdeu o pai</segment>
    <segment id="4">, Paulo Roberto Souza Santos</segment>
    <segment id="5">, 34, assassinado a tiros durante uma briga de trânsito em Campinas de Pirajá</segment>
    <segment id="6">, em maio último.</segment>
    <segment id="7">A paisagista Lúcia Roriz</segment>
    <segment id="8">, 57, enfrenta as idas e vindas ao Hospital Geral do Estado (HGE)</segment>
    <segment id="9">, onde o filho</segment>
    <segment id="10">, Paulo César Perrone Júnior</segment>
    <segment id="11">, 32, baterista da banda Estakazero</segment>
    <segment id="12">, está internado desde 19 de julho</segment>
    <segment id="13">, quando foi baleado na cabeça durante um assalto.</segment>
    <segment id="14">Estas são apenas duas das centenas de histórias contadas na “</segment>
    <segment id="15">Mobilização contra a Violência – a Favor da Paz”</segment>
    <segment id="16">, que levou pelo menos 500 pessoas</segment>
    <segment id="17">, do monumento Clériston Andrade</segment>
    <segment id="18">, na Avenida Garibaldi</segment>
    <segment id="19">, ao Palácio de Ondina</segment>
    <segment id="20">, residência oficial do governador</segment>
    <segment id="21">, ontem pela manhã.</segment>
    <segment id="22">“</segment>
    <segment id="23">Nossa luta é por uma cidade mais segura.</segment>
    <segment id="24">Quando saímos de casa não sabemos</segment>
    <segment id="25">sese vamos voltar”</segment>
    <segment id="26">, disse uma das idealizadoras da mobilização</segment>
    <segment id="27">, a musicoterapeuta Gal Vieira.</segment>
    <segment id="28">Ela e uma amiga</segment>
    <segment id="29">, a enfermeira Karla Santana</segment>
    <segment id="30">, não tiveram nenhum familiar vítima da violência</segment>
    <segment id="31">, masmas não queriam mais</segment>
    <segment id="32">sese trancar em casa</segment>
    <segment id="33">, enquanto ouviam notícias de assaltos</segment>
    <segment id="34">, latrocínios (roubos seguidos de morte) e assassinatos ocorrendo na cidade.</segment>
    <segment id="35">“Passamos a discutir a possibilidade de uma mobilização nas redes sociais”</segment>
    <segment id="36">, contou Gal.</segment>
    <segment id="37">Doze dias depois</segment>
    <segment id="38">, pelo menos três mil pessoas apoiaram a iniciativa na redes sociais.</segment>
    <segment id="39">Movimento: Mãos à obra</segment>
    <segment id="40">Uma das idealizadoras da “</segment>
    <segment id="41">Mobilização contra a Violência – a Favor da Paz”</segment>
    <segment id="42">, a musicoterapeuta da Clínica de Desenvolvimento Humano</segment>
    <segment id="43">, Gal Vieira</segment>
    <segment id="44">, 37, formada pela Universidade Católica do Salvador</segment>
    <segment id="45">, decidiu iniciar um movimento no dia 26 de julho</segment>
    <segment id="46">, quando viu na imprensa a notícia da tentativa de assalto que resultou no ferimento à bala da advogada Ludmila de Araújo</segment>
    <segment id="47">, 37 anos</segment>
    <segment id="48">, na Avenida Garibaldi.</segment>
    <segment id="49">Ela se</segment>
    <segment id="50">se juntou a uma amiga</segment>
    <segment id="51">, a enfermeira do Hospital Geral do Estado (HGE) Karla Santana</segment>
    <segment id="52">, 36, e convidaram todos os amigos da rede virtual Facebook para participar.</segment>
    <segment id="53">Entenda o</segment>
    <segment id="54">casocaso</segment>
    <segment id="55">A Secretaria da Segurança Pública registrou 791 assassinatos e 466 tentativas de homicídio na capital baiana de janeiro a junho deste ano.</segment>
    <segment id="56">O índice dá conta de uma média de 131 mortes violentas por mês e</segment>
    <segment id="57">, pelo menos</segment>
    <segment id="58">, quatro a cada dia.</segment>
    <segment id="59">Os homicídios no período de seis meses reduziram 13</segment>
    <segment id="60">,07%, se</segment>
    <segment id="61">se comparados ao registro do mesmo período do ano passado – de 910 para 791 casos.</segment>
    <segment id="62">“</segment>
    <segment id="63">Com relação às investigações do crime praticado contra o músico da banda Estakazero</segment>
    <segment id="64">, a polícia divulgou na sexta-feira imagens dos responsáveis</segment>
    <segment id="65">, que devem ser localizados e presos”</segment>
    <segment id="66">, respondeu a SSP .</segment>
    <segment id="67">De janeiro de 2009 a junho deste ano</segment>
    <segment id="68">, 4.159 pessoas foram assassinadas na capital baiana</segment>
    <segment id="69">, média de 138 mortos por mês</segment>
    <segment id="70">, quatro por dia.</segment>
    <segment id="71">No dia 21 de abril</segment>
    <segment id="72">, a SSP inaugurou o Departamento de Homicídios e Proteção à Pessoa</segment>
    <segment id="73">, com o objetivo de reduzir os altos índices de homicídios no Estado</segment>
    <segment id="74">, entre 16% e 20%</segment>
    <segment id="75">, em até dois anos.</segment>
  </rst>
</analysis>