  <rst>
    <segment id="1">Cantor de A Bronkka vira</segment>
    <segment id="2">casocaso de polГѓВ­cia</segment>
    <segment id="3">Depois de show em Aracaju</segment>
    <segment id="4">, cantor</segment>
    <segment id="5">ГѓВ© acusado de agressГѓВЈo e prejuГѓВ­zos em hotel</segment>
    <segment id="6">Com uma agenda cada vez mais agitada</segment>
    <segment id="7">, Igor KannГѓВЎrio e sua A Bronkka voaram para Aracaju.</segment>
    <segment id="8">Mas o voo foi turbulento.</segment>
    <segment id="9">O cantor protagonizou um barraco tamanho que virou</segment>
    <segment id="10">casocaso de polГѓВ­cia.</segment>
    <segment id="11">ApГѓВіs  fazer um showzaГѓВ§o no Swinga Aracaju</segment>
    <segment id="12">, na PraГѓВ§a da Orla da capital sergipana</segment>
    <segment id="13">, no sГѓВЎbado</segment>
    <segment id="14">, o cantor voltou ao hotel River Side Farol</segment>
    <segment id="15">, por volta das 5h da manhГѓВЈ de ontem</segment>
    <segment id="16">, bastante eufГѓВіrico</segment>
    <segment id="17">, falando alto e usando palavrГѓВµes.</segment>
    <segment id="18">NГѓВЈo gostou quando o mensageiro Alexandre chamou sua atenГѓВ§ГѓВЈo e partiu para cima</segment>
    <segment id="19">, desferindo dois murros contra o rosto dele.</segment>
    <segment id="20">A versГѓВЈo foi dada pela gerente do hotel</segment>
    <segment id="21">, Cristiane Moraes</segment>
    <segment id="22">, que espera Гўв‚¬Е“nunca mais ter de receber IgorГўв‚¬. Гўв‚¬Е“AlГѓВ©m da agressГѓВЈo</segment>
    <segment id="23">, o apartamento 204 em que o cantor</segment>
    <segment id="24">sese hospedou ficou inabitГѓВЎvel.</segment>
    <segment id="25">UtensГѓВ­lios quebrados</segment>
    <segment id="26">, colchГѓВЈo molhado de cachaГѓВ§a</segment>
    <segment id="27">, bitucas de cigarro e maconha para todos os lados.</segment>
    <segment id="28">AtГѓВ© o papel de parede foi queimadoГўв‚¬</segment>
    <segment id="29">, descreve.</segment>
    <segment id="30">Segundo Cristiane</segment>
    <segment id="31">, os prejuГѓВ­zos foram alГѓВ©m</segment>
    <segment id="32">, jГѓВЎ que seis famГѓВ­lia hospedadas no mesmo andar que o cantor saГѓВ­ram do hotel.</segment>
    <segment id="33">A gerente ainda afirma que Igor levou seis garotas para seus aposentos.</segment>
    <segment id="34">Гўв‚¬Е“TrГѓВЄs delas eram menores.</segment>
    <segment id="35">Duas foram encontradas nuas no vestiГѓВЎrio da piscinaГўв‚¬</segment>
    <segment id="36">, conta.</segment>
    <segment id="37">O caso</segment>
    <segment id="38">caso foi parar na polГѓВ­cia</segment>
    <segment id="39">, onde o funcionГѓВЎrio do hotel fez exame de corpo delito e foi lavrado boletim de ocorrГѓВЄncia.</segment>
    <segment id="40">A versГѓВЈo de Igor sГѓВі serГѓВЎ conhecida oficialmente hoje</segment>
    <segment id="41">, apГѓВіs uma reuniГѓВЈo convocada pela empresГѓВЎria da banda.</segment>
    <segment id="42">Enquanto isso</segment>
    <segment id="43">, em Aracaju</segment>
    <segment id="44">, Cristiane batalha para comunicar os outros hoteis da cidade.</segment>
    <segment id="45">Гўв‚¬Е“NГѓВЈo precisamos de alguГѓВ©m assim aqui na nossa cidadeГўв‚¬</segment>
    <segment id="46">, finaliza.</segment>
