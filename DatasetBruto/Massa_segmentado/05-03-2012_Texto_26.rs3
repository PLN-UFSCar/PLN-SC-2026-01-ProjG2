  <rst>
    <segment id="1">Quem ficará com Renata?</segment>
    <segment id="2">Tem dois brothers esperando ela sair</segment>
    <segment id="3">Rafa quer ficar bonito para Renata e até fez as barba e as unhas no salão de beleza</segment>
    <segment id="4">Antes de sair da casa com o maior índice de rejeição do BBB 12</segment>
    <segment id="5">, Rafa disse para Renata:</segment>
    <segment id="6">“Estarei te esperando”.</segment>
    <segment id="7">Mas parece que o brother esqueceu que a loira pegadora passou o rodo na casa</segment>
    <segment id="8">, deixando o colega de confinamento Ronaldo também louquinho de desejo.</segment>
    <segment id="9">Enquanto a musa sofre de saudade lá dentro</segment>
    <segment id="10">, Rafa e Ronaldo declaram que gostariam de ter um repeteco com Renatinha.</segment>
    <segment id="11">A briga será boa!</segment>
    <segment id="12">Ao sair da casa</segment>
    <segment id="13">, Rafa até procurou um salão de beleza</segment>
    <segment id="14">, para tirar a fama de ogro mal cuidado.</segment>
    <segment id="15">Ele deu um trato no cabelo</segment>
    <segment id="16">, fez a barba e até fez as  unhas!</segment>
    <segment id="17">"</segment>
    <segment id="18">Nunca tinha feito as unhas em salão antes na vida!</segment>
    <segment id="19">É tudo pela Renatinha"</segment>
    <segment id="20">, desabafou ele em entrevista para o site Ego.</segment>
    <segment id="21">Ronaldo está mais focado nos trabalhos que apareceram após o a sua saída</segment>
    <segment id="22">, tanto que ele até vai</segment>
    <segment id="23">sese empenhar em um curso para ser ator e apresentador de tevê.</segment>
    <segment id="24">Mesmo cheio de planos profissionais</segment>
    <segment id="25">, ele admitiu que</segment>
    <segment id="26">sese Renata der uma chance</segment>
    <segment id="27">, ele traça!</segment>
    <segment id="28">“</segment>
    <segment id="29">Claro que ficaria com ela.</segment>
    <segment id="30">Só não ficaria</segment>
    <segment id="31">sese fosse cego”</segment>
    <segment id="32">, dispara o bonitão com cara de mau</segment>
    <segment id="33">, que jura não ter feito nada demais com a loira no edredom...

 

