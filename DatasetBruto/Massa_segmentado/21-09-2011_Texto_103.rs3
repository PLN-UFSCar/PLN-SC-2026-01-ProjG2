  <rst>
    <segment id="1">Dê uma mão para o nosso campeão
MASSA!</segment>
    <segment id="2">faz campanha para ajudar o Holyfield a melhorar desta pindaíba</segment>
    <segment id="3">O MASSA!</segment>
    <segment id="4">lança hoje a campanha Ajude o Holyfield.</segment>
    <segment id="5">O objetivo é disponibilizar um canal para quem quiser ajudar o ex-pugilista baiano Reginaldo da Silva de Almeida</segment>
    <segment id="6">, que está internado no HGE desde o dia 8</segment>
    <segment id="7">, após ter 30% do corpo queimado quando tentava salvar dois sobrinhos de um incêndio na casa onde mora em Massaranduba.</segment>
    <segment id="8">“Toda ajuda  é bem- -vinda.</segment>
    <segment id="9">Não sabemos</segment>
    <segment id="10">comocomo será a recuperação e ele não tem condição de arcar com nada”</segment>
    <segment id="11">, afirmou  o  irmão Jackson da Silva de Andrade</segment>
    <segment id="12">, 46.</segment>
    <segment id="13">Holyfield está desempregado há quatro anos  e  vive  de bicos.</segment>
    <segment id="14">No Facebook</segment>
    <segment id="15">, os usuários  também estão na luta para ajudar o ex-atleta e fazem campanha</segment>
    <segment id="16">para que</segment>
    <segment id="17">para que ele  participe do quadro “Lar Doce Lar” do Caldeirão do Huck.</segment>
    <segment id="18">Agora, eles tentam mobilizar os usuários a postarem</segment>
    <segment id="19">, no dia 12 de novembro</segment>
    <segment id="20">, o link da campanha no perfil de Luciano Huck.</segment>
    <segment id="21">A galera do pagode também</segment>
    <segment id="22">sese mexe para ajudar.</segment>
    <segment id="23">Prova disso é o show “Levanta Campeão”</segment>
    <segment id="24">, que acontece nesta sexta-feira</segment>
    <segment id="25">, a partir das 21h</segment>
    <segment id="26">, no espaço Boka Music (fim de linha do bairro Guarany</segment>
    <segment id="27">, na Liberdade).</segment>
    <segment id="28">O ingresso pode ser trocado por  2kg de alimentos não perecíveis.</segment>
    <segment id="29">Por telefone</segment>
    <segment id="30">, Holyfield disse que está  feliz com o carinho.</segment>
    <segment id="31">“</segment>
    <segment id="32">Agradeço ao jornal  MASSA!</segment>
    <segment id="33">, que me conheceu depois do fim da minha carreira e está me ajudando.</segment>
    <segment id="34">Obrigado de coração pela solidariedade”.</segment>
    <segment id="35">O campeão ainda está com dores e não tem previsão de alta.</segment>
  </rst>
</analysis>