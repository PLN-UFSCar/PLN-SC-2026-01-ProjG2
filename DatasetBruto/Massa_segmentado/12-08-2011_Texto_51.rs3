  <rst>
    <segment id="1">Viúva loira acusada de matar o marido
PM da Rondesp Central é assassinado dentro de casa e a mulher é a principal suspeita</segment>
    <segment id="2">A Polícia Civil prendeu e autuou em flagrante por homicídio Cleide Souza Cintra</segment>
    <segment id="3">, 35 anos</segment>
    <segment id="4">, acusada de ter assassinado o marido</segment>
    <segment id="5">, o sargento das Rondas Especiais da PM (Rondesp)</segment>
    <segment id="6">Fábio Nascimento Cintra</segment>
    <segment id="7">, 35.</segment>
    <segment id="8">Segundo o delegado Márcio Alan Assunção</segment>
    <segment id="9">,  do Departamento de Homicídios  (DHPP)</segment>
    <segment id="10">, “tudo leva a crer que ela matou o marido”</segment>
    <segment id="11">, falta provar qual foi a motivação.</segment>
    <segment id="12">Na tarde de ontem</segment>
    <segment id="13">, Cleide fez exames que indicarão</segment>
    <segment id="14">sese há vestígios de pólvora nas mãos</segment>
    <segment id="15">, o que provará</segment>
    <segment id="16">sese ela atirou no dia do crime.</segment>
    <segment id="17">De acordo com o delegado</segment>
    <segment id="18">, os exames  ficarão prontos hoje.</segment>
    <segment id="19">O PM morreu fardado por volta das 6h da manhã de ontem com dois tiros à queima-roupa: um na face e outro no abdômen.</segment>
    <segment id="20">A arma usada era dele</segment>
    <segment id="21">, um revólver  38.</segment>
    <segment id="22">O crime ocorreu no apartamento do casal</segment>
    <segment id="23">, no Edifício Tuiuiu</segment>
    <segment id="24">, Conjunto Novo Arvoredo</segment>
    <segment id="25">,  em Tancredo Neves.</segment>
    <segment id="26">Dois vizinhos ouviram estampidos às 6h</segment>
    <segment id="27">, masmas não viram nenhuma movimentação.</segment>
    <segment id="28">Às 9h, Cleide mandou o filho de seis anos</segment>
    <segment id="29">, que era enteado do policial</segment>
    <segment id="30">, chamar um vizinho e amigo do PM.</segment>
    <segment id="31">“</segment>
    <segment id="32">O menino chegou dizendo: 'meu tio</segment>
    <segment id="33">, minha mãe está te  chamando.</segment>
    <segment id="34">Você não sabe o que aconteceu com meu pai'.</segment>
    <segment id="35">Entrei na casa</segment>
    <segment id="36">, vi o corpo na cama</segment>
    <segment id="37">, a poça de sangue e liguei para a polícia”</segment>
    <segment id="38">, conta o vizinho</segment>
    <segment id="39">, Adilson Bahia Júnior.</segment>
    <segment id="40">A mulher dele foi uma das pessoas que ouviram o barulho dos tiros de manhã cedo.</segment>
    <segment id="41">“Eu estava caminhando.</segment>
    <segment id="42">Minha mulher saiu para olhar</segment>
    <segment id="43">, masmas não viu nada”.</segment>
    <segment id="44">Ela se</segment>
    <segment id="45">se enrolou no depoimento</segment>
    <segment id="46">Márcio Alan afirma que Cleide mantém uma fala desencontrada e parece ser uma pessoa com problemas de comportamento.</segment>
    <segment id="47">“Tive relatos de que o relacionamento não era muito equilibrado</segment>
    <segment id="48">, respeitoso.</segment>
    <segment id="49">Havia um histórico de brigas”</segment>
    <segment id="50">, afirma.</segment>
    <segment id="51">O delegado Marcelo Tannus</segment>
    <segment id="52">, que acompanhou o trabalho da perícia</segment>
    <segment id="53">, disse que a história contada por Cleide de que dois homens a ameaçaram para entrar na casa</segment>
    <segment id="54">, um pela janela e outro pela porta</segment>
    <segment id="55">, é improvável.</segment>
    <segment id="56">Todas as janelas são gradeadas e o portão do prédio é eletrônico.</segment>
    <segment id="57">“</segment>
    <segment id="58">A casa não foi revirada.</segment>
    <segment id="59">A pessoa que matou tinha livre acesso.</segment>
    <segment id="60">Quem atirou colocou a arma debaixo dele.</segment>
    <segment id="61">Pelas lesões</segment>
    <segment id="62">, a vítima nem esboçou reação”</segment>
    <segment id="63">, diz Marcelo Tannus.</segment>
    <segment id="64">Cleide não soube explicar por que demorou para chamar a polícia.</segment>
    <segment id="65">Cartas com ameaça</segment>
    <segment id="66">A perícia encontrou no carro do sargento Fábio Cintra três cartas em que ele era ameaçado de morte por uma pessoa que desejava Cleide.</segment>
    <segment id="67">As cartas eram com letras de papel coladas em uma folha de ofício.</segment>
    <segment id="68">Segundo o vizinho do casal</segment>
    <segment id="69">, Adilson Bahia Júnior</segment>
    <segment id="70">, as cartas eram deixadas na caixa do correio do apartamento do PM.</segment>
    <segment id="71">Cleide dizia que era perseguida há três anos por um homem que ela não conhecia e o marido tentava identificá-lo.</segment>
  </rst>
</analysis>