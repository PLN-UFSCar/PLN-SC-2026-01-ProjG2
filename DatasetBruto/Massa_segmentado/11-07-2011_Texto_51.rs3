    <segment id="1">Na telinha</segment>
    <segment id="2">A gata quer conquistar seu espaço na televisão</segment>
    <segment id="3">Moradora de Brotas</segment>
    <segment id="4">, Claudia Mascarenhas</segment>
    <segment id="5">, 22 anos</segment>
    <segment id="6">, é assistente do palco do programa Cereja Club e sonha ter seu próprio espaço  na televisão.</segment>
    <segment id="7">Enquanto não realiza o desejo</segment>
    <segment id="8">, a moça investe na carreira de modelo.</segment>
    <segment id="9">Apesar de ser cobiçada pelos marmanjos</segment>
    <segment id="10">, a gata alerta aos desavisados de que namora há 4 anos com Pablo Pimenta</segment>
    <segment id="11">, que dá todo apoio para ela.</segment>
