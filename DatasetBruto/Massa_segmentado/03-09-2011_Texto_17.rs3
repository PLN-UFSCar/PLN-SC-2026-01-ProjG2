  <rst>
    <segment id="1">Sem jogar neste domingo</segment>
    <segment id="2">, Botafogo já pensa no Ceará</segment>
    <segment id="3">, na quarta
RIO -  - Na teoria</segment>
    <segment id="4">, o Botafogo está com seu time embalado e pronto para jogar.</segment>
    <segment id="5">Mas, como</segment>
    <segment id="6">como a CBF atendeu ao pedido do Santos de adiar o jogo deste domingo</segment>
    <segment id="7">, na Vila Belmiro</segment>
    <segment id="8">, por ter três jogadores convocados para a seleção brasileira e remarcou a partida para o dia 19 de outubro</segment>
    <segment id="9">, o jeito foi valorizar o fato de o time ter a oportunidade de jogar mais uma vez em sua casa</segment>
    <segment id="10">, no Engenhão</segment>
    <segment id="11">, na quarta-feira</segment>
    <segment id="12">, contra o Ceará.</segment>
    <segment id="13">Para o técnico Caio Júnior a equipe acabou ganhando uma semana</segment>
    <segment id="14">para que</segment>
    <segment id="15">para que todos os seus jogadores possam</segment>
    <segment id="16">sese recuperar e entrem com disposição redobrada na tentativa de somar mais três pontos contra o Ceará e conquistar sua quarta vitória consecutiva no Brasileiro.

-</segment>
    <segment id="17">O fato de fazer mais uma partida em nossa casa é um ponto positivo.</segment>
    <segment id="18">Depois pensamos no futuro - disse o treinador.</segment>
    <segment id="19">Para Caio</segment>
    <segment id="20">, o time está mostrando um diferencial importante para o torcedor.

- Nosso time está com uma boa organização tática</segment>
    <segment id="21">, agressivo e mostrando um bom futebol.</segment>
    <segment id="22">Vale a pena o torcedor vir nos apoiar - lembrou Caio Júnior.</segment>
