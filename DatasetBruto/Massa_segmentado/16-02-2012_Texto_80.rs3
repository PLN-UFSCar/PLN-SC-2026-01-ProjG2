  <rst>
    <segment id="1">Jovens detidos com crack
Diogo Barbosa e Jackson Lima dos Santos</segment>
    <segment id="2">, ambos com 19 anos</segment>
    <segment id="3">, foram presos no ato
Diogo Barbosa e Jackson Lima dos Santos</segment>
    <segment id="4">, ambos com 19 anos</segment>
    <segment id="5">, foram presos em flagrante</segment>
    <segment id="6">, anteontem à noite</segment>
    <segment id="7">, no bairro de São Caetano.</segment>
    <segment id="8">Os dois traficavam 27 pedras de crack  e quantidade não divulgada de maconha  na Rua Sirlândia.</segment>
    <segment id="9">Por isso</segment>
    <segment id="10">, os jovens foram levados para a 4ª Delegacia Territorial (4ª DT).</segment>
