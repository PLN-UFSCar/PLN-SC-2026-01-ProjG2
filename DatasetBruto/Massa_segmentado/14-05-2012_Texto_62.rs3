  <rst>
    <segment id="1">Mulher apaixonada persegue o marido
Vigilante desesperado quer</segment>
    <segment id="2">sese separar da esposa</segment>
    <segment id="3">, não consegue e procura a polícia</segment>
    <segment id="4">O vigilante F.S.S.</segment>
    <segment id="5">, 33 anos</segment>
    <segment id="6">, jamais iria imaginar que seria tão difícil conseguir</segment>
    <segment id="7">sese separar da mulher</segment>
    <segment id="8">, a promotora de vendas Edivânia dos Santos Nascimento</segment>
    <segment id="9">, 24.</segment>
    <segment id="10">Para ele</segment>
    <segment id="11">, o amor já acabou.</segment>
    <segment id="12">O problema é que a jovem não aceita o fim do relacionamento.</segment>
    <segment id="13">O casal está junto há cinco anos e tem um filho de três anos.</segment>
    <segment id="14">Na tarde de ontem</segment>
    <segment id="15">, a história de amor teve um dos momentos mais dramáticos.</segment>
    <segment id="16">O vigilante</segment>
    <segment id="17">, que atua num hospital</segment>
    <segment id="18">, no bairro Nazaré</segment>
    <segment id="19">, afirma que trabalhou das 7h de sábado até as 7h da manhã de ontem.</segment>
    <segment id="20">Quando chegou em casa</segment>
    <segment id="21">, Edivânia teve mais uma crise de ciúmes e fez escândalo</segment>
    <segment id="22">, pois</segment>
    <segment id="23">pois ela imagina que o marido estava na farra</segment>
    <segment id="24">, e não na labuta.</segment>
    <segment id="25">Desesperado</segment>
    <segment id="26">, o vigilante foi à Delegacia de Periperi</segment>
    <segment id="27">, em busca de orientação para acabar de vez com o casamento</segment>
    <segment id="28">, pois</segment>
    <segment id="29">pois a mulher dá provas de que não aceitará facilmente a separação.</segment>
    <segment id="30">Edivânia perseguiu o vigilante até a delegacia e rasgou a blusa do rapaz na entrada da unidade.</segment>
    <segment id="31">Policiais civis da delegacia tiveram dificuldades para controlar a moça.</segment>
    <segment id="32">Na ocorrência registrada</segment>
    <segment id="33">, está escrito que Edivânia demonstrou “irreverência e desobediência” contra os policiais.</segment>
    <segment id="34">“</segment>
    <segment id="35">Não aguento mais.</segment>
    <segment id="36">O ciúme dela é doentio</segment>
    <segment id="37">, tem ciúme de todo mundo.</segment>
    <segment id="38">É uma psicose</segment>
    <segment id="39">, faz pressão psicológica.</segment>
    <segment id="40">Ela precisa de tratamento”</segment>
    <segment id="41">, diz o vigilante.</segment>
    <segment id="42">Edivânia</segment>
    <segment id="43">sese declara.</segment>
    <segment id="44">“Eu amo ele.</segment>
    <segment id="45">É o amor de minha vida.</segment>
    <segment id="46">Vou parar com o ciúme.</segment>
    <segment id="47">Por favor</segment>
    <segment id="48">, moço</segment>
    <segment id="49">, peça a ele para voltar para mim”</segment>
    <segment id="50">, apela Edivânia ao repórter</segment>
    <segment id="51">, o mesmo pedido que fez ao delegado.</segment>
    <segment id="52">Vai sair de casa</segment>
    <segment id="53">Na delegacia</segment>
    <segment id="54">, o vigilante preferiu não formalizar a queixa por ameaça e agressão contra Edivânia</segment>
    <segment id="55">, argumentando que a mulher é mãe do filho dele e não quer que ela fique presa.</segment>
    <segment id="56">O delegado de plantão</segment>
    <segment id="57">, ontem</segment>
    <segment id="58">, em Periperi</segment>
    <segment id="59">, que prefere não</segment>
    <segment id="60">sese identificar</segment>
    <segment id="61">, argumenta que orientou o vigilante a procurar a Defensoria Pública.</segment>
    <segment id="62">Edivânia foi liberada.</segment>
    <segment id="63">Eles moram em Periperi.</segment>
    <segment id="64">O vigilante afirma que irá sair da casa que construiu para morar com Edivânia e o filho.</segment>
    <segment id="65">“Se eu ficar</segment>
    <segment id="66">, sei que ela vai continuar me perseguindo”.</segment>
  </rst>
</analysis>