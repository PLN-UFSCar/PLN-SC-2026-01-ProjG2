  <rst>
    <segment id="1">Galo rende grana e muita diversão</segment>
    <segment id="2">A festa de Diumbanda</segment>
    <segment id="3">, em Pela City</segment>
    <segment id="4">, dá oportunidade de curtir shows de artistas</segment>
    <segment id="5">Para ajudar os vizinhos a ganhar uma graninha com a venda de bebidas e comidas nos shows</segment>
    <segment id="6">, o policial e cantor Jesus Filho</segment>
    <segment id="7">, mais conhecido</segment>
    <segment id="8">comocomo Diumbanda</segment>
    <segment id="9">,  criou a festa do Galo de Diumbanda</segment>
    <segment id="10">, realizada toda quarta-feira</segment>
    <segment id="11">, no Pela Porco (apelidado pelos moradores de Pela City).</segment>
    <segment id="12">Mas o principal objetivo do cantor  é outro.</segment>
    <segment id="13">“Essa  festa  vem sendo uma maneira de ressocializar o local</segment>
    <segment id="14">, popularmente exposto pela mídia</segment>
    <segment id="15">comocomo um ponto de venda de drogas.</segment>
    <segment id="16">As pessoas podem vir conhecer a alegria do nosso povo digno e trabalhador”</segment>
    <segment id="17">, explica o cantor.</segment>
    <segment id="18">A história desse evento começou em 2005</segment>
    <segment id="19">, quando Diumbanda resolveu reunir os amigos para comer escaldado de galo.</segment>
    <segment id="20">Os encontros gastronômicos</segment>
    <segment id="21">sese tornaram cada vez mais rotineiros e  passaram a ser regados a muita comida e samba</segment>
    <segment id="22">, agregando cada vez mais pessoas à roda.</segment>
    <segment id="23">Então, apareceu a ideia: por que não preparar galo e pirão para vender e gerar lucro à comunidade?</segment>
    <segment id="24">O pensamento foi colocado em prática e assim surgiu a festa de Galo</segment>
    <segment id="25">, que  já é sucesso garantido.</segment>
    <segment id="26">“</segment>
    <segment id="27">O evento cresceu de forma tão rápida que completaremos sete anos de realização em setembro”</segment>
    <segment id="28">, comenta.</segment>
    <segment id="29">As festas em Pela City  estão tão bombadas que reúnem cerca de 2 mil pessoas por evento e já foram prestigiadas por grandes artistas</segment>
    <segment id="30">comocomo Margareth Menesez</segment>
    <segment id="31">, Gerônino</segment>
    <segment id="32">,  Tatau</segment>
    <segment id="33">, Márcio Victor e muitos outros.</segment>
    <segment id="34">Com o lucro gerado pelas vendas do escaldado de galo</segment>
    <segment id="35">, Diumbanda prepara cestas básicas para distribuir em outras comunidades carentes de Salvador</segment>
    <segment id="36">, dando exemplo de generosidade.</segment>
    <segment id="37">O segredo do sucesso
Horas antes do início da grande festa</segment>
    <segment id="38">, cerca de 10 galos são  preparados por Diumbanda e sua esposa</segment>
    <segment id="39">, Eunice Ferreira</segment>
    <segment id="40">, no próprio local do evento.</segment>
    <segment id="41">Mas qual o segredo do sucesso?</segment>
    <segment id="42">Eunice revela:</segment>
    <segment id="43">“Sem dúvida</segment>
    <segment id="44">, é o amor e a dedicação do meu marido em ver a nossa comunidade bem e  livre dos maus caminhos.</segment>
    <segment id="45">É pensando nisso que ele prepara a comida com muito gosto.</segment>
    <segment id="46">“Eu faço questão de colocar a mão na massa”</segment>
    <segment id="47">, acrescenta Diumbanda.</segment>
  </rst>
</analysis>