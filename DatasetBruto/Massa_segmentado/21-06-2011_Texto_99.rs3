  <rst>
    <segment id="1">Engavetamento deixa um ferido no Complex</segment>
    <segment id="2">Após essa ocorrência</segment>
    <segment id="3">, aconteceu outra colisão no mesmo local</segment>
    <segment id="4">Uma pessoa ficou ferida em um engavetamento no Complexo Viário Dois de Julho sentido Lauro de Freitas nesta quinta-feira (21).</segment>
    <segment id="5">De acordo com agentes da Transalvador - Superintendência de Trânsito e Transporte -</segment>
    <segment id="6">, a vítima foi socorrida.</segment>
    <segment id="7">Não há informações sobre seu estado de saúde.</segment>
    <segment id="8">Um dos veículos envolvidos no acidente ficou sem condições de tráfego</segment>
    <segment id="9">, o que deixa o trânsito no local.</segment>
    <segment id="10">Após essa ocorrência</segment>
    <segment id="11">, aconteceu outra colisão no mesmo local</segment>
    <segment id="12">, masmas desta vez sem feridos.</segment>
  </rst>
