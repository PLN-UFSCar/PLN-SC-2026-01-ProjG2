  <rst>
    <segment id="1">Para quﾃδｪ ser tﾃδ｣o cruel</segment>
    <segment id="2">, vovﾃδｴ do mal?</segment>
    <segment id="3">Eider matou e escondeu o corpo da neta que viu nascer</segment>
    <segment id="4">O motorista Eider Ferreira de Souza</segment>
    <segment id="5">, 49 anos</segment>
    <segment id="6">, nﾃδ｣o conseguiu sustentar a farsa  inventada para esconder que matou e ocultou o corpo da neta de consideraﾃδｧﾃδ｣o</segment>
    <segment id="7">, no sﾃδｭtio dele</segment>
    <segment id="8">, em Lauro de Freitas</segment>
    <segment id="9">, no ﾃδｺltimo dia 8.</segment>
    <segment id="10">Anteontem ﾃδ noite</segment>
    <segment id="11">, apﾃδｳs entrar em contradiﾃδｧﾃδ｣o vﾃδ｡rias vezes</segment>
    <segment id="12">, ele confessou na Delegacia de Itinga (27ﾃつｪ DT) que matou Juliana Conceiﾃδｧﾃδ｣o Avelino</segment>
    <segment id="13">, 16, a pauladas e escondeu o corpo em uma fossa no sﾃδｭtio.</segment>
    <segment id="14">Eider</segment>
    <segment id="15">ﾃδｩ casado com a avﾃδｳ de Juliana  hﾃδ｡ 30 anos.</segment>
    <segment id="16">O motorista disse que cometeu o crime apﾃδｳs discussﾃδ｣o que teria comeﾃδｧado por causa de uma chantagem da neta.</segment>
    <segment id="17">ﾃ｢竄ｬﾅ摘la estava pedindo R$ 300 para pagar o aluguel de uma casa onde ia morar com uma amiga.</segment>
    <segment id="18">Disse que</segment>
    <segment id="19">sese eu nﾃδ｣o desse</segment>
    <segment id="20">, ela ia inventar para a Itinga inteira que eu estava abusando sexualmente  elaﾃ｢竄ｬ.</segment>
    <segment id="21">A versﾃδ｣o inicial dele foi a do sequestro de Juliana.</segment>
    <segment id="22">Um homem armado com uma pistola teria chegado em uma moto vermelha e obrigou a jovem a subir na garupa.</segment>
    <segment id="23">No ﾃδｺltimo dia 9</segment>
    <segment id="24">, o pai da vﾃδｭtima registrou a queixa e Eider ainda acompanhou as buscas.</segment>
    <segment id="25">ﾃ｢竄ｬﾅ摘le era ouvido por diferentes policiais e percebemos as contradiﾃδｧﾃδｵes.</segment>
    <segment id="26">Ontem (anteontem)</segment>
    <segment id="27">, ele acabou confessandoﾃ｢竄ｬ</segment>
    <segment id="28">, conta o titular da 27ﾃつｪ DT</segment>
    <segment id="29">, Jacinto Alberto.</segment>
    <segment id="30">ﾃ｢竄ｬﾅ鄭migas da vﾃδｭtima disseram que ela</segment>
    <segment id="31">sese queixava  que acordava com o avﾃδｴ alisando as partes ﾃδｭntimas dela toda vez que dormia no sﾃδｭtioﾃ｢竄ｬ</segment>
    <segment id="32">, completa.</segment>
    <segment id="33">Povo estﾃδ｡ revoltado</segment>
    <segment id="34">A fossa onde o corpo da vﾃδｭtima foi colocado tem trﾃδｪs metros de profundidade e dois de comprimento.</segment>
    <segment id="35">Uma tampa de concreto com cerca de 100 kg cobre o local.</segment>
    <segment id="36">Segundo Jacinto Alberto</segment>
    <segment id="37">, Eider cavou um buraco ao lado da fossa e empurrou o corpo por debaixo.</segment>
    <segment id="38">ﾃ｢竄ｬﾅ徹 corpo estava sem roupas</segment>
    <segment id="39">, com um arame farpado enrolado no pescoﾃδｧo.</segment>
    <segment id="40">Vamos solicitar exame para saber</segment>
    <segment id="41">sese houve relaﾃδｧﾃδ｣o sexual.</segment>
    <segment id="42">Eider nega.</segment>
    <segment id="43">Ele disse que tirou as roupas para nﾃδ｣o ficarem retidas na fossaﾃ｢竄ｬ</segment>
    <segment id="44">, relata.</segment>
    <segment id="45">Cerca de 300 pessoas acompanharam o trabalho da polﾃδｭcia.</segment>
    <segment id="46">ﾃ｢竄ｬﾅ擢oi necessﾃδ｡rio chamar reforﾃδｧo policial.</segment>
    <segment id="47">Queriam fazer justiﾃδｧa com as prﾃδｳprias mﾃδ｣osﾃ｢竄ｬ</segment>
    <segment id="48">, conta o delegado.</segment>
    <segment id="49">Um tio de Juliana</segment>
    <segment id="50">, que preferiu nﾃδ｣o</segment>
    <segment id="51">sese identificar</segment>
    <segment id="52">, contou que Eider era uma pessoa acima de qualquer suspeita.</segment>
    <segment id="53">ﾃ｢竄ｬﾅ哲ﾃδ｣o sei por que ele fez isso.</segment>
    <segment id="54">Juliana era uma menina boa.</segment>
    <segment id="55">Era da escola para casaﾃ｢竄ｬ</segment>
    <segment id="56">, lamenta.</segment>
  </rst>
