  <rst>
    <segment id="1">Flamengo só fica no empate com o Ceará
RIO - O Ceará é a pedra no sapato do Flamengo na temporada.</segment>
    <segment id="2">O time de Vanderlei Luxemburgo fez um bom primeiro tempo e saiu na frente</segment>
    <segment id="3">, masmas não manteve o ritmo e acabou apenas empatando em 1 a 1 com o único time que o derrotou no ano - e que o eliminou da Copa do Brasil - na noite deste sábado</segment>
    <segment id="4">, no Moacyrzão</segment>
    <segment id="5">, em Macaé.</segment>
    <segment id="6">Renato Abreu fez o gol do Fla</segment>
    <segment id="7">, enquanto Felipe Azevedo empatou para os cearenses.</segment>
    <segment id="8">Com o resultado</segment>
    <segment id="9">, o Flamengo seguiu com 21 pontos e perdeu a chance de assumir a vice-liderança ultrapassando o São Paulo</segment>
    <segment id="10">, que mais cedo havia empatado com o Atlético-GO.

TEMPO REAL:</segment>
    <segment id="11">Como foi no lance a lance

BLOG: '</segment>
    <segment id="12">O Mais Querido'

TABELA:</segment>
    <segment id="13">Os jogos do Flamengo no Brasileirão</segment>
    <segment id="14">Na próxima rodada o Flamengo encara o Santos</segment>
    <segment id="15">, quarta-feira</segment>
    <segment id="16">, na Vila Belmiro.</segment>
    <segment id="17">O Ceará recebe o Atlético-PR</segment>
    <segment id="18">, também na quarta.</segment>
    <segment id="19">Mesmo sem as estrelas Thiago Neves e Ronaldinho</segment>
    <segment id="20">, que forçaram o terceiro cartão amarelo no jogo do meio de semana contra o Palmeiras</segment>
    <segment id="21">, e sem o volante Aírton</segment>
    <segment id="22">, suspenso pelo STJD</segment>
    <segment id="23">, o Flamengo teve atuação segura nos 45 minutos iniciais.</segment>
    <segment id="24">Com os volantes Willians e Luiz Antônio em noite inspirada</segment>
    <segment id="25">, o Fla marcou muito bem</segment>
    <segment id="26">, teve mais posse de bola e dominou as ações no primeiro tempo.</segment>
    <segment id="27">O time</segment>
    <segment id="28">, porém</segment>
    <segment id="29">porém, chutava pouco a gol e</segment>
    <segment id="30">, ironicamente</segment>
    <segment id="31">, a primeira grande chance foi do Ceará.</segment>
    <segment id="32">Aos 27 minutos</segment>
    <segment id="33">, Felipe saiu jogando errado</segment>
    <segment id="34">, Osvaldo recuperou a bola e</segment>
    <segment id="35">, aproveitando também falha de Ronaldo Angelim</segment>
    <segment id="36">, quase marcou.</segment>
    <segment id="37">Pouco depois</segment>
    <segment id="38">, aos 32</segment>
    <segment id="39">, saiu o gol rubro-negro.</segment>
    <segment id="40">Júnior César cruzou da esquerda</segment>
    <segment id="41">, a zaga do Ceará ficou olhando e Renato Abreu pegou de primeira</segment>
    <segment id="42">, de voleio</segment>
    <segment id="43">, para abrir o placar.</segment>
    <segment id="44">O ritmo não foi o mesmo no segundo tempo.</segment>
    <segment id="45">O Flamengo não conseguiu reter tanto a bola e o Ceará passou a ameaçar mais.</segment>
    <segment id="46">Felipe fez boa defesa em chute de Washington.</segment>
    <segment id="47">A pressão cearense foi aumentando</segment>
    <segment id="48">, aumentando</segment>
    <segment id="49">, e o gol acabou saindo aos 35 minutos.</segment>
    <segment id="50">Wellinton errou ao tentar cortar uma jogada</segment>
    <segment id="51">, Osvaldo recuperou a bola e tocou para Felipe Azevedo</segment>
    <segment id="52">, que driblou Felipe e chutou para empatar.</segment>
    <segment id="53">A torcida não perdoou e passou a vaiar quando Wellinton tocava na bola.</segment>
    <segment id="54">O Flamengo tentou ensaiar uma pressão nos minutos finais</segment>
    <segment id="55">, masmas não conseguiu chegar ao gol da vitória.</segment>
    <segment id="56">FLAMENGO 1 x 1 CEARÁ</segment>
    <segment id="57">Local: Estádio Cláudio Moacyr de Azevedo</segment>
    <segment id="58">, em Macaé (RJ)

Árbitro: Célio Amorim (SC)

Renda e público: R$ 123.480</segment>
    <segment id="59">,00 / 4.737 pagantes</segment>
    <segment id="60">Cartão amarelo: Wellinton

Gol: Renato</segment>
    <segment id="61">, 32'/1ºT (1-0)</segment>
    <segment id="62">; Felipe Azevedo</segment>
    <segment id="63">, 35'/2ºT (1-1)

FLAMENGO: Felipe</segment>
    <segment id="64">; Léo Moura</segment>
    <segment id="65">, Welinton</segment>
    <segment id="66">, Ronaldo Angelim e Junior Cesar</segment>
    <segment id="67">; Willians</segment>
    <segment id="68">, Luiz Antonio (Thomás</segment>
    <segment id="69">, 37'/2ºT)</segment>
    <segment id="70">, Renato e Bottinelli (João Vitor</segment>
    <segment id="71">, 33'/2ºT)</segment>
    <segment id="72">;</segment>
    <segment id="73">Diego Maurício (Vander</segment>
    <segment id="74">, 23'/2ºT) e Deivid.</segment>
    <segment id="75">Técnico: Vanderlei Luxemburgo.

CEARÁ: Diego</segment>
    <segment id="76">; Boiadeiro (Enrico</segment>
    <segment id="77">, 25'/2ºT)</segment>
    <segment id="78">, Fabrício</segment>
    <segment id="79">, Diego Sacoman e Vicente</segment>
    <segment id="80">; Michel</segment>
    <segment id="81">, João Marcos</segment>
    <segment id="82">, Heleno e Thiago Humberto (Felipe Azevedo</segment>
    <segment id="83">, intervalo)</segment>
    <segment id="84">; Osvaldo e Washington (Marcelo Nicácio</segment>
    <segment id="85">, 29'/2ºT).</segment>
    <segment id="86">Técnico: Vágner Mancini.</segment>
