  <rst>
    <segment id="1">Coroa Maníaco
Queria fazer sexo brutal com vovó de 77 anos</segment>
    <segment id="2">Policiais militares da 62ª CIPM  prenderam</segment>
    <segment id="3">, na cidade de Camacan</segment>
    <segment id="4">, Juarez Nery de Jesus</segment>
    <segment id="5">, 55 anos</segment>
    <segment id="6">, acusado de tentativa de estupro contra a idosa Lúcia Modesto de Jesus</segment>
    <segment id="7">, 77, na Fazenda Serra Boa.</segment>
    <segment id="8">Segundo o site Vermelhinho da Bahia</segment>
    <segment id="9">, a vítima estava sozinha em casa quando foi surpreendida pelo suspeito.</segment>
    <segment id="10">Juarez também teria agredido a idosa no rosto.</segment>
    <segment id="11">O acusado foi imobilizado por moradores.</segment>
    <segment id="12">O filho de Lúcia encontrou a mãe toda suja de sangue</segment>
    <segment id="13">, após chegar da roça onde trabalha na colheita de cacau.</segment>
    <segment id="14">A vítima foi levada ao Hospital Osvaldo Valverde.</segment>
    <segment id="15">Não há informações sobre o estado de saúde dela.</segment>
