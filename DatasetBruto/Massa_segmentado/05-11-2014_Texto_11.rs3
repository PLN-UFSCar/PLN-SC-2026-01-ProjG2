    <segment id="20">para que a gente volte a ter confian횄짠a</segment>
    <segment id="21">, opina Jutair J횄쨘nior Silva</segment>
    <segment id="22">, 26.</segment>
    <segment id="23">N횄짙o houve feridos</segment>
    <segment id="24">Ainda segundo a concession횄징ria CCR Metr횄쨈 Bahia</segment>
    <segment id="25">, havia cerca de 40 pessoas no 횄쨘ltimo carro do metr횄쨈</segment>
    <segment id="26">, masmas ningu횄짤m ficou ferido com o acidente.</segment>
