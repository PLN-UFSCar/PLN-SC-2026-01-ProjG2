    <segment id="5">, ap횄쨀s o descarrilamento de um dos carros.</segment>
    <segment id="6">O incidente ocorreu por volta das 10h30</segment>
    <segment id="7">, em uma bifurca횄짠횄짙o entre a esta횄짠횄짙o do Retiro e Acesso Norte.</segment>
    <segment id="8">A contadora Ala횄짯de Macedo</segment>
    <segment id="9">, que estava no equipamento</segment>
    <segment id="10">, disse que os passageiros tiveram que descer nos trilhos e fazer o restante do percurso caminhando.</segment>
