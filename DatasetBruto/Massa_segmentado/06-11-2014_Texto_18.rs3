  <rst>
    <segment id="1">Pol횄짯cia identifica suspeito</segment>
    <segment id="2">Policial afirma que Dagerlan Ara횄쨘jo teria matado George por ci횄쨘me da ex-namorada</segment>
    <segment id="3">Policiais do Servi횄짠o de Investiga횄짠횄짙o da Delegacia de S횄짙o Caetano identificaram o corretor de im횄쨀veis</segment>
    <segment id="4">Dagerlan Ara횄쨘jo de Souza</segment>
    <segment id="5">, 28, como</segment>
    <segment id="6">como suspeito de assassinar com um tiro no rosto o professor de educa횄짠횄짙o f횄짯sica</segment>
    <segment id="7">George L횄징zaro de Carvalho Nascimento</segment>
    <segment id="8">, 29, no dia 3.</segment>
    <segment id="9">O crime foi na Rua Professor Francisco G횄쨀es Calmon</segment>
    <segment id="10">, bairro S횄짙o Caetano.</segment>
    <segment id="11">Segundo testemunhas</segment>
    <segment id="12">, ele foi abordado pelo assassino perto da escola de nata횄짠횄짙o onde dava aulas.</segment>
    <segment id="13">As investiga횄짠횄쨉es iniciais indicavam que o professor foi morto durante tentativa de assalto.</segment>
    <segment id="14">Contudo</segment>
    <segment id="15">, durante a per횄짯cia</segment>
    <segment id="16">, a Pol횄짯cia Civil descartou a hip횄쨀tese e afirmou que nenhum pertence da v횄짯tima foi levado.</segment>
    <segment id="17">Sob anonimato</segment>
    <segment id="18">, um policial informou que o crime foi motivado por ci횄쨘mes.</segment>
    <segment id="19">Segundo ele</segment>
    <segment id="20">, Dagerlan viu no telefone da ex-namorada</segment>
    <segment id="21">, a cabeleireira Tifany Batista dos Santos Marques</segment>
    <segment id="22">, mensagens com teor sexual que ela teria enviado para o professor.</segment>
    <segment id="23">Eles estavam separados h횄징 um m횄짧s.</segment>
    <segment id="24">A횄짯 ela conheceu o professor e passou a mandar mensagens para ele.</segment>
    <segment id="25">Tinha uma que ela disse que quando sonhava com ele acordava toda molhadinha</segment>
    <segment id="26">, daquele jeito...</segment>
    <segment id="27">, revela o policial.</segment>
    <segment id="28">O investigador afirma que n횄짙o foi encontrada nenhuma resposta do professor 횄혻s mensagens de Tifany.</segment>
    <segment id="29">Ficou com raiva</segment>
    <segment id="30">De acordo com o investigador</segment>
    <segment id="31">, h횄징 dois meses</segment>
    <segment id="32">, George j횄징 havia sido procurado por Dagerlan.</segment>
    <segment id="33">Ele ficou com bastante raiva do cara e foi tirar pergunta.</segment>
    <segment id="34">George negou tudo.</segment>
    <segment id="35">A fam횄짯lia da v횄짯tima achou que depois da conversa estava tudo bem e que ele n횄짙o fosse fazer mais nada</segment>
    <segment id="36">, disse o policial.</segment>
    <segment id="37">Pai iria levar o filho para delegacia</segment>
    <segment id="38">Os policiais obtiveram informa횄짠횄쨉es sobre Dagerlan ap횄쨀s 20 horas ininterruptas de investiga횄짠횄짙o.</segment>
    <segment id="39">Segundo o agente</segment>
    <segment id="40">, uma den횄쨘ncia dava conta que um homem de prenome Mateus sabia sobre o crime.</segment>
    <segment id="41">Ele foi conduzido 횄혻 delegacia.</segment>
    <segment id="42">Depois de analisar o celular dele</segment>
    <segment id="43">, os agentes descobriram uma conversa</segment>
    <segment id="44">, na qual ele e outro homem conhecido com J횄쨘nior mencionavam o crime e levantavam suspeita sobre o poss횄짯vel autor.</segment>
    <segment id="45">Segundo o agente</segment>
    <segment id="46">, o pai de Dagerlan</segment>
    <segment id="47">sese comprometeu a levar o filho no Departamento de Homic횄짯dios</segment>
    <segment id="48">, ontem 횄혻 tarde.</segment>
    <segment id="49">Mas isso n횄짙o ocorreu.</segment>
