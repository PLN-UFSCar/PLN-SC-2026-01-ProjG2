  <rst>
    <segment id="1">Fluminense e Botafogo prontos para o clássico no Engenhão</segment>
    <segment id="2">Em seu território</segment>
    <segment id="3">, o Botafogo é soberano.</segment>
    <segment id="4">Goleou o Vasco e empatou com o Flamengo.</segment>
    <segment id="5">Fora dele</segment>
    <segment id="6">, só perdeu no Rio quando jogou em São Januário.</segment>
    <segment id="7">Se vencer</segment>
    <segment id="8">, o time atinge os 60% de aproveitamento estipulados pela comissão técnica.</segment>
    <segment id="9">Isto diante de um adversário que tem</segment>
    <segment id="10">sese comportado</segment>
    <segment id="11">comocomo visitante</segment>
    <segment id="12">, porque</segment>
    <segment id="13">porque só venceu duas fora de casa.</segment>
    <segment id="14">Ainda que seja o mandante do jogo</segment>
    <segment id="15">, o Fluminense sabe que o estádio</segment>
    <segment id="16">, batizado com o nome de um tricolor ilustre</segment>
    <segment id="17">, não é seu.
- Em clássico</segment>
    <segment id="18">, todo resultado é normal - disse o técnico do Fluminense</segment>
    <segment id="19">, Abel Braga.</segment>
    <segment id="20">Técnico perde o sono</segment>
    <segment id="21">A torcida tricolor tem motivos para ficar apreensiva.</segment>
    <segment id="22">Afinal</segment>
    <segment id="23">, foi dormir campeã nacional e acordou em um pesadelo.</segment>
    <segment id="24">A realidade pós-título tem sido dura</segment>
    <segment id="25">, exige paciência e tira o sono.</segment>
    <segment id="26">Dos torcedores e do técnico Abel Braga.</segment>
    <segment id="27">O treinador põe a cabeça no travesseiro e fecha os olhos</segment>
    <segment id="28">, masmas abre logo em seguida</segment>
    <segment id="29">, duas horas depois</segment>
    <segment id="30">, o mesmo tempo de uma partida de futebol.</segment>
    <segment id="31">Somente um sonífero funciona para Abel: a vitória.</segment>
    <segment id="32">Outra solução seria contar carneiros</segment>
    <segment id="33">, masmas Abel tem outros números na cabeça.</segment>
    <segment id="34">Em seis clássicos este ano</segment>
    <segment id="35">, o Fluminense perdeu dois e empatou quatro.</segment>
    <segment id="36">No Engenhão</segment>
    <segment id="37">, jamais venceu o Botafogo.</segment>
    <segment id="38">Então,</segment>
    <segment id="39">comocomo fazer para o dia nascer feliz nas Laranjeiras no domingo pela manhã?

- Preciso ganhar mais para voltar a dormir</segment>
    <segment id="40">, porque</segment>
    <segment id="41">porque estou dormindo só duas horas.</segment>
    <segment id="42">A equipe joga bem e luta</segment>
    <segment id="43">, masmas estamos ficando só no quase - declarou Abel.</segment>
    <segment id="44">As madrugadas no Leblon</segment>
    <segment id="45">, onde Abel Braga mora</segment>
    <segment id="46">, têm sido longas.</segment>
    <segment id="47">Acordado</segment>
    <segment id="48">, ele sonha com a campanha do Grêmio</segment>
    <segment id="49">, em 2010</segment>
    <segment id="50">, e como</segment>
    <segment id="51">como fazer isto inspirar seus jogadores.</segment>
    <segment id="52">Na primeira metade do campeonato</segment>
    <segment id="53">, estava na parte de baixo da tabela</segment>
    <segment id="54">, masmas terminou</segment>
    <segment id="55">comocomo campeão do returno:

- Eu dou exemplo.</segment>
    <segment id="56">Nosso momento pode mudar e a gente brigar para ser campeão.</segment>
    <segment id="57">Tenho que puxar por isto.</segment>
    <segment id="58">No começo do treino de ontem</segment>
    <segment id="59">, o que Abel mais puxou foi as orelhas dos jogadores.</segment>
    <segment id="60">Depois de mais uma derrota jogando bem</segment>
    <segment id="61">, contra o Santos</segment>
    <segment id="62">, recheada de erros de marcação no meio-campo e</segment>
    <segment id="63">, principalmente</segment>
    <segment id="64">, na zaga</segment>
    <segment id="65">, o técnico reuniu o elenco no campo das Laranjeiras</segment>
    <segment id="66">, com faz normalmente</segment>
    <segment id="67">, masmas</segment>
    <segment id="68">, em um tom mais eloquente</segment>
    <segment id="69">, fez observações sobre a maneira que o time entrega os pontos.

- vejo que tem sido fácil marcar gols no Fluminense.</segment>
    <segment id="70">Isto tende a mudar</segment>
    <segment id="71">, porque</segment>
    <segment id="72">porque não é possível!</segment>
    <segment id="73">- disse Abel.</segment>
    <segment id="74">Defesa entrega os pontos</segment>
    <segment id="75">Na ausência de Márcio Rosário</segment>
    <segment id="76">, Digão entrou</segment>
    <segment id="77">, masmas não</segment>
    <segment id="78">sese fez presente contra o Santos.</segment>
    <segment id="79">Ele conseguiu falhar em dois lances.</segment>
    <segment id="80">Dois gols.</segment>
    <segment id="81">Voltará para o banco</segment>
    <segment id="82">, masmas os erros não podem continuar.

- Não comento erro individual - tem afirmado Abel.</segment>
    <segment id="83">Falar do todo é melhor para poupar uma parte do time que foi criticada ao longo do ano.</segment>
    <segment id="84">Se em 2010 o Fluminense tinha a melhor defesa</segment>
    <segment id="85">, em alguns momentos com três zagueiros</segment>
    <segment id="86">, agora o sonho acabou.</segment>
    <segment id="87">E, na frente</segment>
    <segment id="88">, é para chutar a gol.

- Tem que chutar de fora da área</segment>
    <segment id="89">, e o jogador brasileiro não tem este hábito.</segment>
    <segment id="90">O gramado não ajuda e a bola está sempre viva.</segment>
    <segment id="91">Na Europa</segment>
    <segment id="92">, as condições de finalizações são melhores.</segment>
    <segment id="93">O jogador</segment>
    <segment id="94">, aqui</segment>
    <segment id="95">, evita a responsabilidade ao tocar a bola para o companheiro - explicou o treinador.</segment>
    <segment id="96">No momento vivido pelo Fluminense</segment>
    <segment id="97">, o pior time carioca em um campeonato no qual os outros três despertaram para campanhas irretocáveis</segment>
    <segment id="98">, tocar bola para o lado é quase crime.</segment>
    <segment id="99">Abel espera que</segment>
    <segment id="100">, hoje</segment>
    <segment id="101">, todos assumam as suas responsabilidades</segment>
    <segment id="102">, porque</segment>
    <segment id="103">porque ele garante que entende a sua.</segment>
    <segment id="104">Assim como</segment>
    <segment id="105">como o Ministério Público</segment>
    <segment id="106">, que ajuizou ontem uma Ação Civil Pública contra a torcida organizada Young Flu</segment>
    <segment id="107">, com base no estatuto do torcedor</segment>
    <segment id="108">, pedindo à Justiça a destituição do presidente Leandro Carvalho</segment>
    <segment id="109">, o Campinho</segment>
    <segment id="110">, que perseguiu e ameaçou o atacante Fred.

Fluminense:</segment>
    <segment id="111">Diego Cavalieri</segment>
    <segment id="112">, Mariano</segment>
    <segment id="113">, Gum, Márcio Rosário e Carlinhos</segment>
    <segment id="114">; Edinho</segment>
    <segment id="115">, Diogo</segment>
    <segment id="116">, Lanzini e Souza</segment>
    <segment id="117">; Fred e Rafael Moura.</segment>
    <segment id="118">Botafogo: Jéfferson</segment>
    <segment id="119">, Lucas</segment>
    <segment id="120">, Antônio Carlos</segment>
    <segment id="121">, Fábio Ferreira e Cortês</segment>
    <segment id="122">;</segment>
    <segment id="123">Marcelo Martins</segment>
    <segment id="124">, Renato</segment>
    <segment id="125">, Maicossuel e Élkeson</segment>
    <segment id="126">; Herrera e Loco Abreu.</segment>
    <segment id="127">Juiz: Felipe Gomes da Silva (RJ).

TRANSMISSÃO: Premiere e Rádio Globo</segment>
  </rst>
</analysis>