  <rst>
    <segment id="1">Premier grego diz que não conseguirá levantar 27 bilhões de euros e sinaliza com calote</segment>
    <segment id="2">O primeiro-ministro da Grécia</segment>
    <segment id="3">, George Papandreou</segment>
    <segment id="4">, admitiu pela primeira vez</segment>
    <segment id="5">, em entrevista publicada domingo no jornal grego "Ethnos"</segment>
    <segment id="6">, que o país não deverá estar preparado para levantar dinheiro no mercado em 2012 para refinanciar sua dívida.</segment>
    <segment id="7">Ele também afirmou que "muito provavelmente" não honrará seus compromissos financeiros</segment>
    <segment id="8">, caso</segment>
    <segment id="9">caso a quinta parcela do empréstimo acordado com a União Europeia (UE) e o Fundo Monetário Internacional (FMI) em 2010 não seja liberada no prazo previsto.
- Não parece</segment>
    <segment id="10">, no momento</segment>
    <segment id="11">, que a Grécia será capaz de atender normalmente às exigências do empréstimo relativos a 2012</segment>
    <segment id="12">, com a captação no mercado - disse Papandreou ao "Ethnos".</segment>
    <segment id="13">A captação de recursos por meio de emissão de títulos públicos</segment>
    <segment id="14">, no valor de 27 bilhões de euros</segment>
    <segment id="15">, é uma das contrapartidas exigidas pela UE e pelo FMI para liberação integral do socorro de 110 bilhões euros ao país</segment>
    <segment id="16">, acordado em maio de 2010.</segment>
    <segment id="17">Até agora</segment>
    <segment id="18">, quatro parcelas foram concedidas ao governo grego.</segment>
    <segment id="19">A quinta</segment>
    <segment id="20">, de 12 bilhões de euros</segment>
    <segment id="21">, seria liberada após inspeção de uma equipe da UE</segment>
    <segment id="22">, do FMI e do Banco Central Europeu (BCE) prevista para junho.</segment>
    <segment id="23">A falta de solidez da economia grega também tem assustado credores</segment>
    <segment id="24">, que temem um calote do país.</segment>
    <segment id="25">Para analistas</segment>
    <segment id="26">, os comentários do premier são forte indicação de que a Grécia precisará de novo socorro.</segment>
    <segment id="27">Em nota divulgada na noite de sábado</segment>
    <segment id="28">, o Reino Unido declarou apoio ao nome da ministra das Finanças da França</segment>
    <segment id="29">, Christine Lagarde</segment>
    <segment id="30">, para comandar o FMI</segment>
    <segment id="31">, após manifestações no mesmo sentido de Alemanha e Itália.</segment>
    <segment id="32">Na nota</segment>
    <segment id="33">, George Osborne</segment>
    <segment id="34">, ministro de Finanças do Reino Unido</segment>
    <segment id="35">, afirmou que Lagarde "é a melhor pessoa para o trabalho".</segment>
    <segment id="36">Mas o coro de emergentes contra um nome europeu é crescente.</segment>
    <segment id="37">No domingo</segment>
    <segment id="38">, África do Sul e Austrália afirmaram</segment>
    <segment id="39">, em nota conjunta</segment>
    <segment id="40">, que a nomeação deve ser baseada em mérito</segment>
    <segment id="41">, não em nacionalidade.</segment>
    <segment id="42">"Por tempo demais</segment>
    <segment id="43">, a legitimidade do FMI foi comprometida pela convenção de nomear a alta administração com base na nacionalidade".</segment>
    <segment id="44">Já o México disse que indicará o presidente de seu banco central</segment>
    <segment id="45">, Agustín Carstens</segment>
    <segment id="46">, para o cargo.</segment>
    <segment id="47">A Suíça</segment>
    <segment id="48">, voz destoante na Europa</segment>
    <segment id="49">, sinalizou a necessidade de um nome não europeu.</segment>
  </rst>
</analysis>