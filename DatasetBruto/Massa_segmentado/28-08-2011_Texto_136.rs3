  <rst>
    <segment id="1">Falta de manutenção e de tomógrafos são problemas recorrentes no Rio
RIO - A falta de manutenção e de tomógrafos</segment>
    <segment id="2">, assim</segment>
    <segment id="3">comocomo aparelhos que ficam encaixotados por meses após serem comprados</segment>
    <segment id="4">, são problemas antigos no Rio.</segment>
    <segment id="5">Em setembro de 2010</segment>
    <segment id="6">, o tomógrafo do Hospital Municipal Souza Aguiar</segment>
    <segment id="7">, no Centro</segment>
    <segment id="8">, que tem a maior emergência do Rio</segment>
    <segment id="9">, ficou 11 dias quebrado.</segment>
    <segment id="10">O atendimento só foi normalizado</segment>
    <segment id="11">, em caráter de urgência</segment>
    <segment id="12">, com o uso de um equipamento móvel da Secretaria estadual de Saúde.</segment>
    <segment id="13">Já no Lourenço Jorge</segment>
    <segment id="14">, na Barra da Tijuca</segment>
    <segment id="15">, o equipamento</segment>
    <segment id="16">, doado à unidade por uma associação comercial do bairro</segment>
    <segment id="17">, ficou pelo menos dois meses sem funcionar</segment>
    <segment id="18">, à espera de uma peça importada da Holanda.</segment>
    <segment id="19">Enquanto isso</segment>
    <segment id="20">, assim</segment>
    <segment id="21">comocomo no Salgado Filho</segment>
    <segment id="22">, em 2007 um tomógrafo que custou R$ 1 milhão ficou dois anos guardado no Almoxarifado Central da prefeitura.</segment>
    <segment id="23">Em 2005</segment>
    <segment id="24">, no Hospital Rocha Faria</segment>
    <segment id="25">, em Campo Grande</segment>
    <segment id="26">, outro aparelho também ficou em caixas por meses esperando instalação.</segment>
    <segment id="27">Mesmo hospital em que</segment>
    <segment id="28">, em 2006</segment>
    <segment id="29">, médicos precisavam desenhar em papéis as imagens visualizadas no tomógrafo</segment>
    <segment id="30">, pois</segment>
    <segment id="31">pois não havia filme para a impressão dos exames.</segment>
    <segment id="32">Os desenhos eram</segment>
    <segment id="33">, então</segment>
    <segment id="34">, levados para o centro cirúrgico</segment>
    <segment id="35">, para orientar os cirurgiões.</segment>
    <segment id="36">Antes, em 2003</segment>
    <segment id="37">, O GLOBO mostrou que dois tomógrafos helicoidais estavam encaixotados há mais de um ano em outros dois hospitais da rede estadual.</segment>
    <segment id="38">Um deles</segment>
    <segment id="39">, no hall do Instituto Estadual de Cardiologia Aloísio de Castro</segment>
    <segment id="40">, no Humaitá</segment>
    <segment id="41">, onde servia de banco para pacientes na fila de espera</segment>
    <segment id="42">; e outro no refeitório do Hospital Getúlio Vargas</segment>
    <segment id="43">, na Penha.</segment>
  </rst>
</analysis>