  <rst>
    <segment id="1">Vasco recebe o Atlético-PR em São Januário
RIO - No início de maio</segment>
    <segment id="2">, Vasco e Atlético-PR</segment>
    <segment id="3">sese enfrentaram duas vezes pelas quartas de final da Copa do Brasil.</segment>
    <segment id="4">Classificação carioca</segment>
    <segment id="5">, masmas sem vencedor em ambos os jogos.</segment>
    <segment id="6">Pouco mais de um mês depois</segment>
    <segment id="7">, a vitória tornou-</segment>
    <segment id="8">sese fundamental para as pretensões das duas equipes.</segment>
    <segment id="9">Neste sábado</segment>
    <segment id="10">, às 18h30m</segment>
    <segment id="11">, em São Januário</segment>
    <segment id="12">, os dois times lutam pelos três pontos por motivos diferentes.</segment>
    <segment id="13">Ao Vasco</segment>
    <segment id="14">, que ainda sonha com o título brasileiro para encerrar o ano com perfeição</segment>
    <segment id="15">, a vitória significa impedir que a turma do G-4</segment>
    <segment id="16">sese distancie.</segment>
    <segment id="17">Em sétimo lugar</segment>
    <segment id="18">, o time de Ricardo Gomes está com 14 pontos</segment>
    <segment id="19">, 11 atrás do líder Corinthians.

- Qualquer ponto perdido dentro de casa é ruim.</segment>
    <segment id="20">No planejamento do Brasileiro</segment>
    <segment id="21">, contamos com os pontos em casa - disse Felipe</segment>
    <segment id="22">, que não aprovou o gramado do CFZ</segment>
    <segment id="23">, onde o time treinou provisoriamente</segment>
    <segment id="24">, já que São Januário recebe as partidas de futebol dos Jogos Mundiais Militares.</segment>
    <segment id="25">- Agradecemos por nos ter recebido</segment>
    <segment id="26">, masmas não é a estrutura ideal para a equipe profissional.</segment>
    <segment id="27">Por outro lado</segment>
    <segment id="28">, a equipe paranaense figura na lanterna do Brasileirão</segment>
    <segment id="29">, com apenas dois pontos.</segment>
    <segment id="30">A posição ruim</segment>
    <segment id="31">, no entanto</segment>
    <segment id="32">, não engana o time vascaíno.</segment>
    <segment id="33">A memória das duas difíceis partidas contra o Atlético-PR ainda estão vivas.

- É uma posição temporária.</segment>
    <segment id="34">É o mesmo time que fez bom papel na Copa do Brasil</segment>
    <segment id="35">, temos que ter atenção para não relaxar - afirmou Felipe</segment>
    <segment id="36">, que ressaltou outro ponto importante do confronto.</segment>
    <segment id="37">- Eles vão vir muito motivados com o novo treinador (Renato Gaúcho assumiu a equipe semana passada contra o Avaí).</segment>
    <segment id="38">A favor do Vasco</segment>
    <segment id="39">, o time estará praticamente completo em campo.</segment>
    <segment id="40">Alecsandro</segment>
    <segment id="41">, Fernando Prass e Márcio Careca</segment>
    <segment id="42">, que pouco treinaram esta semana</segment>
    <segment id="43">, estão liberados.</segment>
    <segment id="44">Éder Luís</segment>
    <segment id="45">, que fez trabalho à parte por causa de dores na coxa esquerda</segment>
    <segment id="46">, não preocupa e também está garantido.</segment>
    <segment id="47">Allan substitui Fágner</segment>
    <segment id="48">, suspenso</segment>
    <segment id="49">, na lateral direita.</segment>
    <segment id="50">Vasco x Atlético-PR

Local: São Januário

Data: 16/07</segment>
    <segment id="51">, às 18h30

Árbitro: Alício Pena Júnior (MG)

Vasco: Fernando Prass</segment>
    <segment id="52">, Allan</segment>
    <segment id="53">, Dedé</segment>
    <segment id="54">, Anderson Martins e Márcio Careca</segment>
    <segment id="55">; Rômulo</segment>
    <segment id="56">, Juninho Pernambucano</segment>
    <segment id="57">, Felipe e Bernardo</segment>
    <segment id="58">; Éder Luís e Alecsandro.</segment>
    <segment id="59">Atlético-PR: Renan Rocha</segment>
    <segment id="60">, Wagner Diniz</segment>
    <segment id="61">, Manoel</segment>
    <segment id="62">, Fabrício e Paulinho</segment>
    <segment id="63">; Deivid</segment>
    <segment id="64">, Cleber Santana</segment>
    <segment id="65">, Kleberson e Madson</segment>
    <segment id="66">; Guerrón e Morro García.</segment>
  </rst>
