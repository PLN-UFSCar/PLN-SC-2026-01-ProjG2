  <rst>
    <segment id="1">Mamãe Noel
Quem disse que só o Bom Velhinho faz a alegria da galera no Natal?</segment>
    <segment id="2">Rafaela Fiorani</segment>
    <segment id="3">, 27 anos</segment>
    <segment id="4">, dançarina do grupo Raghatoni</segment>
    <segment id="5">, é a Mamãe Noel do MASSA!</segment>
    <segment id="6">que arrasa nas pistas de dança e também na academia.</segment>
    <segment id="7">Isso porque</segment>
    <segment id="8">porque a loira do Espírito Santo também é personal trainer.</segment>
    <segment id="9">“Estou na Raghatoni há sete meses e adoro a galera</segment>
    <segment id="10">, masmas quero mesmo é continuar a carreira</segment>
    <segment id="11">comocomo professora de educação física"</segment>
    <segment id="12">, diz a moça.</segment>
    <segment id="13">Rafa, como</segment>
    <segment id="14">como é carinhosamente chamada pelos amigos</segment>
    <segment id="15">, malha pesado quatro vezes por semana. "</segment>
    <segment id="16">Pego mais peso</segment>
    <segment id="17">, já que a parte aeróbica faço com a dança"</segment>
    <segment id="18">, revela.</segment>
    <segment id="19">Nesta época de Natal</segment>
    <segment id="20">, a dançarina</segment>
    <segment id="21">, que está sozinha em Salvador há um ano</segment>
    <segment id="22">, lamenta não poder passar os festejos com a família</segment>
    <segment id="23">, que mora no Espírito Santo.</segment>
    <segment id="24">"</segment>
    <segment id="25">Desejo um feliz Natal para todos.</segment>
    <segment id="26">Aproveitem bem esses dias com a família</segment>
    <segment id="27">, que é tudo que temos na vida"</segment>
    <segment id="28">, diz.</segment>
    <segment id="29">Os marmanjos que babam por ela podem ficar tranquilos que não tem  nenhum Noel na área.</segment>
    <segment id="30">Pelo menos</segment>
    <segment id="31">, por enquanto.</segment>
    <segment id="32">“Quero focar na banda”</segment>
    <segment id="33">, afirma.</segment>
    <segment id="34">Encontro de sorte

Ela entrou na Raghatoni depois de conhecer Toni Salles em uma academia em Vilas do Atlântico</segment>
    <segment id="35">, onde trabalhava.</segment>
    <segment id="36">Após vê-la dançar</segment>
    <segment id="37">, o cantor a convidou para o grupo</segment>
  </rst>
</analysis>