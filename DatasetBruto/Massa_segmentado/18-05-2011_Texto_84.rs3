  <rst>
    <segment id="1">Músicos em busca de Coco
Conheça as três músicas que foram inspiradas na Mulher Coco do Calabar

Cadê Coco?</segment>
    <segment id="2">Todo mundo quer saber por onde anda o morador do Calabar procurado pela polícia.</segment>
    <segment id="3">As bandas de pagode e forró</segment>
    <segment id="4">, que não são nada bobas</segment>
    <segment id="5">, aproveitaram a curiosidade para transformar a investigação em divertidas músicas.</segment>
    <segment id="6">Todas são inspiradas em Aline Miranda da Silva</segment>
    <segment id="7">, prima de Edeilson da Silva Miranda</segment>
    <segment id="8">, o Coco.</segment>
    <segment id="9">Após ser perguntada por um repórter de TV sobre o paradeiro do primo</segment>
    <segment id="10">, Aline</segment>
    <segment id="11">sese revoltou e  gritou</segment>
    <segment id="12">“Coco tá aqui</segment>
    <segment id="13">, ó!</segment>
    <segment id="14">”</segment>
    <segment id="15">, apontando para as partes íntimas.</segment>
    <segment id="16">O vídeo bombou na TV e na internet</segment>
    <segment id="17">, o que motivou a banda</segment>
    <segment id="18">Nosso Som a criar um pagode que já está na boca do povão.</segment>
    <segment id="19">“</segment>
    <segment id="20">As fãs pediam para a gente perguntar por Coco no show.</segment>
    <segment id="21">No início</segment>
    <segment id="22">, não entendi</segment>
    <segment id="23">, masmas depois que vi a reação delas</segment>
    <segment id="24">, imitando a moça do vídeo</segment>
    <segment id="25">, vi que sairia dali uma  música”</segment>
    <segment id="26">, diz Binho Careca</segment>
    <segment id="27">, que divide os vocais da banda com Lu Vargas</segment>
    <segment id="28">, o Negão.</segment>
    <segment id="29">Quem também apostou no sucesso do vídeo de Aline para</segment>
    <segment id="30">sese dar bem foi a banda</segment>
    <segment id="31">Galácticos do Forró.</segment>
    <segment id="32">A música deles também</segment>
    <segment id="33">sese chama “Cadê Coco?</segment>
    <segment id="34">”, mas</segment>
    <segment id="35">mas a letra e o ritmo são bem diferentes.</segment>
    <segment id="36">“Surgiu de uma brincadeira no estúdio.</segment>
    <segment id="37">Vamos divulgá-la neste São João”</segment>
    <segment id="38">, empolga-</segment>
    <segment id="39">sese o vocalista</segment>
    <segment id="40">, Brad Pitt.</segment>
    <segment id="41">A terceira versão sobre o paradeiro de Coco vem da banda de pagode</segment>
    <segment id="42">No Allvo</segment>
    <segment id="43">, lá de São Gonçalo dos Campos</segment>
    <segment id="44">, a 108 km de Salvador.</segment>
    <segment id="45">A música “Coco</segment>
    <segment id="46">Tá no Buraco”</segment>
    <segment id="47">é sucesso nas rádios da região.</segment>
    <segment id="48">Nosso Som:</segment>
    <segment id="49">O grupo foi o primeiro a cantar o tema</segment>
    <segment id="50">, em “Cadê Coco?</segment>
    <segment id="51">”:
Letra:</segment>
    <segment id="52">”Você que assiste o Na Mira</segment>
    <segment id="53">, programa que é a cara do povo</segment>
    <segment id="54">A pergunta que não quer calar</segment>
    <segment id="55">, todo mundo pergunta por Coco
Cadê</segment>
    <segment id="56">, cadê Coco?</segment>
    <segment id="57">Olha Coco aqui! (3x)
Disseram que ele tá na praia</segment>
    <segment id="58">, disseram que tá na TV</segment>
    <segment id="59">Todo mundo pergunta por Coco: Cadê você?</segment>
    <segment id="60">”

Galácticos do Forró:</segment>
    <segment id="61">A banda do cantor Eugênio aproveitou a onda e criou o forró “Cadê Coco?</segment>
    <segment id="62">” para o São João:
Letra:</segment>
    <segment id="63">“</segment>
    <segment id="64">Tá rolando um pega-pega
Veja que coisa de louco</segment>
    <segment id="65">Todo mundo quer saber</segment>
    <segment id="66">Onde se</segment>
    <segment id="67">se escondeu o Coco</segment>
    <segment id="68">Agora jogue seu corpinho para um lado e para outro
Só quero que você diga o paradeiro de Coco
Ela ficou nervosa quando eu perguntei assim:</segment>
    <segment id="69">Você sabe onde tá Coco - Olhe</segment>
    <segment id="70">sese Coco tá aqui!</segment>
    <segment id="71">Dê um tapa na ‘danada’
Olhe</segment>
    <segment id="72">sese Coco tá aqui
Aqui</segment>
    <segment id="73">, aqui</segment>
    <segment id="74">,</segment>
    <segment id="75">Olhe se</segment>
    <segment id="76">se Coco tá aqui!</segment>
    <segment id="77">”

No Allvo:</segment>
    <segment id="78">A banda de São Gonçalo dos Campos abriu até um concurso em uma rádio local para escolher a dançarina do grupo.</segment>
    <segment id="79">Ela terá que criar uma coreografia para a música “Coco</segment>
    <segment id="80">Tá no Buraco”.</segment>
    <segment id="81">Letra:</segment>
    <segment id="82">“Você sabe onde tá Coco?</segment>
    <segment id="83">Coco tá no buraco! (6x)</segment>
    <segment id="84">Mete o pau que o Coco sai</segment>
    <segment id="85">, Mete o pau que o Coco cai (4x)
E no final da noite</segment>
    <segment id="86">, ninguém sabe</segment>
    <segment id="87">, ninguém viu</segment>
    <segment id="88">Tiro o do meu</segment>
    <segment id="89">, masmas não caiu! (2x)
Quem é que fica?</segment>
    <segment id="90">Ninguém fica não! (3x)”</segment>
  </rst>
</analysis>