  <rst>
    <segment id="1">Promessa de rei do Barradão
Neto garantiu para os torcedores que o Leão será campeão baiano</segment>
    <segment id="2">Final de jogo</segment>
    <segment id="3">, o Vitória consegue uma virada histórica sobre o ABC e</segment>
    <segment id="4">sese classifica para as oitavas de final da Copa do Brasil.</segment>
    <segment id="5">Todos os microfones procuram o herói rubro-negro e ele faz uma promessa</segment>
    <segment id="6">, já coroado</segment>
    <segment id="7">comocomo novo Rei do Barradão:</segment>
    <segment id="8">“Vamos ser campeão baiano.</segment>
    <segment id="9">Escreve o que estou dizendo”</segment>
    <segment id="10">, disparou Neto Baiano</segment>
    <segment id="11">, artilheiro do Brasil com 27 gols e maior artilheiro da história do estádio do Leão</segment>
    <segment id="12">, com 46 gols</segment>
    <segment id="13">, ultrapassando o Reizinho da Toca</segment>
    <segment id="14">, Ramon Menezes</segment>
    <segment id="15">, que marcou 44 gols.</segment>
    <segment id="16">“Rapaz</segment>
    <segment id="17">, superar um ídolo</segment>
    <segment id="18">, uma pessoa íntegra e um profissional muito querido no Vitória</segment>
    <segment id="19">, é um grande orgulho para mim”</segment>
    <segment id="20">, avaliou ontem</segment>
    <segment id="21">, Neto Baiano</segment>
    <segment id="22">, ainda curtindo as imagens da noite anterior</segment>
    <segment id="23">, em que marcou três gols e foi o principal nome do jogo.</segment>
    <segment id="24">Os mais exigentes ou</segment>
    <segment id="25">porque</segment>
    <segment id="26">porque não dizer injustos ainda contestam o valor de Neto</segment>
    <segment id="27">, masmas ele não liga para isso.</segment>
    <segment id="28">“</segment>
    <segment id="29">Um amigo me disse que estavam falando mal de mim em uma rádio</segment>
    <segment id="30">, eu entrego a Deus”</segment>
    <segment id="31">, falou.</segment>
    <segment id="32">Sobre ser chamado de artilheiro dos pênaltis</segment>
    <segment id="33">, o camisa 9 deu uma resposta inteligente.</segment>
    <segment id="34">“</segment>
    <segment id="35">Vá lá bater  para você ver</segment>
    <segment id="36">comocomo é difícil fazer o gol.</segment>
    <segment id="37">No primeiro de ontem (contra o ABC)</segment>
    <segment id="38">, eu tinha que bater daquele jeito [rente à trave] para tirar do goleiro”</segment>
    <segment id="39">, explicou.</segment>
    <segment id="40">Neto diz que homenagem para Ivete vai sair logo</segment>
    <segment id="41">Uma marca histórica foi alcançada</segment>
    <segment id="42">, masmas Neto Baiano</segment>
    <segment id="43">, o guerreiro de Ituaçu-BA</segment>
    <segment id="44">, é incansável.</segment>
    <segment id="45">Com 24 gols</segment>
    <segment id="46">, ele está a três de igualar a marca de Cláudio Adão</segment>
    <segment id="47">, que em 1986 com a camisa do Bahia marcou 27 gols pelo Baianão e jamais foi superado.</segment>
    <segment id="48">“</segment>
    <segment id="49">E tenho que homenagear também a minha amiga Ivete Sangalo (risos).</segment>
    <segment id="50">Ela é uma rubro-negra maravilhosa e não posso desapontá-la”</segment>
    <segment id="51">, lembrou o atacante</segment>
    <segment id="52">, que já pediu duas vezes música no Fantástico e homenageou o amigo rubro-negro Durval Lélys.</segment>
    <segment id="53">“</segment>
    <segment id="54">É difícil chegar no Adão</segment>
    <segment id="55">, masmas quem sabe neste domingo</segment>
    <segment id="56">, em Senhor do Bonfim</segment>
    <segment id="57">,  eu não faça três gols e ainda teria mais três jogos para fazer um”</segment>
    <segment id="58">, afirmou.</segment>
  </rst>
</analysis>