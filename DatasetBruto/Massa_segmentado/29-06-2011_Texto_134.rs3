  <rst>
    <segment id="1">Mução é capturado em ação da polícia</segment>
    <segment id="2">Humorista é conhecido por passar trotes em programa de rádio</segment>
    <segment id="3">A Polícia Federal (PF) prendeu</segment>
    <segment id="4">, na manhã de ontem</segment>
    <segment id="5">, na Rua Guaratinga</segment>
    <segment id="6">, em Pernambués</segment>
    <segment id="7">, uma pessoa</segment>
    <segment id="8">, cujo nome não foi revelado</segment>
    <segment id="9">, acusada de integrar uma rede internacional de pornografia infantil pela internet.</segment>
    <segment id="10">A prisão é resultado da Operação DirtyNet</segment>
    <segment id="11">, que deteve 32 pessoas</segment>
    <segment id="12">, no cumprimento de 50 mandados de busca e apreensão e 15 de prisão</segment>
    <segment id="13">, em dez estados</segment>
    <segment id="14">, entre eles a Bahia.</segment>
    <segment id="15">Uma pessoa segue foragida.</segment>
    <segment id="16">Na cidade de Fortaleza</segment>
    <segment id="17">, o humorista e radialista Rodrigo Vieira Emerenciano</segment>
    <segment id="18">, mais conhecido</segment>
    <segment id="19">comocomo Mução</segment>
    <segment id="20">, foi um dos presos pela operação DirtyNet.</segment>
    <segment id="21">Ele foi preso em casa.</segment>
    <segment id="22">Mução é suspeito de integrar a quadrilha que atuava com pornografia infantil na internet.</segment>
    <segment id="23">A prisão de Mução é temporária - cinco dias -</segment>
    <segment id="24">masmas</segment>
    <segment id="25">, pode ser prorrogada.</segment>
    <segment id="26">Outras duas pessoas</segment>
    <segment id="27">, que não tiveram os nomes divulgados</segment>
    <segment id="28">, também foram presas em flagrante</segment>
    <segment id="29">, em Fortaleza.</segment>
    <segment id="30">Há seis meses</segment>
    <segment id="31">, a PF monitora redes privadas de compartilhamento de arquivos na internet.</segment>
    <segment id="32">Computadores com cenas de exploração sexual e pedofilia são alvo da operação.</segment>
    <segment id="33">Tem até canibal no meio</segment>
    <segment id="34">Os agentes identificaram relatos de outros crimes praticados pelos envolvidos contra crianças</segment>
    <segment id="35">, inclusive com menção a estupro cometido contra os próprios filhos</segment>
    <segment id="36">, sequestros</segment>
    <segment id="37">, assassinatos e atos de canibalismo.</segment>
    <segment id="38">Segundo a assessoria de imprensa da PF</segment>
    <segment id="39">, uma prisão foi efetuada em Esteio (RS)</segment>
    <segment id="40">, uma em Santa Maria (RS) e duas em Porto Alegre (RS).</segment>
    <segment id="41">Os alvos brasileiros da operação compartilhavam material com outros usuários da internet em mais de 34 países.</segment>
  </rst>
</analysis>