  <rst>
    <segment id="1">Boca do Rio é berço do pagodão</segment>
    <segment id="2">Grupo agita o público com o hit “Meta Mãe”</segment>
    <segment id="3">, que já está na ponta da língua da galera
“</segment>
    <segment id="4">O Brasil é o país do futebol e da boa música”</segment>
    <segment id="5">, diz o cantor Luã Freitas ao explicar o porquê de ter  batizado a banda Golaço com esse nome.</segment>
    <segment id="6">“Somos puro show de bola.</segment>
    <segment id="7">A galera adora”</segment>
    <segment id="8">, garante o músico animado.</segment>
    <segment id="9">Apesar de estar dando os primeiros passos no mundo musical</segment>
    <segment id="10">, com três meses de existência</segment>
    <segment id="11">, a trupe mostra que fôlego é o que não falta nos palcos.</segment>
    <segment id="12">“Já estamos no segundo CD de divulgação</segment>
    <segment id="13">, com 28 hits do melhor do pagode.</segment>
    <segment id="14">Oito músicas são nossas.</segment>
    <segment id="15">Agora, vamos preparar com carinho nosso primeiro DVD”</segment>
    <segment id="16">, revela o rapaz.</segment>
    <segment id="17">E não é só a vontade de fazer um novo trabalho que dá gás para essa galera.</segment>
    <segment id="18">Além do vocalista  Luã</segment>
    <segment id="19">, os outros 11 músicos que compõem o grupo são bem experientes e já tocaram muito em bandas renomadas do  pagode baiano</segment>
    <segment id="20">, como</segment>
    <segment id="21">como Rapina</segment>
    <segment id="22">, e com o cantor Edcity.</segment>
    <segment id="23">Os planos dessa rapaziada não são poucos.</segment>
    <segment id="24">“Ainda este ano vamos finalizar o projeto social na Boca do Rio para ensinar a criançada a tocar</segment>
    <segment id="25">, jogar capoeira e futebol</segment>
    <segment id="26">, é claro”</segment>
    <segment id="27">, diz o vocalista.</segment>
    <segment id="28">Ensaios aos sábado</segment>
    <segment id="29">A galera da banda Golaço marca um gol e tanto no quesito ensaio.</segment>
    <segment id="30">Todos os sábados</segment>
    <segment id="31">, na casa de show Clube SSA</segment>
    <segment id="32">, que fica na Rua Piauí</segment>
    <segment id="33">, Pituba</segment>
    <segment id="34">, a partir das 22h</segment>
    <segment id="35">, rola o pagodão de primeira que lota o lugar de gente bonita.</segment>
    <segment id="36">A entrada custa

R$ 15 para os homens e R$ 10 para a mulherada.</segment>
    <segment id="37">Para o cantor Luã Freitas</segment>
    <segment id="38">, os ensaios do “Meta Mãe”</segment>
    <segment id="39">, nome da música de trabalho do grupo</segment>
    <segment id="40">, é um recado para a mulherada.</segment>
    <segment id="41">“</segment>
    <segment id="42">A  mulher tem que ter atitude e vestir o que quiser.</segment>
    <segment id="43">Ela não pode deixar de fazer o que tem vontade por causa de homem nenhum.</segment>
    <segment id="44">Comigo não rola isso.</segment>
    <segment id="45">Minha mulher veste o que quiser e eu não tô nem aí”</segment>
    <segment id="46">, garante o rapaz muito seguro de si.</segment>
  </rst>
</analysis>