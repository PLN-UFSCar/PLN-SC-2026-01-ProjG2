  <rst>
    <segment id="1">Falcão chega para beliscar títulos</segment>
    <segment id="2">Apresentado ontem</segment>
    <segment id="3">, novo técnico do Bahia já começa a dirigir a equipe</segment>
    <segment id="4">O quinto triunfo seguido.</segment>
    <segment id="5">É esse o objetivo do Bahia na partida de hoje</segment>
    <segment id="6">, às 8h30 da noite</segment>
    <segment id="7">, contra o Vitória da Conquista</segment>
    <segment id="8">, em Pituaçu.</segment>
    <segment id="9">A equipe ainda será dirigida pelo auxiliar técnico Eduardo Souza.</segment>
    <segment id="10">Porém, o novo comandante tricolor</segment>
    <segment id="11">, Paulo Roberto Falcão</segment>
    <segment id="12">,  foi apresentado ontem e assume o time na próxima sexta.</segment>
    <segment id="13">Falcão chega para escrever uma nova história no Tricolor</segment>
    <segment id="14">, a começar pela conquista do Baianão.</segment>
    <segment id="15">“A preocupação é ganhar o Campeonato Baiano.</segment>
    <segment id="16">Vamos priorizar essa competição.</segment>
    <segment id="17">Mas, pela tradição do Bahia</segment>
    <segment id="18">, vamos buscar algo mais”</segment>
    <segment id="19">, promete.</segment>
    <segment id="20">O título do estadual</segment>
    <segment id="21">sese torna prioridade</segment>
    <segment id="22">porque</segment>
    <segment id="23">porque o tricolor não coloca a mão nesse troféu há dez  anos.</segment>
    <segment id="24">Além disso</segment>
    <segment id="25">, o último caneco a entrar  no Fazendão foi o da Copa do Nordeste</segment>
    <segment id="26">, em 2002.</segment>
    <segment id="27">Mesmo sabendo disso</segment>
    <segment id="28">, Falcão resolveu encarar a parada.</segment>
    <segment id="29">“</segment>
    <segment id="30">A certeza que existe preocupação com planejamento</segment>
    <segment id="31">, de priorizar algumas coisas e que o Bahia está numa nova fase  fez com que eu me motivasse”</segment>
    <segment id="32">, explicou.</segment>
    <segment id="33">Porém, o Falcão  não vai poder caçar sua primeira presa hoje.</segment>
    <segment id="34">Ele foi ao Rio Grande do Sul e retorna na sexta-feira para preparar a equipe que vai jogar o clássico contra o Vitória.</segment>
    <segment id="35">Será o reencontro com Toninho Cerezo</segment>
    <segment id="36">, companheiro da Seleção de 1982 e da Roma.</segment>
    <segment id="37">“Grande amigo</segment>
    <segment id="38">, grande figura.</segment>
    <segment id="39">A gente nunca vai ser inimigo</segment>
    <segment id="40">, só adversário.</segment>
    <segment id="41">Toninho Cerezo é irmão”</segment>
    <segment id="42">, lembrou.</segment>
    <segment id="43">Falcão trouxe outro amigão do peito para trabalhar com ele.</segment>
    <segment id="44">O auxiliar-técnico Julinho Camargo</segment>
    <segment id="45">, que passou pelo Vitória em 2009</segment>
    <segment id="46">, quando trabalhou com Paulo César Carpegiani.</segment>
    <segment id="47">Muitos torcedores afirmam que quem vai pegar no pesado é ele</segment>
    <segment id="48">, enquanto Falcão só seria uma “jogada” de marketing do Bahia.</segment>
    <segment id="49">Perguntado sobre isso</segment>
    <segment id="50">, Julinho</segment>
    <segment id="51">sese esquivou.</segment>
    <segment id="52">“</segment>
    <segment id="53">A admiração que eu tenho pelo Falcão é enorme e fico muito feliz em ser o auxiliar dele”</segment>
    <segment id="54">, desconversou.

Marketing ou não</segment>
    <segment id="55">, a chegada de Falcão pode dar um novo panaroma ao futebol baiano.</segment>
    <segment id="56">Como foi dito no início desta matéria</segment>
    <segment id="57">, chega para fazer uma nova história.</segment>
    <segment id="58">E essa história começa a ser escrita domingo</segment>
    <segment id="59">, no Ba-Vi.</segment>
  </rst>
</analysis>