  <rst>
    <segment id="1">Famosos detonam presença de ‘Mama’</segment>
    <segment id="2">A sister Fabiana está sendo duramente criticada nas redes sociais pela sua postura</segment>
    <segment id="3">Pelas redes sociais</segment>
    <segment id="4">, muitos internautas e alguns artistas estão demonstrando grande insatisfação com a presença de Fabiana na reta final do Big Brother Brasil 12.</segment>
    <segment id="5">A loira</segment>
    <segment id="6">, que era “unha e carne” com Kelly –  eliminada na noite de anteontem –</segment>
    <segment id="7">, mostrou que não era tão amiga</segment>
    <segment id="8">comocomo</segment>
    <segment id="9">sese dizia.</segment>
    <segment id="10">Após uma briga feia entre as duas na última quinta-feira</segment>
    <segment id="11">,   Fabiana foi muito grosseira com Kelly</segment>
    <segment id="12">, e sua atitude fez com que a insatisfação da galera aumentasse ainda mais.</segment>
    <segment id="13">Até a cantora Preta Gil usou seu Twitter para declarar  seu descontentamento com a garota-propaganda.</segment>
    <segment id="14">“Gente</segment>
    <segment id="15">, a Fabiana é muito falsa mesmo.</segment>
    <segment id="16">O que ela fez hoje com a Kelly dá até raiva</segment>
    <segment id="17">, tô vendo aqui a cena podre”</segment>
    <segment id="18">, escreveu.</segment>
    <segment id="19">Nem o autor Aguinaldo Silva poupou comentários na rede: "</segment>
    <segment id="20">Ai, Fabiana</segment>
    <segment id="21">, deita na BR!</segment>
    <segment id="22">",</segment>
    <segment id="23">debochou ele</segment>
    <segment id="24">, depois da loira</segment>
    <segment id="25">sese oferecer para ir ao paredão ao invés de indicar alguém.</segment>
    <segment id="26">Fabiana é a primeira a</segment>
    <segment id="27">sese garantir na final do reality.</segment>
  </rst>
