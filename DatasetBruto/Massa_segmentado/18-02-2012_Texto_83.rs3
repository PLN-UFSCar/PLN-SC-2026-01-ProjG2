  <rst>
    <segment id="1">Casa cai para rival de Nem Gorda
Jaílson Maciel</segment>
    <segment id="2">, o Jajai</segment>
    <segment id="3">, está preso acusado de matar a irmã de Nem</segment>
    <segment id="4">A saga protagonizada pela traficante Maria Lúcia dos Santos Gomes</segment>
    <segment id="5">, 37 anos</segment>
    <segment id="6">, a Nem Gorda</segment>
    <segment id="7">, vem à tona novamente com mais um capítulo recheado de crueldade</segment>
    <segment id="8">, troca de acusações e guerras mortais por disputas de pontos de venda de drogas.</segment>
    <segment id="9">O mais novo personagem é Jaílson Bomfim Maciel</segment>
    <segment id="10">, 28, o Jajai.</segment>
    <segment id="11">Ele está preso na Delegacia de Periperi acusado de assassinar Eliaci Conceição Gomes</segment>
    <segment id="12">, 49, irmã de Nem Gorda</segment>
    <segment id="13">, no dia 16 de abril de 2011</segment>
    <segment id="14">, no bairro Alto de Coutos.</segment>
    <segment id="15">Eliaci foi morta a tiros</segment>
    <segment id="16">, facadas e teve os olhos arrancados.</segment>
    <segment id="17">Na época do crime</segment>
    <segment id="18">, Nem Gorda fez protestos afirmando que a irmã não era envolvida com o tráfico de drogas e que teria sido morta após um assalto.</segment>
    <segment id="19">Jajai,</segment>
    <segment id="20">porémporém</segment>
    <segment id="21">, conta uma outra versão.</segment>
    <segment id="22">“</segment>
    <segment id="23">Não teve essa história de latrocínio (roubo seguido de morte) não.</segment>
    <segment id="24">Isso é armação dela (de Nem Gorda)”</segment>
    <segment id="25">, afirma Jajai.</segment>
    <segment id="26">Segundo Jailson</segment>
    <segment id="27">, ele resolveu matar Eliaci</segment>
    <segment id="28">porque</segment>
    <segment id="29">porque ela e Nem Gorda estariam ameaçando ele de morte.</segment>
    <segment id="30">Jajai diz que vendia maconha em Fazenda Coutos e as duas irmãs queriam expandir o domínio das bocas de fumo para lá.</segment>
    <segment id="31">“É a guerra do tráfico</segment>
    <segment id="32">, irmão.</segment>
    <segment id="33">Estava sendo ameaçado.</segment>
    <segment id="34">Nem Gorda é muito gulosa</segment>
    <segment id="35">, queria tomar tudo para ela.</segment>
    <segment id="36">Ela queria dominar Paripe e o Subúrbio todo</segment>
    <segment id="37">, tomar tudo para ela”</segment>
    <segment id="38">, diz Jajai</segment>
    <segment id="39">, que foi preso em Santo Antônio de Jesus durante operação conjunta dos policiais civis locais com os agentes da Delegacia de Periperi.</segment>
  </rst>
</analysis>