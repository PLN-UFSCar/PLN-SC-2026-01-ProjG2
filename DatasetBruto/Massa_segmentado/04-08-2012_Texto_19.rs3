  <rst>
    <segment id="1">Estrela petista desaparece de placas e santinhos
RIO</segment>
    <segment id="2">, Sﾃθ丹 PAULO e RECIFE - Sﾃδｭmbolo maior do PT</segment>
    <segment id="3">, a estrela vermelha anda sumida do material de propaganda polﾃδｭtica na maior parte das cidades fluminenses onde hﾃδ｡ candidato petista a prefeito.</segment>
    <segment id="4">E, quando ela ﾃδｩ usada</segment>
    <segment id="5">, aparece tﾃδｭmida.</segment>
    <segment id="6">A cor vermelha</segment>
    <segment id="7">, outra marca da legenda</segment>
    <segment id="8">, tambﾃδｩm foi preterida em santinhos</segment>
    <segment id="9">, placas e deixou de reinar sozinha nos sites de candidatos.</segment>
    <segment id="10">Em seu lugar</segment>
    <segment id="11">, o branco</segment>
    <segment id="12">, o azul e o laranja dﾃδ｣o o tom da campanha.</segment>
    <segment id="13">Em Sﾃδ｣o Paulo nﾃδ｣o</segment>
    <segment id="14">ﾃδｩ muito diferente.</segment>
    <segment id="15">Na capital paulista</segment>
    <segment id="16">, o laranja ﾃδｩ mais visto que o vermelho.</segment>
    <segment id="17">Segundo membros da campanha</segment>
    <segment id="18">, para mostrar que o candidato traz mudanﾃδｧa.</segment>
    <segment id="19">Para marqueteiros de campanhas petistas no Rio</segment>
    <segment id="20">, o cuidado no uso de sﾃδｭmbolos do PT remete a uma preocupaﾃδｧﾃδ｣o com o eleitor</segment>
    <segment id="21">, que pode relacionar candidatos e sigla ao julgamento do mensalﾃδ｣o.</segment>
    <segment id="22">Candidato a prefeito de Niterﾃδｳi</segment>
    <segment id="23">, na regiﾃδ｣o metropolitana</segment>
    <segment id="24">, o ex-secretﾃδ｡rio estadual de Assistﾃδｪncia Social Rodrigo Neves trocou o vermelho pelo fundo branco em placas</segment>
    <segment id="25">, adesivos e santinhos.</segment>
    <segment id="26">A estrela desapareceu das ruas</segment>
    <segment id="27">, sob alegaﾃδｧﾃδ｣o de que sua coligaﾃδｧﾃδ｣o</segment>
    <segment id="28">ﾃδｩ extensa.</segment>
    <segment id="29">Em Paraty</segment>
    <segment id="30">, o material de campanha do candidato a prefeito Carlos Miranda</segment>
    <segment id="31">, o Casﾃδｩ</segment>
    <segment id="32">, usa a cor laranja</segment>
    <segment id="33">, sem estrela.</segment>
    <segment id="34">Jﾃδ｡ o deputado estadual e candidato petista a prefeito de Teresﾃδｳpolis</segment>
    <segment id="35">, na Regiﾃδ｣o Serrana</segment>
    <segment id="36">, Nilton Salomﾃδ｣o</segment>
    <segment id="37">, evitou o vermelho no alto de seu site de campanha</segment>
    <segment id="38">, ao contrﾃδ｡rio de sua pﾃδ｡gina de parlamentar.</segment>
    <segment id="39">O fundo tem cores da bandeira nacional.</segment>
    <segment id="40">Em Japeri</segment>
    <segment id="41">, na Baixada Fluminense</segment>
    <segment id="42">, o deputado estadual e candidato petista a prefeito Andrﾃδｩ Ceciliano investiu no azul.</segment>
    <segment id="43">Ainda na Baixada</segment>
    <segment id="44">, o candidato do PT a prefeito de Mesquita</segment>
    <segment id="45">, Andrﾃδｩ Taffarel</segment>
    <segment id="46">, usa a estrela do partido em seu site apenas no pﾃδｩ da pﾃδ｡gina.</segment>
    <segment id="47">De acordo com o presidente regional do PT</segment>
    <segment id="48">, Jorge Florﾃδｪncio</segment>
    <segment id="49">, cada candidato tem a liberdade para criar seu material de campanha.</segment>
    <segment id="50">No entanto</segment>
    <segment id="51">, recomenda-</segment>
    <segment id="52">sese que sejam usadas a estrela e a cor vermelha.</segment>
    <segment id="53">Florﾃδｪncio descarta qualquer relaﾃδｧﾃδ｣o da retirada de sﾃδｭmbolos do PT com o julgamento do mensalﾃδ｣o em curso no Supremo Tribunal Federal.</segment>
    <segment id="54">Em Sﾃδ｣o Paulo</segment>
    <segment id="55">, partido opta pelo 'laranja amanhecer'</segment>
    <segment id="56">Em Sﾃδ｣o Paulo</segment>
    <segment id="57">, o PT nﾃδ｣o chegou a abandonar de vez o vermelho na campanha eleitoral deste ano</segment>
    <segment id="58">, masmas adotou o laranja</segment>
    <segment id="59">comocomo cor predominante nas bandeiras e folhetos do candidato Fernando Haddad.</segment>
    <segment id="60">A estratﾃδｩ</segment>
    <segment id="61">gia</segment>
    <segment id="62">ﾃδｩ remeter a imagem do ex-ministro petista</segment>
    <segment id="63">, cujo slogan ﾃδｩ "o homem novo para um tempo novo"</segment>
    <segment id="64">, ao amanhecer</segment>
    <segment id="65">, segundo a campanha</segment>
    <segment id="66">, aos conceitos de novidade e mudanﾃδｧa.</segment>
    <segment id="67">O esforﾃδｧo dos petistas</segment>
    <segment id="68">ﾃδｩ diferenciar a candidatura de Haddad a de Josﾃδｩ Serra</segment>
    <segment id="69">, candidato do PSDB</segment>
    <segment id="70">, que jﾃδ｡ foi prefeito e governador de Sﾃδ｣o Paulo.</segment>
    <segment id="71">O laranja serﾃδ｡ usado tambﾃδｩm na propaganda eleitoral televisiva</segment>
    <segment id="72">, em cenﾃδ｡rios de estﾃδｺdios e artes visuais.</segment>
    <segment id="73">O candidato do PT tem feito</segment>
    <segment id="74">, inclusive</segment>
    <segment id="75">, gravaﾃδｧﾃδｵes externas durante o inﾃδｭcio da manhﾃδ｣</segment>
    <segment id="76">, para captar imagens de fundo do amanhecer.</segment>
    <segment id="77">A cor tambﾃδｩm</segment>
    <segment id="78">ﾃδｩ associada</segment>
    <segment id="79">, na linguagem semiﾃδｳtica</segment>
    <segment id="80">, ﾃδ juventude e ﾃδ dinﾃδ｢mica.</segment>
    <segment id="81">Novato em campanhas eleitorais</segment>
    <segment id="82">, Fernando Haddad ﾃδｩ 21 anos mais novo que seu principal adversﾃδ｡rio do PSDB.
- Nﾃδｳs nﾃδ｣o abandonamos o vermelho.</segment>
    <segment id="83">Essa cor amarelo-alaranjada</segment>
    <segment id="84">, usada em alguns materiais de campanha</segment>
    <segment id="85">, indica a novidade</segment>
    <segment id="86">, a esperanﾃδｧa</segment>
    <segment id="87">, sugere o novo - explica o vereador Josﾃδｩ</segment>
    <segment id="88">Amﾃδｩrico</segment>
    <segment id="89">, membro do conselho de campanha.</segment>
    <segment id="90">Entre o branco e o vermelho</segment>
    <segment id="91">Ao contrﾃδ｡rio do que acontece no Rio e em Sﾃδ｣o Paulo</segment>
    <segment id="92">, em Recife o vermelho e a estrela foram mantidos.</segment>
    <segment id="93">A cor ainda caracteriza as roupas nﾃδ｣o sﾃδｳ de candidatos (vice e vereadores)</segment>
    <segment id="94">, masmas tambﾃδｩm da militﾃδ｢ncia.</segment>
    <segment id="95">Apenas o Senador Humberto Costa (PT-PE)</segment>
    <segment id="96">, candidato a prefeito</segment>
    <segment id="97">, deixou de vestir o vermelho e usa camisas brancas.</segment>
    <segment id="98">Ele nega que a opﾃδｧﾃδ｣o tenha a ver com algum temor em relaﾃδｧﾃδ｣o ao mensalﾃδ｣o.
- Sempre usei o vermelho.</segment>
    <segment id="99">O problema ﾃδｩ que todo mundo estﾃδ｡ usando e eu preferi mudar para dar destaque ao candidato.</segment>
    <segment id="100">Se saio do mesmo jeito da militﾃδ｢ncia</segment>
    <segment id="101">, ninguﾃδｩm me vﾃδｪ no meio da multidﾃδ｣o</segment>
    <segment id="102">, durante as caminhadas.</segment>
    <segment id="103">O branco</segment>
    <segment id="104">, que ﾃδｩ diferente</segment>
    <segment id="105">, ﾃδｩ que dﾃδ｡ o destaque.</segment>
    <segment id="106">Mas a militﾃδ｢ncia nﾃδ｣o gosta disso nﾃδ｣o.</segment>
    <segment id="107">Cobra a cor vermelha</segment>
    <segment id="108">, reclama</segment>
    <segment id="109">, diz que estou vacilando</segment>
    <segment id="110">, afirma o petista.</segment>
    <segment id="111">Com vantagem nas pesquisas de opiniﾃδ｣o - 40% das intenﾃδｧﾃδｵes de voto no Ibope e 35% por cento no Datafolha -</segment>
    <segment id="112">, Humberto Costa diz nﾃδ｣o ver motivo para introduzir mudanﾃδｧas na programaﾃδｧﾃδ｣o visual de sua campanha:
- Acho importante ratificar cor e sﾃδｭmbolo do partido</segment>
    <segment id="113">, que ﾃδｩ muito forte em Recife.</segment>
    <segment id="114">Entﾃδ｣o</segment>
    <segment id="115">, ao invﾃδｩs de omitir</segment>
    <segment id="116">, vamos carregar nos sﾃδｭmbolos.</segment>
