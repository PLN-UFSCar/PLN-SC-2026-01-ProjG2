  <rst>
    <segment id="1">Meninas são calculadoras do tráfico</segment>
    <segment id="2">Bandidos de Lauro de Freitas aliciam garotas para trabalhar nas atividades das bocas</segment>
    <segment id="3">As prisões de quatro homens</segment>
    <segment id="4">, no bairro de Portão</segment>
    <segment id="5">, em Lauro de Freitas</segment>
    <segment id="6">, anteontem</segment>
    <segment id="7">, revelou uma estratégia que vem sendo cada vez mais adotada pelos traficantes baianos: o aliciamento de meninas adolescentes para atuarem no transporte das drogas e também na contabilidade das bocas de fumo.</segment>
    <segment id="8">Prova disso foi o caderno encontrado pela polícia em uma das casas usadas pelo atual chefão do tráfico na localidade do Pé Preto</segment>
    <segment id="9">, Marcos Vinícius Bispo dos Santos Filho</segment>
    <segment id="10">, 20 anos</segment>
    <segment id="11">, o Ninja</segment>
    <segment id="12">, um dos detidos</segment>
    <segment id="13">, anteontem.</segment>
    <segment id="14">O caderno pertence a uma jovem conhecida</segment>
    <segment id="15">comocomo Vivi Pimentinha.</segment>
    <segment id="16">Nas anotações</segment>
    <segment id="17">, há informações sobre valores relativos a venda de drogas e divisão de lucros do tráfico.</segment>
    <segment id="18">Segundo o delegado Cláudio Meirelles</segment>
    <segment id="19">, titular da Delegacia de Portão</segment>
    <segment id="20">, os bandidos cooptam as jovens</segment>
    <segment id="21">poispois sabem que as adolescentes chamam menos atenção nas atividades de vendas de drogas e também têm punições mais brandas em relação às pessoas maiores de idade.</segment>
    <segment id="22">Muitas delas têm casos amorosos com os bandidos.</segment>
    <segment id="23">Além de Ninja</segment>
    <segment id="24">, foram presos ainda José Nilton Gonzaga Junior</segment>
    <segment id="25">, 20, Manoel Alves de Jesus</segment>
    <segment id="26">, 54, e o taxista Amilton Costa Filho</segment>
    <segment id="27">, 54.</segment>
    <segment id="28">De acordo com o delegado</segment>
    <segment id="29">, Amilton usava o táxi para prestar serviços ao tráfico</segment>
    <segment id="30">, como</segment>
    <segment id="31">como transporte de tóxicos e armas</segment>
    <segment id="32">, além de corridas com os criminosos.</segment>
    <segment id="33">Um adolescente de 17 anos também foi preso com a quadrilha.</segment>
    <segment id="34">Segundo a polícia</segment>
    <segment id="35">, Ninja assumiu os lugares dos chefões Anderson Andrade</segment>
    <segment id="36">, 27, o Seu Dani</segment>
    <segment id="37">, e Diego Reis da Silva</segment>
    <segment id="38">, 20, o Chalalau</segment>
    <segment id="39">,  após eles serem presos.</segment>
    <segment id="40">Seguiu viatura</segment>
    <segment id="41">Sem imaginar que estavam sendo monitorados</segment>
    <segment id="42">, Ninja e o taxista Amilton foram detidos quando seguiam uma viatura despadronizada da Polícia Civil.</segment>
    <segment id="43">Segundo o delegado</segment>
    <segment id="44">, a quadrilha de Ninja planejava atacar os rivais do bando do traficante Babão</segment>
    <segment id="45">, para dominar as bocas de fumo da Rua Direta de Portão.</segment>
  </rst>
</analysis>