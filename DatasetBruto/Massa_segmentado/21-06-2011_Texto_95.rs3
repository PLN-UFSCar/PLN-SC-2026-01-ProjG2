    <segment id="1">Ah, ela quer...</segment>
    <segment id="2">Melancia cria funk</segment>
    <segment id="3">‘kero ti</segment>
    <segment id="4">, kero dá’
Andressa Soares</segment>
    <segment id="5">, a Mulher Melancia</segment>
    <segment id="6">, acaba de lançar uma música novinha.</segment>
    <segment id="7">Na letra da canção de duplo sentido</segment>
    <segment id="8">, ela canta “‘</segment>
    <segment id="9">Eu kero ti</segment>
    <segment id="10">, eu kero dá”</segment>
    <segment id="11">,  em uma criativa versão da música "</segment>
    <segment id="12">Eu quero tchu</segment>
    <segment id="13">, eu quero tchá”</segment>
    <segment id="14">, da dupla sertaneja João Lucas e Marcelo.</segment>
    <segment id="15">A bela está fazendo o maior sucesso em seus shows com o hit - e o rebolado que lhe é peculiar.</segment>
    <segment id="16">O público feminino a acompanha até o chão</segment>
    <segment id="17">, enquanto o masculino</segment>
    <segment id="18">sese ocupa de fotografar tudo e mais um pouco.</segment>
    <segment id="19">Afinal</segment>
    <segment id="20">, o que ela quer mesmo?</segment>
