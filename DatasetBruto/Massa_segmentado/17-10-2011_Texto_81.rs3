  <rst>
    <segment id="1">Pais perdem os três filhos de uma vez
Acidente na Paralela interrompe união de três irmãos que morreram juntos</segment>
    <segment id="2">A morte já é um golpe duro.</segment>
    <segment id="3">A dor foi multiplicada por três para os familiares dos irmãos Ítalo</segment>
    <segment id="4">, 30 anos</segment>
    <segment id="5">, Thiago</segment>
    <segment id="6">, 26, e Túlio Cerqueira Pereira</segment>
    <segment id="7">, 24, que morreram em um acidente na noite de sábado (15).</segment>
    <segment id="8">Segundo parentes</segment>
    <segment id="9">, o Fiat Uno onde os irmãos estavam bateu no meio-fio</segment>
    <segment id="10">, perdeu o controle e capotou até</segment>
    <segment id="11">sese chocar contra um poste na Avenida Paralela</segment>
    <segment id="12">, sentido Rodoviária</segment>
    <segment id="13">, próximo ao Wet’n Wild.</segment>
    <segment id="14">“</segment>
    <segment id="15">O avô deles me informou que Túlio ficou preso nas ferragens.</segment>
    <segment id="16">Enquanto Thiago e Ítalo foram arremessados para fora do carro”</segment>
    <segment id="17">, declarou o radialista Giliard José.</segment>
    <segment id="18">Os irmãos moravam em Salvador</segment>
    <segment id="19">, masmas eram naturais de Santo Amaro</segment>
    <segment id="20">, cidade a 71 Km da capital.</segment>
    <segment id="21">Os três eram estudantes de engenharia da faculdade Área 1.</segment>
    <segment id="22">Ítalo cursava engenharia de produção e já estava no 10º semestre.</segment>
    <segment id="23">Thiago e Túlio estudavam engenharia civil</segment>
    <segment id="24">, ambos no 6º semestre.</segment>
    <segment id="25">Os corpos dos jovens foram enterrados ontem no cemitério Campo da Caridade</segment>
    <segment id="26">, em Santo Amaro.</segment>
    <segment id="27">Familiares entraram em desespero no enterro dos três jovens ontem à tarde</segment>
    <segment id="28">Cerca de 700 pessoas compareceram à cerimônia.</segment>
    <segment id="29">“Foi uma fatalidade.</segment>
    <segment id="30">Eles eram muito queridos.</segment>
    <segment id="31">Por isso tanta gente veio”</segment>
    <segment id="32">, declarou José Augusto Pinto</segment>
    <segment id="33">, tio das vítimas.</segment>
    <segment id="34">“</segment>
    <segment id="35">Os pais estão desorientados.</segment>
    <segment id="36">Imagine</segment>
    <segment id="37">comocomo fica a cabeça de quem perde todos os filhos de uma vez só?</segment>
    <segment id="38">”, questionou o tio.</segment>
    <segment id="39">Irmãos eram unidos</segment>
    <segment id="40">“</segment>
    <segment id="41">Não aconteceu por acaso.</segment>
    <segment id="42">A ideia que a tragédia veio passar é a da união que eles sempre tiveram.</segment>
    <segment id="43">A questão da família”</segment>
    <segment id="44">, acredita Osvaldo Júnior</segment>
    <segment id="45">, primo dos jovens.</segment>
    <segment id="46">Ítalo, o irmão mais velho</segment>
    <segment id="47">, foi o primeiro a vir morar em Salvador</segment>
    <segment id="48">, onde estudou no Cefet e</segment>
    <segment id="49">sese formou técnico mecânico industrial</segment>
    <segment id="50">, antes de começar a faculdade de engenharia de produção.</segment>
    <segment id="51">“</segment>
    <segment id="52">O sonho dele era</segment>
    <segment id="53">sese formar para orgulhar a mãe</segment>
    <segment id="54">, que sempre</segment>
    <segment id="55">sese esforçou e o colocou nas melhores escolas de Santo Amaro”</segment>
    <segment id="56">, lembra Osvaldo.</segment>
    <segment id="57">“Ele também incentivava muito os amigos a estudar”</segment>
    <segment id="58">, completa.</segment>
    <segment id="59">Dias difíceis:</segment>
    <segment id="60">Dor dos pais</segment>
    <segment id="61">Os pais dos jovens</segment>
    <segment id="62">, o  técnico em refrigeração  Antônio Evaristo Pinto Pereira e a professora de geografia Gracília</segment>
    <segment id="63">Raimunda Cerqueira Pereira</segment>
    <segment id="64">, estavam inconsoláveis no enterro.</segment>
    <segment id="65">O casal não teve condições de conversar com a imprensa.</segment>
    <segment id="66">Gracília Cerqueira Pereira</segment>
    <segment id="67">, mãe das vítimas</segment>
    <segment id="68">, precisou ser amparada por parentes</segment>
  </rst>
</analysis>