  <rst>
    <segment id="1">Parque de diversões onde uma adolescente morreu e outras nove pessoas ficaram feridas não tinha alvará de funcionamento
RIO - A festa</segment>
    <segment id="2">sese transformou em tragédia na segunda-feira de madrugada num parque de diversões clandestino</segment>
    <segment id="3">O Glória Center</segment>
    <segment id="4">, na Estrada dos Bandeirantes</segment>
    <segment id="5">, em Vargem Grande.</segment>
    <segment id="6">Um dos carrinhos do brinquedo</segment>
    <segment id="7">Tufão se</segment>
    <segment id="8">se soltou</segment>
    <segment id="9">, matando a adolescente Alessandra da Silva Aguilar</segment>
    <segment id="10">, de 17 anos</segment>
    <segment id="11">, e ferindo nove pessoas</segment>
    <segment id="12">, duas em estado grave.</segment>
    <segment id="13">A jovem</segment>
    <segment id="14">, que morreu na hora</segment>
    <segment id="15">, foi atingida quando comprava ingresso na bilheteria para andar na atração pela segunda vez.</segment>
    <segment id="16">No Tufão</segment>
    <segment id="17">, carrinhos rodam suspensos no ar.</segment>
    <segment id="18">Embora o laudo só vá sair em 30 dias</segment>
    <segment id="19">, peritos da polícia disseram que o brinquedo "estava bastante enferrujado"</segment>
    <segment id="20">, segundo a delegada da 42ª DP (Recreio dos Bandeirantes)</segment>
    <segment id="21">, Adriana Belém.</segment>
    <segment id="22">O Glória Center foi interditado e sua dona</segment>
    <segment id="23">, Maria Glória Pinto</segment>
    <segment id="24">, será indiciada por homicídio culposo (sem intenção de matar).</segment>
    <segment id="25">O parque estava funcionando no local</segment>
    <segment id="26">, ilegalmente</segment>
    <segment id="27">, há duas semanas.</segment>
    <segment id="28">Os brinquedos haviam sido liberados por um engenheiro e pelo Corpo de Bombeiros.</segment>
    <segment id="29">No entanto</segment>
    <segment id="30">, o Glória Center não tinha recebido alvará de funcionamento da prefeitura</segment>
    <segment id="31">, segundo informou a Secretaria Especial de Ordem Pública.</segment>
    <segment id="32">Por isso</segment>
    <segment id="33">, foi multado em R$ 535</segment>
    <segment id="34">,50.</segment>
    <segment id="35">O órgão esclareceu que o alvará é concedido somente após os proprietários entrarem com pedido na prefeitura</segment>
    <segment id="36">, mediante autorização dos bombeiros.</segment>
    <segment id="37">Para que um parque de diversões funcione legalmente</segment>
    <segment id="38">, seus responsáveis precisam cumprir algumas exigências.</segment>
    <segment id="39">É necessário</segment>
    <segment id="40">, por exemplo</segment>
    <segment id="41">, apresentar na Diretoria de Diversões Públicas do Corpo de Bombeiros anotações de responsabilidade técnica de um engenheiro credenciado pelo Conselho regional de Engenharia e Arquitetura (Crea).</segment>
    <segment id="42">Esse profissional deve</segment>
    <segment id="43">sese responsabilizar por todos os brinquedos durante o período de funcionamento do parque.</segment>
    <segment id="44">Além disso</segment>
    <segment id="45">, é necessário apresentar contrato social</segment>
    <segment id="46">, nota fiscal dos extintores e croqui do local</segment>
    <segment id="47">, com o posicionamento dos brinquedos.

- Depois disso</segment>
    <segment id="48">, vamos ao local fazer as vistorias - disse o capitão Marcelo Rosa</segment>
    <segment id="49">, responsável pela Diretoria de Diversões Públicas.</segment>
    <segment id="50">No caso</segment>
    <segment id="51">caso do Glória Center</segment>
    <segment id="52">, segundo o capitão Marcelo Rosa</segment>
    <segment id="53">, os responsáveis apresentaram toda a documentação necessária</segment>
    <segment id="54">, inclusive anotações de responsabilidade técnica de um engenheiro - Luís Soares Santiago - credenciado pelo Crea.</segment>
    <segment id="55">De acordo com o militar</segment>
    <segment id="56">, foram feitas vistorias no local antes de ser autorizado o funcionamento do parque</segment>
    <segment id="57">, e nenhuma irregularidade foi constatada:

- Estava tudo OK.</segment>
    <segment id="58">De acordo com a Secretaria de Ordem Pública</segment>
    <segment id="59">, no entanto</segment>
    <segment id="60">, os responsáveis pelo Glória Center não deram entrada no processo na prefeitura.</segment>
    <segment id="61">O engenheiro Luís Soares costuma ser o responsável pelo projeto e pela manutenção de outros parques.</segment>
    <segment id="62">Na página do Crea-RJ</segment>
    <segment id="63">, ele tem em seu cadastro cerca de 1.300 Anotações de Responsabilidade Técnica (ART)</segment>
    <segment id="64">, documento com que o profissional faz o registro obrigatório dos trabalhos para os quais é contratado.</segment>
    <segment id="65">Muitas dessas anotações são referentes a projetos</segment>
    <segment id="66">, inspeção</segment>
    <segment id="67">, manutenção e legalização de parques de diversões.</segment>
    <segment id="68">A Polícia Civil abriu inquérito para investigar o acidente no Glória Center.</segment>
    <segment id="69">Segundo a delegada Adriana Belém</segment>
    <segment id="70">, a proprietária do parque</segment>
    <segment id="71">, Maria Glória Pinto</segment>
    <segment id="72">, também apresentou o documento do engenheiro responsável pela vistoria dos brinquedos.

- Ela disse que foi tudo uma fatalidade</segment>
    <segment id="73">, que nunca tinha acontecido um acidente no parque.</segment>
    <segment id="74">Mas vamos investigar essas informações e aguardar o resultado da perícia - disse a delegada.</segment>
    <segment id="75">A Polícia Civil deverá ouvir outras testemunhas esta semana</segment>
    <segment id="76">, além dos pais de Alessandra e do engenheiro.</segment>
    <segment id="77">O acidente ocorreu por volta das 2h30m e houve pânico no parque.</segment>
    <segment id="78">A estimativa é que havia entre 1.500 e duas mil pessoas no local</segment>
    <segment id="79">, onde era realizada uma festa junina fora de época</segment>
    <segment id="80">, com shows de artistas</segment>
    <segment id="81">comocomo a funkeira Verônica Costa.</segment>
    <segment id="82">Segundo testemunhas contaram à família de Alessandra</segment>
    <segment id="83">, o carrinho que</segment>
    <segment id="84">sese soltou estaria com seis pessoas</segment>
    <segment id="85">, quando a lotação é quatro.</segment>
    <segment id="86">Os promotores da festa</segment>
    <segment id="87">, no entanto</segment>
    <segment id="88">, afirmaram na polícia que havia apenas três pessoas.</segment>
    <segment id="89">Parentes da adolescente morta fizeram fotos que mostram o mau estado de conservação do brinquedo e do carrinho que atingiu a jovem.</segment>
    <segment id="90">A peça</segment>
    <segment id="91">, de fibra de vidro</segment>
    <segment id="92">, apresenta ferrugem</segment>
    <segment id="93">, pintura danificada e corrosão na parte inferior.</segment>
    <segment id="94">Cunhada de Alessandra</segment>
    <segment id="95">, Jéssica Siqueira Costa</segment>
    <segment id="96">, de 26 anos</segment>
    <segment id="97">, contou que ela e a vítima tinham ido ao brinquedo pouco antes de ocorrer o acidente:

- Ela (Alessandra) quis ir mais uma vez.</segment>
    <segment id="98">Pediu dinheiro ao meu irmão</segment>
    <segment id="99">, que acabou dando.</segment>
    <segment id="100">A única coisa que percebi quando fui da primeira vez era que estava saindo vapor.</segment>
    <segment id="101">O motoboy Arlindo Pereira da Silva</segment>
    <segment id="102">, de 40 anos</segment>
    <segment id="103">, estava no brinquedo que despencou e escapou sem ferimentos.

- Eu estava num carrinho quando o brinquedo</segment>
    <segment id="104">sese soltou e saiu voando.</segment>
    <segment id="105">Momentos antes</segment>
    <segment id="106">, escutei alguns estalos.</segment>
    <segment id="107">Algumas pessoas começaram a gritar</segment>
    <segment id="108">, dizendo que ele estava pegando fogo - contou.</segment>
    <segment id="109">Entre os feridos</segment>
    <segment id="110">, há gente que estava no carrinho e que esperava a vez de</segment>
    <segment id="111">sese divertir no Tufão.</segment>
    <segment id="112">Dois se</segment>
    <segment id="113">se encontram em estado grave: Vitor Alcântara Oliveira</segment>
    <segment id="114">, de 16 anos</segment>
    <segment id="115">, e Daiane Mesquita</segment>
    <segment id="116">, de 17.</segment>
    <segment id="117">Eles tiveram traumatismo craniano e estão no Hospital Miguel Couto</segment>
    <segment id="118">, no Leblon.</segment>
    <segment id="119">Pâmela Beatriz</segment>
    <segment id="120">, de 17 anos</segment>
    <segment id="121">, passou o dia em observação no Hospital Lourenço Jorge</segment>
    <segment id="122">, na Barra</segment>
    <segment id="123">, e recebeu alta por volta das 18h30</segment>
    <segment id="124">m.</segment>
    <segment id="125">O mesmo aconteceu com Ana Gabriela Vanbelhe</segment>
    <segment id="126">, de 18 anos</segment>
    <segment id="127">, que sofreu um corte na nuca.</segment>
    <segment id="128">Francine Santana</segment>
    <segment id="129">, de 20 anos</segment>
    <segment id="130">, fraturou a mandíbula e está no Miguel Couto.</segment>
    <segment id="131">Os outros quatro feridos são Leandro da Conceição</segment>
    <segment id="132">, de 26 anos</segment>
    <segment id="133">;</segment>
    <segment id="134">Luciano Ferreira dos Santos</segment>
    <segment id="135">, de 30</segment>
    <segment id="136">; Luiz Gomes do Nascimento e Neide Carvalho Pinto</segment>
    <segment id="137">, que não tiveram as idades divulgadas.</segment>
    <segment id="138">Segundo a Secretaria municipal de Saúde</segment>
    <segment id="139">, eles foram atendidos em hospitais particulares.</segment>
    <segment id="140">O Glória Center é itinerante e teria ficado algumas semanas em Curicica (Jacarepaguá)</segment>
    <segment id="141">, antes de</segment>
    <segment id="142">sese instalar em Vargem Grande.</segment>
    <segment id="143">Em março do ano passado</segment>
    <segment id="144">, ele esteve em Saquarema.

Ex-PM perdeu a filha no Dia dos Pais</segment>
    <segment id="145">O almoço do Dia dos Pais seria em família.</segment>
    <segment id="146">O PM reformado Carlos Augusto Aguilar</segment>
    <segment id="147">, de 53 anos</segment>
    <segment id="148">, já tinha comprado o peixe que prepararia para comemorar a data.</segment>
    <segment id="149">Mas, no meio da madrugada</segment>
    <segment id="150">, um telefonema o acordou para um pesadelo.</segment>
    <segment id="151">Eram mais de 4h quando ele soube da morte de sua única filha.</segment>
    <segment id="152">E, em vez da celebração com os filhos</segment>
    <segment id="153">, Carlos Augusto passou o dia ontem no IML para liberar o corpo de Alessandra da Silva Aguilar.

- Hoje (domingo)</segment>
    <segment id="154">, ela queria comer peixe.</segment>
    <segment id="155">Eu faria ensopado</segment>
    <segment id="156">, do jeito que ela gostava - contou o pai</segment>
    <segment id="157">, muito emocionado.</segment>
    <segment id="158">- Agora</segment>
    <segment id="159">, quero apenas enterrá-la.</segment>
    <segment id="160">Amanhã</segment>
    <segment id="161">, não sei.</segment>
    <segment id="162">Morreu minha princesa.</segment>
    <segment id="163">Ainda de madrugada</segment>
    <segment id="164">, Carlos foi ao parque.</segment>
    <segment id="165">E recuperou das mãos da jovem uma nota de R$ 2 que ela usaria para pagar o ingresso do brinquedo que a matou.

- Ela estava com a mão fechadinha</segment>
    <segment id="166">, segurando o dinheiro.</segment>
    <segment id="167">O mais doloroso foi ver minha filha coberta por um plástico preto</segment>
    <segment id="168">, no chão - afirmou Carlos</segment>
    <segment id="169">, que se</segment>
    <segment id="170">se disse indignado com as más condições do parque.</segment>
    <segment id="171">- Encontrei brinquedos enferrujados e malconservados.</segment>
    <segment id="172">Infelizmente</segment>
    <segment id="173">, amanhã</segment>
    <segment id="174">, o parque vai sair de lá</segment>
    <segment id="175">, comprar outro brinquedo e matar outra criança.</segment>
    <segment id="176">Se houvesse uma fiscalização mais rígida e menos corrupta</segment>
    <segment id="177">, com certeza isso não teria acontecido.</segment>
    <segment id="178">A despeito da morte trágica</segment>
    <segment id="179">, ele fez questão de guardar a lembrança da menina de sorriso largo e estudiosa.</segment>
    <segment id="180">Carlos Augusto contou que a jovem estava na segunda série do ensino médio</segment>
    <segment id="181">, masmas já</segment>
    <segment id="182">sese preparava para ingressar na faculdade:

- O sonho dela era ser professora de espanhol e conhecer o México.</segment>
    <segment id="183">Eu me lembro dela cantando em casa as letras do grupo mexicano Rebelde.</segment>
    <segment id="184">Em julho</segment>
    <segment id="185">, ela terminou o curso de espanhol</segment>
    <segment id="186">, e estava toda feliz por isso.</segment>
    <segment id="187">Os pais da jovem eram separados e ela morava com Carlos.</segment>
    <segment id="188">Além dos três irmãos por parte de pai</segment>
    <segment id="189">, Alessandra tinha dois por parte de mãe.</segment>
    <segment id="190">A jovem será enterrada nesta segunda-feira</segment>
    <segment id="191">, no Cemitério de Inhaúma</segment>
    <segment id="192">, às 10h30</segment>
    <segment id="193">m.</segment>
    <segment id="194">Em 2009</segment>
    <segment id="195">, menino morreu eletrocutado

Parques de diversões já foram cenário de outros acidentes no Rio.</segment>
    <segment id="196">Em janeiro de 2009</segment>
    <segment id="197">, um menino de 10 anos morreu eletrocutado junto à grade de proteção de um brinquedo (miniaturas de caminhões) do Toy World</segment>
    <segment id="198">, em Bangu.</segment>
    <segment id="199">No ano anterior</segment>
    <segment id="200">, uma menina de 9 anos teve parte do couro cabeludo arrancada ao ficar presa</segment>
    <segment id="201">, por meia hora</segment>
    <segment id="202">, no brinquedo Roda-Estrela</segment>
    <segment id="203">, uma pequena roda-gigante no Philadelfia Park e Games</segment>
    <segment id="204">, no West Shopping</segment>
    <segment id="205">, em Campo Grande.</segment>
    <segment id="206">Em fevereiro de 2001</segment>
    <segment id="207">, ocorreram dois acidentes no Rio Water Planet</segment>
    <segment id="208">, em Vargem Grande: um teleférico caiu de uma altura de seis metros sobre pedras e brinquedos</segment>
    <segment id="209">, ferindo dez pessoas</segment>
    <segment id="210">, e um frequentador fraturou o tornozelo ao cair de um brinquedo.</segment>
    <segment id="211">O Terra Encantada</segment>
    <segment id="212">, na Barra da Tijuca</segment>
    <segment id="213">, também foi palco de acidentes.</segment>
    <segment id="214">O primeiro aconteceu pouco menos de um mês após a inauguração</segment>
    <segment id="215">, em janeiro de 1998</segment>
    <segment id="216">, quando a atriz Isis de Oliveira</segment>
    <segment id="217">sese machucou no Cabum</segment>
    <segment id="218">, principal atração do local.</segment>
    <segment id="219">Meses depois</segment>
    <segment id="220">, um homem foi atingido por um parafuso que</segment>
    <segment id="221">sese soltou do mesmo brinquedo.</segment>
    <segment id="222">Em agosto de 2005</segment>
    <segment id="223">, o vendedor Franck Ribeiro Sousa despencou da montanha-russa e foi parar na plataforma de embarque</segment>
    <segment id="224">, com traumatismo craniano.</segment>
    <segment id="225">O problema mais recente aconteceu no ano passado</segment>
    <segment id="226">, quando a ajudante de cozinha Heydiaria Lemos Ribeiro</segment>
    <segment id="227">, de 61 anos</segment>
    <segment id="228">, morreu ao cair de um carro da montanha-russa do parque.</segment>
    <segment id="229">COLABOROU</segment>
    <segment id="230">Natanael Damasceno</segment>
  </rst>
</analysis>