  <rst>
    <segment id="1">Perdas e danos:</segment>
    <segment id="2">será que foi tudo em vão?</segment>
    <segment id="3">RIO - Apesar da tragédia que arrasou a Região Serrana</segment>
    <segment id="4">, quase nada mudou na maneira</segment>
    <segment id="5">comocomo o poder público lida com a prevenção de catástrofes.</segment>
    <segment id="6">Este ano</segment>
    <segment id="7">, o orçamento da Secretaria estadual de Defesa Civil pretende destinar R$ 980 mil para o programa "prevenção de desastres".</segment>
    <segment id="8">Isso corresponde a apenas 1</segment>
    <segment id="9">,7% do total que deverá ser utilizado para ampliar o atendimento do órgão.</segment>
    <segment id="10">A secretaria alega que haverá mudanças no orçamento ao longo do ano e que esse programa será ampliado.</segment>
    <segment id="11">Se os recursos estaduais para este ano ainda são uma incógnita</segment>
    <segment id="12">, 2011 mostra</segment>
    <segment id="13">comocomo o governo federal tratou a questão.</segment>
    <segment id="14">No ano passado</segment>
    <segment id="15">, a União repassou ao Rio</segment>
    <segment id="16">, para obras de recuperação de cidades atingidas pelas chuvas</segment>
    <segment id="17">, um valor 80 vezes maior do que o enviado para projetos e serviços de prevenção</segment>
    <segment id="18">, dando a entender que remediar é melhor do que prevenir.</segment>
    <segment id="19">Planilhas obtidas pela ONG Contas Abertas</segment>
    <segment id="20">, junto ao sistema de acompanhamento financeiro da União</segment>
    <segment id="21">, mostram que foram repassados cerca de R$ 3</segment>
    <segment id="22">,7 milhões para sete municípios fluminenses dentro do programa "prevenção e preparação para desastres".</segment>
    <segment id="23">Um ano depois</segment>
    <segment id="24">, cenário da tragédia é quase o mesmo</segment>
    <segment id="25">Entre os beneficiados</segment>
    <segment id="26">, Barra Mansa foi o município que mais recebeu: R$ 2</segment>
    <segment id="27">,1 milhões.</segment>
    <segment id="28">Já no programa "resposta aos desastres e reconstrução"</segment>
    <segment id="29">, o governo repassou R$ 296 milhões para cidades fluminenses (80 vezes mais).</segment>
    <segment id="30">Friburgo ficou com a maior parte (R$ 10 milhões)</segment>
    <segment id="31">, seguida de Petrópolis (R$ 7</segment>
    <segment id="32">,3 milhões).</segment>
    <segment id="33">Embora os estragos do temporal de janeiro de 2011 expliquem em parte o grande volume de recursos destinados à reparação</segment>
    <segment id="34">, o cálculo per capita da verba para prevenção</segment>
    <segment id="35">mostra que o Estado do Rio recebeu pouco em comparação com outras unidades da federação.</segment>
    <segment id="36">Entre os que tiveram recursos desse programa (20 estados</segment>
    <segment id="37">, além do Distrito Federal)</segment>
    <segment id="38">, o Rio ficou na 16 posição</segment>
    <segment id="39">, com R$ 0</segment>
    <segment id="40">,23 por habitante</segment>
    <segment id="41">, à frente apenas de Minas Gerais (R$ 0</segment>
    <segment id="42">,14), Espírito Santo (R$ 0</segment>
    <segment id="43">,12), Goiás (R$ 0</segment>
    <segment id="44">,10) e Pará (R$ 0</segment>
    <segment id="45">,04).</segment>
    <segment id="46">Pernambuco</segment>
    <segment id="47">, reduto do ministro da Integração Nacional</segment>
    <segment id="48">, Fernando Bezerra</segment>
    <segment id="49">, conquistou o maior volume de recursos por habitante: R$ 3</segment>
    <segment id="50">,89.</segment>
    <segment id="51">Um ano depois da tragédia</segment>
    <segment id="52">, o governo federal corre atrás do prejuízo e pretende destinar R$ 81</segment>
    <segment id="53">,5 milhões ao Estado do Rio</segment>
    <segment id="54">, dentro do novo programa denominado "gestão de riscos e resposta a desastres".</segment>
    <segment id="55">Desta vez</segment>
    <segment id="56">, o valor é inferior apenas ao de São Paulo (R$ 89 milhões).</segment>
    <segment id="57">Nas cidades onde ocorreu a catástrofe</segment>
    <segment id="58">, a percepção é que pouco foi feito para reparar os danos e</segment>
    <segment id="59">, principalmente</segment>
    <segment id="60">, evitar novas tragédias.</segment>
    <segment id="61">Basta percorrer os bairros atingidos para</segment>
    <segment id="62">sese constatar que o cenário é praticamente o mesmo de um ano atrás.</segment>
    <segment id="63">Moradores dizem que</segment>
    <segment id="64">, após as primeiras semanas</segment>
    <segment id="65">, quando foram feitas ações de emergência</segment>
    <segment id="66">, as máquinas sumiram.</segment>
    <segment id="67">Os parques fluviais</segment>
    <segment id="68">, que teriam o objetivo de impedir a ocupação das margens dos rios</segment>
    <segment id="69">, não saíram do papel.</segment>
    <segment id="70">Os radares meteorológicos</segment>
    <segment id="71">, prometidos logo após a tragédia</segment>
    <segment id="72">, devem ser instalados somente em março.</segment>
    <segment id="73">De 2013.</segment>
    <segment id="74">O secretário do Ambiente</segment>
    <segment id="75">, Carlos Minc</segment>
    <segment id="76">, alega que o processo de compra do equipamento é complexo.</segment>
    <segment id="77">E diz que o o estado hoje está mais preparado para enfrentar as chuvas do que em 2011.

- As pessoas estão mais conscientes.</segment>
    <segment id="78">Dragamos os rios</segment>
    <segment id="79">, melhoramos o sistema de alerta de cheias.</segment>
    <segment id="80">E as equipes de Defesa Civil também estão mais preparadas.</segment>
    <segment id="81">Mas, na verdade</segment>
    <segment id="82">, nenhuma solução sozinha resolve o problema.</segment>
    <segment id="83">Pezão: "</segment>
    <segment id="84">Não temos o dinheiro do Japão"</segment>
    <segment id="85">O vice-governador Luiz Fernando Pezão</segment>
    <segment id="86">, que comandou o esforço de reconstrução da região desde os primeiros dias da tragédia</segment>
    <segment id="87">, diz que os atrasos nas obras</segment>
    <segment id="88">sese devem unicamente a entraves burocráticos:

-</segment>
    <segment id="89">As pessoas falam muito</segment>
    <segment id="90">, criticam</segment>
    <segment id="91">, dizem que nada foi feito.</segment>
    <segment id="92">Mas fizemos muita coisa.</segment>
    <segment id="93">Com R$ 49 milhões</segment>
    <segment id="94">, limpamos as cidades</segment>
    <segment id="95">, demos acesso</segment>
    <segment id="96">, melhoramos uma porção de estradas.</segment>
    <segment id="97">É claro que não fizemos estradas</segment>
    <segment id="98">comocomo no Japão</segment>
    <segment id="99">, porque</segment>
    <segment id="100">porque não temos o dinheiro do Japão</segment>
    <segment id="101">, nem temos a velocidade que a legislação deles permite.</segment>
    <segment id="102">Mas se</segment>
    <segment id="103">se você for lá hoje (na Serra)</segment>
    <segment id="104">, vai ver outra situação.</segment>
    <segment id="105">Já o secretário estadual de Defesa Civil</segment>
    <segment id="106">, coronel Sérgio Simões</segment>
    <segment id="107">, afirma que o trabalho de prevenção foi feito da melhor forma possível.</segment>
    <segment id="108">Ele lista uma série de ações</segment>
    <segment id="109">, como</segment>
    <segment id="110">como o mapeamento das áreas de risco geológico feito pelo Departamento de Recursos Minerais e a instalação de sirenes e pluviômetros em áreas vulneráveis.</segment>
    <segment id="111">Segundo ele</segment>
    <segment id="112">, o programa já cobre as 50 comunidades da Região Serrana com maior risco de desastre.

- A gente está fazendo um trabalho diferente de tudo o que foi feito até agora</segment>
    <segment id="113">, que é antecipar as ações - diz Simões.</segment>
    <segment id="114">A maior tragédia natural do país foi agravada pela negligência do homem.</segment>
    <segment id="115">Falhas em série</segment>
    <segment id="116">, desde a permissão para ocupação de áreas de risco até a falta coordenação entre as defesas civis</segment>
    <segment id="117">, impediram que as pessoas</segment>
    <segment id="118">sese preparassem para enfrentar a catástrofe.</segment>
    <segment id="119">As chuvas foram extraordinárias - nem mesmo os mais antigos relataram danos tão extremos -</segment>
    <segment id="120">masmas não inéditas</segment>
    <segment id="121">, diz a geógrafa Ana Luiza Coelho Netto</segment>
    <segment id="122">, professora da UFRJ e coordenadora do Laboratório de Geohidroecologia:

- Fenômenos desta magnitude</segment>
    <segment id="123">, ou maiores</segment>
    <segment id="124">, ocorreram num período recente da geomorfologia local - explica Ana Luiza.</segment>
    <segment id="125">- A ciência pode mapear as áreas de risco.</segment>
    <segment id="126">A intensidade das chuvas na serra foi recorde.</segment>
    <segment id="127">Em Friburgo</segment>
    <segment id="128">, em janeiro de 2011</segment>
    <segment id="129">, a quantidade chegou a ser 450% maior do que no mesmo período do ano anterior</segment>
    <segment id="130">, de acordo com a Coppe/UFRJ.</segment>
    <segment id="131">Ernani Nascimento</segment>
    <segment id="132">, professor de meteorologia da Universidade Federal de Santa Maria</segment>
    <segment id="133">, afirma que a situação foi agravada</segment>
    <segment id="134">porque</segment>
    <segment id="135">porque o solo já estava encharcado pelas chuvas dos dez dias anteriores:

- Com reduzida capacidade de infiltração</segment>
    <segment id="136">, a água escoou horizontalmente e</segment>
    <segment id="137">, por ser encosta</segment>
    <segment id="138">, em alta velocidade</segment>
    <segment id="139">, com grande poder destrutivo.</segment>
  </rst>
</analysis>