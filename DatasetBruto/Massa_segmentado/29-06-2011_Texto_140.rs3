  <rst>
    <segment id="1">Viúvas acendem fogueira</segment>
    <segment id="2">Costume ainda é revivido com alegria</segment>
    <segment id="3">, bom humor e rango para a galera
Quem pensa que</segment>
    <segment id="4">, após a perda dos maridos</segment>
    <segment id="5">, as mulheres</segment>
    <segment id="6">sese fecham para o mundo e vivem em luto eterno e a derramar lágrimas</segment>
    <segment id="7">, sese engana redondamente.</segment>
    <segment id="8">Se existe padroeiro dos solteiros</segment>
    <segment id="9">, dos namorados e dos casados</segment>
    <segment id="10">, as viúvas não poderiam ficar desprotegidas pelos santos.</segment>
    <segment id="11">Assim, as viúvas antigas</segment>
    <segment id="12">sese apegaram a São Pedro e  passaram a considerá-lo o  protetor da categoria.</segment>
    <segment id="13">Ainda que a tradição esteja mais fraca agora no século 21</segment>
    <segment id="14">, é possível encontrar viúvas que no dia 29 de junho acendem fogueiras para reviver tempos antigos.
Joana Pereira</segment>
    <segment id="15">, de 65 anos</segment>
    <segment id="16">, acende fogueira há 30 anos</segment>
    <segment id="17">, época em que seu marido faleceu.</segment>
    <segment id="18">“É costume da minha família do interior.</segment>
    <segment id="19">Vim para a cidade e continuei seguindo o  ritual”</segment>
    <segment id="20">, explica Joana.</segment>
    <segment id="21">Na Avenida Suburbana</segment>
    <segment id="22">, dona Railda Falck</segment>
    <segment id="23">, de 74 anos</segment>
    <segment id="24">, também mantém acesas as chamas da tradição.</segment>
    <segment id="25">“Eu perdi meu marido há mais de 20 anos.</segment>
    <segment id="26">No dia de São Pedro eu sempre preparo quitutes e reúno meus familiares para festejar à noite</segment>
    <segment id="27">, ao lado da fogueira”</segment>
    <segment id="28">, explicou.</segment>
    <segment id="29">Feijoada das boas</segment>
    <segment id="30">Um grupo de 24 viúvas e dois viúvos</segment>
    <segment id="31">, que vivem na Rua Amazonas</segment>
    <segment id="32">, em Paripe</segment>
    <segment id="33">, fez ontem uma festança regada a boa feijoada para homenagear São Pedro.</segment>
    <segment id="34">O evento já virou tradição no bairro e está completando 20 anos de realização.</segment>
    <segment id="35">Para organizar a festa</segment>
    <segment id="36">, cada morador colaborou com um quilo de feijão.</segment>
    <segment id="37">“</segment>
    <segment id="38">Esse ano a feijoada foi feita com vinte quilos de feijão.</segment>
    <segment id="39">Já teve ano que coloquei trinta!</segment>
    <segment id="40">Botamos a panela no meio da rua e todo mundo</segment>
    <segment id="41">sese serve”</segment>
    <segment id="42">, explica dona Maria Antônia</segment>
    <segment id="43">, organizadora.</segment>
  </rst>
</analysis>