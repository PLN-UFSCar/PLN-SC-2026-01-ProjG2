  <rst>
    <segment id="1">Atacante do Bahia vive dia de susto</segment>
    <segment id="2">Luciana</segment>
    <segment id="3">, mulher de Potita</segment>
    <segment id="4">, ГѓВ© baleada apГѓВіs ladrГѓВµes roubarem cliente de banco</segment>
    <segment id="5">Como se</segment>
    <segment id="6">se nГѓВЈo bastasse a mГѓВЎ fase que o Esporte Clube Bahia vem enfrentando</segment>
    <segment id="7">, o atacante da equipe</segment>
    <segment id="8">, Alessander Asloquer</segment>
    <segment id="9">, 25, o Potita</segment>
    <segment id="10">, levou um baita susto</segment>
    <segment id="11">, na tarde de ontem.</segment>
    <segment id="12">Luciana de FГѓВЎtima Rosa Maciel</segment>
    <segment id="13">, esposa de Potita</segment>
    <segment id="14">, foi atingida na perna por uma bala perdida.</segment>
    <segment id="15">Ela estava saindo do centro comercial Alpha Mall</segment>
    <segment id="16">, na Avenida Alphaville 1</segment>
    <segment id="17">, na Av. Paralela</segment>
    <segment id="18">, quando  foi surpreendida por uma troca de tiros entre  dois  homens</segment>
    <segment id="19">, que fugiam em uma moto</segment>
    <segment id="20">, e seguranГѓВ§as do Banco Santander.</segment>
    <segment id="21">Ela mora no CondomГѓВ­nio Le Parc - prГѓВіximo ao local do crime.</segment>
    <segment id="22">Momentos antes</segment>
    <segment id="23">, a dupla havia assaltado um casal de empresГѓВЎrios</segment>
    <segment id="24">, que foi ГѓВ  agГѓВЄncia fazer um depГѓВіsito.</segment>
    <segment id="25">Os ladrГѓВµes conseguiram levar R$ 15 mil.</segment>
    <segment id="26">Eles tinham pego o dinheiro no Banco ItaГѓВє do ImbuГѓВ­ e foram lГѓВЎ depositar.</segment>
    <segment id="27">Estavam com R$ 25 mil</segment>
    <segment id="28">, masmas eles [os ladrГѓВµes] sГѓВі conseguiram levar R$ 15 mil.</segment>
    <segment id="29">O restante estava na cintura do rapaz</segment>
    <segment id="30">, diz ACM dos Santos</segment>
    <segment id="31">, titular da Delegacia de ItapuГѓВЈ</segment>
    <segment id="32">, onde o crime foi registrado.</segment>
    <segment id="33">Conforme o delegado</segment>
    <segment id="34">, Luciana foi levada ao Hospital SГѓВЈo Rafael</segment>
    <segment id="35">, pelo ServiГѓВ§o de Atendimento MГѓВіvel de UrgГѓВЄncia (Samu)</segment>
    <segment id="36">, masmas jГѓВЎ teve alta e passa bem.</segment>
    <segment id="37">Bandidos ligados no casal
Potita nГѓВЈo estava com Luciana quando ela foi atingida.</segment>
    <segment id="38">Ele foi prestar apoio apГѓВіs saber do ocorrido.</segment>
    <segment id="39">Para o delegado</segment>
    <segment id="40">, hГѓВЎ a suspeita de que os homens jГѓВЎ estavam seguindo o casal.</segment>
    <segment id="41">No mГѓВ­nimo</segment>
    <segment id="42">, foram trГѓВЄs elementos.</segment>
    <segment id="43">Dois em uma moto e outro em um VW</segment>
    <segment id="44">Corsa prata.</segment>
    <segment id="45">Ele informou que aguarda Luciana para prestar esclarecimentos.</segment>
    <segment id="46">O delegado disse que os seguranГѓВ§as do banco - funcionГѓВЎrios da empresa Prosegur -</segment>
    <segment id="47">, jГѓВЎ foram ouvidos e as armas deles foram apreendidas para perГѓВ­cia.</segment>
    <segment id="48">CГѓВўmeras de seguranГѓВ§a da agГѓВЄncia</segment>
    <segment id="49">, do centro comercial e da avenida 1 foram recolhidas para anГѓВЎlise.</segment>
    <segment id="50">AtГѓВ© a noite</segment>
    <segment id="51">, nenhum suspeito foi preso.</segment>
    <segment id="52">Galera fica assustada</segment>
    <segment id="53">Quando o carro parou</segment>
    <segment id="54">, o cara da moto desceu e falou ao motorista:</segment>
    <segment id="55">Гўв‚¬Е“Me dГѓВЄ esse dinheiro que estГѓВЎ dentro de sua calГѓВ§aГўв‚¬в„ўГўв‚¬</segment>
    <segment id="56">, diz uma testemunha.</segment>
    <segment id="57">Segundo o presidente da AssociaГѓВ§ГѓВЈo Alphaville Empresarial</segment>
    <segment id="58">, Alex Fialho</segment>
    <segment id="59">, esta ГѓВ© a segunda vez</segment>
    <segment id="60">, em oito meses</segment>
    <segment id="61">, que clientes do banco sГѓВЈo assaltados.</segment>
    <segment id="62">Гўв‚¬Е“Essa mesma situaГѓВ§ГѓВЈo</segment>
    <segment id="63">, entradinha bancГѓВЎriaГўв‚¬. Assustada e revoltada</segment>
    <segment id="64">, Valdelice de Jesus</segment>
    <segment id="65">, cliente da agГѓВЄncia</segment>
    <segment id="66">, relatou que no momento do assalto</segment>
    <segment id="67">, ela estava do lado de fora  aguardando o filho que estava no banco.</segment>
    <segment id="68">O carro dela</segment>
    <segment id="69">, um Renault Duster prata</segment>
    <segment id="70">, foi atingido.</segment>
    <segment id="71">A bala entrou pelo vidro do motorista e</segment>
    <segment id="72">sese alojou no banco traseiro.</segment>
    <segment id="73">Гўв‚¬Е“NГѓВЈo entendi</segment>
    <segment id="74">porque</segment>
    <segment id="75">porque o seguranГѓВ§a</segment>
    <segment id="76">sese manisfestou.</segment>
    <segment id="77">Foi ele quem atirouГўв‚¬</segment>
    <segment id="78">, afirma.</segment>
    <segment id="79">Segundo a assessoria do Bahia</segment>
    <segment id="80">, no momento do fato</segment>
    <segment id="81">, Potita nГѓВЈo estava no treino.</segment>
    <segment id="82">Гўв‚¬Е“O atleta estГѓВЎ acompanhado a esposa.</segment>
    <segment id="83">O clube estГѓВЎ dando todo o apoioГўв‚¬.</segment>
  </rst>
