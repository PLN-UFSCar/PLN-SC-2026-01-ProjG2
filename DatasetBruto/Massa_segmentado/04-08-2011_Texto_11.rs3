  <rst>
    <segment id="1">Triplo assassinato abala a rua da Paz</segment>
    <segment id="2">Policiais acreditam que crime está relacionado ao tráfico de drogas</segment>
    <segment id="3">Um triplo assassinato deixou os moradores da Rua da Paz Coqueiro Grande</segment>
    <segment id="4">, em Jaguaripe 1</segment>
    <segment id="5">, nas imediações do bairro de Cajazeira 10</segment>
    <segment id="6">, em pânico.</segment>
    <segment id="7">As vítimas</segment>
    <segment id="8">, Idelmar Mota Bonfim</segment>
    <segment id="9">, 18, e seu cunhado</segment>
    <segment id="10">, Robson Santana da Silva</segment>
    <segment id="11">, foram executados dentro de casa por volta das 2h30 da madrugada de ontem.</segment>
    <segment id="12">A terceira vítima</segment>
    <segment id="13">, o adolescente I.M.B</segment>
    <segment id="14">, de 17 anos (irmão de Idelmar)</segment>
    <segment id="15">, foi socorrido ainda com vida por policiais da 3ª Companhia Independente da Polícia Militar (CIPM) de Cajazeiras e levado para o Hospital Eládio Lasserre</segment>
    <segment id="16">, masmas não resistiu aos ferimentos e morreu por volta das 5 horas da manhã.</segment>
    <segment id="17">As únicas testemunhas do crime são uma criança de cinco anos e sua mãe</segment>
    <segment id="18">, de prenome Daiane</segment>
    <segment id="19">, que era esposa de Robson e irmã das outras duas vítimas.</segment>
    <segment id="20">Segundo informações preliminares do Departamento de Homicídios e Proteção à Pessoa (DHPP)</segment>
    <segment id="21">, cinco homens armados invadiram a casa onde eles moravam e fizeram vários disparos com pistola 380.</segment>
    <segment id="22">Os três rapazes moravam em casas separadas.</segment>
    <segment id="23">Robson vivia com a esposa Daiane e o menino</segment>
    <segment id="24">, que é filho dela com outro homem</segment>
    <segment id="25">, no andar térreo.</segment>
    <segment id="26">Idelmar e o menor I.M.B. ocupavam as duas casas construídas no andar de cima.</segment>
    <segment id="27">Sem querer revelar o nome</segment>
    <segment id="28">, o ex marido de Daiane</segment>
    <segment id="29">, que mora na mesma rua</segment>
    <segment id="30">, disse que “é possível que os crimes estejam relacionados ao tráfico de drogas.</segment>
    <segment id="31">No dia a dia</segment>
    <segment id="32">, eles eram pessoas tranquilas</segment>
    <segment id="33">, sese comunicavam normalmente com a vizinhança</segment>
    <segment id="34">, masmas usavam drogas”</segment>
    <segment id="35">, reiterou sem revelar nomes.</segment>
    <segment id="36">Adolescente ajudava o pai

Três  vizinhas dos irmãos executados recolheram as roupas e outros pertences das vítimas</segment>
    <segment id="37">, a pedido do pai</segment>
    <segment id="38">, o mestre de obras Ideraldo da Silva Bonfim.</segment>
    <segment id="39">Ele confirmou que o filho mais velho</segment>
    <segment id="40">, Idelmar</segment>
    <segment id="41">, era usuário de drogas</segment>
    <segment id="42">, masmas negou que o menor usava entorpecentes.</segment>
    <segment id="43">“</segment>
    <segment id="44">O de 17 anos trabalhava comigo</segment>
    <segment id="45">comocomo ajudante de pedreiro.</segment>
    <segment id="46">Hoje de manhã (ontem) percebi que ele faltou ao trabalho e quando estava quase chegando aqui para buscá-lo soube do assassinato”</segment>
    <segment id="47">, informou o pai ainda muito abalado.</segment>
    <segment id="48">Com lágrimas nos olhos</segment>
    <segment id="49">, seu Ideraldo lamentou não ter dado  adeus aos filhos.</segment>
    <segment id="50">Rolou baculejo...</segment>
    <segment id="51">Segundo a polícia</segment>
    <segment id="52">, o alvo teria sido Idelmar</segment>
    <segment id="53">, que era usuário de drogas.</segment>
    <segment id="54">Vizinhos</segment>
    <segment id="55">, que não quiseram</segment>
    <segment id="56">sese identificar</segment>
    <segment id="57">, levantaram a hipótese de o outro irmão ter morrido por ter presenciado a execução e o cunhado por ter  tentado socorrê-los.</segment>
    <segment id="58">“</segment>
    <segment id="59">Embora nenhum dos três tenha antecedentes criminais</segment>
    <segment id="60">, a linha de investigação será o tráfico de drogas”</segment>
    <segment id="61">, explica o delegado do Departamento de Homicídios (DH)</segment>
    <segment id="62">, Márcio Alan.</segment>
    <segment id="63">Ele adiantou que durante a perícia técnica realizada nas casas  foi encontrado um caderno com anotações de possíveis compradores de drogas.</segment>
    <segment id="64">“</segment>
    <segment id="65">Provavelmente</segment>
    <segment id="66">, o local funcionava</segment>
    <segment id="67">comocomo boca de fumo</segment>
    <segment id="68">, masmas isso só poderá ser confirmado  depois que a irmã deles prestar depoimento.</segment>
    <segment id="69">Ela ainda está muito abalada”</segment>
    <segment id="70">, salientou o delegado Márcio Alan.</segment>
  </rst>
</analysis>