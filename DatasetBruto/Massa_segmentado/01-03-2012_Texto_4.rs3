  <rst>
    <segment id="1">Bando toca terror em Amargosa
Quadrilha assalta duas agências bancárias</segment>
    <segment id="2">, faz reféns e joga dinheiro para cima</segment>
    <segment id="3">As agências do Banco do Brasil e Bradesco do município de Amargosa (a 235 km de Salvador) foram assaltadas ao mesmo tempo por volta das 11h de ontem (29).</segment>
    <segment id="4">Cerca de 20 homens fortemente armados e encapuzados</segment>
    <segment id="5">, com luvas</segment>
    <segment id="6">, roupas do Exército e coletes à prova de bala chegaram em dois carros roubados</segment>
    <segment id="7">, uma Toyota Hilux prata e um Crossfox preto.</segment>
    <segment id="8">Divididos</segment>
    <segment id="9">, eles invadiram as agências e fizeram clientes e funcionários dos dois bancos reféns.</segment>
    <segment id="10">Antes da fuga</segment>
    <segment id="11">, os bandidos atiraram em uma viatura da Polícia Civil</segment>
    <segment id="12">, furando os pneus.</segment>
    <segment id="13">O pânico</segment>
    <segment id="14">sese instalou nas imediações da Praça Lourival Monte</segment>
    <segment id="15">, no centro da cidade</segment>
    <segment id="16">, no momento da ação</segment>
    <segment id="17">, que durou uma hora.</segment>
    <segment id="18">Segundo populares</segment>
    <segment id="19">, os bandidos dispararam tiros para o alto</segment>
    <segment id="20">, quebrando as câmeras do sistema de segurança instaladas na praça e nas portas giratórias dos bancos.</segment>
    <segment id="21">Ninguém</segment>
    <segment id="22">sese feriu.</segment>
    <segment id="23">Esta é a terceira vez que o Banco do Brasil é assaltado</segment>
    <segment id="24">, sendo duas no ano passado.</segment>
    <segment id="25">O Bradesco foi a segunda.</segment>
    <segment id="26">Clientes e funcionários</segment>
    <segment id="27">sese jogaram ao chão.</segment>
    <segment id="28">Sete pessoas do Banco do Brasil e quatro do Bradesco</segment>
    <segment id="29">, incluindo clientes</segment>
    <segment id="30">, gerentes</segment>
    <segment id="31">, seguranças e funcionários</segment>
    <segment id="32">, foram  levados</segment>
    <segment id="33">comocomo reféns e libertados   horas depois.</segment>
    <segment id="34">Pânico na cidade</segment>
    <segment id="35">Eles chegaram com tudo</segment>
    <segment id="36">, tocando terror.</segment>
    <segment id="37">O primeiro carro usado pelos bandidos foi incendiado em frente ao Banco do Brasil levando pânico aos populares.</segment>
    <segment id="38">Parte do comércio localizado nas imediações das agências fechou as portas.</segment>
    <segment id="39">Na saída</segment>
    <segment id="40">, o bando ainda jogou dinheiro para o alto e em direção das pessoas que</segment>
    <segment id="41">sese arriscavam a ficar por perto</segment>
    <segment id="42">, aumentando o alvoroço na praça e provocando ainda mais confusão.</segment>
    <segment id="43">Segundo informações do delegado titular da cidade</segment>
    <segment id="44">, Wagner Marinho</segment>
    <segment id="45">, até o final da tarde de ontem não havia pistas sobre a quadrilha.</segment>
    <segment id="46">“Estamos com reforço das coordenadorias do interior de Valença</segment>
    <segment id="47">, Jequié e Santo Antônio de Jesus</segment>
    <segment id="48">, da Polícia Militar da região e com um helicóptero da PM de Feira de Santana</segment>
    <segment id="49">, além de equipes do Grupo de Apoio ao Combate a Instituições Financeiras (GACIF).</segment>
    <segment id="50">Bloqueamos as estradas do Vale do Jiquiriçá na tentativa de capturar os assaltantes</segment>
    <segment id="51">, masmas ainda não há suspeitos ou pistas”</segment>
    <segment id="52">, disse.</segment>
    <segment id="53">Fogo na praça</segment>
    <segment id="54">O empresário Adalberto Barreto teve a caminhonete Hilux levada pelo bando.</segment>
    <segment id="55">“Eu chegava à agência quando oito homens encapuzados</segment>
    <segment id="56">, que estavam na porta</segment>
    <segment id="57">, me abordaram.</segment>
    <segment id="58">Pegaram o carro  para fugir com os reféns e depois a queimaram”</segment>
    <segment id="59">, lamentou.</segment>
    <segment id="60">O casal Tim e Eronilda dos Santos  estava apavorado.</segment>
    <segment id="61">O filho deles</segment>
    <segment id="62">, Claudio Alberto dos Santos</segment>
    <segment id="63">, foi um dos reféns.</segment>
    <segment id="64">“</segment>
    <segment id="65">Meu filho nasceu de novo</segment>
    <segment id="66">, graças a Deus”</segment>
    <segment id="67">, contou a dona de casa.</segment>
    <segment id="68">Segundo os  seguranças das agências</segment>
    <segment id="69">,  os bandidos usavam armas de grosso calibre.</segment>
  </rst>
</analysis>