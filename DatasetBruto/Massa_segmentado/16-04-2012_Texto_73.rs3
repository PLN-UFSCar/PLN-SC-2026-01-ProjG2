  <rst>
    <segment id="1">Morte de estudante ainda é mistério</segment>
    <segment id="2">Vítima era filho de PM lotado na Casa Militar.</segment>
    <segment id="3">Amigos suspeitam de ritual macabro</segment>
    <segment id="4">Durante o enterro do fotógrafo e estudante de administração do Ifba</segment>
    <segment id="5">, Marcelo Araújo dos Santos</segment>
    <segment id="6">, 28 anos</segment>
    <segment id="7">, ontem</segment>
    <segment id="8">, no Cemitério Campo Santo</segment>
    <segment id="9">, parentes e amigos do jovem ainda buscavam explicações sobre o que pode ter motivado o brutal assassinato do rapaz.</segment>
    <segment id="10">O corpo de Marcelo foi encontrado boiando</segment>
    <segment id="11">, em um esgoto</segment>
    <segment id="12">, no bairro Costa Azul</segment>
    <segment id="13">, na manhã do último sábado.</segment>
    <segment id="14">O cadáver estava com um corte profundo no pescoço e marcas de agressões no rosto.</segment>
    <segment id="15">Amigos de Marcelo rebatem a suspeita de que o estudante possa ter sido vítima de roubo seguido de morte (latrocínio)</segment>
    <segment id="16">, pois</segment>
    <segment id="17">pois o celular e a carteira com dinheiro não foram levados pelos assassinos.</segment>
    <segment id="18">No dia do crime</segment>
    <segment id="19">, Marcelo também não estava com a câmera fotográfica profissional</segment>
    <segment id="20">, que foi encontrada pela mãe dele</segment>
    <segment id="21">, na madrugada de ontem</segment>
    <segment id="22">, dentro do guarda-roupa.</segment>
    <segment id="23">Suspeita de ritual macabro</segment>
    <segment id="24">Segundo os amigos</segment>
    <segment id="25">, Marcelo foi encontrar alguns colegas</segment>
    <segment id="26">, no Campo Grande</segment>
    <segment id="27">, na última sexta-feira.</segment>
    <segment id="28">Durante o enterro</segment>
    <segment id="29">, alguns amigos especularam que Marcelo pode ter sido morto em um ritual de magia negra</segment>
    <segment id="30">, em plena sexta-feira 13</segment>
    <segment id="31">, masmas não souberam precisar quem poderia ser o assassino.</segment>
    <segment id="32">A polícia não divulgou detalhes das investigações sobre o</segment>
    <segment id="33">casocaso.</segment>
  </rst>
</analysis>