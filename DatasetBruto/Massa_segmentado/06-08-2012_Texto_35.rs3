  <rst>
    <segment id="1">Caminhoneiro busca amada</segment>
    <segment id="2">Caminhoneiro busca amada</segment>
    <segment id="3">Quem anda por Salvador nota que os trabalhadores informais usam postes</segment>
    <segment id="4">, muros e meio fios  para divulgar seus telefones para trabalho.</segment>
    <segment id="5">Com o carreteiro apaixonado do muro do  Cabula nГѓВЈo foi diferente.</segment>
    <segment id="6">SГѓВі  que ele nГѓВЈo pede  emprego e sim uma mulher Гўв‚¬Е“sangue bomГўв‚¬. MASSA!</segment>
    <segment id="7">ligou para ele (8887-8683 ) com o intuito de  ajudГѓВЎ-lo.</segment>
    <segment id="8">Гўв‚¬Е“A propaganda</segment>
    <segment id="9">ГѓВ© a alma do negГѓВіcio.</segment>
    <segment id="10">Eu jГѓВЎ recebia ligaГѓВ§ГѓВµes para trabalho e por que nГѓВЈo encontrar minha parceira da mesma forma?Гўв‚¬</segment>
    <segment id="11">, argumenta Anderson Silva</segment>
    <segment id="12">, 32, que chega a receber 20 ligaГѓВ§ГѓВµes por dia.</segment>
    <segment id="13">Гўв‚¬Е“Converso bastante com elas</segment>
    <segment id="14">, masmas ainda nГѓВЈo sei quem  vou conhecerГўв‚¬.</segment>
    <segment id="15">As ligaГѓВ§ГѓВµes sГѓВЈo de  jovens e coroas interessadas em algo sГѓВ©rio.</segment>
    <segment id="16">Гўв‚¬Е“Procuro uma mulher para casar.</segment>
    <segment id="17">E  que honre a alianГѓВ§a que eu colocar no dedoГўв‚¬</segment>
    <segment id="18">, sonha.</segment>
    <segment id="19">Ele</segment>
    <segment id="20">Гѓ</segment>
    <segment id="21">В© cheio de graГѓВ§a!</segment>
    <segment id="22">O carreteiro Anderson Silva ГѓВ© um homem de muitas posses.</segment>
    <segment id="23">Em seu anГѓВєncio</segment>
    <segment id="24">, ele informa possuir carro e casa para chamar atenГѓВ§ГѓВЈo da mulherada.</segment>
    <segment id="25">Mas garante que sГѓВі fez propaganda</segment>
    <segment id="26">porque</segment>
    <segment id="27">porque as mulheres gostam de homens com posses Гўв‚¬вЂњ nГѓВЈo que elas sejam interesseiras</segment>
    <segment id="28">, masmas isso dГѓВЎ seguranГѓВ§a para o casal.</segment>
    <segment id="29">Quanto ГѓВ s ligaГѓВ§ГѓВµes</segment>
    <segment id="30">, Anderson ouve a conversa delas</segment>
    <segment id="31">, masmas garante:</segment>
    <segment id="32">Гўв‚¬Е“SГѓВі vou comeГѓВ§ar a acreditar nelas quando eu conhecer.</segment>
    <segment id="33">Quero que seja tudo verdadeГўв‚¬.</segment>
    <segment id="34">A mГѓВЈe dele mora em CoraГѓВ§ГѓВЈo de Maria</segment>
    <segment id="35">, a 105 km de Salvador.</segment>
    <segment id="36">EvangГѓВ©lica</segment>
    <segment id="37">, ela acredita que o filho vai conseguir encontrar uma pessoa direita e que sua nora vai amar bastante seu filho.</segment>
    <segment id="38">Гўв‚¬Е“Ela acha que sou doido</segment>
    <segment id="39">, masmas acredita que todo doido dГѓВЎ certo na vida e que eu vou conseguirГўв‚¬</segment>
    <segment id="40">, conta o romГѓВўntico Anderson.</segment>
