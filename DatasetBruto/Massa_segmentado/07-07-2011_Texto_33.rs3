  <rst>
    <segment id="1">Pé no traseiro</segment>
    <segment id="2">Após sair do Tchan</segment>
    <segment id="3">, Karol é dispensada de peça</segment>
    <segment id="4">A direção do espetáculo infantil “</segment>
    <segment id="5">O Casamento de Dona Baratinha”</segment>
    <segment id="6">, em cartaz</segment>
    <segment id="7">no Rio de Janeiro</segment>
    <segment id="8">, não gostou nada das fotos que a ex-loira do É o Tchan</segment>
    <segment id="9">, Karol Loren</segment>
    <segment id="10">, fez para a seção Happy Hour</segment>
    <segment id="11">, da revista “Playboy” de julho.</segment>
    <segment id="12">A loira causou um mal-estar ao usar o nome da peça e ainda ao dizer que recebe olhadas diferentes de alguns pais que vão ao espetáculo.</segment>
    <segment id="13">“Ela não tinha autorização para usar o nome do espetáculo daquela maneira</segment>
    <segment id="14">, dizer que recebe olhares de pais e expor a companhia desse jeito.</segment>
    <segment id="15">As pessoas podem achar que não somos sérios.</segment>
    <segment id="16">Ela será substituída pela atriz Amanda Gallo nas próximas apresentações”</segment>
    <segment id="17">, disse a assessoria da peça ao site Ego.</segment>
    <segment id="18">Já a assessoria de Karol não entendeu a polêmica.</segment>
    <segment id="19">"</segment>
    <segment id="20">Ela assinou contrato para fazer uma participação especial em quatro sessões.</segment>
    <segment id="21">Ela cumpriu esse contrato e estava livre para fazer outros trabalhos"</segment>
    <segment id="22">, falou a assessoria acrescentando que a loira já está negociando um novo trabalho para atuar.</segment>
  </rst>
