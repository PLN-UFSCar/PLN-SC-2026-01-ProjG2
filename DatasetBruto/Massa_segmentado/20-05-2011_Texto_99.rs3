  <rst>
    <segment id="1">Gasto com dengue cresce 68% em rede privada</segment>
    <segment id="2">RIO - Com o início da redução do número de casos de dengue no Rio</segment>
    <segment id="3">, a rede particular de saúde começa a contabilizar os números da doença referentes a custos com internações e atendimentos de emergência.</segment>
    <segment id="4">Somente a Unimed-Rio</segment>
    <segment id="5">, que conta com 86 hospitais credenciados</segment>
    <segment id="6">, estima que</segment>
    <segment id="7">, até o momento</segment>
    <segment id="8">, o custo com internações por dengue - cujo valor médio ficou mais alto - tenha ultrapassado R$ 1</segment>
    <segment id="9">,6 milhão</segment>
    <segment id="10">, superando em quase 68% o ano anterior (aproximadamente R$ 956 mil).</segment>
    <segment id="11">Enquanto em 2010 foram 530 internações na rede da Unimed-Rio</segment>
    <segment id="12">, este ano já foram contabilizados 822 apenas nos quatro primeiros meses.
MAPA: Casos de dengue no município do Rio em 2011</segment>
    <segment id="13">A Rede D'Or não apresentou os gastos de sua rede com o atendimentos aos pacientes com dengue.</segment>
    <segment id="14">Segundo a sua assessoria de comunicação social</segment>
    <segment id="15">, a gravidade dos casos da doença atendidos por seus hospitais não é alta e</segment>
    <segment id="16">, com isso</segment>
    <segment id="17">, o custo é baixo para as unidades.</segment>
    <segment id="18">No Copa D'Or</segment>
    <segment id="19">, de janeiro até meados de abril</segment>
    <segment id="20">, foram atendidos 450 pacientes</segment>
    <segment id="21">, sendo 20% deles crianças.</segment>
    <segment id="22">No Quinta D'Or</segment>
    <segment id="23">, em São Cristóvão</segment>
    <segment id="24">, a média de atendimentos foi a mesma.</segment>
    <segment id="25">A Unimed-Rio tem um Pronto Atendimento na Barra da Tijuca que é referência da rede para o atendimento a pacientes com dengue na Zona Oeste.</segment>
    <segment id="26">Segundo o hospital</segment>
    <segment id="27">, um análise dos dados deste mês mostra que houve uma queda no número de casos suspeitos.</segment>
    <segment id="28">Até o último dia 16</segment>
    <segment id="29">, foram emitidas 47 notificações à Secretaria municipal de Saúde</segment>
    <segment id="30">, número que projeta uma redução em relação ao consolidado de abril.</segment>
    <segment id="31">No mês passado</segment>
    <segment id="32">, foram 172 notificações - a maior incidência no ano.</segment>
    <segment id="33">Ao longo deste ano</segment>
    <segment id="34">, 492 notificações foram feitas.</segment>
    <segment id="35">A direção ressaltou que</segment>
    <segment id="36">, mesmo que o paciente não esteja comprovadamente com dengue</segment>
    <segment id="37">, os casos suspeitos são notificados ao Centro Municipal de Saúde Harvey Ribeiro de Souza</segment>
    <segment id="38">, no Recreio dos Bandeirantes</segment>
    <segment id="39">, que os encaminha à prefeitura.</segment>
    <segment id="40">Os médicos do Pronto Atendimento costumam dizer aos pacientes que retornem</segment>
    <segment id="41">, para que</segment>
    <segment id="42">para que o seu</segment>
    <segment id="43">casocaso seja acompanhado.</segment>
  </rst>
</analysis>