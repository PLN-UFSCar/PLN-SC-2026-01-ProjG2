  <rst>
    <segment id="1">Criminosos bem vestidos atacam linhas especiais
RIO - Apesar da redução em 24</segment>
    <segment id="2">,36% dos casos de roubo em coletivo registrados no estado nos primeiro semestre
 segundo o Instituto de Segurança Pública do Rio</segment>
    <segment id="3">, o sequestro ao coletivo da Viação Jurema revelou uma prática que ocorre principalmente com os ônibus especiais de viações que atravessam vias expressas</segment>
    <segment id="4">comocomo a Avenida Brasil</segment>
    <segment id="5">, a Ponte Rio-Niterói e as linhas Amarela e Vermelha.</segment>
    <segment id="6">Os assaltantes chegam bem vestidos</segment>
    <segment id="7">, pagam a passagem e só anunciam o assalto quando o veículo está na linha expressa ou próximo dela.</segment>
    <segment id="8">Na quarta-feira</segment>
    <segment id="9">, um dia depois do ataque</segment>
    <segment id="10">, no horário do rush da tarde</segment>
    <segment id="11">, às 18h</segment>
    <segment id="12">, o ônibus da Jurema para Caxias deixou o ponto final da Praça Quinze com apenas cinco passageiros</segment>
    <segment id="13">, numa clara reação da população ao terror da véspera.</segment>
    <segment id="14">Os poucos passageiros que</segment>
    <segment id="15">sese arriscaram a pegar ônibus neste horário contaram outras histórias de violência.</segment>
    <segment id="16">Na linha Castelo-Caxias</segment>
    <segment id="17">, um homem que</segment>
    <segment id="18">sese identificou</segment>
    <segment id="19">comocomo Santos contou que foi assaltado três vezes:

- Em duas das vezes em que fui assaltado</segment>
    <segment id="20">, reconheci um mesmo assaltante.</segment>
    <segment id="21">Na segunda vez</segment>
    <segment id="22">, a ousadia dele foi tanta que ele chegou a pedir calma aos passageiros e dizer que talvez até o conhecêssemos.</segment>
    <segment id="23">Na linha sequestrada na noite de terça-feira</segment>
    <segment id="24">, Praça Quinze-Caxias</segment>
    <segment id="25">, da Viação Jurema</segment>
    <segment id="26">, passageiros contam que os assaltos são frequentes.</segment>
    <segment id="27">Há cerca de um ano</segment>
    <segment id="28">, uma vendedora que</segment>
    <segment id="29">sese identificou apenas</segment>
    <segment id="30">comocomo Marcele contou quando três bandidos armados anunciaram um assalto</segment>
    <segment id="31">, próximo à entrada de Caxias:

- Foram cerca de 20 minutos de pânico.</segment>
    <segment id="32">Ameaçaram os passageiros e agiram agressivamente.</segment>
    <segment id="33">Depoimento de leitores enviados ao site do GLOBO revelam que a prática criminosa já é rotina:</segment>
    <segment id="34">"</segment>
    <segment id="35">Fui assaltada há um mês no ônibus da linha 1136 (Campo Grande-Cascadura).</segment>
    <segment id="36">Quatro homens entraram na altura da prefeitura (Cidade Nova)</segment>
    <segment id="37">, três dias antes de outro assalto</segment>
    <segment id="38">, também na altura do prédio.</segment>
    <segment id="39">Foram quase três horas com os assaltantes"</segment>
    <segment id="40">, contou Thaysa Tamiozo dos Santos.</segment>
  </rst>
