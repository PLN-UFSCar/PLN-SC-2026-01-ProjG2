  <rst>
    <segment id="1">Pai de santo assassinado sofria ameaças</segment>
    <segment id="2">O pai de santo Marques de Jesus Santos</segment>
    <segment id="3">, 28 anos</segment>
    <segment id="4">, foi assassinado dentro de casa</segment>
    <segment id="5">O pai de santo Marques de Jesus Santos</segment>
    <segment id="6">, 28 anos</segment>
    <segment id="7">, foi assassinado dentro de casa</segment>
    <segment id="8">, na noite da última quarta-feira</segment>
    <segment id="9">, na cidade de Eunápolis (a 671 km de Salvador).</segment>
    <segment id="10">Um irmão da vítima contou que ele vinha sendo ameaçado de morte</segment>
    <segment id="11">, masmas não sabe o motivo.</segment>
    <segment id="12">Um amigo e uma cunhada de  Marques</segment>
    <segment id="13">, que também moram na casa</segment>
    <segment id="14">, conseguiram fugir pelos fundos.</segment>
    <segment id="15">Eles contaram à polícia que Marques</segment>
    <segment id="16">, que já estava dormindo</segment>
    <segment id="17">, sese assustou com o barulho e ainda</segment>
    <segment id="18">sese escondeu embaixo da cama (foto)</segment>
    <segment id="19">, masmas os bandidos puxaram o colchão e o executaram com um tiro na cabeça.</segment>
    <segment id="20">A casa ficou toda revirada.</segment>
    <segment id="21">Os assassinos quebraram várias imagens de santo que estavam num altar.</segment>
  </rst>
