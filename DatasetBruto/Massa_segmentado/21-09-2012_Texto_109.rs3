  <rst>
    <segment id="1">Mais um barraco no pagodГѓВЈo
Rolou fuzuГѓВЄ entre vocalista e produГѓВ§ГѓВЈo do BastiГѓВЈo Fest</segment>
    <segment id="2">O bicho pegou na 7Г‚ВЄ ediГѓВ§ГѓВЈo do BastiГѓВЈo Fest</segment>
    <segment id="3">, em SГѓВЈo SebastiГѓВЈo do PassГѓВ©.</segment>
    <segment id="4">A confusГѓВЈo</segment>
    <segment id="5">, que teve inГѓВ­cio por conta do atraso da banda Guettho ГѓВ© Guettho</segment>
    <segment id="6">, deixou muita gente nervosa no ГѓВєltimo sГѓВЎbado</segment>
    <segment id="7">, 15.</segment>
    <segment id="8">De acordo com Levi Palagani</segment>
    <segment id="9">, produtor da festa</segment>
    <segment id="10">, o lГѓВ­der do grupo</segment>
    <segment id="11">, Chiclete</segment>
    <segment id="12">, chegou atrasado e comeГѓВ§ou a colocar o pГѓВєblico contra a organizaГѓВ§ГѓВЈo do evento.</segment>
    <segment id="13">A galera ficou nervosa e comeГѓВ§aram a surgir brigas na plateia.</segment>
    <segment id="14">Гўв‚¬Е“O contrato prevГѓВЄ multa por atraso.</segment>
    <segment id="15">O show estava marcado para 3h e eles chegaram</segment>
    <segment id="16">ГѓВ s 6h.</segment>
    <segment id="17">Subiram ao palco e</segment>
    <segment id="18">, na 2Г‚ВЄ mГѓВєsica</segment>
    <segment id="19">, Chiclete pegou o microfone e disse que sГѓВі estava lГѓВЎ por causa dos fГѓВЈs</segment>
    <segment id="20">, jГѓВЎ que nГѓВЈo estava sendo pago.</segment>
    <segment id="21">Cantou 25 minutos e foi emboraГўв‚¬</segment>
    <segment id="22">, lembra.</segment>
    <segment id="23">Levi disse ainda que a produГѓВ§ГѓВЈo quis cancelar o show</segment>
    <segment id="24">, masmas desistiu por conta do pГѓВєblico que esperava sentado na grama hГѓВЎ mais de 2h.</segment>
    <segment id="25">Гўв‚¬Е“Falei que o cachГѓВЄ completo nГѓВЈo seria pago pela irresponsabilidade deles.</segment>
    <segment id="26">O vocalista ficou nervoso e quis brigar.</segment>
    <segment id="27">No final</segment>
    <segment id="28">, acabaram levando o sinal de R$ 3 mil.</segment>
    <segment id="29">ГѓвЂ° a 2Г‚ВЄ vez que isso acontece em 7 anos.</segment>
    <segment id="30">As duas foram com o pagodeiro</segment>
    <segment id="31">, a ГѓВєltima foi quando ele era cantor da banda</segment>
    <segment id="32">No EstiloГўв‚¬.
Segundo o assessor da banda</segment>
    <segment id="33">, Carlinhos Soares</segment>
    <segment id="34">, a Guettho ГѓВ© Guettho fez um show de 1 hora e foi</segment>
    <segment id="35">embora</segment>
    <segment id="36">embora sem receber: Гўв‚¬Е“Eles sГѓВЈo acostumados a fazer isso</segment>
    <segment id="37">, masmas vamos deixar pra lГѓВЎГўв‚¬. Sobre o atraso</segment>
    <segment id="38">, a justificativa</segment>
    <segment id="39">ГѓВ© a agenda do grupo: Гўв‚¬Е“Eles vГѓВЄm de um show pra outro</segment>
    <segment id="40">, fazem atГѓВ© 7 em um final de semana.</segment>
    <segment id="41">Mas, na verdade</segment>
