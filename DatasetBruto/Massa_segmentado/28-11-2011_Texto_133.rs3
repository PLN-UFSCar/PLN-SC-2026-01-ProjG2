  <rst>
    <segment id="1">Gata é cheia de sonhos</segment>
    <segment id="2">De Portão para as passarelas: Arleia quer brilhar</segment>
    <segment id="3">A jovem Arleia Soares Santana</segment>
    <segment id="4">, 17 anos</segment>
    <segment id="5">, mora em Portão</segment>
    <segment id="6">, em Lauro de Freitas.</segment>
    <segment id="7">Atualmente</segment>
    <segment id="8">, a gata trabalha</segment>
    <segment id="9">comocomo modelo e está estudando para ser atriz no futuro.</segment>
    <segment id="10">Ainda no segundo grau</segment>
    <segment id="11">, ela quer brilhar nas passarelas e</segment>
    <segment id="12">, quem sabe um dia</segment>
    <segment id="13">, trabalhar na novela Malhação.</segment>
    <segment id="14">Para manter o corpo em forma</segment>
    <segment id="15">, ela faz exercícios em casa e usa bastante protetor solar para evitar as machas.</segment>
    <segment id="16">Com relação à família</segment>
    <segment id="17">, a jovem quer dar uma vida melhor aos pais.</segment>
    <segment id="18">“Quero comprar uma casa maior”.</segment>
    <segment id="19">Os problemas do bairro também preocupam Arleia.</segment>
    <segment id="20">“</segment>
    <segment id="21">A fama de bairro violento ofusca um pouco o que existe de belo no bairro.</segment>
    <segment id="22">Quero mostrar que aqui é cheio de mulher bonita”</segment>
    <segment id="23">, conta ela</segment>
    <segment id="24">, orgulhosa de Portão.</segment>
    <segment id="25">Abrir uma loja para o sustento da família também faz parte da lista de sonhos a serem realizados por  Arleia.</segment>
    <segment id="26">“</segment>
    <segment id="27">Com a ajuda de minha mãe</segment>
    <segment id="28">, quero ter um negócio meu para gerar emprego e renda no meu bairro”</segment>
    <segment id="29">, conta.</segment>
    <segment id="30">Nada de academia</segment>
    <segment id="31">A musa de Portão</segment>
    <segment id="32">, em Lauro</segment>
    <segment id="33">, na Região Metropolitana de Salvador</segment>
    <segment id="34">, gosta de fazer exercício em casa para manter a boa forma.</segment>
    <segment id="35">E que forma!</segment>
    <segment id="36">Quer estar em Malhação</segment>
    <segment id="37">Investindo nas aulas de teatro</segment>
    <segment id="38">,</segment>
    <segment id="39">a gatíssima</segment>
    <segment id="40">Arleia sonha um dia fazer parte do elenco de Malhação</segment>
    <segment id="41">, novela da Globo destinada ao público mais jovem.</segment>
    <segment id="42">Força de vontade</segment>
    <segment id="43">, ela tem.</segment>
  </rst>
</analysis>