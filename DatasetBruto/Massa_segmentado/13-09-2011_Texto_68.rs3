  <rst>
    <segment id="1">Sucesso do Vasco só não é completo pela presença tímida da torcida
TÉCNICO:</segment>
    <segment id="2">Ricardo Gomes segue melhorando e deve começar a</segment>
    <segment id="3">sese alimentar sem sonda
 -</segment>
    <segment id="4">A torcida pode fazer a diferença a favor do Vasco.</segment>
    <segment id="5">Jogar no Engenhão não é a mesma coisa que em São Januário - enfatiza o goleiro Fernando Prass.</segment>
    <segment id="6">- Não arrancamos agora</segment>
    <segment id="7">, temos uma regularidade.</segment>
    <segment id="8">Jogador sente a movimentação já no ônibus.</segment>
    <segment id="9">Quando vê a entrada cheia</segment>
    <segment id="10">, fica mais ligado no jogo.</segment>
    <segment id="11">E, aqui</segment>
    <segment id="12">, quando</segment>
    <segment id="13">sese entra em campo</segment>
    <segment id="14">, com o torcedor bem perto</segment>
    <segment id="15">, essa sensação só tende a aumentar.</segment>
    <segment id="16">Entre os cariocas</segment>
    <segment id="17">, o Flamengo é o mais bem colocado</segment>
    <segment id="18">, em sexto na tabela e em média de público</segment>
    <segment id="19">, com 16.509 pagantes por partida.</segment>
    <segment id="20">O Botafogo</segment>
    <segment id="21">, terceiro</segment>
    <segment id="22">, é apenas o décimo-primeiro</segment>
    <segment id="23">, com 13.327.</segment>
    <segment id="24">Com 10.411 pagantes de média</segment>
    <segment id="25">, o Vasco aparece na frente do Fluminense</segment>
    <segment id="26">, cujas quatro vitórias consecutivas o levaram à quinta posição e</segment>
    <segment id="27">, nas próximas rodadas</segment>
    <segment id="28">, devem turbinar a média ainda modesta de 9.668 pagantes.</segment>
    <segment id="29">Fernando Prass lembra que</segment>
    <segment id="30">, no início do Brasileiro</segment>
    <segment id="31">, a disputa paralela da Copa do Brasil fez com que o torcedor priorizasse a segunda.</segment>
    <segment id="32">Agora, é hora de voltar ao estádio</segment>
    <segment id="33">, até porque</segment>
    <segment id="34">porque a conquista antecipada da vaga na Libertadores reduziu a margem de manobra do time na busca pelo pentacampeonato.

- Segundo</segment>
    <segment id="35">, terceiro e quarto lugares nos dão algo que já temos.</segment>
    <segment id="36">Enquanto todos lutam para estar no G-4</segment>
    <segment id="37">, a nós só interessa ser campeão.</segment>
    <segment id="38">Temos um único objetivo</segment>
    <segment id="39">, contra quatro dos outros - esclarece Prass.</segment>
    <segment id="40">- Não sei</segment>
    <segment id="41">sese seremos campeões</segment>
    <segment id="42">, masmas temos certeza de que vamos brigar pelo título até o fim.</segment>
    <segment id="43">As próximas duas rodadas</segment>
    <segment id="44">, nas quais recebe Grêmio (sábado) e Atlético-GO (dia 22)</segment>
    <segment id="45">, no Rio</segment>
    <segment id="46">, representam mais uma chance de o time assumir a liderança e</segment>
    <segment id="47">, por tabela</segment>
    <segment id="48">, reaquecer a temperatura das arquibancadas de São Januário.</segment>
  </rst>
