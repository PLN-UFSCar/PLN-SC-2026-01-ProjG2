    <segment id="10">, na rua Pitanga</segment>
    <segment id="11">, bairro Jorge Amado</segment>
    <segment id="12">, em Itabuna.</segment>
    <segment id="13">Em entrevista ao site Vermelhinho da Bahia</segment>
    <segment id="14">, o pai da vítima</segment>
    <segment id="15">, Reinan Santos Araújo</segment>
    <segment id="16">, disse que ele estava envolvido no mundo do crime e que o sentimento pela morte do filho era pequena.</segment>
    <segment id="17">"</segment>
    <segment id="18">Ele já foi tarde.</segment>
    <segment id="19">Eu acho que ele roubava também</segment>
