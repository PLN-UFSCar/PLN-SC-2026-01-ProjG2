  <rst>
    <segment id="1">Amor hГѓВЎ mais de 50 anos
Marlene Alves sonha em tirar uma foto com Roberto Carlos</segment>
    <segment id="2">Em cada canto da casa de Marlene Alves</segment>
    <segment id="3">, em Mussurunga</segment>
    <segment id="4">, hГѓВЎ um pouquinho de sua paixГѓВЈo pelo Rei Roberto Carlos: sГѓВЈo revistas</segment>
    <segment id="5">, fotos</segment>
    <segment id="6">, chaveiros e qualquer coisa que tenha a imagem do cantor.</segment>
    <segment id="7">A aposentada</segment>
    <segment id="8">, de 73 anos</segment>
    <segment id="9">, ГѓВ©</segment>
    <segment id="10">fГѓВЈ hГѓВЎ mais de 50 anos do cantor e faz questГѓВЈo de declarar o que sente:</segment>
    <segment id="11">Гўв‚¬Е“Sou uma pessoa feliz.</segment>
    <segment id="12">Roberto Carlos completa minha felicidadeГўв‚¬.</segment>
    <segment id="13">A histГѓВіria de amor</segment>
    <segment id="14">, que comeГѓВ§ou aos poucos</segment>
    <segment id="15">, jГѓВЎ rendeu muitas aventuras ГѓВ  aposentada.</segment>
    <segment id="16">A justificativa?</segment>
    <segment id="17">Гўв‚¬Е“As palavras que ele diz entram no meu coraГѓВ§ГѓВЈoГўв‚¬</segment>
    <segment id="18">, derrete-</segment>
    <segment id="19">sese.</segment>
    <segment id="20">Em todos os shows de Roberto que aconteceram em Salvador</segment>
    <segment id="21">, dona Marlene esteve presente.</segment>
    <segment id="22">Com a empolgaГѓВ§ГѓВЈo de uma verdadeira fГѓВЈ</segment>
    <segment id="23">, ela relembra situaГѓВ§ГѓВµes que passou para ver o ГѓВ­dolo.</segment>
    <segment id="24">Гўв‚¬Е“No show da Bahia Marina</segment>
    <segment id="25">, vesti um conjunto azul de linho elegante e fui no salГѓВЈo pintar o cabelo de vermelho.</segment>
    <segment id="26">Pensei: pelo menos</segment>
    <segment id="27">, ele vai ver meu cabeloГўв‚¬</segment>
    <segment id="28">, conta</segment>
    <segment id="29">, aos risos.</segment>
    <segment id="30">Para ela</segment>
    <segment id="31">, as loucuras jГѓВЎ</segment>
    <segment id="32">sese tornaram comuns</segment>
    <segment id="33">, sГѓВі para ficar pertinho do Rei.</segment>
    <segment id="34">Гўв‚¬Е“Quando tem show</segment>
    <segment id="35">, tenho que ir.</segment>
    <segment id="36">Deus dГѓВЎ um jeitoГўв‚¬</segment>
    <segment id="37">, diz.</segment>
    <segment id="38">Tanto em Salvador</segment>
    <segment id="39">comocomo em Natal</segment>
    <segment id="40">, dona Marlene participa de fГѓВЈs clubes do cantor.</segment>
    <segment id="41">Em Natal</segment>
    <segment id="42">, ela tem atГѓВ© uma carteirinha de cliente especial do bar</segment>
    <segment id="43">O Popular</segment>
    <segment id="44">, onde os fГѓВЈs</segment>
    <segment id="45">sese reГѓВєnem.</segment>
    <segment id="46">Aqui, a aposentada vai aos encontros na casa de uma amiga</segment>
    <segment id="47">, na Fazenda Grande II</segment>
    <segment id="48">, para comemorar qulquer data referente ao Rei.</segment>
    <segment id="49">Por ser fГѓВЈ hГѓВЎ muitos anos</segment>
    <segment id="50">, dona Marlene tem dificuldade para relembrar tudo</segment>
    <segment id="51">, masmas</segment>
    <segment id="52">, assim que ouve uma mГѓВєsica do cantor</segment>
    <segment id="53">, nГѓВЈo erra nenhuma parte da letra.</segment>
    <segment id="54">Гўв‚¬Е“Todas as mГѓВєsicas dele me lembram de algo.</segment>
    <segment id="55">Adoro Гўв‚¬ЛњDetalhesГўв‚¬в„ў</segment>
    <segment id="56">; marca minha vida e lembro de muitas coisas do meu coraГѓВ§ГѓВЈoГўв‚¬</segment>
    <segment id="57">, diz, emocionada.</segment>
    <segment id="58">Seu maior sonho nГѓВЈo deve ser difГѓВ­cil de adivinhar: tirar uma foto com o ГѓВ­dolo.</segment>
    <segment id="59">O mГѓВЎximo que ela conseguiu foi receber uma rosa do cantor.</segment>
    <segment id="60">Гўв‚¬Е“Me senti a pessoa mais feliz do mundo!Гўв‚¬</segment>
    <segment id="61">, revela.</segment>
    <segment id="62">Em relaГѓВ§ГѓВЈo ao show de Roberto Carlos</segment>
    <segment id="63">, que acontecerГѓВЎ no dia 29 de novembro</segment>
    <segment id="64">, na Fonte Nova</segment>
    <segment id="65">, ГѓВ s 21h30</segment>
    <segment id="66">, ela garante que vai ser tudo de bom.</segment>
    <segment id="67">Гўв‚¬Е“O show dele me renova</segment>
    <segment id="68">, me enche de satisfaГѓВ§ГѓВЈo.</segment>
    <segment id="69">A casa vai estar cheia!Гўв‚¬</segment>
    <segment id="70">Dia sagrado</segment>
    <segment id="71">O show Гўв‚¬ЛњRoberto Carlos EspecialГўв‚¬в„ў</segment>
    <segment id="72">, exibido em dezembro na Rede Globo</segment>
    <segment id="73">, talvez seja um dos dias mais importantes para dona Marlene.</segment>
    <segment id="74">Ela conta que veste a melhor roupa</segment>
    <segment id="75">, prepara uma mesa farta e coloca duas taГѓВ§as de champanhe: uma para ela e uma para o cantor.</segment>
    <segment id="76">Гўв‚¬Е“Ajeito dois pratos</segment>
    <segment id="77">, tiro os garfos inox e desligo o celular para ninguГѓВ©m me incomodarГўв‚¬</segment>
    <segment id="78">, conta.</segment>
    <segment id="79">AlГѓВ©m disso</segment>
    <segment id="80">, ela curte o show apenas ГѓВ  luz de velas</segment>
    <segment id="81">, para deixar o clima ainda mais especial.
PROMOГѓвЂЎГѓЖ’O MASSA!</segment>
    <segment id="82">D. Marlene ГѓВ© uma das participantes da promoГѓВ§ГѓВЈo do MASSA!</segment>
    <segment id="83">, que vai levar um fГѓВЈ ao show do dia 29.</segment>
    <segment id="84">O felizardo serГѓВЎ escolhido pelos leitores em enquete no site do jornal</segment>
    <segment id="85">, a partir de sГѓВЎbado.</segment>
    <segment id="86">Para ajudar a contar suas histГѓВіrias</segment>
    <segment id="87">, dona Marlene recorre ГѓВ  vasta coleГѓВ§ГѓВЈo.</segment>
    <segment id="88">Cada objeto tem um significado especial.</segment>
    <segment id="89">Гўв‚¬Е“Tudo dele ГѓВ© importante.</segment>
    <segment id="90">Todas as minhas bolsas tГѓВЄm um chaveiro com a foto de RobertoГўв‚¬. Sobre a cama</segment>
    <segment id="91">, a aposentada exibe um presente que ganhou do ГѓВ­dolo: uma rosa</segment>
    <segment id="92">, jГѓВЎ murcha</segment>
    <segment id="93">, que recebeu em um show na Concha AcГѓВєstica.</segment>
    <segment id="94">Гўв‚¬Е“Eu me joguei na ГѓВЎrea da frente</segment>
    <segment id="95">, onde tem uns seguranГѓВ§as.</segment>
    <segment id="96">AГѓВ­ ele veio</segment>
    <segment id="97">, olhou pra mim</segment>
    <segment id="98">, e me deu essa rosaГўв‚¬.</segment>
  </rst>
