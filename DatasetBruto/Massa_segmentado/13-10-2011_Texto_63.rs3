  <rst>
    <segment id="1">Olho sempre vivo!
MASSA!</segment>
    <segment id="2">está presente e atuante nos bairros</segment>
    <segment id="3">“</segment>
    <segment id="4">Alguns jornais estão preocupados em resolver os grandes problemas da humanidade.</segment>
    <segment id="5">Outros buscam solucionar  problemas da vida de pessoas simples”.</segment>
    <segment id="6">Essa frase dita por muitos</segment>
    <segment id="7">sese aplica bem à essência do jornal MASSA!</segment>
    <segment id="8">, que é pautado por essa simplicidade</segment>
    <segment id="9">, como</segment>
    <segment id="10">como um grande porta-voz da população mais necessitada.</segment>
    <segment id="11">Durante o primeiro ano de vida</segment>
    <segment id="12">, o MASSA! levou ao conhecimento de todos  as mais variadas questões que  vinham causando transtornos para cidadãos de bairros populares de Salvador e Região Metropolitana.

Mais que isso: cobramos ao poder público que</segment>
    <segment id="13">sese fizesse presente  em localidades até então esquecidas.</segment>
    <segment id="14">No dia 18</segment>
    <segment id="15">, o MASSA!</segment>
    <segment id="16">celebra um ano de vigilância nos bairros.</segment>
    <segment id="17">Por isso</segment>
    <segment id="18">,  é com orgulho que apresentamos alguns problemas da vida de pessoas simples que ajudamos a solucionar.

 

DENUNCIE: Tem problemas em seu bairro?</segment>
    <segment id="19">Conte-nos deixando um comentário!</segment>
    <segment id="20">Cajazeiras 8: Galera deu adeus ao buracão</segment>
    <segment id="21">Durante o mês de junho  e parte do mês de julho</segment>
    <segment id="22">, moradores e condutores que passavam pela Estrada da Paciência</segment>
    <segment id="23">, em Cajazeiras 8</segment>
    <segment id="24">, sofriam com um buraco de 3 m x 1</segment>
    <segment id="25">,5 m  e  25 cm de profundidade.</segment>
    <segment id="26">A cratera foi tapada pela prefeitura após o MASSA!</segment>
    <segment id="27">fazer blitz mostrando esse e outros buracos da cidade.</segment>
    <segment id="28">“</segment>
    <segment id="29">Agora temos um jornal que faz alguma coisa por nós</segment>
    <segment id="30">, que chama a atenção dos dirigentes”</segment>
    <segment id="31">, disse a atendente Treicy Medeiros</segment>
    <segment id="32">, 22.</segment>
    <segment id="33">“Desejo que o MASSA!</segment>
    <segment id="34">continue trazendo benfeitorias para a nós”.</segment>
    <segment id="35">Cratera é coisa do passado.</segment>
    <segment id="36">A pista de Cajazeiras 8 está lisinha!</segment>
    <segment id="37">Moradores agradecem!</segment>
    <segment id="38">Bate Facho: Coleta de lixo está regularizada</segment>
    <segment id="39">Em novembro do ano passado completaram três meses que o caminhão compactador da Limpurb não entrava na Rua da Bolandeira</segment>
    <segment id="40">, no Bate Facho (Imbuí).</segment>
    <segment id="41">Nesse período</segment>
    <segment id="42">, os moradores faziam vaquinha e pagavam  a Edmílson Pereira Batista</segment>
    <segment id="43">, 42 anos</segment>
    <segment id="44">, o Lindo</segment>
    <segment id="45">,  para recolher o lixo.</segment>
    <segment id="46">O cara chegava a ganhar até R$ 10 por dia.</segment>
    <segment id="47">Em janeiro deste ano</segment>
    <segment id="48">, o lixo voltou a ser recolhido após o MASSA! comunicar o problema à Limpurb.</segment>
    <segment id="49">“</segment>
    <segment id="50">Não ganho mais aquele dinheirinho extra</segment>
    <segment id="51">, masmas é bom ter a rua sempre limpa.</segment>
    <segment id="52">Felicidades para o jornal!</segment>
    <segment id="53">”</segment>
    <segment id="54">, desejou  Lindo.</segment>
    <segment id="55">Além da via sem entulhos de lixo</segment>
    <segment id="56">, um fio de alta tensão também foi arrumado nesta rua após matéria publicada no MASSA!</segment>
    <segment id="57">Lindo, o gari solidário</segment>
    <segment id="58">, perdeu a boquinha</segment>
    <segment id="59">, masmas não reclama.</segment>
    <segment id="60">Agora a Limpurb passa regularmente

 

Estação Pirajá:</segment>
    <segment id="61">Agora, banheiro só anda limpo</segment>
    <segment id="62">Mau-cheiro</segment>
    <segment id="63">, chão molhado</segment>
    <segment id="64">, vasos sanitários entupidos com papel higiênico e dejetos</segment>
    <segment id="65">, pias e torneiras quebradas</segment>
    <segment id="66">, cabines sem portas e preservativos no chão.</segment>
    <segment id="67">Essa era a situação dos banheiros da Estação Pirajá em março</segment>
    <segment id="68">, quando o MASSA! publicou matéria denunciando  o abandono em que</segment>
    <segment id="69">sese encontrava o local.</segment>
    <segment id="70">Após a denúncia</segment>
    <segment id="71">, a situação é outra: dois dos quatro banheiros foram reformados e</segment>
    <segment id="72">, além de pias</segment>
    <segment id="73">, portas e  pintura</segment>
    <segment id="74">,  ganharam dois funcionários que não descuidam da limpeza.</segment>
    <segment id="75">“</segment>
    <segment id="76">Antes o banheiro era horrível.</segment>
    <segment id="77">Agora anda sempre limpo.</segment>
    <segment id="78">Espero que o  MASSA!</segment>
    <segment id="79">continue fazendo matérias assim”</segment>
    <segment id="80">, afirma a consultora de vendas</segment>
    <segment id="81">, Marcia Gomes</segment>
    <segment id="82">, 28 anos.</segment>
    <segment id="83">Passageiros felizes: os banheiros recebem faxina</segment>
    <segment id="84">todos os dias na Estação Pirajá</segment>
  </rst>
</analysis>