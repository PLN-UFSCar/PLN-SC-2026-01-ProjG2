  <rst>
    <segment id="1">Feriado de São Jorge com show de bailarinos ucranianos
RIO - No feriado de São Jorge</segment>
    <segment id="2">, mais um grandioso espetáculo de dança promete atrair uma multidão</segment>
    <segment id="3">, nesta segunda-feira</segment>
    <segment id="4">, à Quinta da Boa Vista.</segment>
    <segment id="5">Desta vez</segment>
    <segment id="6">, o show gratuito ficará a cargo da Companhia Virsky - Balé Nacional da Ucrânia</segment>
    <segment id="7">, a partir das 18h.</segment>
    <segment id="8">Antes, às 17h</segment>
    <segment id="9">, a Companhia Brasileira de Dança abre os trabalhos.</segment>
    <segment id="10">A prefeitura espera um público de cerca de 40 mil pessoas</segment>
    <segment id="11">, similar ao que o russo Balé Kirov atraiu no 7 de Setembro do ano passado.</segment>
    <segment id="12">A última vez em que o grupo de dança folclórica ucraniana</segment>
    <segment id="13">sese apresentou no Brasil foi em 1985</segment>
    <segment id="14">, com um elenco bem diferente do atual.</segment>
    <segment id="15">Similar</segment>
    <segment id="16">, mesmo</segment>
    <segment id="17">, é a excelência na performance dos dançarinos que desafiam a gravidade.</segment>
    <segment id="18">Ao todo</segment>
    <segment id="19">, a companhia conta com 80 integrantes</segment>
    <segment id="20">, entre membros da orquestra e bailarinos.</segment>
    <segment id="21">A companhia leva o nome de seu fundador</segment>
    <segment id="22">, Pavlo Virsky</segment>
    <segment id="23">, que levou o grupo ao posto de principal corpo de baile do país.</segment>
    <segment id="24">Para a turnê no Brasil</segment>
    <segment id="25">, foram preparados dois números novos.</segment>
    <segment id="26">Um deles</segment>
    <segment id="27">, criado pelo atual diretor geral</segment>
    <segment id="28">, Myroslav Vantukh</segment>
    <segment id="29">, é uma dança cigana que representa um ritual tradicional da Bessarábia</segment>
    <segment id="30">, na qual homens e mulheres "competem".</segment>
    <segment id="31">O outro número consiste numa coreografia masculina de marinheiros.</segment>
    <segment id="32">A turnê do Virsky passa por nove cidades de três regiões do país.</segment>
    <segment id="33">Na terça-feira e na quarta</segment>
    <segment id="34">, eles sobem ao palco do Teatro João Caetano</segment>
    <segment id="35">, com ingressos a R$ 100 (balcão simples) e R$ 150 (plateia</segment>
    <segment id="36">, balcão nobre).</segment>
  </rst>
</analysis>