  <rst>
    <segment id="1">Técnica feminina do Judô critica postura de atletas</segment>
    <segment id="2">A treinadora da seleção feminina de judô do Brasil</segment>
    <segment id="3">, a ex-judoca Rosicleia Campos</segment>
    <segment id="4">, não escondeu toda sua decpeção com o comportamento e o rendimento de algumas das atletas brasileiras durante os Jogos Pan-Americanos de Guadalajara.
- Foi muito ruim (o balanço do feminino).</segment>
    <segment id="5">Ficou muito aquém da capacidade da equipe</segment>
    <segment id="6">, que é muito melhor do que isso.</segment>
    <segment id="7">O resultado mostra que as atletas ainda não estão maturadas.</segment>
    <segment id="8">Não podemos ver uma vice-campeã mundial</segment>
    <segment id="9">comocomo a Rafaella Silva respeitar demais uma atleta cubana</segment>
    <segment id="10">, só porque</segment>
    <segment id="11">porque ela é mais experiente</segment>
    <segment id="12">, com todo o respeito que merece a Yorisley Lupetey (que ganhou de Rafaella na final).</segment>
    <segment id="13">É algo que temos de avaliar</segment>
    <segment id="14">, porque</segment>
    <segment id="15">porque este evento é uma pequena Olimpíada - afirmou Rosicléia.</segment>
    <segment id="16">- Peço desculpas a todos no Brasil.</segment>
    <segment id="17">Foi ruim.</segment>
    <segment id="18">Faltou coração e entrega.</segment>
    <segment id="19">Não foi mérito das adversárias</segment>
    <segment id="20">, masmas demérito das nossas atletas.</segment>
    <segment id="21">Segundo a treinadora</segment>
    <segment id="22">, faltou postura às brasileiras:

- Faltou essa postura.</segment>
    <segment id="23">Não entendo a Rafaella</segment>
    <segment id="24">, respeitada pela atual campeã mundial</segment>
    <segment id="25">, respeitar demais a cubana.</segment>
    <segment id="26">Isso não é leal com ela própria.</segment>
    <segment id="27">É diferente o</segment>
    <segment id="28">casocaso da Érika (Miranda</segment>
    <segment id="29">, que perdeu na final deste sábado para Yanet Bernoy).</segment>
    <segment id="30">A adversária foi realmente superior.</segment>
    <segment id="31">A Mayra (Aguiar) também lutou pessimamente</segment>
    <segment id="32">, com uma postura excessivamente defensiva.</segment>
    <segment id="33">Ainda conforme a treinadora</segment>
    <segment id="34">, além da capacidade técnica</segment>
    <segment id="35">, as brasileiras precisam ter a postura de campeãs.

- Temos de entrar com o coração na mão.</segment>
    <segment id="36">O atleta de alto rendimento vai além de onde o corpo permite.</segment>
    <segment id="37">Não tem de ser arrogante</segment>
    <segment id="38">, nem prepotente</segment>
    <segment id="39">, masmas não posso admitir submissão ou inferioridade.</segment>
    <segment id="40">Aqui estáo exemplo dos mexicanos que são inferiores tecnicamente</segment>
    <segment id="41">, masmas dão a alma.</segment>
    <segment id="42">Para nós faltou isso.</segment>
    <segment id="43">Houve época em que éramos inferiores tecnicamente</segment>
    <segment id="44">, masmas hoje não somos mais.</segment>
    <segment id="45">No feminino</segment>
    <segment id="46">, o Brasil obteve em Guadalajara duas pratas</segment>
    <segment id="47">, com Érika Miranda e Rafaela Silva</segment>
    <segment id="48">, e bronze com Sarah Meneses</segment>
    <segment id="49">, Maria Portella</segment>
    <segment id="50">, Mayra Aguiar e Maria Suellen.</segment>
    <segment id="51">No masculino</segment>
    <segment id="52">, foram seis ouros - Felipe Kitadai</segment>
    <segment id="53">, Leandro Cunha</segment>
    <segment id="54">, Bruno Mendonça</segment>
    <segment id="55">, Leandro Guilheiro</segment>
    <segment id="56">, Tiago Camilo e Luciano Corrêa - e uma prata - de Rafael Silva - em sete finais em sete categorias.</segment>
  </rst>
</analysis>