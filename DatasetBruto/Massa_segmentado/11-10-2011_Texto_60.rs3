  <rst>
    <segment id="1">Riquezas do mar e mistérios cercam Trápani e Erice</segment>
    <segment id="2">, na Sicília
TRÁPANI</segment>
    <segment id="3">, SICÍLIA - De um lado o Mar Mediterrâneo</segment>
    <segment id="4">; do outro</segment>
    <segment id="5">, o Tirreno</segment>
    <segment id="6">A visita a Trápani</segment>
    <segment id="7">, no extremo oeste da Sicília</segment>
    <segment id="8">, leva também a Erice</segment>
    <segment id="9">, cidade medieval a 12 quilômetros dali</segment>
    <segment id="10">, subindo 750 metros do nível do mar</segment>
    <segment id="11">, no topo do Monte Erix</segment>
    <segment id="12">, ou Erice.</segment>
    <segment id="13">Trápani tem em suas igrejas um dos destaques no roteiro do visitante.</segment>
    <segment id="14">Um passeio pelo Corso Vittorio Emanuele revela algumas</segment>
    <segment id="15">, entre elas a Chiesa de Sant'Agostino</segment>
    <segment id="16">, que tem em sua fachada uma rosácea em estilo gótico</segment>
    <segment id="17">, e a catedral dedicada a San Lorenzo</segment>
    <segment id="18">, que exibe entre as obras de seu interior uma pintura da Crucificação atribuída ao flamengo Van Dyke.</segment>
    <segment id="19">O centro histórico é pequeno e bonito e ganha vida nos fins de semana.</segment>
    <segment id="20">Na porta mais antiga da cidade</segment>
    <segment id="21">, fica a Torre dell'Orologio</segment>
    <segment id="22">, datando provavelmente do tempo dos cartagineses</segment>
    <segment id="23">, recentemente restaurada.</segment>
    <segment id="24">O emaranhado de ruas perto do porto é ideal para</segment>
    <segment id="25">sese explorar a pé ou de bicicleta.</segment>
    <segment id="26">O aluguel por um dia custa 10 euros</segment>
    <segment id="27">, no centro de informações turísticas.</segment>
    <segment id="28">Depois de ver todos estes prédios históricos</segment>
    <segment id="29">, gostoso mesmo é sentar num bar no fim da Via Torrearsa</segment>
    <segment id="30">, ao cair da tarde</segment>
    <segment id="31">, pedir uma cerveja local e trocar alguns dedos de prosa</segment>
    <segment id="32">, observando os nonos fazerem o mesmo.</segment>
    <segment id="33">Passeios: Roteiro pela Sicília</segment>
    <segment id="34">, na Itália</segment>
    <segment id="35">, leva a locações usadas em '</segment>
    <segment id="36">O poderoso chefão' e ao topo do vulcão Etna

Vizinha: À sombra do vulcão em Taormina

Praias e história:</segment>
    <segment id="37">Sorrento é ponto de partida para roteiro pela Campanha</segment>
    <segment id="38">, que inclui visita a Pompeia</segment>
    <segment id="39">, aos pés do vulcão Vesúvio

No inverno:</segment>
    <segment id="40">A Toscana que vale esperar pelo frio</segment>
    <segment id="41">O sal marinho e os pescados (atum</segment>
    <segment id="42">, principalmente) foram por muito tempo um forte componente da economia de Trápani.</segment>
    <segment id="43">As salinas tornaram-</segment>
    <segment id="44">sese parte da paisagem da cidade e ainda estão lá bem ao lado do porto.</segment>
    <segment id="45">Mas nos últimos anos</segment>
    <segment id="46">, com a concorrência do norte da África a um custo menor</segment>
    <segment id="47">, a produção está diminuindo</segment>
    <segment id="48">, conta a guia que nos acompanha no ônibus</segment>
    <segment id="49">, a caminho de Erice: "</segment>
    <segment id="50">A cidade era mais branca</segment>
    <segment id="51">, montanhas de sal e moinhos de vento eram aspectos característicos da paisagem</segment>
    <segment id="52">, que está</segment>
    <segment id="53">sese transformando".</segment>
    <segment id="54">Lendas e histórias rondam a cidade de Erice</segment>
    <segment id="55">, como</segment>
    <segment id="56">como a bruma que costuma encobrir o lugar nas primeiras horas da manhã.</segment>
    <segment id="57">Se hoje é refúgio de verão para os sicilianos de Trápani</segment>
    <segment id="58">, Erice</segment>
    <segment id="59">, cujas origens datam dos séculos VIII a VI a.C.</segment>
    <segment id="60">, também foi um porto seguro para os troianos</segment>
    <segment id="61">, que buscavam ali melhores condições de vida.</segment>
    <segment id="62">Talvez venha daí sua inspiração para o turismo.</segment>
    <segment id="63">Hoje</segment>
    <segment id="64">Erice enfileira lojinhas de suvenires e doces em suas ruas calçadas de pedra.</segment>
    <segment id="65">Para quem busca lembrancinhas</segment>
    <segment id="66">, há peças encantadoras de cerâmica</segment>
    <segment id="67">, produzidas artesanalmente.</segment>
    <segment id="68">Passaram por lá os gregos</segment>
    <segment id="69">, que deixaram</segment>
    <segment id="70">comocomo herança o Templo de Vênus.</segment>
    <segment id="71">A cidade teria sido fundada por Eryx</segment>
    <segment id="72">, filho de Afrodite e do rei local Butes.</segment>
    <segment id="73">Em homenagem à mãe</segment>
    <segment id="74">, ele construiu o Santuário da Vênus de Erice</segment>
    <segment id="75">, onde depois foi erguido o castelo de Vênus.</segment>
    <segment id="76">A Porta Trápani</segment>
    <segment id="77">, que protegia um arco importante da fortaleza</segment>
    <segment id="78">, é a principal entrada da cidade</segment>
    <segment id="79">, que ainda guarda 800 metros de muros medievais.</segment>
    <segment id="80">Bem perto dali fica a Igreja Matriz</segment>
    <segment id="81">, que data do século XV e é um dos principais cartões-postais de Erice.</segment>
    <segment id="82">Os bizantinos dominaram a cidade até 827</segment>
    <segment id="83">, quando os árabes a conquistaram em menos de 30 anos.</segment>
    <segment id="84">Acostumados à vida no deserto</segment>
    <segment id="85">, inventavam sistema de irrigações das terras</segment>
    <segment id="86">, aquedutos</segment>
    <segment id="87">, e trouxeram a expertise em fazer os doces com pasta de amêndoa</segment>
    <segment id="88">, como</segment>
    <segment id="89">como o cannoli (canudo de massa crocante recheado com creme de amêndoas) e outras influências gastronômicas</segment>
    <segment id="90">, como</segment>
    <segment id="91">como o cuscuz com pescado.</segment>
    <segment id="92">As casas com pátios internos</segment>
    <segment id="93">, tradição em Erice</segment>
    <segment id="94">, são todas heranças dos árabes.</segment>
    <segment id="95">Nos pátios ficavam as crianças e as mulheres</segment>
    <segment id="96">, onde lavavam roupas</segment>
    <segment id="97">, aproveitando os reservatórios que recolhiam água das chuvas no centro dos pátios.</segment>
    <segment id="98">Um teleférico leva até Erice</segment>
    <segment id="99">, desde Trápani.</segment>
    <segment id="100">Em cabines para oito pessoas</segment>
    <segment id="101">, o percurso dura 11 minutos.

SERVIÇO:</segment>
    <segment id="102">Como chegar:</segment>
    <segment id="103">De barco: Pela Grimaldi Lines</segment>
    <segment id="104">, de Roma (Civittavecchia) a Trápani</segment>
    <segment id="105">, cabine com duas camas (e carro pequeno no ferryboat) por 640 euros</segment>
    <segment id="106">, ida e volta.</segment>
    <segment id="107">São 14h30m de viagem.</segment>
    <segment id="108">Aferry.com

De trem:</segment>
    <segment id="109">O serviço de trem na Sicília tem horários limitados</segment>
    <segment id="110">, masmas há linhas que passam por diversas cidades.</segment>
    <segment id="111">A estação de Taormina é Giardini Naxos</segment>
    <segment id="112">, na costa do Mar Jônico.</segment>
    <segment id="113">Há ônibus e táxis que levam da estação de trem ou do porto até Taormina</segment>
    <segment id="114">, em uma colina a 200 metros acima do nível do mar.</segment>
    <segment id="115">A cidade fica a dez minutos de carro do litoral.</segment>
    <segment id="116">trenitalia.it

De carro:</segment>
    <segment id="117">As estradas são estreitas e sinuosas quando o roteiro inclui vilas</segment>
    <segment id="118">comocomo Savoca e Erice</segment>
    <segment id="119">, que ficam no alto de montanhas.</segment>
    <segment id="120">Carros pequenos circulam com mais desenvoltura e custam a partir de 185 por semana</segment>
    <segment id="121">, em opensicily.com.</segment>
    <segment id="122">Savoca fica a 36 km de Messina e 15 km de Taormina</segment>
    <segment id="123">, via Stradale 114 até Santa Teresa di Riva.</segment>
    <segment id="124">De Santa Teresa di Riva</segment>
    <segment id="125">, seguir pela SP 19 até Savoca.</segment>
  </rst>
</analysis>