  <rst>
    <segment id="1">Bandidão bota mãe no maior esparro!</segment>
    <segment id="2">Polícia estava atrás do traficante Cleidson</segment>
    <segment id="3">, masmas foi dona Vera que foi em cana</segment>
    <segment id="4">A busca era por Cleison de Jesus dos Santos</segment>
    <segment id="5">, conhecido</segment>
    <segment id="6">comocomo Thor e apontado</segment>
    <segment id="7">comocomo o maior traficante da  Baixa Fria</segment>
    <segment id="8">, na Boca do Rio.</segment>
    <segment id="9">Mas quem acabou dançando mesmo foi a mãe dele</segment>
    <segment id="10">, Vera Lima de Jesus</segment>
    <segment id="11">, 47 anos.</segment>
    <segment id="12">Ela era a única</segment>
    <segment id="13">, na casa</segment>
    <segment id="14">, quando os policiais da 9ª DT (Boca do Rio) encontram cocaína</segment>
    <segment id="15">, maconha e crack escondidos em uma panela em cima de um armário de cozinha.</segment>
    <segment id="16">O filho</segment>
    <segment id="17">, apesar de não ter nenhum mandado de prisão contra ele</segment>
    <segment id="18">, não deu as caras na delegacia para saber da mãe.</segment>
    <segment id="19">Em vez disso</segment>
    <segment id="20">, mandou cinco advogados.</segment>
    <segment id="21">Segundo a polícia</segment>
    <segment id="22">, Vera  já sabia que o filho não estava em casa e permitiu a entrada dos  policiais</segment>
    <segment id="23">porque</segment>
    <segment id="24">porque achou que eles não fariam  revista.</segment>
    <segment id="25">“Vera negou ser a dona da droga.</segment>
    <segment id="26">E disse que o filho e a mulher dele</segment>
    <segment id="27">, de prenome Paloma</segment>
    <segment id="28">, são traficantes</segment>
    <segment id="29">, masmas ela não sabia da existência da droga e não os via traficando lá”</segment>
    <segment id="30">, afirmou  a delegada da 9ª DT</segment>
    <segment id="31">, Fernanda Porfírio.</segment>
    <segment id="32">“Mas não tem</segment>
    <segment id="33">comocomo ela não saber</segment>
    <segment id="34">porque</segment>
    <segment id="35">porque a casa possui apenas um cômodo pequeno”</segment>
    <segment id="36">, completou.</segment>
    <segment id="37">Vera foi indiciada por tráfico de drogas e associação ao tráfico.</segment>
    <segment id="38">Ela foi encaminhada para a Derca.</segment>
    <segment id="39">Thor de volta à ação</segment>
    <segment id="40">Thor saiu do presídio em outubro do ano passado e</segment>
    <segment id="41">, desde então</segment>
    <segment id="42">, estava sumido do mundo do tráfico</segment>
    <segment id="43">, de acordo com a delegada Fernanda Porfírio.

“</segment>
    <segment id="44">Recentemente</segment>
    <segment id="45">, recebemos denúncias de que ele voltou a traficar</segment>
    <segment id="46">, na Baixa Fria</segment>
    <segment id="47">, e fomos averiguar.</segment>
    <segment id="48">Essas denúncias também apontam o envolvimento da mãe dele com o tráfico de drogas”</segment>
    <segment id="49">, explicou.</segment>
    <segment id="50">Em 2010</segment>
    <segment id="51">, Vera e Thor foram apresentados na 9ª DT por tráfico de drogas</segment>
    <segment id="52">, masmas apenas o filho foi autuado.</segment>
    <segment id="53">A polícia investiga também o envolvimento do traficante com diversos homicídios na região.</segment>
    <segment id="54">Um deles teria ocorrido há dez dias.</segment>
    <segment id="55">Policiais da 9ª DT fizeram diligência ontem à tarde em busca de Thor</segment>
    <segment id="56">, que não havia sido preso até o final da tarde.</segment>
  </rst>
</analysis>