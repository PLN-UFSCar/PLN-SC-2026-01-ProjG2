  <rst>
    <segment id="1">Tem muita culhuda por aí...</segment>
    <segment id="2">Hoje Salvador completa 463 anos e o MASSA!</segment>
    <segment id="3">presenteia os leitores com dados curiosos</segment>
    <segment id="4">Você sabia que as Cajazeiras são oito</segment>
    <segment id="5">, e não 11?</segment>
    <segment id="6">Qual o bairro mais negro de Salvador?</segment>
    <segment id="7">Quem apostou na Liberdade perdeu feio!</segment>
    <segment id="8">Você gosta de passar uma tarde em Itapuã</segment>
    <segment id="9">, como</segment>
    <segment id="10">como recomendava o Poetinha Vinicius de Moraes?</segment>
    <segment id="11">Pois  é</segment>
    <segment id="12">, muitas “verdades absolutas” sobre Salvador não passam de lendas urbanas.</segment>
    <segment id="13">Confira aqui alguns mitos que o mais recente Censo do Instituto Brasileiro de Geografia e Estatística</segment>
    <segment id="14">, em 2010</segment>
    <segment id="15">, faz cair por terra.</segment>
    <segment id="16">Itapuã está bem longe da poesia</segment>
    <segment id="17">É grande o abandono do bairro escolhido</segment>
    <segment id="18">comocomo um dos sete pontos mágicos de Salvador em 2009.</segment>
    <segment id="19">Com ocupação e comércio desordenados</segment>
    <segment id="20">, não há obras de infraestrutura nem trabalho de preservação das belezas naturais do local.</segment>
    <segment id="21">Brotas</segment>
    <segment id="22">, o mais populoso da cidade</segment>
    <segment id="23">Hoje, são 70.158 habitantes.</segment>
    <segment id="24">Os limites do bairro iam até Itapuã</segment>
    <segment id="25">, o segundo mais populoso</segment>
    <segment id="26">, com 66.961 moradores.</segment>
    <segment id="27">Brotas abriga diferentes classes sociais –  é possível encontrar mansões em condomínios de luxo e casebres inacabados.</segment>
    <segment id="28">Pernambués é o mais negro</segment>
    <segment id="29">Este é o bairro com o maior número de moradores que</segment>
    <segment id="30">sese declararam negros ou pardos: 53.580 pessoas</segment>
    <segment id="31">, 2,52% de toda a população negra da cidade.</segment>
    <segment id="32">Vovô, do Ilê</segment>
    <segment id="33">, desconfia dos números do IBGE:</segment>
    <segment id="34">“</segment>
    <segment id="35">Só sese a população (da Liberdade) voltou a</segment>
    <segment id="36">sese ver</segment>
    <segment id="37">comocomo morena” .</segment>
    <segment id="38">Caja City não é uma cidade</segment>
    <segment id="39">A região tem 147.155 habitantes</segment>
    <segment id="40">, segundo o Censo</segment>
    <segment id="41">, e não 800 mil</segment>
    <segment id="42">, como</segment>
    <segment id="43">como diz a lenda.</segment>
    <segment id="44">Se excluídos moradores de Boca da Mata</segment>
    <segment id="45">, das quatro Fazendas Grandes e de Águas Claras</segment>
    <segment id="46">, a população das oito Cajazeiras é de 60 mil</segment>
    <segment id="47">, a 5ª maior da capital.</segment>
  </rst>
