    <segment id="9">, em Mata Escura.</segment>
    <segment id="10">Outro interno</segment>
    <segment id="11">, Carlos Alberto dos Santos</segment>
    <segment id="12">, 23, foi identificado</segment>
    <segment id="13">comocomo autor do delito.</segment>
    <segment id="14">Conforme registros do Departamento de Homicﾃδｭdios (DHPP)</segment>
    <segment id="15">, Carlos cometeu o crime</segment>
    <segment id="16">porque</segment>
    <segment id="17">porque teria sido agredido pela vﾃδｭtima hﾃδ｡ dez dias.</segment>
    <segment id="18">No boletim do DHPP</segment>
    <segment id="19">, consta que um terceiro detento presenciou o momento em que Carlos desferiu diversos golpes no crﾃδ｢nio de Marcus Vinﾃδｭcius ﾃ｢竄ｬﾅ電e forma incontrolﾃδ｡velﾃ｢竄ｬ.
Hﾃδ｡ suspeitas de que a vﾃδｭtima dormia quando sofreu o ataque.</segment>
    <segment id="20">Carlos foi preso por furto em novembro do ano passado.</segment>
    <segment id="21">Jﾃδ｡</segment>
    <segment id="22">Marcus fora preso em flagrante</segment>
    <segment id="23">, em maio</segment>
    <segment id="24">, pelo assassinato de Ederivaldo dos Santos Ferreira</segment>
    <segment id="25">, em Sﾃδ｣o Marcos.</segment>
    <segment id="26">A assessoria da Secretaria de Administraﾃδｧﾃδ｣o Penitenciﾃδ｡ria  (Seap) informou que Carlos e Marcus Vinﾃδｭcius eram mantidos em uma cela de isolamento</segment>
    <segment id="27">, pelo motivo de usarem medicamentos controlados.</segment>
    <segment id="28">Nﾃδ｣o havia sinais de divergﾃδｪncia entre os dois.</segment>
    <segment id="29">Alex dos Santos da Silva</segment>
    <segment id="30">, 26, que matou o colega de cela</segment>
    <segment id="31">, Reginaldo Souza dos Santos</segment>
    <segment id="32">, 46, a facadas</segment>
    <segment id="33">, na ﾃδｺltima segunda-feira</segment>
    <segment id="34">, foi transferido para a Unidade Especial Disciplinar.</segment>
    <segment id="35">Alex disse que Reginaldo o ameaﾃδｧava de morte.</segment>
    <segment id="36">Vinganﾃδｧa sangrenta
Leandro Sousa Santos</segment>
    <segment id="37">, 28, detido por suspeita de roubo</segment>
    <segment id="38">, foi morto por companheiros de cela</segment>
    <segment id="39">, dentro da carceragem da Delegacia de Eunﾃδ｡polis</segment>
    <segment id="40">, durante o banho de sol.</segment>
    <segment id="41">O crime ocorreu na ﾃδｺltima terﾃδｧa-feira.</segment>
    <segment id="42">Leandro sofreu quase dez perfuraﾃδｧﾃδｵes pelo corpo.</segment>
    <segment id="43">Os suspeitos pela morte do colega de cela sﾃδ｣o Rubens Lourenﾃδｧo dos Santos</segment>
    <segment id="44">, 27, Leonildo de Jesus Cruz</segment>
    <segment id="45">, 22, e Clﾃδ｡udio Jean.</segment>
    <segment id="46">O motivo do assassinato seria uma vinganﾃδｧa.</segment>
    <segment id="47">Leonildo</segment>
    <segment id="48">, Rubens e Clﾃδ｡udio desconfiaram que Leandro teria informado ﾃδ polﾃδｭcia sobre um plano de fuga e resolveram matar o rapaz.</segment>
    <segment id="49">Os acusados pretendiam detonar ainda outro preso</segment>
