  <rst>
    <segment id="1">Mulherada em guerra
Rita foi agredida pela ex-companheira de uma amiga</segment>
    <segment id="2">, há oito meses</segment>
    <segment id="3">Pior do que sofrer as sequelas de uma facada na barriga é saber que o criminoso continua livre.</segment>
    <segment id="4">Esta é a revolta da comerciante Rita Baraúna</segment>
    <segment id="5">, 41.</segment>
    <segment id="6">Ela foi esfaqueada</segment>
    <segment id="7">, em outubro de 2011</segment>
    <segment id="8">, por Aldenise Pascoal</segment>
    <segment id="9">, quando estava na casa da colega</segment>
    <segment id="10">,  Taís Alves</segment>
    <segment id="11">, na Boca do Rio.</segment>
    <segment id="12">Taís e Aldenise tinham um</segment>
    <segment id="13">casocaso amoroso</segment>
    <segment id="14">, masmas estariam separadas há três meses.</segment>
    <segment id="15">Após receber alta médica</segment>
    <segment id="16">, Rita prestou queixa na  Delegacia da Boca do Rio</segment>
    <segment id="17">, um mês após o crime.</segment>
    <segment id="18">“</segment>
    <segment id="19">Uma audiência</segment>
    <segment id="20">, no dia 5 de dezembro</segment>
    <segment id="21">, foi cancelada</segment>
    <segment id="22">porque</segment>
    <segment id="23">porque a delegada disse que o endereço de Aldenise não foi encontrado para entregar a intimação.</segment>
    <segment id="24">Depois disso</segment>
    <segment id="25">, o caso</segment>
    <segment id="26">caso não andou”</segment>
    <segment id="27">, relata Rita.</segment>
    <segment id="28">Mas a delegada   Florisbela Rodrigues da Rocha</segment>
    <segment id="29">, responsável pela investigação</segment>
    <segment id="30">, garante que o inquérito está perto do fim.
Testemunha</segment>
    <segment id="31">sese calou</segment>
    <segment id="32">A delegada conta que teve dificuldades para descobrir o nome de Aldenise e o endereço dela.</segment>
    <segment id="33">“Aldenise já foi interrogada.</segment>
    <segment id="34">Vou fazer mais uma análise no inquérito para encaminhar à Justiça.</segment>
    <segment id="35">É possível que seja feito o pedido de prisão preventiva (contra Aldenise)”</segment>
    <segment id="36">, explica a delegada.</segment>
    <segment id="37">Rita conta que Taís Alves presenciou o crime</segment>
    <segment id="38">, masmas não quis testemunhar na delegacia.</segment>
    <segment id="39">“Ela foi o pivô da história</segment>
    <segment id="40">, masmas disse que já foi presa por estelionato e não quer ir à delegacia.</segment>
    <segment id="41">Ainda me ameaça para retirar a queixa”</segment>
    <segment id="42">, afirma.</segment>
    <segment id="43">A delegada Florisbela esclarece que a lei não permite forçar uma pessoa a testemunhar em um inquérito.</segment>
    <segment id="44">“Entreguei o endereço de Taís e a foto das duas à polícia</segment>
    <segment id="45">, para ajudar na investigação”</segment>
    <segment id="46">, afirma Rita.</segment>
    <segment id="47">A vítima disse nunca ter visto Aldenise antes de sofrer o ataque.</segment>
    <segment id="48">“Encontrei Taís na Boca do Rio e ela me convidou para ir na casa dela</segment>
    <segment id="49">, onde levei a facada”</segment>
    <segment id="50">, relembra.</segment>
  </rst>
</analysis>