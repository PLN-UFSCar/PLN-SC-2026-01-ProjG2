  <rst>
    <segment id="1">Branco foi a cor do azar na sexta 13</segment>
    <segment id="2">Homem que ameaçou matar o prefeito de Simões Filho é morto a tiros por policiais
Acusado pela polícia de ser o principal líder do tráfico de drogas no bairro Góes Calmon</segment>
    <segment id="3">, na cidade de Simões Filho</segment>
    <segment id="4">, Genilson Anunciação de Jesus</segment>
    <segment id="5">, 19 anos</segment>
    <segment id="6">, conhecido</segment>
    <segment id="7">comocomo Branco</segment>
    <segment id="8">, foi morto a tiros</segment>
    <segment id="9">, por volta das 11h30 da manhã de ontem.</segment>
    <segment id="10">De acordo com o capitão PM Hildegard</segment>
    <segment id="11">, subcomandante da Rondesp RMS</segment>
    <segment id="12">, Branco atirou contra os policiais militares que estavam em duas viaturas</segment>
    <segment id="13">, fazendo rondas pelo Góes Calmon.</segment>
    <segment id="14">“Ele fugiu pelo mato.</segment>
    <segment id="15">Nossos PMs reagiram e ele acabou sendo atingido”</segment>
    <segment id="16">, relata o capitão.</segment>
    <segment id="17">Segundo o delegado Antônio Fernando Soares do Carmo</segment>
    <segment id="18">, titular de Simões Filho</segment>
    <segment id="19">, Branco ameaçou matar o prefeito do município</segment>
    <segment id="20">, Eduardo Alencar (PSD)</segment>
    <segment id="21">, há cerca de seis meses.</segment>
    <segment id="22">“Ele espalhou na comunidade que</segment>
    <segment id="23">sese o prefeito fosse visitar o bairro dele</segment>
    <segment id="24">, seria assassinado”</segment>
    <segment id="25">, afirma o delegado.</segment>
    <segment id="26">Em Simões Filho</segment>
    <segment id="27">, a população especula o motivo para justificar a ameaça contra o prefeito: o fato de Branco</segment>
    <segment id="28">sese incomodar com as ações de combate ao crime realizadas pelo gestor municipal.</segment>
    <segment id="29">A assessoria de comunicação do prefeito preferiu não comentar o</segment>
    <segment id="30">casocaso.</segment>
    <segment id="31">O delegado Antônio Fernando destaca que existem</segment>
    <segment id="32">, na delegacia</segment>
    <segment id="33">, pelo menos oito inquéritos apontando Branco</segment>
    <segment id="34">comocomo autor de homicídios na cidade.</segment>
    <segment id="35">“</segment>
    <segment id="36">Na última segunda-feira</segment>
    <segment id="37">, ele matou um rival”</segment>
    <segment id="38">, diz o delegado.</segment>
    <segment id="39">Arma poderosa</segment>
    <segment id="40">Segundo os policiais da Rondesp</segment>
    <segment id="41">, com Branco foram apreendidas 61 pedras de crack</segment>
    <segment id="42">, um telefone celular</segment>
    <segment id="43">, uma submetralhadora calibre 38</segment>
    <segment id="44">, de fabricação artesanal</segment>
    <segment id="45">, e seis munições intactas.</segment>
    <segment id="46">O capitão Hildegard diz que o acusado estava abastecendo os pontos de venda de droga</segment>
    <segment id="47">, no momento da operação policial</segment>
    <segment id="48">, no Góes Calmon.</segment>
    <segment id="49">Branco tinha ficha na polícia.</segment>
    <segment id="50">Em julho de 2010</segment>
    <segment id="51">, ele foi detido por porte ilegal de arma.</segment>
    <segment id="52">‘</segment>
    <segment id="53">Não houve troca de tiros’</segment>
    <segment id="54">Um irmão de Branco</segment>
    <segment id="55">, de prenome Jimeilson</segment>
    <segment id="56">, nega que Genilson tenha ameaçado o prefeito.</segment>
    <segment id="57">“Também é mentira essa história de que houve troca de tiros.</segment>
    <segment id="58">Várias viaturas cercaram o local e atiraram nele</segment>
    <segment id="59">, que estava na porta de um amigo.</segment>
    <segment id="60">Depois</segment>
    <segment id="61">, enrolaram ele no lençol e mandaram os moradores ficarem em casa.</segment>
    <segment id="62">Meu irmão era usuário</segment>
    <segment id="63">, masmas respeitava os moradores</segment>
    <segment id="64">, era querido”</segment>
    <segment id="65">, defende o irmão.</segment>
  </rst>
</analysis>