  <rst>
    <segment id="1">Benazzi é o bombeiro do Vitória
Vágner Benazzi está de malas prontas para voltar a Salvador</segment>
    <segment id="2">,
Vagner Benazzi foi oficializado ontem</segment>
    <segment id="3">comocomo novo treinador do Vitória.</segment>
    <segment id="4">Sim, é aquele mesmo que treinou o Bahia no primeiro semestre deste ano</segment>
    <segment id="5">, no Baianão.</segment>
    <segment id="6">O técnico</segment>
    <segment id="7">, que chega no máximo amanhã</segment>
    <segment id="8">, vem com o aval do presidente Alexi Portela</segment>
    <segment id="9">, que fez questão de explicar a escolha.</segment>
    <segment id="10">“Benazzi conhece o time e isso é muito importante.</segment>
    <segment id="11">Ele tinha propostas de outros quatro clubes</segment>
    <segment id="12">, alguns deles de Série</segment>
    <segment id="13">A, porém</segment>
    <segment id="14">porém preferiu vir para o Vitória.</segment>
    <segment id="15">Ele disse que sabe da qualidade do elenco e que tem certeza que poderá tirar o time desta situação”</segment>
    <segment id="16">, afirmou Portela.</segment>
    <segment id="17">Satisfeito com a contratação</segment>
    <segment id="18">, o vice-presidente do rubro-negro</segment>
    <segment id="19">, Carlos Falcão</segment>
    <segment id="20">, mostrou confiança no novo comandante.</segment>
    <segment id="21">“</segment>
    <segment id="22">O que nós precisamos é de um treinador com experiência em acesso e isso o Benazzi tem.</segment>
    <segment id="23">Precisamos de um cara que chegue aqui e resolva</segment>
    <segment id="24">, que dê equilíbrio e tenha atitude.</segment>
    <segment id="25">Esse cara é o Benazzi”</segment>
    <segment id="26">, disse Falcão</segment>
    <segment id="27">, que completou:</segment>
    <segment id="28">“Não podemos achar que esta situação é normal”.</segment>
    <segment id="29">Benazzi levou três times à Série A.</segment>
    <segment id="30">Em 1998</segment>
    <segment id="31">, subiu com Gama-DF</segment>
    <segment id="32">, quando foi o campeão da Série B.</segment>
    <segment id="33">Em 2001 conquistou o acesso com o Figueirense e em 2007 com a Portuguesa.</segment>
    <segment id="34">O novo comandante rubro-negro</segment>
    <segment id="35">, 57 anos</segment>
    <segment id="36">, tem 22 anos de carreira</segment>
    <segment id="37">comocomo treinador.</segment>
    <segment id="38">Porém, mesmo com este currículo o paulista não era o primeiro nome da lista</segment>
    <segment id="39">, como</segment>
    <segment id="40">como afirma Alexi Portela.</segment>
    <segment id="41">“</segment>
    <segment id="42">Tentamos o PC Gusmão e o Márcio Araújo.</segment>
    <segment id="43">Porém, os dois estão com problemas familiares e não querem treinar nenhum time no momento.</segment>
    <segment id="44">O melhor à disposição era o Vagner Benazzi.</segment>
    <segment id="45">Sei que irá reverter a situação”</segment>
    <segment id="46">, garantiu o presidente</segment>
    <segment id="47">, que criticou o desempenho do time.</segment>
    <segment id="48">“É uma vergonha o que está acontecendo aqui.</segment>
    <segment id="49">Isso tem que mudar e rápido”</segment>
    <segment id="50">, finalizou.</segment>
    <segment id="51">Neto Baiano diz:</segment>
    <segment id="52">‘time precisa ter vergonha na cara’

Sempre polêmico</segment>
    <segment id="53">, o atacante Neto Baiano</segment>
    <segment id="54">, em entrevista à rádio Itapoan FM</segment>
    <segment id="55">, voltou a atacar no último sábado</segment>
    <segment id="56">,  após a derrota do Vitória.</segment>
    <segment id="57">Na oportunidade</segment>
    <segment id="58">, o jogador afirmou que o elenco está dividido.</segment>
    <segment id="59">Porém, ontem</segment>
    <segment id="60">, afirmou que foi mal interpretado.</segment>
    <segment id="61">“Não quis dizer que tem racha no grupo.</segment>
    <segment id="62">Apenas disse que nós somos os culpados e precisamos de mais comprometimento.</segment>
    <segment id="63">Não adianta apenas um querer dar sangue pelo time</segment>
    <segment id="64">, tem que ser o elenco inteiro”</segment>
    <segment id="65">, falou.</segment>
    <segment id="66">Porém, o atacante não perdeu a oportunidade de desabafar e causar mais polêmica.</segment>
    <segment id="67">“Temos que ter vergonha na cara</segment>
    <segment id="68">, jogar com mais vontade e determinação.</segment>
    <segment id="69">Ou fazemos isso ou será difícil alcançar o nosso objetivo que é o retorno à Série</segment>
    <segment id="70">A”.</segment>
    <segment id="71">Ao ficar sabendo da história</segment>
    <segment id="72">, o presidente do Leão</segment>
    <segment id="73">, Alexi Portela</segment>
    <segment id="74">, ficou irritado.</segment>
    <segment id="75">“Vamos conversar com Neto e não vamos aceitar essa racha no elenco de forma alguma”.</segment>
    <segment id="76">O diretor de futebol</segment>
    <segment id="77">, Beto Silveira</segment>
    <segment id="78">, completou</segment>
    <segment id="79">, ironizando:</segment>
    <segment id="80">“O elenco está rachado?</segment>
    <segment id="81">Então vai ter que colar.</segment>
    <segment id="82">Eles recebem em dia”</segment>
    <segment id="83">, afirmou.</segment>
    <segment id="84">Porém, um funcionário do time</segment>
    <segment id="85">, que pediu para não ser identificado</segment>
    <segment id="86">, contou outra história.</segment>
    <segment id="87">“Tem jogador com ciúme do outro</segment>
    <segment id="88">, por prestígio ou salário.</segment>
    <segment id="89">Já vi isto acontecer antes e não terminou bem.</segment>
    <segment id="90">A garotada não</segment>
    <segment id="91">sese entende com os mais experientes”</segment>
    <segment id="92">, revelou.</segment>
  </rst>
</analysis>