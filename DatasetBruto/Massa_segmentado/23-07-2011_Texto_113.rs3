  <rst>
    <segment id="1">Norueguês preso admite ser o autor dos dois ataques que mataram mais de 90 e diz que foram 'atrozes</segment>
    <segment id="2">, masmas necessários'
OSLO - Anders Behring Breivik</segment>
    <segment id="3">, o homem suspeito de matar ao menos 92 pessoas na Noruega</segment>
    <segment id="4">, admitiu a culpa pelos dois ataques e disse que seus atos foram "atrozes</segment>
    <segment id="5">, masmas necessários"</segment>
    <segment id="6">, afirmou seu advogado neste sábado</segment>
    <segment id="7">, em entrevista à TV norueguesa.</segment>
    <segment id="8">"</segment>
    <segment id="9">Ele disse que acreditava que suas ações foram atrozes</segment>
    <segment id="10">, masmas que</segment>
    <segment id="11">, no seu entendimento</segment>
    <segment id="12">, elas eram necessárias"</segment>
    <segment id="13">, disse Geir Lippestad à TV2.</segment>
    <segment id="14">Lippestad disse que seu cliente admitiu a culpa pela explosão que matou 7 e destruiu prédios na sede do governo norueguês na capital</segment>
    <segment id="15">, Oslo</segment>
    <segment id="16">, e do tiroteio em um acampamento de jovens do Partido Trabalhista</segment>
    <segment id="17">, que matou 85 em uma ilha perto da capital</segment>
    <segment id="18">, ambos na sexta-feira.</segment>
    <segment id="19">Segundo o advogado</segment>
    <segment id="20">, as ações estavam sendo planejadas "havia muito tempo".</segment>
    <segment id="21">O advogado disse que seu cliente</segment>
    <segment id="22">, que se</segment>
    <segment id="23">se entregou às autoridades após os ataques sem resistir</segment>
    <segment id="24">, quer</segment>
    <segment id="25">sese explicar em uma audiência judicial na segunda-feira.</segment>
    <segment id="26">Convicções de extrema direita e contra muçulmanos</segment>
    <segment id="27">Um homem de convicções de extrema-direita</segment>
    <segment id="28">, antimuçulmano</segment>
    <segment id="29">, masmas sem ligação direta com terroristas.</segment>
    <segment id="30">Os motivos que levaram Anders Behring Breivik a cometer o maior massacre na Noruega em mais de seis décadas ainda é um mistério para a polícia.</segment>
    <segment id="31">Os antecedentes dele também confundem os agentes.</segment>
    <segment id="32">Segundo a agência de notícias norueguesa NTB</segment>
    <segment id="33">, Breivik tem a posse legal de três armas de fogo - uma pistola Glock</segment>
    <segment id="34">, um rifle e uma espingarda</segment>
    <segment id="35">, de acordo com o jornal "VG" - e participa de um clube de tiro.</segment>
    <segment id="36">"</segment>
    <segment id="37">Não tínhamos conhecimento de sua existência</segment>
    <segment id="38">, o que teria acontecido</segment>
    <segment id="39">sese ele fosse membro de algum grupo neonazista"</segment>
    <segment id="40">, disse um agente.</segment>
    <segment id="41">O chefe da polícia nacional</segment>
    <segment id="42">, Sveinung Sponheim</segment>
    <segment id="43">, afirmou à TV que as mensagens de Breivik na internet sugeriam sua inclinação política: ele pregava contra o Islã e o multiculturalismo.</segment>
    <segment id="44">Porém, de acordo com Mikel Ekman</segment>
    <segment id="45">, investigador da Fundação Expo</segment>
    <segment id="46">, com base em Estocolmo</segment>
    <segment id="47">, que monitora grupos de extrema direita</segment>
    <segment id="48">, Behring criou um perfil em 2009 sob um pseudônimo que pode ser rastreado para seu endereço de e-mail em um fórum neonazista sueco chamado Nordisk.</segment>
    <segment id="49">Fundado em 2007</segment>
    <segment id="50">, o Nordisk conta com 22 mil membros na região.</segment>
    <segment id="51">De 2004 a 2006</segment>
    <segment id="52">, Breivik foi membro do Partido do Progresso</segment>
    <segment id="53">, no qual entrou na ala jovem em 1997.</segment>
    <segment id="54">Jonas Kallmyr</segment>
    <segment id="55">, antigo integrante do partido</segment>
    <segment id="56">, disse ao jornal "VG" que encontrar Breivik era</segment>
    <segment id="57">comocomo "um encontro com Hitler antes da Segunda Guerra".</segment>
    <segment id="58">Já Siv Jensen</segment>
    <segment id="59">, também do partido (que luta por restrições à imigração)</segment>
    <segment id="60">, afirma que o terrorista nunca foi militante.</segment>
    <segment id="61">Breivik tocava uma empresa de agricultura dedicada ao cultivo de hortaliças no leste da Noruega - o que lhe permitiu acumular grandes quantidades de fertilizante</segment>
    <segment id="62">, que pode ser usado na fabricação de explosivos.</segment>
    <segment id="63">Ele morava num prédio de quatro andares numa região burguesa à oeste de Oslo</segment>
    <segment id="64">, cuja entrada estava sendo protegida pela polícia neste domingo.</segment>
    <segment id="65">Em sua suposta página no Facebook</segment>
    <segment id="66">, bloqueada pela polícia</segment>
    <segment id="67">, Breivik mostrava alguns de seus interesses</segment>
    <segment id="68">, da maçonaria (à qual pertenceu) à música trance</segment>
    <segment id="69">, passando pela política conservadora.</segment>
    <segment id="70">Na rede social</segment>
    <segment id="71">, o suspeito gostava dos jogos de guerra "World of Warcraft" e "</segment>
    <segment id="72">Modern Warfare" e dos livros "1984</segment>
    <segment id="73">", de George Orwell</segment>
    <segment id="74">, e "</segment>
    <segment id="75">O príncipe"</segment>
    <segment id="76">, de Maquiavel.</segment>
  </rst>
</analysis>