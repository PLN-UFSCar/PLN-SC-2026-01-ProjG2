  <rst>
    <segment id="1">Ba-Vi Está na hora de balançar a rede</segment>
    <segment id="2">O primeiro clássico do ano terminou num chato 0 a 0.</segment>
    <segment id="3">Amanhã</segment>
    <segment id="4">, a galera quer ver gol!</segment>
    <segment id="5">Um Ba-Vi sem gols é o mesmo que ir à praia e não tomar sol</segment>
    <segment id="6">, dançar com irmã e beber cerveja quente.</segment>
    <segment id="7">No primeiro clássico deste ano</segment>
    <segment id="8">, a rede não balançou</segment>
    <segment id="9">, em Pituaçu.</segment>
    <segment id="10">Amanhã à tarde</segment>
    <segment id="11">, no Barradão</segment>
    <segment id="12">, a ordem para os jogadores é brocar o rival.</segment>
    <segment id="13">O duelo</segment>
    <segment id="14">sese repete: o rubro-negro Neto Baiano</segment>
    <segment id="15">, artilheiro do estadual e do Brasil</segment>
    <segment id="16">, com 16 gols</segment>
    <segment id="17">, contra o caveirão tricolor Souza</segment>
    <segment id="18">, 11 gols no Baianão</segment>
    <segment id="19">, e animado pela música feita para ele pelo cantor Ricardo Chaves.</segment>
    <segment id="20">Na história dos confrontos entre Vitória e Bahia ocorreram  um total de 125 empates</segment>
    <segment id="21">, sendo que em 48 deles o placar ficou em branco.</segment>
    <segment id="22">No Barradão três Ba-Vis</segment>
    <segment id="23">terminaram empatados:

0x0 em 3 de novembro de 1991</segment>
    <segment id="24">, 2x2 em 9 de abril de 1995 e 0x0 em 2 de abril de 2000</segment>
    <segment id="25">, todos pelo Campeonato Baiano</segment>
    <segment id="26">, segundo as estatísticas do professor Marcelo Lopes Monteiro.</segment>
    <segment id="27">E os principais artilheiros trataram de motivar a disputa.</segment>
    <segment id="28">“Vou guardar para o Ba-Vi”</segment>
    <segment id="29">, disparou Neto Baiano</segment>
    <segment id="30">, após passar em branco no triunfo sobre o São Domingos pela Copa do Brasil.</segment>
    <segment id="31">“Não é comigo</segment>
    <segment id="32">, não.</segment>
    <segment id="33">Ele que</segment>
    <segment id="34">sese resolva com Tite e Rafael Donato.</segment>
    <segment id="35">Eu quero é brocar”</segment>
    <segment id="36">, devolveu Souza.</segment>
  </rst>
</analysis>