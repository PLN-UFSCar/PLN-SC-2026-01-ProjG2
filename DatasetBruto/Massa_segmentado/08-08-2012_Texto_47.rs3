    <segment id="1">Chefe mata peﾃδ｣o respondﾃδ｣o
Paulo Santos</segment>
    <segment id="2">, 53, conta que briga com Genivaldo comeﾃδｧou</segment>
    <segment id="3">porque</segment>
    <segment id="4">porque ele era insubordinado</segment>
    <segment id="5">Um crime premeditado.</segment>
    <segment id="6">Esse ﾃδｩ o entendimento da polﾃδｭcia sobre o assassinato do carpinteiro Genivaldo do Santos Cruz</segment>
    <segment id="7">, 29 anos</segment>
    <segment id="8">, morto a tiros no ﾃδｺltimo dia 9 de julho</segment>
    <segment id="9">, no canteiro de obras do loteamento Aquarius</segment>
    <segment id="10">, na Pituba.</segment>
    <segment id="11">O acusado</segment>
    <segment id="12">, o encarregado de carpintaria Paulo de Oliveira Santos</segment>
    <segment id="13">, 53, se</segment>
    <segment id="14">se entregou na ﾃδｺltima segunda-feira (6)</segment>
    <segment id="15">, no Departamento de Homicﾃδｭdios (DHPP).</segment>
    <segment id="16">Acompanhado do advogado</segment>
    <segment id="17">, ele disse que nﾃδ｣o tinha a intenﾃδｧﾃδ｣o de matar e agiu em legﾃδｭtima defesa.</segment>
    <segment id="18">ﾃ｢竄ｬﾅ鄭s circunstﾃδ｢ncias e a forma</segment>
    <segment id="19">comocomo o crime ocorreu nﾃδ｣o configura legﾃδｭtima defesa.</segment>
    <segment id="20">Esse homicﾃδｭdio foi premeditadoﾃ｢竄ｬ</segment>
    <segment id="21">, afirma o delegado do DHPP</segment>
    <segment id="22">, Juvﾃδｪncio Meneses Neto.</segment>
    <segment id="23">Em depoimento</segment>
    <segment id="24">,  Paulo</segment>
    <segment id="25">, que era chefe da vﾃδｭtima</segment>
    <segment id="26">, contou que Genivaldo  era insubordinado e nﾃδ｣o aceitava as determinaﾃδｧﾃδｵes dele.</segment>
    <segment id="27">E, ao tomar conhecimento do comportamento do carpinteiro</segment>
    <segment id="28">, a empresa decidiu  demiti-lo</segment>
    <segment id="29">, apﾃδｳs o perﾃδｭodo de experiﾃδｪncia.</segment>
    <segment id="30">Paulo afirmou ainda</segment>
    <segment id="31">, conforme a polﾃδｭcia</segment>
    <segment id="32">, que Genivaldo ameaﾃδｧou dar um tiro nele</segment>
    <segment id="33">, caso</segment>
    <segment id="34">caso fosse demitido.
Revﾃδｳlver ﾃδｩ do pai
Paulo disse que ficou preocupado com as ameaﾃδｧas e</segment>
    <segment id="35">, por isso</segment>
    <segment id="36">, levou a arma do pai (um revﾃδｳlver calibre 38) para o trabalho</segment>
    <segment id="37">, no dia em que Genivaldo voltaria ﾃδ obra para receber a rescisﾃδ｣o.</segment>
    <segment id="38">Ele alegou ainda ter levado um murro da vﾃδｭtima e ficado desacordado.</segment>
    <segment id="39">Quando recuperou os sentidos</segment>
    <segment id="40">, viu Genivaldo pegando um barrote para agredi-lo e atirou para</segment>
    <segment id="41">sese defender.</segment>
    <segment id="42">ﾃ｢竄ｬﾅ撤aulo alega que nﾃδ｣o teve a intenﾃδｧﾃδ｣o de matar</segment>
    <segment id="43">, masmas atirou justamente nas regiﾃδｵes vitais: um tiro na cabeﾃδｧa e dois na regiﾃδ｣o do tﾃδｳraxﾃ｢竄ｬ</segment>
    <segment id="44">, questiona o delegado.</segment>
    <segment id="45">ﾃ｢竄ｬﾅ鉄e ele estava preocupado com as ameaﾃδｧas</segment>
    <segment id="46">, deveria evitar encontrar com Genivaldo e nﾃδ｣o usar uma arma no dia</segment>
    <segment id="47">, hora e local em que o desafeto estaria.</segment>
    <segment id="48">Ele sabia que o cara ia buscar a rescisﾃδ｣o e pegou a arma do pai.</segment>
    <segment id="49">Ele esperava encontrar a vﾃδｭtimaﾃ｢竄ｬ</segment>
    <segment id="50">, defende o delegado.</segment>
