  <rst>
    <segment id="1">PSDB de SP reconduz à direção estadual nome ligado a Alckmin</segment>
    <segment id="2">Após um impasse na semana passada</segment>
    <segment id="3">, o PSDB encerrou nesta quinta-feira em São Paulo a eleição da sua nova direção estadual</segment>
    <segment id="4">, com a recondução do secretário-geral</segment>
    <segment id="5">, César Gontijo</segment>
    <segment id="6">, ligado ao governador de São Paulo</segment>
    <segment id="7">, Geraldo Alckmin.</segment>
    <segment id="8">O cargo estava sendo pleiteado também pelo deputado Vaz de Lima</segment>
    <segment id="9">, ligado ao ex-governador José Serra</segment>
    <segment id="10">, masmas ele decidiu abrir mão da vaga.</segment>
    <segment id="11">O desfecho sem disputa foi resultado de um esforço dos líderes tucanos para estancar a crise que atingia o partido desde abril</segment>
    <segment id="12">, quando houve debandada de filiados após a convenção municipal - seis vereadores e um dos fundadores do PSDB</segment>
    <segment id="13">, Walter Feldman</segment>
    <segment id="14">, ligado a Serra.</segment>
    <segment id="15">O próximo desafio é a escolha da direção nacional do partido</segment>
    <segment id="16">, marcada para este mês.</segment>
    <segment id="17">Por enquanto</segment>
    <segment id="18">, há somente um postulante: o deputado Sérgio Guerra (PE)</segment>
    <segment id="19">, atual presidente do PSDB.</segment>
    <segment id="20">O processo eleitoral paulista começou sábado passado</segment>
    <segment id="21">, com a escolha do novo presidente estadual do PSDB</segment>
    <segment id="22">, deputado estadual Pedro Tobias.</segment>
    <segment id="23">Ele foi eleito com apoio dos grupos de Serra e Alckmin.</segment>
    <segment id="24">Principais líderes do partido marcaram presença</segment>
    <segment id="25">, tentando demonstrar unidade partidária.</segment>
    <segment id="26">Na ocasião</segment>
    <segment id="27">, não houve consenso sobre quem ocuparia a secretaria geral</segment>
    <segment id="28">, cargo mais cobiçado na direção partidária</segment>
    <segment id="29">, e os tucanos adiaram a escolha para evitar decisão no voto.</segment>
    <segment id="30">Ontem, a permanência de Gontijo foi feita por aclamação.
- Prevaleceu o que todos queríamos</segment>
    <segment id="31">, fazer com que o racha da eleição do diretório municipal não</segment>
    <segment id="32">sese estabelecesse na esfera estadual - disse o deputado Luiz Fernando Machado</segment>
    <segment id="33">, coordenador da bancada paulista do PSDB na Câmara e articulador da postulação de Lima.</segment>
    <segment id="34">Em troca</segment>
    <segment id="35">, os deputados federais ficaram com a vice-presidência</segment>
    <segment id="36">, uma secretaria e uma vogal.</segment>
  </rst>
</analysis>