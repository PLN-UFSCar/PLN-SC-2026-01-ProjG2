  <rst>
    <segment id="1">Em cinco minutos</segment>
    <segment id="2">, blitz móvel do Detran reboca dois carros
RIO - Bastaram cinco minutos de ronda</segment>
    <segment id="3">para que</segment>
    <segment id="4">para que fiscais da blitz móvel do Detran encontrassem na quinta-feira</segment>
    <segment id="5">, no Leblon</segment>
    <segment id="6">, dois carros em situação irregular e os rebocassem.</segment>
    <segment id="7">O novo modelo de operação</segment>
    <segment id="8">, itinerante</segment>
    <segment id="9">, entrou em vigor em toda a Região Metropolitana para flagrar irregularidades</segment>
    <segment id="10">comocomo dívidas de IPVA</segment>
    <segment id="11">, falta de vistoria e motoristas com habilitação vencida ou cassada.</segment>
    <segment id="12">Ao todo</segment>
    <segment id="13">, quatro equipes atuarão todos os dias</segment>
    <segment id="14">, em diferentes horários.</segment>
    <segment id="15">O comboio conta com um carro equipado com leitor de placa interligado ao sistema do Detran</segment>
    <segment id="16">, duas motocicletas da PM e um reboque.</segment>
    <segment id="17">Quando as câmaras flagram um veículo com irregularidades</segment>
    <segment id="18">, ele é abordado por motociclistas do Batalhão de Choque.</segment>
    <segment id="19">Em seguida</segment>
    <segment id="20">, agentes do Detran autuam o motorista</segment>
    <segment id="21">, que pode ter seu veículo rebocado.</segment>
    <segment id="22">Toda a ação</segment>
    <segment id="23">, segundo o presidente do Detran</segment>
    <segment id="24">, Fernando Avelino</segment>
    <segment id="25">, é rápida</segment>
    <segment id="26">, para evitar transtornos ao trânsito:

- Fizemos testes e vamos conseguir abordar o motorista sem prejudicar o trânsito.</segment>
    <segment id="27">Além dessas ações circulantes</segment>
    <segment id="28">, as outras operações fixas do Detran que flagram motoristas inadimplentes continuarão a acontecer.</segment>
    <segment id="29">Ontem, no primeiro dia da operação</segment>
    <segment id="30">, um táxi e um Honda Fit com problemas foram flagrados de manhã na Avenida Delfim Moreira</segment>
    <segment id="31">, no Leblon.</segment>
    <segment id="32">Quando os carros passaram pelo comboio do Detran</segment>
    <segment id="33">, um aviso foi repassado aos PMs de motos</segment>
    <segment id="34">, que abordaram os motoristas infratores.</segment>
    <segment id="35">A motorista do Honda Fit foi flagrada pelos fiscais com a habilitação vencida desde 2007 e o carro sem vistoria desde 2009.</segment>
    <segment id="36">Ao ser abordada</segment>
    <segment id="37">, ela, que não quis</segment>
    <segment id="38">sese identificar</segment>
    <segment id="39">, contou que esquecera a habilitação em casa.</segment>
    <segment id="40">Agentes do Detran</segment>
    <segment id="41">, no entanto</segment>
    <segment id="42">, checaram a validade da carteira da motorista através do CPF dela e verificaram que estava vencida.</segment>
    <segment id="43">Metade da frota do estado tem licenciamento atrasado</segment>
    <segment id="44">De acordo com o coordenador de Fiscalização do Detran</segment>
    <segment id="45">, coronel José Macedo</segment>
    <segment id="46">, a motorista pagará multa por três infrações: dirigir sem habilitação</segment>
    <segment id="47">, estar com a carteira vencida e com o licenciamento do veículo atrasado.</segment>
    <segment id="48">As multas</segment>
    <segment id="49">, somadas</segment>
    <segment id="50">, chegam a R$ 509</segment>
    <segment id="51">,28 - o valor não inclui a diária do depósito para onde foi levado o carro.</segment>
    <segment id="52">Já o táxi estava sem a vistoria anual.</segment>
    <segment id="53">O motorista ainda alegou que a inspeção estava agendada para a próxima semana</segment>
    <segment id="54">, masmas não adiantou.</segment>
    <segment id="55">Seu carro também foi rebocado.</segment>
    <segment id="56">Perguntado sobre a blitz</segment>
    <segment id="57">, o taxista José Soares</segment>
    <segment id="58">, de 66 anos</segment>
    <segment id="59">, disse ser a favor da ação.

- É correto fiscalizar.</segment>
    <segment id="60">Desta vez</segment>
    <segment id="61">, tive problemas com o kit-gás</segment>
    <segment id="62">, por isso atrasei a vistoria - disse o motorista.</segment>
    <segment id="63">Em Ipanema</segment>
    <segment id="64">, outros dois veículos foram rebocados</segment>
    <segment id="65">, também por falta de licenciamento e carteira vencida.</segment>
    <segment id="66">De acordo com o coordenador de Fiscalização do Detran</segment>
    <segment id="67">, cerca de 50% do total de veículos do estado (5</segment>
    <segment id="68">,4 milhões) estão com o licenciamento atrasado.</segment>
    <segment id="69">Somente no município do Rio de Janeiro</segment>
    <segment id="70">, com uma frota de 2</segment>
    <segment id="71">,5 milhões de veículos</segment>
    <segment id="72">, 50,7% estão com esse problema.</segment>
    <segment id="73">Ainda de acordo com dados do Detran</segment>
    <segment id="74">, somente nos meses de janeiro e fevereiro deste ano</segment>
    <segment id="75">, 6.007 carteiras de motorista foram apreendidas.</segment>
    <segment id="76">No mesmo período do ano passado</segment>
    <segment id="77">, 4.988 motoristas ficaram sem suas habilitações</segment>
    <segment id="78">, devido ao excesso de pontos na carteira (por causa de infrações cometidas).</segment>
    <segment id="79">Em todo o ano passado</segment>
    <segment id="80">, o total de habilitações apreendidas chegou a 38.070.</segment>
    <segment id="81">Segundo a Secretaria estadual de Fazenda</segment>
    <segment id="82">, de 10% a 15% dos veículos que circulam no Rio estão com dívida de IPVA.</segment>
    <segment id="83">A frota fluminense que recolhe o imposto é de aproximadamente 2</segment>
    <segment id="84">,8 milhões de veículos.</segment>
  </rst>
</analysis>