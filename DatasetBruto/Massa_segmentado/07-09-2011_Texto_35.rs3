  <rst>
    <segment id="1">Homem é ferido em outra confusão entre moradores e PMs na Cidade de Deus
RIO - Em outra confusão entre moradores e PMs de uma UPP da Cidade de Deus</segment>
    <segment id="2">, em Jacarepaguá</segment>
    <segment id="3">, um homem foi ferido na perna por uma bala de borracha.</segment>
    <segment id="4">Segundo o site G1</segment>
    <segment id="5">, o tumulto ocorreu às 19h</segment>
    <segment id="6">, após PMs pedirem a um grupo que desligasse um aparelho de som que tocava funk fazendo apologia do crime e entregasse o CD a eles.</segment>
    <segment id="7">O morador atingido</segment>
    <segment id="8">, segundo o comandante de uma das três UPPs da comunidade</segment>
    <segment id="9">, capitão Marlow</segment>
    <segment id="10">, teria</segment>
    <segment id="11">sese recusado a entregar o disco.</segment>
    <segment id="12">O oficial contou</segment>
    <segment id="13">, ainda de acordo com o G1</segment>
    <segment id="14">, que o homem tentou agredir os policiais</segment>
    <segment id="15">, que fizeram então um disparo de bala de borracha.</segment>
    <segment id="16">O ferido foi levado para o Hospital Lourenço Jorge</segment>
    <segment id="17">, na Barra.</segment>
    <segment id="18">Outros dois disparos de bala de borracha foram feitos para dispersar um grupo que protestou contra a ação.</segment>
    <segment id="19">Na madrugada de segunda-feira</segment>
    <segment id="20">, já havia ocorrido uma confusão no local: na saída de um baile funk</segment>
    <segment id="21">, moradores jogaram pedras e garrafas contra a sede de uma UPP</segment>
    <segment id="22">, ferindo um PM.</segment>
  </rst>
