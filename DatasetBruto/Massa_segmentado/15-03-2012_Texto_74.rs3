  <rst>
    <segment id="1">Leão despacha o São Domingos e quer mais
Jogadores do Vitória comemoram um dos gols que garantiram o time na próxima fase</segment>
    <segment id="2">O Vitória bem que teve chances para golear o São Domingos</segment>
    <segment id="3">, ontem</segment>
    <segment id="4">, no Barradão.</segment>
    <segment id="5">Porém, o placar de 2 a 0 foi o suficiente para o time classificar-</segment>
    <segment id="6">sese à próxima fase da Copa do Brasil.</segment>
    <segment id="7">Agora, o Leão quer mais</segment>
    <segment id="8">, diante do ABC-RN</segment>
    <segment id="9">, na próxima fase do torneio.</segment>
    <segment id="10">Antes do apito inicial</segment>
    <segment id="11">, a maioria dos torcedores do Vitória acreditava que o duelo contra a equipe sergipana seria fácil.</segment>
    <segment id="12">E foi.</segment>
    <segment id="13">Entretanto</segment>
    <segment id="14">, os jogadores deixaram a desejar na pontaria e jogaram para o gasto.</segment>
    <segment id="15">A classificação começou a ser construída com Marquinhos</segment>
    <segment id="16">, que  abriu o placar aos 27 do primeiro tempo</segment>
    <segment id="17">, com um chute da entrada da área.</segment>
    <segment id="18">O segundo gol do Leão foi marcado por Arthur Maia</segment>
    <segment id="19">, que fez o terceiro gol dele</segment>
    <segment id="20">comocomo profissional.</segment>
    <segment id="21">Aos 35 da segunda etapa</segment>
    <segment id="22">, o meia cobrou falta que o goleiro Ivan aceitou.</segment>
    <segment id="23">Um frangaço!</segment>
    <segment id="24">Antes disso</segment>
    <segment id="25">, o atacante Índio entrou em campo para fazer</segment>
    <segment id="26">, enfim</segment>
    <segment id="27">, sua reestreia pelo Vitória.</segment>
    <segment id="28">O ídolo das flechadas</segment>
    <segment id="29">sese movimentou bem e arriscou alguns lances.</segment>
    <segment id="30">Já o Bahia de Feira  venceu o Aquidauanense-MS por 2 a 0</segment>
    <segment id="31">, no Joia da Princesa</segment>
    <segment id="32">, e vai encarar o São Paulo.</segment>
    <segment id="33">O Bahia da capital vai enfrentar o Remo na próxima fase.</segment>
  </rst>
