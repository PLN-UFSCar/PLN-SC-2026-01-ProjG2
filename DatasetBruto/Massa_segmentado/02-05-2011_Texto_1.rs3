  <rst>
    <segment id="1">Parabéns!</segment>
    <segment id="2">Classificação nota dez!</segment>
    <segment id="3">Vitória vai à final e festeja pelos dez anos de fila do rival</segment>
    <segment id="4">Foi ao som de “Parabéns para você” que os rubro- -negros comemoraram os dez anos do rival sem nenhuma conquista de títulos estaduais.</segment>
    <segment id="5">O Vitória usou a vantagem do empate para garantir sua vaga na decisão contra o Bahia de Feira</segment>
    <segment id="6">, que começa no próximo domingo em local ainda não definido.</segment>
    <segment id="7">Na partida de ontem</segment>
    <segment id="8">, venceu quem de fato jogou melhor</segment>
    <segment id="9">, masmas a classificação veio de forma justa para quem demonstrou a superioridade durante todo o campeonato.</segment>
    <segment id="10">O Bahia chegava com tudo quando estava descansado</segment>
    <segment id="11">, tanto que Marcone balançou a rede aos dois minutos do primeiro e do segundo tempo.</segment>
    <segment id="12">Mas, durante o desgaste físico dos tricolores</segment>
    <segment id="13">, a competente zaga do Vitória administrou bem a prerrogativa de</segment>
    <segment id="14">sese dar ao luxo de perder por um gol de diferença.</segment>
    <segment id="15">Cada vez que o tricolor marcava</segment>
    <segment id="16">, o Vitória corria atrás para diminuir.</segment>
    <segment id="17">Como todo clássico que</segment>
    <segment id="18">sese preze</segment>
    <segment id="19">, não faltaram polêmicas.</segment>
    <segment id="20">Mas desta vez elas nem passaram perto das discussões sobre a irregularidade dos lances ou sobre a validade dos pênaltis.</segment>
    <segment id="21">O bate-boca ficou por conta de Souza e Viáfara</segment>
    <segment id="22">, depois que o atacante atingiu a perna do goleiro em lance sem bola.</segment>
    <segment id="23">“Ele não é homem não?</segment>
    <segment id="24">Por que correu pro vestiário?</segment>
    <segment id="25">”, questionou Souza doido para partir para a briga física com o goleiro.</segment>
    <segment id="26">O zagueiro Titi</segment>
    <segment id="27">, expulso após duas entradas violentas</segment>
    <segment id="28">, ainda cornetou: “Viáfara é palhaço</segment>
    <segment id="29">, tinha que ir pro circo”.</segment>
    <segment id="30">O Campeonato já acabou para o Bahia</segment>
    <segment id="31">, masmas o ringue ainda está armado.</segment>
  </rst>
</analysis>