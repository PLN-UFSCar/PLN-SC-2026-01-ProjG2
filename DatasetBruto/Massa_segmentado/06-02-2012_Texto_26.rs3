  <rst>
    <segment id="1">Papo picante:</segment>
    <segment id="2">Guga e suas duas meninas</segment>
    <segment id="3">A galera de O Trio</segment>
    <segment id="4">sese anima falando sobre suas experiências sexuais fora do reality</segment>
    <segment id="5">Nada mais animador do que um  bom papo sobre sexo.</segment>
    <segment id="6">Com a galera de “</segment>
    <segment id="7">O Trio” não é diferente.</segment>
    <segment id="8">Ontem à tarde</segment>
    <segment id="9">, Rosiane Pinheiro</segment>
    <segment id="10">, Guga de Paula e Léo Kret contaram experiências vividas fora do reality.</segment>
    <segment id="11">A história mais curiosa foi a de Guga:</segment>
    <segment id="12">“</segment>
    <segment id="13">Duas amigas me chamaram no quarto</segment>
    <segment id="14">, apagaram a luz e começaram a</segment>
    <segment id="15">sese beijar”.</segment>
    <segment id="16">E Léo, curiosíssima</segment>
    <segment id="17">, perguntou:</segment>
    <segment id="18">“E aí?</segment>
    <segment id="19">Você beijou as duas?</segment>
    <segment id="20">”.</segment>
    <segment id="21">“Claro!</segment>
    <segment id="22">”,</segment>
    <segment id="23">respondeu o cantor.</segment>
  </rst>
