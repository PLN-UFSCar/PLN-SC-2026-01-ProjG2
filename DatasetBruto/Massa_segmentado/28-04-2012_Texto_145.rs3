  <rst>
    <segment id="1">Família diz que pastor estava limpo
Religioso e dois homens foram mortos a tiros</segment>
    <segment id="2">, em uma oficina</segment>
    <segment id="3">, em São Tomé de Paripe
Familiares e amigos ainda buscam motivos que possam explicar os brutais assassinatos do pastor Raimundo Araújo Costa</segment>
    <segment id="4">, 58 anos</segment>
    <segment id="5">, do chapista e pintor Carlos Augusto de Araújo Ferreira</segment>
    <segment id="6">, 52, e de Ismael Jesus da Silva</segment>
    <segment id="7">, 20, que trabalhava há um ano no Moinho Fortaleza</segment>
    <segment id="8">, no Subúrbio.</segment>
    <segment id="9">Carlos e Raimundo eram primos.</segment>
    <segment id="10">Os três foram mortos com tiros na cabeça.</segment>
    <segment id="11">O crime ocorreu na oficina mecânica pertencente a Raimundo - mais conhecido</segment>
    <segment id="12">comocomo Pastor Raimundão - localizada  no bairro São Tomé de Paripe.</segment>
    <segment id="13">Na tarde de ontem</segment>
    <segment id="14">, durante os enterros de Carlos e Ismael</segment>
    <segment id="15">, amigos e parentes das vítimas fizeram questão de frisar que os rapazes não tinham envolvimento com o tráfico de drogas</segment>
    <segment id="16">, refutando informações que foram publicadas por setores da imprensa.</segment>
    <segment id="17">“</segment>
    <segment id="18">O pastor Raimundo era uma ótima pessoa</segment>
    <segment id="19">, muito querido e respeitado em toda a Suburbana.</segment>
    <segment id="20">É um absurdo a imprensa dizer que ele era envolvido com o tráfico.</segment>
    <segment id="21">A única arma que ele carregava era a Bíblia.</segment>
    <segment id="22">Os únicos cartuchos da arma dele são os 65 livros da Bíblia”</segment>
    <segment id="23">, defende Rafael de Jesus  Soares</segment>
    <segment id="24">, 21, fiel da igreja onde o pastor atuava.</segment>
    <segment id="25">Sem ficha na polícia</segment>
    <segment id="26">Segundo os amigos</segment>
    <segment id="27">, o pastor Raimundo pregava na Igreja Pentecostal Aperfeiçoamento dos Santos</segment>
    <segment id="28">, na localidade conhecida</segment>
    <segment id="29">comocomo Alto do Tororó</segment>
    <segment id="30">, região de São Tomé de Paripe.</segment>
    <segment id="31">“</segment>
    <segment id="32">Não sabemos</segment>
    <segment id="33">porque</segment>
    <segment id="34">porque mataram os três.</segment>
    <segment id="35">Não acho que tenha sido pelo tráfico de drogas.</segment>
    <segment id="36">Aqui tem muita rivalidade entre os bairros:</segment>
    <segment id="37">São Tomé</segment>
    <segment id="38">, Nova Brasília</segment>
    <segment id="39">, Alto dos Pontes e Tororó.

Pode ser isso</segment>
    <segment id="40">, masmas os três não tinham inimigos”</segment>
    <segment id="41">, argumenta o irmão de uma das vítimas.</segment>
    <segment id="42">Ismael e Carlos Augusto não tinham ficha na polícia.</segment>
    <segment id="43">O corpo de Raimundo será enterrado hoje.</segment>
    <segment id="44">Matadores trocam tiros com PMs</segment>
    <segment id="45">Segundo a polícia</segment>
    <segment id="46">, o trio foi morto por cinco assassinos</segment>
    <segment id="47">, que chegaram em um Fiat Uno (JYQ-0332)</segment>
    <segment id="48">, amarelo</segment>
    <segment id="49">, roubado pelos bandidos na Ilha de São João.</segment>
    <segment id="50">Um cliente fazia uma festa de aniversário na oficina.</segment>
    <segment id="51">Após a matança</segment>
    <segment id="52">, os criminosos trocaram tiros com policiais militares e fugiram por um matagal.</segment>
    <segment id="53">Policiais do Departamento de Homicídios afirmam que nenhum suspeito do crime foi preso</segment>
    <segment id="54">, ontem.</segment>
  </rst>
</analysis>