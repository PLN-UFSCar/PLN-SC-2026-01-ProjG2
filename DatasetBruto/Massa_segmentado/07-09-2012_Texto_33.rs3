    <segment id="102">Vias do Centro ficam fechadas para desfile
V횄징rias das principais vias do Centro ficaram fechadas para o desfile c횄짯vico do Dia da Independ횄짧ncia at횄</segment>
    <segment id="103">짤</segment>
    <segment id="104">as 14h</segment>
    <segment id="105">, o que provocou um engarrafamento no entorno durante a manh횄짙.</segment>
    <segment id="106">Com a Presidente Vargas parcialmente interditada</segment>
    <segment id="107">, as avenidas</segment>
    <segment id="108">Presidente Ant횄쨈nio Carlos</segment>
    <segment id="109">, Marechal C횄짖mara e General Justo ficaram com tr횄짖nsito muito lento</segment>
    <segment id="110">, assim</segment>
    <segment id="111">comocomo o Elevado da Perimetral</segment>
    <segment id="112">, sentido Centro.</segment>
    <segment id="113">O tr횄짖nsito procedente da Zona Norte (Pra횄짠a da Bandeira e Avenida Francisco Bicalho) com destino ao Centro ou 횄혻 Zona Sul</segment>
    <segment id="114">, dever횄징 seguir pela Avenida Presidente Vargas (pista lateral)</segment>
    <segment id="115">, Rua Carmo Neto</segment>
    <segment id="116">, Rua Benedito Hip횄쨀lito</segment>
    <segment id="117">, seguindo os condutores para seus destinos conforme sinaliza횄짠횄짙o indicativa de dire횄짠횄짙o</segment>
    <segment id="118">, dia 7</segment>
    <segment id="119">, das 5h at횄짤 o t횄짤rmino do evento.</segment>
    <segment id="120">J횄징 o tr횄짖nsito da Zona Norte (Avenida Rodrigues Alves) com destino ao Centro ou 횄혻 Zona Sul</segment>
    <segment id="121">, dever횄징 seguir pela Avenida Bar횄짙o de Tef횄짤</segment>
    <segment id="122">, Avenida Venezuela</segment>
    <segment id="123">, Pra횄짠a Mau횄징</segment>
    <segment id="124">, Avenida Rio Branco</segment>
    <segment id="125">, Rua Visconde de Inha횄쨘ma (m횄짙o invertida)</segment>
    <segment id="126">, Rua Primeiro de Mar횄짠o (m횄짙o invertida)</segment>
    <segment id="127">, Avenida Presidente Vargas e Avenida Alfredo Agache.</segment>
    <segment id="128">Motoqueiro transportando drogas 횄짤 preso na Ponte</segment>
    <segment id="129">No fim da madrugada</segment>
    <segment id="130">, o tr횄짖nsito chegou a ser interditado para a pris횄짙o de um motoqueiro tentou invadir a Base do Mocangu횄짧.</segment>
    <segment id="131">A base avisou a concession횄징ria que administra a via</segment>
    <segment id="132">, que acionou a Pol횄짯cia Rodovi횄징ria Federal.</segment>
    <segment id="133">O motoqueiro tentou fugir em dire횄짠횄짙o ao ped횄징gio</segment>
    <segment id="134">, no sentido Niter횄쨀i.</segment>
    <segment id="135">Agentes da PRF o esperaram no local e o prenderam.</segment>
    <segment id="136">Devido a isso</segment>
    <segment id="137">, a ponte precisou ter o tr횄짖nsito interditado por cerca de cinco minutos.</segment>
    <segment id="138">Com o preso</segment>
    <segment id="139">, foram apreendidas 45 c횄징psulas de coca횄짯na</segment>
