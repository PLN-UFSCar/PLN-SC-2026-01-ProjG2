    <segment id="72">, com tr횄짖nsito lento pela Avenida Brasil.
- Ficou t횄짙o lento que paramos para comer.</segment>
    <segment id="73">S횄짙o 12h30</segment>
    <segment id="74">m e ainda estamos em Itabora횄짯.</segment>
    <segment id="75">Na BR-101 estava muito moroso</segment>
    <segment id="76">, s횄쨀 melhorou agora - conta ela.</segment>
    <segment id="77">O congestionamento teria afetado at횄짤 mesmo a sa횄짯da de 횄쨈nibus da Rodovi횄징ria Novo Rio.</segment>
    <segment id="78">Segundo a administra횄짠횄짙o do terminal</segment>
    <segment id="79">, coletivos com destino 횄혻 Regi횄짙o dos Lagos chegaram a ter atrasos de at횄짤 uma hora durante a manh횄짙 devido ao tr횄짖nsito</segment>
    <segment id="80">, que estaria prendendo os ve횄짯culos no trecho.</segment>
    <segment id="81">Apenas por volta das 13h a sa횄짯da de 횄쨈nibus do terminal foi normalizada.</segment>
    <segment id="82">Novamente</segment>
    <segment id="83">, os viajantes reclamaram no Twitter da falta de informa횄짠횄짙o</segment>
    <segment id="84">, e tamb횄짤m da superlota횄짠횄짙o do local: "Rodovi횄징ria Novo Rio um caos!</segment>
    <segment id="85">Nem o monitor que avisa a chegada dos onibus funciona!</segment>
    <segment id="86">Ningu횄짤m sabe dar informa횄짠횄짙o!</segment>
    <segment id="87">", disse Diego Oliveira ?(@DCROliveira).</segment>
    <segment id="88">J횄징 Leonardo Martes (?@LEOMARTES) comentou a grande quantidade de pessoas</segment>
    <segment id="89">, aumentada pelos atrasos: "</segment>
    <segment id="90">Neste momento</segment>
    <segment id="91">, contando comigo</segment>
    <segment id="92">, tem 10 mil pessoas saindo da Rodovi횄징ria Novo Rio.</segment>
    <segment id="93">Caos total</segment>
    <segment id="94">, tudo parado!</segment>
    <segment id="95">".</segment>
    <segment id="96">Helena Ribeiro ?(@lenaribeiro) parecia j횄징 estar preparada para os problemas do dia: "</segment>
    <segment id="97">Primeira etapa do sofrimento</segment>
    <segment id="98">, rodovi횄징ria cheia.</segment>
    <segment id="99">Que venha o engarrafamento!</segment>
