  <rst>
    <segment id="1">Quem veio do interior não foi atendido</segment>
    <segment id="2">Com médicos em greve</segment>
    <segment id="3">, pacientes tiveram que remarcar os exames e as consultas</segment>
    <segment id="4">Após esperar quatro horas</segment>
    <segment id="5">, recebeu a notícia de que o procedimento foi remarcado para sábado</segment>
    <segment id="6">porque</segment>
    <segment id="7">porque o médico não apareceu.</segment>
    <segment id="8">“Desde  domingo</segment>
    <segment id="9">, meu marido só</segment>
    <segment id="10">sese alimentava de líquido por causa do exame”</segment>
    <segment id="11">, lamentou a lavradora.</segment>
    <segment id="12">“</segment>
    <segment id="13">A greve é justa</segment>
    <segment id="14">porque</segment>
    <segment id="15">porque eles precisam melhorar o salário e injusta</segment>
    <segment id="16">porque</segment>
    <segment id="17">porque a população sofre”</segment>
    <segment id="18">, completou Maria das Graças.</segment>
    <segment id="19">Após esperar dois meses pela consulta cardiológica e viajar por seis horas e meia</segment>
    <segment id="20">, a aposentada Helenita Moura Santos</segment>
    <segment id="21">, 61, vai voltar para Boa Vista do Tupim sem a avaliação para a cirurgia no ombro.</segment>
    <segment id="22">“Sinto dores e preciso do exame para operar”</segment>
    <segment id="23">, contou.</segment>
    <segment id="24">O mesmo aconteceu com a dona de casa Marinês de Jesus</segment>
    <segment id="25">, 21.</segment>
    <segment id="26">Depois de ter saído de Gameleira às 4h e pegar o ferry de 5 h</segment>
    <segment id="27">, ela não tirou os pontos do transplante de córnea realizado no último dia 22.</segment>
    <segment id="28">Os atendimentos de emergência e urgência estão garantidos na rede estadual</segment>
    <segment id="29">, masmas consultas</segment>
    <segment id="30">, exames e cirurgias marcados foram suspensos.

Adesão parcial:</segment>
    <segment id="31">Alguns conseguiram
Parte dos médicos não aderiu ao movimento no Hospital Roberto Santos.</segment>
    <segment id="32">Foi o caso</segment>
    <segment id="33">caso do ortopedista que atendeu o filho do lavrador José Antônio</segment>
    <segment id="34">, 58, que veio de Acajatiba</segment>
    <segment id="35">, a 200 Km da capital.</segment>
    <segment id="36">“Foi uma consulta de revisão.</segment>
    <segment id="37">Ele fraturou o maxilar.</segment>
    <segment id="38">Ainda bem que o médico estava atendendo”</segment>
    <segment id="39">, comemorou.</segment>
    <segment id="40">Mas a mãe do conferente Marcos Pimentel não teve a mesma sorte.</segment>
    <segment id="41">“</segment>
    <segment id="42">Ele tinha uma ressonância marcada para hoje (ontem)</segment>
    <segment id="43">, masmas foi transferida para sexta-feira</segment>
    <segment id="44">porque</segment>
    <segment id="45">porque o médico não apareceu”</segment>
    <segment id="46">, relata.</segment>
    <segment id="47">A mãe de Marcos está internada no Roberto Santos há 11 dias devido a um derrame cerebral.</segment>
    <segment id="48">Segundo o diretor da unidade</segment>
    <segment id="49">, Paulo Bicalho</segment>
    <segment id="50">, a minoria dos profissionais aderiu à greve.</segment>
    <segment id="51">Em balanço da Secretaria Estadual de Saúde</segment>
    <segment id="52">, dos médicos que trabalham em ambulatórios de  unidades estaduais</segment>
    <segment id="53">, apenas 39 faltaram</segment>
    <segment id="54">, contestando informações divulgadas pelos sindicalistas sobre a adesão ao movimento.</segment>
    <segment id="55">Está sofrendo com a grave dos médicos?</segment>
    <segment id="56">Conte-nos.</segment>
  </rst>
</analysis>