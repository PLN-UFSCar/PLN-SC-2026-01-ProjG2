  <rst>
    <segment id="1">Ladrões atiram</segment>
    <segment id="2">, masmas não levam o dinheiro</segment>
    <segment id="3">Quando os ladrões abordaram Mário</segment>
    <segment id="4">, ele não estava mais com os R$ 31 mil em seu poder</segment>
    <segment id="5">Os dois homens em uma moto que atiraram no empresário Mário César Ferreira</segment>
    <segment id="6">, 42 anos</segment>
    <segment id="7">, na tarde da última segunda</segment>
    <segment id="8">, na Calçada</segment>
    <segment id="9">, não levaram os  R$ 31 mil.</segment>
    <segment id="10">De acordo com informações da 3ª DT (Bonfim)</segment>
    <segment id="11">, o dinheiro já havia sido depositado por um funcionário da empresa de Mário</segment>
    <segment id="12">, a Attacknet</segment>
    <segment id="13">,  na agência do Banco Bradesco</segment>
    <segment id="14">, na Avenida Barão de Cotegipe.</segment>
    <segment id="15">Por volta de 14h15</segment>
    <segment id="16">, o empresário saiu da empresa</segment>
    <segment id="17">, no Bahia Outlet Center</segment>
    <segment id="18">,  no Uruguai</segment>
    <segment id="19">, deixou o funcionário na agência</segment>
    <segment id="20">,  seguia para o dentista e</segment>
    <segment id="21">, no caminho</segment>
    <segment id="22">, foi abordado pelos bandidos.</segment>
    <segment id="23">“</segment>
    <segment id="24">Sabemos que não conseguiram levar o dinheiro</segment>
    <segment id="25">, que  já havia sido depositado”</segment>
    <segment id="26">, afirmou  a delegada titular da 3ª DT</segment>
    <segment id="27">, Vânia Matos.</segment>
    <segment id="28">A informação foi passada pelo sócio de Mário.</segment>
    <segment id="29">Policiais da unidade não conseguiram falar com a vítima para obter detalhes sobre ação dos bandidos</segment>
    <segment id="30">porque</segment>
    <segment id="31">porque ele estava na UTI.</segment>
    <segment id="32">Internado</segment>
    <segment id="33">, empresário segue na UTI</segment>
    <segment id="34">Até o início da noite de ontem</segment>
    <segment id="35">, Mário seguia internado na UTI do HGE</segment>
    <segment id="36">, para onde foi levado.</segment>
    <segment id="37">Segundo a assessoria da Secretaria  de Saúde do Estado</segment>
    <segment id="38">, o empresário foi submetido a exames.</segment>
    <segment id="39">O quadro dele é estável</segment>
    <segment id="40">, masmas não havia previsão de alta.</segment>
    <segment id="41">O pai de Mário</segment>
    <segment id="42">, César Ferreira</segment>
    <segment id="43">, 60, disse que o tiro atingiu o intestino do filho</segment>
    <segment id="44">, que  reclamava de dores nas costas e não sentia as pernas.</segment>
    <segment id="45">A família queria transferi-lo para  hospital particular.</segment>
  </rst>
</analysis>