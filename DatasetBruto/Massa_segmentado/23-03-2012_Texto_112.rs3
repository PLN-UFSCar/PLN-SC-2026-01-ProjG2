  <rst>
    <segment id="1">Não punam os inocentes</segment>
    <segment id="2">A discussão sobre torcida única nos Ba-Vis está programada para o próximo dia 29</segment>
    <segment id="3">Nas décadas de 70</segment>
    <segment id="4">, 80 e 90</segment>
    <segment id="5">, a Ladeira da Fonte das Pedras</segment>
    <segment id="6">, ao lado do Estádio Octávio Mangabeira</segment>
    <segment id="7">, era o ponto de encontro de amigos tricolores e rubro-negros antes e após os clássicos</segment>
    <segment id="8">, seja qual fosse o resultado.</segment>
    <segment id="9">Nos bares</segment>
    <segment id="10">, eles travavam uma rivalidade sadia</segment>
    <segment id="11">, com a costumeira gozação sobre o lado perdedor.</segment>
    <segment id="12">No final</segment>
    <segment id="13">, todos voltavam para suas casas sãos e salvos.</segment>
    <segment id="14">Agora, o Ministério Público</segment>
    <segment id="15">, a Polícia Militar e a Federação Baiana de Futebol (FBF) em face dos vários episódios de violência entre as duas maiores torcidas organizadas (Bamor e Os Imbatíveis) de Bahia e Vitória</segment>
    <segment id="16">, articulam uma reunião para o próximo dia 29 de março</segment>
    <segment id="17">, quando será discutida a possibilidade de</segment>
    <segment id="18">sese colocar uma torcida única nos Ba-Vis daqui por diante.</segment>
    <segment id="19">MASSA!</segment>
    <segment id="20">ouviu torcedores dos dois clubes e alguns deram esta sugestão: no clássico de Pituaçu ficaria proibida a presença de Os Imbatíveis e outras organizadas rubro-negras e</segment>
    <segment id="21">, no Barradão</segment>
    <segment id="22">, da Bamor e demais organizadas tricolores.</segment>
    <segment id="23">Está provado que a violência ocorre antes e após os Ba-Vis</segment>
    <segment id="24">, masmas fora dos estádios</segment>
    <segment id="25">, principalmente durante a condução das duas maiores torcidas pela PM para as praças esportivas.</segment>
    <segment id="26">Vale ressaltar que</segment>
    <segment id="27">, tanto a Bamor quanto</segment>
    <segment id="28">Os Imbatíveis têm projetos sociais de grande valia</segment>
    <segment id="29">, masmas</segment>
    <segment id="30">, infelizmente</segment>
    <segment id="31">, alguns integrantes resolveram importar o comportamento das “organizadas” de São Paulo e Rio de Janeiro</segment>
    <segment id="32">, e aqui isso é reprovado.</segment>
  </rst>
</analysis>