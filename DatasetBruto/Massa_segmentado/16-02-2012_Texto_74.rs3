  <rst>
    <segment id="1">Esquadrão sem freio no topo
Felicidade Magno marcou o primeiro gol do tricolor e não segurou a alegria</segment>
    <segment id="2">O Bahia continua embalado no Baianão: venceu a oitava partida seguida e</segment>
    <segment id="3">, de quebra</segment>
    <segment id="4">, conquistou a liderança do Estadual.</segment>
    <segment id="5">Desta vez</segment>
    <segment id="6">, a vítima foi o Fluminense</segment>
    <segment id="7">, que saiu ontem de Pituaçu com uma goleada de 4  a 0.</segment>
    <segment id="8">Com gols de Magno</segment>
    <segment id="9">, Fahel</segment>
    <segment id="10">, Hélder e Lenine</segment>
    <segment id="11">, todos no segundo tempo</segment>
    <segment id="12">, o tricolor desbancou o Touro do Sertão.</segment>
    <segment id="13">Com a derrota do Bahia de Feira para o Juazeirense</segment>
    <segment id="14">, o tricolor agora é líder absoluto</segment>
    <segment id="15">, com 23 pontos.</segment>
    <segment id="16">Seis a mais que o rival</segment>
    <segment id="17">Vitória e sete à frente do quinto colocado</segment>
    <segment id="18">, o Atlético.</segment>
    <segment id="19">O técnico Falcão apostou em Magno para substituir Morais.</segment>
    <segment id="20">O meia não fez uma  partida para encher os olhos dos torcedores</segment>
    <segment id="21">, entretanto</segment>
    <segment id="22">, dos pés dele</segment>
    <segment id="23">, surgiu o primeiro gol</segment>
    <segment id="24">, o que deu ânimo à equipe.</segment>
    <segment id="25">Ele e Gabriel comandaram o meio-campo tricolor.</segment>
    <segment id="26">O triunfo poderia ser construído logo no primeiro tempo.</segment>
    <segment id="27">O Esquadrão foi infinitamente superior ao Touro.</segment>
    <segment id="28">Só que a equipe do técnico Falcão só garantiu o triunfo na segunda etapa: 4 a 0 sem pena.</segment>
  </rst>
</analysis>