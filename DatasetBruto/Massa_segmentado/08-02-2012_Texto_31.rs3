  </header>
  <rst>
    <segment id="1">Terror continua.</segment>
    <segment id="2">Nada decidido..</segment>
    <segment id="3">O principal ponto da negociação refere-</segment>
    <segment id="4">sese à punição dos PMs acusados de vandalismo</segment>
    <segment id="5">A reunião entre representantes das associações policiais e do governo</segment>
    <segment id="6">, intermediada pelo arcebispo de Salvador e Primaz do Brasil</segment>
    <segment id="7">, Dom Murilo Krieger</segment>
    <segment id="8">, teve uma breve pausa no início de ontem.</segment>
    <segment id="9">“</segment>
    <segment id="10">A Bahia quer paz.</segment>
    <segment id="11">Venho conclamar todos – Governo</segment>
    <segment id="12">, associações de militares</segment>
    <segment id="13">, homens e mulheres de boa-vontade – para</segment>
    <segment id="14">, juntos</segment>
    <segment id="15">, construirmos a paz”</segment>
    <segment id="16">, clamou o arcebispo.</segment>
    <segment id="17">O principal ponto da negociação refere-</segment>
    <segment id="18">sese à punição dos manifestantes acusados de atos de vandalismo.</segment>
    <segment id="19">Segundo o defensor público de prenome Gilmar</segment>
    <segment id="20">, as negociações estão avançadas.</segment>
    <segment id="21">Mas, de acordo com o advogado do presidente da Aspra</segment>
    <segment id="22">, Marco Prisco</segment>
    <segment id="23">, ainda não há novidades nas negociações.</segment>
    <segment id="24">"</segment>
    <segment id="25">Queremos anistia administrativa</segment>
    <segment id="26">, revogação das prisões e pagamento da Gratificação por Atividade Policial 4 e 5</segment>
    <segment id="27">, as chamadas GAP.</segment>
    <segment id="28">Somente com essas três reivindicações a greve terá fim"</segment>
    <segment id="29">,  disse.</segment>
    <segment id="30">Os policiais militares grevistas conseguiram em negociação</segment>
    <segment id="31">, na madrugada de ontem</segment>
    <segment id="32">, a liberação da entrada de pão</segment>
    <segment id="33">, água</segment>
    <segment id="34">, medicamentos e material de higiene na Assembleia Legislativa</segment>
    <segment id="35">, onde estão acampados.</segment>
    <segment id="36">Ainda ontem</segment>
    <segment id="37">, os amotinados cantaram o Hino da Polícia Militar  e oraram com os PMs e familiares que estão do lado de fora do CAB</segment>
    <segment id="38">, demonstrando que a ação dos dois grupos é articulada.</segment>
    <segment id="39">Os funcionários dos órgãos instalados no CAB já têm acesso liberado.</segment>
    <segment id="40">É  possível transitar pela região de carro ou a pé.</segment>
    <segment id="41">Para isso</segment>
    <segment id="42">, eles precisam apresentar crachá ou outra identificação funcional.</segment>
    <segment id="43">Bolo para comemorar</segment>
    <segment id="44">Em meio ao tumulto</segment>
    <segment id="45">, o general Gonçalves Dias</segment>
    <segment id="46">, comandante das forças de segurança na Bahia durante a greve da Polícia Militar</segment>
    <segment id="47">, foi homenageado e ganhou dos manifestantes</segment>
    <segment id="48">comocomo presente de aniversário um bolo confeitado com direito a “Parabéns pra você!”.</segment>
    <segment id="49">Dias, que completou 62 anos</segment>
    <segment id="50">, sese aproximou da grade que separa a tropa de 800 homens do Exército das famílias acampadas e agradeceu.</segment>
    <segment id="51">"</segment>
    <segment id="52">Não vamos entrar em confronto...</segment>
    <segment id="53">Vocês foram atendidos</segment>
    <segment id="54">, pelo que eu sei</segment>
    <segment id="55">, em bastante reivindicações.</segment>
    <segment id="56">É meu aniversário</segment>
    <segment id="57">, cara!</segment>
    <segment id="58">", brincou o general ao abraçar um dos grevistas.</segment>
  </rst>
</analysis>