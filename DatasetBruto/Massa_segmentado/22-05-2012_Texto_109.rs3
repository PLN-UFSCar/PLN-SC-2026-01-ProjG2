  <rst>
    <segment id="1">Faturando com a greve dos motôs
Mototaxistas e motoristas de transporte clandestino ficam cheios de grana</segment>
    <segment id="2">A greve dos rodoviários  causa muitos  transtornos e prejudica cerca de 1 milhão de pessoas em Salvador.</segment>
    <segment id="3">Mas, para uma categoria específica</segment>
    <segment id="4">, a greve traz só benefícios.</segment>
    <segment id="5">Com os buzus fora de circulação</segment>
    <segment id="6">, os mototaxistas faturam alto.</segment>
    <segment id="7">No ramo há cerca de um ano</segment>
    <segment id="8">, Alex Rosário afirma que ontem</segment>
    <segment id="9">, primeiro dia da greve</segment>
    <segment id="10">, lucrou 70% mais do  que consegue em dias normais.</segment>
    <segment id="11">“E digo mais: só não fiz 100%</segment>
    <segment id="12">porque</segment>
    <segment id="13">porque há muitas empresas mandando o carro  pegar (funcionários) em casa e há gente que pega carona com o colega”</segment>
    <segment id="14">, explica o mototaxista</segment>
    <segment id="15">, que antes era entregador de pizza.</segment>
    <segment id="16">Apesar do lucro acima da média</segment>
    <segment id="17">, alguns mototaxistas  não estão satisfeitos.</segment>
    <segment id="18">Para eles</segment>
    <segment id="19">, devido às chuvas que castigam Salvador e ao fato da data não coincidir com o pagamento dos salários</segment>
    <segment id="20">, os soteropolitanos não estão fazendo tanta questão de usar o serviço.</segment>
    <segment id="21">“Quando chove</segment>
    <segment id="22">, é sempre mais difícil.</segment>
    <segment id="23">O povo também está sem dinheiro.</segment>
    <segment id="24">Para se</segment>
    <segment id="25">se ter uma ideia</segment>
    <segment id="26">, na última paralisação</segment>
    <segment id="27">, que só durou 3 horas</segment>
    <segment id="28">,  consegui fazer mais corridas que nessa de agora”</segment>
    <segment id="29">, conta Ricardo dos  Santos.</segment>
    <segment id="30">Mesmo sendo uma alternativa para os dias de greve</segment>
    <segment id="31">, uma corrida de mototáxi costuma ser mais cara que a passagem dos ônibus convencionais.</segment>
    <segment id="32">Nenhuma moto sai do ponto por menos de R$ 3 e o valor só vai aumentando conforme a distância.</segment>
    <segment id="33">Ainda assim</segment>
    <segment id="34">, a condução é a favorita do técnico de telecomunicações Teórgenes Ferreira: “</segment>
    <segment id="35">Mesmo sem greve</segment>
    <segment id="36">,  sempre pego mototáxi.</segment>
    <segment id="37">Me livro de engarrafamento e ganho tempo para fazer as coisas”.</segment>
    <segment id="38">Clandestinos são alternativa</segment>
    <segment id="39">Os donos de transportes clandestinos aproveitaram a situação.</segment>
    <segment id="40">Nos principais pontos de ônibus</segment>
    <segment id="41">, vans</segment>
    <segment id="42">, kombis</segment>
    <segment id="43">, carros  particulares e ônibus de empresas desconhecidas e  sem autorização ou fiscalização da prefeitura</segment>
    <segment id="44">, muitos em condições precárias de uso</segment>
    <segment id="45">, recebiam passageiros agoniados para chegar aos seus destinos.</segment>
    <segment id="46">Na Suburbana</segment>
    <segment id="47">, um ônibus particular</segment>
    <segment id="48">, placa NTU-1043</segment>
    <segment id="49">, de Salvador</segment>
    <segment id="50">, levou pelo menos cinco passageiros que esperavam em um ponto de Paripe.</segment>
    <segment id="51">A passagem saiu por R$ 2</segment>
    <segment id="52">,50, a mesma do sistema regular.</segment>
    <segment id="53">“Espero desde as 4h da manhã.</segment>
    <segment id="54">Sou mãe de família e tenho apenas alguns dias de emprego</segment>
    <segment id="55">, não posso faltar”</segment>
    <segment id="56">, afirmou</segment>
    <segment id="57">, às 8h30 de ontem</segment>
    <segment id="58">, a empregada doméstica Graça</segment>
    <segment id="59">, 47.</segment>
  </rst>
</analysis>