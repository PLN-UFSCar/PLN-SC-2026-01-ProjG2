  <rst>
    <segment id="1">Abel Braga diz que mudança de ambiente foi crucial para arrancada do Fluminense
RIO - A frase do hino do Fluminense descreve o capítulo atual de sua história:</segment>
    <segment id="2">"</segment>
    <segment id="3">Quem espera sempre alcança".</segment>
    <segment id="4">O verso de Lamartine Babo composto no século passado entra na era digital</segment>
    <segment id="5">comocomo sinônimo da paciência e esperança por dias melhores.</segment>
    <segment id="6">Da terra arrasada do primeiro semestre ao terreno fértil e propício para a colheita de mais um título</segment>
    <segment id="7">, o clube desfruta do ambiente semeado por Abel Braga nas Laranjeiras.</segment>
    <segment id="8">Além de tirar a diferença para os líderes na tabela</segment>
    <segment id="9">, o técnico ganhou pontos ao unir patrocinador com presidente</segment>
    <segment id="10">, dar proteção incondicional aos jogadores e continuar firme diante das vaias de uma torcida impaciente.</segment>
    <segment id="11">A espera por Abel durou uma estação.</segment>
    <segment id="12">Nos três meses de Enderson Moreira</segment>
    <segment id="13">, o time jogou um futebol provisório</segment>
    <segment id="14">, aquém do que poderia.</segment>
    <segment id="15">Ao ouvir as recusas de técnicos consagrados</segment>
    <segment id="16">, a nova diretoria conheceu de perto velhos hábitos dos bastidores de um universo que Abel conhece bem.</segment>
    <segment id="17">Para juntar os cacos da saída de Muricy Ramalho</segment>
    <segment id="18">, da polêmica com Emerson e das divergências com o patrocinador</segment>
    <segment id="19">, o técnico começou por dentro</segment>
    <segment id="20">, no vestiário.

- Nosso ponto de virada foi o tempo</segment>
    <segment id="21">, a convivência.</segment>
    <segment id="22">O ambiente ficou muito melhor no segundo semestre.</segment>
    <segment id="23">E, sese tem uma coisa que eu sei fazer</segment>
    <segment id="24">, é formar um bom ambiente</segment>
    <segment id="25">, no qual todos</segment>
    <segment id="26">sese falam</segment>
    <segment id="27">, existe o diálogo.</segment>
    <segment id="28">Isto nos deixa unidos.</segment>
    <segment id="29">E só é possível unir um grupo falando a verdade.</segment>
    <segment id="30">Eu protejo muito os jogadores do que vem de fora.</segment>
    <segment id="31">Mas cobro demais nos bastidores.</segment>
    <segment id="32">Mas sempre com sinceridade e honestidade.</segment>
    <segment id="33">Assim, o jogador corre por ele</segment>
    <segment id="34">, pelo clube e pelo treinador - declarou Abel.</segment>
    <segment id="35">Da tensão ao otimismo das rodadas finais</segment>
    <segment id="36">, os jogadores</segment>
    <segment id="37">sese transformaram na medida que as primeiras colocações</segment>
    <segment id="38">sese aproximavam.</segment>
    <segment id="39">Para uma equipe que tinha 15 pontos de diferença para o líder</segment>
    <segment id="40">, o tempo foi o remédio para vencer a desconfiança e a distância.</segment>
    <segment id="41">Prova do ambiente tão falado e pouco visível esteve na pele do atacante Araújo.</segment>
    <segment id="42">Vestido de terno</segment>
    <segment id="43">, gravata e chapéu</segment>
    <segment id="44">, o coadjuvante roubou a cena.</segment>
    <segment id="45">O que começou</segment>
    <segment id="46">comocomo uma brincadeira interna ganhou o mundo e deu esperança a Araújo.</segment>
    <segment id="47">Assim como</segment>
    <segment id="48">como o Fluminense</segment>
    <segment id="49">, ele esperou com paciência e</segment>
    <segment id="50">, mesmo</segment>
    <segment id="51">comocomo reserva</segment>
    <segment id="52">, espera ter algo de bom para ele nos próximos jogos.</segment>
    <segment id="53">-</segment>
    <segment id="54">É bom ter alegria e levar isto para o campo.</segment>
    <segment id="55">Nosso ambiente é muito bom e isto poderá ajudar a alcançar nossa meta</segment>
    <segment id="56">, que é o título.</segment>
    <segment id="57">Eles duvidaram que eu tinha terno</segment>
    <segment id="58">, então eu provei...</segment>
    <segment id="59">Nem sempre o Fluminense esteve tão vistoso.</segment>
    <segment id="60">Quando o time não jogava o fino</segment>
    <segment id="61">, a torcida pichava.</segment>
    <segment id="62">O muro das Laranjeiras e o treinador.</segment>
    <segment id="63">Apesar do apelido no aumentativo e da grande estatura</segment>
    <segment id="64">, Abel ficou magoado e passou pela sua cabeça não mais comandar o time.</segment>
    <segment id="65">A frase "</segment>
    <segment id="66">Fora Abel" foi apagada</segment>
    <segment id="67">, masmas segue escrita na memória do treinador tricolor.

- Existem coisas que magoam</segment>
    <segment id="68">, a gente sente...</segment>
    <segment id="69">Mas eu levo a sério o meu trabalho.</segment>
    <segment id="70">Tem coisas que fizeram e me desagradaram.</segment>
    <segment id="71">Então, eu penso que</segment>
    <segment id="72">, sese não estou feliz</segment>
    <segment id="73">, vou embora</segment>
    <segment id="74">embora.</segment>
    <segment id="75">Eu não peço mais para torcedor encher estádio</segment>
    <segment id="76">, masmas também não lamento nenhuma atitude ou manifestação da torcida</segment>
    <segment id="77">, que é soberana.</segment>
    <segment id="78">A torcida quer resultado</segment>
    <segment id="79">, título</segment>
    <segment id="80">, quer ver o time ganhar</segment>
    <segment id="81">,</segment>
    <segment id="82">é normal.</segment>
    <segment id="83">E nós trabalhamos muito</segment>
    <segment id="84">, porque</segment>
    <segment id="85">porque queremos as mesmas coisas que eles.</segment>
    <segment id="86">Sentimos do mesmo jeito - afirmou Abel.</segment>
    <segment id="87">Vencer o Internacional no Beira-Rio fez do Fluminense um candidato forte ao título.</segment>
    <segment id="88">E Abel provou a sua teoria.</segment>
    <segment id="89">A torcida gritou seu nome e estampou seu rosto em uma bandeira.</segment>
    <segment id="90">O legado continua mesmo quando ele é adversário.</segment>
    <segment id="91">Tricolor de coração</segment>
    <segment id="92">, o treinador é querido em Porto Alegre pelo lado racional.</segment>
    <segment id="93">Afinal</segment>
    <segment id="94">, em 2006 venceu a Libertadores e o Mundial contra o Barcelona.</segment>
    <segment id="95">Adriano Gabiru</segment>
    <segment id="96">, autor do gol do título</segment>
    <segment id="97">, não era unanimidade</segment>
    <segment id="98">, como</segment>
    <segment id="99">como há no elenco tricolor jogadores que não agradam a torcida</segment>
    <segment id="100">, masmas são importantes para Abel.</segment>
    <segment id="101">A paciência e a insistência do treinador foram recompensadas.</segment>
    <segment id="102">Este é o seu ponto de vista na temporada:

- Eu estou tentando construir aqui no Fluminense o que eu fiz no Internacional.</segment>
    <segment id="103">Aquilo que aconteceu no domingo prova que alguma coisa boa da nossa passagem ficou no Internacional para sempre.</segment>
    <segment id="104">Título é marcante para ambos os lados.</segment>
    <segment id="105">Em caso</segment>
    <segment id="106">caso do bicampeonato inédito</segment>
    <segment id="107">, a galeria de heróis tricolores aumentará significativamente.</segment>
    <segment id="108">Depois de 2008</segment>
    <segment id="109">, vencer a Libertadores também é uma obsessão.</segment>
    <segment id="110">Por isto</segment>
    <segment id="111">, a costura entre todas as partes pela manutenção do bom ambiente é constante.</segment>
    <segment id="112">Nesta quarta-feira</segment>
    <segment id="113">, Abel</segment>
    <segment id="114">sese reúne com o patrocinador e o vice de futebol Sandro Lima para falar do presente e do futuro.</segment>
    <segment id="115">As reuniões têm sido quinzenais e teve em Abel e em Sandro os condutores de uma aproximação entre Peter Siemsen e Celso Barros</segment>
    <segment id="116">, que se</segment>
    <segment id="117">se afastaram depois do episódio com Muricy.

- Todos</segment>
    <segment id="118">sese entendem muito bem - disse Abel.</segment>
    <segment id="119">Na próxima rodada</segment>
    <segment id="120">, o time enfrentará o América-MG no Engenhão.</segment>
    <segment id="121">Diante do lanterna</segment>
    <segment id="122">, um adversário que não vence desde 1958</segment>
    <segment id="123">, Abel pede cuidado</segment>
    <segment id="124">, masmas sabe que chegou a hora de alcançar a liderança</segment>
    <segment id="125">, mesmo provisória</segment>
    <segment id="126">, depois de tantos meses de espera:

- O Corinthians nos alertou.</segment>
    <segment id="127">Não ganhamos nada e vamos jogar com seriedade.</segment>
  </rst>
</analysis>