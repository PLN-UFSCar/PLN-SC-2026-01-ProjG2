  <rst>
    <segment id="1">MotГѓВґ</segment>
    <segment id="2">ГѓВ© apagado com 4 balaГѓВ§os
Valter foi alvejado por dois homens que estavam em um carro</segment>
    <segment id="3">, ГѓВ s 5h da manhГѓВЈ</segment>
    <segment id="4">Como de costume</segment>
    <segment id="5">, o motorista de ГѓВґnibus Valter Ferreira dos Santos</segment>
    <segment id="6">, 52 anos</segment>
    <segment id="7">, saiu de casa</segment>
    <segment id="8">, na Rua Almirante Saldanha</segment>
    <segment id="9">,  por volta de 5h da manhГѓВЈ de ontem para o trabalho</segment>
    <segment id="10">, na empresa Cidade das Гѓguas</segment>
    <segment id="11">, na Rua  Washington Luiz</segment>
    <segment id="12">, ambos  no bairro Parque PetrГѓВіpolis</segment>
    <segment id="13">, em Dias DГўв‚¬в„ў</segment>
    <segment id="14">Гѓvila.</segment>
    <segment id="15">A cerca de 200 metros da casa onde morava com a famГѓВ­lia</segment>
    <segment id="16">, Valter foi executado com  quatro dos sete tiros de pistola 380 direcionados  a ele.</segment>
    <segment id="17">Os projГѓВ©teis atingiram as costas</segment>
    <segment id="18">, glГѓВєteo e tГѓВіrax da vГѓВ­tima</segment>
    <segment id="19">, que morreu no local.</segment>
    <segment id="20">Em protesto</segment>
    <segment id="21">, colegas dele paralisaram as atividades por cerca de duas horas na praГѓВ§a de Nova Dias DГўв‚¬в„ў</segment>
    <segment id="22">Гѓvila.</segment>
    <segment id="23">O protesto chegou ao fim apГѓВіs os motoristas saberem que Valter nГѓВЈo havia sido assassinado no desempenho de suas funГѓВ§ГѓВµes.</segment>
    <segment id="24">InformaГѓВ§ГѓВµes colhidas pela polГѓВ­cia dГѓВЈo conta de que os tiros vieram de dentro de um carro</segment>
    <segment id="25">, cuja identificaГѓВ§ГѓВЈo ainda ГѓВ© desconhecida.</segment>
    <segment id="26">AlГѓВ©m disso</segment>
    <segment id="27">, duas pessoas estariam no veГѓВ­culo</segment>
    <segment id="28">, com seus rostos descobertos.</segment>
    <segment id="29">Na Rua Almirante Saldanha</segment>
    <segment id="30">, fala-</segment>
    <segment id="31">sese em um carro  branca.</segment>
    <segment id="32">Гўв‚¬Е“De imediato foi descartada a hipГѓВіtese de assalto</segment>
    <segment id="33">, jГѓВЎ que nГѓВЈo houve rendiГѓВ§ГѓВЈo e nem levaram nenhum pertence da vГѓВ­tima.</segment>
    <segment id="34">As evidГѓВЄncias apontam para um crime com motivaГѓВ§ГѓВЈo passionalГўв‚¬.  afirmou o coordenador de investigaГѓВ§ГѓВЈo da 25Г‚ВЄ DT (Delegacia de Dias DГўв‚¬в„ўГѓvila)</segment>
    <segment id="35">, Edmundo JГѓВєnior.</segment>
    <segment id="36">Гўв‚¬Е“NГѓВЈo descartamos nenhuma possibilidade.</segment>
    <segment id="37">Quem matou</segment>
    <segment id="38">, matou por raiva ou vinganГѓВ§aГўв‚¬</segment>
    <segment id="39">, completou.</segment>
    <segment id="40">Passageiro jura vinganГѓВ§a</segment>
    <segment id="41">Parentes relataram que</segment>
    <segment id="42">, hГѓВЎ alguns dias</segment>
    <segment id="43">, Valter discutiu com um casal de passageiros que queria viajar sem pagar a passagem de ГѓВґnibus.</segment>
    <segment id="44">Os passageiros teriam dito:</segment>
    <segment id="45">Гўв‚¬Е“Isso nГѓВЈo vai ficar assim.</segment>
    <segment id="46">Vai ter voltaГўв‚¬. Por telefone</segment>
    <segment id="47">, uma filha de Valter contou que ele recebeu uma ameaГѓВ§a de morte por telefone de uma mulher.</segment>
    <segment id="48">Valter era natural da cidade de Valente (distante 229 km de Salvador) e morava</segment>
    <segment id="49">, em Dias DГўв‚¬в„ў</segment>
    <segment id="50">Гѓvila, hГѓВЎ</segment>
    <segment id="51">mais de 20 anos</segment>
    <segment id="52">,</segment>
    <segment id="53">segundo familiares.</segment>
    <segment id="54">Pai de trГѓВЄs filhos e avГѓВґ de quatro netos</segment>
    <segment id="55">, ele foi descrito</segment>
    <segment id="56">comocomo um homem reservado.</segment>
    <segment id="57">Ontem mesmo</segment>
    <segment id="58">, a famГѓВ­lia  viajou  para sepultГѓВЎ-lo em Valente</segment>
    <segment id="59">, para onde ele pretendia voltar apГѓВіs</segment>
    <segment id="60">sese aposentar.</segment>
  </rst>
