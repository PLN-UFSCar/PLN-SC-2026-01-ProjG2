  <rst>
    <segment id="1">Grupo de PM quer aderir ao movimento</segment>
    <segment id="2">Uma das entidades radicaliza</segment>
    <segment id="3">, o Comando não reconhece o fato e tranquiliza população</segment>
    <segment id="4">Tensão e jogo de empurra marcaram o segundo dia de paralisação dos policiais militares que seguem as orientações da Associação dos  Policiais</segment>
    <segment id="5">, Bombeiros e de seus Familiares do Estado (Aspra).</segment>
    <segment id="6">À tarde</segment>
    <segment id="7">, cerca de 80 deles hostilizaram uma equipe do Esquadrão Águia que estava em serviço no Centro Administrativo da Bahia (CAB).</segment>
    <segment id="8">Os grevistas que</segment>
    <segment id="9">, até o fechamento desta edição</segment>
    <segment id="10">, permaneciam concentrados no prédio da Assembleia Legislativa</segment>
    <segment id="11">, no CAB (onde passaram a noite anterior)</segment>
    <segment id="12">, surpreenderam colegas do Esquadrão  Águia</segment>
    <segment id="13">, na Avenida 1.</segment>
    <segment id="14">Lá, bloquearam a pista para  impedir o fluxo de veículos.</segment>
    <segment id="15">"</segment>
    <segment id="16">O pessoal do Águia é o único que não parou.</segment>
    <segment id="17">Só vamos sair da pista quando eles pararem de retaliar”</segment>
    <segment id="18">, reclamou um dos grevistas.</segment>
    <segment id="19">A viatura do Águia</segment>
    <segment id="20">, uma GM Blazer</segment>
    <segment id="21">, teve os pneus dianteiros furados.</segment>
    <segment id="22">Enquanto isso</segment>
    <segment id="23">, motoristas subiam o canteiro central para desviar do bloqueio montado pelos manifestantes.</segment>
    <segment id="24">A confusão</segment>
    <segment id="25">, que incluiu gritos de “covardes” aos policiais em serviço</segment>
    <segment id="26">, durou cerca de 15 minutos.</segment>
    <segment id="27">Alguns grevistas tentavam convencer os fardados a aderir ao movimento.</segment>
    <segment id="28">“</segment>
    <segment id="29">Em todos os segmentos existe o bom e o mau profissional.</segment>
    <segment id="30">Estamos trabalhando normalmente”</segment>
    <segment id="31">, falou o major Paulo José Coutinho</segment>
    <segment id="32">, comandante do Esquadrão Águia.</segment>
    <segment id="33">Nas ruas</segment>
    <segment id="34">, há pessoas assustadas com boatos de crimes cometidos</segment>
    <segment id="35">p or conta da falta de policiais e outras que sequer sabem  do movimento de parte da categoria.</segment>
  </rst>
