    <segment id="2">, a ministra da Cultura</segment>
    <segment id="3">, Ana de Hollanda</segment>
    <segment id="4">, agora</segment>
    <segment id="5">sese diz satisfeita com a perspectiva de elevaГѓВ§ГѓВЈo dos recursos destinados a sua ГѓВЎrea em 2013 para R$ 2</segment>
    <segment id="6">,83 bilhГѓВµes</segment>
