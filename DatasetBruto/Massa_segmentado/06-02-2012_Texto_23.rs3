  <rst>
    <segment id="1">Assembleia pede retirada de PMs
Marcelo Nilo</segment>
    <segment id="2">, presidente da Casa</segment>
    <segment id="3">, pediu ao Exército que retirassem os grevistas</segment>
    <segment id="4">O presidente da Assembleia Legislativa da Bahia Marcelo Nilo estabeleceu a meia-noite de ontem</segment>
    <segment id="5">comocomo prazo máximo para retirada dos policiais militares em greve do prédio da Assembleia.</segment>
    <segment id="6">“</segment>
    <segment id="7">A Assembleia não pode ser usada</segment>
    <segment id="8">comocomo abrigo para foragidos da Justiça”</segment>
    <segment id="9">, disse o deputado.</segment>
    <segment id="10">A solução</segment>
    <segment id="11">, agora</segment>
    <segment id="12">, está a cargo do do general Gonçalves Dias</segment>
    <segment id="13">, comandante da 6ª Região Militar</segment>
    <segment id="14">, que convocou uma reunião com os outros comandantes que participam da operação de segurança de Salvador para avaliar o</segment>
    <segment id="15">casocaso.</segment>
    <segment id="16">Os policias em greve descartaram a possibilidade de violência com a entrada da tropa de elite da PF por conta da presença de mulheres e crianças que estão no local.</segment>
    <segment id="17">No entanto</segment>
    <segment id="18">, não descartaram a possibilidade de confronto</segment>
    <segment id="19">, caso</segment>
    <segment id="20">caso atirassem contra eles.</segment>
    <segment id="21">Estratégia</segment>
    <segment id="22">As luzes da Assembleia Legislativa</segment>
    <segment id="23">, ocupada por policiais grevistas desde a última terça-feira (31)</segment>
    <segment id="24">, foi cortada no início da noite de ontem.</segment>
    <segment id="25">De acordo com informações da Secretaria de Comunicação do Estado</segment>
    <segment id="26">, a interrupção não foi realizada pelo governo estadual</segment>
    <segment id="27">, masmas pode ter sido causada pelos próprios amotinados.</segment>
    <segment id="28">Todo o local estava cercado por viaturas</segment>
    <segment id="29">, enquanto helicópteros da Força Nacional também rondavam a área.</segment>
    <segment id="30">Ainda de acordo com a Secom</segment>
    <segment id="31">, o movimento dos policiais na Bahia é parte de uma estratégia da Associação Nacional de Entidades Representativas de Praças Militares Estaduais (Anaspra)</segment>
    <segment id="32">, cujo próximo alvo seria a PM do Rio.</segment>
  </rst>
</analysis>