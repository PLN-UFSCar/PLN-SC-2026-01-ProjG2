  <rst>
    <segment id="1">PM leva 5 tiros no Barbalho</segment>
    <segment id="2">Soldado passou por três cirurgias ontem no Hospital Geral do Estado (HGE)</segment>
    <segment id="3">O soldado da Polícia Militar Richardson Remígio de Freitas</segment>
    <segment id="4">, 33 anos</segment>
    <segment id="5">, foi baleado por volta das 6h30 de ontem no bairro do Barbalho.</segment>
    <segment id="6">A vítima dirigia um VW</segment>
    <segment id="7">Gol branco</segment>
    <segment id="8">,</segment>
    <segment id="9">quando foi alvejada por cinco tiros</segment>
    <segment id="10">, de acordo com a polícia.</segment>
    <segment id="11">Richardson</segment>
    <segment id="12">, que estava à paisana</segment>
    <segment id="13">, voltava da academia Stillus quando foi ferido por tiros que partiram de um Siena preto (NYI-1612).</segment>
    <segment id="14">O carro era ocupado por "quatro ou cinco homens"</segment>
    <segment id="15">, disse  a delegada Lenice Nascimento.</segment>
    <segment id="16">Não há informações sobre os autores do crime.</segment>
    <segment id="17">Policiais que estiveram no local afirmaram  que é possível que uma das marcas no para-brisa do veículo tenha partido de um tiro disparado pela  vítima</segment>
    <segment id="18">, que foi atingida no pescoço</segment>
    <segment id="19">, braço e tórax.</segment>
    <segment id="20">A delegada confirmou que as marcas de sangue na rua podem ser de um dos atiradores</segment>
    <segment id="21">, que teria sido baleado.</segment>
    <segment id="22">Comandante elogia soldado:</segment>
    <segment id="23">“É um homem tranquilo”</segment>
    <segment id="24">Um dos sócios da Academia Stillus</segment>
    <segment id="25">, Jafé Fernandes</segment>
    <segment id="26">, 55 anos</segment>
    <segment id="27">, afirma que Richardson é  uma pessoa reservada.</segment>
    <segment id="28">O PM frequentava a academia desde 15 de abril.</segment>
    <segment id="29">"</segment>
    <segment id="30">Ele malhava mais à noite</segment>
    <segment id="31">, masmas hoje (ontem) decidiu vir pela manhã"</segment>
    <segment id="32">, disse outro sócio da academia</segment>
    <segment id="33">, sem se</segment>
    <segment id="34">se identificar.</segment>
    <segment id="35">De acordo com a delegada Lenice Nascimento</segment>
    <segment id="36">, ainda não</segment>
    <segment id="37">sese apurou</segment>
    <segment id="38">sese o policial respondia a inquérito.</segment>
    <segment id="39">O comandante da 37ª CIPM (Liberdade)</segment>
    <segment id="40">, onde Richardson é lotado</segment>
    <segment id="41">, afirma que ele é  tranquilo e que não tem problemas na corporação.</segment>
  </rst>
