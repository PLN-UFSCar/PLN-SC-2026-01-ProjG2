  <rst>
    <segment id="1">Capobreak invade praças de Salvador
Jovens apostam na dança</segment>
    <segment id="2">comocomo forma de conhecimento do próprio corpo
Inspirado numa pesquisa sobre a junção da luta africana</segment>
    <segment id="3">, a capoeira</segment>
    <segment id="4">, com o hip hop</segment>
    <segment id="5">, estilo de dança popular nos Estados Unidos</segment>
    <segment id="6">, surgiu o grupo Brart Crew</segment>
    <segment id="7">, no bairro da Boca do Rio.</segment>
    <segment id="8">O “capobreack”</segment>
    <segment id="9">, como</segment>
    <segment id="10">como foi apelidada a mistura</segment>
    <segment id="11">, é exibida nas rodas de dança espalhadas pelas praças da cidade</segment>
    <segment id="12">, em que nove jovens entre 12 e 24 anos</segment>
    <segment id="13">sese apresentam mostrando todo tipo de movimento que o corpo é capaz de fazer.</segment>
    <segment id="14">Capoeirista</segment>
    <segment id="15">, o baiano B.Boy Ananias foi para os Estados Unidos em 2009 para estudar o hip hop.</segment>
    <segment id="16">Ele acredita que as duas danças são uma estilo de vida</segment>
    <segment id="17">, “quase uma religião” e</segment>
    <segment id="18">, por isso</segment>
    <segment id="19">, apostou no estudo.</segment>
    <segment id="20">“</segment>
    <segment id="21">A capoeira e o breaking têm movimentos parecidos.</segment>
    <segment id="22">Alguns acham que quem dança esses ritmos está na criminalidade</segment>
    <segment id="23">, masmas é o contrário.</segment>
    <segment id="24">As danças ajudam a fortalecer a cultura e são  uma forma de conhecimento”</segment>
    <segment id="25">, explica Ananias.</segment>
    <segment id="26">É o que acredita também o dançarino e líder da Brart Crew</segment>
    <segment id="27">, Ladson Luiz</segment>
    <segment id="28">, 24.</segment>
    <segment id="29">“</segment>
    <segment id="30">A dança resgata a pessoa do mundo do crime.</segment>
    <segment id="31">Muitos jovens saíram da criminalidade para vir dançar com a gente.</segment>
    <segment id="32">Nos apresentamos nas praças para mostrar o trabalho.</segment>
    <segment id="33">Inclusive</segment>
    <segment id="34">, já nos apresentamos até em São Paulo”</segment>
    <segment id="35">, comemora ele.</segment>
    <segment id="36">Piruetas</segment>
    <segment id="37">Jovens apostam na dança</segment>
    <segment id="38">comocomo forma de conhecimento do próprio corpo.</segment>
    <segment id="39">Apresentações são sempre em praças da cidade</segment>
  </rst>
