  <rst>
    <segment id="1">40 pessoas querem adotar cães espancados</segment>
    <segment id="2">Lobo recebeu abrigo de ONG</segment>
    <segment id="3">, masmas Found segue internado.</segment>
    <segment id="4">Eles estão em paz</segment>
    <segment id="5">O cachorro Lobo</segment>
    <segment id="6">, que sofria maus-tratos de uma moradora do bairro de Pau da Lima</segment>
    <segment id="7">, encontra-</segment>
    <segment id="8">sese abrigado no sítio Doce Lar</segment>
    <segment id="9">, na Estrada do Cia.

Lobo  – ou Lobinho</segment>
    <segment id="10">, como</segment>
    <segment id="11">como carinhosamente passou a ser chamado após ser salvo do cativeiro – foi medicado em uma clínica veterinária de Salvador e em seguida foi levado ao sítio pela advogada Ana Rita Tavares</segment>
    <segment id="12">, voluntária da Associação Terra Verde Viva.</segment>
    <segment id="13">O outro cão</segment>
    <segment id="14">, de apenas 2 meses de vida</segment>
    <segment id="15">, que recebeu o nome de Found pelos voluntários da ONG</segment>
    <segment id="16">, continua internado.</segment>
    <segment id="17">Segundo Ana Rita</segment>
    <segment id="18">, a procura pela adoção de Lobinho é grande e já passa de 40 interessados</segment>
    <segment id="19">, masmas ele ainda deve aguardar pelo menos 40 dias</segment>
    <segment id="20">, até que  seja liberada a sua adoção.</segment>
    <segment id="21">Os maus-tratos aos bichinhos foram revelados por um vídeo produzido por um  vizinho e publicado na internet na última segunda-feira.</segment>
    <segment id="22">A advogada alerta  que os maus-tratos contra animais são frequentes.</segment>
    <segment id="23">Por conta disso</segment>
    <segment id="24">, ela incentiva que casos assim devem ser denunciados.</segment>
    <segment id="25">Adote o seu bichinho</segment>
    <segment id="26">Em Salvador</segment>
    <segment id="27">, cerca de 800 cães e gatos aguardam por um novo lar nos abrigos.</segment>
    <segment id="28">O abrigo São Francisco de Assis</segment>
    <segment id="29">, em Paripe</segment>
    <segment id="30">, realiza uma feira de adoção todos os sábados das 9 às 13h</segment>
    <segment id="31">, na praça Ana Lúcia Magalhães</segment>
    <segment id="32">, na Pituba.</segment>
    <segment id="33">Para adotar animais na ONG Terra Verde Viva</segment>
    <segment id="34">, basta enviar e-mail para terraverdeviva@yahoo.com.br</segment>
    <segment id="35">, informando os documentos pessoais e o motivo de interesse em fazer a adoção.</segment>
    <segment id="36">Quem presenciar algum tipo de mau-trato a animais pode denunciar nos telefones: (71) 3103.6833/3103.6842.</segment>
  </rst>
</analysis>