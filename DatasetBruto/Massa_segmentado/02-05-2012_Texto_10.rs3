  <rst>
    <segment id="1">Polícia bota ordem em Simões Filho</segment>
    <segment id="2">Quadrilha troca tiros com agentes no CIA.</segment>
    <segment id="3">Cinco bandidos morreram na ação</segment>
    <segment id="4">Uma operação orquestrada pelos policiais civis da Delegacia de Simões Filho teve um saldo de cinco mortos</segment>
    <segment id="5">, ontem.</segment>
    <segment id="6">De acordo com o delegado Antônio Fernando Soares do Carmo</segment>
    <segment id="7">, titular de Simões Filho</segment>
    <segment id="8">, quatro homens foram mortos ao trocarem tiros com os policiais</segment>
    <segment id="9">, após tentarem assaltar a distribuidora Planeta Natural</segment>
    <segment id="10">, no Centro Industrial de Aratu (CIA).</segment>
    <segment id="11">Os acusados chegaram à empresa em um carro Renault Clio (NTG-3535).</segment>
    <segment id="12">Como obtiveram informações de que o assalto iria ocorrer ontem</segment>
    <segment id="13">, os policiais aguardaram os bandidos dentro da empresa.</segment>
    <segment id="14">Ao perceberem a presença da polícia</segment>
    <segment id="15">, os criminosos iniciaram o tiroteio.</segment>
    <segment id="16">Houve perseguição e o carro caiu em uma vala.</segment>
    <segment id="17">O motorista do Renault conseguiu fugir.</segment>
    <segment id="18">Os outros quatro ocupantes do carro morreram.</segment>
    <segment id="19">Ameaçava ex-colega</segment>
    <segment id="20">O delegado Antônio Fernando afirma que o líder da quadrilha era Leonardo Jesus Conceição</segment>
    <segment id="21">, 28, que estava no Clio.</segment>
    <segment id="22">Leonardo trabalhou na Planeta Natural até outubro de 2011.</segment>
    <segment id="23">Ele estava ameaçando um funcionário da empresa</segment>
    <segment id="24">para que</segment>
    <segment id="25">para que ele passasse informações sobre a chegada de dinheiro na firma.</segment>
    <segment id="26">Com medo</segment>
    <segment id="27">, o funcionário conversou com o chefe</segment>
    <segment id="28">, que deu queixa na polícia.</segment>
    <segment id="29">Com base nessa denúncia</segment>
    <segment id="30">, os policiais montaram a operação para prender os criminosos.</segment>
    <segment id="31">Em dezembro de 2011</segment>
    <segment id="32">, a mesma quadrilha roubou R$ 31 mil da Planeta Natural</segment>
    <segment id="33">, diz a polícia.</segment>
    <segment id="34">Perseguição em Águas Claras</segment>
    <segment id="35">Segundo a polícia</segment>
    <segment id="36">, o Corsa Sedan (DZY-5759) também participou do assalto.</segment>
    <segment id="37">Policiais militares da Cipe-Polo Industrial perseguiram os ocupantes do Corsa até o viaduto do bairro Águas Claras</segment>
    <segment id="38">, em Salvador.</segment>
    <segment id="39">Laércio de Jesus Miranda Barbosa</segment>
    <segment id="40">, 23, motorista do Corsa</segment>
    <segment id="41">, morreu após troca de tiros</segment>
    <segment id="42">, afirma a polícia.</segment>
    <segment id="43">Outro ocupante desse veículo foi preso e um terceiro fugiu.</segment>
    <segment id="44">A polícia não divulgou o nome do acusado detido durante a operação.</segment>
  </rst>
</analysis>