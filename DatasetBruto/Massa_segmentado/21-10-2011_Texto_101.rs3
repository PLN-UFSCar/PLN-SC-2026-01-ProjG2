  <rst>
    <segment id="1">Preso o sucessor do traficante Peu</segment>
    <segment id="2">Polícia acredita que Roberto Ferreira</segment>
    <segment id="3">sese mudou do Nordeste após a chegada das bases</segment>
    <segment id="4">Apontado pela  polícia</segment>
    <segment id="5">comocomo o sucessor do traficante Jairo Santos da Silva</segment>
    <segment id="6">, 29 anos</segment>
    <segment id="7">,  conhecido</segment>
    <segment id="8">comocomo Peu</segment>
    <segment id="9">, (que comandava  o tráfico de drogas no Nordeste de Amaralina)</segment>
    <segment id="10">, Roberto Ferreira Gomes</segment>
    <segment id="11">, 25, o Beto Babão ou Boca Mole</segment>
    <segment id="12">, foi apresentado à imprensa</segment>
    <segment id="13">, ontem</segment>
    <segment id="14">, na Delegacia de Repressão a Furtos e Roubos (DRFR)</segment>
    <segment id="15">, na   Baixa do Fiscal.</segment>
    <segment id="16">Ele ganhou o apelido de Boca Mole desde o dia em que teve a boca lesionada por uma bala</segment>
    <segment id="17">, durante uma troca de tiros com policiais.</segment>
    <segment id="18">Ontem, o acusado de ser chefão mostrou que é um homem fashion</segment>
    <segment id="19">, como</segment>
    <segment id="20">como provam as flores coloridas pintadas nas unhas dos pés e das mãos.</segment>
    <segment id="21">Conforme o  delegado titular da Delegacia de Furtos e Roubos</segment>
    <segment id="22">, Nilson Tormes</segment>
    <segment id="23">, após a prisão de Peu</segment>
    <segment id="24">,  durante a operação Gênesis</segment>
    <segment id="25">, em junho deste ano</segment>
    <segment id="26">,  Boca Mole assumiu o tráfico  no Nordeste.</segment>
    <segment id="27">Porém, ele</segment>
    <segment id="28">sese mudou para o Candeal quando  as Bases Comunitárias de Segurança começaram a ser instaladas.</segment>
    <segment id="29">Vaidoso</segment>
    <segment id="30">, Boca Mole pinta as unhas dos pés e das mãos com flores</segment>
    <segment id="31">Mesmo assim</segment>
    <segment id="32">, ele  continuou  comandando</segment>
    <segment id="33">, a distância</segment>
    <segment id="34">, as vendas de drogas</segment>
    <segment id="35">, no Nordeste</segment>
    <segment id="36">, e também passou a  traficar no Candeal.</segment>
    <segment id="37">Boca Mole foi preso</segment>
    <segment id="38">, na quarta-feira</segment>
    <segment id="39">, 19, depois da suspeita de que teria atirado contra policiais civis da Delegacia de Brotas</segment>
    <segment id="40">, no Candeal.</segment>
    <segment id="41">Porém, ele foi liberado</segment>
    <segment id="42">, porque</segment>
    <segment id="43">porque não estava com armas.</segment>
    <segment id="44">Ele nega tudinho</segment>
    <segment id="45">No mesmo dia em que os agentes da Delegacia de Brotas foram recebidos a tiros</segment>
    <segment id="46">, os policiais da DRFR</segment>
    <segment id="47">, que deram apoio aos colegas</segment>
    <segment id="48">, receberam informações de que Boca Mole havia voltado ao Nordeste e possuía drogas e armas.</segment>
    <segment id="49">Ele foi preso em uma casa</segment>
    <segment id="50">, perto da Ceasa</segment>
    <segment id="51">, no Rio Vermelho.</segment>
    <segment id="52">No local</segment>
    <segment id="53">, a polícia encontrou um revólver calibre 38 e 77 pedras de crack.</segment>
    <segment id="54">Boca Mole negou que tenha atirado contra os policiais.</segment>
    <segment id="55">Inicialmente</segment>
    <segment id="56">, ele também negou ser o dono do material apreendido.</segment>
    <segment id="57">Depois</segment>
    <segment id="58">, admitiu que usava a arma para</segment>
    <segment id="59">sese defender.</segment>
    <segment id="60">Roberto já tinha ficha na polícia.</segment>
    <segment id="61">Em uma das prisões</segment>
    <segment id="62">, ele foi flagrado com uma metralhadora 9 mm e uma pistola 380.</segment>
  </rst>
</analysis>