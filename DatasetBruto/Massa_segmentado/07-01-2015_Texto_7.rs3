  <rst>
    <segment id="1">Galera bebe ГѓВЎgua de rato e passa mal</segment>
    <segment id="2">FuncionГѓВЎrios de construtora matam a sede com lГѓВ­quidos com ratos e passam mal</segment>
    <segment id="3">Cerca de 50 trabalhadores da construtora Prefac</segment>
    <segment id="4">, da cidade de Pojuca (67 km de Salvador)</segment>
    <segment id="5">, passaram mal ontem</segment>
    <segment id="6">, apГѓВіs ingerirem ГѓВЎgua de um reservatГѓВіrio que estava com oito ratos mortos.</segment>
    <segment id="7">O incidente aconteceu em uma fazenda na zona rural de Mata de SГѓВЈo JoГѓВЈo</segment>
    <segment id="8">, na RegiГѓВЈo Metropolitana (RMS).</segment>
    <segment id="9">A ГѓВЎgua consumida pelos funcionГѓВЎrios vinha de um tanque que possuГѓВ­a um filtro colocado pela prГѓВіpria empresa.</segment>
    <segment id="10">Segundo o sargento Radson</segment>
    <segment id="11">, da 32Г‚ВЄ Companhia Independente da PolГѓВ­cia Militar de Pojuca</segment>
    <segment id="12">, eles sentiram mau cheiro na ГѓВЎgua e subiram no tanque para olhar</segment>
    <segment id="13">, foi quando encontraram os animais mortos.</segment>
    <segment id="14">Гўв‚¬Е“Os funcionГѓВЎrios estavam com sede e</segment>
    <segment id="15">, mesmo sentindo o mau cheiro</segment>
    <segment id="16">, continuaram bebendo a ГѓВЎgua.</segment>
    <segment id="17">Por volta das 13h</segment>
    <segment id="18">, um deles passou mal e</segment>
    <segment id="19">, quando os outros subiram ao tanque</segment>
    <segment id="20">, avistaram os oito ratos mortosГўв‚¬</segment>
    <segment id="21">, explica o policial.</segment>
    <segment id="22">Ainda de acordo com o Radson</segment>
    <segment id="23">, os funcionГѓВЎrios foram encaminhados para um pronto-socorro e</segment>
    <segment id="24">, em seguida</segment>
    <segment id="25">, para o Hospital Municipal Doutor Carlito Silva</segment>
    <segment id="26">, em Pojuca</segment>
    <segment id="27">, onde a maioria reside.</segment>
    <segment id="28">Гўв‚¬Е“Nem todos passaram mal</segment>
    <segment id="29">, masmas</segment>
    <segment id="30">, por precauГѓВ§ГѓВЈo</segment>
    <segment id="31">, alguns foram encaminhados para uma avaliaГѓВ§ГѓВЈo mГѓВ©dicaГўв‚¬.</segment>
    <segment id="32">Os funcionГѓВЎrios deram entrada no hospital por volta das 17h30</segment>
    <segment id="33">, masmas foram liberados na mesma noite.</segment>
    <segment id="34">Segundo a assessoria da unidade de saГѓВєde</segment>
    <segment id="35">, os pacientes receberam soro e ficaram em observaГѓВ§ГѓВЈo por algumas horas.
PossГѓВ­vel sabotagem?</segment>
    <segment id="36">Com sede em Pojuca</segment>
    <segment id="37">, a Prefac prestava serviГѓВ§o para a empresa Ferbasa</segment>
    <segment id="38">, localizada em Mata de SГѓВЈo JoГѓВЈo.</segment>
    <segment id="39">Procurada pela reportagem</segment>
    <segment id="40">, uma funcionГѓВЎria do setor de recursos humanos</segment>
    <segment id="41">, que preferiu nГѓВЈo</segment>
    <segment id="42">sese identificar</segment>
    <segment id="43">, informou que ainda nГѓВЈo hГѓВЎ um posicionamento sobre o</segment>
    <segment id="44">casocaso.</segment>
    <segment id="45">Гўв‚¬Е“NГѓВіs ainda nГѓВЈo podemos passar nenhum detalhe</segment>
    <segment id="46">, pois</segment>
    <segment id="47">pois o</segment>
    <segment id="48">casocaso estГѓВЎ sendo investigado.</segment>
    <segment id="49">A suspeita ГѓВ© que tenha sido uma sabotagem</segment>
    <segment id="50">, masmas a polГѓВ­cia tГѓВ©cnica vai apurar e</segment>
    <segment id="51">, em seguida</segment>
    <segment id="52">, a empresa</segment>
    <segment id="53">sese posicionarГѓВЎГўв‚¬</segment>
    <segment id="54">, disse.</segment>
  </rst>
