  <rst>
    <segment id="1">Pagode dedicado à patroa do pó
Fãs da banda</segment>
    <segment id="2">A Bronkka</segment>
    <segment id="3">sese vestem iguais a Kelly Cyclone</segment>
    <segment id="4">Uma semana após a morte de Kelly Cyclone</segment>
    <segment id="5">, fãs, amigos e a irmã dela</segment>
    <segment id="6">, Karla Sales</segment>
    <segment id="7">, foram ontem ao show da  banda preferida da patroa</segment>
    <segment id="8">, A Bronkka.</segment>
    <segment id="9">Era a gravação do DVD do grupo</segment>
    <segment id="10">, masmas o vocalista Igor Kanário logo anunciou:</segment>
    <segment id="11">“</segment>
    <segment id="12">Hoje é o tributo a Kelly Cyclone”.</segment>
    <segment id="13">O cantor disse que a musa do tráfico era sua maior fã.</segment>
    <segment id="14">Cerca de 5 mil fãs foram ao espaço Karrapixo</segment>
    <segment id="15">, em Camaçari</segment>
    <segment id="16">, totalmente “cyclonados”</segment>
    <segment id="17">, vestindo roupas e acessórios da marca predileta de Kelly</segment>
    <segment id="18">, a Cyclone.</segment>
    <segment id="19">Karla, que a pedido da irmã morta ganhou o nome de Karla Cyclone</segment>
    <segment id="20">, chorava muito.</segment>
    <segment id="21">“Me sinto mal</segment>
    <segment id="22">, pela saudade.</segment>
    <segment id="23">Mas me sinto bem</segment>
    <segment id="24">, pois</segment>
    <segment id="25">pois sei que Kelly queria muito estar aqui”</segment>
    <segment id="26">, falou ela</segment>
    <segment id="27">, que fez um cartaz em homenagem à irmã e o levou para ser autografado por Kanário.</segment>
    <segment id="28">O cantor recebeu Karla no camarim.</segment>
    <segment id="29">“Ela era do bem</segment>
    <segment id="30">, vou orar por ela”</segment>
    <segment id="31">, disse Kanário</segment>
    <segment id="32">, rebatendo acusações de que Kelly era envolvida com o crime.

 

Aritana de Oxossi: Irmã de Kelly terá sucesso</segment>
    <segment id="33">O sarcedote da Umbanda Aritana de Oxossi esteve no show e disse que Karla Cyclone não terá o destino trágico da irmã.</segment>
    <segment id="34">“Karla terá um futuro de sucesso”</segment>
    <segment id="35">, prevê Aritana</segment>
    <segment id="36">, que virou o guia espiritual de Karla após as previsões sobre a morte de Kelly</segment>
    <segment id="37">sese confirmarem.</segment>
    <segment id="38">“Ela disse que virá até mim antes de tomar uma decisão importante”</segment>
    <segment id="39">, falou.</segment>
  </rst>
</analysis>