  <rst>
    <segment id="1">Mãe apela: ‘</segment>
    <segment id="2">Onde está o corpo?</segment>
    <segment id="3">’
Lúcia crê que o filho Tiago desaparecido há 13 dias</segment>
    <segment id="4">, foi morto e enterrado numa mata</segment>
    <segment id="5">Para a agente de saúde Vera Lúcia Rodrigues</segment>
    <segment id="6">, 49 anos</segment>
    <segment id="7">, o pior já aconteceu com o filho Tiago Rodrigues Alves Dias</segment>
    <segment id="8">, 25, desaparecido há 13 dias.</segment>
    <segment id="9">O jovem foi visto pela última vez entrando em uma mata acompanhado de outras cinco pessoas</segment>
    <segment id="10">, em Simões Filho (Grande Salvador).</segment>
    <segment id="11">A mata fica no bairro Simões Filho 1</segment>
    <segment id="12">, onde o jovem morava com os pais</segment>
    <segment id="13">, irmãos a mulher e o filho de um ano.</segment>
    <segment id="14">“Eu só quero o corpo do meu filho.</segment>
    <segment id="15">Eu já perdoei quem matou ele.</segment>
    <segment id="16">A justiça pertence a Deus.</segment>
    <segment id="17">Eles podem fazer uma ligação anônima dizendo onde enterraram o corpo”</segment>
    <segment id="18">, suplica Vera Lúcia</segment>
    <segment id="19">, que diz estar sem dormir</segment>
    <segment id="20">, comer e trabalhar desde o último 20 de janeiro</segment>
    <segment id="21">, dia do desaparecimento.</segment>
    <segment id="22">“Tenho que retomar a minha vida.</segment>
    <segment id="23">Só vou conseguir voltar a trabalhar depois que enterrar o meu filho”.</segment>
    <segment id="24">Vera conta que a mulher do filho ouviu o som de quatro tiros vindo da mata onde Tiago foi visto pela última vez.</segment>
    <segment id="25">Além disso</segment>
    <segment id="26">, os homens que o acompanhavam pediram aos moradores do bairro água e ferramentas para cavar o chão.</segment>
    <segment id="27">Após o desaparecimento</segment>
    <segment id="28">, Vera descobriu que o filho estava usando drogas.</segment>
    <segment id="29">Boataria</segment>
    <segment id="30">A titular em exercício da 22ª Delegacia Territorial (Simões Filho)</segment>
    <segment id="31">, Celinei Ramos Iotti</segment>
    <segment id="32">, diz que uma série de boatos surgiu desde o desaparecimento de Tiago.</segment>
    <segment id="33">O último apareceu</segment>
    <segment id="34">, ontem</segment>
    <segment id="35">, dando conta de que o corpo foi encontrado esquartejado na mata onde ele foi visto pela última vez.</segment>
    <segment id="36">“</segment>
    <segment id="37">Os policiais já realizaram quatro diligências pela região</segment>
    <segment id="38">, masmas ainda não encontraram o corpo.</segment>
    <segment id="39">É uma área muito extensa”</segment>
    <segment id="40">, conta a delegada.</segment>
    <segment id="41">Quem tiver informações</segment>
    <segment id="42">, os telefones são: 3235-0000</segment>
    <segment id="43">, 3396-2840 ou 3396-4601.</segment>
    <segment id="44">Amigos de Tiago também estão realizando buscas pela mata</segment>
    <segment id="45">, ainda sem sucesso.</segment>
  </rst>
</analysis>