  <rst>
    <segment id="1">Bahia dá mole e Leão engasga</segment>
    <segment id="2">Tricolor saiu na frente</segment>
    <segment id="3">masmas empatou e ataque do Feirense deu trabalho ao Vitória</segment>
    <segment id="4">O Bahia estreou mal no Baianão 2012.</segment>
    <segment id="5">Mesmo com o apoio de 11.264 mil torcedores</segment>
    <segment id="6">, o tricolor</segment>
    <segment id="7">sese engasgou com o Carcará e ficou no empate de 3 a 3.</segment>
    <segment id="8">O resultado não foi bom</segment>
    <segment id="9">, masmas a torcida presente em Pituaçu ao menos pôde presenciar belos gols e um jogo bem disputado.</segment>
    <segment id="10">A chuva foi iniciada por Júnior</segment>
    <segment id="11">, aos 14 minutos.</segment>
    <segment id="12">O Anjo Loiro recebeu bola de Boiadeiro</segment>
    <segment id="13">, invadiu a área e</segment>
    <segment id="14">, mesmo sem ângulo</segment>
    <segment id="15">, bateu forte para abrir o placar.</segment>
    <segment id="16">No entanto</segment>
    <segment id="17">, o Atlético mostrou que não saiu de Alagoinhas para brincar.</segment>
    <segment id="18">No fim do primeiro tempo</segment>
    <segment id="19">, Fausto</segment>
    <segment id="20">, ex-Bahia</segment>
    <segment id="21">, marcou de cabeça.</segment>
    <segment id="22">No início da segunda etapa</segment>
    <segment id="23">, o meia Tácio acertou um belo chute de fora da área e marcou um golaço</segment>
    <segment id="24">, o da virada do Carcará: 2 a 1.</segment>
    <segment id="25">Como o jogo estava ruim para o Bahia</segment>
    <segment id="26">, a melhora veio do banco.</segment>
    <segment id="27">Rafael Gladiador substituiu Boiadeiro e aproveitou cruzamento rasteiro da direita para empatar o jogo</segment>
    <segment id="28">, aos 20.</segment>
    <segment id="29">Sete minutos depois</segment>
    <segment id="30">, o enjoado Carcará marcou o terceiro com Deon</segment>
    <segment id="31">, que cortou Fahel antes de chutar e vencer Marcelo Lomba.</segment>
    <segment id="32">Aos 32</segment>
    <segment id="33">, porém</segment>
    <segment id="34">porém, o Bahia conseguiu aliviar o problema com  gol de Júnior</segment>
    <segment id="35">, após  rebote em cobrança de falta de Diego Jussani.</segment>
    <segment id="36">Leão engasga em Senhor do Bonfim



 

Empate fora de casa pode ser considerado um bom resultado</segment>
    <segment id="37">, masmas a atuação do Vitória ontem à noite</segment>
    <segment id="38">, em Senhor do Bonfim</segment>
    <segment id="39">, deixou a desejar.</segment>
    <segment id="40">Desperdiçou um pênalti</segment>
    <segment id="41">, saiu na frente com um gol de Mineiro</segment>
    <segment id="42">, masmas o Feirense chegou à igualdade com Cristóvão e quase virou.</segment>
    <segment id="43">Domingo</segment>
    <segment id="44">, no Barradão</segment>
    <segment id="45">, o Leão pega o Juazeiro</segment>
    <segment id="46">, enquanto o Feirense sai para enfrentar o Serrano.</segment>
    <segment id="47">Aos 13 minutos</segment>
    <segment id="48">, Rildo sofreu pênalti de Valdo</segment>
    <segment id="49">, masmas Lúcio Flávio chutou e o goleiro Naldo defendeu.</segment>
    <segment id="50">Na falha de Dankler</segment>
    <segment id="51">, André Cabeça invadiu a área e tocou para Ermínio encher o pé.</segment>
    <segment id="52">Douglas salvou o Vitória.</segment>
    <segment id="53">Depois</segment>
    <segment id="54">, outro chute forte de Ananias e o goleiro do Leão vez evitou o gol.</segment>
    <segment id="55">Quem não faz leva e a história</segment>
