    <segment id="13">gia para evitar que o governador nomeasse o promotor.</segment>
    <segment id="14">Eles articulam uma indica脙搂脙拢o conjunta de um novo nome por parte dos tr脙陋s senadores goianos</segment>
    <segment id="15">脙聽 脙漏poca:</segment>
    <segment id="16">Dem脙鲁stenes Torres</segment>
    <segment id="17">, L脙潞cia V脙垄nia (PSDB) e Cyro Miranda (PSDB).</segment>
    <segment id="18">Plano do grupo fracassou
脙鈧瑂 12h12m</segment>
    <segment id="19">, logo ap脙鲁s a conversa com Eliane</segment>
    <segment id="20">, Garcez conversa com Cachoeira</segment>
    <segment id="21">, que diz que "o senador vai entrar no processo"</segment>
    <segment id="22">, numa prov脙隆vel refer脙陋ncia a Dem脙鲁stenes</segment>
    <segment id="23">, cassado em julho por deixar o mandato a servi脙搂o do bicheiro.</segment>
    <segment id="24">Diante das evid脙陋ncias de proximidade a Cachoeira</segment>
    <segment id="25">, inclusive por portar um r脙隆dio oferecido pelo grupo</segment>
    <segment id="26">, Eliane deixou o cargo no gabinete de Marconi Perillo em abril deste ano.</segment>
    <segment id="27">Os planos de Carlinhos Cachoeira e Wladimir Garcez n脙拢o prosperaram.</segment>
    <segment id="28">Os dois foram presos na manh脙拢 seguinte</segment>
    <segment id="29">, 29 de fevereiro</segment>
    <segment id="30">, dia em que a PF deflagrou a Monte Carlo.</segment>
    <segment id="31">O promotor de Justi脙搂a Umberto Machado</segment>
    <segment id="32">, do Minist脙漏rio P脙潞blico (MP) de Goi脙隆s</segment>
    <segment id="33">, assumiu o cargo de secret脙隆rio um m脙陋s depois</segment>
    <segment id="34">, masmas deixou a fun脙搂脙拢o</segment>
    <segment id="35">, em junho</segment>
