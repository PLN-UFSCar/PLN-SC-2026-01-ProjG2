  <rst>
    <segment id="1">Mulher mata e ﾃδｩ liberada</segment>
    <segment id="2">Agressora mata namorado com facada no peito</segment>
    <segment id="3">, sese apresenta ﾃδ polﾃδｭcia e ﾃδｩ dispensada</segment>
    <segment id="4">A famﾃδｭlia do atendente Elinoﾃδｩ Santos de Almeida Sena</segment>
    <segment id="5">, 25 anos</segment>
    <segment id="6">, nﾃδ｣o consegue entender</segment>
    <segment id="7">comocomo a mulher que o matou com uma facada no peito nﾃδ｣o foi presa em flagrante</segment>
    <segment id="8">, mesmo tendo sido encontrada momentos apﾃδｳs o crime</segment>
    <segment id="9">, na madrugada de anteontem.</segment>
    <segment id="10">Tailma Oliveira Costa</segment>
    <segment id="11">, 18, morava com Elinoﾃδｩ hﾃδ｡ cinco meses em uma casa na Rua Alcides Barreto</segment>
    <segment id="12">, em Sussuarana Velha</segment>
    <segment id="13">, local do crime.</segment>
    <segment id="14">Apﾃδｳs uma discussﾃδ｣o do casal</segment>
    <segment id="15">, Tailma deu uma facada no peito de Elinoﾃδｩ.</segment>
    <segment id="16">Segundo a delegada Simone Moutinho</segment>
    <segment id="17">, do Departamento de Homicﾃδｭdios e Proteﾃδｧﾃδ｣o ﾃδ Pessoa (DHPP)</segment>
    <segment id="18">, Tailma nﾃδ｣o foi presa em flagrante</segment>
    <segment id="19">porque</segment>
    <segment id="20">porque</segment>
    <segment id="21">sese apresentou espontaneamente.</segment>
    <segment id="22">A assassina confessa foi interrogada e liberada em seguida.</segment>
    <segment id="23">ﾃ｢竄ｬﾅ鄭utuar em flagrante uma pessoa que</segment>
    <segment id="24">sese apresenta espontaneamente ﾃδｩ abuso de autoridade</segment>
    <segment id="25">, de acordo com o Cﾃδｳdigo Penalﾃ｢竄ｬ</segment>
    <segment id="26">, afirma a delegada.</segment>
    <segment id="27">Tailma disse em depoimento que agiu em legﾃδｭtima defesa.</segment>
    <segment id="28">Simone Moutinho ressalta que todos os indﾃδｭcios indicaram a versﾃδ｣o da autora.</segment>
    <segment id="29">ﾃ｢竄ｬﾅ滴ﾃδ｡ testemunhos de que ela e ele estavam com faca.</segment>
    <segment id="30">Tailma disse que era ela ou eleﾃ｢竄ｬ</segment>
    <segment id="31">, conta a delegada.</segment>
    <segment id="32">ﾃ｢竄ｬﾅ溺as as investigaﾃδｧﾃδｵes ainda estﾃδ｣o em andamentoﾃ｢竄ｬ</segment>
    <segment id="33">, completa.</segment>
    <segment id="34">Agora ﾃδｩ o delegado do DHPP Vinicius Brandﾃδ｣o</segment>
    <segment id="35">o responsﾃδ｡vel pelo inquﾃδｩrito.</segment>
    <segment id="36">Ele disse estar ouvindo as testemunhas para elucidar o</segment>
    <segment id="37">casocaso.</segment>
    <segment id="38">ﾃ｢竄ｬﾅ鼎aso</segment>
    <segment id="39">sese comprove a intenﾃδｧﾃδ｣o de Tailma em matar Elinoﾃδｩ</segment>
    <segment id="40">, eu vou pedir a prisﾃδ｣o preventiva delaﾃ｢竄ｬ</segment>
    <segment id="41">, explica o delegado.</segment>
    <segment id="42">Advogado discorda de delegada</segment>
    <segment id="43">Elinoﾃδｩ deixou os pais e 11 irmﾃδ｣os.</segment>
    <segment id="44">ﾃ｢竄ｬﾅ典ailma foi a primeira namorada dele.</segment>
    <segment id="45">Ela era muito ciumenta.</segment>
    <segment id="46">Ele se</segment>
    <segment id="47">se afastou atﾃδｩ da famﾃδｭlia quando comeﾃδｧou esse namoro.</segment>
    <segment id="48">Ela nﾃδ｣o gostava que ele falasse com mulher nenhumaﾃ｢竄ｬ</segment>
    <segment id="49">, declara Enoque Santos</segment>
    <segment id="50">, irmﾃδ｣o da vﾃδｭtima.</segment>
    <segment id="51">ﾃ｢竄ｬﾅ溺eu irmﾃδ｣o era um cara tranquilo</segment>
    <segment id="52">, trabalhador</segment>
    <segment id="53">, pedia a bﾃδｪnﾃδｧﾃδ｣o ao pai.</segment>
    <segment id="54">Nﾃδ｣o acredito que ele tentou bater nessa mulherﾃ｢竄ｬ</segment>
    <segment id="55">, completa.</segment>
    <segment id="56">O advogado criminalista Francisco Buisine discorda do entendimento da delegada para liberar Tailma do flagrante.</segment>
    <segment id="57">ﾃ｢竄ｬﾅ溺esmo ela</segment>
    <segment id="58">sese apresentando</segment>
    <segment id="59">, a delegada teria que dar o flagrante.</segment>
    <segment id="60">Foi um homicﾃδｭdio.</segment>
    <segment id="61">A nﾃδ｣o ser que seja uma legﾃδｭtima defesa</segment>
    <segment id="62">, que, nesse</segment>
    <segment id="63">casocaso</segment>
    <segment id="64">, sese caracteriza com lesﾃδｵes no corpo dos doisﾃ｢竄ｬ</segment>
    <segment id="65">,  explica.</segment>
    <segment id="66">Era agressiva
Vizinhos de Elinoﾃδｩ contam que Tailma era muita agressiva e a discussﾃδ｣o do dia do crime comeﾃδｧou</segment>
    <segment id="67">porque</segment>
    <segment id="68">porque ele encontrou mensagens de outro homem no celular dela.</segment>
    <segment id="69">ﾃ｢竄ｬﾅ摘le subiu para falar com o marido da cunhada dizendo que estava indo</segment>
    <segment id="70">embora</segment>
    <segment id="71">embora</segment>
    <segment id="72">, masmas retornou para casa para pegar os documentos.</segment>
    <segment id="73">Nessa hora ele levou a facadaﾃ｢竄ｬ</segment>
    <segment id="74">, relata Amilton Costa.</segment>
    <segment id="75">ﾃ｢竄ｬﾅ摘la batia no rapaz e ele nem reagia.</segment>
    <segment id="76">Aconselhei ele a</segment>
    <segment id="77">sese separar</segment>
    <segment id="78">, masmas ele achava que ela mudariaﾃ｢竄ｬ</segment>
    <segment id="79">, conta Antﾃδｴnia Maria de Jesus.</segment>
