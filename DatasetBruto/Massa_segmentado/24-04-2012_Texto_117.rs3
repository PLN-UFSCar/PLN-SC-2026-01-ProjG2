    <segment id="1">Gravidez esquenta sexo</segment>
    <segment id="2">, admite Claudinha</segment>
    <segment id="3">A cantora foi entrevistada por Claudinho Delícia</segment>
    <segment id="4">, maquiador do “Caldeirão do Huck”</segment>
    <segment id="5">Grávida do segundo filho</segment>
    <segment id="6">, a cantora foi entrevistada por Claudinho Delícia</segment>
    <segment id="7">, maquiador do “Caldeirão do Huck”.</segment>
    <segment id="8">Curioso</segment>
    <segment id="9">, ele perguntou sobre a relação da musa com o marido durante a gestação.</segment>
    <segment id="10">A loira não</segment>
    <segment id="11">sese fez de rogada e respondeu sem constrangimento.</segment>
    <segment id="12">“Se estiver tudo bem</segment>
    <segment id="13">, fica ótimo.</segment>
    <segment id="14">Se não estiver</segment>
