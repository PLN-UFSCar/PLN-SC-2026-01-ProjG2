  <rst>
    <segment id="1">Presos ladrões de postos de combustíveis
Quadrilha foi desarticulada pela Polícia Rodoviária Federal em Jequié</segment>
    <segment id="2">Uma quadrilha acusada de assaltar postos de combustíveis foi desarticulada pela Polícia Rodoviária Federal (PRF)</segment>
    <segment id="3">, no km 677 da BR-116</segment>
    <segment id="4">, perto da cidade de Jequié.</segment>
    <segment id="5">De acordo com a assessoria de comunicação da PRF</segment>
    <segment id="6">, os criminosos foram encontrados após o órgão ter recebido denúncias de que três homens em um caminhão haviam acabado de abordar os funcionários do Posto Serra do Mutum.</segment>
    <segment id="7">Com os acusados</segment>
    <segment id="8">, os policiais rodoviários federais encontraram cinco aparelhos de celular</segment>
    <segment id="9">, duas tocas pretas</segment>
    <segment id="10">, duas mangueiras de secar tanques</segment>
    <segment id="11">, três macacos de suspensão</segment>
    <segment id="12">, além de  R$ 3 mil e 12 dólares</segment>
    <segment id="13">, em dinheiro.</segment>
  </rst>
</analysis>