  <rst>
    <segment id="1">Polícia investiga óbito de casal no Itanhangá
RIO - O coração é fraco: ao ver o amado morto</segment>
    <segment id="2">, a mulher</segment>
    <segment id="3">, grávida de dois meses</segment>
    <segment id="4">, não aguenta a dor e acaba entrando em choque.</segment>
    <segment id="5">Passa quase três dias ao lado do corpo do marido</segment>
    <segment id="6">, até ser encontrada.</segment>
    <segment id="7">Socorrida</segment>
    <segment id="8">, morre poucas horas depois no hospital.</segment>
    <segment id="9">A cena</segment>
    <segment id="10">, digna de roteiro de filme</segment>
    <segment id="11">, ao que tudo indica aconteceu este fim de semana na vida real</segment>
    <segment id="12">, envolvendo justamente dois contadores de histórias: o diretor Emiliano Ribeiro e a roteirista Karla Hansen.</segment>
    <segment id="13">Espantado com a tragédia nos moldes de Tristão e Isolda no Itanhangá</segment>
    <segment id="14">, área sob sua jurisdição</segment>
    <segment id="15">, o delegado Fernando Cesar Magalhães Reis</segment>
    <segment id="16">, da 16ª DP</segment>
    <segment id="17">, disse na quarta-feira que</segment>
    <segment id="18">, embora</segment>
    <segment id="19">embora tudo aponte para mortes naturais</segment>
    <segment id="20">, vai investigar o</segment>
    <segment id="21">casocaso.</segment>
    <segment id="22">Casados há dez anos</segment>
    <segment id="23">, Karla e o marido comemoravam a chegada do primeiro filho.</segment>
    <segment id="24">Aos 63 anos</segment>
    <segment id="25">, com uma filha já adulta do primeiro casamento</segment>
    <segment id="26">, Emiliano não escondia a felicidade por voltar ao mundo das fraldas e mamadeiras.</segment>
    <segment id="27">Vinte anos mais nova</segment>
    <segment id="28">, Karla também fazia planos e já havia escolhido os padrinhos do bebê.</segment>
    <segment id="29">No último sábado</segment>
    <segment id="30">, o casal conversou com amigos e marcou compromissos para o domingo.</segment>
    <segment id="31">Não apareceram</segment>
    <segment id="32">, masmas ninguém estranhou.</segment>
    <segment id="33">Na segunda-feira</segment>
    <segment id="34">, não atenderam ao telefone.</segment>
    <segment id="35">Mas o alarme ainda não soara.</segment>
    <segment id="36">Na terça-feira</segment>
    <segment id="37">, a faxineira chegou à casa e estranhou os jornais empilhados do lado de fora</segment>
    <segment id="38">, intocados.</segment>
    <segment id="39">Abriu a porta e encontrou Emiliano morto e Karla agonizando.</segment>
    <segment id="40">As famílias foram chamadas e as providências tomadas: um médico constatou que Emiliano sofrera um infarto e Karla foi levada</segment>
    <segment id="41">, ainda com vida</segment>
    <segment id="42">, para o Hospital Lourenço Jorge</segment>
    <segment id="43">, onde morreria pouco depois</segment>
    <segment id="44">, como</segment>
    <segment id="45">como informou na quarta-feira Ancelmo Gois em sua coluna no GLOBO.</segment>
    <segment id="46">Ela nada falou.</segment>
    <segment id="47">O que se</segment>
    <segment id="48">se especula é que tenha passado mal ao ver Emiliano morto.</segment>
    <segment id="49">A hipótese ganha força</segment>
    <segment id="50">, segundo Lúcia Roma</segment>
    <segment id="51">, amiga da família</segment>
    <segment id="52">, porque</segment>
    <segment id="53">porque Karla sofreria de uma miocardiopatia que todos</segment>
    <segment id="54">, inclusive ela</segment>
    <segment id="55">, desconheciam.</segment>
    <segment id="56">Apenas a necropsia</segment>
    <segment id="57">, diz Lúcia</segment>
    <segment id="58">, revelou o problema.</segment>
    <segment id="59">-</segment>
    <segment id="60">É uma cena shakesperiana</segment>
    <segment id="61">, Romeu e Julieta.</segment>
    <segment id="62">Queria saber</segment>
    <segment id="63">comocomo foi a cena anterior - diz o ator Anselmo Vasconcellos</segment>
    <segment id="64">, amigo de Emiliano</segment>
    <segment id="65">, assistente de direção de Dona Flor e Seus Dois Maridos</segment>
    <segment id="66">, entre outros filmes.</segment>
    <segment id="67">O casal deverá ser cremado nesta quinta-feira.</segment>
  </rst>
</analysis>