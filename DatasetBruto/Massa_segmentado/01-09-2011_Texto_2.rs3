  <rst>
    <segment id="1">Criminalidade cai em Nova Constituinte
Bairro</segment>
    <segment id="2">, no entanto</segment>
    <segment id="3">, carece de infraestrutura</segment>
    <segment id="4">A comunidade de Nova Constituinte</segment>
    <segment id="5">, no subúrbio</segment>
    <segment id="6">, tem diversas histórias para contar sobre mortes relacionadas ao tráfico</segment>
    <segment id="7">, masmas garante que a situação melhorou há um ano.</segment>
    <segment id="8">A localidade foi citada em reportagem do jornal “The New York Times”</segment>
    <segment id="9">, dos EUA</segment>
    <segment id="10">, publicada na última terça</segment>
    <segment id="11">, como</segment>
    <segment id="12">como uma das áreas de Salvador onde houve uma série de assassinatos ligados às drogas entre 2006 e 2010.</segment>
    <segment id="13">Segundo o major PM Gérson Pereira</segment>
    <segment id="14">, comandante da 18ª CI-PM (responsável pelo policiamento em Nova Constituinte e outros cinco bairros)</segment>
    <segment id="15">, o ápice da violência foi em 2009</segment>
    <segment id="16">, quando houve 17 assassinatos.</segment>
    <segment id="17">“Havia dois grandes grupos rivais disputando os pontos de drogas.</segment>
    <segment id="18">Os grandes líderes foram presos</segment>
    <segment id="19">, enquanto outros morreram”</segment>
    <segment id="20">, explica.</segment>
    <segment id="21">Em 2010</segment>
    <segment id="22">, o número caiu para 12 e este ano</segment>
    <segment id="23">, duas pessoas foram assassinadas</segment>
    <segment id="24">, uma delas em crime passional.</segment>
    <segment id="25">O tapeceiro José dos Santos lembra dos tempos de violência desenfreada:</segment>
    <segment id="26">“Antes dava 18h e estava tudo fechado.</segment>
    <segment id="27">Os traficantes da rua Alto do Congo viviam em guerra com os rivais da  Beira Rio.</segment>
    <segment id="28">Quem estivesse na hora sobrava”.</segment>
    <segment id="29">Se a comunidade vive dias melhores em relação à criminalidade</segment>
    <segment id="30">,  a situação é caótica em termos de infraestrutura e risco social.</segment>
    <segment id="31">Comunidade abandonada: Só quatro ruas asfaltadas</segment>
    <segment id="32">O grande problema da comunidade de Nova Constituinte é infraestrutura ou a falta dela.</segment>
    <segment id="33">Os únicos equipamentos públicos do bairro são um Posto de Saúde da Família e uma quadra de esportes.</segment>
    <segment id="34">Não há escolas públicas</segment>
    <segment id="35">,  transporte e apenas quatro das 85 ruas (entre travessas e becos) do bairro são asfaltadas.</segment>
    <segment id="36">Os moradores precisam andar entre 10 e 15 minutos para pegar ônibus.</segment>
    <segment id="37">A primeira rua foi asfaltada há apenas dois anos.</segment>
    <segment id="38">Os Correios entregam as cartas na Associação de Moradores</segment>
    <segment id="39">, onde cada morador vai buscar.</segment>
    <segment id="40">“A numeração das casas não obedece a uma ordem.</segment>
    <segment id="41">Por isso os Correios não realizam a entrega”</segment>
    <segment id="42">, conta a líder comunitária Angela dos Santos.</segment>
    <segment id="43">A comunidade Nova Constituinte foi fundada há 27 anos.</segment>
    <segment id="44">Atualmente</segment>
    <segment id="45">, o bairro tem cerca de 32 mil habitantes em uma área de 5.600 quilômetros quadrados.</segment>
    <segment id="46">Energia elétrica e água encanada chegaram em 1996.</segment>
    <segment id="47">Antes disso</segment>
    <segment id="48">,  as ligações eram clandestinas.</segment>
    <segment id="49">Nova Constituinte faz fronteira com os bairros de Periperi</segment>
    <segment id="50">, Alto de Coutos</segment>
    <segment id="51">, Vista Alegre e Fazenda Coutos.</segment>
  </rst>
</analysis>