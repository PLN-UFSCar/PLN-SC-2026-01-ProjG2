  <rst>
    <segment id="1">Cantora deve</segment>
    <segment id="2">sese recuperar em 15 dias</segment>
    <segment id="3">Com o tipo brando da doença</segment>
    <segment id="4">, ela precisa de repouso</segment>
    <segment id="5">A infectologista Ana Paula</segment>
    <segment id="6">Alcântara alerta para a diferenciação que deve haver sobre a meningite viral – que foi diagnosticada na cantora Ivete Sangalo –</segment>
    <segment id="7">, com relação à meningite bacteriana</segment>
    <segment id="8">,  causada por três tipos de bactérias: meningococos</segment>
    <segment id="9">, pneumococos e hemófilos.</segment>
    <segment id="10">“</segment>
    <segment id="11">As bacterianas são as mais greves e requer um tratamento a base de antibióticos</segment>
    <segment id="12">, já as virais são de evolução benigna</segment>
    <segment id="13">, ou seja</segment>
    <segment id="14">, tem uma evolução favorável independente de remédio e não estão relacionadas com complicações maiores”</segment>
    <segment id="15">, explicou.</segment>
    <segment id="16">Segundo a também infectologista Ledivia Espinheira</segment>
    <segment id="17">, a meningite viral é atribuída a um vírus que não apresenta possibilidade de terapêutica antibiótica</segment>
    <segment id="18">, ou seja</segment>
    <segment id="19">, o uso de medicamentos antibióticos.</segment>
    <segment id="20">“Estes agentes virais são doenças autolimitadas</segment>
    <segment id="21">, masmas que também requerem internamento</segment>
    <segment id="22">porque</segment>
    <segment id="23">porque muitas vezes causam febre</segment>
    <segment id="24">, dor de cabeça e vômitos”</segment>
    <segment id="25">, destacou.</segment>
    <segment id="26">Os sintomas das meningites bacterianas e virais são os mesmos: dor de cabeça</segment>
    <segment id="27">, febre e vômito.</segment>
    <segment id="28">Somente um médico poderá confirmar o diagnóstico.</segment>
    <segment id="29">De acordo com as infectologistas</segment>
    <segment id="30">, o tratamento da meningite viral dura em torno de duas semanas e é recomendado repouso.</segment>
    <segment id="31">Ou seja</segment>
    <segment id="32">, Veveta deve voltar à ativa em 15 dias.</segment>
    <segment id="33">Entenda o</segment>
    <segment id="34">casocaso</segment>
    <segment id="35">A transmissão do vírus</segment>
    <segment id="36">, na maioria dos casos</segment>
    <segment id="37">, é por via respiratória ou pela contaminação de alimentos e objetos.</segment>
    <segment id="38">Segundo a superintendente de vigilância e proteção da saúde da Sesab</segment>
    <segment id="39">, Alcina Andrade</segment>
    <segment id="40">, o  período de festas e o verão não devem ser considerados</segment>
    <segment id="41">comocomo momentos de grande risco de transmissão da meningite viral.</segment>
    <segment id="42">“Teoricamente</segment>
    <segment id="43">sese a transmissão direta é para quem tem contato íntimo.</segment>
    <segment id="44">Mas um contato dentro do ônibus</segment>
    <segment id="45">, no bloco</segment>
    <segment id="46">, não há tanto risco.</segment>
    <segment id="47">A definição de contato é intimidade.</segment>
    <segment id="48">Existe um risco aumentado no risco de Carnaval</segment>
    <segment id="49">, por causa do beijo</segment>
    <segment id="50">, por isso pedimos que os artistas não estimulem esse tipo de contato”.</segment>
    <segment id="51">O tratamento geralmente é com hidratação na veia</segment>
    <segment id="52">, repouso e tomar medicamentos para melhorar os sintomas.</segment>
  </rst>
</analysis>