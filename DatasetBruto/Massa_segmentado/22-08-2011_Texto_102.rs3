  <rst>
    <segment id="1">Cinara Leal</segment>
    <segment id="2">Atriz pode gravar série austríaca em Salvador
Cinara Leal</segment>
    <segment id="3">, que fez a novela “Araguaia”</segment>
    <segment id="4">, está feliz da vida.</segment>
    <segment id="5">Isso porque</segment>
    <segment id="6">porque a moça vai fazer um teste para uma série austríaca.</segment>
    <segment id="7">Os produtores do seriado já estão no Brasil exclusivamente para realizar essa avaliação com a atriz.</segment>
    <segment id="8">Se aprovada</segment>
    <segment id="9">, ela vai gravar as cenas</segment>
    <segment id="10">, que vão ao ar na Áustria</segment>
    <segment id="11">, em Salvador.</segment>
    <segment id="12">Apesar de não falar alemão</segment>
    <segment id="13">, a língua oficial deste país</segment>
    <segment id="14">, ela diz:</segment>
    <segment id="15">“Vou dar o melhor de mim”.</segment>
  </rst>
