  <rst>
    <segment id="1">Jardineiro viciado em game é miserê</segment>
    <segment id="2">Um dos cabeças do tráfico de Portão</segment>
    <segment id="3">, Rô foi pego com armas</segment>
    <segment id="4">, drogas e video game</segment>
    <segment id="5">Em meio à pistola 380</segment>
    <segment id="6">,  munições</segment>
    <segment id="7">, drogas</segment>
    <segment id="8">, balança de precisão e algemas plásticas</segment>
    <segment id="9">– objetos normalmente apreendidos em posse de pessoas com ligação ao tráfico de drogas – policiais da 34ª DT (Portão) apreenderam também com o traficante Robson dos Santos Soares</segment>
    <segment id="10">, 19 anos</segment>
    <segment id="11">, vulgo Rô</segment>
    <segment id="12">,  um PlayStation 2.</segment>
    <segment id="13">O brinquedo tinha um papel importante na boca de fumo.</segment>
    <segment id="14">“Todo trabalhador tem direito a um dia de diversão”</segment>
    <segment id="15">, explicou ele</segment>
    <segment id="16">, revelando gostar de jogos de futebol</segment>
    <segment id="17">, luta e troca de tiros.</segment>
    <segment id="18">Conforme informações  do Serviço de Investigação (SI) da 34ª DT</segment>
    <segment id="19">, Rô jogava</segment>
    <segment id="20">, enquanto os comparsas  vigiavam a movimentação das vias de acesso à boca e traficavam.</segment>
    <segment id="21">O traficante atuava no Caji</segment>
    <segment id="22">, localidade do bairro de Vida Nova</segment>
    <segment id="23">, em Portão</segment>
    <segment id="24">, e foi preso na última terça</segment>
    <segment id="25">, na casa onde morava no Condomínio Campos Verde.</segment>
    <segment id="26">O “bom moço” diz</segment>
    <segment id="27">sese considerar um trabalhador e</segment>
    <segment id="28">, além do tráfico</segment>
    <segment id="29">, atua</segment>
    <segment id="30">comocomo jardineiro no condomínio.</segment>
    <segment id="31">“Recebemos denúncias de tráfico de drogas naquela área</segment>
    <segment id="32">, que apontam Robson</segment>
    <segment id="33">comocomo um dos cabeças.</segment>
    <segment id="34">Ele era responsável por armazenar as drogas</segment>
    <segment id="35">, fazer a cobrança e a segurança da boca”</segment>
    <segment id="36">, disse o delegado  da 34ª DT</segment>
    <segment id="37">, Cláudio Meireles.</segment>
    <segment id="38">Robson já foi preso por porte ilegal de armas e tráfico de drogas.</segment>
    <segment id="39">Quadrilha do pânico</segment>
    <segment id="40">Segundo o delegado</segment>
    <segment id="41">, há denúncias que apontam Rô e seu grupo</segment>
    <segment id="42">comocomo responsáveis por diversos homicídios</segment>
    <segment id="43">, cujas vítimas teriam sido mortas com um porrete.</segment>
    <segment id="44">“Acreditamos que uma dessas vítimas tenha sido um integrante do grupo dele conhecido</segment>
    <segment id="45">comocomo Igor</segment>
    <segment id="46">, além de devedores da boca”</segment>
    <segment id="47">, completou.</segment>
    <segment id="48">O porrete</segment>
    <segment id="49">, que também foi apreendido</segment>
    <segment id="50">, era sempre usado pelo bando.</segment>
    <segment id="51">Nesse mesmo dia</segment>
    <segment id="52">, eles o usaram para agredir o marido e o cunhado de uma moradora acusada de ter passado informações à polícia.</segment>
    <segment id="53">A mulher</segment>
    <segment id="54">, que morava há 10 anos no Caji</segment>
    <segment id="55">, e foi ameaçada de morte</segment>
    <segment id="56">, sese mudou na terça-feira sob escolta policial.</segment>
    <segment id="57">Em outra ocasião</segment>
    <segment id="58">, o bando destruiu e roubou a loja de um comerciante</segment>
    <segment id="59">, o agrediu com o porrete e o obrigou a deixar o bairro.</segment>
  </rst>
</analysis>