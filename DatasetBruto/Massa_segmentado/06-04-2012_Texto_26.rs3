  <rst>
    <segment id="1">Clientes madrugam para comprar peixe na Sexta-feira Santa
RIO - A Sexta-feira Santa começou cedo para quem madrugou no Mercado São Pedro</segment>
    <segment id="2">, em Niterói</segment>
    <segment id="3">, em busca de peixe.</segment>
    <segment id="4">Cerca de 20 mil pessoas passaram pelo mercado</segment>
    <segment id="5">, que às 5h já tinha fila na porta.</segment>
    <segment id="6">Muitos deixaram para comprar o almoço na última hora.</segment>
    <segment id="7">Até as 14h desta sexta-feira</segment>
    <segment id="8">, cerca de 50 toneladas de peixes e frutos do mar já tinham sido vendidos nos 40 boxes do Mercado São Pedro</segment>
    <segment id="9">, o mesmo volume comercializado em uma semana de funcionamento.</segment>
    <segment id="10">O trânsito ao redor foi intenso durante toda a manhã.</segment>
    <segment id="11">Nem mesmo a dificuldade para conseguir uma vaga para o carro afastou os clientes.</segment>
    <segment id="12">Luiz Alberto Arruda saiu de Saquarema e percorreu 90 quilômetros para comprar peixe em Niterói.</segment>
    <segment id="13">Já a médica colombiana Maria Patrícia mora na cidade</segment>
    <segment id="14">, masmas deixou para sexta a ida ao mercado:

- Sempre compro na própria sexta-feira</segment>
    <segment id="15">porque</segment>
    <segment id="16">porque consigo peixe mais fresco e preços melhores.</segment>
    <segment id="17">Tem sempre promoção.</segment>
    <segment id="18">Atílio Guglielmo</segment>
    <segment id="19">, dono de uma da peixarias do mercado</segment>
    <segment id="20">, vendeu nesta sexta-feira cerca de 1</segment>
    <segment id="21">,5 mil quilos de peixe.

-</segment>
    <segment id="22">O movimento foi grande</segment>
    <segment id="23">, não dava nem para andar no mercado.</segment>
    <segment id="24">Mas durante a semana também foi bom.</segment>
    <segment id="25">Muitos anteciparam as compras e o mercado vendeu 150 toneladas de pescado entre segunda e hoje - contou.</segment>
    <segment id="26">- Amanhã ainda vem muita gente.</segment>
    <segment id="27">Acho que pelo menos 5 toneladas ainda serão vendidas.</segment>
    <segment id="28">Depois do almoço</segment>
    <segment id="29">, católicos comparecem a eventos religiosos</segment>
    <segment id="30">Após o almoço em família</segment>
    <segment id="31">, foi a vez do católicos celebrarem a paixão e a morte de Cristo numa cerimônia na Catedral Metropolitana</segment>
    <segment id="32">, no Centro do Rio</segment>
    <segment id="33">, presidida pelo arcebispo Dom Orani Tempesta.</segment>
    <segment id="34">Em seguida</segment>
    <segment id="35">, no início da noite</segment>
    <segment id="36">, pelo menos 3 mil fiéis acompanharam a procissão do Senhor Morto até os Arcos da Lapa.</segment>
    <segment id="37">Na Catedral</segment>
    <segment id="38">, Dom Orani passou uma mensagem sobre a importância de manter a esperança</segment>
    <segment id="39">, mesmo diante das dificuldades do mundo atual.</segment>
    <segment id="40">Para o arcebispo</segment>
    <segment id="41">, a Páscoa é tempo de reaprender e aprofundar as lições deixadas por Cristo.

- Acho que as violências</segment>
    <segment id="42">, as corrupções</segment>
    <segment id="43">, as dificuldades</segment>
    <segment id="44">, as desuniões e as guerras desse tempo agora demonstram o egoísmo que está no coração do homem</segment>
    <segment id="45">, e muitas vezes também todos os seus ódios</segment>
    <segment id="46">, seus rancores.</segment>
    <segment id="47">Cristo nos mostra que o caminho é outro:</segment>
    <segment id="48">o caminho da paz</segment>
    <segment id="49">, do perdão e da fraternidade.</segment>
    <segment id="50">E celebrar a morte de Cristo e a sua ressurreição é ter confiança de que</segment>
    <segment id="51">, apesar de todos os problemas</segment>
    <segment id="52">, não devemos desanimar.</segment>
    <segment id="53">A ressurreição é a ultima palavra - disse Dom Orani</segment>
    <segment id="54">, depois da liturgia.</segment>
    <segment id="55">O arcebispo também participou da procissão</segment>
    <segment id="56">, seguida por cariocas e turistas estrangeiros de férias no Rio.</segment>
    <segment id="57">Moradora de Botafogo</segment>
    <segment id="58">, a aposentada Nicinia Brandão</segment>
    <segment id="59">, de 71 anos</segment>
    <segment id="60">, contou que acompanha todos os anos o cortejo</segment>
    <segment id="61">, e que a emoção é sempre a mesma:

- É sempre muito emocionante.</segment>
    <segment id="62">É como</segment>
    <segment id="63">como estar perdendo alguém.</segment>
    <segment id="64">As celebrações continuam neste sábado com a Vigília Pascal</segment>
    <segment id="65">, na Catedral</segment>
    <segment id="66">, às 20h.</segment>
    <segment id="67">Após a vigília</segment>
    <segment id="68">, haverá a missa pela ressurreição do Senhor.</segment>
    <segment id="69">No domingo</segment>
    <segment id="70">, às 10h</segment>
    <segment id="71">, acontece a Missa de Páscoa.</segment>
  </rst>
</analysis>