  <rst>
    <segment id="1">Axezeira vira heroína de gibi</segment>
    <segment id="2">A cantora aposta no estilo dos mangás para marcar a sua volta à folia de Momo</segment>
    <segment id="3">Gilmelândia irá desfilar uma única vez no Carnaval deste ano</segment>
    <segment id="4">, masmas promete fazer com que esse momento repercuta muito.</segment>
    <segment id="5">E, para isso</segment>
    <segment id="6">, a cantora aposta no estilo dos mangás</segment>
    <segment id="7">, como</segment>
    <segment id="8">como pode ser visto no figurino mostrado aqui com exclusividade.</segment>
    <segment id="9">A peça</segment>
    <segment id="10">, que marcará a volta de Gil à folia de Momo</segment>
    <segment id="11">, foi criada pelo estilista Sandro Lopes em parceria com a Thonson Produções.</segment>
    <segment id="12">Além do figurino</segment>
    <segment id="13">, a artista apostará na interatividade e em muita axé-music  para comandar  o Bloco da Gil</segment>
    <segment id="14">, dia 17 de fevereiro</segment>
    <segment id="15">, no circuito Dodô (Barra-Ondina).</segment>
    <segment id="16">Os foliões pagam apenas R$ 50</segment>
    <segment id="17">,00 pelo abadá</segment>
    <segment id="18">, com direito a uma cerveja.</segment>
    <segment id="19">A ação social também estará presente na festa da cantora.</segment>
    <segment id="20">Destacando  o “Dia Rosa”</segment>
    <segment id="21">, que é dedicado ao combate ao câncer de mama</segment>
    <segment id="22">, Gil  pretende chamar a atenção sobre uma doença que pode  atingir 2.110 mulheres na Bahia este ano</segment>
    <segment id="23">, segundo o  Instituto Nacional de Câncer.</segment>
    <segment id="24">A cor rosa</segment>
    <segment id="25">, por sinal</segment>
    <segment id="26">, estará presente também em outros detalhes da agremiação</segment>
    <segment id="27">, como</segment>
    <segment id="28">como nas camisas dos cordeiros e na corda de neon que circunda o bloco.</segment>
    <segment id="29">Esse ano marca a volta da cantora</segment>
    <segment id="30">, já que no ano passado ela não desfilou.</segment>
  </rst>
</analysis>