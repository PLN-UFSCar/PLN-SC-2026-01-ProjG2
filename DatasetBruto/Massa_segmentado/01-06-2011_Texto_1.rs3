  <rst>
    <segment id="1">Executado pelo Bonde da Nem
Tailan Elias testemunhou contra os bandidos de Periperi na polícia e foi morto</segment>
    <segment id="2">Uma das principais testemunhas do inquérito policial contra Maria Lúcia dos Santos Gomes</segment>
    <segment id="3">, 36 anos</segment>
    <segment id="4">, a Nem Gorda (presa sob acusação de tráfico de drogas e homicídio)</segment>
    <segment id="5">, o jovem Tailan Elias de Brito</segment>
    <segment id="6">, 18, foi assassinado com dois tiros nas costas</segment>
    <segment id="7">, na última sexta-feira</segment>
    <segment id="8">, 27, na Rua Belo Horizonte</segment>
    <segment id="9">, Praça do Cruzeiro</segment>
    <segment id="10">, no bairro de Periperi.</segment>
    <segment id="11">Tailan havia sido preso pela polícia no dia 15 de maio</segment>
    <segment id="12">, junto com Nem Gorda.</segment>
    <segment id="13">Em depoimento no Departamento de Homicídios e Proteção à Pessoa (DHPP)</segment>
    <segment id="14">, Tailan relatou que a idosa Alaíde Queiroz</segment>
    <segment id="15">, 70, foi morta no dia 14 de maio por três soldados do Bonde da Nem: Alex Brito das Neves</segment>
    <segment id="16">, 21, o Grilinho</segment>
    <segment id="17">, marido de Nem Gorda</segment>
    <segment id="18">; e outros dois homens conhecidos</segment>
    <segment id="19">comocomo Fofão e Neizinho.</segment>
    <segment id="20">Preferindo manter o nome em sigilo</segment>
    <segment id="21">, um policial revelou ao MASSA! não ter dúvidas de que Tailan foi assassinado</segment>
    <segment id="22">comocomo forma de represália</segment>
    <segment id="23">, pois</segment>
    <segment id="24">pois o Bonde da Nem teria desconfiado de que ele denunciou membros da quadrilha à polícia.</segment>
    <segment id="25">Segundo a fonte</segment>
    <segment id="26">, Tailan foi morto por um homem de prenome Danilo.</segment>
    <segment id="27">A delegada Joana Angélica</segment>
    <segment id="28">, titular do DHPP</segment>
    <segment id="29">, afirma que ainda é cedo para especular sobre os possíveis assassinos e motivos para o homicídio.</segment>
    <segment id="30">Aterrorizados</segment>
    <segment id="31">, os familiares de Tailan preferiram não comparecer à polícia e evitaram contato com a imprensa.</segment>
    <segment id="32">Estava na casa de Nem quando ela foi presa
Tailan foi baleado por volta das 6h30 da noite do último dia 27.</segment>
    <segment id="33">Ele ainda foi levado ao Hospital do Subúrbio</segment>
    <segment id="34">, por uma viatura da PM</segment>
    <segment id="35">, masmas morreu por volta das 8h30.</segment>
    <segment id="36">Segundo a polícia</segment>
    <segment id="37">, Tailan estava na casa de Nem Gorda no dia em que ela foi presa.</segment>
    <segment id="38">Grilinho atirou nos policiais e acabou atingindo a mão esquerda de Tailan.</segment>
    <segment id="39">O marido de Nem fugiu e Tailan foi encaminhado ao DHPP</segment>
    <segment id="40">, no bairro da Pituba</segment>
    <segment id="41">, para prestar esclarecimentos.</segment>
    <segment id="42">Após depoimento</segment>
    <segment id="43">, ele foi liberado por falta de provas e</segment>
    <segment id="44">porque</segment>
    <segment id="45">porque não foi reconhecido pelas testemunhas da morte da idosa Alaíde.</segment>
    <segment id="46">Ele não tinha ficha na polícia.</segment>
    <segment id="47">Denúncias: Moradores com medo
Moradores da região do Alto do Tanque</segment>
    <segment id="48">, em Periperi</segment>
    <segment id="49">, denunciam que bandidos ligados ao tráfico de drogas continuam amedrontando a população local com ameaças</segment>
    <segment id="50">, além de esconderem várias armas dentro das próprias casas.</segment>
    <segment id="51">“</segment>
    <segment id="52">Enquanto tiver gente visitando</segment>
    <segment id="53">Nem Gorda na prisão</segment>
    <segment id="54">, ela vai mandar mensagem para matar alguém”</segment>
    <segment id="55">, desabafa uma testemunha</segment>
    <segment id="56">, sem revelar o nome</segment>
    <segment id="57">, pois</segment>
    <segment id="58">pois teme represálias.</segment>
    <segment id="59">Em depoimento</segment>
    <segment id="60">, Nem Gorda disse duvidar que os vizinhos faziam denúncias à polícia</segment>
    <segment id="61">, pois</segment>
    <segment id="62">pois nunca teve desentendimento com nenhum morador do bairro.</segment>
  </rst>
</analysis>