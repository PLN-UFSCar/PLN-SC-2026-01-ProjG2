  <rst>
    <segment id="1">Andrezinho</segment>
    <segment id="2">, a estrela do Botafogo para 2012
RIO - Aos poucos</segment>
    <segment id="3">, o Botafogo ganha uma nova cara para a temporada de 2012.</segment>
    <segment id="4">Nesta terça-feira pela manhã</segment>
    <segment id="5">, em General Severiano</segment>
    <segment id="6">, a diretoria vai apresentar o meia-atacante Andrezinho</segment>
    <segment id="7">, contratado para ser uma das estrelas do time que será comandado pelo técnico Oswaldo de Oliveira.</segment>
    <segment id="8">O zagueiro Brinner</segment>
    <segment id="9">, ex-Paraná</segment>
    <segment id="10">, foi o primeiro nome anunciado pelo clube.
- A motivação é enorme</segment>
    <segment id="11">, até pela confiança que o Botafogo depositou em mim e pela recepção que tive - disse Andrezinho</segment>
    <segment id="12">, ao site oficial do clube.</segment>
    <segment id="13">- No aeroporto</segment>
    <segment id="14">, encontrei torcedores empolgados e confiantes</segment>
    <segment id="15">, o que me dá mais vontade de jogar.</segment>
    <segment id="16">Era um namoro antigo</segment>
    <segment id="17">, felizmente agora</segment>
    <segment id="18">sese concretizou.</segment>
    <segment id="19">É uma satisfação atuar em um clube de tantos ídolos.</segment>
    <segment id="20">Estou animado para defender o Botafogo.</segment>
    <segment id="21">O Botafogo adquiriu 50% dos direitos econômicos de Andrezinho ao Internacional.</segment>
    <segment id="22">O Nova Iguaçu</segment>
    <segment id="23">, clube formador do jogador</segment>
    <segment id="24">, continua com os outros 50%.</segment>
    <segment id="25">Andrezinho</segment>
    <segment id="26">, de 28 anos</segment>
    <segment id="27">, começou a carreira profissional no Flamengo</segment>
    <segment id="28">, seguindo para a Coreia do Sul antes de aterrissar no Beira-Rio</segment>
    <segment id="29">, onde ficou nos últimos quatro anos e ganhou títulos importantes</segment>
    <segment id="30">comocomo a Copa Libertadores</segment>
    <segment id="31">, a Sul-Americana e três campeonatos gaúchos.</segment>
    <segment id="32">O clube espera acertar em breve com um zagueiro e dois laterais</segment>
    <segment id="33">, um para cada lado.</segment>
  </rst>
