  <rst>
    <segment id="1">Tiros e morte em local de estudo</segment>
    <segment id="2">Suposto policial reage a assalto e mata adolescente de 17 anos que tentou roubﾃδ｡-lo</segment>
    <segment id="3">Os tiros e a posterior morte de um adolescente de 17 anos no estacionamento da Faculdade ﾃビea 1</segment>
    <segment id="4">, situada na Avenida Paralela</segment>
    <segment id="5">, causaram alvoroﾃδｧo entre os estudantes da unidade</segment>
    <segment id="6">, na manhﾃδ｣ de ontem.</segment>
    <segment id="7">Os seguranﾃδｧas da instituiﾃδｧﾃδ｣o mandaram os alunos</segment>
    <segment id="8">sese trancarem na sala ou deixarem o prﾃδｩdio</segment>
    <segment id="9">, porque</segment>
    <segment id="10">porque havia um homem armado no local.</segment>
    <segment id="11">A Polﾃδｭcia Militar foi chamada e encontrou Railan da Silva Santana</segment>
    <segment id="12">, 17, baleado e escondido no banheiro.</segment>
    <segment id="13">O jovem portava um revﾃδｳlver.</segment>
    <segment id="14">Conforme nota enviada pela ﾃビea 1</segment>
    <segment id="15">, Railan tentou assaltar um policial</segment>
    <segment id="16">, que reagiu atirando.</segment>
    <segment id="17">Para fugir</segment>
    <segment id="18">, o adolescente entrou no prﾃδｩdio da faculdade pela garagem e</segment>
    <segment id="19">sese escondeu no banheiro.</segment>
    <segment id="20">No entanto</segment>
    <segment id="21">, alguns estudantes contaram que os tiros ocorreram dentro do prﾃδｳprio estacionamento e que o suposto policial</segment>
    <segment id="22">, que foi alvo do roubo</segment>
    <segment id="23">, ﾃδｩ estudante da instituiﾃδｧﾃδ｣o.</segment>
    <segment id="24">O ladrﾃδ｣o veio roubar a moto do suposto policial.</segment>
    <segment id="25">Aﾃδｭ ele reagiu dando quatro tiros</segment>
    <segment id="26">ﾃδ queima-roupa dentro da garagem</segment>
    <segment id="27">, conta o estudante de engenharia elﾃδｩtrica Moisﾃδｩs Abraﾃδ｣o.</segment>
    <segment id="28">Antes do envio da nota</segment>
    <segment id="29">, o coordenador geral de curso da ﾃビea 1</segment>
    <segment id="30">, Cristiano de Aguiar</segment>
    <segment id="31">, concedeu entrevista coletiva aos repﾃδｳrteres presentes no local do crime.</segment>
    <segment id="32">Ele informou que a vﾃδｭtima do assalto era um estudante da faculdade</segment>
    <segment id="33">, masmas nﾃδ｣o soube dizer quem foi o autor dos disparos contra o suposto assaltante.</segment>
    <segment id="34">A vﾃδｭtima (do roubo) era estudante da instituiﾃδｧﾃδ｣o e estava vindo para a faculdade.</segment>
    <segment id="35">O bandido provavelmente estava seguindo ele atﾃδｩ aqui</segment>
    <segment id="36">, relatou.</segment>
    <segment id="37">Jﾃδ｡ chegou morto</segment>
    <segment id="38">Uma guarniﾃδｧﾃδ｣o da 82ﾃつｪ CIPM</segment>
    <segment id="39">(CAB) levou Railan ao Hospital Roberto Santos.</segment>
    <segment id="40">Segundo informaﾃδｧﾃδｵes do posto policial</segment>
    <segment id="41">, o adolescente foi baleado na cabeﾃδｧa</segment>
    <segment id="42">, tﾃδｳrax e braﾃδｧo esquerdo</segment>
    <segment id="43">,</segment>
    <segment id="44">e jﾃδ｡ chegou morto.</segment>
    <segment id="45">Os PMs informaram no posto que foram ﾃδ faculdade atender um chamado para prestar socorro a um baleado.</segment>
    <segment id="46">Eles recolheram um revﾃδｳlver com Railan</segment>
    <segment id="47">, masmas a arma nﾃδ｣o foi apresentada no posto policial do hospital.</segment>
    <segment id="48">Segundo informaﾃδｧﾃδｵes da Delegacia para o Adolescente Infrator</segment>
    <segment id="49">, Railan nﾃδ｣o tem histﾃδｳrico na unidade.</segment>
    <segment id="50">A PM nega que o atirador seja policial.</segment>
    <segment id="51">O Departamento de Homicﾃδｭdios investiga o</segment>
    <segment id="52">casocaso.</segment>
    <segment id="53">Estudantes na bruxa</segment>
    <segment id="54">Os estudantes aproveitaram a presenﾃδｧa da imprensa para reclamar da seguranﾃδｧa na faculdade.</segment>
    <segment id="55">Falaram sobre as catracas que ficam quebradas com frequﾃδｪncia</segment>
    <segment id="56">, o que facilita o acesso ao local.</segment>
    <segment id="57">Nesse estacionamento</segment>
    <segment id="58">, qualquer um entra antes das catracas</segment>
    <segment id="59">, reclama o estudante de engenharia Pedro Henrique.</segment>
    <segment id="60">O aluno de direito Murilo Dourado lembrou que existem cursos com a mensalidade acima de R$ 2 mil e que o fato nﾃδ｣o poderia ter ocorrido na faculdade.</segment>
    <segment id="61">Estava na praﾃδｧa de alimentaﾃδｧﾃδ｣o e comeﾃδｧou o alvoroﾃδｧo por causa do barulho.</segment>
    <segment id="62">Ninguﾃδｩm sabia</segment>
    <segment id="63">sese era tiro ou outra coisa.</segment>
    <segment id="64">Isso ﾃδｩ lamentﾃδ｡vel</segment>
    <segment id="65">, declarou.</segment>
    <segment id="66">A ﾃビea 1 informou</segment>
    <segment id="67">, por meio de nota</segment>
    <segment id="68">, que o prﾃδｩdio da faculdade</segment>
    <segment id="69">ﾃδｩ protegido por um sistema de seguranﾃδｧa com catracas de acesso e vigilantes.</segment>
    <segment id="70">Sem feridos</segment>
    <segment id="71">De acordo com a nota da ﾃビea 1</segment>
    <segment id="72">, a confusﾃδ｣o causada pelo crime</segment>
    <segment id="73">, ninguﾃδｩm</segment>
    <segment id="74">sese feriu.</segment>
    <segment id="75">Ninguﾃδｩm da faculdade</segment>
    <segment id="76">ﾃビea 1 foi ferido</segment>
    <segment id="77">, nem alunos</segment>
    <segment id="78">, nem professores</segment>
    <segment id="79">, nem colaboradores.</segment>
    <segment id="80">Nossa comunidade acadﾃδｪmica tambﾃδｩm nﾃδ｣o teve contato com o ocorrido</segment>
    <segment id="81">, pois</segment>
    <segment id="82">pois a ﾃδ｡rea foi isolada rapidamenteﾃ｢竄ｬ.</segment>
  </rst>
