  <rst>
    <segment id="1">Moradores de área de risco pedem socorro</segment>
    <segment id="2">Eles relatam momentos de terror com o deslizamento</segment>
    <segment id="3">A história das áreas de risco de Salvador</segment>
    <segment id="4">sese confunde com o relato das  tragédias</segment>
    <segment id="5">, quase sempre anunciadas muito antes da época das chuvas.</segment>
    <segment id="6">Não é diferente na Rua Jaguaracira de Souza</segment>
    <segment id="7">, no Calabetão</segment>
    <segment id="8">, onde os moradores convivem com o medo há 20 anos.</segment>
    <segment id="9">“Estava dormindo  e somente escutei os vizinhos gritando que a casa estava caindo.</segment>
    <segment id="10">Só deu tempo de abrir a janela e passar  minha esposa gestante.</segment>
    <segment id="11">Depois</segment>
    <segment id="12">, enquanto eu passava</segment>
    <segment id="13">,  tudo desabou”.</segment>
    <segment id="14">O  relato é de Daniel Asenio</segment>
    <segment id="15">, 21, que escapou ileso de um  deslizamento de terra</segment>
    <segment id="16">, na madrugada de ontem.</segment>
    <segment id="17">Cerca de 50 famílias que moram  no local</segment>
    <segment id="18">sese queixam do descaso.</segment>
    <segment id="19">Segundo a comunidade</segment>
    <segment id="20">, diversos contatos  foram feitos com a Defesa Civil e a Limpurb</segment>
    <segment id="21">, masmas nenhuma providência  foi adotada.</segment>
    <segment id="22">Moradores dizem que há pelo menos quatro casas ameaçadas.</segment>
    <segment id="23">O Calabetão está na lista dos bairros considerados críticos pela Defesa Civil.</segment>
    <segment id="24">Mas, se</segment>
    <segment id="25">se depender do tempo</segment>
    <segment id="26">, a situação vai continuar tensa no local.</segment>
    <segment id="27">Segundo a meteorologia</segment>
    <segment id="28">, a chuva continua nos próximos dias.</segment>
    <segment id="29">Em alguns momentos o sol pode até aparecer</segment>
    <segment id="30">, masmas o mau tempo persiste até domingo.</segment>
    <segment id="31">Desabrigados: 100 casas condenadas no Santo Antônio</segment>
    <segment id="32">A encosta do Largo do Santo Antônio Além do Carmo foi condenada ontem e as famílias evacuadas</segment>
    <segment id="33">, depois que duas casas caíram e cinco estão na iminência de desabar.</segment>
    <segment id="34">Ninguém ficou ferido.</segment>
    <segment id="35">Há pelo menos 100 casas condenadas pela Defesa Civil.</segment>
    <segment id="36">Pela manhã</segment>
    <segment id="37">, vários moradores tinham sido retirados</segment>
    <segment id="38">, masmas alguns ainda resistiam.</segment>
    <segment id="39">À tarde</segment>
    <segment id="40">, um grupo de desabrigados fez manifestação na Av. Jequitaia contra a interdição.</segment>
    <segment id="41">O protesto só acabou após a chegada de uma assistente social da prefeitura.</segment>
    <segment id="42">Os desalojados foram levados para uma escola no Uruguai.</segment>
    <segment id="43">A Setad  informou que doará 600 itens para os desabrigados</segment>
    <segment id="44">, entre quentinhas</segment>
    <segment id="45">, colchões</segment>
    <segment id="46">, cobertores e cestas básicas.</segment>
  </rst>
</analysis>