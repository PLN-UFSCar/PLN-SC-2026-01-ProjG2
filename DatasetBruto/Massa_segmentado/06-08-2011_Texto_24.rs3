  <rst>
    <segment id="1">Desafio especial para Elkeson no Botafogo</segment>
    <segment id="2">A trajetória de Elkeson no clube é interessante.</segment>
    <segment id="3">Ele chegou ao Botafogo antes do início do Brasileiro após uma dura disputa com o Fluminense.</segment>
    <segment id="4">A resposta do jogador nascido no Maranhão</segment>
    <segment id="5">masmas com toda a sua trajetória no futebol passada no Vitória-BA foi a mais positiva possível.</segment>
    <segment id="6">Teve atuações convincentes</segment>
    <segment id="7">, fez gols e logo caiu no gosto da torcida.</segment>
    <segment id="8">Nas últimas rodadas</segment>
    <segment id="9">, o seu desempenho não foi o mesmo.</segment>
    <segment id="10">Muito marcado por ser um dos destaques da equipe</segment>
    <segment id="11">, o jogador oscilou junto com o time.</segment>
    <segment id="12">Mesmo assim</segment>
    <segment id="13">, não deixou de aparecer com a bola nos pés.</segment>
    <segment id="14">Mas o rendimento geral ficou comprometido.</segment>
    <segment id="15">Sem marcar há seis jogos</segment>
    <segment id="16">, o jogador passou a ser contestado por um grupo de torcedores que atribuiu sua queda de rendimento a uma vida noturna incompatível com a de um atleta de futebol.</segment>
    <segment id="17">No dia seguinte à derrota para o Figueirense por 2 a 0 em Florianópolis</segment>
    <segment id="18">, na quarta-feira</segment>
    <segment id="19">, Elkeson respondeu as críticas em seu Twitter.</segment>
    <segment id="20">Ele explicou que não é jogador que goste de sair à noite e</segment>
    <segment id="21">, educadamente</segment>
    <segment id="22">, pediu desculpas a todos por não estar rendendo tudo o que sabe dentro de campo</segment>
    <segment id="23">, masmas ressaltou que estava</segment>
    <segment id="24">sese esforçando.</segment>
    <segment id="25">Logo após decidiu encerrar a sua conta na rede social.</segment>
    <segment id="26">O fato não preocupou o técnico Caio Júnior.</segment>
    <segment id="27">Para ele</segment>
    <segment id="28">, é natural que um jogador jovem</segment>
    <segment id="29">comocomo Elkeson oscile um pouco durante uma competição tão difícil</segment>
    <segment id="30">comocomo o Brasileiro.</segment>
    <segment id="31">Mas nada que tire sua esperança no brilho do jogador.

- O Elkeson é dono de um potencial incrível.</segment>
    <segment id="32">Oscilou</segment>
    <segment id="33">, masmas vai dar resposta logo.</segment>
    <segment id="34">Ainda vai ser um dos grandes do futebol brasileiro.</segment>
    <segment id="35">É só ter um pouco de paciência - disse o treinador.</segment>
    <segment id="36">O fato de depositar grande esperança em Elkeson faz parte de uma estratégia clara de Caio Júnior de valorizar seus jogadores.</segment>
    <segment id="37">Ele sabe que não pode depender apenas de um dia iluminado de Elkeson para vencer o Vasco.</segment>
    <segment id="38">Pelo contrário</segment>
    <segment id="39">, conta com o esforço e a dedicação de todos para o time não cometer o mesmo pecado da derrota contra o Figueirense</segment>
    <segment id="40">, em que teve a posse de bola na maior parte do jogo</segment>
    <segment id="41">, masmas finalizou muito pouco.</segment>
    <segment id="42">Em meio à rivalidade do clássico</segment>
    <segment id="43">, a diretoria alvinegra ainda decidiu lançar seus três novos modelos de camisa contra o Vasco.</segment>
    <segment id="44">No ano passado</segment>
    <segment id="45">, quando tomou decisão semelhante</segment>
    <segment id="46">, o resultado foi desastroso</segment>
    <segment id="47">, com uma goleada vascaína de 6 a 0 no Engenhão.</segment>
    <segment id="48">Este ano</segment>
    <segment id="49">, a torcida é pelo sucesso da promoção.</segment>
    <segment id="50">No intervalo do jogo também será anunciada a data de uma homenagem a Zagallo pelos seus 80 anos.</segment>
    <segment id="51">Como Zagallo é um devoto fervoroso do número 13 e Loco Abreu não abre mão de sua camisa com o mesmo número</segment>
    <segment id="52">, a torcida alvinegra é que a superstição funcione à favor desta vez.</segment>
    <segment id="53">Seja com ele ou com a nove de Elkeson.</segment>
    <segment id="54">Botafogo:Jéfferson</segment>
    <segment id="55">, Alessandro</segment>
    <segment id="56">, Antônio Carlos</segment>
    <segment id="57">, Fábio Ferreira e Cortês</segment>
    <segment id="58">; Marcelo Mattos</segment>
    <segment id="59">, Renato</segment>
    <segment id="60">, Elkeson e Felipe Menezes ( Lucas Zen)</segment>
    <segment id="61">;</segment>
    <segment id="62">Herrera e Loco Abreu.</segment>
    <segment id="63">Vasco:Fernando Prass</segment>
    <segment id="64">, Fágner</segment>
    <segment id="65">, Dedé</segment>
    <segment id="66">, Anderson Martins e Márcio Careca</segment>
    <segment id="67">; Rômulo</segment>
    <segment id="68">, Jumar (Juninho Pernambucano)</segment>
    <segment id="69">, Felipe e Diego Souza</segment>
    <segment id="70">; Éder Luís e Alecsandro.</segment>
    <segment id="71">Juiz: Marcelo de Lima Henrique.</segment>
  </rst>
