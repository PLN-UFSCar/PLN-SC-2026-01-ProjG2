  <rst>
    <segment id="1">Galera descobre</segment>
    <segment id="2">comocomo Гѓ</segment>
    <segment id="3">В© feito o MASSA!</segment>
    <segment id="4">Jornalista JoГѓВЈo EГѓВ§a faz palestra para estudantes de escola pГѓВєblica
Empolgados</segment>
    <segment id="5">, curiosos e bem dispostos.</segment>
    <segment id="6">Foi assim que os alunos do 8Г‚Вє ano do ColГѓВ©gio Estadual Tereza Helena Mata Pires</segment>
    <segment id="7">, no Lobato</segment>
    <segment id="8">, participaram da palestra do jornalista do MASSA!</segment>
    <segment id="9">, JoГѓВЈo EГѓВ§a</segment>
    <segment id="10">, na tarde da ГѓВєltima quarta (12)</segment>
    <segment id="11">, na sede da instituiГѓВ§ГѓВЈo.</segment>
    <segment id="12">Durante uma hora e meia</segment>
    <segment id="13">, aproximadamente</segment>
    <segment id="14">, ele falou sobre a rotina produtiva do jornal</segment>
    <segment id="15">, a escolha das notГѓВ­cias e respondeu ГѓВ s perguntas dos estudantes.</segment>
    <segment id="16">E como</segment>
    <segment id="17">como perguntaram!</segment>
    <segment id="18">Os meninos queriam saber de tudo</segment>
    <segment id="19">, desde o motivo que levou o Grupo</segment>
    <segment id="20">A TARDE a criar o MASSA!</segment>
    <segment id="21">atГѓВ© a seleГѓВ§ГѓВЈo de fotos das gatas que estampam as capas.</segment>
    <segment id="22">Antes mesmo do inГѓВ­cio da apresentaГѓВ§ГѓВЈo</segment>
    <segment id="23">, houve quem externasse o desejo de atuar na ГѓВЎrea.</segment>
    <segment id="24">Гўв‚¬Е“Poderia abrir vaga para alguns meninos daqui.</segment>
    <segment id="25">AГѓВ­ a fotГѓВіgrafa ia me ensinar a usar aquela mГѓВЎquina.</segment>
    <segment id="26">Se eu for trabalhar</segment>
    <segment id="27">, quero ficar na parte de PolГѓВ­ciaГўв‚¬</segment>
    <segment id="28">, reivindicou Renan Vitor Bispo</segment>
    <segment id="29">, 16.</segment>
    <segment id="30">Durante a explanaГѓВ§ГѓВЈo</segment>
    <segment id="31">, o jornalista JoГѓВЈo EГѓВ§a ressaltou que o papel do MASSA!</segment>
    <segment id="32">ГѓВ© buscar sempre o  lado humano das histГѓВіrias e valorizar os bairros populares.</segment>
    <segment id="33">Гўв‚¬Е“A gente quer mostrar as coisas boas que acontecem nos bairros.</segment>
    <segment id="34">O MASSA!</segment>
    <segment id="35">tem o estigma de ser Гўв‚¬Лњespreme e sai sangueГўв‚¬в„ў</segment>
    <segment id="36">, masmas tem apenas duas pГѓВЎginas de PolГѓВ­cia e nunca publicou imagem de sangue nem de corpoГўв‚¬</segment>
    <segment id="37">, completou ele</segment>
    <segment id="38">, que comanda a cobertura policial.</segment>
    <segment id="39">O encontro fez parte do projeto de leitura do jornal MASSA!</segment>
    <segment id="40">desenvolvido com a turma pela professora de LГѓВ­ngua Portuguesa MГѓВ©rcia</segment>
    <segment id="41">Abreu.</segment>
    <segment id="42">Criatividade chama atenГѓВ§ГѓВЈo
InspiraГѓВ§ГѓВЈo que vem das ruas Гўв‚¬Е“como sГѓВЈo feitos os tГѓВ­tulos?Гўв‚¬</segment>
    <segment id="43">, questionou Uanderson de Jesus</segment>
    <segment id="44">, 16.</segment>
    <segment id="45">A linguagem usada no MASSA!</segment>
    <segment id="46">, sobretudo nos tГѓВ­tulos</segment>
    <segment id="47">, ГѓВ© um dos aspectos que mais chamam atenГѓВ§ГѓВЈo da turma e</segment>
    <segment id="48">, por isso</segment>
    <segment id="49">, um dos mais trabalhados em sala de aula pela professora MГѓВ©rcia</segment>
    <segment id="50">Abreu.</segment>
    <segment id="51">Гўв‚¬Е“A gente percebe que a maioria dos textos tem linguagem formal.</segment>
    <segment id="52">E os tГѓВ­tulos sГѓВЈo mais criativos.</segment>
    <segment id="53">Existe um jogo de sentido que ГѓВ© construГѓВ­do de forma lГѓВєdica e eu costumo trabalhar com essa questГѓВЈoГўв‚¬</segment>
    <segment id="54">, explica a professora.</segment>
    <segment id="55">JoГѓВЈo EГѓВ§a disse que a inspiraГѓВ§ГѓВЈo para a criaГѓВ§ГѓВЈo dos tГѓВ­tulos pode vir de qualquer lugar</segment>
    <segment id="56">, inclusive de frases soltas ouvidas de colegas.</segment>
    <segment id="57">Гўв‚¬Е“Гѓв‚¬s vezes</segment>
    <segment id="58">, o tГѓВ­tulo vem do que as pessoas falam na rua.</segment>
    <segment id="59">O MASSA!</segment>
    <segment id="60">ГѓВ© feito mais de fora [da redaГѓВ§ГѓВЈo] para dentroГўв‚¬</segment>
    <segment id="61">, explicou o jornalista.</segment>
    <segment id="62">A opiniГѓВЈo dos estudantes
"</segment>
    <segment id="63">A gente tirou todas as dГѓВєvidas que surgiram durante as leituras do MASSA!</segment>
    <segment id="64">em sala.</segment>
    <segment id="65">Nunca pensei em ser jornalista.</segment>
    <segment id="66">Agora vou pensar melhor".</segment>
    <segment id="67">Cris Ewenly Pereira</segment>
    <segment id="68">, 17, Boiadeiro.
"</segment>
    <segment id="69">A palestra me ajudou a entender um pouco mais as linguagens e a profissГѓВЈo.</segment>
    <segment id="70">Achava que</segment>
    <segment id="71">sese usava mГѓВЎquina de escrever".</segment>
    <segment id="72">Гѓcaro Silva</segment>
    <segment id="73">, 15, Alto do Cabrito.
"</segment>
    <segment id="74">Ficamos sabemos</segment>
    <segment id="75">comocomo o MASSA!</segment>
    <segment id="76">ГѓВ© feito.</segment>
    <segment id="77">Agora eu jГѓВЎ tenho uma noГѓВ§ГѓВЈo melhor sobre o trabalho dos jornalistas.</segment>
    <segment id="78">A palestra foi boa</segment>
    <segment id="79">, foi ГѓВіtima".</segment>
    <segment id="80">Danilo GonГѓВ§alves</segment>
    <segment id="81">, 16, Plataforma.</segment>
