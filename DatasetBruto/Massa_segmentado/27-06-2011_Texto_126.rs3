  <rst>
    <segment id="1">Márcio Victor quer o fim do preconceito</segment>
    <segment id="2">Projeto já dura cinco anos e volta com força em julho de 2012</segment>
    <segment id="3">Há cinco anos</segment>
    <segment id="4">, Márcio Victor participou do programa global</segment>
    <segment id="5">“Som Brasil” ao lado de Lulu Santos.</segment>
    <segment id="6">Juntos</segment>
    <segment id="7">, eles cantaram os clássicos “Sincero”</segment>
    <segment id="8">, “Assim Caminha a Humanidade” e “Aviso aos Navegantes”.</segment>
    <segment id="9">A partir dessa experiência</segment>
    <segment id="10">, surgiu o Psi Experimental</segment>
    <segment id="11">, projeto destinado a um público diferente do original</segment>
    <segment id="12">, masmas que não deixa para trás as raízes do pagodão que agita o povo do gueto.</segment>
    <segment id="13">“Damos uma nova roupagem aos sons da MPB.</segment>
    <segment id="14">Temos influência do candomblé</segment>
    <segment id="15">, maracatu</segment>
    <segment id="16">, capoeira</segment>
    <segment id="17">, samba</segment>
    <segment id="18">, masmas não esquecemos o pagode</segment>
    <segment id="19">, não”</segment>
    <segment id="20">, conta o cantor.</segment>
    <segment id="21">O público é ‘selecionado’ pela grana mesmo.</segment>
    <segment id="22">Os ingressos de um show do Psi Experimental custam entre R$ 100 e R$ 150.</segment>
    <segment id="23">“</segment>
    <segment id="24">O objetivo é atingir outro público.</segment>
    <segment id="25">Aquele que não vai aos nossos shows</segment>
    <segment id="26">, masmas quer curtir o som do Psirico”</segment>
    <segment id="27">, afirma Márcio.</segment>
    <segment id="28">O projeto já é sucesso na Europa e tem novidades.</segment>
    <segment id="29">“</segment>
    <segment id="30">Gravamos um CD promocional e usamos instrumentos  eruditos</segment>
    <segment id="31">, como</segment>
    <segment id="32">como o violoncelo</segment>
    <segment id="33">, violino e piano”</segment>
    <segment id="34">, conta o vocalista</segment>
    <segment id="35">, que espera influenciar outras bandas de pagode.</segment>
    <segment id="36">“</segment>
    <segment id="37">O projeto é uma resposta para os que julgam mal ou discriminam o pagode”</segment>
    <segment id="38">, revela o cantor.</segment>
    <segment id="39">Se jogue nessa onda
Márcio Victor fará shows com o Psi Experimental em Minas Gerais</segment>
    <segment id="40">, Espírito Santo e nas cidades baianas de Vitória da Conquista e Salvador.</segment>
    <segment id="41">Na capital</segment>
    <segment id="42">, os shows acontecem na segunda semana de julho</segment>
    <segment id="43">, no Padaria Bar e no Lolita.</segment>
    <segment id="44">Como os ingressos são caros (R$ 100 a R$ 150)</segment>
    <segment id="45">, Márcio</segment>
    <segment id="46">sese preocupa em colocar</segment>
    <segment id="47">, pelo menos</segment>
    <segment id="48">, uma caixa de som externa para a galera de fora curtir.</segment>
  </rst>
</analysis>