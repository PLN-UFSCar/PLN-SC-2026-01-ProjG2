  <rst>
    <segment id="1">Melancia diet
Fininha para tirar a roupa</segment>
    <segment id="2">A revista “Sexy” quer ter Andressa Soares</segment>
    <segment id="3">, a Mulher Melancia</segment>
    <segment id="4">, em sua capa.</segment>
    <segment id="5">Porém, colocou uma condição para ela mostrar seus encantos novamente: vai ter que emagrecer.</segment>
    <segment id="6">Segundo o jornal “Agora São Paulo”</segment>
    <segment id="7">, Melancia</segment>
    <segment id="8">, que já saiu pelada na “Playboy” por quatro vezes</segment>
    <segment id="9">, precisa emagrecer cinco quilos antes de fotografar.</segment>
    <segment id="10">A morena tem um corpo</segment>
    <segment id="11">, digamos</segment>
    <segment id="12">, bem farto.</segment>
    <segment id="13">O problema é que</segment>
    <segment id="14">, com tanta carne</segment>
    <segment id="15">, qualquer quilinho a mais pode ser um desastre.</segment>
  </rst>
