  <rst>
    <segment id="1">Um segundo tempo para Xerém</segment>
    <segment id="2">A luz do sol tem dificuldade para atravessar as janelas cercadas pela grade de arame.</segment>
    <segment id="3">Mas a escuridão não esconde o buraco no teto</segment>
    <segment id="4">, as paredes infiltradas e a instalação precária do encanamento dos cinco chuveiros (dois com água) para atender até 60 garotos e adolescentes.</segment>
    <segment id="5">Poderia ser uma cela dos temidos institutos de correção para menores infratores.</segment>
    <segment id="6">Porém, é um dos dois únicos vestiários do Centro de Treinamento Vale das Laranjeiras (CTVL)</segment>
    <segment id="7">, em Xerém</segment>
    <segment id="8">, bairro de Duque de Caxias</segment>
    <segment id="9">, sede das categorias de base do Fluminense</segment>
    <segment id="10">, que enfrenta o Coritiba neste sábado</segment>
    <segment id="11">, às 18h30m</segment>
    <segment id="12">, no Couto Pereira</segment>
    <segment id="13">, pela décima rodada do Campeonato Brasileiro.</segment>
    <segment id="14">Obra custará R$ 1</segment>
    <segment id="15">,5 milhão</segment>
    <segment id="16">A reforma de Xerém começou na última segunda-feira.</segment>
    <segment id="17">E não falta trabalho.</segment>
    <segment id="18">Assustador</segment>
    <segment id="19">, insalubre</segment>
    <segment id="20">, malcheiroso e caindo aos pedaços.</segment>
    <segment id="21">Assim, Fernando de Simone</segment>
    <segment id="22">, gerente das divisões de base</segment>
    <segment id="23">, definiu as condições do CTVL para o presidente Peter Siemsen</segment>
    <segment id="24">, no fim de 2010</segment>
    <segment id="25">, depois de a nova administração ser eleita.</segment>
    <segment id="26">Se apenas descrevesse o que encontrou</segment>
    <segment id="27">, ninguém acreditaria.</segment>
    <segment id="28">Por isto</segment>
    <segment id="29">, Simone fotografou os beliches caquéticos e com colchões em frangalhos</segment>
    <segment id="30">, encostados em paredes infiltradas</segment>
    <segment id="31">, ao lado de banheiros onde sequer existia pia ou chuveiro.

FOTOGALERIA: Veja</segment>
    <segment id="32">comocomo estava o CT e o que já está sendo feito para melhorar as instalações</segment>
    <segment id="33">Em um dos cinco campos</segment>
    <segment id="34">, havia um buraco capaz de engolir (sem exagero) um jogador.</segment>
    <segment id="35">Convenceu dirigentes e conselheiros da urgência na reconstrução.</segment>
    <segment id="36">Serão investidos R$ 400 mil na reforma do alojamento para abrigar 92 jogadores e mais R$ 800 mil na recuperação de quatro dos cinco campos.</segment>
    <segment id="37">O dinheiro investido nos campos sairá da venda do atacante Rafael Pernão para a Traffic.</segment>
    <segment id="38">O restante é recurso do próprio clube.</segment>
    <segment id="39">O prazo é de 10 meses.

- Quando cheguei em Xerém</segment>
    <segment id="40">, no fim de 2010</segment>
    <segment id="41">, levei um choque.</segment>
    <segment id="42">Foi assustador.</segment>
    <segment id="43">O cheiro era insuportável.</segment>
    <segment id="44">Como posso cobrar amor ao Fluminense</segment>
    <segment id="45">sese os jogadores ficavam em um lugar assim?</segment>
    <segment id="46">- questionou Simone.</segment>
    <segment id="47">Tradicionalmente</segment>
    <segment id="48">, Xerém é um celeiro de talentos.</segment>
    <segment id="49">Mas os jogadores nunca poderiam ser tratados</segment>
    <segment id="50">comocomo animais.</segment>
    <segment id="51">As péssimas condições dos quartos causavam doenças respiratórias.</segment>
    <segment id="52">E os locais de treinos eram campos minados.

- Os garotos tinham asma</segment>
    <segment id="53">, e o Fluminense</segment>
    <segment id="54">, o maior índice de lesões nas divisões de base do Brasil</segment>
    <segment id="55">, porque</segment>
    <segment id="56">porque o campo é duro e causa problemas no púbis.</segment>
    <segment id="57">Daqui sairá o retorno técnico e financeiro para o clube.</segment>
    <segment id="58">Faremos isto direito a partir de agora - disse Simone.</segment>
    <segment id="59">O trator começou a cuidar do gramado do campo principal na última quinta-feira.</segment>
    <segment id="60">Terá irrigação e drenagem sustentável</segment>
    <segment id="61">, reaproveitando a água.</segment>
    <segment id="62">É boa ideia</segment>
    <segment id="63">, porque</segment>
    <segment id="64">porque no vestiário ao lado</segment>
    <segment id="65">, o filete que corre é escasso para os 60 jogadores que treinam no local.</segment>
    <segment id="66">Neste momento</segment>
    <segment id="67">, o Fluminense não irá reformá-lo</segment>
    <segment id="68">, porque</segment>
    <segment id="69">porque a obra não está incluída no projeto atual e depende de captação de recursos.

- Este vestiário é o mesmo da inauguração do CTVL</segment>
    <segment id="70">, no início da década de 1980.</segment>
    <segment id="71">É o símbolo de anos de abandono.</segment>
    <segment id="72">Posso te garantir que nunca passou por reforma</segment>
    <segment id="73">, masmas irá abaixo - disse Simone.</segment>
    <segment id="74">Marquinho recebe proposta</segment>
    <segment id="75">A obra pode ser estrutural.</segment>
    <segment id="76">Porém, a reforma mais importante é a da filosofia.</segment>
    <segment id="77">Com as contratações de Simone</segment>
    <segment id="78">, Jorge Macedo</segment>
    <segment id="79">, coordenador (ex-Internacional)</segment>
    <segment id="80">, e Marcelo Teixeira</segment>
    <segment id="81">, gerente de futebol</segment>
    <segment id="82">, o Fluminense quer</segment>
    <segment id="83">sese candidatar ao posto de clube de excelência na revelação de jogadores.</segment>
    <segment id="84">Não só para a venda</segment>
    <segment id="85">, masmas para a conquista de títulos.

- Xerém era a pior parte do que herdamos do clube.</segment>
    <segment id="86">E virou prioridade.</segment>
    <segment id="87">Com a nossa dívida e a estrutura antiquada</segment>
    <segment id="88">, o Fluminense não sobreviverá sem vender jogador.</segment>
    <segment id="89">Mas não é só isto.</segment>
    <segment id="90">Queremos criar uma escola de futebol.</segment>
    <segment id="91">Assim,</segment>
    <segment id="92">sese um jogador for vendido</segment>
    <segment id="93">, a reposição será imediata.</segment>
    <segment id="94">Primeiro</segment>
    <segment id="95">, resultado esportivo.</segment>
    <segment id="96">Depois</segment>
    <segment id="97">, renda.</segment>
    <segment id="98">O Santos deu o exemplo.</segment>
    <segment id="99">E vamos seguir - disse Siemsen.</segment>
    <segment id="100">O trabalho de inteligência na caça aos talentos é feito tijolo por tijolo.</segment>
    <segment id="101">Dos mais de 1.750 jogadores observados em sete meses</segment>
    <segment id="102">, o Fluminense contratou 40.

- Em vez de esperar aparecer a oportunidade</segment>
    <segment id="103">, nós iremos atrás dela.</segment>
    <segment id="104">É o aperfeiçoamento de uma tradição tricolor - declarou Siemsen.</segment>
    <segment id="105">Enquanto as reformas não são concluídas</segment>
    <segment id="106">, os jogadores do Fluminense ficarão hospedados no Hotel/Concentração Telê Santana</segment>
    <segment id="107">, ao lado do CTVL.</segment>
    <segment id="108">Para os jogos dos campeonatos das divisões de base</segment>
    <segment id="109">, o tricolor irá utilizar o campo do Tigres</segment>
    <segment id="110">, que também fica em Xerém e concedeu o local através de uma parceria.</segment>
    <segment id="111">Quando voltarem ao CT</segment>
    <segment id="112">, os jogadores poderão ter vida nova</segment>
    <segment id="113">, promete Simone.</segment>
    <segment id="114">- Tenho que criar alguma coisa para eles fazerem aqui.</segment>
    <segment id="115">Hoje em dia</segment>
    <segment id="116">, a TV é o único lazer.</segment>
    <segment id="117">Penso em um salão de jogos...</segment>
    <segment id="118">Também precisam ter mais privacidade.</segment>
    <segment id="119">Toda a parte administrativa</segment>
    <segment id="120">, que hoje funciona no alojamento</segment>
    <segment id="121">, será transferida.</segment>
    <segment id="122">Assim, não teremos empresários circulando por aqui - disse Simone.</segment>
    <segment id="123">Para o jogo deste sábado</segment>
    <segment id="124">, o Fluminense não terá o meia Marquinho</segment>
    <segment id="125">, que já fez seis jogos e tem proposta para deixar o clube.</segment>
  </rst>
</analysis>