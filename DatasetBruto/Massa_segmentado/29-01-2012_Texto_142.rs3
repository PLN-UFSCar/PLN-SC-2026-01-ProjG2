  <rst>
    <segment id="1">A fé dos devotos à rainha do mar</segment>
    <segment id="2">A devoção a Iemanjá ultrapassa os limites das religiões e atraem também os católicos</segment>
    <segment id="3">O pescador Valtinho</segment>
    <segment id="4">, como</segment>
    <segment id="5">como é conhecido Valter Cardoso de Souza</segment>
    <segment id="6">, 59 anos</segment>
    <segment id="7">, é católico.</segment>
    <segment id="8">E  um dos responsáveis pela festa em homenagem a Iemanjá realizada na Praia de Tubarão</segment>
    <segment id="9">, no Subúrbio Ferroviário</segment>
    <segment id="10">, desde 2002.</segment>
    <segment id="11">“</segment>
    <segment id="12">Faço por satisfação.</segment>
    <segment id="13">A gente que sempre está no mar precisa de proteção.</segment>
    <segment id="14">Peço a Iemanjá para ir em paz</segment>
    <segment id="15">, voltar em paz e trazer o pescado permitido”</segment>
    <segment id="16">, afirma.</segment>
    <segment id="17">A devoção é tamanha que</segment>
    <segment id="18">, durante os primeiros quatro anos</segment>
    <segment id="19">, Valtinho e os amigos faziam vaquinha  para financiar a festa – hoje</segment>
    <segment id="20">,  a segunda maior do bairro.</segment>
    <segment id="21">Os agrados a Iemanjá</segment>
    <segment id="22">sese estendem durante o ano.</segment>
    <segment id="23">“De onde tira e não bota</segment>
    <segment id="24">, acaba.</segment>
    <segment id="25">Iemanjá é a nossa segurança no mar e sobrevivência do pescado”</segment>
    <segment id="26">, diz Valtinho.</segment>
    <segment id="27">O respeito e a devoção de Maria da Conceição dos Anjos</segment>
    <segment id="28">, 43, por Iemanjá vieram com o ofício de marisqueira.</segment>
    <segment id="29">Ela é filha de Iansã.</segment>
    <segment id="30">A rainha do mar</segment>
    <segment id="31">, para Conceição</segment>
    <segment id="32">, foi a responsável pelas vezes em que voltou para casa com o cesto cheio</segment>
    <segment id="33">, quando tudo indicava que a maré não estava para marisco.</segment>
    <segment id="34">É preciso ter fé”</segment>
    <segment id="35">, enfatiza.</segment>
    <segment id="36">A marisqueira  herdou a religião da bisavó Apolinária e</segment>
    <segment id="37">, mesmo com a rejeição dos quatro filhos</segment>
    <segment id="38">,  segue no candomblé</segment>
    <segment id="39">, devota à sua mãe Iansã e sua protetora Iemanjá.</segment>
  </rst>
</analysis>