  <rst>
    <segment id="1">Foliões no altar</segment>
    <segment id="2">Guga de Paula e Rianne Ferreira oficializaram a união
Parece que o romance entre o ex-Babado Novo Guga de Paula e a modelo Rianne Ferreira</segment>
    <segment id="3">,  iniciado no programa “</segment>
    <segment id="4">O Trio Reality” ( TV Aratu) engatou  de verdade</segment>
    <segment id="5">, mesmo fora do confinamento!</segment>
    <segment id="6">O amor de carnaval subiu a serra</segment>
    <segment id="7">, contrariando o ditado.</segment>
    <segment id="8">Os pombinhos</segment>
    <segment id="9">, que já juntaram os trapinhos e moram juntos na residência do cantor na Ladeira do Galés</segment>
    <segment id="10">, oficializaram a união.</segment>
    <segment id="11">Eles  noivaram ontem</segment>
    <segment id="12">, em cerimônia religiosa ministrada pelo pastor Walter Jr.</segment>
    <segment id="13">, na Igreja Evangélica Ministério do Amor de Cristo (MAC)</segment>
    <segment id="14">, no bairro do Itaigara.</segment>
  </rst>
