  <rst>
    <segment id="1">Policial atira em namorada</segment>
    <segment id="2">O crime aconteceu no povoado de Itabaiana</segment>
    <segment id="3">, zona rural de Brejolância</segment>
    <segment id="4">Com 13 anos de Polícia Civil</segment>
    <segment id="5">, o agente policial Waldison Oliveira dos Santos</segment>
    <segment id="6">, 50 anos</segment>
    <segment id="7">, atirou duas vezes contra a namorada Edilânia Castro da Silva</segment>
    <segment id="8">, 25 anos</segment>
    <segment id="9">, e depois cometeu suicídio com um tiro na cabeça</segment>
    <segment id="10">, nesta quinta-feira (17)</segment>
    <segment id="11">, por volta das 19h</segment>
    <segment id="12">, no povoado de Itabaiana</segment>
    <segment id="13">, zona rural de Brejolância</segment>
    <segment id="14">, a 760 km de Salvador.</segment>
    <segment id="15">De acordo com informações iniciais</segment>
    <segment id="16">, apesar de ser casado e pai de três filhos</segment>
    <segment id="17">, Waldison</segment>
    <segment id="18">, mais conhecido</segment>
    <segment id="19">comocomo Bigode</segment>
    <segment id="20">, mantinha um relacionamento extraconjugal com Edilânia</segment>
    <segment id="21">, que teria terminado o namoro</segment>
    <segment id="22">, motivando a tragédia.</segment>
    <segment id="23">Ela foi encaminhada para o Hospital do Oeste</segment>
    <segment id="24">, em Barreiras</segment>
    <segment id="25">, onde permanece internada em estado estável.</segment>
    <segment id="26">O corpo do policial está sendo velado na residência da família</segment>
    <segment id="27">, no bairro Vila Rica</segment>
    <segment id="28">, em Barreiras.</segment>
    <segment id="29">Ainda não foram divulgados o horário e local do sepultamento.</segment>
  </rst>
</analysis>