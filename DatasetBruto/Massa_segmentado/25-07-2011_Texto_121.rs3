  <rst>
    <segment id="1">Baiana fica em 2º lugar no Miss Brasil</segment>
    <segment id="2">Foto sensual da vencedora com os seios de fora cai na internet</segment>
    <segment id="3">A eleição da mulher mais bonita do País deu o que falar.</segment>
    <segment id="4">Na noite de sábado</segment>
    <segment id="5">, a baiana Gabriella Rocha</segment>
    <segment id="6">, 21 anos</segment>
    <segment id="7">,  apesar de aclamada pelo público</segment>
    <segment id="8">, perdeu o posto de Miss Brasil para a gaúcha Priscila Machado.</segment>
    <segment id="9">Após ter sido coroada em São Paulo</segment>
    <segment id="10">, Priscila ficou por um triz de perder o título e passá-lo para a baiana de Simões Filho.</segment>
    <segment id="11">O motivo: a divulgação de uma foto dela pagando peitinho</segment>
    <segment id="12">, o que é proibido pelo regulamento do concurso.</segment>
    <segment id="13">Apesar de todo o bafafá</segment>
    <segment id="14">, a organização do Miss Brasil não vê a possibilidade da moça perder a coroa.</segment>
    <segment id="15">“</segment>
    <segment id="16">A regra diz que candidatas que autorizam a publicação de fotos nuas não podem participar do concurso.</segment>
    <segment id="17">No caso</segment>
    <segment id="18">caso, Priscila não permitiu.</segment>
    <segment id="19">O fotógrafo agiu de má-fé”</segment>
    <segment id="20">, diz Boanerges Gaeta</segment>
    <segment id="21">, diretor executivo do Miss Brasil.</segment>
    <segment id="22">Apesar da segunda colocação</segment>
    <segment id="23">, Gabriella era só alegria ontem</segment>
    <segment id="24">, na chegada a Salvador.</segment>
    <segment id="25">“</segment>
    <segment id="26">O público torcia por mim.</segment>
    <segment id="27">Foi uma vitória e tenho a sensação de dever cumprido”</segment>
    <segment id="28">, afirma a estudante de publicidade</segment>
    <segment id="29">, que aos sete anos foi Miss Bahia Mirim.</segment>
    <segment id="30">Chuva de vaias:</segment>
    <segment id="31">Priscila não agrada</segment>
    <segment id="32">Junto com a coroa de mulher mais bonita do País</segment>
    <segment id="33">, a gaúcha Priscila Machado recebeu muitas vaias.</segment>
    <segment id="34">Nos momentos finais do concurso</segment>
    <segment id="35">, a maioria do público presente dava</segment>
    <segment id="36">comocomo certa a vitória da baiana Gabriella e</segment>
    <segment id="37">, descontente com o resultado</segment>
    <segment id="38">, tirou todo o glamour da festa.</segment>
    <segment id="39">A insatisfação também tomou conta do Twitter e gerou reações da galera</segment>
    <segment id="40">, que protestou pela suposta quebra do regulamento com a foto nua de Priscila e por achar Gabriella mais bonita.</segment>
    <segment id="41">Peitinhos:</segment>
    <segment id="42">Coroada diz que foi maldade</segment>
    <segment id="43">A foto da recém-coroada pagando peitinho vazou no Twitter logo após o resultado.</segment>
    <segment id="44">Segundo a miss Priscila Machado</segment>
    <segment id="45">, a foto foi tirada há mais de um ano</segment>
    <segment id="46">, durante um ensaio.</segment>
    <segment id="47">Ao site G1</segment>
    <segment id="48">, Priscila diz não saber quem fez a maldade</segment>
    <segment id="49">, masmas também não</segment>
    <segment id="50">sese mostrou interessada em descobrir.</segment>
    <segment id="51">“Foi um ato de má fé</segment>
    <segment id="52">, masmas a pessoa não vai conseguir denegrir a minha imagem”</segment>
    <segment id="53">, afirma a bela do Brasil.</segment>
  </rst>
</analysis>