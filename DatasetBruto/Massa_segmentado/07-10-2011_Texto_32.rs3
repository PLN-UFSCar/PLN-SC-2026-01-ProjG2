  <rst>
    <segment id="1">Babalorixá dá força ao Bahia
Pai Zé Carlos</segment>
    <segment id="2">, da Tenda d’Omolú</segment>
    <segment id="3">, fez oferenda a Iemanjá para abrir os caminhos</segment>
    <segment id="4">Quando o assunto é futebol</segment>
    <segment id="5">, vale tudo.</segment>
    <segment id="6">O torcedor não quer saber de ver seu time do coração em má-fase.</segment>
    <segment id="7">A situação não é diferente com a torcida do Bahia</segment>
    <segment id="8">, que não pensa em outra coisa a não ser disputar mais uma vez a Série</segment>
    <segment id="9">A do Brasileiro.</segment>
    <segment id="10">Atual 14º colocado com 33 pontos</segment>
    <segment id="11">, o Esquadrão ainda corre o risco de cair para a Segundona</segment>
    <segment id="12">, masmas</segment>
    <segment id="13">sese depender da fé</segment>
    <segment id="14">, o tricolor permanecerá entre os melhores times do Brasil.</segment>
    <segment id="15">Na tarde de ontem</segment>
    <segment id="16">, na Praia de Boa Viagem</segment>
    <segment id="17">, o   Pai Zé Carlos</segment>
    <segment id="18">, da Tenda d’Omolú</segment>
    <segment id="19">, fez uma oferenda a  Iemanjá para ‘desembaraçar’ o tricolor.</segment>
    <segment id="20">“</segment>
    <segment id="21">Fiz um ritual nas águas para pedir pelo Bahia</segment>
    <segment id="22">, que está brigando para sair de perto da zona de rebaixamento.</segment>
    <segment id="23">Esse ritual desembaraça pra valer.</segment>
    <segment id="24">A gente quer que o Bahia levante</segment>
    <segment id="25">, não só na partida de sábado (amanhã</segment>
    <segment id="26">, contra o Botafogo)</segment>
    <segment id="27">, masmas que o astral do time esteja sempre pra cima”</segment>
    <segment id="28">, contou.

"</segment>
    <segment id="29">A gente quer que o Bahia levante</segment>
    <segment id="30">, não só na partida de sábado (contra o Botafogo)"</segment>
    <segment id="31">, diz Pai Zé Carlos</segment>
    <segment id="32">O  babalorixá</segment>
    <segment id="33">, que recebeu a reportagem do MASSA!</segment>
    <segment id="34">em seu terreiro</segment>
    <segment id="35">, na Travessa Lídio dos Santos</segment>
    <segment id="36">, avenida San Martin</segment>
    <segment id="37">, explicou que não torce</segment>
    <segment id="38">, masmas sempre tenta ajudar o tricolor:</segment>
    <segment id="39">“Não sou torcedor</segment>
    <segment id="40">, masmas é um prazer para nós religiosos do axé.</segment>
    <segment id="41">Sempre peço aos orixás pelo Bahia”</segment>
    <segment id="42">, justificou Pai Zé Carlos</segment>
    <segment id="43">, que já fez despachos para o Bahia.</segment>
    <segment id="44">“Já fiz vários trabalhos para o Bahia.</segment>
    <segment id="45">Em 2010</segment>
    <segment id="46">, fiz para o time subir”.</segment>
    <segment id="47">Pai Zé Carlos também é famoso em acertar previsões.</segment>
    <segment id="48">Na última Copa</segment>
    <segment id="49">, ele chegou a aparecer na TV em rede nacional.</segment>
    <segment id="50">Ontem, quando jogou os búzios</segment>
    <segment id="51">, afirmou:</segment>
    <segment id="52">“</segment>
    <segment id="53">O Bahia deve empatar com o Botafogo.</segment>
    <segment id="54">O time vai lutar muito e fica na Série</segment>
    <segment id="55">A, mas</segment>
    <segment id="56">mas não vai para a Copa Sul-Americana”.</segment>
    <segment id="57">Jogadores do Bahia foram convidados para acompanhar a entrega da oferenda</segment>
    <segment id="58">, masmas ninguém compareceu</segment>
  </rst>
</analysis>