  <rst>
    <segment id="1">Não deu tempo de terminar a mudança</segment>
    <segment id="2">Marginais invadem casa em Massaranduba</segment>
    <segment id="3">, executam mulher e ferem o companheiro</segment>
    <segment id="4">A cozinheira Dulcinéia Silva dos Santos</segment>
    <segment id="5">, 38, foi executada</segment>
    <segment id="6">, ontem</segment>
    <segment id="7">, com três tiros</segment>
    <segment id="8">, por um grupo de três marginais que invadiram a residência</segment>
    <segment id="9">, na Rua Juracy Magalhães</segment>
    <segment id="10">, quadra 9/10</segment>
    <segment id="11">, Conjunto Vivendas da Massaranduba</segment>
    <segment id="12">, no bairro da Massaranduba.</segment>
    <segment id="13">O companheiro da vítima</segment>
    <segment id="14">, Hortêncio Haleston Emídio dos Santos</segment>
    <segment id="15">, 32, suposto alvo dos bandidos</segment>
    <segment id="16">, também foi atingido pelos disparos.</segment>
    <segment id="17">Tentando fugir do local</segment>
    <segment id="18">, Hortêncio</segment>
    <segment id="19">, mesmo ferido</segment>
    <segment id="20">, conseguiu dirigir o carro Gol até o Cruzamento da Rua Santos Titara com a  Coronel Felinto Sampaio</segment>
    <segment id="21">, onde bateu em um veículo parado.</segment>
    <segment id="22">Ele foi levado ao HGE.</segment>
    <segment id="23">Até o fechamento da edição</segment>
    <segment id="24">, não havia saído do centro cirúrgico.</segment>
    <segment id="25">Minutos antes do crime</segment>
    <segment id="26">, o casal estava carregando um caminhão de mudanças e</segment>
    <segment id="27">sese preparando para deixar a residência.</segment>
    <segment id="28">Segundo o delegado Sérgio Schlang Júnior</segment>
    <segment id="29">, o crime apresenta características de vingança envolvendo o tráfico de drogas.</segment>
    <segment id="30">“</segment>
    <segment id="31">Eles estavam consumindo cocaína e cerveja na hora que os bandidos chegaram.</segment>
    <segment id="32">Os vizinhos relataram que eles falaram que precisavam vender a casa emergencialmente.</segment>
    <segment id="33">É provável que eles vinham sendo ameaçados”</segment>
    <segment id="34">, diz ele.</segment>
    <segment id="35">Em 2010</segment>
    <segment id="36">, Dulcinéia registrou queixa na Delegacia da Mulher contra o ex-marido</segment>
    <segment id="37">, Jeovani Almeida.</segment>
    <segment id="38">Ela relatou que Jeovani espalhou  pelo bairro que a mulher estava entregando à polícia os donos das bocas de fumo.</segment>
    <segment id="39">Roubados depois da morte</segment>
    <segment id="40">A irmã de Dulcinéia</segment>
    <segment id="41">, Luzinete Silva dos Santos</segment>
    <segment id="42">, chegou ao local do crime cheia de dúvidas.</segment>
    <segment id="43">“Eu não sei quem fez isso com minha irmã.</segment>
    <segment id="44">Não sabia que ela tinha envolvimento com drogas.</segment>
    <segment id="45">Eu não conhecia este companheiro dela.</segment>
    <segment id="46">Acho que só tinha uns três meses que eles estavam juntos.</segment>
    <segment id="47">O que estranhei foram as pessoas saquearem a casa toda.</segment>
    <segment id="48">Aí dentro não tem mais nada.</segment>
    <segment id="49">Só sangue”.</segment>
    <segment id="50">Segundo moradores</segment>
    <segment id="51">, que preferiram não</segment>
    <segment id="52">sese identificar</segment>
    <segment id="53">, na hora do crime um caminhão estava realizando a mudança do casal.</segment>
    <segment id="54">Percebendo os tiros</segment>
    <segment id="55">, o responsável pelo caminhão saiu em disparada com o veículo</segment>
    <segment id="56">, deixando objetos caídos pela rua.</segment>
    <segment id="57">Depois que o rabecão saiu</segment>
    <segment id="58">, a galera levou tudo.</segment>
  </rst>
</analysis>