  <rst>
    <segment id="1">Mais um gay é agredido</segment>
    <segment id="2">Usuários do facebook</segment>
    <segment id="3">sese organizam para realizar um beijaço de apoio a Willian</segment>
    <segment id="4">, dia 25</segment>
    <segment id="5">Mais um jovem gay é agredido no Brasil.</segment>
    <segment id="6">Willian Santos mora longe</segment>
    <segment id="7">, em Nova Hamburgo</segment>
    <segment id="8">, no Rio Grande do Sul</segment>
    <segment id="9">, masmas poderia ser seu vizinho</segment>
    <segment id="10">, amigo ou familiar</segment>
    <segment id="11">, uma vez que a Bahia ostenta o título vergonhoso de Estado que mais mata gays no País.</segment>
    <segment id="12">O que mais chama a atenção nessa situação (que é um reflexo de várias outras que acontecem no Brasil)</segment>
    <segment id="13">, é a impunidade.

Willian</segment>
    <segment id="14">, certamente</segment>
    <segment id="15">, será apenas mais uma vítima a entrar para estatística sem que os agressores</segment>
    <segment id="16">, mais uma vez</segment>
    <segment id="17">, sejam punidos.</segment>
    <segment id="18">Isso acontece</segment>
    <segment id="19">, acredito</segment>
    <segment id="20">, por falta de uma lei que proteja os gays.</segment>
    <segment id="21">Diante de mais um episódio</segment>
    <segment id="22">comocomo esse</segment>
    <segment id="23">, faz-</segment>
    <segment id="24">sese necessária a aprovação do Projeto de Lei da Câmara 122</segment>
    <segment id="25">, que criminaliza a homofobia e que está em votação no Senado.

Willian</segment>
    <segment id="26">, apesar da distância</segment>
    <segment id="27">, saiba que a agressão sofrida por você atinge a todos os gays do País.</segment>
  </rst>
