  <rst>
    <segment id="1">Abelhas causam corre-corre em Itapuã</segment>
    <segment id="2">Funcionários da Coelba foram resolver a falta de luz</segment>
    <segment id="3">, masmas encontraram uma colmeia</segment>
    <segment id="4">Um blecaute de energia seguido de um ataque de abelhas acabou em tumulto e pânico na tarde de ontem no Largo de Itapuã</segment>
    <segment id="5">, nas proximidades do acarajé da Cira.</segment>
    <segment id="6">O funcionário da Eletec – empresa que presta serviços de manutenção à Coelba – Alexsandro Neves da Silva</segment>
    <segment id="7">, ficou ferido com as picadas das abelhas.</segment>
    <segment id="8">Encaminhado ao Hospital Menandro de Farias</segment>
    <segment id="9">, em Lauro de Freitas</segment>
    <segment id="10">, ele já teve alta.</segment>
    <segment id="11">A falta de energia começou por volta das 15h por   sobrecarga em um dos transformadores de energia.</segment>
    <segment id="12">A Coelba foi acionada</segment>
    <segment id="13">, masmas os funcionários</segment>
    <segment id="14">sese depararam com uma colmeia no alto do poste onde ficava o transformador danificado.</segment>
    <segment id="15">Numa tentativa de exterminar as abelhas</segment>
    <segment id="16">, os funcionários utilizaram inseticida.</segment>
    <segment id="17">Mas o produto acabou estimulando as abelhas a deixarem a colmeia e  partirem em direção ao largo</segment>
    <segment id="18">, onde estavam dezenas de famílias .</segment>
  </rst>
</analysis>