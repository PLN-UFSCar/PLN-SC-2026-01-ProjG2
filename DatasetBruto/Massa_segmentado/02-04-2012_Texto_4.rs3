  <rst>
    <segment id="1">Absoluto!</segment>
    <segment id="2">Esquadrão leva a primeira fase</segment>
    <segment id="3">Bahia passa pelo Serrano em Pituaçu</segment>
    <segment id="4">, chega aos 45 pontos e garante liderança</segment>
    <segment id="5">Com um resultado conquistado no primeiro tempo</segment>
    <segment id="6">, o Bahia venceu ontem o Serrano</segment>
    <segment id="7">, por 3 a 2</segment>
    <segment id="8">, no Estádio de Pituaçu</segment>
    <segment id="9">, e garantiu o título moral de campeão da primeira fase.</segment>
    <segment id="10">Com 45 pontos</segment>
    <segment id="11">, o tricolor não pode ser alcançado pelo Vitória</segment>
    <segment id="12">, segundo colocado</segment>
    <segment id="13">, com 36.</segment>
    <segment id="14">O Esquadrão jogou bem até marcar os três gols do triunfo.</segment>
    <segment id="15">Depois</segment>
    <segment id="16">, não agradou o torcedor: deixou o adversário jogar à vontade.</segment>
    <segment id="17">Só que o destaque da partida foi a arbitragem</segment>
    <segment id="18">, bastante contestada pelas duas equipes.</segment>
    <segment id="19">Logo no  início</segment>
    <segment id="20">, o time de Falcão partiu para cima e</segment>
    <segment id="21">, aos quatro minutos</segment>
    <segment id="22">, abriu o placar.</segment>
    <segment id="23">Gabriel lançou Ciro</segment>
    <segment id="24">, que arrancou com velocidade e deixou o zagueiro no chão antes de bater forte</segment>
    <segment id="25">, no canto esquerdo do goleiro Gil.</segment>
    <segment id="26">O Bahia não</segment>
    <segment id="27">sese acomodou e foi em busca de mais gols.</segment>
    <segment id="28">Aos 16</segment>
    <segment id="29">, Ciro aproveitou cruzamento rasteiro para balançar a rede pela segunda vez.</segment>
    <segment id="30">O terceiro veio em um pênalti sofrido por Lenine.</segment>
    <segment id="31">Em coro</segment>
    <segment id="32">, a torcida pedia Ciro</segment>
    <segment id="33">, masmas foi Coelho quem bateu: 3 a 0.</segment>
    <segment id="34">Aos 34</segment>
    <segment id="35">,  o árbitro marcou pênalti para o Serrano</segment>
    <segment id="36">, masmas o assistente já sinalizava um impedimento</segment>
    <segment id="37">, que não existiu.</segment>
    <segment id="38">No entanto</segment>
    <segment id="39">, antes de acabar o primeiro tempo</segment>
    <segment id="40">, o Serrano diminuiu com Rodrigo</segment>
    <segment id="41">, que aproveitou o rebote de Marcelo Lomba.</segment>
    <segment id="42">No segundo tempo</segment>
    <segment id="43">, o juiz</segment>
    <segment id="44">sese atrapalhar de novo: depois de marcar pênalti a favor do Serrano</segment>
    <segment id="45">, voltou atrás com o impedimento visto pelo bandeirinha.</segment>
    <segment id="46">Aos 36</segment>
    <segment id="47">, Danny Morais puxou Felipe</segment>
    <segment id="48">Adão</segment>
    <segment id="49">pela camisa na  área e</segment>
    <segment id="50">, desta vez</segment>
    <segment id="51">, o pênalti foi mesmo marcado.</segment>
    <segment id="52">O próprio Felipe bateu e diminuiu</segment>
    <segment id="53">, masmas o jogo ficou no 3 a 2.</segment>
  </rst>
</analysis>