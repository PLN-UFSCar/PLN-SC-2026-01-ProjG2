  <rst>
    <segment id="1">Escola completa 30 anos de sucesso no Leblon
RIO - Fundado por três mães de alunos numa rua calma do Leblon</segment>
    <segment id="2">, o Espaço Educação tem sido</segment>
    <segment id="3">, além do primeiro contato com a escola para milhares de crianças do bairro</segment>
    <segment id="4">, uma segunda casa para os alunos.</segment>
    <segment id="5">E é neste clima de intimidade que o colégio pretende comemorar amanhã seus 30 anos dedicados à educação infantil.</segment>
    <segment id="6">Como toda festa caseira</segment>
    <segment id="7">, vai ter bolo feito em casa - no</segment>
    <segment id="8">casocaso</segment>
    <segment id="9">, na cozinha da escola-</segment>
    <segment id="10">, brigadeiros e</segment>
    <segment id="11">, promete a diretora pedagógica Isabela Secchin</segment>
    <segment id="12">, uma espécie de "madeleine" para os ex-alunos:
- A Conceição</segment>
    <segment id="13">, cozinheira que está conosco há 28 anos</segment>
    <segment id="14">, vai preparar pão quente.</segment>
    <segment id="15">É um pão na chapa que desperta a memória afetiva dos ex-alunos.</segment>
    <segment id="16">Todos sentem saudades</segment>
    <segment id="17">, relembram os tempos na escola - conta a diretora pedagógica.</segment>
    <segment id="18">A escola</segment>
    <segment id="19">, que segue a linha construtivista e tem cerca de 150 alunos</segment>
    <segment id="20">, do maternal ao 5 ano do ensino fundamental</segment>
    <segment id="21">, surgiu da insatisfação de um grupo de mães com a saída de Leda Pellegrini da coordenação do Colégio Souza Leão.</segment>
    <segment id="22">Elas convidaram a coordenadora para o desafio de ajudar na montagem de um novo espaço</segment>
    <segment id="23">, que virou referência para as mães da Zona Sul.</segment>
    <segment id="24">A história de sucesso vai ser comemorada amanhã em três etapas.</segment>
    <segment id="25">De manhã e à tarde a festa será restrita aos alunos atuais</segment>
    <segment id="26">, que vão</segment>
    <segment id="27">sese divertir fazendo cupcakes</segment>
    <segment id="28">, montando a própria toalha de mesa e elaborando presentes que serão dados à escola</segment>
    <segment id="29">, como</segment>
    <segment id="30">como jogos feitos a partir de sucata</segment>
    <segment id="31">, desenhos e o que mais a imaginação das crianças permitir.</segment>
    <segment id="32">À noite</segment>
    <segment id="33">, a comemoração será aberta a pais</segment>
    <segment id="34">, ex-alunos e funcionários.

- Dois ex-alunos</segment>
    <segment id="35">, o Felipe Fernandes e a Luísa Mayol</segment>
    <segment id="36">, vão tocar e cantar.</segment>
    <segment id="37">Vai começar às 19h e terminar às 22h.</segment>
    <segment id="38">Somos festeiros</segment>
    <segment id="39">, masmas respeitamos nossos vizinhos - diz Isabela.</segment>
    <segment id="40">Depois de polêmica</segment>
    <segment id="41">, paz com vizinhança do Alto Leblon</segment>
    <segment id="42">A política de boa vizinhança não é à toa.</segment>
    <segment id="43">Depois de 28 anos funcionando numa casa na Rua Almirante Guilhem</segment>
    <segment id="44">, o Espaço Educação teve que procurar uma nova sede</segment>
    <segment id="45">, em 2009</segment>
    <segment id="46">, quando o terreno em que estava foi vendido para uma construtora.</segment>
    <segment id="47">A mudança para o endereço atual</segment>
    <segment id="48">, uma casa no Alto Leblon</segment>
    <segment id="49">, não foi das mais fáceis.</segment>
    <segment id="50">Vizinhos da Rua Timóteo da Costa</segment>
    <segment id="51">, com medo do barulho e de possíveis complicações no trânsito</segment>
    <segment id="52">, sese mobilizaram para tentar impedir a chegada da escola.</segment>
    <segment id="53">Alunos e ex-alunos entraram na batalha e fizeram passeata pela permanência do colégio no novo endereço.</segment>
    <segment id="54">No fim</segment>
    <segment id="55">, o Espaço Educação ocupou a casa.</segment>
    <segment id="56">E, diz Isabela</segment>
    <segment id="57">, agora há paz novamente:

- Tem gente que chegou a participar do abaixo-assinado contra a escola e que agora matricula os filhos</segment>
    <segment id="58">, dizendo que não perturbamos em nada.</segment>
  </rst>
</analysis>