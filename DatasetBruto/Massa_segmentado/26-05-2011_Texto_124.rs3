  <rst>
    <segment id="1">Professor e aluno</segment>
    <segment id="2">sese estranham
Bate-boca com ameaças virou</segment>
    <segment id="3">casocaso de polícia</segment>
    <segment id="4">Um aluno de 14 anos da Escola Estadual Lea Leal</segment>
    <segment id="5">, em Fazenda Grande I</segment>
    <segment id="6">, diz ter levado um murro no peito do professor de matemática</segment>
    <segment id="7">Lázaro Esteves dos Santos</segment>
    <segment id="8">, 44 anos</segment>
    <segment id="9">, ao discutirem na sala onde</segment>
    <segment id="10">sese encontrava a vice-diretora da escola.</segment>
    <segment id="11">A confusão começou quando o professor reclamou do som alto que  o garoto ouvia com colegas em um miniaparelho de som no pátio da escola</segment>
    <segment id="12">, no horário do intervalo.</segment>
    <segment id="13">O garoto</segment>
    <segment id="14">sese recusou a entregar o objeto</segment>
    <segment id="15">, e o professor tentou levá-lo à direção.</segment>
    <segment id="16">“Eu disse que só iria entregar ao dono.</segment>
    <segment id="17">Ele apertou meu braço e</segment>
    <segment id="18">, quando consegui me soltar</segment>
    <segment id="19">, fui atrás dele me defender da queixa que ele ia fazer na direção.</segment>
    <segment id="20">Quando disse que não ia ficar por isso mesmo</segment>
    <segment id="21">, ele me deu um murro no peito”</segment>
    <segment id="22">, conta o adolescente.</segment>
    <segment id="23">O professor negou.</segment>
    <segment id="24">“Não bati nele em momento nenhum.</segment>
    <segment id="25">Apenas reclamei de forma firme.</segment>
    <segment id="26">Não estou aqui para ser ameaçado por ninguém”</segment>
    <segment id="27">, defendeu- -</segment>
    <segment id="28">sese.</segment>
    <segment id="29">A vice-diretora</segment>
    <segment id="30">, de prenome Sônia</segment>
    <segment id="31">, testemunhou o episódio</segment>
    <segment id="32">, masmas ainda não prestou depoimento.</segment>
    <segment id="33">Ela passou mal na hora e foi parar no hospital.</segment>
    <segment id="34">Todo pepinado</segment>
    <segment id="35">O caso</segment>
    <segment id="36">caso foi registrado na Delegacia de Repressão a Crimes Contra a Criança e o Adolescente pela agressão</segment>
    <segment id="37">, e o professor registrou queixa de ameaça e desacato na Delegacia para o Adolescente Infrator.</segment>
    <segment id="38">A Secretaria de Educação do Estado está acompanhando o</segment>
    <segment id="39">casocaso e</segment>
    <segment id="40">, a depender do resultado</segment>
    <segment id="41">, irá encaminhar à corregedoria para abertura de processo administrativo.</segment>
    <segment id="42">O professor pode ser advertido</segment>
    <segment id="43">, suspenso ou até demitido.</segment>
    <segment id="44">Lázaro também é policial civil lotado na Delegacia de Cajazeiras.</segment>
    <segment id="45">Em consulta ao site do Tribunal de Justiça</segment>
    <segment id="46">, constam quatro processos contra ele.</segment>
    <segment id="47">Três por crimes contra a pessoa: na Vara do Júri</segment>
    <segment id="48">, na Vara Crime contra criança e o adolescente e na 11ª Vara Criminal.</segment>
    <segment id="49">O último</segment>
    <segment id="50">, é na 1ª Vara de violência doméstica contra a mulher.</segment>
  </rst>
</analysis>