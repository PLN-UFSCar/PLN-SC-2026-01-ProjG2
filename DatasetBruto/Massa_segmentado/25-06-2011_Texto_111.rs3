  <rst>
    <segment id="1">Barbeiragem destrói são joão de criança</segment>
    <segment id="2">Garoto de 10 anos é esmagado por carro pilotado por mulher que aprendia a dirigir</segment>
    <segment id="3">O garoto Jeferson Oliveira Silva</segment>
    <segment id="4">, 10 anos</segment>
    <segment id="5">,  protegia a chama  de uma vela com as mãos quando foi atropelado por um carro Chevrolet Montana Combo da empresa “Aluga Tudo” (placa NZI-9078)</segment>
    <segment id="6">, dirigido pela estudante  Luciana dos Santos Souza.</segment>
    <segment id="7">O veículo subiu a calçada e  atingiu a criança</segment>
    <segment id="8">, que soltava fogos de São João</segment>
    <segment id="9">, com a mãe</segment>
    <segment id="10">, ao lado do prédio onde morava</segment>
    <segment id="11">, na Rua 1</segment>
    <segment id="12">, em Mirantes de Periperi.</segment>
    <segment id="13">Jeferson morreu na hora.</segment>
    <segment id="14">Revoltados</segment>
    <segment id="15">, populares incendiaram o veículo.</segment>
    <segment id="16">De acordo com testemunhas</segment>
    <segment id="17">,  a mãe da criança havia ido   em casa  pegar um fósforo e</segment>
    <segment id="18">, na volta</segment>
    <segment id="19">, presenciou o momento em que o filho foi atropelado</segment>
    <segment id="20">,  desesperando-</segment>
    <segment id="21">sese.</segment>
    <segment id="22">Além de Luciana</segment>
    <segment id="23">, o marido dela</segment>
    <segment id="24">, o mecânico de refrigeração Linsmar da Paixão dos Santos</segment>
    <segment id="25">, 32, também estava no carro e ensinava a mulher a dirigir</segment>
    <segment id="26">, conforme as testemunhas.</segment>
    <segment id="27">“Vimos quando ele parou o carro e deu a direção a ela.</segment>
    <segment id="28">A mulher acelerou e perdeu a direção”</segment>
    <segment id="29">, disse o servidor público Gilson dos Santos</segment>
    <segment id="30">, 44.</segment>
    <segment id="31">Amigo fica emocionado
“</segment>
    <segment id="32">Infelizmente</segment>
    <segment id="33">, eu não estava aqui na hora.</segment>
    <segment id="34">Eu ia ajudar ele de alguma forma.</segment>
    <segment id="35">Eles vão ter que pagar</segment>
    <segment id="36">porque</segment>
    <segment id="37">porque tiraram o sonho do meu amigo de ser jogador de futebol”</segment>
    <segment id="38">, emocionou-</segment>
    <segment id="39">sese Igor Pinto</segment>
    <segment id="40">, 13, amigo da vítima.</segment>
    <segment id="41">Linsmar feriu a cabeça e recebeu atendimento médico antes de ser levado à 5ª DT (Periperi).</segment>
    <segment id="42">“</segment>
    <segment id="43">Os dois foram presos em flagrante por homicídio culposo (sem intenção de matar)”</segment>
    <segment id="44">, afirmou o delegado Silvino Martins</segment>
    <segment id="45">, que arbitraria fiança de R$ 4</segment>
    <segment id="46">,5 mil.</segment>
  </rst>
</analysis>