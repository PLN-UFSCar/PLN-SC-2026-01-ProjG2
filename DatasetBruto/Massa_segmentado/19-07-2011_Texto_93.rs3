  <rst>
    <segment id="1">Juliane Almeida deixa o É o Tchan</segment>
    <segment id="2">A morena lançou um comunicado na imprensa sobre a decisão de virar atriz</segment>
    <segment id="3">Após 6 anos de muito rebolado</segment>
    <segment id="4">, a morena  Juliane Almeida anunciou ontem sua saída da banda de pagode É o Tchan.</segment>
    <segment id="5">A gata</segment>
    <segment id="6">, que entrou no lugar de Scheila Carvalho</segment>
    <segment id="7">, decidiu</segment>
    <segment id="8">sese dedicar à carreira de atriz.</segment>
    <segment id="9">Com os ensaios semanais da banda na capital baiana</segment>
    <segment id="10">, ela teve que deixar o Rio de Janeiro e vir morar em Salvador.</segment>
    <segment id="11">“Estou vivendo em ponte aérea toda semana</segment>
    <segment id="12">, por conta de meus compromissos na carreira de atriz.</segment>
    <segment id="13">Decidi que é isso que quero seguir na minha vida.</segment>
    <segment id="14">Amo o palco</segment>
    <segment id="15">, amei fazer novela e agora quero mostrar conteúdo”</segment>
    <segment id="16">, diz a morena em comunicado oficial enviado à imprensa.</segment>
    <segment id="17">Juliane cursou faculdade de teatro e ficou empolgada com a participação que fez na novela “Morde &amp; Assopra” (Globo)</segment>
    <segment id="18">, no mês passado.</segment>
  </rst>
