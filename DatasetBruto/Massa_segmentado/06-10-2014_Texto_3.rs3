  <rst>
    <segment id="1">Rui Costa vence no 1ﾃつｺ turno
Contrariando as pesquisas antes das eleiﾃδｧﾃδｵes</segment>
    <segment id="2">, o candidato do PT</segment>
    <segment id="3">ﾃδｩ eleito</segment>
    <segment id="4">O candidato Rui Costa (PT) estﾃδ｡ eleito para governar a Bahia de 2015 a 2018</segment>
    <segment id="5">, com 54</segment>
    <segment id="6">,51% dos votos (99</segment>
    <segment id="7">,35% das urnas apuradas).</segment>
    <segment id="8">Paulo Souto ficou na 2ﾃつｪ colocaﾃδｧﾃδ｣o com 37</segment>
    <segment id="9">,37% dos votos</segment>
    <segment id="10">, seguido de Lﾃδｭdice da Mata</segment>
    <segment id="11">, Marcos Mendes</segment>
    <segment id="12">, Da Luz e Renata Mallet.</segment>
    <segment id="13">Nﾃδ｣o foi na ﾃδｺltima semana que a eleiﾃδｧﾃδ｣o virou.</segment>
    <segment id="14">Jﾃδ｡ observﾃδ｡vamos esse sentimento hﾃδ｡ semanas</segment>
    <segment id="15">, afirmou Rui</segment>
    <segment id="16">, em coletiva de imprensa no Palﾃδ｡cio de Ondina.</segment>
    <segment id="17">Me parece que o governador e o partido acertaram</segment>
    <segment id="18">, disse ele</segment>
    <segment id="19">, ao falar sobre a escolha da candidatura dele para disputar as eleiﾃδｧﾃδｵes.</segment>
    <segment id="20">Rui havia comeﾃδｧado a campanha com 9% das intenﾃδｧﾃδｵes de voto contra 42% de Souto.</segment>
    <segment id="21">Rui tem 51 anos</segment>
    <segment id="22">, ﾃδｩ economista</segment>
    <segment id="23">, soteropolitano e cresceu na Liberdade.</segment>
    <segment id="24">Foi empregado na ﾃδ｡rea de projetos da antiga Copene</segment>
    <segment id="25">, com participaﾃδｧﾃδ｣o ativa no Sindicato dos Quﾃδｭmicos e Petroquﾃδｭmicos.</segment>
    <segment id="26">Foi um dos fundadores do PT na Bahia.</segment>
    <segment id="27">Com a eleiﾃδｧﾃδ｣o de Jaques Wagner</segment>
    <segment id="28">, de quem ﾃδｩ amigo hﾃδ｡ mais de 30 anos</segment>
    <segment id="29">,</segment>
    <segment id="30">torna-</segment>
    <segment id="31">sese secretﾃδ｡rio de Relaﾃδｧﾃδｵes Institucionais</segment>
    <segment id="32">, responsﾃδ｡vel pelas articulaﾃδｧﾃδｵes polﾃδｭticas.</segment>
    <segment id="33">Foi eleito deputado federal em 2010 e depois escolhido para dirigir a Secretaria da Casa Civil na Bahia.</segment>
    <segment id="34">Ele</segment>
    <segment id="35">ﾃδｩ casado e pai de trﾃδｪs filhos.</segment>
    <segment id="36">Raio duas vezes no mesmo lugar</segment>
    <segment id="37">Pela segunda vez</segment>
    <segment id="38">, Paulo Souto perde para o PT uma eleiﾃδｧﾃδ｣o para governador da Bahia.</segment>
    <segment id="39">E a derrota de ontem guarda muitas semelhanﾃδｧas com as eleiﾃδｧﾃδｵes de 2006</segment>
    <segment id="40">, quando Souto foi vencido pelo entﾃδ｣o candidato Jaques Wagner</segment>
    <segment id="41">, tambﾃδｩm no primeiro turno.</segment>
    <segment id="42">Naquele ano</segment>
    <segment id="43">, as pesquisas tambﾃδｩm indicavam que Paulo Souto ganharia o pleito ainda no primeiro turno.</segment>
    <segment id="44">Governador da Bahia duas vezes</segment>
    <segment id="45">, Souto contou</segment>
    <segment id="46">, nessas eleiﾃδｧﾃδｵes</segment>
    <segment id="47">, com o forte apoio do prefeito de Salvador ACM Neto.</segment>
    <segment id="48">Ontem, o clima foi de desﾃδ｢nimo no comitﾃδｪ do candidato do DEM.</segment>
    <segment id="49">ﾃ☖ぎ medida que a apuraﾃδｧﾃδ｣o dos votos avanﾃδｧava</segment>
    <segment id="50">, militantes</segment>
    <segment id="51">sese retiravam do local.</segment>
    <segment id="52">Claro que foi uma surpresa.</segment>
    <segment id="53">Nﾃδ｣o sou capaz de dizer o que houve.</segment>
    <segment id="54">O Democrata continua a ser uma forﾃδｧa polﾃδｭtica e estﾃδ｡ preparado para futuras batalhas"</segment>
    <segment id="55">, disse Paulo Souto</segment>
    <segment id="56">, apﾃδｳs a derrota.</segment>
    <segment id="57">Otto Alencar conquista a vaga de senador pela Bahia
Otto Alencar foi eleito com mais de 55% dos votos vﾃδ｡lidos</segment>
    <segment id="58">, superando Geddel Vieira Lima</segment>
    <segment id="59">, principal concorrente.</segment>
    <segment id="60">Natural do municﾃδｭpio de Ruy Barbosa</segment>
    <segment id="61">, Otto Alencar (PSD)</segment>
    <segment id="62">ﾃδｩ mﾃδｩdico e tem 67 anos.</segment>
    <segment id="63">Ele jﾃδ｡ foi deputado estadual constituinte e deputado estadual.</segment>
