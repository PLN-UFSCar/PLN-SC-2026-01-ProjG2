  <rst>
    <segment id="1">Barcelona não dá chance ao Real Madrid no Santiago Bernabéu
RIO - De virada</segment>
    <segment id="2">, o Barcelona detonou o Real Madrid na casa do adversário: 3 a 1.</segment>
    <segment id="3">E manteve a escrita de não perder no Santiago Bernabéu para o maior rival desde 2008.</segment>
    <segment id="4">São agora seis jogos e algumas vitórias emblemáticas</segment>
    <segment id="5">, como</segment>
    <segment id="6">como o 6 a 2 de maio de 2009 e o 2 a 0 em abril</segment>
    <segment id="7">, decisivo para garantir o Barcelona na final da Liga dos Campeões (o jogo da volta foi 1 a 1).</segment>
    <segment id="8">O período de invencibilidade é o mesmo do comando do técnico Pep Guardiola no Barça.</segment>
    <segment id="9">Desde sua chegada</segment>
    <segment id="10">, no início da temporada 2008-09</segment>
    <segment id="11">, o treinador disputou 11 clássicos: sete vitórias</segment>
    <segment id="12">, três empates e apenas uma derrota</segment>
    <segment id="13">, na decisão da última Copa do Rey.</segment>
    <segment id="14">O jogo começou às 19h (horário de Brasília) e logo aos 21 segundos o Real Madrid abriu o placar</segment>
    <segment id="15">, com um gol-relâmpago do atacante francês Benzema.</segment>
    <segment id="16">O gol nasceu de uma autêntica 'píxotada' do goleiro Victor Valdés</segment>
    <segment id="17">, do Barça</segment>
    <segment id="18">, que saiu jogando errado com os pés.</segment>
    <segment id="19">Ele deu a bola de graça para Di María</segment>
    <segment id="20">, que achou Özil na área.</segment>
    <segment id="21">O alemão chutou</segment>
    <segment id="22">, houve desvio em Busquets e Benzema aproveitou</segment>
    <segment id="23">, totalmente livre: 1 a 0.</segment>
    <segment id="24">Logo depois do gol</segment>
    <segment id="25">, Messi quase empatou.</segment>
    <segment id="26">Cara a cara com o goleiro</segment>
    <segment id="27">, após arrancada sensacional</segment>
    <segment id="28">, chutou para grande defesa de Casillas.</segment>
    <segment id="29">Aos 29</segment>
    <segment id="30">, repetiu o feito</segment>
    <segment id="31">, só que com mais sorte para o Barça.</segment>
    <segment id="32">O craque argentino deu ótimo passe para o chileno Alexis Sanchez</segment>
    <segment id="33">, que dominou e</segment>
    <segment id="34">, mesmo apertado pelo zagueiro do Real</segment>
    <segment id="35">, bateu forte</segment>
    <segment id="36">, rasteiro: 1 a 1.</segment>
    <segment id="37">No segundo tempo</segment>
    <segment id="38">, o Barça virou.</segment>
    <segment id="39">Aos 9, Xávi chutou e a bola bateu no lateral brasileiro</segment>
    <segment id="40">Marcelo</segment>
    <segment id="41">, enganando o goleiro Casillas.</segment>
    <segment id="42">Aos 20</segment>
    <segment id="43">, Messi iniciou a jogada e lançou Daniel Alves na direita.</segment>
    <segment id="44">O lateral-direito cruzou na área e Fábregas emendou de cabeça: Barcelona 3 a 1.</segment>
    <segment id="45">A partir daí o jogo ficou mais duro</segment>
    <segment id="46">, com algumas jogadas ríspidas.</segment>
    <segment id="47">Os jogadores do Real</segment>
    <segment id="48">sese mostravam visivelmente irritados por não conseguir parar o Barcelona.</segment>
    <segment id="49">O time catalão seguiu direto do estádio em Madri para o Japão</segment>
    <segment id="50">, onde na quinta-feira estreia no Mundial de Clubes da Fifa.</segment>
    <segment id="51">Os jogadores nem participaram da entrevista coletiva após o jogo</segment>
    <segment id="52">, responsabilidade que ficou exclusivamente com o técnico Guardiola.</segment>
    <segment id="53">O jogo contra o Real foi transmitido em 3D em cinemas no Brasil.</segment>
    <segment id="54">A vitória deixou o Barcelona empatado em pontos com o Real Madrid (37 cada um) na liderança do Campeonato Espanhol</segment>
    <segment id="55">, masmas com um jogo a mais.</segment>
    <segment id="56">Em 15 jogos</segment>
    <segment id="57">, o Real tem 12 vitórias</segment>
    <segment id="58">, um empate e agora duas derrotas.</segment>
    <segment id="59">O Barça</segment>
    <segment id="60">, em 16 partidas</segment>
    <segment id="61">, venceu dez vezes</segment>
    <segment id="62">, empatou quatro e perdeu uma.</segment>
    <segment id="63">Dois times em excelente fase</segment>
    <segment id="64">Donos dos melhores jogadores do mundo atualmente</segment>
    <segment id="65">, tanto o Real quanto o Barça puderam</segment>
    <segment id="66">sese dar ao luxo de disputar a última rodada da fase de grupos da Liga dos Campeões no meio de semana jogando com times mistos para poupar seus principais atletas para o jogo deste sábado.</segment>
    <segment id="67">Enquanto um possível rival</segment>
    <segment id="68">, o Manchester United</segment>
    <segment id="69">, e um potencial rival endinheirado</segment>
    <segment id="70">, o Manchester City</segment>
    <segment id="71">, caiam na primeira fase</segment>
    <segment id="72">, os dois times goleavam o Ajax (3 a 0) e o BATE Borisov (4 a 0) e encerravam a primeira fase passeando.</segment>
    <segment id="73">O Real teve 100% de aproveitamento</segment>
    <segment id="74">, sese tornando o quinto time da história a conseguir tal feito.</segment>
    <segment id="75">Já o Barça também terminou invicto</segment>
    <segment id="76">, masmas com cinco vitórias e um empate</segment>
    <segment id="77">, tendo garantido o primeiro lugar do grupo com uma rodada de antecedência.</segment>
    <segment id="78">O Barcelona</segment>
    <segment id="79">, que no período de Guardiola conquistou 12 títulos</segment>
    <segment id="80">, pode ganhar no domingo</segment>
    <segment id="81">, dia 18</segment>
    <segment id="82">, o seu 13º. Para isso</segment>
    <segment id="83">, terá que vencer a semifinal</segment>
    <segment id="84">, na quinta-feira</segment>
    <segment id="85">, e a decisão do Mundial de Clubes.</segment>
    <segment id="86">No caminho do Barça</segment>
    <segment id="87">, assim esperam os brasileiros</segment>
    <segment id="88">, pode estar o Santos de Neymar.</segment>
  </rst>
</analysis>