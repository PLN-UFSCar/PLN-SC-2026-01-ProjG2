  <rst>
    <segment id="1">Nordeste ainda não encontrou a paz</segment>
    <segment id="2">Jovem de 16 anos é morto em assalto a minimercado no Areal</segment>
    <segment id="3">A morte de um adolescente de 16 anos durante o assalto ao Mini Mercado Brandino Curvelo</segment>
    <segment id="4">, na Rua São Jorge</segment>
    <segment id="5">, no Nordeste de Amaralina</segment>
    <segment id="6">, prova que a Base Comunitária de Segurança (BCS) do bairro deve enfrentar muitos desafios para alcançar pacificação da região.

Ruan Oliveira Menezes dos Santos trabalhava no estabelecimento que foi assaltado</segment>
    <segment id="7">, no Areal.</segment>
    <segment id="8">Ele levou um tiro no peito de um dos assaltantes e foi encaminhado até o HGE.</segment>
    <segment id="9">Segundo informações do Posto da Polícia Civil</segment>
    <segment id="10">, o jovem morreu 17 minutos após dar entrada na unidade</segment>
    <segment id="11">, às 20h30.</segment>
    <segment id="12">De acordo com o técnico em refrigeração Rodrigo Santos</segment>
    <segment id="13">, os assaltantes chegaram em um Fiat Uno vermelho.</segment>
    <segment id="14">“</segment>
    <segment id="15">Pelo menos um cara entrou no mercado.</segment>
    <segment id="16">Ouvir dizer que Ruan</segment>
    <segment id="17">sese assustou na hora e correu”</segment>
    <segment id="18">, conta.</segment>
    <segment id="19">“Era um rapaz calmo</segment>
    <segment id="20">, brincalhão e trabalhador”</segment>
    <segment id="21">, completa.</segment>
    <segment id="22">Moradores lembraram da existência de uma câmera da BCS no local</segment>
    <segment id="23">, que deve ter registrado imagens da movimentação dos assaltantes.</segment>
    <segment id="24">“Queremos saber</segment>
    <segment id="25">sese a câmera está funcionando.</segment>
    <segment id="26">Os policiais só chegaram depois de 40 minutos.</segment>
    <segment id="27">Queremos que os bandidos sejam presos”</segment>
    <segment id="28">, apela o ajudante de pedreiro Luis Claudio Costa.</segment>
    <segment id="29">“</segment>
    <segment id="30">A comunidade quer que a Base seja mais eficiente”</segment>
    <segment id="31">, destaca o morador.</segment>
    <segment id="32">Familiares e amigos do adolescente</segment>
    <segment id="33">Ruan dos Santos fizeram homenagem ele após sua morte</segment>
    <segment id="34">O crime está sendo investigado pela 28ª Delegacia Territorial.</segment>
    <segment id="35">A reportagem procurou a unidade</segment>
    <segment id="36">, masmas não teve acesso ao Boletim de Ocorrência.</segment>
    <segment id="37">Na BCS</segment>
    <segment id="38">, os PMs de serviço disseram que só a comandante</segment>
    <segment id="39">, Capitã Fabiana Moraes</segment>
    <segment id="40">, poderia falar.</segment>
    <segment id="41">Mas ela estava de folga.</segment>
    <segment id="42">Homenagem</segment>
    <segment id="43">O corpo de Ruan será sepultado hoje</segment>
    <segment id="44">, às 10h30</segment>
    <segment id="45">, no Cemitério do Campo Santo.</segment>
    <segment id="46">Amigos do jovem já vestiam camisas com foto e mensagens de carinho.</segment>
    <segment id="47">Ontem, a mãe de Ruan estava sob efeito de medicamentos e não teve condições de conversar com a equipe de reportagem.</segment>
    <segment id="48">Os moradores dão dicas à polícia sobre os locais no Nordeste de Amaralina onde as rondas devem ser intensificadas.</segment>
    <segment id="49">“Areal</segment>
    <segment id="50">, onde o menino morreu</segment>
    <segment id="51">, Boqueirão e  Rua Emídio Pio têm que ter mais ronda”</segment>
    <segment id="52">, diz a professora Maria Tavares.</segment>
  </rst>
</analysis>