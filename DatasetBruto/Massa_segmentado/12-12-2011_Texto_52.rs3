  <rst>
    <segment id="1">Pedreiro fica doido e quebra 40 carros
Liberou a raiva nos carros dos outros</segment>
    <segment id="2">O encarregado de pedreiro Everaldo Santos Silva</segment>
    <segment id="3">, 38 anos</segment>
    <segment id="4">, revoltou-</segment>
    <segment id="5">sese ao encontrar o Ecosport dele arrombado</segment>
    <segment id="6">, sem os aparelhos de GPS e som</segment>
    <segment id="7">, no início da noite do último sábado.</segment>
    <segment id="8">Foi o bastante para ele depredar cerca de 40 carros que estavam estacionados na  Rua Forte São Diogo</segment>
    <segment id="9">, na Barra.</segment>
    <segment id="10">Antes de tomar tal atitude</segment>
    <segment id="11">, Everaldo comunicou o furto a PMs e perguntou quem poderia assumir o prejuízo dele.</segment>
    <segment id="12">Os PMs orientaram Everaldo a buscar informações  no Yacht Clube.</segment>
    <segment id="13">“</segment>
    <segment id="14">Nós explicamos que trata-</segment>
    <segment id="15">sese de uma via pública e que apenas fazemos um controle de entrada</segment>
    <segment id="16">, para evitar o caos na rua que dá acesso ao clube.</segment>
    <segment id="17">Mas ele não deve ter compreendido”</segment>
    <segment id="18">,  afirma o diretor do Yacht Clube</segment>
    <segment id="19">, Marconi Andraus Oliveira.</segment>
    <segment id="20">Everaldo utilizou pedras e deu socos e pontapésnos carros</segment>
    <segment id="21">, depois de ouvir a explicação.</segment>
    <segment id="22">Populares revoltados com o pedreiro destruíram o veículo dele.</segment>
    <segment id="23">Everaldo foi autuado em flagrante por dano qualificado</segment>
    <segment id="24">, na 14ª DT (Barra) e foi solto após pagar fiança de um salário mínimo.</segment>
    <segment id="25">Ele responderá em liberdade.</segment>
    <segment id="26">Arrependido: Está com medo das ameaças</segment>
    <segment id="27">Treze vítimas já registraram queixa na 14ª DT sobre os danos provocados por Everaldo.</segment>
    <segment id="28">Segundo o delegado Dalton Aparecido Pereira</segment>
    <segment id="29">, as vítimas poderão acionar o pedreiro na Justiça para ter o prejuízo ressarcido.</segment>
    <segment id="30">Everaldo parece estar arrependido.</segment>
    <segment id="31">“Estou tomando anti-inflamatório para desinchar o pé e remédios para dormir”</segment>
    <segment id="32">, relatou Everaldo</segment>
    <segment id="33">, que disse ter sofrido ameaças de morte de alguma pessoas que tiveram os carros detonados por ele.</segment>
  </rst>
</analysis>