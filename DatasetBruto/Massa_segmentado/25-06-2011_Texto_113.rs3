  <rst>
    <segment id="1">Pontinho em ritmo de forró
Vander entrou bem no jogo e acertou o alvo com bela finalização</segment>
    <segment id="2">No dia de São João</segment>
    <segment id="3">, o Figueirense tentou jogar água no licor do Bahia e saiu na frente</segment>
    <segment id="4">, no Estádio Orlando Scarpelli</segment>
    <segment id="5">, em Florianópolis.</segment>
    <segment id="6">O gol foi marcado por Júlio César</segment>
    <segment id="7">, que aproveitou cochilo da defesa tricolor após cobrança de escanteio para abrir o placar do jogo</segment>
    <segment id="8">, aos seis minutos do segundo tempo.</segment>
    <segment id="9">Porém, quem entende de forró é o Esquadrão.</segment>
    <segment id="10">Após vacilo do adversário</segment>
    <segment id="11">, Vander mostrou</segment>
    <segment id="12">comocomo</segment>
    <segment id="13">sese dança quadrilha e marcou um belo gol da entrada da área</segment>
    <segment id="14">, o do empate por 1 a 1</segment>
    <segment id="15">, pela sexta rodada do Brasileirão.</segment>
    <segment id="16">Apesar do pênalti não marcado em cima do estreante Mancini</segment>
    <segment id="17">, o Bahia “pulou a figueira” na tarde de ontem.</segment>
    <segment id="18">O Paredão Marcelo Lomba novamente fez grandes defesas e garantiu o resultado.</segment>
    <segment id="19">Quem também teve ótima atuação foi o zagueiro Danny Morais</segment>
    <segment id="20">, que evitou dois gols do Figueirense em cima da linha.
Falcão satisfeito com apresentação</segment>
    <segment id="21">O empate fora de casa foi elogiado por Falcão</segment>
    <segment id="22">, satisfeito com o desempenho do Bahia no Orlando Scarpelli.</segment>
    <segment id="23">“Tivemos uma boa apresentação.</segment>
    <segment id="24">Foram as estreias do Mancini e do Lucas [Fonseca]</segment>
    <segment id="25">, o segundo jogo do Elias.</segment>
    <segment id="26">A gente tinha pouco ritmo</segment>
    <segment id="27">, não dá para dizer que foi ruim.</segment>
    <segment id="28">Nós tivemos condições de ganhar</segment>
    <segment id="29">, tivemos o pênalti no Mancini</segment>
    <segment id="30">, masmas o Figueirense também teve chances.</segment>
    <segment id="31">Não podemos jogar fora um empate</segment>
    <segment id="32">comocomo esse.</segment>
    <segment id="33">Os jogadores tiveram a competência de buscar o resultado”</segment>
    <segment id="34">, contou o treinador.</segment>
    <segment id="35">O meia Vander também comemorou o resultado e falou sobre o belo gol: “Ajudou no resultado</segment>
    <segment id="36">, que foi um prêmio pela partida que fizemos.</segment>
    <segment id="37">Eu observei que o Wilson estava um pouco mal colocado e bati no canto.</segment>
    <segment id="38">Foi um resultado importante.</segment>
    <segment id="39">Fico feliz em poder ajudar”</segment>
    <segment id="40">, explicou.</segment>
    <segment id="41">Outro destaque na partida</segment>
    <segment id="42">, o zagueiro Danny Morais garantiu que o Bahia evoluiu:</segment>
    <segment id="43">“É a segunda partida que a gente busca o empate</segment>
    <segment id="44">, com um futebol um pouco mais para frente”</segment>
    <segment id="45">, justificou.</segment>
  </rst>
</analysis>