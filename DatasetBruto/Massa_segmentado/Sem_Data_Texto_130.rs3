  <rst>
    <segment id="1">Bebê cardíaca consegue vaga
Larissa obteve autorização ontem à noite para</segment>
    <segment id="2">sese internar no Hospital Ana Nery</segment>
    <segment id="3">A família de Larissa Cerqueira dos Reis</segment>
    <segment id="4">, de apenas 13 dias</segment>
    <segment id="5">, aguardava até ontem à noite</segment>
    <segment id="6">, uma vaga neonatal em Unidade de Terapia Intensiva (UTI) em hospital de Salvador para transferi-la de Feira de Santana (a 109 km da capital).</segment>
    <segment id="7">A pequena nasceu com uma deficiência no coração e precisa ser submetida a uma cirurgia que só é realizada em Salvador.</segment>
    <segment id="8">Ontem à noite a vaga surgiu no Hospital Ana Nery e a previsão era de que a criança fosse transferida imediatamente.</segment>
    <segment id="9">A bebê de Ilhéus (a 464 km de Salvador) nasceu com cardiopatia congênita</segment>
    <segment id="10">, uma má- -formação no coração e precisa fazer uma cirurgia de correção nas artérias com urgência.</segment>
    <segment id="11">A criança estava internada na UTI do Hospital Inácia Pinto</segment>
    <segment id="12">, em Feira de Santana</segment>
    <segment id="13">, e corre risco de morte.</segment>
    <segment id="14">“</segment>
    <segment id="15">O meu receio é a transferência demore e minha bebê morra.</segment>
    <segment id="16">Peço pelo amor de Deus que façam logo esta cirurgia”</segment>
    <segment id="17">, desabafou o pai da criança</segment>
    <segment id="18">, Luís Carlos Passos dos Reis</segment>
    <segment id="19">, antes de receber a boa notícia.</segment>
    <segment id="20">A diretora de Gestão da Rede Própria da Secretária Municipal de Saúde de Feira de Santana</segment>
    <segment id="21">, Gilberte Lucas</segment>
    <segment id="22">, informou que enviou um relatório do</segment>
    <segment id="23">casocaso diretamente para o secretário.</segment>
    <segment id="24">“Pedimos que ele fizesse o possível para agilizar o procedimento”</segment>
    <segment id="25">, informou.</segment>
    <segment id="26">Governo pagará despesa</segment>
    <segment id="27">As despesas da cirurgia de Larissa estão avaliadas em R$ 80 mil e os pais da criança não têm</segment>
    <segment id="28">comocomo arcar com o valor.</segment>
    <segment id="29">No entanto</segment>
    <segment id="30">, eles obtiveram liminar na Justiça obrigando o município</segment>
    <segment id="31">, o Estado e a União a custearem o procedimento.</segment>
    <segment id="32">Por intermédio da assessoria de comunicação</segment>
    <segment id="33">, a Secretaria da Saúde do Estado da Bahia (Sesab) informou:</segment>
    <segment id="34">“</segment>
    <segment id="35">O secretário está pessoalmente em contato com a direção das unidades para conseguir esta vaga e assim realizar a cirurgia.</segment>
    <segment id="36">A vaga na UTI é importante</segment>
    <segment id="37">, pois</segment>
    <segment id="38">pois a bebê necessita ser transferida para lá após o procedimento”.</segment>
  </rst>
</analysis>