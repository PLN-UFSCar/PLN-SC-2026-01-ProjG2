  <rst>
    <segment id="1">Galera pﾃδｵe violﾃδ｣o para chorar</segment>
    <segment id="2">O show rola todo domingo</segment>
    <segment id="3">, masmas</segment>
    <segment id="4">sese o tempo fecha</segment>
    <segment id="5">, a festa</segment>
    <segment id="6">ﾃδｩ cancelada</segment>
    <segment id="7">Nos domingos de sol</segment>
    <segment id="8">,  a praﾃδｧa Almeida Couto</segment>
    <segment id="9">, emNazarﾃδｩ</segment>
    <segment id="10">, ﾃδｩ tomada por uma multidﾃδ｣o que vai ouvir e danﾃδｧar ao som das melodias do chorinho do Grupo Cultural Canto da Praﾃδｧa.</segment>
    <segment id="11">A festa vai das 9h30</segment>
    <segment id="12">ﾃδs 12h e reﾃδｺne cerca de mil pessoas.</segment>
    <segment id="13">Embora grande parte do pﾃδｺblico seja de pessoas idosas</segment>
    <segment id="14">, as crianﾃδｧas tambﾃδｩm aproveitam o espaﾃδｧo para brincar.</segment>
    <segment id="15">Uma cama elﾃδ｡stica fez a alegria dos pequenos.</segment>
    <segment id="16">O grupo</segment>
    <segment id="17">, que ﾃδｩ composto por dez mﾃδｺsicos</segment>
    <segment id="18">, foi formado em 2004.</segment>
    <segment id="19">Eles se</segment>
    <segment id="20">se reﾃδｺnem para cantar na praﾃδｧa hﾃδ｡ sete anos e arrastam adeptos do chorinho de todas as partes de Salvador.</segment>
    <segment id="21">A aposentada Lindaura Nunes</segment>
    <segment id="22">, 85, mora em periperi</segment>
    <segment id="23">, masmas chega bem cedinho para pegar uma mesa na frente do palco improvisado.</segment>
    <segment id="24">Os mﾃδｺsicos Joﾃδ｣o Dias</segment>
    <segment id="25">, 61, e Edvaldo Carvalhal</segment>
    <segment id="26">, 57, sﾃδ｣o os fundadores do grupo.</segment>
    <segment id="27">ﾃ｢竄ｬﾅ擢omos apresentados e surgiu uma afinidade</segment>
    <segment id="28">, entﾃδ｣o decidimos fazer este projetoﾃ｢竄ｬ</segment>
    <segment id="29">, relembra Joﾃδ｣o.</segment>
    <segment id="30">Para continuar fazendo parte da banda</segment>
    <segment id="31">, o mﾃδｺsico deve seguir ﾃδ risca os princﾃδｭpios de comportamento do grupo e nﾃδ｣o pode beber durante as apresentaﾃδｧﾃδｵes.</segment>
    <segment id="32">Canﾃδｧﾃδｵes de vﾃδ｡rios ritmos sﾃδ｣o transformadas em chorinho.</segment>
    <segment id="33">O Hino do Senhor do Bonfim abre a festa</segment>
    <segment id="34">, masmas o Rei Roberto Carlos ﾃδｩ o preferido das coroas.</segment>
    <segment id="35">ﾃ｢竄ｬﾅ摘ssas canﾃδｧﾃδｵes fizeram parte da minha juventudeﾃ｢竄ｬ</segment>
    <segment id="36">, relembra Lindaura.</segment>
    <segment id="37">No amor e na danﾃδｧa</segment>
    <segment id="38">O casal de aposentados Jeovﾃδ｡ de Andrade</segment>
    <segment id="39">, 86, e Guiomar Pinto</segment>
    <segment id="40">, 81, se</segment>
    <segment id="41">se conheceram danﾃδｧando e estﾃδ｣o juntos hﾃδ｡ 24 anos.</segment>
    <segment id="42">Eles nﾃδ｣o perdem um domingo de chorinho e sﾃδ｣o conhecidos por todos</segment>
    <segment id="43">comocomo o casal mais antigo do evento.</segment>
    <segment id="44">ﾃ｢竄ｬﾅ摘u costumava amanhecer o dia danﾃδｧando</segment>
    <segment id="45">, masmas hoje ele estﾃδ｡ cansado e nﾃδ｣o consegue acompanhar o meu ritmoﾃ｢竄ｬ</segment>
    <segment id="46">, brinca Guiomar.</segment>
    <segment id="47">A aposentada relembra a sua juventude nos salﾃδｵes da cidade e afirma que chamava a atenﾃδｧﾃδ｣o com seu jeito de danﾃδｧar.</segment>
    <segment id="48">Comida variada
Mais de 20 barracas de bebida e comida sﾃδ｣o montadas na praﾃδｧa.</segment>
    <segment id="49">Os vendedores ambulantes madrugam para armar as bancas antes da folia comeﾃδｧar.</segment>
    <segment id="50">O cardﾃδ｡pio ﾃδｩ variado e cabe em todos os bolsos</segment>
    <segment id="51">, a preﾃδｧos entre R$ 2 e R$ 10.</segment>
    <segment id="52">O famoso churrasquinho no palito</segment>
    <segment id="53">ﾃδｩ o mais pedido.</segment>
    <segment id="54">Mas, para quem nﾃδ｣o dispensa uma refeiﾃδｧﾃδ｣o</segment>
    <segment id="55">, tem feijoada</segment>
    <segment id="56">, arrumadinho</segment>
    <segment id="57">, churrasco no prato e acarajﾃδｩ.</segment>
    <segment id="58">A ambulante Joseane Macedo</segment>
    <segment id="59">, 42, resolveu inovar.</segment>
    <segment id="60">ﾃ｢竄ｬﾅ典em muita gente trabalhando aqui</segment>
    <segment id="61">, entﾃδ｣o fiz um abaralhau (abarﾃδ｡ de bacalhau)</segment>
    <segment id="62">, todo mundo gosta</segment>
    <segment id="63">, pois</segment>
    <segment id="64">pois ﾃδｩ</segment>
    <segment id="65">diferenteﾃ｢竄ｬ.</segment>
  </rst>
