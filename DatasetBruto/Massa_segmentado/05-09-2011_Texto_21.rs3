  <rst>
    <segment id="1">Tricolor reage e depena</segment>
    <segment id="2">Urubu</segment>
    <segment id="3">Com direito a olé e dancinhas</segment>
    <segment id="4">, tricolores fizeram a maior festa no Engenhão</segment>
    <segment id="5">Se Joel Santana só queria treinar peixe grande</segment>
    <segment id="6">, conseguiu.</segment>
    <segment id="7">Uma vitória inquestionável contra o Flamengo</segment>
    <segment id="8">, em pleno Engenhão</segment>
    <segment id="9">, foi a prova de que o Bahia tem time para neutralizar até um dos favoritos ao título</segment>
    <segment id="10">, confirmando sua invencibilidade perante os times cariocas da Série A.</segment>
    <segment id="11">No momento que aceitou o convite para ser o novo técnico do tricolor</segment>
    <segment id="12">, na noite de sábado</segment>
    <segment id="13">, Joel</segment>
    <segment id="14">sese comprometeu a assumir um time na zona de rebaixamento.</segment>
    <segment id="15">Mas já não será preciso.</segment>
    <segment id="16">Com o inesperado triunfo</segment>
    <segment id="17">, o Bahia subiu duas posições e está em 15º.</segment>
    <segment id="18">Bem distribuído em campo</segment>
    <segment id="19">, o Esquadrão não deu espaço para uma reação rubro-negra</segment>
    <segment id="20">, com direito a caneta de Jones e até mesmo dribles dos criticados Júnior e Souza.</segment>
    <segment id="21">O primeiro gol veio com um chute de Titi na entrada da área</segment>
    <segment id="22">, marcando seu segundo com a camisa tricolor.</segment>
    <segment id="23">Mesmo sabendo que o Flamengo tem os melhores batedores de falta do Brasileirão</segment>
    <segment id="24">, o Bahia não conseguiu evitar a penalidade.</segment>
    <segment id="25">Renato bateu por cima da barreira para marcar o único gol do Fla na partida.</segment>
    <segment id="26">O Bahia buscou a vitória com Dodô</segment>
    <segment id="27">, que mandou para as redes por entre as pernas do goleiro.</segment>
    <segment id="28">O placar fechou ainda no primeiro tempo</segment>
    <segment id="29">, com um gol chorado de Souza.</segment>
    <segment id="30">Os times  empataram em 3x3 no primeiro turno</segment>
    <segment id="31">, em jogo marcado pelos erros de arbitragem favorecendo o Flamengo.</segment>
    <segment id="32">Desta vez</segment>
    <segment id="33">, o árbitro bem que tentou</segment>
    <segment id="34">, masmas nem com cinco minutos de acréscimo o Fla conseguiu estragar a festa.</segment>
  </rst>
</analysis>