  <rst>
    <segment id="1">Cuidado para sonho não virar pesadelo!</segment>
    <segment id="2">Feirão Caixa da Casa Própria começa amanhã e vai até domingo</segment>
    <segment id="3">Cautela e atenção podem ser o segredo do sucesso para consumidores interessados em conferir os 18 mil imóveis disponíveis em Salvador.</segment>
    <segment id="4">A recomendação é de órgãos de defesa do consumidor e analistas financeiros</segment>
    <segment id="5">, que alertam que adquirir o imóvel dos sonhos nem sempre significa um bom negócio.</segment>
    <segment id="6">“</segment>
    <segment id="7">É preciso ter em  mente que  a compra terá impactos no orçamento por até 20 anos”</segment>
    <segment id="8">, lembra a gerente jurídica do Instituto Brasileiro de Defesa do Consumidor (Idec)</segment>
    <segment id="9">, Maria Luiza Novaes</segment>
    <segment id="10">, que sugere aos compradores que não</segment>
    <segment id="11">sese deixem influenciar pela publicidade em torno dos empreendimentos.</segment>
    <segment id="12">A ordem é resistir às tentações.</segment>
    <segment id="13">Os  vendedores vêm com tudo: imóveis para todos os gostos e vantagens aparentemente imperdíveis</segment>
    <segment id="14">, que muitas vezes</segment>
    <segment id="15">sese confirmam e outras</segment>
    <segment id="16">, não.</segment>
    <segment id="17">Por isso</segment>
    <segment id="18">, comprar por impulso pode ser um erro com impactos a longo prazo.</segment>
    <segment id="19">“Todos os aspectos da  compra devem ser avaliados”</segment>
    <segment id="20">, diz a advogada</segment>
    <segment id="21">, que recomenda</segment>
    <segment id="22">, inclusive</segment>
    <segment id="23">, uma visita ao  empreendimento:</segment>
    <segment id="24">“Como a feira dura um certo tempo</segment>
    <segment id="25">, é possível fazer isso antes de assinar o contrato”.</segment>
    <segment id="26">O analista financeiro Ângelo Guerreiro vai ainda mais longe.</segment>
    <segment id="27">Para ele</segment>
    <segment id="28">, os feirões  são locais ideais para</segment>
    <segment id="29">sese buscar informações.</segment>
    <segment id="30">A compra pode ser concretizada mais tarde.</segment>
    <segment id="31">“</segment>
    <segment id="32">Os corretores vão pressionar</segment>
    <segment id="33">para que</segment>
    <segment id="34">para que</segment>
    <segment id="35">sese aproveite a oferta do momento</segment>
    <segment id="36">, masmas</segment>
    <segment id="37">, geralmente</segment>
    <segment id="38">, elas são mantidas após a feira”.</segment>
    <segment id="39">Até mobiliário gratuito</segment>
    <segment id="40">As vendas serão impulsionadas também por ofertas de todos os tipos</segment>
    <segment id="41">, inclusive o mobiliário gratuito em algumas dependências.</segment>
    <segment id="42">Esse tipo de promoção</segment>
    <segment id="43">, segundo o presidente do Conselho Regional de Corretores de Imóveis (Creci/Ba)</segment>
    <segment id="44">, Samuel Prado</segment>
    <segment id="45">, aparentemente simples diante do alto valor dos imóveis</segment>
    <segment id="46">, pode determinar uma venda.</segment>
    <segment id="47">“Quem pensa em adquirir imóvel em alguns meses</segment>
    <segment id="48">, pode</segment>
    <segment id="49">sese interessar pela oferta e antecipar a compra”</segment>
    <segment id="50">, ressalta.</segment>
    <segment id="51">Antes de fechar o negócio</segment>
    <segment id="52">, sese ligue!</segment>
  </rst>
</analysis>