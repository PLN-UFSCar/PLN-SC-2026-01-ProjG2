  <rst>
    <segment id="1">Polﾃδｭcia troca tiro ao criar nova base</segment>
    <segment id="2">Branco morreu apﾃδｳs levar bala.</segment>
    <segment id="3">Ele foi pego com fuzil</segment>
    <segment id="4">, colete</segment>
    <segment id="5">, muniﾃδｧﾃδ｣o e crack</segment>
    <segment id="6">Um homem foi baleado e outro foi preso</segment>
    <segment id="7">, na manhﾃδ｣ de ontem</segment>
    <segment id="8">, durante uma operaﾃδｧﾃδ｣o com cerca de 250 policiais (civis e militares)</segment>
    <segment id="9">, que irﾃδ｡ preparar  a instalaﾃδｧﾃδ｣o da Base Comunitﾃδ｡ria de Seguranﾃδｧa (serﾃδ｡ a sﾃδｩtima no Estado)</segment>
    <segment id="10">provisﾃδｳria no Bairro da Paz</segment>
    <segment id="11">, prevista para funcionar a partir do dia 13.</segment>
    <segment id="12">Acusado pela polﾃδｭcia de liderar o trﾃδ｡fico de drogas na regiﾃδ｣o</segment>
    <segment id="13">, alﾃδｩm de ser acusado de cometer vﾃδ｡rios homicﾃδｭdios</segment>
    <segment id="14">, Florisvaldo dos Santos</segment>
    <segment id="15">, o Flor</segment>
    <segment id="16">, segue foragido.</segment>
    <segment id="17">Um suspeito de prenome Edmilson</segment>
    <segment id="18">, o Ed</segment>
    <segment id="19">, foi preso por volta das 6h</segment>
    <segment id="20">, ao ser reconhecido por um oficial da PM</segment>
    <segment id="21">comocomo um dos sequestradores da delegada Gabriela Macedo</segment>
    <segment id="22">, no ﾃδｺltimo dia 4</segment>
    <segment id="23">, na Pituba.</segment>
    <segment id="24">ﾃ｢竄ｬﾅ摘le nﾃδ｣o ofereceu resistﾃδｪnciaﾃ｢竄ｬ</segment>
    <segment id="25">, disse o major PM Aloysio Herwans.</segment>
    <segment id="26">O mesmo nﾃδ｣o aconteceu com o suspeito de prenome Tiago</segment>
    <segment id="27">, o Branco</segment>
    <segment id="28">, que foi baleado numa suposta troca de tiros com policiais</segment>
    <segment id="29">, na localidade Alto da Felicidade</segment>
    <segment id="30">, e depois levado ao Hospital Menandro de Farias</segment>
    <segment id="31">, em Lauro de Freitas</segment>
    <segment id="32">, onde faleceu.
ﾃ｢竄ｬﾅ摘le trocou tiros com nossos homens.</segment>
    <segment id="33">Ainda nﾃδ｣o sabemos o estado de saﾃδｺde deleﾃ｢竄ｬ</segment>
    <segment id="34">, afirmou o coronel PM Berlink</segment>
    <segment id="35">, ﾃδ frente da operaﾃδｧﾃδ｣o de ocupaﾃδｧﾃδ｣o policial no bairro.</segment>
    <segment id="36">Comunidade estﾃδ｡ por fora do processo</segment>
    <segment id="37">O vice-coordenador da Associaﾃδｧﾃδ｣o de Moradores do Bairro da Paz</segment>
    <segment id="38">, que preferiu</segment>
    <segment id="39">sese identificar</segment>
    <segment id="40">comocomo Carlos</segment>
    <segment id="41">, afirma que a permanﾃδｪncia da polﾃδｭcia no local</segment>
    <segment id="42">ﾃδｩ uma realidade nova.</segment>
    <segment id="43">ﾃ｢竄ｬﾅ撤or enquanto</segment>
    <segment id="44">, nﾃδ｣o temos expectativas</segment>
    <segment id="45">, porque</segment>
    <segment id="46">porque nﾃδ｣o sabemos</segment>
    <segment id="47">comocomo serﾃδ｡ essa ocupaﾃδｧﾃδ｣o.</segment>
    <segment id="48">Nosso histﾃδｳrico ﾃδｩ de ver a polﾃδｭcia entrando na comunidade para derrubar as casasﾃ｢竄ｬ</segment>
    <segment id="49">, recordou.</segment>
    <segment id="50">Segundo o major PM Herwans</segment>
    <segment id="51">, a base funcionarﾃδ｡ no antigo prﾃδｩdio da Escola Estadual Mestre Paulo dos Anjos</segment>
    <segment id="52">, na Rua da Resistﾃδｪncia</segment>
    <segment id="53">, com 360 policiais.</segment>
    <segment id="54">ﾃ｢竄ｬﾅ哲osso objetivo maior ﾃδｩ nos aproximar da populaﾃδｧﾃδ｣o</segment>
    <segment id="55">, atravﾃδｩs da filosofia de policiamento comunitﾃδ｡rio</segment>
    <segment id="56">, para diminuirmos os ﾃδｭndices de violﾃδｪnciaﾃ｢竄ｬ</segment>
    <segment id="57">, frisou.</segment>
