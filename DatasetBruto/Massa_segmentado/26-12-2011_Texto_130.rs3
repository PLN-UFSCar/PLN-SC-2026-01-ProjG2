  <rst>
    <segment id="1">Drama do jegue Roberto Carlos
Malvadão ateou fogo no bicho</segment>
    <segment id="2">porque</segment>
    <segment id="3">porque estava montando no animal e foi derrubado</segment>
    <segment id="4">O sofrimento do carroceiro Edson Pereira Correia</segment>
    <segment id="5">, 38 anos</segment>
    <segment id="6">, conhecido</segment>
    <segment id="7">comocomo Tchu</segment>
    <segment id="8">, vai além de ver seu jegue Roberto Carlos com parte do corpo queimado.</segment>
    <segment id="9">O animal</segment>
    <segment id="10">, domesticado para transportar carga</segment>
    <segment id="11">, foi queimado há cerca de três semanas por um jovem no bairro de Plataforma</segment>
    <segment id="12">, no subúrbio ferroviário.</segment>
    <segment id="13">A maior parte do ferimento já cicatrizou</segment>
    <segment id="14">, masmas uma grande ferida ainda está aberta no couro de Roberto Carlos.</segment>
    <segment id="15">Tchu está gastando R$ 50 por semana</segment>
    <segment id="16">, metade do que ganha nesse período</segment>
    <segment id="17">, com remédios para tratar o jegue.</segment>
    <segment id="18">Roberto Carlos é um dos três animais de tração utilizado por Edson para sustentar a mulher e os seis filhos.</segment>
    <segment id="19">“Comprei o jegue há um ano por R$ 400 e vem um desgraçado fazer isso.</segment>
    <segment id="20">Labuto desde os 10 anos com animais.</segment>
    <segment id="21">É assim que ganho a vida”</segment>
    <segment id="22">, conta o carroceiro que não registrou queixa do crime por temer represálias.</segment>
    <segment id="23">“Quem fez isso não tem nada a perder e eu tenho minha família para sustentar.</segment>
    <segment id="24">Tenho medo desse elemento atentar contra minha vida”</segment>
    <segment id="25">, completa.</segment>
    <segment id="26">Tchu está aplicando um anti-inflamatório e um antibiótico em Roberto Carlos</segment>
    <segment id="27">, seguindo sugestão de um funcionário de uma loja de produtos veterinários.</segment>
    <segment id="28">O carroceiro aproveita para fazer um apelo pedindo ajuda para tratar o animal.</segment>
    <segment id="29">Se um veterinário puder explicar a melhor forma para tratar as queimaduras e outras pessoas puderem ajudar a comprar os remédios eu fico muito agradecido”</segment>
    <segment id="30">, declara.</segment>
    <segment id="31">O jegue Roberto Carlos foi queimado na Rua da Bela Vista</segment>
    <segment id="32">, em Plataforma.</segment>
    <segment id="33">Segundo os moradores</segment>
    <segment id="34">, a Polícia Militar foi chamada e compareceu ao local.</segment>
    <segment id="35">Mas  ninguém entregou o autor do delito.</segment>
    <segment id="36">Os policiais orientaram a população a procurar o Ibama.</segment>
    <segment id="37">Crime ambiental:</segment>
    <segment id="38">Pessoas devem prestar queixa</segment>
    <segment id="39">O delegado Pedro Andrade</segment>
    <segment id="40">, titular em exercício da 5ª Delegacia Territorial (Periperi)</segment>
    <segment id="41">, orienta os donos dos animais ou testemunhas de maus-tratos contra os bichos a prestarem queixa.</segment>
    <segment id="42">“Cabe um termo circustanciado contra o autor de maus-tratos a animias.</segment>
    <segment id="43">Infelizmente</segment>
    <segment id="44">, a legislação considera esse crime</segment>
    <segment id="45">comocomo de menor potencial ofensivo”</segment>
    <segment id="46">, explica o delegado.</segment>
    <segment id="47">O art. 32 da lei que dispões sobre as atividades lesivas ao meio ambiente (9.605/98) determina pena de detenção</segment>
    <segment id="48">, de três meses a um ano</segment>
    <segment id="49">, e multa para quem pratica ato de abuso</segment>
    <segment id="50">, maus-tratos</segment>
    <segment id="51">, fere ou mutila animais.</segment>
    <segment id="52">Moradores acusam jovem</segment>
    <segment id="53">Os moradores de Plataforma acusam um jovem de prenome Osvaldo</segment>
    <segment id="54">, de idade entre 16 e 18 anos</segment>
    <segment id="55">, de ter ateado fogo ao jegue.</segment>
    <segment id="56">“Ele e outros colegas estavam montando no animal.</segment>
    <segment id="57">Como o bicho derrubou Osvaldo</segment>
    <segment id="58">, ele amarrou o jegue com fio e ateou fogo no bicho”</segment>
    <segment id="59">, contou um morador sob anonimato.</segment>
    <segment id="60">As pessoas disseram que Osvaldo seria usuário de drogas e envolvido com a criminalidade.</segment>
    <segment id="61">“Se ele foi capaz de fazer isso com um bicho também é capaz de fazer com gente.</segment>
    <segment id="62">Foi perversidade mesmo.</segment>
    <segment id="63">Ele já colou a boca de filhotes de cachorro com cola Super Bonder”</segment>
    <segment id="64">, afirma outra moradora.</segment>
  </rst>
</analysis>