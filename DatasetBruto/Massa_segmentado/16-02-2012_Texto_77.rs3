  <rst>
    <segment id="1">Renata fura olho de Monique e beija Rafa
Depois de trocarem carícias no edredom</segment>
    <segment id="2">, Rafa e Renata</segment>
    <segment id="3">sese beijaram na pista de dança</segment>
    <segment id="4">Mesmo com uma redução de bebidas nas festas do BBB 12</segment>
    <segment id="5">, as noites de badalação têm deixado os brothers bem assanhadinhos.</segment>
    <segment id="6">Na Festa Lapinha</segment>
    <segment id="7">, realizada anteontem</segment>
    <segment id="8">, foi a vez de Renata  e Rafa trocarem beijos em  meio a todos os confinados.</segment>
    <segment id="9">O brother nem</segment>
    <segment id="10">sese incomodou com o fato de ser comprometido e ainda disse bem alto que queria trair a namorada naquela noite.</segment>
    <segment id="11">Dito e feito!</segment>
    <segment id="12">A pegação não ficou só no momento da festa.</segment>
    <segment id="13">Os dois continuaram os amassos debaixo do edredom no quarto Selva.</segment>
    <segment id="14">O clima esquentou ainda mais e Rafa chegou a dizer à Renata: "</segment>
    <segment id="15">Ai, que tesão!</segment>
    <segment id="16">”.</segment>
    <segment id="17">Camila Pastorini</segment>
    <segment id="18">, a namorada do brother</segment>
    <segment id="19">, não deve estar nada satisfeita com o corno que levou em plena rede nacional!</segment>
    <segment id="20">Coitadinha!</segment>
    <segment id="21">Novo casal foi reprovado!</segment>
    <segment id="22">Monique não gostou do novo casal.</segment>
    <segment id="23">"Não me venha com inocência falar que não pensava em ficar com ele</segment>
    <segment id="24">, como</segment>
    <segment id="25">como foi com o Jonas.</segment>
    <segment id="26">É a segunda vez que você faz isso.</segment>
    <segment id="27">Não confio mais em você"</segment>
    <segment id="28">, disse a gaúcha para Renata.</segment>
    <segment id="29">Yuri também  brigou com Rafa</segment>
    <segment id="30">, porque</segment>
    <segment id="31">porque o  brother não tinha contado a ele o que está rolando entre os dois na casa do BBB 12.</segment>
