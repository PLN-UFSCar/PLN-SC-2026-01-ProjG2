  <rst>
    <segment id="1">PMs avisam que o movimento continua
PMs e familiares deixaram o prédio da AL</segment>
    <segment id="2">, masmas garantem que o movimento vai continuar
Depois de uma madrugada de tensão na última quinta-feira (9)</segment>
    <segment id="3">, cerca de 250 policiais militares e familiares deixaram o prédio da Assembleia Legislativa</segment>
    <segment id="4">, onde estavam acampados desde o dia 31 de janeiro.</segment>
    <segment id="5">Com a saída dos manifestantes grevistas</segment>
    <segment id="6">, tropas do Exército e da Força Nacional de Segurança realizaram uma varredura no prédio</segment>
    <segment id="7">, localizado no Centro Administrativo da Bahia</segment>
    <segment id="8">, e constataram que não há mais nenhum manifestante no local.</segment>
    <segment id="9">Os PMs decidiram ainda que só vão encerrar o movimento depois que o Governo garantir o pagamento da Gratificação por atividade Policial IV (GAP IV) em março deste ano e revogar as prisões que foram decretadas pela Justiça baiana para 12 policiais militares</segment>
    <segment id="10">, entre eles</segment>
    <segment id="11">, o líder do movimento (leia quadro abaixo).</segment>
    <segment id="12">Ontem, cerca de 500 policiais militares  vinculados à Associação de Policiais e Bombeiros e de seus Familiares (Aspra)</segment>
    <segment id="13">, grupo que liderava a ocupação</segment>
    <segment id="14">, passaram o dia reunidos no Sindicato dos Bancários</segment>
    <segment id="15">, no Largo dos Aflitos</segment>
    <segment id="16">, em Salvador.</segment>
    <segment id="17">Durante o encontro</segment>
    <segment id="18">, os grevistas</segment>
    <segment id="19">, presentes no sindicato</segment>
    <segment id="20">, sese mostraram revoltados com a detenção de quatro dos 12 líderes do movimento que tiveram a prisão preventiva decretada pela Justiça.</segment>
    <segment id="21">Um dos presentes garantiu que a paralisação da PM é quase que total.</segment>
    <segment id="22">“</segment>
    <segment id="23">Só quem está dizendo que a greve acabou é a mídia”</segment>
    <segment id="24">, reclamou.</segment>
    <segment id="25">Por volta das 20h eles deixaram o local cantando 'A PM parou' e 'Uhu</segment>
    <segment id="26">, a greve continua'.</segment>
    <segment id="27">O governador da Bahia Jaques Wagner não apresentará uma nova proposta.</segment>
    <segment id="28">De acordo com a Secom</segment>
    <segment id="29">, não há orçamento para ceder um aumento superior aos 6</segment>
    <segment id="30">,5% propostos.</segment>
    <segment id="31">Prisco está preso

Marco Prisco foi preso ontem</segment>
    <segment id="32">, após</segment>
    <segment id="33">sese render.</segment>
    <segment id="34">Ele saiu pelo fundo da Assembleia Legislativa da Bahia</segment>
    <segment id="35">, de acordo com o tenente-coronel Márcio Cunha</segment>
    <segment id="36">, chefe de comunicação da 6ª Região do Exército.</segment>
    <segment id="37">Segundo Rogério Andrade</segment>
    <segment id="38">, um dos advogados de Prisco</segment>
    <segment id="39">, ele decidiu</segment>
    <segment id="40">sese entregar por conta da "inflexibilidade do governo para negociar" e com o objetivo de evitar um conflito armado.</segment>
    <segment id="41">De acordo com Andrade</segment>
    <segment id="42">,  o ex-PM ficará em cela convencional</segment>
    <segment id="43">, onde dividirá espaço com outros internos.</segment>
    <segment id="44">Prisco saiu algemado da sede da Polícia do Exército</segment>
    <segment id="45">, na Paralela</segment>
    <segment id="46">, após consenso com a Polícia Federal.</segment>
    <segment id="47">Atrás das grades</segment>
    <segment id="48">A Secretaria de Comunicação divulgou mensagens trocadas pela soldado Jeane Batista de Souza com o líder grevista Marco Prisco sobre uma possível invasão ao Batalhão de Guardas</segment>
    <segment id="49">, no Complexo de Mata Escura</segment>
    <segment id="50">, onde a soldado é lotada.</segment>
    <segment id="51">O telefone de Jeane foi grampeado com autorização da Justiça.</segment>
    <segment id="52">Nas mensagens</segment>
    <segment id="53">, ela informa o melhor horário para a ação do plano.</segment>
    <segment id="54">"</segment>
    <segment id="55">O efetivo é muito pouco.</segment>
    <segment id="56">15 homens armados rendem a guarnição"</segment>
    <segment id="57">, diz um dos SMS.</segment>
    <segment id="58">E incentiva:</segment>
    <segment id="59">“</segment>
    <segment id="60">Não recue</segment>
    <segment id="61">, não podemos aceitar a migalha de 6</segment>
    <segment id="62">,5% oferecido por Wagner com a desculpa de ter orçamento apertado”.</segment>
    <segment id="63">A Secom também divulgou um telefonema de Jeane para Prisco em que ele demonstra conhecimento sobre as escutas telefônicas.</segment>
    <segment id="64">"</segment>
    <segment id="65">Essa ligação não está sendo gravada</segment>
    <segment id="66">, não, né?</segment>
    <segment id="67">", ela pergunta.</segment>
    <segment id="68">"</segment>
    <segment id="69">Tá.</segment>
    <segment id="70">Tudo grampo"</segment>
    <segment id="71">, Prisco afirma</segment>
    <segment id="72">, antes de orientá-la a passar informações por mensagens.</segment>
    <segment id="73">Jeane está presa.</segment>
  </rst>
</analysis>