  <rst>
    <segment id="1">Crédito fácil para 50 mil trabalhadores</segment>
    <segment id="2">Convênio entre governo e Crediamigo priorizará ex-barraqueiros</segment>
    <segment id="3">, ambulantes e baianas</segment>
    <segment id="4">Na próxima sexta-feira</segment>
    <segment id="5">, a prefeitura de Salvador e o Banco do Nordeste vão assinar convênio para disponibilizar</segment>
    <segment id="6">, por meio do Crediamigo</segment>
    <segment id="7">, R$ 20 milhões de crédito para trabalhadores formais e informais.</segment>
    <segment id="8">Segundo o secretário de Comunicação da prefeitura</segment>
    <segment id="9">, Diogo Tavares</segment>
    <segment id="10">, a prefeitura visa atender</segment>
    <segment id="11">, principalmente</segment>
    <segment id="12">, os ambulantes</segment>
    <segment id="13">, os ex-barraqueiros e as baianas de acarajé.</segment>
    <segment id="14">Estes trabalhadores somam aproximadamente 50 mil profissionais</segment>
    <segment id="15">, sendo 12 mil  regulares  – cerca de 600 baianas de acarajé</segment>
    <segment id="16">, além de ex-barraqueiros e ambulantes –  e 38 mil irregulares.</segment>
    <segment id="17">Os dados são da Sesp.</segment>
    <segment id="18">“</segment>
    <segment id="19">O convênio é para quem quiser</segment>
    <segment id="20">, desde que esteja dentro dos critérios do Crediamigo”</segment>
    <segment id="21">, afirma o secretário de Infraestrura</segment>
    <segment id="22">, João Leão.</segment>
    <segment id="23">Segundo ele</segment>
    <segment id="24">, o acordo visa ampliar o  programa em Salvador.</segment>
    <segment id="25">O Crediamigo  teve aplicação de R$ 36 milhões entre 2007 e 2011</segment>
    <segment id="26">, segundo o gerente do programa do Banco do Nordeste</segment>
    <segment id="27">, Joaci Sabino Silva.</segment>
    <segment id="28">Para tanto</segment>
    <segment id="29">, serão implantados 20 postos do Crediamigo em Salvador</segment>
    <segment id="30">, usando instalações do  município</segment>
    <segment id="31">, como</segment>
    <segment id="32">como as Administrações  Regionais (ARs) e  estações de ônibus.</segment>
    <segment id="33">Comerciante interessado: Empréstimo de R$ 10 mil</segment>
    <segment id="34">O vendedor ambulante Gilvan de Jesus Costa</segment>
    <segment id="35">, 37,  ficou interessado na oferta de crédito para ambulantes e disse que vai procurar</segment>
    <segment id="36">sese informar sobre o convênio.</segment>
    <segment id="37">Há dois meses</segment>
    <segment id="38">, ele tentou pegar um empréstimo de R$ 3 mil em um banco</segment>
    <segment id="39">, masmas  desistiu depois que soube que teria de pagar uma prestação de R$ 120</segment>
    <segment id="40">, quantia importante para seu rendimento</segment>
    <segment id="41">, que varia de R$ 600 a R$ 1 mil</segment>
    <segment id="42">, a depender do mês.</segment>
    <segment id="43">“Gostaria de pegar um empréstimo de R$ 5 mil a R$ 10 mil para investir em mercadorias”</segment>
    <segment id="44">, diz.</segment>
    <segment id="45">Gilvan quer  comprar acessórios para celulares e relógios.</segment>
  </rst>
</analysis>