  <rst>
    <segment id="1">Betha Portella
Bailarina de tirar o fôlego
Betha</segment>
    <segment id="2">, apelido de Robertha Portella</segment>
    <segment id="3">, mostrou toda sua sexualidade em um ensaio pra lá de provocante para o site Paparazzo.</segment>
    <segment id="4">E os marmanjos que não</segment>
    <segment id="5">sese engracem muito com a bailarina do Domingo do Faustão.</segment>
    <segment id="6">Isso porque</segment>
    <segment id="7">porque a moça é uma mulher com um estado civil complicado.</segment>
    <segment id="8">Como ela mesmo diz:</segment>
    <segment id="9">“Não estou lá nem cá” quando o assunto é namoro.</segment>
    <segment id="10">Sexo só com amor</segment>
    <segment id="11">Quando o assunto é cama</segment>
    <segment id="12">, a moça é taxativa ao afirmar que só faz sexo com amor:</segment>
    <segment id="13">“</segment>
    <segment id="14">Nunca fiz um sem o outro”.</segment>
    <segment id="15">Com relação ao carinho que mais gosta</segment>
    <segment id="16">, Betha diz que gosta de</segment>
    <segment id="17">sese sentir protegida e cuidada.</segment>
