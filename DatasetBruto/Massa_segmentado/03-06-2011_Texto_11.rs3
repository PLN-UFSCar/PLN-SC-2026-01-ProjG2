  <rst>
    <segment id="1">Acabou o bem-bom do Barão
Bandidão mais procurado pela polícia baiana é preso em Sampa após curtir bem a vida</segment>
    <segment id="2">O criminoso mais procurado pela Secretaria da Segurança Pública foi preso ontem.</segment>
    <segment id="3">Acusado de ser o maior fornecedor de cocaína da Bahia</segment>
    <segment id="4">, Fagner Souza da Silva</segment>
    <segment id="5">, conhecido</segment>
    <segment id="6">comocomo Fal</segment>
    <segment id="7">, 30 anos</segment>
    <segment id="8">, foi localizado em São Paulo</segment>
    <segment id="9">, após pouco mais de um ano de investigações.</segment>
    <segment id="10">Na mesma operação</segment>
    <segment id="11">, denominada Gênesis</segment>
    <segment id="12">, outras 11 pessoas acabaram presas</segment>
    <segment id="13">, na Bahia e em São Paulo.</segment>
    <segment id="14">Entre os capturados</segment>
    <segment id="15">, estão Rosângela de Souza Pinto</segment>
    <segment id="16">, a Tia</segment>
    <segment id="17">, integrante da facção criminosa paulista PCC</segment>
    <segment id="18">, e Jairo Santos da Silva</segment>
    <segment id="19">, conhecido</segment>
    <segment id="20">comocomo Peu</segment>
    <segment id="21">, apontado pela polícia</segment>
    <segment id="22">comocomo um dos líderes do tráfico no Nordeste de Amaralina.</segment>
    <segment id="23">Rosângela era a responsável por fornecer cocaína do PCC aos traficantes da Bahia.</segment>
    <segment id="24">Entre as quadrilhas clientes dela</segment>
    <segment id="25">, estava a Comissão de Paz</segment>
    <segment id="26">, liderada atualmente pelo próprio Fal</segment>
    <segment id="27">, que detém o domínio do narcotráfico em diversos bairros da Grande Salvador.</segment>
    <segment id="28">“</segment>
    <segment id="29">Fal era o responsável por distribuir 200 quilos de pasta-base de cocaína</segment>
    <segment id="30">, todo mês</segment>
    <segment id="31">, na Grande Salvador”</segment>
    <segment id="32">, revelou Maurício Teles Barbosa</segment>
    <segment id="33">, secretário da Segurança.</segment>
    <segment id="34">Pelos cálculos da polícia</segment>
    <segment id="35">, a venda da droga renderia algo em torno de R$ 4 milhões mensais a Fal.</segment>
    <segment id="36">Ele chegou a oferecer R$ 500 mil aos policiais</segment>
    <segment id="37">para que</segment>
    <segment id="38">para que não fosse preso.</segment>
    <segment id="39">Fal chega hoje</segment>
    <segment id="40">Fal foi rendido quando entrava na tesouraria de um banco</segment>
    <segment id="41">, na capital paulista</segment>
    <segment id="42">, de onde planejava sacar R$ 40 mil.</segment>
    <segment id="43">O acusado alegou que</segment>
    <segment id="44">sese mudou para São Paulo por não suportar mais as ameaças de traficantes rivais e as extorsões praticadas por policiais.</segment>
    <segment id="45">Ele será transferido hoje para uma prisão</segment>
    <segment id="46">, em Salvador</segment>
    <segment id="47">, assim</segment>
    <segment id="48">comocomo os cúmplices dele capturados em São Paulo.</segment>
    <segment id="49">Só Rosângela permanecerá em território paulista</segment>
    <segment id="50">, onde mora.</segment>
    <segment id="51">Ela foi presa em Americana (a 126 km da capital paulista).</segment>
    <segment id="52">“Ela mora em uma casa avaliada em R$ 1 milhão</segment>
    <segment id="53">, com piscina e cinco carros na garagem”</segment>
    <segment id="54">, informou a delegada Gabriela Macedo</segment>
    <segment id="55">, da Superintendência de Inteligência</segment>
    <segment id="56">, que presidiu o inquérito.</segment>
    <segment id="57">Entre os veículos</segment>
    <segment id="58">, um VW Golf novo</segment>
    <segment id="59">, um GM Vectra e um Citröen C4.</segment>
  </rst>
</analysis>