  <rst>
    <segment id="1">O cineasta William Friedkin</segment>
    <segment id="2">, de "</segment>
    <segment id="3">O Exorcista" e "</segment>
    <segment id="4">Operação França"</segment>
    <segment id="5">,</segment>
    <segment id="6">morreu nesta segunda-feira (7)</segment>
    <segment id="7">, aos 87 anos</segment>
    <segment id="8">, em Los Angeles</segment>
    <segment id="9">, por insuficiência cardíaca causada por uma pneumonia.</segment>
    <segment id="10">A informação foi confirmada por sua mulher</segment>
    <segment id="11">, a produtora Sherry Lansing.</segment>
    <segment id="12">O diretor William Friedkin em frente à escadaria icônico de &amp;#039</segment>
    <segment id="13">;O Exorcista&amp;#039</segment>
    <segment id="14">; - Gabriella Demczuk/The New York TimesFriedkin foi um dos nomes mais influentes do cinema americano nos anos 1970</segment>
    <segment id="15">, parte de uma geração de cineastas que desafiou as convenções da indústria com obras autorais e com frequência provocativas.</segment>
    <segment id="16">Ele chegou a formar</segment>
    <segment id="17">, ao lado de Francis Ford Coppola e Peter Bogdanovich</segment>
    <segment id="18">, a associação The Directors Company</segment>
    <segment id="19">, que dava total liberdade criativa para diretores</segment>
    <segment id="20">, embora</segment>
    <segment id="21">embora a iniciativa logo tenha</segment>
    <segment id="22">sese dissolvido.</segment>
    <segment id="23">Tal revolução foi impulsionada por "</segment>
    <segment id="24">O Exorcista"</segment>
    <segment id="25">, sua obra-prima</segment>
    <segment id="26">, de 1973.</segment>
    <segment id="27">O longa venceu a resistência das grandes premiações aos filmes de gênero e conquistou dez indicações ao Oscar</segment>
    <segment id="28">, incluindo melhor filme e direção.</segment>
    <segment id="29">Venceu duas estatuetas</segment>
    <segment id="30">, de roteiro adaptado e som.</segment>
    <segment id="31">Em 2023</segment>
    <segment id="32">, ao completar 50 anos</segment>
    <segment id="33">, o longa segue influenciando tramas sobre possessão demoníaca em Hollywood.</segment>
    <segment id="34">Confira cenas do filme &amp;#039</segment>
    <segment id="35">;O Exorcista&amp;#039</segment>
    <segment id="36">;Mais    novamente         de   de  de  representando um  Friedkin tem no currículo uma única vitória no Oscar</segment>
    <segment id="37">, de melhor direção</segment>
    <segment id="38">, por "Operação França".</segment>
    <segment id="39">Lançado dois anos antes</segment>
    <segment id="40">, em 1971</segment>
    <segment id="41">, o longa policial estrelado por Gene Hackman e Roy Scheider acompanhava uma dupla que investiga um grupo de traficantes de drogas.</segment>
    <segment id="42">"</segment>
    <segment id="43">Operação França" venceu cinco estatuetas do Oscar</segment>
    <segment id="44">, incluindo melhor filme.</segment>
    <segment id="45">Antes desses filmes mais celebrados</segment>
    <segment id="46">, porém</segment>
    <segment id="47">porém, Friedkin lançou em 1970 "</segment>
    <segment id="48">Os Rapazes da Banda"</segment>
    <segment id="49">, que desafiou o status quo</segment>
    <segment id="50">comocomo um dos primeiros filmes americanos a falar abertamente sobre homossexualidade.</segment>
    <segment id="51">Baseado na peça "</segment>
    <segment id="52">The Boys in the Band"</segment>
    <segment id="53">, pioneira por seu retrato franco e naturalizado da vida gay em Nova York</segment>
    <segment id="54">, antes mesmo de Stonewall</segment>
    <segment id="55">,</segment>
    <segment id="56">o filme ganhou uma refilmagem há três anos</segment>
    <segment id="57">, pela Netflix.</segment>
    <segment id="58">Friedkin</segment>
    <segment id="59">, que era heterossexual</segment>
    <segment id="60">, não se</segment>
    <segment id="61">se envolveu na nova versão</segment>
    <segment id="62">, desta vez capitaneada por diretor</segment>
    <segment id="63">, produtores e atores gays</segment>
    <segment id="64">, masmas</segment>
    <segment id="65">sese encontrou com a equipe para narrar os desafios de levar a obra às telas numa época muito mais conservadora e hostil ao universo LGBTQIA+.</segment>
    <segment id="66">Confira cenas da nova versão de &amp;#039</segment>
    <segment id="67">;The Boys in the Band&amp;#039</segment>
    <segment id="68">;Mais    novamente         de   de  de  representando um  Ele voltaria à temática queer uma década depois</segment>
    <segment id="69">, em "Parceiros da Noite"</segment>
    <segment id="70">, embora</segment>
    <segment id="71">embora para muitos este tenha envelhecido mal</segment>
    <segment id="72">, por supostamente reforçar estereótipos acerca da homossexualidade.</segment>
    <segment id="73">A trama mostra um policial</segment>
    <segment id="74">, vivido por Al Pacino</segment>
    <segment id="75">, que entra no submundo gay de Nova York em busca de um serial killer.</segment>
    <segment id="76">Independente da abordagem</segment>
    <segment id="77">, Friedkin mais uma vez levou ao espectador médio um universo para o qual este fechava os olhos</segment>
    <segment id="78">, abrindo portas na indústria.</segment>
    <segment id="79">Apropriando-</segment>
    <segment id="80">sese de elementos do cinema de gênero</segment>
    <segment id="81">, em especial o terror e o policial</segment>
    <segment id="82">, e mostrando que filmes poderiam abraçá-los e ainda assim serem considerados sérios e autorais</segment>
    <segment id="83">, o cineasta capturou com maestria o mal-estar e as transformações da sociedade americana entre os anos 1970 e 1980.</segment>
    <segment id="84">Influenciado por Orson Welles e Alfred Hitchcock</segment>
    <segment id="85">, com quem chegou a trabalhar ainda muito jovem e depois</segment>
    <segment id="86">sese desentendeu por sua negativa em usar uma gravata no set de filmagem da série "The Alfred Hitchcock Hour"</segment>
    <segment id="87">, Friedkin tem sua filmografia marcada pelo apuro técnico</segment>
    <segment id="88">, como</segment>
    <segment id="89">como prova "</segment>
    <segment id="90">O Exorcista"</segment>
    <segment id="91">, com sua trilha incisiva e efeitos assombrosos</segment>
    <segment id="92">, e se</segment>
    <segment id="93">se debruçou</segment>
    <segment id="94">, com frequência</segment>
    <segment id="95">, sobre a linha tênue que separa bem e mal</segment>
    <segment id="96">, o ético e o imoral.</segment>
    <segment id="97">Em 1975</segment>
    <segment id="98">, o cineasta demonstrou seu lado cinéfilo ao conduzir uma longa entrevista com Fritz Lang</segment>
    <segment id="99">, diretor de clássicos</segment>
    <segment id="100">comocomo "M</segment>
    <segment id="101">, o Vampiro de Dusseldorf" e "Metrópolis".</segment>
    <segment id="102">O diretor alemão morreria no ano seguinte.</segment>
    <segment id="103">William FriedkinMais    novamente         de   de  de  representando um</segment>
    <segment id="104">Apesar de ter colecionado obras-primas nos anos 1970 e outros sucessos</segment>
    <segment id="105">comocomo "</segment>
    <segment id="106">O Comboio do Medo" e "</segment>
    <segment id="107">Um Golpe Muito Louco"</segment>
    <segment id="108">, Friedkin não conseguiu manter a relevância na máquina de Hollywood</segment>
    <segment id="109">, e seguiu fazendo filmes menores e menos aplaudidos pela crítica depois do policial "Viver e Morrer em Los Angeles"</segment>
    <segment id="110">, de 1985.</segment>
    <segment id="111">No ano seguinte</segment>
    <segment id="112">, fez "Rampage"</segment>
    <segment id="113">, um longa que acompanha um serial killer que não acredita ter feito mal.</segment>
    <segment id="114">Mas, como</segment>
    <segment id="115">como o próprio diretor apontou</segment>
    <segment id="116">, este era um filme em defesa da pena de morte.</segment>
    <segment id="117">Sem grandes estrelas no elenco</segment>
    <segment id="118">, nunca foi corretamente lançado em DVD ou chegou aos streamings.</segment>
    <segment id="119">Seguiria nos anos 1990 e 2000 alternando entre o gênero fantástico e sobrenatural</segment>
    <segment id="120">, com "</segment>
    <segment id="121">A Árvore da Maldição" e "Possuídos"</segment>
    <segment id="122">, e suspenses e policiais</segment>
    <segment id="123">, como</segment>
    <segment id="124">como o remake para TV de "</segment>
    <segment id="125">12</segment>
    <segment id="126">Homens e uma Sentença"</segment>
    <segment id="127">, "Jade" e "</segment>
    <segment id="128">Caçado" —este último de 2003</segment>
    <segment id="129">, com Tomie Lee Jones e Benicio Del Toro</segment>
    <segment id="130">, considerado seu último trabalho mais sólido.</segment>
    <segment id="131">Seu último filme de ficção foi "Killer Joe: Matador de Aluguel"</segment>
    <segment id="132">, com Matthew McConaughey no papel título</segment>
    <segment id="133">comocomo um policial que faz "bicos</segment>
    <segment id="134">" sanguinários</segment>
    <segment id="135">, e dividiu a crítica entre alguns que consideraram o trabalho</segment>
    <segment id="136">comocomo uma volta à forma do diretor</segment>
    <segment id="137">, enquanto outros torceram o nariz pela representação de valores conservadores do Sul dos EUA.</segment>
    <segment id="138">Mas seu último trabalho lançado comercialmente foi "</segment>
    <segment id="139">O Diabo e o Padre Amorth"</segment>
    <segment id="140">, documentário que retomou os temas de "</segment>
    <segment id="141">O Exorcista" com a história de um padre de idade avançada</segment>
    <segment id="142">, que se</segment>
    <segment id="143">se prepara para expulsar o demônio do corpo de uma pessoa pela nona vez.</segment>
    <segment id="144">Entre as honrarias</segment>
    <segment id="145">, estão ainda indicações ao Emmy e ao Bafta e duas vitórias no Globo de Ouro</segment>
    <segment id="146">, além de um Leão de Ouro honorário</segment>
    <segment id="147">, em Veneza</segment>
    <segment id="148">, e um prêmio por "Killer Joe"</segment>
    <segment id="149">, no mesmo festival.</segment>
    <segment id="150">Em Cannes</segment>
    <segment id="151">, levou o troféu da crítica na seção paralela Quinzena dos Realizadores</segment>
    <segment id="152">, por "Possuídos".</segment>
  </rst>
</analysis>