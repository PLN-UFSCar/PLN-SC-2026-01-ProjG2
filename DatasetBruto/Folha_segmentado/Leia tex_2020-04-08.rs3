    <segment id="446">, no qual um príncipe</segment>
    <segment id="447">, crendo-</segment>
    <segment id="448">sese intrépido e sagaz</segment>
    <segment id="449">, nutre a ilusão de ignorar uma epidemia devastadora ao</segment>
    <segment id="450">sese refugiar em sua abadia.</segment>
