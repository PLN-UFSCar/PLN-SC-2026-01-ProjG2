    <segment id="405">, medida para salvar vidas na atual pandemia.</segment>
    <segment id="406">Leia aqui</segment>
    <segment id="407">Coronavírus evidencia que cartilha de Bolsonaro é delírio de loucos</segment>
    <segment id="408">Por Fernando Limongi  4.abr.2020  [RESUMO]</segment>
    <segment id="409">Diante da urgência do cenário que</segment>
    <segment id="410">sese desenha com a eclosão do coronavírus</segment>
    <segment id="411">, cientista político considera que a cartilha neoliberal primitiva de Bolsonaro e Guedes</segment>
    <segment id="412">, que vê na redução do Estado o remédio para todos os males do país</segment>
    <segment id="413">, deve ser ignorada</segment>
