  <rst>
    <segment id="1">A pandemia do novo coronavírus está mudando a vida de governos</segment>
    <segment id="2">, populações e indivíduos.</segment>
    <segment id="3">Um novo mundo parece</segment>
    <segment id="4">sese desenhar</segment>
    <segment id="5">, de contornos ainda pouco nítidos.</segment>
    <segment id="6">Fiel a seu espírito de promover debates densos acerca dos temas que mobilizam a sociedade</segment>
    <segment id="7">, a Ilustríssima vem publicando</segment>
    <segment id="8">, desde janeiro</segment>
    <segment id="9">, reflexões sobre esse cenário conturbado</segment>
    <segment id="10">, abordando diversos pontos de vista</segment>
    <segment id="11">, da política à medicina</segment>
    <segment id="12">, passando pela economia e filosofia.</segment>
    <segment id="13">O sociólogo italiano Domenico De Masi</segment>
    <segment id="14">, o economista Persio Arida</segment>
    <segment id="15">, o neurocientista Sidarta Ribeiro</segment>
    <segment id="16">, o ensaísta José Miguel Wisnik</segment>
    <segment id="17">, o professor de filosofia Marcos Nobre e o ex-presidente Fernando Henrique Cardoso são alguns dos autores que</segment>
    <segment id="18">sese debruçaram sobre os variados e profundos impactos da pandemia no mundo.  Confira a relação completa de textos.   *  Distantes há sete meses</segment>
    <segment id="19">, professores e alunos tentam preservar afeto nas aulas virtuais  15.out.2020  PorKátia Chiaradia  [resumo]</segment>
    <segment id="20">Pesquisadora reúne depoimentos de professores e alunos</segment>
    <segment id="21">, da educação infantil à universitária</segment>
    <segment id="22">, a respeito do modelo de aula online iniciado há sete meses</segment>
    <segment id="23">, em decorrência da pandemia do novo coronavírus.</segment>
    <segment id="24">Em meio a severas desigualdades de renda e escolaridade entre famílias</segment>
    <segment id="25">, dificuldades de acesso à internet e impasses na aprendizagem virtual</segment>
    <segment id="26">, todos tentam preservar um mínimo de afetividade na interação por meio de computadores e celulares.</segment>
    <segment id="27">Leia aqui   *  Covid-19 veio para ficar</segment>
    <segment id="28">, e precisamos nos preparar para conviver com o vírus  11.set.2020  PorEsper Kallás</segment>
    <segment id="29">​  [resumo]</segment>
    <segment id="30">Em reflexão sobre o que nos espera após a onda inicial de pandemia</segment>
    <segment id="31">, infectologista avalia que o vírus Sars-CoV-2</segment>
    <segment id="32">, causador da Covid-19</segment>
    <segment id="33">, irá circular por um longo tempo</segment>
    <segment id="34">, uma vez que outros tipos de coronavírus saltaram de animais para humanos há mais de cem anos e ainda estão entre nós.</segment>
    <segment id="35">Diante das dúvidas a respeito de vacinas a curto prazo e da imunização em larga escala</segment>
    <segment id="36">, e na ausência de remédios comprovadamente eficazes</segment>
    <segment id="37">, será necessário concentrar esforços no entendimento da doença e no encontro de outros métodos de tratamento.</segment>
    <segment id="38">Leia aqui   *</segment>
    <segment id="39">Formato on-line traz chance de festivais de cinema serem mais ousados e independentes  29.ago.2020</segment>
    <segment id="40">Por Sérgio Alpendre  [resumo] Adotado na pandemia</segment>
    <segment id="41">, formato on-line para festivais de cinema pode</segment>
    <segment id="42">sese fixar</segment>
    <segment id="43">comocomo novo padrão capaz de mitigar vícios desses eventos</segment>
    <segment id="44">, propiciando mais acesso ao público</segment>
    <segment id="45">, visibilidade aos artistas e ousadia e independência aos curadores.</segment>
    <segment id="46">Leia aqui     Jorge Ben Jor lidera revolta contra totalitarismo em conto distópico  18.jul.2020</segment>
    <segment id="47">Por Dodô Azevedo  [RESUMO]</segment>
    <segment id="48">Em 2032</segment>
    <segment id="49">, na noite em que faria 90 anos</segment>
    <segment id="50">, Jorge Ben Jor</segment>
    <segment id="51">, único morador do Copacabana Palace</segment>
    <segment id="52">, isolado pelo governo</segment>
    <segment id="53">, inicia operação para libertar o país.</segment>
    <segment id="54">No conto " Adúmáadán"</segment>
    <segment id="55">, autor imagina um Brasil distópico castigado pelo totalitarismo e pela pandemia</segment>
    <segment id="56">, que dizimou pobres e negros.</segment>
    <segment id="57">Leia aqui  Ilustração de Adams Carvalho para conto de Dodô Azevedo sobre Jorge Ben Jor e o Copacabana Palace - Adams Carvalho *  Bolsonaro envergonha um país</segment>
    <segment id="58">comocomo Berlusconi</segment>
    <segment id="59">, diz historiador italiano  4.jul.2020  Por Naief Haddad  [RESUMO]</segment>
    <segment id="60">Em entrevista</segment>
    <segment id="61">, o historiador italiano Carlo Ginzburg comenta célebre ensaio</segment>
    <segment id="62">, que será publicado nesta segunda (6) na revista Serrote</segment>
    <segment id="63">, no qual afirma que a vergonha tornou-</segment>
    <segment id="64">sese um vínculo social e político mais forte que o amor nas relações entre cidadãos e países</segment>
    <segment id="65">, sensação agravada sob governos</segment>
    <segment id="66">comocomo os de Berlusconi e Bolsonaro ou a crise global decorrente da pandemia.</segment>
    <segment id="67">Leia aqui   *</segment>
    <segment id="68">Em diálogo ficcional</segment>
    <segment id="69">, Sidarta Ribeiro discute atual sinuca de bico de militares  27.jun.2020  PorSidarta Ribeiro  [resumo]</segment>
    <segment id="70">Em conversa ficcional entre dois amigos —cujos nomes ecoam personagens do livro "</segment>
    <segment id="71">Diálogo sobre os Dois Principais Sistemas do Mundo" (1632)</segment>
    <segment id="72">, de Galileu Galilei—</segment>
    <segment id="73">, autor reflete sobre temas da conjuntura política</segment>
    <segment id="74">, sanitária e econômica do Brasil</segment>
    <segment id="75">, como</segment>
    <segment id="76">como a relação das Forças Armadas com o governo Bolsonaro e a negligência do Executivo nas decisões para combater a pandemia de Covid-19.</segment>
    <segment id="77">Leia aqui</segment>
    <segment id="78">Apocalipse causado por coronavírus pode tornar o trabalho mais criativo e afetuoso  26.jun.2020  PorDomenico</segment>
    <segment id="79">De Masi  [RESUMO] Imposto a milhões de pessoas em todo o mundo em decorrência da pandemia</segment>
    <segment id="80">, modelo de home office pode significar o início de uma reorganização do trabalho e</segment>
    <segment id="81">, de forma mais ampla</segment>
    <segment id="82">, de nosso modelo sociopolítico</segment>
    <segment id="83">, garantindo mais autonomia e criatividade para trabalhadores</segment>
    <segment id="84">, mais produtividade para as empresas e um desenvolvimento mais igualitário da coletividade.</segment>
    <segment id="85">Leia aqui</segment>
    <segment id="86">De panelaços a sexo na janela</segment>
    <segment id="87">, escritor conta o que viu de seus vizinhos na quarentena  25.jun.2020</segment>
    <segment id="88">Por Ronaldo Bressane  [RESUMO]Morador do bairro República (centro de São Paulo)</segment>
    <segment id="89">, o escritor narra a atribulada nova rotina (com voos de urubus e drones</segment>
    <segment id="90">, panelaços</segment>
    <segment id="91">, obras ensurdecedoras e sexo às claras) de seus vizinhos dos prédios Louvre</segment>
    <segment id="92">, Copan e São Luiz em tempos de isolamento social</segment>
    <segment id="93">, quando janelas</segment>
    <segment id="94">, reais ou virtuais</segment>
    <segment id="95">, são das poucas formas de contato com o mundo.</segment>
    <segment id="96">Leia aqui     Três propostas para evitar uma tragédia irreversível na Amazônia  23.jun.2020</segment>
    <segment id="97">Por Ilona Szabó de Carvalho</segment>
    <segment id="98">, Brenda Brito e Daniel Azeredo  [RESUMO] Crises sanitária</segment>
    <segment id="99">, decorrente da pandemia</segment>
    <segment id="100">, e ambiental</segment>
    <segment id="101">, com o crescente desmatamento</segment>
    <segment id="102">, que atacam a Amazônia neste momento refletem erros do modelo político-econômico que predomina na região há décadas.</segment>
    <segment id="103">A exploração predatória e o enfraquecimento da fiscalização podem ser revertidos com propostas de fácil implantação que não dependem do governo federal</segment>
    <segment id="104">, como</segment>
    <segment id="105">como maior transparência e difusão de dados ambientais e leis mais rigorosas.</segment>
    <segment id="106">Leia aqui     Necropolítica de Bolsonaro aponta para um futuro distópico  18.jun.2020</segment>
    <segment id="107">Por Rodrigo Nunes  [RESUMO]</segment>
    <segment id="108">Autor reflete sobre o conceito de necropolítica</segment>
    <segment id="109">, que faz referência ao poder do Estado decidir quem pode viver ou deve morrer</segment>
    <segment id="110">, na conjuntura atual.</segment>
    <segment id="111">Em sua avaliação</segment>
    <segment id="112">, vidas de negros e pobres</segment>
    <segment id="113">sese tornam mais descartáveis no Brasil e nos EUA à medida que avançam a Covid-19</segment>
    <segment id="114">, a pandemia e medidas neoliberais equivocadas.</segment>
    <segment id="115">Leia aqui     Celebrar conquistas ecológicas e sociais da pandemia é delírio</segment>
    <segment id="116">, diz sociólogo  10.jun.2020  José Guilherme Pereira Leite  [RESUMO]</segment>
    <segment id="117">À semelhança de ficções distópicas</segment>
    <segment id="118">, pandemia aprofundou artificialização do cotidiano</segment>
    <segment id="119">, isolamento de pobres em moradias precárias e sentimento de angústia sobre o futuro.</segment>
    <segment id="120">Previsões sobre o mundo pós-coronavírus são terreno fértil para a ficção</segment>
    <segment id="121">, não para a reflexão acadêmica</segment>
    <segment id="122">, diz autor.</segment>
    <segment id="123">Leia aqui</segment>
    <segment id="124">Com manifestações na pandemia</segment>
    <segment id="125">, esquerda faz o que criticava  8.jun.2020  Marcos Augusto Gonçalves  [RESUMO]</segment>
    <segment id="126">Nas manifestações deste domingo (7)</segment>
    <segment id="127">, lideranças de esquerda aderiram animadas à promoção irresponsável de aglomerações durante a pandemia</segment>
    <segment id="128">, atitude recorrente de Jair Bolsonaro nos últimos meses que tanto condenavam.</segment>
    <segment id="129">Leia aqui</segment>
    <segment id="130">De Fernanda Montenegro a Sonia Guajajara</segment>
    <segment id="131">, 19 artistas e ativistas contam quarentenas  7.jun.2020  Por Claudio Leal  [RESUMO]</segment>
    <segment id="132">Em 19 breves relatos</segment>
    <segment id="133">, brasileiros de diversas idades e regiões contam suas rotinas em tempos de confinamento.</segment>
    <segment id="134">De Fernanda Montenegro à líder indígena Sonia Guajajara</segment>
    <segment id="135">, passando por cineastas</segment>
    <segment id="136">, escritores</segment>
    <segment id="137">, músicos</segment>
    <segment id="138">, fotógrafos</segment>
    <segment id="139">, ativistas</segment>
    <segment id="140">, educadores e médicos</segment>
    <segment id="141">, todos buscam na criação e no estudo uma maneira de não sucumbir ao cenário desolador da pandemia.</segment>
    <segment id="142">Leia aqui  Vidas em quarentena: artistas e ativistas relatam isolamento   novamente         de   de  de  representando</segment>
    <segment id="143">um     Governo tem que aumentar ajuda para economia</segment>
    <segment id="144">sese recuperar mais rapidamente  5.jun.2020</segment>
    <segment id="145">Por Persio Arida  [RESUMO]</segment>
    <segment id="146">Programa oficial de suporte à economia tem muitas falhas</segment>
    <segment id="147">; ajustes na rede assistencial e mais gastos a fundo perdido para empresas devem ser acompanhados por juros mais baixos em curto e longo prazos.</segment>
    <segment id="148">Leia aqui</segment>
    <segment id="149">Emissão de moeda para combater Covid-19 não aumentará dívida pública  2.jun.2020</segment>
    <segment id="150">Por Luiz Carlos Bresser-Pereira  [RESUMO]</segment>
    <segment id="151">Economista argumenta que o financiamento monetário (compra direta de títulos do Tesouro pelo Banco Central) é essencial para financiar gastos do Estado durante a crise do coronavírus e que a medida não causará aumento da inflação e da dívida pública.</segment>
    <segment id="152">Leia aqui</segment>
    <segment id="153">Ótima biografia mostra atualidade de Keynes na crise do coronavírus  30.mai.2020</segment>
    <segment id="154">Por Jennifer Szalai  [RESUMO]</segment>
    <segment id="155">Biografia recém-lançada nos EUA apresenta a trajetória do pensamento econômico de John Maynard Keynes e mostra</segment>
    <segment id="156">comocomo suas propostas foram ignoradas por governantes antes da Grande Depressão —e</segment>
    <segment id="157">comocomo</segment>
    <segment id="158">, nas décadas seguintes</segment>
    <segment id="159">, o keynesianismo</segment>
    <segment id="160">sese tornou a nova ortodoxia nos EUA e foi adotado em diversos países.</segment>
    <segment id="161">Leia aqui</segment>
    <segment id="162">Governos respondem a surtos de Covid-19 em favelas com punho de ferro ou negligência  27.mai.2020  PorRobert Muggah  [RESUMO]</segment>
    <segment id="163">Autor aponta que</segment>
    <segment id="164">, no cenário de rápida disseminação do novo coronavírus em bairros pobres dos países em desenvolvimento</segment>
    <segment id="165">, governos insistem em ações inadequadas</segment>
    <segment id="166">, como</segment>
    <segment id="167">como confinamento radical sem investimentos em sistemas de saúde e garantia de renda dessas populações.</segment>
    <segment id="168">Leia aqui     Amazônia vive pandemia de destruição com Covid-19 e ofensiva de Bolsonaro  20.mai.2020</segment>
    <segment id="169">Por Marcos Colón</segment>
    <segment id="170">, Luís de Camões Lima Boaventura e Erik Jennings  [RESUMO]</segment>
    <segment id="171">Autores argumentam que a aceleração do desmatamento e da degradação ambiental da Amazônia —potencializados por sucessivos golpes do governo Bolsonaro na política de proteção ao meio ambiente— tem relação direta com as condições precárias de saúde pública da região</segment>
    <segment id="172">, que amplificam a letalidade de doenças</segment>
    <segment id="173">comocomo a Covid-19.</segment>
    <segment id="174">Leia aqui</segment>
    <segment id="175">Crise exige superar equívocos sobre emissão de moeda e dívida pública</segment>
    <segment id="176">, diz André Lara  16.mai.2020</segment>
    <segment id="177">Por André Lara Resende  [RESUMO]</segment>
    <segment id="178">Em meio a uma crise que ameaça</segment>
    <segment id="179">sese transformar em catástrofe econômica e social</segment>
    <segment id="180">, é preciso compreender que especialmente nessa hora o Estado pode</segment>
    <segment id="181">, e deve</segment>
    <segment id="182">, investir de forma produtiva</segment>
    <segment id="183">, o que não implica em setor público inchado</segment>
    <segment id="184">, refém de clientelistas.</segment>
    <segment id="185">Para agir de maneira eficaz é urgente superar falsas premissas sobre políticas monetária e fiscal e rever a proibição de o Banco Central emitir moeda para financiar o Tesouro.  Leia aqui​     Brasil está capotando com Bolsonaro e coronavírus  15.mai.2020</segment>
    <segment id="186">Por Sidarta Ribeiro  [RESUMO]</segment>
    <segment id="187">Neurocientista usa metáfora de um carro que capota para refletir sobre o Brasil atual</segment>
    <segment id="188">, que vê Bolsonaro e seu entorno dobrarem a aposta no negacionismo e na desinformação em meio à pandemia.</segment>
    <segment id="189">Quando o capotamento parar</segment>
    <segment id="190">, será preciso resgatar o que a alma brasileira tem de mais amoroso</segment>
    <segment id="191">, solidário e criativo</segment>
    <segment id="192">, diz.</segment>
    <segment id="193">Leia aqui     Veja proposta para decidir acesso de pacientes a UTI durante a pandemia  11.mai.2020</segment>
    <segment id="194">Por Alcino Eduardo Bonella</segment>
    <segment id="195">, Darlei Dall’Agnol</segment>
    <segment id="196">, Marco Antônio Azevedo e Marcelo de Araujo  [RESUMO] Autores defendem a instituição de diretrizes especiais de destinação de leitos de UTI a pacientes durante a pandemia do novo coronavírus e propõe critérios de priorização com base no princípio de tentar salvar o maior número possível de vidas humanas.</segment>
    <segment id="197">Leia aqui</segment>
    <segment id="198">Coronavírus condena práticas insustentáveis do mundo da arte</segment>
    <segment id="199">, diz galerista  10.mai.2020</segment>
    <segment id="200">Por Márcia Fortes   [RESUMO]</segment>
    <segment id="201">Galerista reflete sobre os efeitos da pandemia no mercado de arte</segment>
    <segment id="202">, que se</segment>
    <segment id="203">se vê obrigado a reavaliar modelo predatório de negócio</segment>
    <segment id="204">, marcado</segment>
    <segment id="205">, entre outros aspectos</segment>
    <segment id="206">, pela multiplicação de feiras internacionais e pela sobrevalorização de artistas.</segment>
    <segment id="207">Leia aqui</segment>
    <segment id="208">Apesar da crise da Covid-19</segment>
    <segment id="209">, América Latina pode conter aumento da desigualdade  8.mai.2020  Por Mauricio De Rosa</segment>
    <segment id="210">, Ignacio Flores e Marc Morgan  [RESUMO] Para pesquisadores do World Inequality Lab</segment>
    <segment id="211">, a intensa crise econômica que</segment>
    <segment id="212">sese anuncia na região devido à pandemia de coronavírus ameaça romper a trajetória de redução da desigualdade dos países latino-americanos.</segment>
    <segment id="213">É urgente que governos implementem políticas para frear a queda de renda dos mais pobres</segment>
    <segment id="214">, argumentam.</segment>
    <segment id="215">Leia aqui</segment>
    <segment id="216">Realidade ficou monstruosa</segment>
    <segment id="217">, diz poeta que temeu contrair coronavírus  6.mai.2020</segment>
    <segment id="218">Por Felipe Fortuna  [RESUMO] Poeta e diplomata em serviço na embaixada brasileira na Coreia do Sul</segment>
    <segment id="219">, Felipe Fortuna teve contato em seu hotel com atores e dançarinos do musical "</segment>
    <segment id="220">O Fantasma da Ópera" infectados pelo coronavírus.</segment>
    <segment id="221">Nos dias seguintes</segment>
    <segment id="222">, enquanto aguardava o resultado de seu exame para saber</segment>
    <segment id="223">sese também contraíra o vírus</segment>
    <segment id="224">, o poeta viveu momentos de tensão</segment>
    <segment id="225">, tomado pela culpa e por dúvidas acerca do que havia tocado ou</segment>
    <segment id="226">sese esfregara os olhos sem ter lavado as mãos.</segment>
    <segment id="227">Leia aqui     Não permitam choque séptico no corpo coletivo da classe artística</segment>
    <segment id="228">, conclama Oficina  5.mai.2020</segment>
    <segment id="229">Por Cafira ZoéAssociação e Teat(r)o Oficina Uzyna Uzona / Núcleo de Estudos da Subjetividade  [RESUMO]</segment>
    <segment id="230">Em carta</segment>
    <segment id="231">, coletivo do Teatro Oficina sustenta que artes cênicas e seus trabalhadores agonizam com a falta completa de horizonte em meio à pandemia de coronavírus e defende a criação de um fundo emergencial com o objetivo de evitar o colapso do teatro no país.</segment>
    <segment id="232">Leia aqui</segment>
    <segment id="233">​  Brasil enfrenta duplo apocalipse com Bolsonaro e coronavírus  3.mai.2020</segment>
    <segment id="234">Por Nuno Ramos  [RESUMO]</segment>
    <segment id="235">Revisitando a festa de seus 60 anos no início de março</segment>
    <segment id="236">, em momento que já parece muito distante</segment>
    <segment id="237">, artista e escritor</segment>
    <segment id="238">, neste texto caleidoscópico</segment>
    <segment id="239">, reflete sobre o bolsonarismo e a sobreposição do tempo da política e da pandemia no Brasil.</segment>
    <segment id="240">Enfrentamos um duplo apocalipse ainda mais assustador por não sabermos</segment>
    <segment id="241">sese já</segment>
    <segment id="242">sese instaurou ou está por vir.</segment>
    <segment id="243">Leia aqui</segment>
    <segment id="244">Coronavírus não vai mudar a crença de que é possível vencer a morte</segment>
    <segment id="245">, diz Harari  2.mai.2020  Por Yuval Noah Harari  [RESUMO]</segment>
    <segment id="246">Historiador israelense argumenta que a pandemia</segment>
    <segment id="247">, embora</segment>
    <segment id="248">embora nos faça confrontar a fragilidade de cada um</segment>
    <segment id="249">, provavelmente não mudará a atitude humana moderna que vê no fim da vida não mais uma decisão divina inevitável</segment>
    <segment id="250">, masmas sim um problema técnico que pode ser solucionado pela ciência.</segment>
    <segment id="251">Leia aqui</segment>
    <segment id="252">Estabilizar dívida a longo prazo importa mais que conter seu aumento na pandemia  2.mai.2020</segment>
    <segment id="253">Por Persio Arida  [RESUMO]</segment>
    <segment id="254">Uma vez que a dívida pública pode chegar a 100% do PIB neste ano</segment>
    <segment id="255">, economista diz que o drama não é o patamar alto</segment>
    <segment id="256">, masmas a percepção de que ela poderia estar em rumo explosivo</segment>
    <segment id="257">, sendo fundamental estabilizar tal relação.</segment>
    <segment id="258">Leia aqui</segment>
    <segment id="259">Coronavírus vai marcar o fim de uma era no cinema  1º.mai.2020  Por Ana Paula Sousa  [RESUMO] Eclosão da Covid-19 impõe série de mudanças na indústria do cinema</segment>
    <segment id="260">, do fechamento das salas de exibição e adiamento de filmagens à mudança na regra do Oscar</segment>
    <segment id="261">, o que</segment>
    <segment id="262">, em longo prazo</segment>
    <segment id="263">, deve</segment>
    <segment id="264">sese refletir na reorganização de forças entre os players do setor e na redefinição das formas de consumir o audiovisual</segment>
    <segment id="265">, com o fortalecimento dos serviços de streaming.</segment>
    <segment id="266">Leia aqui     Trump</segment>
    <segment id="267">sese comporta</segment>
    <segment id="268">comocomo filósofo da morte durante a pandemia</segment>
    <segment id="269">, diz escritor chileno  28.abr.2020</segment>
    <segment id="270">PorAriel Dorfman  [RESUMO] Crítico contumaz do obscurantismo que cerca o presidente americano</segment>
    <segment id="271">, autor</segment>
    <segment id="272">, que é professor nos EUA</segment>
    <segment id="273">, afirma ter</segment>
    <segment id="274">sese surpreendido ao</segment>
    <segment id="275">sese deparar com a estupidez das medidas de Trump contra o coronavírus.</segment>
    <segment id="276">Defesa do presidente de uso de hidroxicloroquina é a a última cena de farsa trágica</segment>
    <segment id="277">, diz.</segment>
    <segment id="278">Leia aqui     Lucro com propósito e pesquisa colaborativa devem sair fortalecidos da pandemia  27.abr.2020  [RESUMO]</segment>
    <segment id="279">Professor afirma que haverá uma revalorização do passado depois da pandemia de coronavírus —atividades sociais</segment>
    <segment id="280">sese enraizarão nos lugares</segment>
    <segment id="281">, mercado incentivará empresas sustentáveis e haverá domínio da área médica.</segment>
    <segment id="282">Riquezas brasileiras</segment>
    <segment id="283">, como</segment>
    <segment id="284">como a biodiversidade da Amazônia</segment>
    <segment id="285">, poderão contribuir em um mundo ameaçado por novas epidemias.</segment>
    <segment id="286">Leia aqui     Brasil tem que renovar agenda e ousar para ser grande  25.abr.2020</segment>
    <segment id="287">Por Roberto Mangabeira Unger  [RESUMO]</segment>
    <segment id="288">Professor em Harvard</segment>
    <segment id="289">, pensador brasileiro vê na crise atual a possibilidade de construir alternativa mais produtiva e igualitária à agenda que</segment>
    <segment id="290">, com variações de ênfase</segment>
    <segment id="291">, atravessou os governos pós-ditadura e condenou o Brasil à estagnação e à manutenção de padrões inaceitáveis de desigualdade.</segment>
    <segment id="292">Leia aqui</segment>
    <segment id="293">Coronavírus reforça urgência da união de forças democráticas contra Bolsonaro  24.abr.2020</segment>
    <segment id="294">Por André Singer</segment>
    <segment id="295">, Christian Dunker</segment>
    <segment id="296">, Cicero Araújo</segment>
    <segment id="297">, Laura Carvalho</segment>
    <segment id="298">, Felipe Loureiro</segment>
    <segment id="299">, Leda Paulani</segment>
    <segment id="300">, Ruy Braga e Vladimir Safatle  [RESUMO]</segment>
    <segment id="301">Em meio à escalada autoritária e negacionista patrocinada por Bolsonaro</segment>
    <segment id="302">, Covid-19 possibilita janela de oportunidades para setores democráticos ao mobilizar esforços de solidariedade e abrir espaço para a construção de um plano efetivo de transformação social</segment>
    <segment id="303">, o que pode</segment>
    <segment id="304">sese constituir no embrião de uma nova agenda de combate político.</segment>
    <segment id="305">Leia aqui     Adesão à aliança liberal-miliciana de Bolsonaro degringola</segment>
    <segment id="306">PorMarcos Augusto Gonçalves  24.abr.2020   [RESUMO]</segment>
    <segment id="307">Jornalista afirma que adesão de elites econômicas ao governo Bolsonaro</segment>
    <segment id="308">, capitaneada pela agenda do Estado mínimo e de combate à corrupção</segment>
    <segment id="309">, sese deteriora a cada surto presidencial.</segment>
    <segment id="310">Brasil está na retaguarda do planeta e continua buscando saídas no passado.</segment>
    <segment id="311">Leia aqui</segment>
    <segment id="312">Redução global da violência pode ganhar impulso depois da pandemia</segment>
    <segment id="313">Por Robert Muggah e Steven Pinker  23.abr.2020  [RESUMO] Autores discutem</segment>
    <segment id="314">comocomo a Covid-19 afeta os índices de violência no mundo</segment>
    <segment id="315">, que vêm sofrendo intensa redução nas últimas décadas.</segment>
    <segment id="316">Não há explicação única para o fenômeno</segment>
    <segment id="317">, masmas estudos demonstram que treinamento de polícias</segment>
    <segment id="318">, foco em grupos criminosos e áreas que concentram delitos e melhorias no ambiente urbano são políticas eficazes para combater criminalidade.</segment>
    <segment id="319">Leia aqui     Covid-19 mostra que medicina concentrada em grandes hospitais tem que ser superada</segment>
    <segment id="320">Por Marcos Colón e Erik Jennings</segment>
    <segment id="321">22.abr.2020  [RESUMO]</segment>
    <segment id="322">Autores argumentam que avanços tecnológicos na medicina foram acompanhados por perda progressiva de humanidade no atendimento de saúde.</segment>
    <segment id="323">O paradigma da culturalidade</segment>
    <segment id="324">, que defende práticas</segment>
    <segment id="325">comocomo descentralização de serviços médicos e preservação de saberes locais</segment>
    <segment id="326">, é uma revolução necessária em tempos de pandemia de coronavírus.</segment>
    <segment id="327">Leia aqui</segment>
    <segment id="328">Mundo ameaçado por coronavírus não</segment>
    <segment id="329">sese parece com filmes apocalípticos de Hollywood  Por Slavoj Zizek  21.abr.2020  [RESUMO]</segment>
    <segment id="330">Filósofo esloveno contrapõe a pandemia de coronavírus a roteiros cinematográficos que marcam nosso imaginário</segment>
    <segment id="331">, argumentando que desenrolar da crise atual não terá um desfecho catastrófico rápido.</segment>
    <segment id="332">Mundo desmorona sem fim à vista</segment>
    <segment id="333">, e é preciso contornar lógicas de mercado para reagir à pandemia</segment>
    <segment id="334">, afirma.</segment>
    <segment id="335">Leia aqui</segment>
    <segment id="336">Veja cenas do filme &amp;#039</segment>
    <segment id="337">;2012&amp;#039</segment>
    <segment id="338">;   novamente         de   de  de  representando um     Fortalecimento do Estado depois da pandemia não está garantido</segment>
    <segment id="339">Por Maria Paula Dallari Bucci  20.abr.2020  [RESUMO]</segment>
    <segment id="340">Professora da USP considera que pandemia de coronavírus produziu um consenso incomum em torno da importância de sistemas nacionais de saúde e da ampliação de investimento públicos.</segment>
    <segment id="341">Atual revalorização de políticas públicas</segment>
    <segment id="342">, no entanto</segment>
    <segment id="343">, pode ser interrompida com retorno de discursos contra o Estado.</segment>
    <segment id="344">Leia aqui</segment>
    <segment id="345">Com coronavírus</segment>
    <segment id="346">, destino bate na porta do planeta</segment>
    <segment id="347">Por Paulo Coelho  19.abr.2020  [RESUMO]</segment>
    <segment id="348">Escritor acredita que não voltaremos a ser os mesmos após a pandemia</segment>
    <segment id="349">, uma vez que objetivos efêmeros deram lugar à urgência de sobreviver.</segment>
    <segment id="350">Neste estado de incerteza e solidão</segment>
    <segment id="351">, resta-nos valorizar as relações pessoais e aceitar os mistérios da vida.</segment>
    <segment id="352">Leia aqui     Impeachment de Bolsonaro depende de acordo entre direita e esquerda</segment>
    <segment id="353">Por Marcos Nobre  16.abr.2020  [RESUMO] Para pesquisador</segment>
    <segment id="354">, conversas para transformar o panelaço diário do "</segment>
    <segment id="355">Fora Bolsonaro</segment>
    <segment id="356">"</segment>
    <segment id="357">em "</segment>
    <segment id="358">Impeachment</segment>
    <segment id="359">Já" devem começar</segment>
    <segment id="360">, masmas uma eventual cassação só terá efeitos benéficos para a democracia</segment>
    <segment id="361">sese for acompanhada de um amplo acordo</segment>
    <segment id="362">, sem caráter eleitoral</segment>
    <segment id="363">, entre direita e esquerda.</segment>
    <segment id="364">Leia aqui     Distribuição de UTIs a pacientes de Covid-19 por algoritmo não elimina dilema ético</segment>
    <segment id="365">Por Marcela Mattiuzzo  13.abr.2020  [RESUMO]</segment>
    <segment id="366">Uso de inteligência artificial para decidir quais doentes ocuparão leitos em UTIs é valioso para eliminar subjetividades e padronizar decisões de profissionais de saúde</segment>
    <segment id="367">, masmas depende de critérios técnicos transparentes.</segment>
    <segment id="368">Algoritmos</segment>
    <segment id="369">podem não ser adequados em situações de juízo moral e</segment>
    <segment id="370">, indiretamente</segment>
    <segment id="371">, beneficiar grupos socioeconômicos favorecidos.</segment>
    <segment id="372">Leia aqui     Coronavírus vai tornar ainda mais difícil ser escritor no Brasil  Por Joca Reiners Terron  12.abr.2020  [RESUMO]</segment>
    <segment id="373">Romancista reflete sobre o impacto econômico da pandemia no já combalido mercado editorial</segment>
    <segment id="374">, o que ameaça avanços recentes</segment>
    <segment id="375">, como</segment>
    <segment id="376">como a proliferação de escritores que tiram seu sustento de sua obra ou de serviços ligados à cadeia do livro.</segment>
    <segment id="377">Leia aqui</segment>
    <segment id="378">Com coronavírus</segment>
    <segment id="379">, mundo vive em nevoeiro</segment>
    <segment id="380">Por Guilherme Wisnik  11.abr.2020  [RESUMO]</segment>
    <segment id="381">Ao contrário do que imaginavam os profetas do fim da história</segment>
    <segment id="382">, o mundo é dominado por sentimentos de paranoia e angústia.</segment>
    <segment id="383">Imersos em nevoeiro</segment>
    <segment id="384">, na era em que esgotamos os recursos do planeta</segment>
    <segment id="385">, fabricamos a pandemia de nossa própria vulnerabilidade</segment>
    <segment id="386">, sem poder culpar um ‘outro’.</segment>
    <segment id="387">Leia aqui     Crise do coronavírus na cultura exige medidas urgentes</segment>
    <segment id="388">Por Sérgio Sá</segment>
    <segment id="389">Leitão  9.abr.2020  [RESUMO] Medidas de apoio ao setor cultural do país são urgentes para enfrentar os efeitos econômicos devastadores da paralisação das atividades artísticas.</segment>
    <segment id="390">Secretário estadual de Cultura de São Paulo alerta que</segment>
    <segment id="391">, sem programas imediatos de crédito e fomento ao setor</segment>
    <segment id="392">, pode não haver o que recuperar depois da pandemia.</segment>
    <segment id="393">Leia aqui.</segment>
