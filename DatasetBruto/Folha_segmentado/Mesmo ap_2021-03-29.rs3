  <rst>
    <segment id="1">A reabertura do Canal de Suez ao tr&amp;aacute</segment>
    <segment id="2">;fego de navios ap&amp;oacute</segment>
    <segment id="3">;s seis dias de paralisa&amp;ccedil</segment>
    <segment id="4">;&amp;atilde</segment>
    <segment id="5">;o deve provocar um efeito domin&amp;oacute</segment>
    <segment id="6">;</segment>
    <segment id="7">com impactos nas cadeias globais de suprimento e efeitos na produ&amp;ccedil</segment>
    <segment id="8">;&amp;atilde</segment>
    <segment id="9">;o da ind&amp;uacute</segment>
    <segment id="10">;stria global</segment>
    <segment id="11">, segundo especialistas no setor.</segment>
    <segment id="12">O navio Ever Given foi desencalhado nesta segunda-feira (29)</segment>
    <segment id="13">, reabrindo uma das principais rotas do com&amp;eacute</segment>
    <segment id="14">;rcio internacional</segment>
    <segment id="15">, masmas ainda assim a expectativa &amp;eacute</segment>
    <segment id="16">; que os fluxos de cargas levem algum tempo para retornar &amp;agrave</segment>
    <segment id="17">; normalidade.</segment>
    <segment id="18">O encalhe ocorreu na &amp;uacute</segment>
    <segment id="19">;ltima ter&amp;ccedil</segment>
    <segment id="20">;a (23).</segment>
    <segment id="21">Com 400 metros de comprimento</segment>
    <segment id="22">, a embarca&amp;ccedil</segment>
    <segment id="23">;&amp;atilde</segment>
    <segment id="24">;o ficou presa na diagonal em um dos pontos do canal que n&amp;atilde</segment>
    <segment id="25">;o t&amp;ecirc</segment>
    <segment id="26">;m via auxiliar</segment>
    <segment id="27">, interrompendo a rota que liga a &amp;Aacute</segment>
    <segment id="28">;sia e a Europa e provocando uma enorme fila de navios nas duas pontas do canal.</segment>
    <segment id="29">Navio Ever Given volta a navegar no Canal de Suez</segment>
    <segment id="30">, no Egito - Wang Dongzhen/Xinhua&amp;quot</segment>
    <segment id="31">;Apesar de falarmos de regi&amp;atilde</segment>
    <segment id="32">;o geogr&amp;aacute</segment>
    <segment id="33">;fica longe do Brasil</segment>
    <segment id="34">, que n&amp;atilde</segment>
    <segment id="35">;o &amp;eacute</segment>
    <segment id="36">; parte de nossas principais rotas comerciais</segment>
    <segment id="37">, esperamos impactos indiretos para o pa&amp;iacute</segment>
    <segment id="38">;s&amp;quot</segment>
    <segment id="39">;, diz Lucas Leite Marques</segment>
    <segment id="40">, s&amp;oacute</segment>
    <segment id="41">;cio do escrit&amp;oacute</segment>
    <segment id="42">;rio especializado em direito mar&amp;iacute</segment>
    <segment id="43">;timo Kincaid Mendes Vianna Advogados.</segment>
    <segment id="44">&amp;quot;Pelo canal transitam mercadorias que s&amp;atilde</segment>
    <segment id="45">;o mat&amp;eacute</segment>
    <segment id="46">;rias-primas para insumos mais diversos</segment>
    <segment id="47">, combust&amp;iacute</segment>
    <segment id="48">;veis e outros derivados de petr&amp;oacute</segment>
    <segment id="49">;leo, ent&amp;atilde</segment>
    <segment id="50">;o uma hora o reflexo vai ser sentido por toda a cadeia econ&amp;ocirc</segment>
    <segment id="51">;mica&amp;quot</segment>
    <segment id="52">;, completa.</segment>
    <segment id="53">Al&amp;eacute</segment>
    <segment id="54">;m disso</segment>
    <segment id="55">, diz, a interrup&amp;ccedil</segment>
    <segment id="56">;&amp;atilde</segment>
    <segment id="57">;o do fluxo sobrecarregou portos europeus e asi&amp;aacute</segment>
    <segment id="58">;ticos que esperavam os navios que passam pela regi&amp;atilde</segment>
    <segment id="59">;o para escoar suas cargas</segment>
    <segment id="60">, com efeitos j&amp;aacute</segment>
    <segment id="61">;</segment>
    <segment id="62">sentidos em estradas de acesso e at&amp;eacute</segment>
    <segment id="63">; em ind&amp;uacute</segment>
    <segment id="64">;strias que dependem da rota.</segment>
    <segment id="65">&amp;quot;Al&amp;eacute</segment>
    <segment id="66">;m de atrasos em toda a cadeia log&amp;iacute</segment>
    <segment id="67">;stica</segment>
    <segment id="68">, como</segment>
    <segment id="69">como efeito domin&amp;oacute</segment>
    <segment id="70">; a gente v&amp;ecirc</segment>
    <segment id="71">; indisponibilidades de cont&amp;ecirc</segment>
    <segment id="72">;ineres no mercado</segment>
    <segment id="73">, o que j&amp;aacute</segment>
    <segment id="74">; foi visto durante a pandemia</segment>
    <segment id="75">, aumento de custos das mercadorias e varia&amp;ccedil</segment>
    <segment id="76">;&amp;otilde</segment>
    <segment id="77">;es nos pre&amp;ccedil</segment>
    <segment id="78">;os de frete mar&amp;iacute</segment>
    <segment id="79">;timo.&amp;quot</segment>
    <segment id="80">;</segment>
    <segment id="81">A interrup&amp;ccedil</segment>
    <segment id="82">;&amp;atilde</segment>
    <segment id="83">;o do canal de Suez ampliou os efeitos da pandemia no transporte mar&amp;iacute</segment>
    <segment id="84">;timo global</segment>
    <segment id="85">, num momento em que a crise dava sinais de melhora.</segment>
    <segment id="86">Desde o segundo semestre de 2020 o setor tenta resolver problemas gerados pela ruptura nos fluxos de com&amp;eacute</segment>
    <segment id="87">;rcio no in&amp;iacute</segment>
    <segment id="88">;cio da pandemia.</segment>
    <segment id="89">Com economias fechadas e rotas mar&amp;iacute</segment>
    <segment id="90">;timas suspensas no primeiro semestre</segment>
    <segment id="91">, cont&amp;ecirc</segment>
    <segment id="92">;ineres e navios ficaram espalhados pelo mundo.</segment>
    <segment id="93">O rearranjo foi prejudicado pelo crescimento do com&amp;eacute</segment>
    <segment id="94">;rcio de mercadorias e pela elevada demanda por produtos farmac&amp;ecirc</segment>
    <segment id="95">;uticos a partir do segundo semestre.</segment>
    <segment id="96">Navio de 400 metros de comprimento encalhou no Canal de Suez   novamente         de   de  de  representando um  Como efeito</segment>
    <segment id="97">, os fretes dispararam e os cont&amp;ecirc</segment>
    <segment id="98">;ineres desapareceram.</segment>
    <segment id="99">O custo do transporte entre a China e o porto de Santos chegou a bater US$ 9.000 em janeiro</segment>
    <segment id="100">, quase cinco vezes a m&amp;eacute</segment>
    <segment id="101">;dia dos &amp;uacute</segment>
    <segment id="102">;ltimos anos</segment>
    <segment id="103">, acrescentando um fator adicional de preocupa&amp;ccedil</segment>
    <segment id="104">;&amp;otilde</segment>
    <segment id="105">;es para a ind&amp;uacute</segment>
    <segment id="106">;stria brasileira.</segment>
    <segment id="107">O valor vinha caindo desde ent&amp;atilde</segment>
    <segment id="108">;o, mas</segment>
    <segment id="109">mas deu um repique ap&amp;oacute</segment>
    <segment id="110">;s o encalhe do Ever Given</segment>
    <segment id="111">, como</segment>
    <segment id="112">como reflexo dos efeitos do engarrafamento na disponibilidade de navios e cont&amp;ecirc</segment>
    <segment id="113">;ineres.</segment>
    <segment id="114">Na semana passada</segment>
    <segment id="115">, o frete entre Shangai e a Europa ficou 2</segment>
    <segment id="116">,1% mais caro</segment>
    <segment id="117">, na primeira alta desde o final de fevereiro.</segment>
    <segment id="118">O presidente da AEB (Associa&amp;ccedil</segment>
    <segment id="119">;&amp;atilde</segment>
    <segment id="120">;o de Com&amp;eacute</segment>
    <segment id="121">;rcio Exterior do Brasil)</segment>
    <segment id="122">, Jos&amp;eacute</segment>
    <segment id="123">; Augusto de Castro</segment>
    <segment id="124">, diz que ainda n&amp;atilde</segment>
    <segment id="125">;o ouviu relatos de impactos da crise sobre empresas brasileiras que dependem do com&amp;eacute</segment>
    <segment id="126">;rcio mar&amp;iacute</segment>
    <segment id="127">;timo de cargas.</segment>
    <segment id="128">Mas avalia que pode haver atrasos em entregas e preju&amp;iacute</segment>
    <segment id="129">;zos financeiros decorrentes da paralisa&amp;ccedil</segment>
    <segment id="130">;&amp;atilde</segment>
    <segment id="131">;o.  &amp;quot</segment>
    <segment id="132">;E, num primeiro momento</segment>
    <segment id="133">, eleva&amp;ccedil</segment>
    <segment id="134">;&amp;atilde</segment>
    <segment id="135">;o dos pre&amp;ccedil</segment>
    <segment id="136">;os do petr&amp;oacute</segment>
    <segment id="137">;leo e dos fretes&amp;quot</segment>
    <segment id="138">;, diz</segment>
    <segment id="139">, esperando que os impactos sejam pontuais.</segment>
    <segment id="140">&amp;quot;Quando o fluxo for regularizado</segment>
    <segment id="141">, reajusta-</segment>
    <segment id="142">sese novamente.</segment>
    <segment id="143">Para o Brasil [devem ocorrer] apenas atrasos nas estat&amp;iacute</segment>
    <segment id="144">;sticas.&amp;quot</segment>
    <segment id="145">;  Marques</segment>
    <segment id="146">, da Kincaid</segment>
    <segment id="147">, diz que o mercado segurador global ser&amp;aacute</segment>
    <segment id="148">; outro prejudicado</segment>
    <segment id="149">, j&amp;aacute</segment>
    <segment id="150">; que propriet&amp;aacute</segment>
    <segment id="151">;rios de cargas e seus clientes tendem a acionar seguros por lucros cessantes ou preju&amp;iacute</segment>
    <segment id="152">;zos &amp;agrave</segment>
    <segment id="153">;</segment>
    <segment id="154">produ&amp;ccedil</segment>
    <segment id="155">;&amp;atilde</segment>
    <segment id="156">;o provocados pelo atraso ou cancelamento das entregas.</segment>
    <segment id="157">As seguradoras</segment>
    <segment id="158">, por sua vez</segment>
    <segment id="159">, poder&amp;atilde</segment>
    <segment id="160">;o acionar os respons&amp;aacute</segment>
    <segment id="161">;veis pelo encalhe</segment>
    <segment id="162">, que ainda ser&amp;atilde</segment>
    <segment id="163">;o apontados por investiga&amp;ccedil</segment>
    <segment id="164">;&amp;otilde</segment>
    <segment id="165">;es da autoridade mar&amp;iacute</segment>
    <segment id="166">;tima local</segment>
    <segment id="167">, para cobrir o preju&amp;iacute</segment>
    <segment id="168">;zo.  &amp;quot</segment>
    <segment id="169">;Podemos esperar uma s&amp;eacute</segment>
    <segment id="170">;rie de lit&amp;iacute</segment>
    <segment id="171">;gios ao redor do mundo</segment>
    <segment id="172">, em jurisdi&amp;ccedil</segment>
    <segment id="173">;&amp;otilde</segment>
    <segment id="174">;es diversas</segment>
    <segment id="175">, que v&amp;atilde</segment>
    <segment id="176">;o desencadear num pleito enorme frente ao mercado de seguros e</segment>
    <segment id="177">, no fim</segment>
    <segment id="178">, os prejudicados e seguradores v&amp;atilde</segment>
    <segment id="179">;o buscar remediar seus preju&amp;iacute</segment>
    <segment id="180">;zos contra o causador do dano&amp;quot</segment>
    <segment id="181">;, diz.</segment>
  </rst>
