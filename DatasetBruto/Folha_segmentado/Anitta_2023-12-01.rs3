  <rst>
    <segment id="1">A cantora Anitta diz que parou de tentar</segment>
    <segment id="2">sese provar nos relacionamentos amorosos.</segment>
    <segment id="3">Em entrevista à revista Marie Claire</segment>
    <segment id="4">, a artista afirma que sua vida sexual mudou muito desde que abandonou a tese de que tinha que</segment>
    <segment id="5">sese mostrar autossuficiente nas relações.  "</segment>
    <segment id="6">Antes eu estava sempre em uma posição de ataque</segment>
    <segment id="7">, de querer me provar autossuficiente</segment>
    <segment id="8">, e não vejo nada de errado nisso"</segment>
    <segment id="9">, explicou na conversa.</segment>
    <segment id="10">"</segment>
    <segment id="11">Agora estou em um momento diferente</segment>
    <segment id="12">, de guardar a minha energia para alguém que possa me proporcionar algo melhor ainda.</segment>
    <segment id="13">"</segment>
    <segment id="14">A cantora Anitta - Cristina Quicler/AFPA artista</segment>
    <segment id="15">, que está solteira no momento</segment>
    <segment id="16">, também disse que deu um tempo nos relacionamentos —o último</segment>
    <segment id="17">, com o ator italiano Simone Susinna em agosto</segment>
    <segment id="18">, é descrito por ela</segment>
    <segment id="19">comocomo uma brincadeira.</segment>
    <segment id="20">"</segment>
    <segment id="21">Tem algum tempo que não me relaciono com alguém.</segment>
    <segment id="22">Tive por dois meses uma brincadeira de férias</segment>
    <segment id="23">, uma coisa meio midiática.</segment>
    <segment id="24">Quando estou levando algo a sério</segment>
    <segment id="25">, não abro para o público.</segment>
    <segment id="26">Acho que para dar certo</segment>
    <segment id="27">, tem que ser privado.</segment>
    <segment id="28">"  Imagens dos bastidores do clipe &amp;#039</segment>
    <segment id="29">;Funk Rave&amp;#039</segment>
    <segment id="30">;, de AnittaMais    novamente         de   de  de  representando um  Anitta ainda afirmou que agia por carência no passado</segment>
    <segment id="31">, quando buscava a posição de alguém que podia "pegar quem quiser".</segment>
    <segment id="32">"</segment>
    <segment id="33">Hoje prefiro me preservar e pensar: '</segment>
    <segment id="34">O que vou levar disso?</segment>
    <segment id="35">'</segment>
    <segment id="36">.</segment>
    <segment id="37">Não estou mais nessa de uma noite aleatória.</segment>
    <segment id="38">Não tenho feito mais isso.</segment>
    <segment id="39">"</segment>
  </rst>
