  <rst>
    <segment id="1">Um complexo de hotéis e de escritórios em Nairóbi</segment>
    <segment id="2">, capital do Quênia</segment>
    <segment id="3">, é alvo de uma explosão e de um ataque armado nesta terça-feira (15) assumido pelo grupo militante islamita somali Al-Shabaab.</segment>
    <segment id="4">Ao menos uma pessoa morreu e oito ficaram feridas.</segment>
    <segment id="5">"</segment>
    <segment id="6">Estamos por trás do ataque em Nairóbi.</segment>
    <segment id="7">A operação está em andamento"</segment>
    <segment id="8">, afirmou Abdiasis Abu Musab</segment>
    <segment id="9">, porta-voz das operações militares do grupo.</segment>
    <segment id="10">A polícia trata o incidente</segment>
    <segment id="11">comocomo um potencial ataque terrorista</segment>
    <segment id="12">, segundo o porta-voz Charles Owino disse à Citizen Television.</segment>
    <segment id="13">Uma explosão foi ouvida no escritório da AFP</segment>
    <segment id="14">, a mais de 5 km do local.</segment>
    <segment id="15">"</segment>
    <segment id="16">Houve uma bomba e há muitos tiros"</segment>
    <segment id="17">, afirmou um funcionário do Dusit Hotel.</segment>
    <segment id="18">"Estamos sendo atacados"</segment>
    <segment id="19">, afirmou uma pessoa por telefone de dentro de um dos escritórios.</segment>
    <segment id="20">Ataque no Quênia   novamente         de   de  de  representando um</segment>
    <segment id="21">Um homem saiu do local coberto de sangue</segment>
    <segment id="22">, enquanto estudantes eram retirados de uma universidade nas proximidades.</segment>
    <segment id="23">"</segment>
    <segment id="24">Comecei a ouvir tiros e então vi pessoas fugindo com as mãos para cima.</segment>
    <segment id="25">Alguns entraram no banco para</segment>
    <segment id="26">sese esconder e salvar suas vidas"</segment>
    <segment id="27">, afirmou uma mulher</segment>
    <segment id="28">, que disse ainda ter ouvido duas explosões.</segment>
    <segment id="29">Ataques de militantes islamitas somalis são comuns em Nairóbi</segment>
    <segment id="30">, como</segment>
    <segment id="31">como o contra um shopping center em 2013 que deixou dezenas de mortos e em uma universidade em 2015</segment>
    <segment id="32">, com quase 150 mortos.</segment>
  </rst>
