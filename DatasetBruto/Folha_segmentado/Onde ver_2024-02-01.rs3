  <rst>
    <segment id="1">No thriller "Sr. e Sra. Smith"</segment>
    <segment id="2">, de 2005</segment>
    <segment id="3">, Angelina Jolie e Brad Pitt faziam um casal em que um desconhecia a profissão do outro: ambos eram assassinos profissionais.</segment>
    <segment id="4">As coisas</segment>
    <segment id="5">sese complicam quando eles recebem a missão de eliminar o outro.</segment>
    <segment id="6">A premissa serve de base para a série de mesmo nome</segment>
    <segment id="7">, que alterou muitas coisas em relação ao filme.</segment>
    <segment id="8">Donald Glover e Maya Erskine em cena de &amp;quot</segment>
    <segment id="9">;Sr.</segment>
    <segment id="10">e Sra. Smith&amp;quot</segment>
    <segment id="11">;, da Amazon - Reprodução/Amazon StudiosAgora os Smiths vivem um casamento arranjado pela agência que os emprega.</segment>
    <segment id="12">Mas, aos poucos</segment>
    <segment id="13">, vão se</segment>
    <segment id="14">se apaixonando de verdade.</segment>
    <segment id="15">Com Donald Glover e Maya Erskine.</segment>
    <segment id="16">Entre os atores convidados está Wagner Moura.</segment>
    <segment id="17">Prime Video</segment>
    <segment id="18">, 16 anos   Orgulho e Compaixão</segment>
    <segment id="19">No século 19</segment>
    <segment id="20">, um jovem oficial da cavalaria da Dinamarca</segment>
    <segment id="21">sese encanta por um jovem que ficou paraplégica depois de um acidente.</segment>
    <segment id="22">Mas ele precisa entender</segment>
    <segment id="23">sese o que sente por ela é amor genuíno ou apenas compaixão.</segment>
    <segment id="24">Direção de Bille August.  Looke</segment>
    <segment id="25">, 12 anos</segment>
    <segment id="26">Homenagem a Luis Gustavo</segment>
    <segment id="27">No dia em que o ator completaria 90 anos de idade</segment>
    <segment id="28">, o canal exibe três de seus longas em sequência: "</segment>
    <segment id="29">Beto Rockfeller" (19h30</segment>
    <segment id="30">, 10 anos)</segment>
    <segment id="31">, "</segment>
    <segment id="32">Sai de Baixo –</segment>
    <segment id="33">O Filme" (21h</segment>
    <segment id="34">, 12 anos) e "</segment>
    <segment id="35">O Casamento de Romeu e Julieta" (22h25</segment>
    <segment id="36">, 10 anos).</segment>
    <segment id="37">Veja fotos da carreira do ator Luis GustavoMais    novamente         de   de  de  representando um  Canal Brasil</segment>
    <segment id="38">, a partir de 19h30</segment>
    <segment id="39">Mundo em Caos</segment>
    <segment id="40">Num futuro distópico onde não há mais mulheres e os homens conseguem ouvir os pensamentos uns dos outros</segment>
    <segment id="41">, uma jovem sobrevive à queda de sua astronave.</segment>
    <segment id="42">Um rapaz a encontra e decide protegê-la.</segment>
    <segment id="43">Ficção científica dirigida por Doug Liman</segment>
    <segment id="44">, com Daisy Ridley e Tom Holland.</segment>
    <segment id="45">Cena do filme &amp;#</segment>
    <segment id="46">039;Mundo em Caos&amp;#039</segment>
    <segment id="47">;Mais    novamente         de   de  de  representando um  Telecine Premium</segment>
    <segment id="48">, 22h, 14 anos</segment>
    <segment id="49">Diálogos com Mario Sergio Conti</segment>
    <segment id="50">Ivana Jinkings é dona da editora Boitempo</segment>
    <segment id="51">, que publica no Brasil obras de Angela Davis e Judith Butler.</segment>
    <segment id="52">Ela conversa com o jornalista e colunista da Folha sobre livros</segment>
    <segment id="53">, feminismo e o debate cultural brasileiro.  GloboNews</segment>
    <segment id="54">, 23h30</segment>
    <segment id="55">, livre   The Noite com Danilo Gentili</segment>
    <segment id="56">O jornalista Edney Silvestre compartilha histórias de sua carreira no programa do humorista</segment>
    <segment id="57">, como</segment>
    <segment id="58">como a cobertura dos ataques de 11 de Setembro</segment>
    <segment id="59">, e também fala de seus livros e da dislexia que o aflige.</segment>
    <segment id="60">Programa The Noite (2021)Mais    novamente         de   de  de  representando um  SBT</segment>
