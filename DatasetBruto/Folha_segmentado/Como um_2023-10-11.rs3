  <rst>
    <segment id="1">O açougueiro londrino abriu um sorrisão quando lhe pedi um pedaço de guanciale –papada suína curada com sal.</segment>
    <segment id="2">"</segment>
    <segment id="3">Coisa boa</segment>
    <segment id="4">, né?</segment>
    <segment id="5">", ele me disse enquanto embrulhava a parada.</segment>
    <segment id="6">Meio que para testar sua reação</segment>
    <segment id="7">, mandei: "</segment>
    <segment id="8">Vou fazer uma carbonara".</segment>
    <segment id="9">Aí o fulano desandou a falar.</segment>
    <segment id="10">"</segment>
    <segment id="11">Você não usa creme de leite</segment>
    <segment id="12">, certo?</segment>
    <segment id="13">"</segment>
    <segment id="14">Franzi o cenho e balancei a cabeça em sinal negativo.</segment>
    <segment id="15">Então o açougueiro apontou para um colega: "</segment>
    <segment id="16">Este cara põe creme de leite na carbonara!"</segment>
    <segment id="17">O contraventor sorriu envergonhado</segment>
    <segment id="18">, exibindo as gengivas quase todas desprovidas de dentes.</segment>
    <segment id="19">Rigatoni à carbonara</segment>
    <segment id="20">, em foto meramente ilustrativa - DivulgaçãoO macarrão à carbonara</segment>
    <segment id="21">, nas décadas mais recentes</segment>
    <segment id="22">, sese converteu numa bandeira da ortodoxia culinária italiana.</segment>
    <segment id="23">Não muito tempo atrás</segment>
    <segment id="24">, a galera punha creme</segment>
    <segment id="25">, presunto</segment>
    <segment id="26">, ervilha</segment>
    <segment id="27">, bechamel –e ninguém dava a menor pelota para tais transgressões.</segment>
    <segment id="28">Italianos</segment>
    <segment id="29">sese apegaram ao purismo para propagandear que só eles são capazes de executar bem as receitas de seu país.</segment>
    <segment id="30">Virou folclore</segment>
    <segment id="31">, já.</segment>
    <segment id="32">Não pode cortar espaguete no prato.</segment>
    <segment id="33">Não pode</segment>
    <segment id="34">, em hipótese alguma</segment>
    <segment id="35">, servir macarrão</segment>
    <segment id="36">comocomo acompanhamento de carne.</segment>
    <segment id="37">Não pode fazer espaguete com molho à bolonhesa.</segment>
    <segment id="38">Mas por que não?</segment>
    <segment id="39">A justificativa recai sempre nas tradições regionais da Itália.</segment>
    <segment id="40">A massa à carbonara</segment>
    <segment id="41">, a despeito de sua origem controversa (há pesquisador italiano dizendo que os americanos a criaram)</segment>
    <segment id="42">, incorpora perfeitamente o espírito desse fundamentalismo.</segment>
    <segment id="43">Aprenda a preparar espaguete à carbonaraMais    novamente         de   de  de  representando um  É muito tradicional em Roma e usa ingredientes regionais romanos –queijo pecorino (de ovelha) e o tal guanciale</segment>
    <segment id="44">, que só recentemente ficou conhecido fora da Itália central.</segment>
    <segment id="45">Soma-se</segment>
    <segment id="46">se a isso o fato de ser uma receita traiçoeira.</segment>
    <segment id="47">Qualquer vacilo</segment>
    <segment id="48">, e a mistura de ovos e queijos desanda</segment>
    <segment id="49">, vira ovo mexido.</segment>
    <segment id="50">Requer</segment>
    <segment id="51">, portanto</segment>
    <segment id="52">, alguma perícia do piloto de fogão –eis por que o ufanismo italiano foi encampado pelo esnobismo foodie no mundo todo.</segment>
    <segment id="53">Italianos adoram sacanear estrangeiros que conspurcam a receita única e imutável da pasta ala carbonara: ovos</segment>
    <segment id="54">, guanciale</segment>
    <segment id="55">, pimenta-do-reino</segment>
    <segment id="56">, pecorino e só.</segment>
    <segment id="57">Agora, vejamos o que um restaurante de Roma (capital intergaláctica da carbonara) faz com a comida sagrada: leva o macarrão à mesa numa coqueteleira</segment>
    <segment id="58">, então o garçom sacode a coisa</segment>
    <segment id="59">comocomo</segment>
    <segment id="60">sese estivesse a preparar um daiquiri.</segment>
    <segment id="61">Depois despeja o rigatoni (nem sempre é espaguete) no prato do cliente</segment>
    <segment id="62">, dramaticamente para ser filmado e ganhar engajamento nas redes sociais.</segment>
    <segment id="63">Como em qualquer caça-níqueis cafona do Itaim ou do Jardim Anália Franco.</segment>
    <segment id="64">O lugar</segment>
    <segment id="65">sese chama Aroma (a Roma</segment>
    <segment id="66">, sacou?)</segment>
    <segment id="67">, exibe ostensivamente sua estrela Michelin e fica no Palazzo Manfredi</segment>
    <segment id="68">, um hotel 5 estrelas com vista para o Coliseu.</segment>
    <segment id="69">O prato custa 45 euros (R$ 240).</segment>
    <segment id="70">Se a encenação grotesca da "carbonara shakerata" não cobre de vergonha a tradição romana</segment>
    <segment id="71">, não será um pouquinho de creme que o fará.</segment>
  </rst>
</analysis>