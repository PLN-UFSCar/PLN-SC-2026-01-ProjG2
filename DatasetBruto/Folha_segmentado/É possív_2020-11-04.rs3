  <rst>
    <segment id="1">&amp;</segment>
    <segment id="2">ldquo;Os cidad&amp;atilde</segment>
    <segment id="3">;os s&amp;atilde</segment>
    <segment id="4">;o racionais em sua vis&amp;atilde</segment>
    <segment id="5">;o das institui&amp;ccedil</segment>
    <segment id="6">;&amp;otilde</segment>
    <segment id="7">;es pol&amp;iacute</segment>
    <segment id="8">;ticas</segment>
    <segment id="9">, atualizando sua avalia&amp;ccedil</segment>
    <segment id="10">;&amp;atilde</segment>
    <segment id="11">;o em resposta ao que observam&amp;rdquo</segment>
    <segment id="12">;, diz relat&amp;oacute</segment>
    <segment id="13">;rio rec&amp;eacute</segment>
    <segment id="14">;m-lan&amp;ccedil</segment>
    <segment id="15">;ado da Universidade de Cambridge sobre a percep&amp;ccedil</segment>
    <segment id="16">;&amp;atilde</segment>
    <segment id="17">;o da democracia.</segment>
    <segment id="18">A confian&amp;ccedil</segment>
    <segment id="19">;a nas institui&amp;ccedil</segment>
    <segment id="20">;&amp;otilde</segment>
    <segment id="21">;es declina</segment>
    <segment id="22">porque</segment>
    <segment id="23">porque os governos falharam em coisas</segment>
    <segment id="24">comocomo &amp;</segment>
    <segment id="25">ldquo;a</segment>
    <segment id="26">coordena&amp;ccedil</segment>
    <segment id="27">;&amp;atilde</segment>
    <segment id="28">;o econ&amp;ocirc</segment>
    <segment id="29">;mica na zona do euro&amp;rdquo</segment>
    <segment id="30">; e na resposta mais efetiva &amp;agrave</segment>
    <segment id="31">;</segment>
    <segment id="32">&amp;ldquo</segment>
    <segment id="33">;mudan&amp;ccedil</segment>
    <segment id="34">;a clim&amp;aacute</segment>
    <segment id="35">;tica global&amp;rdquo</segment>
    <segment id="36">;.</segment>
    <segment id="37">Fiquei em d&amp;uacute</segment>
    <segment id="38">;vida se</segment>
    <segment id="39">se os autores listavam alguns itens de suas pr&amp;oacute</segment>
    <segment id="40">;prias predile&amp;ccedil</segment>
    <segment id="41">;&amp;otilde</segment>
    <segment id="42">;es pol&amp;iacute</segment>
    <segment id="43">;ticas ou de fato imaginam que sejam estas as preocupa&amp;ccedil</segment>
    <segment id="44">;&amp;otilde</segment>
    <segment id="45">;es das pessoas e causa de sua crescente insatisfa&amp;ccedil</segment>
    <segment id="46">;&amp;atilde</segment>
    <segment id="47">;o com a pol&amp;iacute</segment>
    <segment id="48">;tica.</segment>
    <segment id="49">Mas este n&amp;atilde</segment>
    <segment id="50">;o &amp;eacute</segment>
    <segment id="51">;</segment>
    <segment id="52">o ponto.</segment>
    <segment id="53">O ponto &amp;eacute</segment>
    <segment id="54">; que suas conclus&amp;otilde</segment>
    <segment id="55">;es expressam bem o que os professores Christopher Achen e Larry Bartels chamam de teoria &amp;ldquo</segment>
    <segment id="56">;folk&amp;rdquo</segment>
    <segment id="57">; da democracia.</segment>
    <segment id="58">Achen e Bartels discutem o tema em seu livro &amp;ldquo</segment>
    <segment id="59">;Democracia para Realistas&amp;rdquo</segment>
    <segment id="60">;.</segment>
    <segment id="61">Seu alvo s&amp;atilde</segment>
    <segment id="62">;o as vis&amp;otilde</segment>
    <segment id="63">;es ing&amp;ecirc</segment>
    <segment id="64">;nuas que teimam em tratar a democracia</segment>
    <segment id="65">comocomo express&amp;atilde</segment>
    <segment id="66">;o dos &amp;ldquo</segment>
    <segment id="67">;interesses&amp;rdquo</segment>
    <segment id="68">; dos eleitores que talvez tenha florescido &amp;agrave</segment>
    <segment id="69">;</segment>
    <segment id="70">sombra da famosa frase de Lincoln em Gettysburg.​</segment>
    <segment id="71">Manifestantes desafiam proibição do governo e protestam por democracia na Tailândia   novamente         de   de  de  representando um</segment>
    <segment id="72">A partir da&amp;iacute</segment>
    <segment id="73">; sua cr&amp;iacute</segment>
    <segment id="74">;tica &amp;eacute</segment>
    <segment id="75">; devastadora.</segment>
    <segment id="76">Eleitores</segment>
    <segment id="77">, em primeiro lugar</segment>
    <segment id="78">, det&amp;eacute</segment>
    <segment id="79">;m muito pouca informa&amp;ccedil</segment>
    <segment id="80">;&amp;atilde</segment>
    <segment id="81">;o relevante sobre temas pol&amp;iacute</segment>
    <segment id="82">;ticos.</segment>
    <segment id="83">Isso acontece por que o custo da informa&amp;ccedil</segment>
    <segment id="84">;&amp;atilde</segment>
    <segment id="85">;o &amp;eacute</segment>
    <segment id="86">; alto.</segment>
    <segment id="87">Muita gente imaginou que a internet resolveria isso</segment>
    <segment id="88">, com informa&amp;ccedil</segment>
    <segment id="89">;&amp;atilde</segment>
    <segment id="90">;o barata e abundante</segment>
    <segment id="91">, masmas tudo parece ter piorado pela raiva</segment>
    <segment id="92">, pelo excesso</segment>
    <segment id="93">, pelo tribalismo e essas coisas que todos sabemos.</segment>
    <segment id="94">O livro traz exemplos saborosos sobre</segment>
    <segment id="95">comocomo os eleitores de fato agem nas democracias.</segment>
    <segment id="96">Um deles mostra</segment>
    <segment id="97">comocomo pequenas altera&amp;ccedil</segment>
    <segment id="98">;&amp;otilde</segment>
    <segment id="99">;es nas palavras</segment>
    <segment id="100">, ou na maneira</segment>
    <segment id="101">comocomo uma pergunta &amp;eacute</segment>
    <segment id="102">; feita</segment>
    <segment id="103">, podem produzir uma enorme mudan&amp;ccedil</segment>
    <segment id="104">;a na opini&amp;atilde</segment>
    <segment id="105">;o das pessoas.</segment>
    <segment id="106">Exemplos: uma pesquisa mostrou que perto de metade dos americanos achavam OK &amp;ldquo</segment>
    <segment id="107">;n&amp;atilde</segment>
    <segment id="108">;o permitir&amp;rdquo</segment>
    <segment id="109">; que um comunista pudesse discursar por a&amp;iacute</segment>
    <segment id="110">;, mas</segment>
    <segment id="111">mas apenas 1/4 concordava em &amp;ldquo</segment>
    <segment id="112">;proibir&amp;rdquo</segment>
    <segment id="113">; ele de falar.</segment>
    <segment id="114">Outra mostrou 2/3 dos eleitores</segment>
    <segment id="115">, &amp;agrave</segment>
    <segment id="116">;s v&amp;eacute</segment>
    <segment id="117">;speras da Guerra do Golfo</segment>
    <segment id="118">, favor&amp;aacute</segment>
    <segment id="119">;veis ao uso da &amp;ldquo</segment>
    <segment id="120">;for&amp;ccedil</segment>
    <segment id="121">;a militar&amp;rdquo</segment>
    <segment id="122">;, mas</segment>
    <segment id="123">mas apenas 30% a favor de &amp;ldquo</segment>
    <segment id="124">;ir &amp;agrave</segment>
    <segment id="125">; guerra&amp;rdquo</segment>
    <segment id="126">;.</segment>
    <segment id="127">Tra&amp;ccedil</segment>
    <segment id="128">;o comum &amp;eacute</segment>
    <segment id="129">;</segment>
    <segment id="130">o que Keith Stanovich chama de &amp;ldquo</segment>
    <segment id="131">;myside bias&amp;rdquo</segment>
    <segment id="132">;.</segment>
    <segment id="133">Ao inv&amp;eacute</segment>
    <segment id="134">;s de ajustar opini&amp;otilde</segment>
    <segment id="135">;es diante da realidade</segment>
    <segment id="136">, ajusta-</segment>
    <segment id="137">sese a realidade a opini&amp;otilde</segment>
    <segment id="138">;es.</segment>
    <segment id="139">E regra do grupo ou &amp;ldquo</segment>
    <segment id="140">;lado&amp;rdquo</segment>
    <segment id="141">; pol&amp;iacute</segment>
    <segment id="142">;tico.</segment>
    <segment id="143">&amp;Eacute</segment>
    <segment id="144">; o feij&amp;atilde</segment>
    <segment id="145">;o com arroz de nossas democracias.</segment>
    <segment id="146">Exemplo disso tivemos no debate sobre a suposta privatiza&amp;ccedil</segment>
    <segment id="147">;&amp;atilde</segment>
    <segment id="148">;o do SUS</segment>
    <segment id="149">, na &amp;uacute</segment>
    <segment id="150">;ltima semana.</segment>
    <segment id="151">Bastava um clique na internet para saber que j&amp;aacute</segment>
    <segment id="152">;</segment>
    <segment id="153">h&amp;aacute</segment>
    <segment id="154">; milhares de unidades de sa&amp;uacute</segment>
    <segment id="155">;de gerenciadas pelo setor privado.</segment>
    <segment id="156">Inclusive PPPs</segment>
    <segment id="157">, desde o primeiro e bem sucedido contrato feito pelo ex-governador Jaques Wagner na Bahia.</segment>
    <segment id="158">Mesmo com informa&amp;ccedil</segment>
    <segment id="159">;&amp;atilde</segment>
    <segment id="160">;o e uma penca de bons estudos acad&amp;ecirc</segment>
    <segment id="161">;micos dispon&amp;iacute</segment>
    <segment id="162">;veis, as pessoas prosseguiam &amp;ldquo</segment>
    <segment id="163">;ajustando&amp;rdquo</segment>
    <segment id="164">; sua narrativa.</segment>
    <segment id="165">Promover estudos sobre as parcerias seria &amp;ldquo</segment>
    <segment id="166">;inconstitucional&amp;rdquo</segment>
    <segment id="167">; (!);</segment>
    <segment id="168">tem a &amp;ldquo</segment>
    <segment id="169">;pandemia&amp;rdquo</segment>
    <segment id="170">; (!);</segment>
    <segment id="171">tem coisa &amp;ldquo</segment>
    <segment id="172">;por tr&amp;aacute</segment>
    <segment id="173">;s&amp;rdquo</segment>
    <segment id="174">;</segment>
    <segment id="175">(!)</segment>
    <segment id="176">O que mesmo os estudos indicam?</segment>
    <segment id="177">Isso pode melhorar a qualidade do atendimento?</segment>
    <segment id="178">Sei l&amp;aacute</segment>
    <segment id="179">;, mas</segment>
    <segment id="180">mas a gritaria est&amp;aacute</segment>
    <segment id="181">; grande</segment>
    <segment id="182">, na internet.</segment>
    <segment id="183">&amp;Eacute</segment>
    <segment id="184">; um tipo de negacionismo democr&amp;aacute</segment>
    <segment id="185">;tico, hoje banal e possivelmente sem cura.</segment>
    <segment id="186">Ainda que todos pudessem ganhar com um debate p&amp;uacute</segment>
    <segment id="187">;blico qualificado</segment>
    <segment id="188">, n&amp;atilde</segment>
    <segment id="189">;o h&amp;aacute</segment>
    <segment id="190">; incentivos</segment>
    <segment id="191">para que</segment>
    <segment id="192">para que cada um aja de acordo</segment>
    <segment id="193">, isto &amp;eacute</segment>
    <segment id="194">;, pense com algum distanciamento e julgue programas p&amp;uacute</segment>
    <segment id="195">;blicos com responsabilidade.</segment>
    <segment id="196">O professor James Fishkin</segment>
    <segment id="197">, da Universidade Stanford</segment>
    <segment id="198">, desenvolveu um modelo de democracia deliberativa para lidar com isso.</segment>
    <segment id="199">Ele faz uma amostra da popula&amp;ccedil</segment>
    <segment id="200">;&amp;atilde</segment>
    <segment id="201">;o e exp&amp;otilde</segment>
    <segment id="202">;e as pessoas a um ambiente reflexivo</segment>
    <segment id="203">, com argumentos a favor e contra</segment>
    <segment id="204">, e incentivos</segment>
    <segment id="205">para que</segment>
    <segment id="206">para que todos ajam de modo sereno e respons&amp;aacute</segment>
    <segment id="207">;vel.</segment>
    <segment id="208">H&amp;aacute</segment>
    <segment id="209">; alguns anos assisti a um de seus experimentos.</segment>
    <segment id="210">De metade a 2/3 das pessoas tendem a mudar sua vis&amp;atilde</segment>
    <segment id="211">;o ao longo do processo.</segment>
    <segment id="212">Sua mudan&amp;ccedil</segment>
    <segment id="213">;a (esta &amp;eacute</segment>
    <segment id="214">; a tese) reflete o que aconteceria com a grande sociedade</segment>
    <segment id="215">, caso</segment>
    <segment id="216">caso algo similar fosse poss&amp;iacute</segment>
    <segment id="217">;vel.</segment>
    <segment id="218">Obviamente n&amp;atilde</segment>
    <segment id="219">;o &amp;eacute</segment>
    <segment id="220">;.</segment>
    <segment id="221">O que nos leva a uma indaga&amp;ccedil</segment>
    <segment id="222">;&amp;atilde</segment>
    <segment id="223">;o perturbadora: nossas melhores esperan&amp;ccedil</segment>
    <segment id="224">;as democr&amp;aacute</segment>
    <segment id="225">;ticas funcionariam apenas em condi&amp;ccedil</segment>
    <segment id="226">;&amp;otilde</segment>
    <segment id="227">;es de laborat&amp;oacute</segment>
    <segment id="228">;rio?</segment>
    <segment id="229">De certo modo</segment>
    <segment id="230">, &amp;eacute</segment>
    <segment id="231">; a resposta de Fishkin.</segment>
    <segment id="232">De minha parte</segment>
    <segment id="233">, n&amp;atilde</segment>
    <segment id="234">;o tenho resposta.</segment>
    <segment id="235">Sei apenas que daqui de fora</segment>
    <segment id="236">, da selva</segment>
    <segment id="237">, dever&amp;iacute</segment>
    <segment id="238">;amos pensar a respeito.</segment>
  </rst>
</analysis>