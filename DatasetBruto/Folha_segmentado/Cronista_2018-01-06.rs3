      <rel name="non-volitional-result" type="rst"/>
      <rel name="volitional-cause" type="rst"/>
      <rel name="volitional-result" type="rst"/>
    </relations>
  </header>
  <rst>
    <segment id="1">O romancista</segment>
    <segment id="2">, escritor</segment>
    <segment id="3">, jornalista e colunista da Folha</segment>
    <segment id="4">, Carlos Heitor Cony morreu por volta das 23h desta sexta-feira (5) aos 91 anos</segment>
    <segment id="5">, no Rio de Janeiro.</segment>
    <segment id="6">Ele estava internado no Hospital Samaritano e morreu em decorrência de falência de múltiplos órgãos.</segment>
    <segment id="7">A informação foi confirmada pela ABL (Academia Brasileira de Letras)</segment>
    <segment id="8">, da qual ele era membro desde 2000.</segment>
    <segment id="9">O corpo deve ser cremado na tarde de terça (9) no Memorial do Carmo</segment>
    <segment id="10">, no Rio.</segment>
    <segment id="11">O Carlos Heitor Cony que conhecemos &amp;ndash</segment>
    <segment id="12">;cronista agudo e lírico</segment>
    <segment id="13">, romancista prolífico de texto ágil e conciso&amp;ndash</segment>
    <segment id="14">; forjou-</segment>
    <segment id="15">sese de uma brincadeira e de uma clausura.</segment>
    <segment id="16">A primeira</segment>
    <segment id="17">sese deu aos oito anos de idade</segment>
    <segment id="18">, quando o garoto</segment>
    <segment id="19">, que por problemas de formação pronunciava ditongos com dificuldade e trocava letras ao falar (o &amp;quot</segment>
    <segment id="20">;g&amp;quot</segment>
    <segment id="21">; pelo &amp;quot</segment>
    <segment id="22">;d&amp;quot</segment>
    <segment id="23">;, por exemplo)</segment>
    <segment id="24">, foi desafiado pelo irmão mais velho e amigos</segment>
    <segment id="25">, numa festinha</segment>
    <segment id="26">, a dizer &amp;quot</segment>
    <segment id="27">;Dona</segment>
    <segment id="28">Jandira adora um fogão&amp;quot</segment>
    <segment id="29">;.Ingenuamente</segment>
    <segment id="30">, disse-o</segment>
    <segment id="31">, e foi objeto de agressiva caçoada.</segment>
    <segment id="32">Angustiado</segment>
    <segment id="33">, em seguida escreveu &amp;quot</segment>
    <segment id="34">;fogão&amp;quot</segment>
    <segment id="35">; inúmeras vezes numa folha de papel e mostrou-a ao mesmo grupo</segment>
    <segment id="36">, que nisso não viu graça alguma.</segment>
    <segment id="37">Donde o menino concluiu que</segment>
    <segment id="38">, sese não falava direito</segment>
    <segment id="39">, podia escrever corretamente e ter</segment>
    <segment id="40">, na escrita</segment>
    <segment id="41">, uma forma de defesa e de manifestação da qual ninguém podia caçoar.</segment>
    <segment id="42">Nascido em 14 de março de 1926</segment>
    <segment id="43">, em Lins de Vasconcelos</segment>
    <segment id="44">, zona norte do Rio de Janeiro</segment>
    <segment id="45">, Cony fora considerado &amp;quot</segment>
    <segment id="46">;mudo&amp;quot</segment>
    <segment id="47">; pela família até os quatro anos de idade.</segment>
    <segment id="48">Só emitira o primeiro som ao levar um susto na praia de Icaraí (Niterói) ante o surgimento de um hidroavião vermelho vindo do mar em direção à areia.</segment>
    <segment id="49">Em 1941</segment>
    <segment id="50">, quando já estava com 15 anos</segment>
    <segment id="51">, uma cirurgia poria fim ao problema.</segment>
    <segment id="52">Já a clausura &amp;ndash</segment>
    <segment id="53">;segundo pilar do Cony que conhecemos&amp;ndash</segment>
    <segment id="54">;</segment>
    <segment id="55">foram os anos passados no Seminário Arquidiocesano de São José</segment>
    <segment id="56">, no Rio Comprido</segment>
    <segment id="57">, de 1938 a 1945</segment>
    <segment id="58">, período em que estudou os clássicos gregos e romanos</segment>
    <segment id="59">, praticou diversas línguas</segment>
    <segment id="60">, conheceu música lírica e</segment>
    <segment id="61">, principalmente</segment>
    <segment id="62">, trocou muitas ideias</segment>
    <segment id="63">, em especial consigo mesmo.</segment>
    <segment id="64">GaleriaÍcone seta para esquerdaÍcone seta para direita   novamenteÍcone seta para esquerda</segment>
    <segment id="65">VoltarÍcone seta para cimaÍcone seta para baixoÍcone seta para esquerda Voltar       de  PinterestPinterestÍcone  de  de  representando um  Do seminário</segment>
    <segment id="66">, onde ingressara por vontade própria e de onde saiu aos 19 anos e meses antes de obter a tonsura</segment>
    <segment id="67">, Cony herdou grande capacidade de concentração e o hábito de sempre</segment>
    <segment id="68">sese ocupar com alguma coisa</segment>
    <segment id="69">, o tempo inteiro</segment>
    <segment id="70">, além do gosto pela liturgia.</segment>
    <segment id="71">Mas conheceu</segment>
    <segment id="72">, também</segment>
    <segment id="73">, o valor da dúvida</segment>
    <segment id="74">, a experiência dolorida da ruptura e o alto custo a pagar pela livre expressão de pensamento e opinião.</segment>
    <segment id="75">Em &amp;quot</segment>
    <segment id="76">;Informação ao Crucificado&amp;quot</segment>
    <segment id="77">; (ficção com tonalidade autobiográfica em forma de diário publicada em 1961)</segment>
    <segment id="78">, o jovem seminarista João Falcão relata o tenso e decisivo diálogo no qual</segment>
    <segment id="79">, acuado</segment>
    <segment id="80">, respondendo a uma pergunta do Senhor Arcebispo (&amp;quot</segment>
    <segment id="81">;por que você quis ser padre?&amp;quot</segment>
    <segment id="82">;), explicava: &amp;quot</segment>
    <segment id="83">;Porque achei bonito ser padre.</segment>
    <segment id="84">Bonito e difícil&amp;quot</segment>
    <segment id="85">;.</segment>
    <segment id="86">Pouco a ver com &amp;quot</segment>
    <segment id="87">;levar almas a Deus&amp;quot</segment>
    <segment id="88">; ou com apego religioso</segment>
    <segment id="89">, portanto.</segment>
    <segment id="90">Réplica do Arcebispo: &amp;quot</segment>
    <segment id="91">;...ou você muda radicalmente sua maneira de pensar</segment>
    <segment id="92">, ou faça-me o extraordinário favor de abandonar o quanto antes</segment>
    <segment id="93">o Seminário&amp;quot</segment>
    <segment id="94">;.Ao longo dessa experiência</segment>
    <segment id="95">, solidificou-</segment>
    <segment id="96">sese uma personalidade marcada pelo ceticismo</segment>
    <segment id="97">, alérgica a grupos &amp;ndash</segment>
    <segment id="98">;fossem ou culturais&amp;ndash</segment>
    <segment id="99">;, assumidamente individualista e</segment>
    <segment id="100">, por isso mesmo</segment>
    <segment id="101">, também errática</segment>
    <segment id="102">, imprevisível.</segment>
    <segment id="103">Em maio de 2000</segment>
    <segment id="104">, no discurso de posse da cadeira número 3 da Academia Brasileira de Letras</segment>
    <segment id="105">, Cony definiu-</segment>
    <segment id="106">sese, citando Eça de Queiroz</segment>
    <segment id="107">, como</segment>
    <segment id="108">como um &amp;quot</segment>
    <segment id="109">;anarquista entristecido</segment>
    <segment id="110">, humilde e inofensivo&amp;quot</segment>
    <segment id="111">;.</segment>
    <segment id="112">&amp;quot;Não</segment>
    <segment id="113">tenho disciplina suficiente para ser de esquerda</segment>
    <segment id="114">, não tenho firmeza suficiente para ser de direita e não tenho a imobilidade oportunista do centro&amp;quot</segment>
    <segment id="115">;.Em 1946</segment>
    <segment id="116">, aos 20 anos</segment>
    <segment id="117">, como</segment>
    <segment id="118">como quem busca um novo eixo</segment>
    <segment id="119">, o ex-seminarista ingressa na Faculdade Nacional de Filosofia da Universidade do Brasil.</segment>
    <segment id="120">Abandona a instituição</segment>
    <segment id="121">, porém</segment>
    <segment id="122">porém, no ano seguinte.</segment>
    <segment id="123">De 1948 a 1950</segment>
    <segment id="124">, frequenta o Curso de Preparação de Oficiais de Reserva (CPOR).</segment>
    <segment id="125">Nesse intervalo</segment>
    <segment id="126">, casa-</segment>
    <segment id="127">sese em 1949.</segment>
    <segment id="128">Nascem as filhas Regina Celi (1951) e Maria Verônica (1954).</segment>
    <segment id="129">Ao longo da vida</segment>
    <segment id="130">, Cony teve mais três casamentos formais e duas uniões informais &amp;ndash</segment>
    <segment id="131">;além de um filho</segment>
    <segment id="132">, André Heitor</segment>
    <segment id="133">, nascido em 1973.JORNALISMOFilho de Julieta de Moraes e do modesto jornalista Ernesto Cony Filho &amp;ndash</segment>
    <segment id="134">;morto em 1985 aos 91 anos e celebrizado em 1995</segment>
    <segment id="135">comocomo protagonista de &amp;quot</segment>
    <segment id="136">;Quase Memória&amp;quot</segment>
    <segment id="137">;&amp;ndash</segment>
    <segment id="138">;, Cony ingressa oficialmente no jornalismo aos 26 anos</segment>
    <segment id="139">, em 1952</segment>
    <segment id="140">, como</segment>
    <segment id="141">como redator na Rádio Jornal do Brasil.</segment>
    <segment id="142">Antes tivera passagens</segment>
    <segment id="143">comocomo &amp;quot</segment>
    <segment id="144">;setorista&amp;quot</segment>
    <segment id="145">; da Gazeta de Notícias na Câmara Municipal do Rio de Janeiro</segment>
    <segment id="146">, em substituição ao pai.</segment>
    <segment id="147">Foi também no lugar do pai &amp;ndash</segment>
    <segment id="148">;vítima de uma isquemia cerebral&amp;ndash</segment>
    <segment id="149">; que Cony passou a ser credenciado pelo &amp;quot</segment>
    <segment id="150">;Jornal do Brasil&amp;quot</segment>
    <segment id="151">;, em 1955</segment>
    <segment id="152">, na Sala de Imprensa da Prefeitura da cidade.</segment>
    <segment id="153">Memória</segment>
    <segment id="154">Carlos Heitor Cony morre aos 91 anos no RioAnálise:</segment>
    <segment id="155">Cony encarnou</segment>
    <segment id="156">comocomo poucos a figura do escritor profissional Em março</segment>
    <segment id="157">, escritor publicou a coluna '</segment>
    <segment id="158">Se eu morrer amanhã' Releia a última coluna de Cony publicada na Folha</segment>
    <segment id="159">, em 31 de dezembro</segment>
    <segment id="160">O primeiro romance (&amp;quot</segment>
    <segment id="161">;O</segment>
    <segment id="162">Ventre&amp;quot</segment>
    <segment id="163">;)</segment>
    <segment id="164">é escrito nesse ano.</segment>
    <segment id="165">Em 1956</segment>
    <segment id="166">, o autor o inscreve sob pseudônimo para o Prêmio Manuel Antonio de Almeida</segment>
    <segment id="167">, concurso da Prefeitura.</segment>
    <segment id="168">A comissão julgadora considera o livro &amp;quot</segment>
    <segment id="169">;muito bom&amp;quot</segment>
    <segment id="170">;, mas</segment>
    <segment id="171">mas nega-lhe o prêmio por achá-lo forte demais para um certame oficial.</segment>
    <segment id="172">Em apenas nove dias</segment>
    <segment id="173">, para cumprir o prazo de inscrição</segment>
    <segment id="174">, o autor produz seu segundo romance</segment>
    <segment id="175">, &amp;quot</segment>
    <segment id="176">;A Verdade de Cada Dia&amp;quot</segment>
    <segment id="177">;, e com ele vence o concurso</segment>
    <segment id="178">, em 1957.</segment>
    <segment id="179">Com &amp;quot</segment>
    <segment id="180">;Tijolo de Segurança&amp;quot</segment>
    <segment id="181">;, recebe o mesmo prêmio</segment>
    <segment id="182">, em 1958.Os três romances viriam a ser publicados respectivamente em 1958</segment>
    <segment id="183">, 1959 e 1960 pela Civilização Brasileira</segment>
    <segment id="184">, dirigida por Ênio Silveira</segment>
    <segment id="185">, que &amp;quot</segment>
    <segment id="186">;adota&amp;quot</segment>
    <segment id="187">;</segment>
    <segment id="188">Cony como</segment>
    <segment id="189">como autor de ponta da prestigiosa editora.</segment>
    <segment id="190">Seguem-</segment>
    <segment id="191">sese &amp;quot</segment>
    <segment id="192">;Informação ao Crucificado&amp;quot</segment>
    <segment id="193">; (1961)</segment>
    <segment id="194">, &amp;quot</segment>
    <segment id="195">;Matéria de Memória&amp;quot</segment>
    <segment id="196">; (1962) e &amp;quot</segment>
    <segment id="197">;Antes</segment>
    <segment id="198">, o Verão&amp;quot</segment>
    <segment id="199">; (1964).Nessa inusitada avalanche de romances</segment>
    <segment id="200">, a crítica observou a composição de um retrato impiedoso da classe média carioca</segment>
    <segment id="201">, em compasso existencialista com elevada dose de autocomiseração</segment>
    <segment id="202">, assim</segment>
    <segment id="203">comocomo a expressão do vazio individual</segment>
    <segment id="204">, da incomunicabilidade e da ausência de perspectivas coletivas &amp;</segment>
    <segment id="205">ndash;tudo isso</segment>
    <segment id="206">, na perfeita contramão da euforia da era Juscelino Kubitscheck.</segment>
    <segment id="207">Voluntária ou involuntariamente</segment>
    <segment id="208">, Cony já assumia</segment>
    <segment id="209">, em todas essas obras</segment>
    <segment id="210">, a postura muito própria de enfrentamento que marcaria toda a sua trajetória pessoal e profissional.</segment>
    <segment id="211">Ao comentar &amp;quot</segment>
    <segment id="212">;A Verdade de Cada Dia&amp;quot</segment>
    <segment id="213">;</segment>
    <segment id="214">em 1961</segment>
    <segment id="215">, o crítico Paulo Rónai classificava os romances de Cony</segment>
    <segment id="216">comocomo &amp;quot</segment>
    <segment id="217">;chocantes e pungentes&amp;quot</segment>
    <segment id="218">;, com um &amp;quot</segment>
    <segment id="219">;lugar definitivo na história da ficção brasileira&amp;quot</segment>
    <segment id="220">;.</segment>
    <segment id="221">Na &amp;quot</segment>
    <segment id="222">;História Concisa da Literatura Brasileira&amp;quot</segment>
    <segment id="223">;, Alfredo Bosi via a obra do autor</segment>
    <segment id="224">comocomo uma &amp;quot</segment>
    <segment id="225">;experiência cortante de neorrealismo psicológico&amp;quot</segment>
    <segment id="226">;.O projeto inicial do ficcionista</segment>
    <segment id="227">, segundo confidenciou o próprio em diferentes ocasiões</segment>
    <segment id="228">, era compor um conjunto de dez romances</segment>
    <segment id="229">, uma série sobre a &amp;quot</segment>
    <segment id="230">;condição humana&amp;quot</segment>
    <segment id="231">;.</segment>
    <segment id="232">Autoilusão</segment>
    <segment id="233">, sem dúvida</segment>
    <segment id="234">, pois</segment>
    <segment id="235">pois Cony</segment>
    <segment id="236">, desde o início</segment>
    <segment id="237">, sempre foi</segment>
    <segment id="238">, acima de tudo</segment>
    <segment id="239">, uma máquina humana de escrever</segment>
    <segment id="240">; vulcânica</segment>
    <segment id="241">, acelerada</segment>
    <segment id="242">, infatigável</segment>
    <segment id="243">, fora de controle do próprio dono.</segment>
    <segment id="244">Não só produziu bem mais do que dez romances (foram 17 no total)</segment>
    <segment id="245">, como</segment>
    <segment id="246">como enveredaria incansavelmente pela crônica e outros vários gêneros: romance-reportagem</segment>
    <segment id="247">, biografias</segment>
    <segment id="248">, ficção infantojuvenil</segment>
    <segment id="249">, adaptações de clássicos nacionais e estrangeiros.</segment>
    <segment id="250">No total</segment>
    <segment id="251">, sua produção reúne 65 publicações</segment>
    <segment id="252">, sem falar naquelas realizadas em parceria ou a participação em coletâneas.</segment>
    <segment id="253">Certamente não tinha preocupação de fazer obras-primas.</segment>
    <segment id="254">Escrevia</segment>
    <segment id="255">, simplesmente</segment>
    <segment id="256">, de modo compulsivo</segment>
    <segment id="257">, como</segment>
    <segment id="258">como extensão</segment>
    <segment id="259">, no papel</segment>
    <segment id="260">, de sua fisiologia.</segment>
    <segment id="261">Muitas vezes</segment>
    <segment id="262">sese classificou</segment>
    <segment id="263">comocomo um autor &amp;quot</segment>
    <segment id="264">;sem estilo&amp;quot</segment>
    <segment id="265">; &amp;ndash</segment>
    <segment id="266">;embora</segment>
    <segment id="267">embora</segment>
    <segment id="268">, segundo diferentes críticos</segment>
    <segment id="269">, isso esteja longe da realidade.</segment>
    <segment id="270">Sempre autoirônico</segment>
    <segment id="271">, disse numa entrevista: &amp;quot</segment>
    <segment id="272">;Acho que já poluí demais o mercado editorial.</segment>
    <segment id="273">O Ibama deveria tomar uma providência contra mim&amp;quot</segment>
    <segment id="274">;.CRONISTASe o reconhecimento literário veio cedo</segment>
    <segment id="275">, expresso em prêmios e resenhas elogiosas</segment>
    <segment id="276">, foi como</segment>
    <segment id="277">como cronista &amp;ndash</segment>
    <segment id="278">;cuja estreia</segment>
    <segment id="279">sese deu em 1962 no &amp;quot</segment>
    <segment id="280">;Correio da Manhã&amp;quot</segment>
    <segment id="281">; (onde fora contratado em 1960</segment>
    <segment id="282">comocomo copidesque e depois editorialista)&amp;ndash</segment>
    <segment id="283">; que Cony surgiu para uma faixa mais ampla de leitores.</segment>
    <segment id="284">A coluna</segment>
    <segment id="285">, em revezamento com o escritor Otávio de Faria (1908-1980)</segment>
    <segment id="286">, chamava-</segment>
    <segment id="287">sese &amp;quot</segment>
    <segment id="288">;Da arte de falar mal&amp;quot</segment>
    <segment id="289">;.Quando de sua reunião em livro</segment>
    <segment id="290">, em 1963</segment>
    <segment id="291">, o crítico Fausto Cunha destacou o domínio da língua e a temática individual</segment>
    <segment id="292">, elogiando-lhe</segment>
    <segment id="293">, entre outros aspectos</segment>
    <segment id="294">, a &amp;quot</segment>
    <segment id="295">;audácia da afirmação&amp;quot</segment>
    <segment id="296">;, uma qualidade</segment>
    <segment id="297">, segundo ele</segment>
    <segment id="298">, ausente em &amp;quot</segment>
    <segment id="299">;nossos cronistas&amp;quot</segment>
    <segment id="300">;.A explosão pública de Cony</segment>
    <segment id="301">, porém</segment>
    <segment id="302">porém, ocorreria no ano seguinte</segment>
    <segment id="303">, logo após a implantação da ditadura militar</segment>
    <segment id="304">, em 1964.</segment>
    <segment id="305">E não por acaso.</segment>
    <segment id="306">Avesso a grupos</segment>
    <segment id="307">, sem laços partidários nem compromissos programáticos</segment>
    <segment id="308">, o cronista pôde</segment>
    <segment id="309">sese dar o luxo de</segment>
    <segment id="310">, a partir de abril daquele ano</segment>
    <segment id="311">, agir por instinto</segment>
    <segment id="312">, atirar sozinho</segment>
    <segment id="313">, expor-</segment>
    <segment id="314">sese como</segment>
    <segment id="315">como e quando achasse melhor em reação à implantação do regime militar.</segment>
    <segment id="316">As crônicas dos dias e semanas imediatamente posteriores ao Golpe são de uma ousadia sem igual em toda a imprensa.</segment>
    <segment id="317">Cony dava nome aos bois.</segment>
    <segment id="318">Chamava o golpe de &amp;quot</segment>
    <segment id="319">;quartelada&amp;quot</segment>
    <segment id="320">;, ironizava a presença político-militar dos Estados Unidos no país</segment>
    <segment id="321">, investia contra os altos comandantes do novo regime.</segment>
    <segment id="322">O impacto de seus textos era proporcional ao pasmo que tomara conta da maior parte dos setores atingidos pelo golpe</segment>
    <segment id="323">, ainda mais por serem provenientes de um autor antes freqüentemente tachado de &amp;quot</segment>
    <segment id="324">;alienado&amp;quot</segment>
    <segment id="325">; e individualista &amp;ndash</segment>
    <segment id="326">;rótulos que ele próprio</segment>
    <segment id="327">, diga-</segment>
    <segment id="328">sese, nunca rejeitou.&amp;quot</segment>
    <segment id="329">;Era o nosso respiradouro&amp;quot</segment>
    <segment id="330">;, escreveu em 1996 Moacyr Scliar.</segment>
    <segment id="331">Testemunha o também escritor Luiz Fernando Veríssimo: &amp;quot</segment>
    <segment id="332">;Em pouco tempo</segment>
    <segment id="333">, aquele ato</segment>
    <segment id="334">, ler o Cony</segment>
    <segment id="335">, sese tornou um exercício vital de oxigenação para muita gente</segment>
    <segment id="336">, e a sua coluna uma espécie de cidadela intelectual em que também resistíamos &amp;ndash</segment>
    <segment id="337">;mesmo que a resistência consistisse apenas em dizer &amp;quot</segment>
    <segment id="338">;É isso mesmo!&amp;quot</segment>
    <segment id="339">;, ou &amp;quot</segment>
    <segment id="340">;Dá-lhe</segment>
    <segment id="341">, Cony!&amp;quot</segment>
    <segment id="342">;, a cada duas frases lidas.</segment>
    <segment id="343">&amp;quot;Leu o Cony hoje?&amp;quot</segment>
    <segment id="344">;, passou a ser a senha de uma conspiração tácita de inconformados passivos cujo lema silencioso seria &amp;quot</segment>
    <segment id="345">;Pelo menos</segment>
    <segment id="346">, eles não estão conseguindo engambelar todo o mundo&amp;quot</segment>
    <segment id="347">;.Os relatos da noite de autógrafos de &amp;quot</segment>
    <segment id="348">;O Ato e o Fato</segment>
    <segment id="349">, livro que reuniu essas crônicas poucos meses depois de publicadas em jornal</segment>
    <segment id="350">, dão conta de um sucesso retumbante: mais de 1.600 exemplares vendidos na ocasião</segment>
    <segment id="351">; edição esgotada em poucas semanas.</segment>
    <segment id="352">Aquilo que socialmente aparecia</segment>
    <segment id="353">comocomo protesto politizado</segment>
    <segment id="354">, engajamento determinado e firme</segment>
    <segment id="355">, tinha para o autor</segment>
    <segment id="356">, porém</segment>
    <segment id="357">porém, um sentido diferente</segment>
    <segment id="358">, particular: mais dever de consciência do que atitude programática.</segment>
    <segment id="359">Cony explicou certa vez: &amp;quot</segment>
    <segment id="360">;(...) não tive motivação política alguma para escrever</segment>
    <segment id="361">comocomo escrevia (...) não estava em jogo o fato político: estava em jogo</segment>
    <segment id="362">, em grande parte</segment>
    <segment id="363">, um lado humano.</segment>
    <segment id="364">Pessoas que trabalhavam comigo desapareciam</segment>
    <segment id="365">, eram espancadas nas ruas</segment>
    <segment id="366">, eram torturadas...</segment>
    <segment id="367">Foi um espetáculo deprimente</segment>
    <segment id="368">, abominável (...)</segment>
    <segment id="369">Isso tudo me enojou de uma tal maneira que eu comecei a escrever sobre o assunto.</segment>
    <segment id="370">E com uma violência toda pessoal&amp;quot</segment>
    <segment id="371">;.A ousadia valeu-lhe fama e simpatia</segment>
    <segment id="372">, masmas custou-lhe</segment>
    <segment id="373">, também</segment>
    <segment id="374">, inúmeros transtornos.</segment>
    <segment id="375">As filhas foram ameaçadas por militares</segment>
    <segment id="376">, que rondavam o prédio onde Cony morava</segment>
    <segment id="377">, no Posto 6</segment>
    <segment id="378">, em Copacabana.</segment>
    <segment id="379">O então ministro da Guerra</segment>
    <segment id="380">, general Costa e Silva</segment>
    <segment id="381">, moveu ação com base da Lei de Segurança Nacional</segment>
    <segment id="382">, considerando as crônicas ofensivas às Forças Armadas.</segment>
    <segment id="383">Mais tarde</segment>
    <segment id="384">, a defesa do jornalista conseguiu que o processo ocorresse sob a Lei de Imprensa (em que as penas eram menores).</segment>
    <segment id="385">Cony foi condenado a três meses de prisão</segment>
    <segment id="386">, com direito a sursis.</segment>
    <segment id="387">De 1964 a 1972</segment>
    <segment id="388">, sofreria 12 processos</segment>
    <segment id="389">, sendo detido em seis oportunidades</segment>
    <segment id="390">; na mais grave delas</segment>
    <segment id="391">, ao final de 1968</segment>
    <segment id="392">, com a decretação do Ato Institucional N° 5</segment>
    <segment id="393">, chegou a ficar quase um mês na prisão.</segment>
    <segment id="394">Em 1965</segment>
    <segment id="395">, sob pressão</segment>
    <segment id="396">, o escritor deixa o &amp;quot</segment>
    <segment id="397">;Correio da Manhã&amp;quot</segment>
    <segment id="398">;</segment>
    <segment id="399">e começa a trabalhar nas Edições de Ouro (Ediouro) &amp;ndash</segment>
    <segment id="400">;fazendo adaptações de clássicos</segment>
    <segment id="401">, traduções e prefácios&amp;ndash</segment>
    <segment id="402">;, além de colaborar com diferentes publicações.</segment>
    <segment id="403">Chega a escrever uma telenovela (&amp;quot</segment>
    <segment id="404">;Comédia Carioca&amp;quot</segment>
    <segment id="405">;) para a TV Record</segment>
    <segment id="406">, censurada.</segment>
    <segment id="407">No começo de 1966</segment>
    <segment id="408">, sai o romance &amp;quot</segment>
    <segment id="409">;Balé Branco&amp;quot</segment>
    <segment id="410">;, dedicado a Carlos Drummond de Andrade</segment>
    <segment id="411">, Austregésilo de Athayde</segment>
    <segment id="412">, Alceu Amoroso Lima e Fernando de Azevedo</segment>
    <segment id="413">, os quais haviam deposto em favor de Cony na Justiça durante o processo que sofrera pela ação de Costa e Silva.</segment>
    <segment id="414">Nesse período publicaria</segment>
    <segment id="415">, entre outros livros</segment>
    <segment id="416">, uma coletânea de contos (&amp;quot</segment>
    <segment id="417">;Sobre Todas as Coisas&amp;quot</segment>
    <segment id="418">;, 1968) e produziria</segment>
    <segment id="419">, para a Bloch Editores</segment>
    <segment id="420">, reportagens que mais tarde redundaram no livro &amp;quot</segment>
    <segment id="421">;Quem Matou Vargas?&amp;quot</segment>
    <segment id="422">; (1972).A</segment>
    <segment id="423">Civilização Brasileira edita em 1967 o mais polêmico dos romances do autor: &amp;quot</segment>
    <segment id="424">;Pessach: a Travessia&amp;quot</segment>
    <segment id="425">;, obra que tematiza o drama vivido por boa parte da esquerda e da intelectualidade em relação ao engajamento ou não na luta armada contra a ditadura.</segment>
    <segment id="426">Embora com uma orelha assinada pelo filósofo Leandro Konder</segment>
    <segment id="427">, um dos responsáveis então pela política cultural do Partido Comunista Brasileiro (PCB)</segment>
    <segment id="428">, o livro é explicitamente crítico quanto ao papel desempenhado por essa organização no enfrentamento ao regime.</segment>
    <segment id="429">Primeira ficção com fundo político de Cony</segment>
    <segment id="430">, &amp;quot</segment>
    <segment id="431">;Pessach&amp;quot</segment>
    <segment id="432">; causou debate até mesmo na sua reedição</segment>
    <segment id="433">, em 1997</segment>
    <segment id="434">, oportunidade em que o autor afirmou ter sido boicotado à época pelos jornalistas e intelectuais ligados ao PCB na difusão do livro &amp;ndash</segment>
    <segment id="435">;denúncia contestada por dirigentes comunistas daquele período</segment>
    <segment id="436">comocomo Ferreira Gullar e o próprio Konder.</segment>
    <segment id="437">Em circunstâncias políticas e pessoais desconfortáveis</segment>
    <segment id="438">, Cony viaja ao exterior</segment>
    <segment id="439">, passando por Paris</segment>
    <segment id="440">, Moscou</segment>
    <segment id="441">, Praga e Havana.</segment>
    <segment id="442">Na capital cubana &amp;ndash</segment>
    <segment id="443">;inicialmente</segment>
    <segment id="444">comocomo jurado do concurso</segment>
    <segment id="445">Casa de Las Américas&amp;ndash</segment>
    <segment id="446">;, permanece durante onze meses</segment>
    <segment id="447">, entre 1967 e 1968.Sem perspectiva profissional</segment>
    <segment id="448">, na volta ao Brasil</segment>
    <segment id="449">Cony aceita o convite de Adolpho Bloch para trabalhar no seu grupo editorial &amp;ndash</segment>
    <segment id="450">;cujo apoio aos governos militares era explícito&amp;ndash</segment>
    <segment id="451">;, onde permaneceria por cerca de 30 anos.</segment>
    <segment id="452">No dizer do próprio jornalista</segment>
    <segment id="453">, foi uma opção por ajustar-</segment>
    <segment id="454">sese a uma espécie de &amp;quot</segment>
    <segment id="455">;prisão de luxo&amp;quot</segment>
    <segment id="456">;, com bons salários e viagens constantes ao exterior.</segment>
    <segment id="457">Ali, de início</segment>
    <segment id="458">, ajudou a finalizar o livro das memórias de Juscelino Kubitschek</segment>
    <segment id="459">, para depois exercer sucessivamente diversos cargos executivos</segment>
    <segment id="460">, dirigindo revistas de entretenimento</segment>
    <segment id="461">comocomo &amp;quot</segment>
    <segment id="462">;Ele &amp;amp</segment>
    <segment id="463">;</segment>
    <segment id="464">Ela&amp;quot</segment>
    <segment id="465">;, &amp;quot</segment>
    <segment id="466">;Desfile&amp;quot</segment>
    <segment id="467">; e &amp;quot</segment>
    <segment id="468">;Fatos &amp;amp</segment>
    <segment id="469">; Fotos&amp;quot</segment>
    <segment id="470">;.</segment>
    <segment id="471">Em meados dos anos 1970</segment>
    <segment id="472">, passaria a escrever para a &amp;quot</segment>
    <segment id="473">;Manchete&amp;quot</segment>
    <segment id="474">;, carro-chefe da Bloch</segment>
    <segment id="475">, datando de 1976 a entrevista que realizou com o delegado Sergio Paranhos Fleury</segment>
    <segment id="476">, do Dops</segment>
    <segment id="477">, então símbolo maior da aplicação da tortura no Brasil</segment>
    <segment id="478">, fato que lhe rendeu ainda mais animosidade por parte da oposição ao regime.</segment>
    <segment id="479">Para a esquerda</segment>
    <segment id="480">, ao integrar o grupo de Bloch Cony fizera uma espécie de pacto com o diabo.</segment>
    <segment id="481">Para a geração mais nova</segment>
    <segment id="482">, que começava a entender alguma coisa apenas em meados dos anos 70</segment>
    <segment id="483">, seu nome já</segment>
    <segment id="484">sese associava</segment>
    <segment id="485">, ainda que indiretamente</segment>
    <segment id="486">, à zona de influência do regime &amp;ndash</segment>
    <segment id="487">;o mesmo que ele combatera anos antes de modo tão escancarado e impetuoso.</segment>
    <segment id="488">Anos mais tarde</segment>
    <segment id="489">, em 2004</segment>
    <segment id="490">, ele voltaria a ser criticado</segment>
    <segment id="491">, quando a Comissão de Anistia aprovou pedido seu</segment>
    <segment id="492">, determinando que recebesse uma pensão mensal de R$ 19.115</segment>
    <segment id="493">,19, além de uma indenização de R$ 1</segment>
    <segment id="494">,4 milhão</segment>
    <segment id="495">, pelas perseguições sofridas.</segment>
    <segment id="496">Mas o &amp;quot</segment>
    <segment id="497">;lobo solitário de feroz individualismo&amp;quot</segment>
    <segment id="498">; (expressão de Ênio Silveira) não estava nem um pouco incomodado com tudo isso.</segment>
    <segment id="499">Arredio</segment>
    <segment id="500">, em 1974 reagiu de maneira bem própria</segment>
    <segment id="501">, bem &amp;quot</segment>
    <segment id="502">;conyniana&amp;quot</segment>
    <segment id="503">;, escrevendo o romance &amp;quot</segment>
    <segment id="504">;Pilatos&amp;quot</segment>
    <segment id="505">;.</segment>
    <segment id="506">Trata-</segment>
    <segment id="507">sese de um livro cáustico</segment>
    <segment id="508">, com traços escatológicos e pornográficos</segment>
    <segment id="509">, cujo protagonista</segment>
    <segment id="510">, um sujeito que fora castrado depois de sofrer um acidente</segment>
    <segment id="511">, perambula pelas ruas do Rio com seu pênis preservado num vidro de compota.</segment>
    <segment id="512">Um texto &amp;quot</segment>
    <segment id="513">;originalíssimo (...) não tem semelhança com nenhuma outra obra da literatura brasileira&amp;quot</segment>
    <segment id="514">;, nas palavras de Otto Maria Carpeaux.</segment>
    <segment id="515">&amp;quot;</segment>
    <segment id="516">(...)</segment>
    <segment id="517">Este romance pede inteligências abertas</segment>
    <segment id="518">, capazes de descobrir</segment>
    <segment id="519">, em meio à falação desabrida</segment>
    <segment id="520">, ao grotesco à la Goya ou à mordacidade à Daumier</segment>
    <segment id="521">, o quanto há de humano</segment>
    <segment id="522">, sofrido e pungente nessa parábola escrita antes com sangue e lágrimas do que com riso&amp;quot</segment>
    <segment id="523">;, analisava Mário da Silva Brito.</segment>
    <segment id="524">Cony sempre viu em &amp;quot</segment>
    <segment id="525">;Pilatos&amp;quot</segment>
    <segment id="526">;</segment>
    <segment id="527">o seu melhor livro.</segment>
    <segment id="528">Não tanto pelas qualidades literárias</segment>
    <segment id="529">, masmas principalmente por ser</segment>
    <segment id="530">, segundo dizia</segment>
    <segment id="531">, o único que o expressava integralmente e que só ele poderia ter escrito.</segment>
    <segment id="532">Com essa obra</segment>
    <segment id="533">, ele &amp;quot</segment>
    <segment id="534">;chuta o pau da barraca&amp;quot</segment>
    <segment id="535">;, à esquerda e à direita.</segment>
    <segment id="536">Lava as mãos e</segment>
    <segment id="537">sese despede da ficção.</segment>
    <segment id="538">Nesse período</segment>
    <segment id="539">, segundo contava</segment>
    <segment id="540">, vivia feliz</segment>
    <segment id="541">, um &amp;quot</segment>
    <segment id="542">;clone às avessas do seminário&amp;quot</segment>
    <segment id="543">;.</segment>
    <segment id="544">Sentia-</segment>
    <segment id="545">sese bem casado</segment>
    <segment id="546">, passou a andar com rabo-de-cavalo</segment>
    <segment id="547">, vestia calça vermelha</segment>
    <segment id="548">, pintava quadros</segment>
    <segment id="549">, viajava.</segment>
    <segment id="550">Teve um filho e uma neta.</segment>
    <segment id="551">Assessorava Bloch em assuntos pessoais e profissionais.</segment>
    <segment id="552">Publicou livros-reportagem e pequenas obras infanto-juvenis.</segment>
    <segment id="553">No final da década de 1980</segment>
    <segment id="554">, chegou a assumir o departamento de teledramaturgia da TV Manchete e a esboçar sinopses de novelas</segment>
    <segment id="555">comocomo &amp;quot</segment>
    <segment id="556">;Kananga do Japão&amp;quot</segment>
    <segment id="557">; e &amp;quot</segment>
    <segment id="558">;Dona Beja&amp;quot</segment>
    <segment id="559">;.Por que deixou de produzir literatura?</segment>
    <segment id="560">Ele mesmo respondia: &amp;quot</segment>
    <segment id="561">;Preferi viver.</segment>
    <segment id="562">A vida estava boa</segment>
    <segment id="563">, divertida</segment>
    <segment id="564">, foi uma fase em que não senti necessidade de escrever&amp;quot</segment>
    <segment id="565">;.</segment>
    <segment id="566">Como o publicitário Augusto Richet de &amp;quot</segment>
    <segment id="567">;A</segment>
    <segment id="568">Casa do Poeta Trágico&amp;quot</segment>
    <segment id="569">; (1997)</segment>
    <segment id="570">, porém</segment>
    <segment id="571">porém, Cony &amp;quot</segment>
    <segment id="572">;sese recusava ao crepúsculo&amp;quot</segment>
    <segment id="573">;.COLUNISTA DA FOLHAEm março de 1993</segment>
    <segment id="574">, por sugestão do colunista Janio de Freitas</segment>
    <segment id="575">, ele volta a ficar sob os holofotes da mídia</segment>
    <segment id="576">, assumindo a coluna &amp;quot</segment>
    <segment id="577">;Rio de Janeiro&amp;quot</segment>
    <segment id="578">; da página A2 da Folha</segment>
    <segment id="579">, antes assinada por Otto Lara Resende.</segment>
    <segment id="580">Seu público mais antigo retoma o contato diário com uma verve ímpar</segment>
    <segment id="581">, independente</segment>
    <segment id="582">, carregada de anedotas curiosas e vastas experiências</segment>
    <segment id="583">, sem ser</segment>
    <segment id="584">, no entanto</segment>
    <segment id="585">, saudosista.</segment>
    <segment id="586">Para os leitores mais jovens</segment>
    <segment id="587">, surge uma prosa cuja contundência</segment>
    <segment id="588">, vivacidade e agilidade nem de longe denunciam tratar-</segment>
    <segment id="589">sese, na verdade</segment>
    <segment id="590">, de um retorno.</segment>
    <segment id="591">A energia produtiva de Cony</segment>
    <segment id="592">, que de novo</segment>
    <segment id="593">sese manifestava em crônica diária</segment>
    <segment id="594">, serviu-lhe</segment>
    <segment id="595">, também</segment>
    <segment id="596">, para retomar a ficção num momento de infelicidade</segment>
    <segment id="597">, dois anos depois</segment>
    <segment id="598">, quando obrigou-</segment>
    <segment id="599">sese a permanecer noites acordado a cuidar de sua setter Mila</segment>
    <segment id="600">, gravemente adoecida.</segment>
    <segment id="601">Nesses momentos</segment>
    <segment id="602">, sem premeditação</segment>
    <segment id="603">, acabou por escrever</segment>
    <segment id="604">, num período intensivo de três semanas</segment>
    <segment id="605">, o livro &amp;quot</segment>
    <segment id="606">;Quase Memória&amp;quot</segment>
    <segment id="607">; (1995)</segment>
    <segment id="608">, misto de romance</segment>
    <segment id="609">, reportagem e crônica centrado na figura de Ernesto Cony Filho</segment>
    <segment id="610">, obra que marcou a sua volta ao mundo da ficção.</segment>
    <segment id="611">Mais do que elogio à personagem pitoresca do velho jornalista</segment>
    <segment id="612">, trata-</segment>
    <segment id="613">sese de um lírico pedido de desculpas do filho pelo desprezo que sempre alimentara em relação ao pai.</segment>
    <segment id="614">Mila, a cadela</segment>
    <segment id="615">, morreria poucos dias antes de encerrar-</segment>
    <segment id="616">sese o livro</segment>
    <segment id="617">, que é a ela dedicado.</segment>
    <segment id="618">O êxito de crítica e de público desse &amp;</segment>
    <segment id="619">quot;quase romance&amp;quot</segment>
    <segment id="620">; levou Cony a deixar para trás a promessa</segment>
    <segment id="621">, feita mais de vinte anos antes</segment>
    <segment id="622">, de abandonar a literatura.</segment>
    <segment id="623">Aos 70 anos de idade</segment>
    <segment id="624">, ele inaugura uma nova avalanche de romances: &amp;quot</segment>
    <segment id="625">;O Piano e a Orquestra&amp;quot</segment>
    <segment id="626">; (1996)</segment>
    <segment id="627">, &amp;quot</segment>
    <segment id="628">;A</segment>
    <segment id="629">Casa do Poeta Trágico&amp;quot</segment>
    <segment id="630">; (1997)</segment>
    <segment id="631">, &amp;quot</segment>
    <segment id="632">;Romance sem Palavras&amp;quot</segment>
    <segment id="633">; (1999)</segment>
    <segment id="634">, &amp;quot</segment>
    <segment id="635">;O Indigitado&amp;quot</segment>
    <segment id="636">; (2001)</segment>
    <segment id="637">, &amp;quot</segment>
    <segment id="638">;A</segment>
    <segment id="639">Tarde da sua Ausência&amp;quot</segment>
    <segment id="640">; (2003) e &amp;quot</segment>
    <segment id="641">;O</segment>
    <segment id="642">Adiantado da Hora&amp;quot</segment>
    <segment id="643">; (2006).Com esses livros</segment>
    <segment id="644">, receberá sucessivamente oito prêmios literários</segment>
    <segment id="645">, dentre eles o &amp;quot</segment>
    <segment id="646">;Machado de Assis&amp;quot</segment>
    <segment id="647">;, da Academia Brasileira de Letras (ABL)</segment>
    <segment id="648">, pelo conjunto da obra</segment>
    <segment id="649">, em julho de 1996.</segment>
    <segment id="650">No mesmo ano</segment>
    <segment id="651">, em agosto</segment>
    <segment id="652">, passa a integrar o Conselho Editorial da Folha e a assinar uma coluna na Ilustrada aos sábados.</segment>
    <segment id="653">Retoma a rotina de conferências em universidades ou instituições culturais</segment>
    <segment id="654">, passa a fazer comentários em rádio.</segment>
    <segment id="655">Em 1998</segment>
    <segment id="656">, recebe do governo francês</segment>
    <segment id="657">, em Paris</segment>
    <segment id="658">, a comenda de Chevalier da Ordre des Arts et des Lettres.</segment>
    <segment id="659">Em março de 2000</segment>
    <segment id="660">, é eleito para a cadeira número 3 da ABL</segment>
    <segment id="661">, com 25 dos 37 votos possíveis.</segment>
    <segment id="662">O pessimismo desabrido e incisivo</segment>
    <segment id="663">, os comentários ferinos e a postura amarga de &amp;quot</segment>
    <segment id="664">;soy contra&amp;quot</segment>
    <segment id="665">; &amp;ndash</segment>
    <segment id="666">;em especial dirigida os governos de plantão (antes João Goulart ou os militares</segment>
    <segment id="667">, depois FHC ou Lula)- certamente levou muita gente a imaginar Cony</segment>
    <segment id="668">comocomo um homem intratável e rabugento.</segment>
    <segment id="669">Nada mais falso</segment>
    <segment id="670">, porém</segment>
    <segment id="671">porém.</segment>
    <segment id="672">Divertido</segment>
    <segment id="673">, com um brilho quase infantil nos olhos pequeninos</segment>
    <segment id="674">, fácil de fala</segment>
    <segment id="675">, Cony era um sedutor de conversa rica e sempre prolongada.</segment>
    <segment id="676">Um galanteador irreverente</segment>
    <segment id="677">, cético e meio cínico.</segment>
    <segment id="678">Brincalhão e autoirônico.</segment>
    <segment id="679">Quase sempre calçava tênis</segment>
    <segment id="680">, trajes descontraídos</segment>
    <segment id="681">, com um discreto charme nos onipresentes suspensórios.</segment>
    <segment id="682">Em palestras</segment>
    <segment id="683">, era envolvente e fazia rir com facilidade.</segment>
    <segment id="684">Alimentava muitas histórias</segment>
    <segment id="685">, às vezes sugestivamente fantasiosas</segment>
    <segment id="686">, sobre si mesmo.</segment>
    <segment id="687">Entre a memória e a invenção</segment>
    <segment id="688">, seus textos &amp;ndash</segment>
    <segment id="689">;seja na crônica seja no romance-e suas entrevistas transpiram essa figura.</segment>
    <segment id="690">Em 2016</segment>
    <segment id="691">, em entrevista à Folha</segment>
    <segment id="692">, disse que havia retomado o projeto do livro &amp;quot</segment>
    <segment id="693">;Messa pro Papa Marcello&amp;quot</segment>
    <segment id="694">;, espécie de continuação de &amp;quot</segment>
    <segment id="695">;Informação ao Crucificado&amp;quot</segment>
    <segment id="696">;</segment>
    <segment id="697">(1961).Nas instituições por que passou</segment>
    <segment id="698">, Cony sabia aliar o estilo informal</segment>
    <segment id="699">, às vezes galhofeiro</segment>
    <segment id="700">, ao rigor cerimonial das reuniões e ao cumprimento dos prazos imperativos da produção editorial.</segment>
    <segment id="701">Assim nos tempos da &amp;quot</segment>
    <segment id="702">;Manchete&amp;quot</segment>
    <segment id="703">; e mais tarde na Folha</segment>
    <segment id="704">;</segment>
    <segment id="705">assim nos compromissos da Academia.</segment>
    <segment id="706">Embora agnóstico</segment>
    <segment id="707">, mantinha em casa uma pequena imagem de Santo Antônio.</segment>
    <segment id="708">Nos últimos anos</segment>
    <segment id="709">, especialmente a partir de um problema grave de saúde sofrido em 1991 que o levou à UTI de um hospital e a sofrer uma anestesia de nove horas de duração</segment>
    <segment id="710">, tornou pública uma revisão interna a respeito do tema (religiosidade).</segment>
    <segment id="711">Em depoimentos</segment>
    <segment id="712">, manifestou apego a santos (José e Maria</segment>
    <segment id="713">, além de Antônio) e uma aproximação com a ideia da existência de Deus.</segment>
    <segment id="714">Tal movimento deveria</segment>
    <segment id="715">sese expressar</segment>
    <segment id="716">, ou melhor</segment>
    <segment id="717">, deveria burilar sua própria definição na escritura do romance &amp;quot</segment>
    <segment id="718">;Messa pro Papa Marcello&amp;quot</segment>
    <segment id="719">;, um projeto de décadas</segment>
    <segment id="720">, sintomaticamente inacabado.</segment>
    <segment id="721">Nele, o ex-seminarista em crise João Falcão</segment>
    <segment id="722">, de &amp;quot</segment>
    <segment id="723">;Informação ao Crucificado&amp;quot</segment>
    <segment id="724">;, ressurgiria muitos anos depois</segment>
    <segment id="725">, buscando resolver seu &amp;quot</segment>
    <segment id="726">;drama&amp;quot</segment>
    <segment id="727">; religioso</segment>
    <segment id="728">, o mistério íntimo que Cony &amp;ndash</segment>
    <segment id="729">;homem que sempre escreveu com rapidez e facilidade&amp;ndash</segment>
    <segment id="730">; aparentemente nunca logrou solucionar.</segment>
    <segment id="731">Em 2001</segment>
    <segment id="732">, surgiu outro problema de saúde</segment>
    <segment id="733">, que o acompanhou até a morte: o escritor foi diagnosticado com um câncer linfático.</segment>
    <segment id="734">Com a quimioterapia</segment>
    <segment id="735">, perdeu força nos braços e nas pernas.</segment>
    <segment id="736">Em 2013</segment>
    <segment id="737">, levou um tombo na Feira de Frankfurt.</segment>
    <segment id="738">O impacto gerou um coágulo em seu cérebro.</segment>
    <segment id="739">Bernardo Ajzenberg</segment>
    <segment id="740">, jornalista e escritor</segment>
    <segment id="741">, ex-ombudsman da Folha</segment>
    <segment id="742">, é autor de &amp;quot</segment>
    <segment id="743">;Gostar de Ostras&amp;quot</segment>
    <segment id="744">; (Rocco)</segment>
    <segment id="745">, entre outros..</segment>
  </rst>
</analysis>