  <rst>
    <segment id="1">Líderes mundiais repercutiram a morte de Pelé</segment>
    <segment id="2">, aos 82 anos</segment>
    <segment id="3">, nesta quinta-feira (29).</segment>
    <segment id="4">Um deles foi Joe Biden.</segment>
    <segment id="5">O presidente dos EUA publicou uma foto sua junto ao Rei em um estádio lotado.</segment>
    <segment id="6">No Twitter</segment>
    <segment id="7">, o norte-americano escreveu que no esporte que une o mundo</segment>
    <segment id="8">comocomo nenhum outro</segment>
    <segment id="9">, a ascensão de Pelé</segment>
    <segment id="10">, de origem humilde a uma lenda do futebol</segment>
    <segment id="11">, é uma história possível.</segment>
    <segment id="12">Outro foi Barack Obama</segment>
    <segment id="13">, ex-presidente dos EUA</segment>
    <segment id="14">, que conheceu Pelé em 2019</segment>
    <segment id="15">, em São Paulo</segment>
    <segment id="16">, durante uma visita ao Brasil.</segment>
    <segment id="17">Na ocasião</segment>
    <segment id="18">, Pelé</segment>
    <segment id="19">, que se</segment>
    <segment id="20">se recuperava de uma infecção urinária</segment>
    <segment id="21">, entregou uma camisa da seleção brasileira para o ex-presidente americano.</segment>
    <segment id="22">"</segment>
    <segment id="23">Para presidente</segment>
    <segment id="24">Obama com abraço</segment>
    <segment id="25">, Edson Pelé".</segment>
    <segment id="26">Barack Obama e Pelé</segment>
    <segment id="27">, durante encontro em 30 de maio de 2019</segment>
    <segment id="28">, em São Paulo - Jânio Quadros NetoObama disse então que o ex-jogador era a "única lenda viva que ele queria conhecer e ainda não havia conhecido"</segment>
    <segment id="29">, o que Pelé retribuiu dizendo que era um admirador "de longa data" de ex-presidente.</segment>
    <segment id="30">Após ter conhecimento da morte do Rei do futebol</segment>
    <segment id="31">, Obama publicou no Twitter: "</segment>
    <segment id="32">Pelé foi um dos maiores que já jogou o belo jogo.</segment>
    <segment id="33">E, como</segment>
    <segment id="34">como um dos atletas mais reconhecidos do mundo</segment>
    <segment id="35">, ele entendeu o poder do esporte para unir as pessoas.</segment>
    <segment id="36">Nossos pensamentos estão com sua família e todos que o amavam e admiravam".</segment>
    <segment id="37">Presidentes também prestaram homenagens ao Rei do futebol.</segment>
    <segment id="38">"</segment>
    <segment id="39">Nos deixou um dos melhores futebolistas da história.</segment>
    <segment id="40">Recordaremos sempre daqueles anos em que Pelé deslumbrou o mundo com suas habilidades.</segment>
    <segment id="41">Um grande abraço a sua família e ao povo do Brasil</segment>
    <segment id="42">, que o levará no coração"</segment>
    <segment id="43">, disse Alberto Fernández</segment>
    <segment id="44">, presidente da Argentina.</segment>
    <segment id="45">Já o presidente da França</segment>
    <segment id="46">, Emmanuel Macro</segment>
    <segment id="47">, postou uma foto de Pelé com os dizeres: "</segment>
    <segment id="48">O Jogo.</segment>
    <segment id="49">O Rei.</segment>
    <segment id="50">A Eternidade.</segment>
    <segment id="51">A primeira-ministra da Itália</segment>
    <segment id="52">, Giorgia Meloni</segment>
    <segment id="53">, afirmou que "graças ao seu talento e à sua classe"</segment>
    <segment id="54">, Pelé "conseguiu deixar a sua marca mesmo nas gerações que não tiveram a sorte de o ver jogar".</segment>
    <segment id="55">"</segment>
    <segment id="56">Hoje o mundo inteiro chora uma lenda chamada Pelé.</segment>
    <segment id="57">"  Viktor Orbán</segment>
    <segment id="58">, da Hungria</segment>
    <segment id="59">, publicou uma foto ao lado do ex-jogador e lembrou que ele era único.</segment>
    <segment id="60">Em português escreveu "</segment>
    <segment id="61">Adeus Lenda!</segment>
    <segment id="62">"</segment>
    <segment id="63">O presidente da Colômbia</segment>
    <segment id="64">, Gustavo Petro</segment>
    <segment id="65">, lembrou que "quando criança</segment>
    <segment id="66">, assisti</segment>
    <segment id="67">Pelé na Copa do Mundo de futebol em uma tela em preto e branco.</segment>
    <segment id="68">Meu pai me disse que eu era o melhor jogador de futebol do mundo.</segment>
    <segment id="69">Hoje acho que meu pai tinha razão"</segment>
    <segment id="70">, disse ele</segment>
    <segment id="71">, que completou: "</segment>
    <segment id="72">Uma mensagem de solidariedade à sua família e a todos os brasileiros que tanto o amavam".</segment>
    <segment id="73">Nicolás Maduro</segment>
    <segment id="74">, da Venezuela</segment>
    <segment id="75">, afirmou que partiu para a eternidade um dos maiores jogadores de futebol da história</segment>
    <segment id="76">, Edson Arantes do Nascimento</segment>
    <segment id="77">, o grande Pelé.</segment>
    <segment id="78">"</segment>
    <segment id="79">Da Venezuela expressamos nossas condolências a seus familiares</segment>
    <segment id="80">, amigos e à grande torcida que o recordará para sempre.</segment>
    <segment id="81">Viva Pelé.</segment>
    <segment id="82">"</segment>
    <segment id="83">O presidente Andrés Manuel López Obrador</segment>
    <segment id="84">, do México</segment>
    <segment id="85">, país em que Pelé conquistou o tricampeonato mundial</segment>
    <segment id="86">, destacou o papel de influência do craque em futuras gerações de jogadores do Brasil e mundo.</segment>
    <segment id="87">"</segment>
    <segment id="88">Que descanse em paz</segment>
    <segment id="89">, Pelé</segment>
    <segment id="90">, o grande jogador e humilde professor que certamente influenciou jogadores</segment>
    <segment id="91">comocomo Ronaldinho com seu exemplo".</segment>
    <segment id="92">Evo Morales</segment>
    <segment id="93">, ex-presidente da Bolívia</segment>
    <segment id="94">, chamou Edson Arantes do Nascimento de irmão e de melhor jogador de futebol brasileiro do mundo.</segment>
    <segment id="95">"</segment>
    <segment id="96">Pelé viverá para sempre na memória daqueles que admiram e praticam futebol.</segment>
    <segment id="97">".</segment>
    <segment id="98">Quem também citou que Pelé influenciou gerações foi Antony Blinken</segment>
    <segment id="99">, secretário de Estado dos EUA</segment>
    <segment id="100">, responsável pela diplomacia do país.</segment>
    <segment id="101">"</segment>
    <segment id="102">Pelé era uma verdadeira lenda</segment>
    <segment id="103">;</segment>
    <segment id="104">não havia ninguém</segment>
    <segment id="105">comocomo ele.</segment>
    <segment id="106">Mas ele também transcendeu o jogo e inspirou gerações dentro e fora do campo".</segment>
    <segment id="107">Já a embaixadora da Suécia no Brasil</segment>
    <segment id="108">, Karin Wallensteen</segment>
    <segment id="109">, lembrou dos laços de seu país com o maior futebolista da história</segment>
    <segment id="110">, já que foi em solo sueco onde Pelé e o Brasil conquistaram pela primeira vez a Copa do Mundo.</segment>
    <segment id="111">"</segment>
    <segment id="112">Pelé não foi apenas uma estrela do futebol</segment>
    <segment id="113">, masmas um jogador de futebol muito amado na Suécia</segment>
    <segment id="114">, após a Copa do Mundo de 1958.</segment>
    <segment id="115">Lamentamos e choramos junto com o Brasil a morte deste ícone do futebol.</segment>
    <segment id="116">"</segment>
    <segment id="117">Veja fotos de Pelé com diferentes personalidades do Brasil e do mundoMais    novamente         de   de  de  representando um  LEIA MAIS SOBRE PELÉCâncer de Pelé progrediu</segment>
    <segment id="118">, e tratamento não surtiu efeitoPelé</segment>
