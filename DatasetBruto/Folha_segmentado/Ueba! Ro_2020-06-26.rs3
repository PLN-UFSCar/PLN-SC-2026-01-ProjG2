  <rst>
    <segment id="1">Buemba!</segment>
    <segment id="2">Buemba!</segment>
    <segment id="3">Macaco Sim&amp;atilde</segment>
    <segment id="4">;o Urgente!</segment>
    <segment id="5">O esculhambador-geral da Rep&amp;uacute</segment>
    <segment id="6">;blica!</segment>
    <segment id="7">O Queiroz que sabe</segment>
    <segment id="8">sese cuidar: foi do isolamento direto pro lockdown!</segment>
    <segment id="9">Rarar&amp;aacute</segment>
    <segment id="10">;!  E a ora&amp;ccedil</segment>
    <segment id="11">;&amp;atilde</segment>
    <segment id="12">;o do casal Bolsonaro: &amp;ldquo</segment>
    <segment id="13">;Fabricio Queiroz/</segment>
    <segment id="14">Tende piedade de n&amp;oacute</segment>
    <segment id="15">;s&amp;rdquo</segment>
    <segment id="16">;.</segment>
    <segment id="17">N&amp;atilde</segment>
    <segment id="18">;o tenha!</segment>
    <segment id="19">Piedade &amp;eacute</segment>
    <segment id="20">;</segment>
    <segment id="21">para os fracos!</segment>
    <segment id="22">Rarar&amp;aacute</segment>
    <segment id="23">;!Fê/FolhapressFê/FolhapressE sabe o que o Bolsonaro falou dos gafanhotos?</segment>
    <segment id="24">S&amp;atilde</segment>
    <segment id="25">;o apenas uns grilinhos!</segment>
    <segment id="26">Rarar&amp;aacute</segment>
    <segment id="27">;!</segment>
    <segment id="28">E o Fl&amp;aacute</segment>
    <segment id="29">;vio ganhou DESAFORO PRIVILEGIADO!</segment>
    <segment id="30">Isso n&amp;atilde</segment>
    <segment id="31">;o estava no roteiro!</segment>
    <segment id="32">Ali&amp;aacute</segment>
    <segment id="33">;s, o roteirista do Brasil renunciou!</segment>
    <segment id="34">Rarar&amp;aacute</segment>
    <segment id="35">;!</segment>
    <segment id="36">E j&amp;aacute</segment>
    <segment id="37">; acharam a mulher do Queiroz?</segment>
    <segment id="38">Acharam a OUTRA METADE DA LARANJA?</segment>
    <segment id="39">Rarar&amp;aacute</segment>
    <segment id="40">;!</segment>
    <segment id="41">Em Rio das Pedras rodeada de milicianos por todos os lados!</segment>
    <segment id="42">&amp;Ocirc</segment>
    <segment id="43">;</segment>
    <segment id="44">fam&amp;iacute</segment>
    <segment id="45">;lia boa de esconderijo!</segment>
    <segment id="46">E a pol&amp;iacute</segment>
    <segment id="47">;cia que ficou procurando em casa de parente?</segment>
    <segment id="48">Se voc&amp;ecirc</segment>
    <segment id="49">; fosse foragido voc&amp;ecirc</segment>
    <segment id="50">; ia se</segment>
    <segment id="51">se esconder na casa do seu irm&amp;atilde</segment>
    <segment id="52">;o?</segment>
    <segment id="53">Rarar&amp;aacute</segment>
    <segment id="54">;!  Fabricio Queiroz em Atibaia   novamente         de   de  de  representando um  E aten&amp;ccedil</segment>
    <segment id="55">;&amp;atilde</segment>
    <segment id="56">;o!</segment>
    <segment id="57">Piaui Herald: &amp;ldquo</segment>
    <segment id="58">;Nuvem de gafanhotos da Argentina desvia do Brasil para n&amp;atilde</segment>
    <segment id="59">;o enfrentar o governo Bolsonaro!</segment>
    <segment id="60">Foram pro Uruguai!</segment>
    <segment id="61">Queimar um fumo!</segment>
    <segment id="62">Aqui no Brasil s&amp;oacute</segment>
    <segment id="63">; tem agrot&amp;oacute</segment>
    <segment id="64">;xico e garimpo</segment>
    <segment id="65">, t&amp;aacute</segment>
    <segment id="66">; tudo desmatado!</segment>
    <segment id="67">Rarar&amp;aacute</segment>
    <segment id="68">;!</segment>
    <segment id="69">Aqui j&amp;aacute</segment>
    <segment id="70">; temos as sete pragas do Egito: o v&amp;iacute</segment>
    <segment id="71">;rus, o Bozo</segment>
    <segment id="72">, o Crivella</segment>
    <segment id="73">, mil&amp;iacute</segment>
    <segment id="74">;cia, live do Luan Santana e aquele fantasiado de papagaio</segment>
    <segment id="75">, o V&amp;eacute</segment>
    <segment id="76">;io da Havan.</segment>
    <segment id="77">Rarar&amp;aacute</segment>
    <segment id="78">;!</segment>
    <segment id="79">Podia ser pior:</segment>
    <segment id="80">ter um gafanhoto</segment>
    <segment id="81">comocomo presidente e estar vindo uma nuvem de bolsonaros!</segment>
    <segment id="82">Rarar&amp;aacute</segment>
    <segment id="83">;!</segment>
    <segment id="84">A Argentina s&amp;oacute</segment>
    <segment id="85">; manda frente fria e gafanhoto!</segment>
    <segment id="86">Festival de Piadas Prontas!</segment>
    <segment id="87">1)&amp;rdquo</segment>
    <segment id="88">;Vereador cheira calcinha durante sess&amp;atilde</segment>
    <segment id="89">;o virtual na C&amp;acirc</segment>
    <segment id="90">;mara de Bragan&amp;ccedil</segment>
    <segment id="91">;a Paulista.&amp;rdquo</segment>
    <segment id="92">;</segment>
    <segment id="93">O vereador ficou cheirando uma calcinha vermelha sem desligar a c&amp;acirc</segment>
    <segment id="94">;mera!</segment>
    <segment id="95">O v&amp;iacute</segment>
    <segment id="96">;deo &amp;eacute</segment>
    <segment id="97">; hil&amp;aacute</segment>
    <segment id="98">;rio: uma vereadora falando s&amp;eacute</segment>
    <segment id="99">;rio sobre abate de &amp;aacute</segment>
    <segment id="100">;rvores e ele cheirando calcinha!</segment>
    <segment id="101">Pior, o vereador</segment>
    <segment id="102">sese chama Ditinho do Asilo.</segment>
    <segment id="103">E diz que a calcinha era de sex shop e presente de um amigo!</segment>
    <segment id="104">E o Ditinho &amp;eacute</segment>
    <segment id="105">; do PSC: Partido Social da Calcinha!</segment>
    <segment id="106">Rarar&amp;aacute</segment>
    <segment id="107">;!  2) &amp;ldquo</segment>
    <segment id="108">;Funcion&amp;aacute</segment>
    <segment id="109">;rios do Banco Mundial pedem suspens&amp;atilde</segment>
    <segment id="110">;o da nomea&amp;ccedil</segment>
    <segment id="111">;&amp;atilde</segment>
    <segment id="112">;o de Weintraub.&amp;rdquo</segment>
    <segment id="113">; Ningu&amp;eacute</segment>
    <segment id="114">;m quer esse traste.</segment>
    <segment id="115">WEINTRASTE!</segment>
    <segment id="116">O Bozo s&amp;oacute</segment>
    <segment id="117">;</segment>
    <segment id="118">manda buscap&amp;eacute</segment>
    <segment id="119">; pros outros!</segment>
    <segment id="120">Rarar&amp;aacute</segment>
    <segment id="121">;!  3) &amp;ldquo</segment>
    <segment id="122">;Grupo bolsonarista &amp;eacute</segment>
    <segment id="123">; preso em ch&amp;aacute</segment>
    <segment id="124">;cara para treinamento militar no DF</segment>
    <segment id="125">, regi&amp;atilde</segment>
    <segment id="126">;o de Rajadinha.&amp;rdquo</segment>
    <segment id="127">;</segment>
    <segment id="128">Mas doutor delegado</segment>
    <segment id="129">, era s&amp;oacute</segment>
    <segment id="130">; uma rajadinha!.</segment>
    <segment id="131">Rumo ao Supremo.</segment>
    <segment id="132">Rarar&amp;aacute</segment>
    <segment id="133">;!  4) &amp;ldquo</segment>
    <segment id="134">;Wassef vende terreno em brejo para ex-mulher por R$2</segment>
    <segment id="135">,9 mi.&amp;rdquo</segment>
    <segment id="136">;</segment>
    <segment id="137">Adivinha onde era o brejo?</segment>
    <segment id="138">Atibaia!</segment>
    <segment id="139">Pior, o Wassef j&amp;aacute</segment>
    <segment id="140">;</segment>
    <segment id="141">escondeu o Queiroz no Guaruj&amp;aacute</segment>
    <segment id="142">;!</segment>
    <segment id="143">Olha, Atibaia e Guaruj&amp;aacute</segment>
    <segment id="144">; &amp;eacute</segment>
    <segment id="145">; copirraite do Lula.</segment>
    <segment id="146">O Lula vai pedir direitos autorais pro roteirista do Brasil!</segment>
    <segment id="147">N&amp;oacute</segment>
    <segment id="148">;is sofre</segment>
    <segment id="149">masmas n&amp;oacute</segment>
    <segment id="150">;is goza!</segment>
    <segment id="151">Que eu vou pingar o meu col&amp;iacute</segment>
    <segment id="152">;rio alucin&amp;oacute</segment>
    <segment id="153">;geno!</segment>
  </rst>
