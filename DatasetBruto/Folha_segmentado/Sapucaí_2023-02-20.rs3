  <rst>
    <segment id="1">Ministra da Cultura do governo Lula</segment>
    <segment id="2">, Margareth Menezes cruzou apressada o corredor lateral da Marquês de Sapucaí</segment>
    <segment id="3">, no Rio de Janeiro</segment>
    <segment id="4">, e foi direto para a concentração da Mangueira.</segment>
    <segment id="5">A ministra da Cultura</segment>
    <segment id="6">, Margareth Menezes</segment>
    <segment id="7">, sese apresenta no camarote Favela</segment>
    <segment id="8">, na Marquês de Sapucaí</segment>
    <segment id="9">, no Rio de Janeiro</segment>
    <segment id="10">, durante o primeiro dia de desfiles - @margarethmenezes no InstagramDestaque da última escola a desfilar na madrugada desta segunda-feira (20)</segment>
    <segment id="11">, a cantora bem que tentou passar</segment>
    <segment id="12">comocomo anônima pelos foliões</segment>
    <segment id="13">, masmas não deu.</segment>
    <segment id="14">"</segment>
    <segment id="15">É a ministra"</segment>
    <segment id="16">, gritava um.</segment>
    <segment id="17">"</segment>
    <segment id="18">Ei, faraó"</segment>
    <segment id="19">, cantarolava outro</segment>
    <segment id="20">, em referência à célebre canção da artista.</segment>
    <segment id="21">Margareth sorria.</segment>
    <segment id="22">Apesar da correria —e da truculência de um dos seguranças—</segment>
    <segment id="23">, a ministra falou rapidamente sobre o seu primeiro Carnaval desde que chegou à Esplanada dos Ministérios.</segment>
    <segment id="24">"</segment>
    <segment id="25">O Carnaval é a cara da cultura do Brasil.</segment>
    <segment id="26">[Ele reúne] todas as manifestações culturais.</segment>
    <segment id="27">Coisa linda.</segment>
    <segment id="28">"  Famosos e personalidades no Carnaval do Rio em 2023Mais    novamente         de   de  de  representando um    Margareth afirmou que recebeu o convite para desfilar na Mangueira antes de ser chamada para compor o governo do presidente Luiz Inácio Lula da Silva (PT).</segment>
    <segment id="29">"</segment>
    <segment id="30">A escola está homenageando a Bahia no enredo.</segment>
    <segment id="31">Os diretores foram lá</segment>
    <segment id="32">, pesquisaram e me convidaram.</segment>
    <segment id="33">E eu aceitei.</segment>
    <segment id="34">"</segment>
    <segment id="35">A cantora já desfilou outras vezes na Sapucaí.</segment>
    <segment id="36">"</segment>
    <segment id="37">Desfilei duas vezes.</segment>
    <segment id="38">[Uma delas foi pela] Unidos de Viradouro</segment>
    <segment id="39">, fomos campeões"</segment>
    <segment id="40">, relembra.</segment>
    <segment id="41">Se ela</segment>
    <segment id="42">sese considera pé quente e acredita que pode repetir o feito?</segment>
    <segment id="43">"Espero fazer de novo"</segment>
    <segment id="44">, diz, aos risos.</segment>
    <segment id="45">"</segment>
    <segment id="46">Vamos lá!</segment>
    <segment id="47">"</segment>
  </rst>
</analysis>