  <rst>
    <segment id="1">O primeiro grande desfile do ano</segment>
    <segment id="2">, o tapete vermelho do 80º Globo de Ouro</segment>
    <segment id="3">, em Hollywood</segment>
    <segment id="4">, teve bastante vestuário com brilho e os já esperados belos vestidos femininos.</segment>
    <segment id="5">Boa parte dos homens optou pelo clássico terno e gravata</segment>
    <segment id="6">, para não errar</segment>
    <segment id="7">, masmas houve algumas boas surpresas dentro deste tema.</segment>
    <segment id="8">Contudo</segment>
    <segment id="9">, ao final das duas horas de badalação no tapete vermelho</segment>
    <segment id="10">, o que ficou foi a sensação de que nenhum look foi arrebatador</segment>
    <segment id="11">, capaz de gerar muitos comentários nas redes sociais</segment>
    <segment id="12">, embora</segment>
    <segment id="13">embora as estrelas vestissem alta-costura feita com exclusividade.</segment>
    <segment id="14">A recepção dos convidados ficou a cargo de Laverne Cox</segment>
    <segment id="15">, atriz que fez fama com o seriado "Orange is the New Black".</segment>
    <segment id="16">Ela estava glamurosa</segment>
    <segment id="17">, com um vestido drapeado em azul com detalhes grandes em prata e uma grande fenda nas costas</segment>
    <segment id="18">, completo por seu penteado tipo Marilyn Monroe.</segment>
    <segment id="19">Laverne Cox</segment>
    <segment id="20">, a apresentadora do Globo de Ouro - Mario Anzuoni -10.jan.23/ReutersCox recebia as estrelas em um hotel em Beverly Hills com a pergunta em tom alto astral "que história você quer contar com sua roupa?</segment>
    <segment id="21">".</segment>
    <segment id="22">Um dos apresentadores da cerimônia</segment>
    <segment id="23">, Colman Domingo</segment>
    <segment id="24">, chegou de terno brilhante desenhado por Dolce &amp;amp</segment>
    <segment id="25">; Gabbana e disse que queria "brilhar</segment>
    <segment id="26">comocomo um diamante negro".  Sheryl Lee Ralph</segment>
    <segment id="27">, na lista de melhor atriz coadjuvante por "Abbott Elementary"</segment>
    <segment id="28">, adentrou com um vestido roxo bordado da estilista Ivy Victoria-Maurice que levou</segment>
    <segment id="29">, segundo ela</segment>
    <segment id="30">, 960 horas para ser feito</segment>
    <segment id="31">Veja looks do tapete vermelho do Globo de OuroMais    novamente         de   de  de  representando um</segment>
    <segment id="32">O ator Eddie Redmayne</segment>
    <segment id="33">, de "</segment>
    <segment id="34">O Enfermeiro da Noite"</segment>
    <segment id="35">, apareceu usando terno preto Valentino com uma flor na mesma cor do lado esquerdo do peito.</segment>
    <segment id="36">Numa gracinha</segment>
    <segment id="37">, ele vestia uma camiseta</segment>
    <segment id="38">, e não uma camisa</segment>
    <segment id="39">, por baixo do casaco.</segment>
    <segment id="40">Outro que chegou com uma flor presa ao paletó foi o ator de "Narcos"</segment>
    <segment id="41">Diego</segment>
    <segment id="42">Cava.</segment>
    <segment id="43">Já o cantor de rap Babyface não vestia camiseta nem camisa</segment>
    <segment id="44">, e sim mostrava o peito nu sob seu terno preto</segment>
    <segment id="45">, no melhor estilo Timothée Chalamet no Oscar do ano passado.</segment>
    <segment id="46">De peito à mostra também estava Donald Glover</segment>
    <segment id="47">, vestindo um robe branco sob um longo terno preto sem abotoar —"só quero estar confortável"</segment>
    <segment id="48">, disse ele sobre seu look.</segment>
    <segment id="49">Ele concorria</segment>
    <segment id="50">comocomo melhor ator pela série "Atlanta".</segment>
    <segment id="51">Jamie Lee Curtis</segment>
    <segment id="52">, que concorreu por melhor atriz coadjuvante pelo longa "</segment>
    <segment id="53">Tudo em Todo Lugar ao Mesmo Tempo"</segment>
    <segment id="54">, vestia um macacão preto sem mangas com uma capa de renda na mesma cor.</segment>
    <segment id="55">Seu look era clássico e esvoaçante ao mesmo tempo.</segment>
    <segment id="56">Jamie Lee Curtis</segment>
    <segment id="57">, que concorre</segment>
    <segment id="58">comocomo atriz coadjuvante por &amp;#039</segment>
    <segment id="59">;Tudo em Todo Lugar ao Mesmo Tempo&amp;#039</segment>
    <segment id="60">;, mostra seu look - Frederic J. Brown -10.jan.23/AFPEmma D’Arcy</segment>
    <segment id="61">, no páreo pelo troféu de melhor atriz por "</segment>
    <segment id="62">A Casa do Dragão"</segment>
    <segment id="63">, veio de cabelo roxo e black tie oversized com uma maquiagem algo sinistra —uma lágrima escorria de seu olho esquerdo.</segment>
    <segment id="64">O look</segment>
    <segment id="65">, ela afirmou</segment>
    <segment id="66">, era o de uma criança prodígio que toca piano</segment>
    <segment id="67">masmas que participou de um recital que não foi bem.  Jeremy Pope</segment>
    <segment id="68">, no páreo pela láurea de melhor ator por "The Inspection"</segment>
    <segment id="69">, foi de casaco e calça de couro</segment>
    <segment id="70">, e é de</segment>
    <segment id="71">sese perguntar</segment>
    <segment id="72">sese ele não estava sentindo bastante calor.</segment>
    <segment id="73">Já Seth Rogen apareceu de terno salmão</segment>
    <segment id="74">, estranhíssimo.</segment>
    <segment id="75">Mas, esquisitices à parte</segment>
    <segment id="76">, boa parte dos convidados não ousou.</segment>
    <segment id="77">Austin Butler</segment>
    <segment id="78">, que fez o papel de Elvis Presley em "Elvis" e por isso concorria</segment>
    <segment id="79">comocomo melhor ator</segment>
    <segment id="80">, estava com um clássico black tie.</segment>
    <segment id="81">O cineasta Quentin Tarantino apareceu de terno</segment>
    <segment id="82">, camisa</segment>
    <segment id="83">, gravata e calça pretas</segment>
    <segment id="84">, sem erro.</segment>
    <segment id="85">Jeremy Pope veste couro dos pés à cabeça - Getty Images via AFPJenniffer</segment>
    <segment id="86">Coolidge</segment>
    <segment id="87">, a atriz do seriado "The White Louts" famosa pelo meme "these gays are trying to kill me"</segment>
    <segment id="88">, ou estes gays estão tentando me matar</segment>
    <segment id="89">, estava de vestido preto brilhoso com decote amplo</segment>
    <segment id="90">, um look de festa tradicional e elegante</segment>
    <segment id="91">, assinado pela dupla Dolce &amp;amp</segment>
    <segment id="92">;</segment>
    <segment id="93">Gabbana.</segment>
    <segment id="94">Jean Smart também estava elegante —e sexy—</segment>
    <segment id="95">, com um vestido preto de decote V acompanhado de bolsa da mesma cor.</segment>
    <segment id="96">Ela concorria</segment>
    <segment id="97">comocomo melhor atriz por "Hacks".</segment>
    <segment id="98">Sim, havia roupas para ver e desejar.</segment>
    <segment id="99">Mas nada passou perto do lacrador</segment>
    <segment id="100">, num sinal de contenção dos convidados que pode ter a ver com a tentativa do Globo de Ouro de restabelecer sua reputação de premiação séria depois de ser acusado de corrupção e falta de diversidade entre os votantes e quase ruir.</segment>
    <segment id="101">Vale notar a ausência de estrelas vestindo Vivienne Westwood</segment>
    <segment id="102">, uma das mais importantes estilistas britânicas</segment>
    <segment id="103">, que acaba de morrer.</segment>
    <segment id="104">Oportunidade perdida de homenagear a madrinha do punk.</segment>
    <segment id="105">Leia mais sobre o Globo de Ouro 2023Spielberg</segment>
    <segment id="106">, Zendaya e &amp;#039</segment>
    <segment id="107">;The White Lotus&amp;#039</segment>
    <segment id="108">; vencem Globo de Ouro</segment>
    <segment id="109">; veja premiadosDepois da Copa</segment>
    <segment id="110">, é uma alegria</segment>
    <segment id="111">, diz Darín</segment>
    <segment id="112">, após vitória no Globo de Ouro&amp;#039</segment>
    <segment id="113">;The White Lotus&amp;#039</segment>
    <segment id="114">;, da HBO</segment>
    <segment id="115">, vence Globo de Ouro de melhor minissérieVolodimir Zelenski faz discurso em vídeo na cerimônia do Globo de OuroGlobo de Ouro coroa Spielberg</segment>
    <segment id="116">, foge da crise e aposta na diversidadeFamosos não ousam nos looks no tapete vermelho do Globo de Ouro</segment>
  </rst>
