    </relations>
  </header>
  <rst>
    <segment id="1">Qual seria a probabilidade de a primeira estudante brasileira a ingressar na então única universidade de língua portuguesa ter o nome América do Sul?</segment>
    <segment id="2">Seriam elas pequenas?</segment>
    <segment id="3">Mínimas!</segment>
    <segment id="4">Talvez até nulas.</segment>
    <segment id="5">No entanto</segment>
    <segment id="6">, a realidade</segment>
    <segment id="7">sese desdobrou de forma surpreendente</segment>
    <segment id="8">, pois</segment>
    <segment id="9">pois foi exatamente isso que o destino ditou.</segment>
    <segment id="10">Iniciei a coluna com o intuito de desvelar a saga de América do Sul</segment>
    <segment id="11">Fontes</segment>
    <segment id="12">Monteiro</segment>
    <segment id="13">, a primeira universitária brasileira a ser aceita em Coimbra.</segment>
    <segment id="14">Mas ao me deparar com ela</segment>
    <segment id="15">, com suas ressonâncias melódicas</segment>
    <segment id="16">, históricas e linguísticas</segment>
    <segment id="17">, percebi que ela não era o foco.</segment>
    <segment id="18">Importante era outra mulher: Vilma Reis</segment>
    <segment id="19">, que a encontrou na poeira dos arquivos da universidade e lhe desenhou formas de futuro.</segment>
    <segment id="20">Alunos caminham pelo Pátio das Escolas</segment>
    <segment id="21">, prédio mais antigo da Universidade de Coimbra</segment>
    <segment id="22">, em Portugal- Ticiana Giehl - 27.set.17/Folhapress</segment>
    <segment id="23">A saga da menina América desenrola-</segment>
    <segment id="24">sese em outubro de 1917</segment>
    <segment id="25">, com a Europa no meio da Primeira Guerra Mundial</segment>
    <segment id="26">, Portugal às voltas com as aparições da Virgem Maria em Fátima e às portas da epidemia de tifo que assolava terras lusas no meio de sua tumultuada Primeira República.</segment>
    <segment id="27">Foi no meio desse caos que ela entregou um requerimento solene ao magnífico reitor</segment>
    <segment id="28">, o jurista Arnaldo Mendes Norton de Matos</segment>
    <segment id="29">, que nem era professor na mais antiga universidade de língua portuguesa.</segment>
    <segment id="30">Com inabalável determinação</segment>
    <segment id="31">, a jovem ansiava por</segment>
    <segment id="32">sese matricular e mergulhar de cabeça em todas as disciplinas do primeiro ano da nobre Faculdade de Letras</segment>
    <segment id="33">, na magnífica seção de Filologia Germânica.</segment>
    <segment id="34">Lá foraReceba no seu email uma seleção semanal com o que de mais importante aconteceu no mundo</segment>
    <segment id="35">; aberta para não assinantes.</segment>
    <segment id="36">Carregando...</segment>
    <segment id="37">Pela primeira vez na história</segment>
    <segment id="38">, uma mulher sul-americana teve o privilégio de adentrar os sagrados portões da renomada Universidade de Coimbra.</segment>
    <segment id="39">Essa conquista singular reverberava</segment>
    <segment id="40">comocomo um marco transcendental</segment>
    <segment id="41">, pois</segment>
    <segment id="42">pois rompia uma tradição que perdurou por mais de três séculos</segment>
    <segment id="43">, desde a formatura de Manuel de Paiva Cabral</segment>
    <segment id="44">, um notável pernambucano</segment>
    <segment id="45">, no longínquo ano de 1574.</segment>
    <segment id="46">A deliciosa saga de América do Sul chama a atenção</segment>
    <segment id="47">, masmas hoje é apenas passado.</segment>
    <segment id="48">Já Vilma representa o presente que investigou a história e</segment>
    <segment id="49">, sobretudo</segment>
    <segment id="50">, o futuro</segment>
    <segment id="51">, que hoje constrói esta nova era de relacionamento entre portugueses e brasileiros.</segment>
    <segment id="52">Como muitas outras mulheres</segment>
    <segment id="53">, Vilma</segment>
    <segment id="54">, nascida em Belém</segment>
    <segment id="55">, no Pará</segment>
    <segment id="56">, seguiu sua insaciável sede por conhecimento e cruzou oceanos para mergulhar em diferentes culturas</segment>
    <segment id="57">; e foi em Coimbra que começou a sua jornada profissional.</segment>
    <segment id="58">Brasileiros contam suas experiências de estudo em PortugalMais    novamente         de   de  de  representando um</segment>
    <segment id="59">Sentindo-</segment>
    <segment id="60">sese protagonista da história</segment>
    <segment id="61">, ainda fica surpresa ao constatar que a mesma universidade que um dia mapeou e sustentou a exploração que Portugal fez da Amazônia empenha-</segment>
    <segment id="62">sese agora em reparar o passado</segment>
    <segment id="63">, contribuindo para a revelação de abusos coloniais.</segment>
    <segment id="64">Prova disso é o improvável tema da sua tese de doutorado: jornalismo indígena.</segment>
    <segment id="65">Ao sese deparar com os documentos que revelaram a história de América do Sul</segment>
    <segment id="66">, Vilma provavelmente sentiu uma mistura de sorte</segment>
    <segment id="67">, fascínio e encantamento.</segment>
    <segment id="68">No entanto</segment>
    <segment id="69">, a verdadeira epifania só ocorreu quando ela percebeu que sua descoberta faz parte de um mosaico maior</segment>
    <segment id="70">, servindo simultaneamente</segment>
    <segment id="71">comocomo metáfora e profecia para o tempo que está por vir.</segment>
  </rst>
</analysis>