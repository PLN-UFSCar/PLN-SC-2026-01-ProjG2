  <rst>
    <segment id="1">João Guilherme Silva</segment>
    <segment id="2">, filho do apresentador Fausto Silva</segment>
    <segment id="3">, gravará o episódio piloto de seu programa na Band no dia 11 de outubro.</segment>
    <segment id="4">A estreia está prevista para o dia 21 daquele mês.</segment>
    <segment id="5">João Guilherme Silva chegapara festa de aniversário de Anitta  - Marcelo</segment>
    <segment id="6">, Araújo e Duzitos/AgNewsO programa deve ir ao ar todo sábado</segment>
    <segment id="7">, às 20:30</segment>
    <segment id="8">, logo após o Jornal da Band</segment>
    <segment id="9">, com a mesma direção do "Faustão na Band".</segment>
    <segment id="10">A partir de 2024</segment>
    <segment id="11">, a apresentação deve ser transmitida ao vivo</segment>
    <segment id="12">, segundo o Globo.  Faustão</segment>
    <segment id="13">, que segue internado após um transplante bem-sucedido do coração</segment>
    <segment id="14">, dividiu palco com o filho em janeiro de 2022.</segment>
    <segment id="15">Em maio</segment>
    <segment id="16">, Fausto Silva encerrou sua participação no "Faustão na Band"</segment>
    <segment id="17">, e João Guilherme seguiu apresentando o programa ao lado da jornalista Anne Lottermann até o fim de agosto —quando a programação foi substituída pelo "Melhor da Noite"</segment>
    <segment id="18">, com Glenda Kozlowski e Zeca Camargo.</segment>
    <segment id="19">Este é João Guilherme Silva</segment>
    <segment id="20">Mais    novamente         de   de  de  representando um</segment>
  </rst>
</analysis>