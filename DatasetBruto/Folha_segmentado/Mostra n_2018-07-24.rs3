  <rst>
    <segment id="1">Não era raro Stanley Kubrick (1928-99)</segment>
    <segment id="2">, durante uma filmagem</segment>
    <segment id="3">, repetir incansavelmente o mesmo plano: 40</segment>
    <segment id="4">, 50 vezes.</segment>
    <segment id="5">No entanto</segment>
    <segment id="6">, mesmo atores caprichosos</segment>
    <segment id="7">comocomo Jack Nicholson</segment>
    <segment id="8">, ou poderosos</segment>
    <segment id="9">, como</segment>
    <segment id="10">como Kirk Douglas</segment>
    <segment id="11">, não se</segment>
    <segment id="12">se queixavam.</segment>
    <segment id="13">Sabiam que Kubrick era um perfeccionista e tirava o melhor de cada ator.</segment>
    <segment id="14">Não apenas isso.</segment>
    <segment id="15">Ao longo de sua vida de 13 filmes longos de ficção</segment>
    <segment id="16">, em 12 deles teve controle completo: da compra de direitos ao roteiro</segment>
    <segment id="17">, da escolha dos atores à montagem.</segment>
    <segment id="18">A única exceção estará presente na retrospectiva do MIS</segment>
    <segment id="19">, que começa nesta terça (24) e reúne dez dos filmes do diretor americano:</segment>
    <segment id="20">é "Spartacus"</segment>
    <segment id="21">, a superprodução que pegou já com uma semana de filmagem</segment>
    <segment id="22">, por indicação de Kirk Douglas</segment>
    <segment id="23">, que se</segment>
    <segment id="24">se desentendera com Anthony Mann</segment>
    <segment id="25">, o primeiro diretor do filme.</segment>
    <segment id="26">Kubrick detestou a experiência.</segment>
    <segment id="27">Mas estava sem filmar desde "</segment>
    <segment id="28">Glória Feita de Sangue" (1957)</segment>
    <segment id="29">; não aguentava mais ficar à espera das decisões dos estúdios.</segment>
    <segment id="30">Pouco depois mudou-</segment>
    <segment id="31">sese para a Inglaterra</segment>
    <segment id="32">, onde via melhores perspectivas de produção e sentia-</segment>
    <segment id="33">sese a salvo do moralismo americano.</segment>
    <segment id="34">Stanley KubrickMais    novamente         de   de  de  representando um  Só longe de Hollywood teria a liberdade para adaptar o ousado "Lolita" de Nabokov</segment>
    <segment id="35">, com seu professor</segment>
    <segment id="36">sese apaixonando por uma adolescente.</segment>
    <segment id="37">Já "Dr. Fantástico"</segment>
    <segment id="38">, nem pensar: o alvo de sua comédia era o belicoso nacionalismo americano (ainda não desgastado pela guerra no Vietnã).</segment>
    <segment id="39">De filme em filme</segment>
    <segment id="40">, Kubrick construiu assim uma obra inteiramente pessoal.</segment>
    <segment id="41">Na base de seu trabalho está a ideia de espetáculo.</segment>
    <segment id="42">Não mais o do cinema clássico</segment>
    <segment id="43">, masmas um espetáculo que</segment>
    <segment id="44">sese pensa e</segment>
    <segment id="45">sese mostra</segment>
    <segment id="46">comocomo tal.</segment>
    <segment id="47">Que se</segment>
    <segment id="48">se distancia do espectador pela frieza do tratamento ("2001 - Uma Odisseia no Espaço")</segment>
    <segment id="49">, pelo uso da lente angular ("Laranja Mecânica")</segment>
    <segment id="50">, pela introdução de técnicas novas (a luz de "Barry Lyndon"</segment>
    <segment id="51">, em que sequências noturnas foram feitas apenas com luz de velas</segment>
    <segment id="52">, graças a uma lente projetada pela Nasa).</segment>
    <segment id="53">A cada vez Kubrick soube-</segment>
    <segment id="54">sese mostrar surpreendente</segment>
    <segment id="55">, quando não desconcertante.</segment>
    <segment id="56">Cada um de seus filmes parece ter estilo próprio</segment>
    <segment id="57">, e no entanto em seu conjunto representam o pensamento de seu autor.</segment>
    <segment id="58">Em política</segment>
    <segment id="59">, Kubrick sempre</segment>
    <segment id="60">sese posicionou contra o establishment</segment>
    <segment id="61">, fosse ele qual fosse.</segment>
    <segment id="62">Apreciou a poesia dos fracassados ("</segment>
    <segment id="63">O Grande Golpe"</segment>
    <segment id="64">, de 1956</segment>
    <segment id="65">, que estará fora da mostra</segment>
    <segment id="66">, assim</segment>
    <segment id="67">comocomo "Medo e Desejo"</segment>
    <segment id="68">, de 1953</segment>
    <segment id="69">, e "</segment>
    <segment id="70">A Morte Passou por Perto"</segment>
    <segment id="71">, de 1955).  Opôs-</segment>
    <segment id="72">sese ao militarismo ("Glória Feita de Sangue"</segment>
    <segment id="73">, "Dr. Fantástico"</segment>
    <segment id="74">, "</segment>
    <segment id="75">Nascido para Matar") e optou pelo lado dos escravos ("Spartacus").</segment>
    <segment id="76">De todo modo</segment>
    <segment id="77">, o pessimismo foi uma marca constante de seu cinema.</segment>
    <segment id="78">Que dizer</segment>
    <segment id="79">, por exemplo</segment>
    <segment id="80">, do Alex de "Laranja Mecânica"</segment>
    <segment id="81">, cuja perversidade de certo modo expressa o homem</segment>
    <segment id="82">"natural</segment>
    <segment id="83">"</segment>
    <segment id="84">,</segment>
    <segment id="85">isto é</segment>
    <segment id="86">, antes de ser controlado socialmente?  Ou da metamorfese de Barry Lyndon</segment>
    <segment id="87">, da inocência mais pura à amargura mais fúnebre (</segment>
    <segment id="88">comocomo o descreveu Martin Scorsese)?</segment>
    <segment id="89">Ou ainda do exército</segment>
    <segment id="90">comocomo engrenagem de transformação de jovens em máquinas de matar</segment>
    <segment id="91">, como</segment>
    <segment id="92">como em "</segment>
    <segment id="93">Nascido para Matar"?</segment>
    <segment id="94">Para não ir longe</segment>
    <segment id="95">, basta ficar com a magnífica elipse de "2001"</segment>
    <segment id="96">, uma das mais belas do cinema.</segment>
    <segment id="97">Ali, um macaco atira um osso para o alto</segment>
    <segment id="98">, e o osso</segment>
    <segment id="99">sese transforma numa nave espacial.</segment>
    <segment id="100">Num resumo cortante da trajetória humana</segment>
    <segment id="101">, ele nos lembra que</segment>
    <segment id="102">, do osso à nave</segment>
    <segment id="103">, o que mais soubemos fabricar foram instrumentos de ataque e destruição.</segment>
    <segment id="104">Otimista</segment>
    <segment id="105">, não é.</segment>
    <segment id="106">Mas esse visionário soube produzir beleza mesmo na amargura.</segment>
    <segment id="107">Kubrick 90 Anos  MIS - Museu da Imagem e do Som</segment>
    <segment id="108">, av. Europa</segment>
    <segment id="109">, 158.</segment>
    <segment id="110">De ter.</segment>
    <segment id="111">(24) a dom. (29).</segment>
    <segment id="112">Ingr.</segment>
    <segment id="113">: R$ 12 (por sessão).</segment>
    <segment id="114">Programação em mis-sp.org.br</segment>
  </rst>
</analysis>