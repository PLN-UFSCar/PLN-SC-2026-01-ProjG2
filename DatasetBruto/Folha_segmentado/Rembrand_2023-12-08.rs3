  <rst>
    <segment id="1">A tela "</segment>
    <segment id="2">A Adoração dos Reis Magos"</segment>
    <segment id="3">, do pintor Rembrandt</segment>
    <segment id="4">, foi vendida em um leilão por quase € 11 milhões</segment>
    <segment id="5">, o equivalente a R$ 68 milhões.</segment>
    <segment id="6">Há dois anos</segment>
    <segment id="7">, o quadro custava cerca de € 15 mil</segment>
    <segment id="8">, uma vez que sua autoria não podia ser confirmada.</segment>
    <segment id="9">No entanto</segment>
    <segment id="10">, após a casa de leilões Sotheby's afirmar</segment>
    <segment id="11">sese tratar de uma obra de Rembrandt</segment>
    <segment id="12">, o valor da peça disparou.</segment>
    <segment id="13">Quadro &amp;#039</segment>
    <segment id="14">;Adoração dos Reis Magos&amp;#039</segment>
    <segment id="15">;, de Rembrandt - Henry Nicholls/ AFPAcreditavam que o trabalho havia sido feito por um dos estudantes do pintor ou por um amigo dele.</segment>
    <segment id="16">A Sotheby’s</segment>
    <segment id="17">, no entanto</segment>
    <segment id="18">, confirmou a autoria após fazer uma investigação que durou 18 meses.</segment>
    <segment id="19">Esse processo envolveu exames de raio-x e imagens infravermelhas</segment>
    <segment id="20">, bem como</segment>
    <segment id="21">como a avaliação de especialistas no pintor.</segment>
    <segment id="22">A casa de leilões acredita que a obra tenha sido pintada no início da carreira de Rembrandt</segment>
    <segment id="23">, por volta de 1628</segment>
    <segment id="24">, quando ele teria 21 ou 22 anos e morava na cidade holandesa de Leiden.</segment>
    <segment id="25">Em nota</segment>
    <segment id="26">, a Sotheby's afirmou que o quadro sintetiza o domínio de Rembrandt sobre a luz e o cuidado que ele tinha com seu trabalho.</segment>
    <segment id="27">Rembrandt faz 350 anos em 2019Mais    novamente         de   de  de  representando um    "</segment>
    <segment id="28">Nessa obra em forma de joia</segment>
    <segment id="29">, que mede 24</segment>
    <segment id="30">,5 centímetros por 18</segment>
    <segment id="31">,5 centímetros</segment>
    <segment id="32">, Rembrandt empregou duas fontes distintas de luz</segment>
    <segment id="33">, uma luz de tom quente</segment>
    <segment id="34">, que emana de uma lanterna localizada fora de vista</segment>
    <segment id="35">, à esquerda da composição</segment>
    <segment id="36">, e uma luz branca</segment>
    <segment id="37">, mais fria da estrela de Belém acima.</segment>
    <segment id="38">"</segment>
  </rst>
</analysis>