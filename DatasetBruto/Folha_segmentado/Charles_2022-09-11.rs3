  <rst>
    <segment id="1">Antígua e Barbuda deve fazer um referendo sobre</segment>
    <segment id="2">sese tornar uma república após a morte da rainha Elizabeth 2ª</segment>
    <segment id="3">, segundo afirmou o primeiro-ministro do país neste domingo (11).</segment>
    <segment id="4">Antígua e Barbuda é um dos 14 países</segment>
    <segment id="5">, além do Reino Unido</segment>
    <segment id="6">, que tem o monarca britânico</segment>
    <segment id="7">, agora Charles 3º</segment>
    <segment id="8">, como</segment>
    <segment id="9">como chefe de Estado.</segment>
    <segment id="10">O primeiro-ministro Gaston Browne disse que um referendo pode acontecer nos próximos três anos</segment>
    <segment id="11">, masmas que isso "não é um ato de hostilidade".</segment>
    <segment id="12">Ele fez o anúncio após cerimônia de confirmação de Charles 3º</segment>
    <segment id="13">comocomo chefe de Estado da nação caribenha.</segment>
    <segment id="14">Primeiro-ministro de Antígua e Barbuda</segment>
    <segment id="15">, Gaston Browne</segment>
    <segment id="16">, anunciou possível votação - Getty Images/BBC News BrasilBrowne disse que vai promover o referendo</segment>
    <segment id="17">sese for reeleito no ano que vem</segment>
    <segment id="18">, o que é esperado</segment>
    <segment id="19">, uma vez que seu partido comanda atualmente 15 dos 17 assentos do Parlamento.</segment>
    <segment id="20">Apesar da promessa</segment>
    <segment id="21">, ele admitiu que não existe um grande clamor público</segment>
    <segment id="22">para que</segment>
    <segment id="23">para que a votação aconteça.</segment>
    <segment id="24">"</segment>
    <segment id="25">Acho que a maioria das pessoas nem pensou nisso"</segment>
    <segment id="26">, disse ele à ITV News.</segment>
    <segment id="27">Também no domingo</segment>
    <segment id="28">, a Austrália</segment>
    <segment id="29">, outro dos países que tem o monarca britânico</segment>
    <segment id="30">comocomo chefe de Estado</segment>
    <segment id="31">, descartou um referendo sobre o tema nos próximos quatro anos.</segment>
    <segment id="32">Charles 3º é proclamado rei do Reino UnidoMais    novamente         de   de  de  representando um  Debate na Austrália</segment>
    <segment id="33">A morte da rainha Elizabeth 2ª reacendeu o debate sobre a monarquia na Austrália.</segment>
    <segment id="34">O primeiro-ministro Anthony Albanese</segment>
    <segment id="35">, eleito em maio</segment>
    <segment id="36">, é republicano.</segment>
    <segment id="37">Mas, em entrevista à Sky News</segment>
    <segment id="38">, ele descartou um referendo em seu primeiro mandato e disse que "as grandes questões sobre nossa Constituição não são para o atual período".</segment>
    <segment id="39">"</segment>
    <segment id="40">Este é um período no qual estamos compartilhando o pesar que muitos australianos estão sentindo no momento</segment>
    <segment id="41">, mostrando nosso respeito profundo e admiração pela contribuição da rainha à Austrália"</segment>
    <segment id="42">, disse Albanese.</segment>
    <segment id="43">Além do Reino Unidos</segment>
    <segment id="44">, Charles 3º</segment>
    <segment id="45">sese tornou</segment>
    <segment id="46">, com a morte da rainha Elizabeth 2ª</segment>
    <segment id="47">, chefe de Estado de outros 14 países: Antígua e Barbuda</segment>
    <segment id="48">, Austrália</segment>
    <segment id="49">, Bahamas</segment>
    <segment id="50">, Belize</segment>
    <segment id="51">, Canadá</segment>
    <segment id="52">, Granada</segment>
    <segment id="53">, Jamaica</segment>
    <segment id="54">, Nova Zelândia</segment>
    <segment id="55">, Papua-Nova Guiné</segment>
    <segment id="56">, São Cristóvão e Neves</segment>
    <segment id="57">, Santa Lúcia</segment>
    <segment id="58">, São Vicente e Granadinas</segment>
    <segment id="59">, Ilhas Salomão e Tuvalu.</segment>
    <segment id="60">Charles 3º é agora chefe de Estado de 15 países</segment>
    <segment id="61">, incluindo o Reino Unido - Getty Images/BBC News BrasilMas muitos países estão reconsiderando o papel da monarquia.</segment>
    <segment id="62">Browne disse que</segment>
    <segment id="63">sese seu país</segment>
    <segment id="64">sese tornar uma república será "o passo final para completar a independência e</segment>
    <segment id="65">sese tornar uma nação realmente soberana".</segment>
    <segment id="66">No ano passado</segment>
    <segment id="67">, Barbados elegeu seu primeiro presidente após o Parlamento votar pela remoção da rainha</segment>
    <segment id="68">comocomo chefe de Estado e a transformação do país em república.</segment>
    <segment id="69">Na Jamaica</segment>
    <segment id="70">, o atual governo também diz ter o objetivo de realizar um referendo para</segment>
    <segment id="71">sese transformar em república.</segment>
    <segment id="72">Este texto foi originalmente publicado aqui.</segment>
  </rst>
