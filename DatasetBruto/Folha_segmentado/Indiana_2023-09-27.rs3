  <rst>
    <segment id="1">Salima Khan nasceu em 1931 no estado de Uttar Pradesh</segment>
    <segment id="2">, no norte da Índia</segment>
    <segment id="3">, e passou a infância em uma aldeia na região de Bulandshahr</segment>
    <segment id="4">, onde não havia escola para meninas.</segment>
    <segment id="5">Casou ainda adolescente</segment>
    <segment id="6">, aos 14 anos</segment>
    <segment id="7">, e durante a vida inteira sempre quis saber ler e escrever.</segment>
    <segment id="8">Aos 92 anos</segment>
    <segment id="9">, ela foi à escola pela primeira vez e</segment>
    <segment id="10">, enfim</segment>
    <segment id="11">, pôde realizar o sonho.</segment>
    <segment id="12">"</segment>
    <segment id="13">Meus netos me enganavam</segment>
    <segment id="14">para que</segment>
    <segment id="15">para que eu lhes desse mais dinheiro</segment>
    <segment id="16">porque</segment>
    <segment id="17">porque eu não sabia contar"</segment>
    <segment id="18">, disse ela ao jornal Times of India.</segment>
    <segment id="19">"</segment>
    <segment id="20">Esses dias acabaram.</segment>
    <segment id="21">"  Salima Khan ao lado de crianças em sala de aula na Índia - @ANINewsUP na plataforma</segment>
    <segment id="22">X  A história de Khan ficou conhecida depois de viralizar um vídeo em que ela aparece contando de zero a cem.</segment>
    <segment id="23">A indiana passou a frequentar a escola há seis meses</segment>
    <segment id="24">, sempre acompanhada da esposa de um dos netos.</segment>
    <segment id="25">Nas salas de aula</segment>
    <segment id="26">, senta-</segment>
    <segment id="27">sese ao lado de crianças oito décadas mais novas.</segment>
    <segment id="28">"</segment>
    <segment id="29">Todos os dias</segment>
    <segment id="30">, eu acordava com os gritos dos estudantes que entravam na escola primária em frente à minha casa</segment>
    <segment id="31">, masmas eu nunca entrei lá</segment>
    <segment id="32">, embora</segment>
    <segment id="33">embora continuasse ardendo de desejo de estudar"</segment>
    <segment id="34">, contou.  Pratibha Sharma</segment>
    <segment id="35">, diretora da escola</segment>
    <segment id="36">, disse que</segment>
    <segment id="37">, em um primeiro momento</segment>
    <segment id="38">, os professores da unidade hesitaram em acolher Khan</segment>
    <segment id="39">, masmas a "paixão" da mulher pelos estudos os convenceu.</segment>
    <segment id="40">Lá foraReceba no seu email uma seleção semanal com o que de mais importante aconteceu no mundo</segment>
    <segment id="41">; aberta para não assinantes.</segment>
    <segment id="42">Carregando...</segment>
    <segment id="43">A história tem inspirado outras pessoas a seguirem seu exemplo.</segment>
    <segment id="44">Desde que Khan começou a frequentar a escola</segment>
    <segment id="45">, 25 mulheres da sua aldeia também começaram aulas de alfabetização</segment>
    <segment id="46">, incluindo duas de suas noras.</segment>
    <segment id="47">Na última terça</segment>
    <segment id="48">, Khan passou por um teste do governo que a declarará alfabetizada —segundo o censo mais recente</segment>
    <segment id="49">, a taxa de alfabetização na Índia era de 73% em 2011.  "</segment>
    <segment id="50">A história reforça a crença de que a busca pelo conhecimento não tem limite de idade"</segment>
    <segment id="51">, disse Lakshmi Pandey</segment>
    <segment id="52">, autoridade educacional local</segment>
    <segment id="53">, à agência de notícias AFP.</segment>
    <segment id="54">Ela afirma que voluntários de uma iniciativa governamental de educação identificaram potencial em Khan para os estudos e a motivaram a ir à escola.</segment>
    <segment id="55">"</segment>
    <segment id="56">Eu lembro do meu primeiro dia</segment>
    <segment id="57">, quando a diretora me deu um livro.</segment>
    <segment id="58">Minhas mãos tremiam.</segment>
    <segment id="59">Eu não sabia segurar uma caneta.</segment>
    <segment id="60">Embora eu estivesse nervosa</segment>
    <segment id="61">, minha felicidade não tinha limites"</segment>
    <segment id="62">, disse Khan.</segment>
    <segment id="63">"</segment>
    <segment id="64">Antes tarde do que nunca.</segment>
    <segment id="65">"  Veja os 10 países mais populosos do mundoMais    novamente         de   de  de  representando</segment>
    <segment id="66">um</segment>
  </rst>
</analysis>