  <rst>
    <segment id="1">Bolsonaristas que pedem um golpe de Estado às Forças Armadas fizeram nesta terça-feira (15) uma corrente humana em torno do Comando Militar do Sudeste</segment>
    <segment id="2">, em São Paulo.</segment>
    <segment id="3">De mãos dadas ou ajoelhados suplicando em frente ao quartel</segment>
    <segment id="4">, os apoiadores de Jair Bolsonaro (PL) rezaram pai-nosso e ave-maria.</segment>
    <segment id="5">Alguns</segment>
    <segment id="6">sese emocionaram e choraram.</segment>
    <segment id="7">15.11.2022 - Bolsonaristas</segment>
    <segment id="8">sese ajoelham</segment>
    <segment id="9">, abraçam quartel em SP e rezam pai-nosso pelo golpe.</segment>
    <segment id="10">Foto Reproducao  Apoiadores ocupam o local há 16 dias.</segment>
    <segment id="11">Eles cobram as Forças Armadas</segment>
    <segment id="12">para que</segment>
    <segment id="13">para que promovam um golpe que impeça a posse do presidente eleito Luiz Inácio Lula da Silva (PT).</segment>
    <segment id="14">Bolsonaro teve uma inédita derrota para um presidente que disputava a reeleição no país.</segment>
    <segment id="15">Os atos antidemocráticos foram inflados com mais gente nesta terça-feira devido ao feriado nacional tanto em Brasília</segment>
    <segment id="16">comocomo em São Paulo e no Rio de Janeiro.</segment>
    <segment id="17">Sob o canto "</segment>
    <segment id="18">Forças Armadas salvem o Brasil" e cartazes com a frase #</segment>
    <segment id="19">BrazilWasStolen (Brasil foi roubado)</segment>
    <segment id="20">, milhares de pessoas de verde e amarelo</segment>
    <segment id="21">sese reuniram nos arredores do Comando Militar do Sudeste —</segment>
    <segment id="22">Segunda divisão do Exército</segment>
    <segment id="23">, próximo ao parque do Ibirapuera.</segment>
    <segment id="24">Na tarde desta terça</segment>
    <segment id="25">, foram dois pontos principais de concentração</segment>
    <segment id="26">, um na rua Manoel da Nóbrega e outro na avenida</segment>
    <segment id="27">Sargento Mario Kozel Filho</segment>
    <segment id="28">, onde fica a Alesp (Assembleia Legislativa do Estado de São Paulo).</segment>
    <segment id="29">Para percorrer esta última</segment>
    <segment id="30">, eram necessários cerca 40 minutos —o trajeto levaria poucos minutos em um dia comum.</segment>
    <segment id="31">Muitos dos acampados ali há 16 dias distribuíram sanduíches</segment>
    <segment id="32">, água e café de graça em tendas.</segment>
    <segment id="33">Estrutura para os manifestantes em ato antidemocrático em frente ao Comando Militar do Sudoeste</segment>
    <segment id="34">, em São Paulo   -Paula Soprana/Folhapress  Havia caixas para doação em dinheiro e pedidos aos gritos: "</segment>
    <segment id="35">Manda no zap da família que a gente tá precisando de água".</segment>
    <segment id="36">Um dos apoiadores</segment>
    <segment id="37">, João Mendes disse à reportagem que a tenda recebe ajuda de empresários e militantes.</segment>
    <segment id="38">"</segment>
    <segment id="39">Empresário do tiro</segment>
    <segment id="40">, do agro</segment>
    <segment id="41">, todo mundo.</segment>
    <segment id="42">"</segment>
    <segment id="43">Uma mulher interrompeu para explicar que não</segment>
    <segment id="44">sese trata de doações exorbitantes.</segment>
    <segment id="45">Disse que era manicure e empresária e também ajudava</segment>
    <segment id="46">, portanto não havia um financiamento oculto.</segment>
    <segment id="47">Em frente ao quartel</segment>
    <segment id="48">, as pessoas cantaram o hino nacional</segment>
    <segment id="49">, o hino da bandeira e o hino do Exército.</segment>
    <segment id="50">Havia faixas pedindo que o TSE (Tribunal Superior Militar) fornecesse o código-fonte das urnas e outras que diziam "resistência civil"</segment>
    <segment id="51">, como</segment>
    <segment id="52">como é chamado o movimento golpista</segment>
    <segment id="53">, e "chegou a hora".</segment>
    <segment id="54">"SOS</segment>
    <segment id="55">Forças Armadas</segment>
    <segment id="56">"</segment>
    <segment id="57">e "</segment>
    <segment id="58">Se precisar</segment>
    <segment id="59">, a gente acampa</segment>
    <segment id="60">, masmas o ladrão não sobe a rampa"</segment>
    <segment id="61">, referindo-</segment>
    <segment id="62">sese ao presidente eleito</segment>
    <segment id="63">, foram os gritos mais comuns.</segment>
    <segment id="64">Quando um helicóptero supostamente da Globo sobrevoou o local</segment>
    <segment id="65">, a multidão entoou "lixo</segment>
    <segment id="66">, lixo</segment>
    <segment id="67">, lixo".</segment>
    <segment id="68">Bolsonaristas promovem atos antidemocráticos em SP</segment>
    <segment id="69">, Rio e Brasília neste 15 de novembro de 2022Mais    novamente         de   de  de  representando um</segment>
