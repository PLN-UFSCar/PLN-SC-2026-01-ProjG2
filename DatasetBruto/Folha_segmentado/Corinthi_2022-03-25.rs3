  <rst>
    <segment id="1">Fora das últimas três edições da Copa Libertadores</segment>
    <segment id="2">, o Corinthians encontrará um velho conhecido no retorno à competição.</segment>
    <segment id="3">No sorteio realizado pela Conmebol (Confederação Sul-Americana de Futebol) nesta sexta-feira (25)</segment>
    <segment id="4">, em Luque</segment>
    <segment id="5">, no Paraguai</segment>
    <segment id="6">, a equipe alvinegra caiu na chave do Boca Juniors</segment>
    <segment id="7">, sua vítima na decisão de 2012.</segment>
    <segment id="8">Os times –que também duelaram no torneio em 1991 e 2013</segment>
    <segment id="9">, com triunfo argentino– estão no Grupo E</segment>
    <segment id="10">, encabeçado pelo Boca.</segment>
    <segment id="11">Eles enfrentarão também o Deportivo Cali</segment>
    <segment id="12">, da Colômbia</segment>
    <segment id="13">, e o Always Ready</segment>
    <segment id="14">, da Bolívia.</segment>
    <segment id="15">A tabela ainda será confeccionada</segment>
    <segment id="16">, masmas a fase de grupos já terá início no começo de abril.</segment>
    <segment id="17">Paulinho duela com jogadores do Boca Juniors na final de 2012</segment>
    <segment id="18">; volante está de volta ao Corinthians e enfrentará argentinos novamente - Junior Lago - 4.jul.12/Reuters  Já o Palmeiras</segment>
    <segment id="19">, atual bicampeão</segment>
    <segment id="20">, não enfrentará nenhuma equipe com tradição na Libertadores.</segment>
    <segment id="21">Cabeça de chave do Grupo A</segment>
    <segment id="22">, a formação alviverde jogará contra o Emelec</segment>
    <segment id="23">, do Equador</segment>
    <segment id="24">, o Deportivo Táchira</segment>
    <segment id="25">, da Venezuela</segment>
    <segment id="26">, e o Independiente Petrolero</segment>
    <segment id="27">, da Bolívia.</segment>
    <segment id="28">O sorteio colocou frente a frente rivais regionais.</segment>
    <segment id="29">Cabeça de chave do Grupo D</segment>
    <segment id="30">, o Atlético-MG terá o América-MG</segment>
    <segment id="31">comocomo um de seus oponentes.</segment>
    <segment id="32">Independiente del Valle</segment>
    <segment id="33">, do Equador</segment>
    <segment id="34">, e Deportes Tolima</segment>
    <segment id="35">, da Colômbia</segment>
    <segment id="36">, completam o grupo.</segment>
    <segment id="37">O Flamengo</segment>
    <segment id="38">, principal time do Grupo H</segment>
    <segment id="39">, medirá forças com Universidad Católica</segment>
    <segment id="40">, do Chile</segment>
    <segment id="41">, Sporting Cristal</segment>
    <segment id="42">, do Peru</segment>
    <segment id="43">, e Talleres</segment>
    <segment id="44">, da Argentina.</segment>
    <segment id="45">No Grupo B</segment>
    <segment id="46">, encabeçado pelo Athletico</segment>
    <segment id="47">, estão ainda Libertad</segment>
    <segment id="48">, do Paraguai</segment>
    <segment id="49">, Caracas</segment>
    <segment id="50">, da Venezuela</segment>
    <segment id="51">, e The Strongest</segment>
    <segment id="52">, da Bolívia.</segment>
    <segment id="53">Estreante na competição</segment>
    <segment id="54">, o Fortaleza caiu no Grupo F</segment>
    <segment id="55">, ao lado de River Plate</segment>
    <segment id="56">, da Argentina</segment>
    <segment id="57">, Colo-Colo</segment>
    <segment id="58">, do Chile</segment>
    <segment id="59">, e Alianza Lima</segment>
    <segment id="60">, do Peru.</segment>
    <segment id="61">Outro que disputa o torneio pela primeira vez</segment>
    <segment id="62">, o Red Bull Bragantino está em uma chave de campeões da Libertadores</segment>
    <segment id="63">, o Grupo C</segment>
    <segment id="64">, que tem Nacional</segment>
    <segment id="65">, do Uruguai</segment>
    <segment id="66">, Vélez Sarsfield</segment>
    <segment id="67">, da Argentina</segment>
    <segment id="68">, e Estudiantes</segment>
    <segment id="69">, também da Argentina.</segment>
    <segment id="70">Final da Libertadores 2021 entre Palmeiras e FlamengoMais    novamente         de   de  de  representando um</segment>
    <segment id="71">A cerimônia na sede da Conmebol teve ainda o sorteio das chaves da Copa Sul-Americana.</segment>
    <segment id="72">No Grupo D</segment>
    <segment id="73">, O São Paulo</segment>
    <segment id="74">, campeão de 2012</segment>
    <segment id="75">, enfrentará Jorge Wilstermann</segment>
    <segment id="76">, da Bolívia</segment>
    <segment id="77">, Ayacucho</segment>
    <segment id="78">, do Peru</segment>
    <segment id="79">, e Everton</segment>
    <segment id="80">, do Chile.</segment>
    <segment id="81">O Santos</segment>
    <segment id="82">, no Grupo C</segment>
    <segment id="83">, duelará com Unión La Calera</segment>
    <segment id="84">, do Chile</segment>
    <segment id="85">, Banfield</segment>
    <segment id="86">, da Argentina</segment>
    <segment id="87">, e Universidad Católica</segment>
    <segment id="88">, do Equador.</segment>
    <segment id="89">Só o primeiro colocado de cada chave avança às oitavas de final</segment>
    <segment id="90">, onde</segment>
    <segment id="91">sese junta aos terceiros colocados dos grupos da Libertadores.</segment>
    <segment id="92">Na Libertadores</segment>
    <segment id="93">, os dois primeiros de cada chave vão aos mata-matas.</segment>
    <segment id="94">Confira as chaves da Copa Libertadores</segment>
    <segment id="95">Grupo</segment>
    <segment id="96">A Palmeiras Emelec (EQU) Deportivo Táchira (VEN)</segment>
    <segment id="97">Independiente Petrolero (BOL)  Grupo B Athletico Libertad (PAR) Caracas (VEN)</segment>
    <segment id="98">The Strongest (BOL)  Grupo C Nacional (URU)</segment>
    <segment id="99">Vélez Sarsfield (ARG)</segment>
    <segment id="100">Red Bull Bragantino Estudiantes (ARG)  Grupo D Atlético-MG Independiente del Valle (EQU)</segment>
    <segment id="101">Deportes Tolima (COL)</segment>
    <segment id="102">América-MG  Grupo E Boca Juniors (ARG) Corinthians Deportivo Cali (COL) Always Ready (BOL)</segment>
    <segment id="103">Grupo F River Plate (ARG) Colo-Colo (CHI)</segment>
    <segment id="104">Alianza Lima (PER)</segment>
    <segment id="105">Fortaleza  Grupo G Peñarol (URU) Cerro Porteño (PAR) Colón (ARG)</segment>
    <segment id="106">Olimpia  Grupo H Flamengo Universidad Católica (CHI) Sporting Cristal (PER) Talleres (ARG)</segment>
    <segment id="107">Confira as chaves da Copa Sul-Americana:  Grupo A Lanús (ARG)</segment>
    <segment id="108">Wanderers (URU)</segment>
    <segment id="109">Metropolitanos (VEN) Barcelona (EQU)</segment>
    <segment id="110">Grupo B Racing (ARG)</segment>
    <segment id="111">Melgar (PER) River Plate (URU)</segment>
    <segment id="112">Cuiabá  Grupo C Santos Unión La Calera (CHI)</segment>
    <segment id="113">Banfield (ARG)</segment>
    <segment id="114">Universidad Católica (EQU)  Grupo D São Paulo Jorge Wilstermann (BOL)</segment>
    <segment id="115">Ayacucho (PER) Everton (CHI)</segment>
    <segment id="116">Grupo E Internacional Independiente Medellín (COL) 9 de Octubre (EQU)</segment>
    <segment id="117">Guaireña (PAR)</segment>
    <segment id="118">Grupo F LDU Quito (EQU) Defensa y Justicia (ARG)</segment>
