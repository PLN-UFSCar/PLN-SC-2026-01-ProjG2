  <rst>
    <segment id="1">Sabemos que o Facebook</segment>
    <segment id="2">, Instagram e YouTube existem</segment>
    <segment id="3">, masmas não temos acesso.</segment>
    <segment id="4">Aqui, todos são bloqueados</segment>
    <segment id="5">, conta Byashim Ishanguliyev</segment>
    <segment id="6">, um vendedor de frutas no Turcomenistão</segment>
    <segment id="7">, um dos países mais fechados do mundo</segment>
    <segment id="8">, onde o estado domina a internet quase completamente.</segment>
    <segment id="9">Passar por cima dessas proibições</segment>
    <segment id="10">, nesta antiga república soviética da Ásia Central</segment>
    <segment id="11">, rica em hidrocarbonetos</segment>
    <segment id="12">, é uma verdadeira corrida de obstáculos.</segment>
    <segment id="13">"</segment>
    <segment id="14">Algumas pessoas conseguem</segment>
    <segment id="15">sese conectar a uma VPN</segment>
    <segment id="16">, masmas é temporário (</segment>
    <segment id="17">porque</segment>
    <segment id="18">porque) também será bloqueada"</segment>
    <segment id="19">, disse Ishanguliyev</segment>
    <segment id="20">, de 19 anos</segment>
    <segment id="21">, em um mercado na capital</segment>
    <segment id="22">, Ashgabat.</segment>
    <segment id="23">Homem assiste ao programa de televisão que mostra evento do governo no Turcomenistão - Divulgação/AFP"A internet é lenta</segment>
    <segment id="24">, então</segment>
    <segment id="25">, sese alguém consegue baixar um vídeo</segment>
    <segment id="26">, um clipe ou um filme interessante</segment>
    <segment id="27">, assistimos todos juntos (com os amigos)</segment>
    <segment id="28">", relata o jovem.</segment>
    <segment id="29">No entanto</segment>
    <segment id="30">, para o presidente do país</segment>
    <segment id="31">, Serdar Berdymujamedov</segment>
    <segment id="32">, essas medidas drásticas não são suficientes.</segment>
    <segment id="33">Em meados de janeiro</segment>
    <segment id="34">, o líder anunciou sua intenção de "reforçar a cibersegurança do país"</segment>
    <segment id="35">, seguindo os passos das restrições impostas por seus antecessores —seu pai Gurbanguly Berdymujamedov e o ex-presidente Saparmurat Niazov</segment>
    <segment id="36">, já morto.</segment>
    <segment id="37">Os principais serviços de mensagens estão proibidos: não há WhatsApp</segment>
    <segment id="38">, Viber</segment>
    <segment id="39">, Signal ou Telegram.</segment>
    <segment id="40">Como substituto</segment>
    <segment id="41">, o governo criou um aplicativo</segment>
    <segment id="42">, o Bizbarde</segment>
    <segment id="43">, sob seu controle.</segment>
    <segment id="44">Para vídeos online</segment>
    <segment id="45">, as autoridades lançaram o Belet Video</segment>
    <segment id="46">, uma espécie de alternativa ao YouTube filtrada de qualquer conteúdo que possa revelar o mundo exterior aos turcomenos</segment>
    <segment id="47">, seja notícias ou entretenimento.</segment>
    <segment id="48">Sem opções  "</segment>
    <segment id="49">Não há panorama midiático"</segment>
    <segment id="50">, resumiu o redator do site de informações Turkmennews</segment>
    <segment id="51">, Ruslan Miatiev</segment>
    <segment id="52">, para a AFP.</segment>
    <segment id="53">O portal é proibido em seu país.</segment>
    <segment id="54">Os turcomanos só veem "propaganda para promover o culto à personalidade dos Berdymujamedov"</segment>
    <segment id="55">, comentou o jornalista</segment>
    <segment id="56">, atualmente morando na Holanda.</segment>
    <segment id="57">"</segment>
    <segment id="58">E para evitar que essa realidade paralela criada pelos meios de comunicação desmorone</segment>
    <segment id="59">, os governantes bloqueiam a internet"</segment>
    <segment id="60">, garantiu.</segment>
    <segment id="61">Folha MercadoReceba no seu email o que de mais importante acontece na economia</segment>
    <segment id="62">; aberta para não assinantes.</segment>
    <segment id="63">Carregando...</segment>
    <segment id="64">Os veículos de comunicação turcomanos</segment>
    <segment id="65">, todos estatais</segment>
    <segment id="66">, só divulgam informações oficiais</segment>
    <segment id="67">, com ênfase especial nos agradecimentos e elogios às autoridades do país.</segment>
    <segment id="68">Yusup Bakhshiyev</segment>
    <segment id="69">, um funcionário de 38 anos de Ashgabat</segment>
    <segment id="70">, tinha acesso a mais canais estrangeiros via satélite.</segment>
    <segment id="71">No entanto</segment>
    <segment id="72">, diz que agora é impossível.</segment>
    <segment id="73">"</segment>
    <segment id="74">Funcionários da prefeitura vieram à minha casa e disseram para eu remover a antena</segment>
    <segment id="75">porque</segment>
    <segment id="76">porque estragava a arquitetura da cidade"</segment>
    <segment id="77">, lembrou.</segment>
    <segment id="78">Depois</segment>
    <segment id="79">, ele se</segment>
    <segment id="80">se cadastrou na televisão a cabo turcomana.</segment>
    <segment id="81">"</segment>
    <segment id="82">Com isso</segment>
    <segment id="83">, o Estado controla a informação e recebe receitas com a assinatura"</segment>
    <segment id="84">, pontuou.</segment>
    <segment id="85">Leia tambémPauta de costumes que fisgou Lula na eleição</segment>
    <segment id="86">sese infiltra na esquerda não só no BrasilAlgumas redes ocidentais</segment>
    <segment id="87">comocomo France 24</segment>
    <segment id="88">, BBC e Euronews são autorizadas</segment>
    <segment id="89">, masmas sua audiência é escassa em um país onde o inglês é pouco falado.  "</segment>
    <segment id="90">Pior do pior"</segment>
    <segment id="91">Todos os dias</segment>
    <segment id="92">, os turcomenos assistem aos programas nos quais Berdymujamedov repreende seus ministros</segment>
    <segment id="93">, planta árvores no deserto ou recebe aplausos.</segment>
    <segment id="94">Seu pai Gurbanguly</segment>
    <segment id="95">, o "herói protetor" (Arkadag) e "chefe da nação turcomana" com grandes prerrogativas</segment>
    <segment id="96">, torna-</segment>
    <segment id="97">sese cada vez mais excêntrico com o culto à sua personalidade.</segment>
    <segment id="98">Às vezes</segment>
    <segment id="99">, chega ao absurdo.</segment>
    <segment id="100">O jornal Arkadag informou uma vez que Arkadag (Gurbanguly) viajou para Arkadag (cidade fundada em sua homenagem) para parabenizar os jogadores vitoriosos do time Arkadag.</segment>
    <segment id="101">A ONG americana Freedom House</segment>
    <segment id="102">, que analisa as liberdades civis e políticas</segment>
    <segment id="103">, classificou o Turcomenistão na categoria de "pior do pior" com uma pontuação de 2 em 100</segment>
    <segment id="104">, ainda menor do que a Coreia do Norte</segment>
    <segment id="105">, com 3.</segment>
    <segment id="106">Mulher navega em sites jornalísticos no Turcomenistão - Divulgação/AFPO</segment>
    <segment id="107">Turcomenistão também ocupa uma das últimas posições no ranking de liberdade de imprensa do Repórteres Sem Fronteiras.</segment>
    <segment id="108">Mas nada disso preocupa Oksana Shumilova</segment>
    <segment id="109">, funcionária de uma construtora de Ashgabat</segment>
    <segment id="110">, que está encantada com a estabilidade do país.</segment>
    <segment id="111">Assinante do jornal "</segment>
    <segment id="112">Turcomenistão Neutro" (em tradução literal)</segment>
    <segment id="113">, com a inevitável foto do presidente na capa</segment>
    <segment id="114">, ela assegura à AFP que sente uma "sensação de estabilidade e tranquilidade"</segment>
    <segment id="115">, porque</segment>
    <segment id="116">porque "não tem artigos críticos nem informações negativas".</segment>
  </rst>
</analysis>