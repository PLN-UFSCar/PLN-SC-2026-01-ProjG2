  <rst>
    <segment id="1">O Parlamento brasileiro</segment>
    <segment id="2">sese tornou palco do conflito que opõe palestinos e israelenses no Oriente Médio.</segment>
    <segment id="3">Na mesma Casa</segment>
    <segment id="4">, e no mesmo horário</segment>
    <segment id="5">, parlamentares à esquerda e à direita protagonizaram</segment>
    <segment id="6">, diante de diplomatas que representam ambos os povos</segment>
    <segment id="7">, ruidosas manifestações de apoio a cada um dos lados.</segment>
    <segment id="8">Na quarta-feira (8)</segment>
    <segment id="9">, a Embaixada de Israel no Brasil convidou mais de 300 deputados e senadores brasileiros para uma exibição</segment>
    <segment id="10">, na Câmara dos Deputados</segment>
    <segment id="11">, de imagens do ataque do Hamas ocorrido em 7 de outubro.</segment>
    <segment id="12">Parlamentares batem boca com o deputado Abilio Brunini (PL-MT) durante ato pró-Palestina</segment>
    <segment id="13">, na Câmara dos Deputados</segment>
    <segment id="14">, em Brasília - @maynafe no Instagram/ReproduçãoOs recortes mostravam israelenses sendo brutalmente assassinados por integrantes do grupo terrorista.</segment>
    <segment id="15">O ex-presidente Jair Bolsonaro (PL) acompanhou parte da exibição ao lado do embaixador de Israel no Brasil</segment>
    <segment id="16">, Daniel Zonshine.</segment>
    <segment id="17">No mesmo horário</segment>
    <segment id="18">, e na mesma Casa legislativa</segment>
    <segment id="19">, parlamentares de PT</segment>
    <segment id="20">, PSOL</segment>
    <segment id="21">, PC do B e Rede promoveram um ato em solidariedade ao povo palestino e em defesa de um cessar-fogo urgente na guerra.</segment>
    <segment id="22">Uma carta acusando Israel de praticar um genocídio e um apartheid na Faixa de Gaza chegou a reunir a assinatura de 61 parlamentares.</segment>
    <segment id="23">Agentes da Polícia Legislativa Federal (PLF) estimam que menos de cem parlamentares compareceram ao ato pró-Israel.</segment>
    <segment id="24">Usando uma gravata estampada com símbolos judaicos</segment>
    <segment id="25">, o senador Magno Malta (PL-ES) deixou a sala de exibição com uma das mãos sobre o peito e com a outra apontando para suas pernas supostamente trêmulas.</segment>
    <segment id="26">"Barbárie</segment>
    <segment id="27">, barbárie"</segment>
    <segment id="28">,</segment>
    <segment id="29">disse o senador à coluna.</segment>
    <segment id="30">"</segment>
    <segment id="31">O mundo tem que ver</segment>
    <segment id="32">, principalmente a mídia precisa ver</segment>
    <segment id="33">, que é para não chamar esse grupo [Hamas] de movimento que</segment>
    <segment id="34">sese defende.</segment>
    <segment id="35">São terroristas</segment>
    <segment id="36">, e o alvo não é só Israel</segment>
    <segment id="37">, não são só os judeus.</segment>
    <segment id="38">Os alvos são os cristãos do mundo"</segment>
    <segment id="39">, completou.</segment>
    <segment id="40">Já o deputado Gilberto Nascimento (PSD-SP)</segment>
    <segment id="41">, que chegou a</segment>
    <segment id="42">sese juntar aos demais colegas</segment>
    <segment id="43">, preferiu</segment>
    <segment id="44">sese retirar da exibição e aguardar seu fim do lado de fora.</segment>
    <segment id="45">"</segment>
    <segment id="46">Em que pese a minha vida toda ser delegado de polícia</segment>
    <segment id="47">, conviver com imagens [violentas]</segment>
    <segment id="48">, eu cheguei num ponto da vida que eu</segment>
    <segment id="49">, agora</segment>
    <segment id="50">, só vejo aquilo que me faz bem"</segment>
    <segment id="51">, explicou.</segment>
    <segment id="52">"</segment>
    <segment id="53">As imagens não são boas.</segment>
    <segment id="54">São imagens de guerra</segment>
    <segment id="55">, um quadro triste.</segment>
    <segment id="56">"  Símbolos e mensagens sobre a guerra Israel-Hamas no mundoMais    novamente         de   de  de  representando um  Secretário de Segurança Pública de São Paulo e deputado licenciado</segment>
    <segment id="57">, o bolsonarista Guilherme Derrite não ficou no recinto por mais de dez minutos.</segment>
    <segment id="58">"</segment>
    <segment id="59">Nem vi.</segment>
    <segment id="60">Não falei com ninguém</segment>
    <segment id="61">, olhei e já sai"</segment>
    <segment id="62">, afirmou à coluna.</segment>
    <segment id="63">Irritado</segment>
    <segment id="64">, tampouco quis comentar o teor das imagens.</segment>
    <segment id="65">"</segment>
    <segment id="66">Eu não acho nada</segment>
    <segment id="67">, minha filha.</segment>
    <segment id="68">Eu estou aqui para trabalhar.</segment>
    <segment id="69">"  Do outro lado da Câmara</segment>
    <segment id="70">, o embaixador da Representação Palestina no Brasil</segment>
    <segment id="71">, Ibrahim Alzeben</segment>
    <segment id="72">, e embaixadores de Tunísia</segment>
    <segment id="73">, Cuba Venezuela</segment>
    <segment id="74">, Síria</segment>
    <segment id="75">, Argélia</segment>
    <segment id="76">, Líbano</segment>
    <segment id="77">, Líbia e Qatar estavam reunidos</segment>
    <segment id="78">, além de representantes do Egito e da Liga dos Países Árabes.</segment>
    <segment id="79">Em determinado momento</segment>
    <segment id="80">, a Polícia Legislativa precisou apartar um tumulto iniciado pelo deputado bolsonarista Abilio Brunini (PL-MT).</segment>
    <segment id="81">"</segment>
    <segment id="82">E viva/ a luta/ do povo</segment>
    <segment id="83">palestino/ Estado de Israel/</segment>
    <segment id="84">Estado assassino"</segment>
    <segment id="85">, gritavam alguns parlamentares</segment>
    <segment id="86">, em represália ao deputado do PL.</segment>
    <segment id="87">Tanto o ato quanto o manifesto pró-Palestina foram puxados pelos deputados Erika Kokay (PT-DF)</segment>
    <segment id="88">, Padre João (PT-MG)</segment>
    <segment id="89">, Fernanda Melchionna (PSOL-RS)</segment>
    <segment id="90">, Glauber Braga (PSOL-RJ) e Jandira Feghali (PC do B-RJ).</segment>
    <segment id="91">LEIA</segment>
    <segment id="92">TODOS OS TEMAS ABORDADOS PELA COLUNA NA EDIÇÃO IMPRESSA DESTA QUINTA (9)Congresso tem bate-boca e senador com &amp;#</segment>
    <segment id="93">039;pernas tremendo&amp;#039</segment>
    <segment id="94">; em dia de atos pró-Israel e pró-Palestina Embaixada de Israel convida 300 parlamentares para sessão de vídeos do terror do Hamas Mais de 60 deputados cobram cessar-fogo de Israel e chamam guerra de genocídio</segment>
    <segment id="95">Integrantes da CPI do 8/1 iniciarão &amp;#</segment>
    <segment id="96">039;turnê pela democracia&amp;#039</segment>
    <segment id="97">;</segment>
    <segment id="98">em BHMargareth Menezes vai propor campanha antirracista conjunta a países do Mercosul Associação Beneficente Santa Fé celebrará 30 anos com leilão para arrecadar recursos Filhas de Nelson Ned e André Barcinski falam sobre biografia do cantor em evento  LOVE SONGS  DJ</segment>
    <segment id="99">Zé Pedro lança o livro &amp;#039</segment>
    <segment id="100">;Mela Cueca&amp;#039</segment>
    <segment id="101">;Mais    novamente         de   de  de  representando um</segment>
    <segment id="102">O DJ Zé Pedro recebeu convidados para o lançamento de seu livro "Mela Cueca –</segment>
    <segment id="103">As Canções de Amor que O Mundo Esqueceu"</segment>
    <segment id="104">, realizado na casa de música Bona</segment>
    <segment id="105">, em São Paulo</segment>
    <segment id="106">, na segunda (6).</segment>
    <segment id="107">A apresentadora Adriane Galisteu e a cantora Zélia Duncan prestigiaram o evento.  com BIANKA VIEIRA</segment>
    <segment id="108">, KARINA MATIAS e MANOELLA SMITH</segment>
  </rst>
