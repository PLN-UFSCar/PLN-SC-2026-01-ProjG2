  <rst>
    <segment id="1">Nas novas inserções partidárias do PSB</segment>
    <segment id="2">, a deputada federal Tabata Amaral (PSB) faz um chamado</segment>
    <segment id="3">para que</segment>
    <segment id="4">para que as mulheres</segment>
    <segment id="5">sese juntem à sigla e cutuca a administração do atual prefeito</segment>
    <segment id="6">, Ricardo Nunes (MDB).</segment>
    <segment id="7">Em um dos vídeos</segment>
    <segment id="8">, ela aparece acompanhada da ex-primeira-dama</segment>
    <segment id="9">Lúcia França</segment>
    <segment id="10">, mulher do ministro Márcio França (Micro e Pequenas Empresas).</segment>
    <segment id="11">A parlamentar é pré-candidata à Prefeitura de São Paulo</segment>
    <segment id="12">, e a professora foi vice de Fernando Haddad (PT) na disputa pelo governo de São Paulo em 2022.</segment>
    <segment id="13">"</segment>
    <segment id="14">A gente sabe da diferença que as mulheres fazem na vida das comunidades</segment>
    <segment id="15">, das igrejas</segment>
    <segment id="16">, da nossa cidade.</segment>
    <segment id="17">Quando a mulher entra na política</segment>
    <segment id="18">, a política muda"</segment>
    <segment id="19">, diz Tabata no vídeo.</segment>
    <segment id="20">Em outro</segment>
    <segment id="21">, ela diz que a cidade tem bilhões em caixa parados "que deveriam estar sendo usados para cuidar da cidade</segment>
    <segment id="22">, melhorar a sua vida".</segment>
    <segment id="23">"</segment>
    <segment id="24">A gente vive numa São Paulo que pode até parecer boa para uns poucos</segment>
    <segment id="25">, masmas que está muito difícil para a maioria"</segment>
    <segment id="26">, completa.</segment>
    <segment id="27">O material foi gravado na Vila Missionária</segment>
    <segment id="28">, na zona sul da capital</segment>
    <segment id="29">, onde Tabata cresceu e que até hoje abriga sua família.</segment>
    <segment id="30">Os vídeos foram criados pela equipe de Tabata com a colaboração do marqueteiro Pablo Nobel</segment>
    <segment id="31">, que fez a campanha de Tarcísio de Freitas (Republicanos-SP) em 2022 e atualmente negocia para assumir a da deputada.</segment>
  </rst>
</analysis>