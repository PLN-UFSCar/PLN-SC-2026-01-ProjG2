  <rst>
    <segment id="1">Mal tinha terminado o jogo que eliminou a seleção brasileira da Copa da Rússia</segment>
    <segment id="2">, quatro anos atrás</segment>
    <segment id="3">, e a Globo lançou o "Fica</segment>
    <segment id="4">, Tite"</segment>
    <segment id="5">, uma campanha por uma atitude inédita da história do Brasil: manter um técnico que havia fracassado.</segment>
    <segment id="6">Relembrando</segment>
    <segment id="7">, o Brasil fora eliminado nas quartas de final (seu desempenho mais recorrente nos últimos 50 anos) após levar um banho tático da Bélgica</segment>
    <segment id="8">, que colocou seus dois atacantes</segment>
    <segment id="9">comocomo pontas</segment>
    <segment id="10">, inclusive Lukaku</segment>
    <segment id="11">, deixando Tite sem reação até o fim do primeiro tempo</segment>
    <segment id="12">, quando já estava 2 a 0.</segment>
    <segment id="13">No meu blog para aquela Copa</segment>
    <segment id="14">, aqui na mesmo Folha</segment>
    <segment id="15">, eu escrevi um post intitulado "</segment>
    <segment id="16">Fica, Tite!</segment>
    <segment id="17">Será?</segment>
    <segment id="18">".</segment>
    <segment id="19">No fim das contas</segment>
    <segment id="20">, a campanha</segment>
    <segment id="21">sese alastrou</segment>
    <segment id="22">, o técnico ficou e levou o Brasil até aqui: duas vitórias e classificação antecipada.</segment>
    <segment id="23">O técnico Tite durante entrevista na Copa do Qatar - Nelson Almeida - 27.nov.22/AFPNesse tempo todo</segment>
    <segment id="24">, Tite teve um veículo de comunicação de uma fidelidade à toda prova: a Globo (incluindo SporTV).</segment>
    <segment id="25">Não importaram as decisões do treinador</segment>
    <segment id="26">, a cobertura da emissora sempre foi compreensiva e quase sempre esteve ao seu lado.</segment>
    <segment id="27">Nesta Copa</segment>
    <segment id="28">, o clima da cobertura é o tradicional otimismo da Globo.</segment>
    <segment id="29">Não chega a ser o clima de "maior favorito da história das Copas"</segment>
    <segment id="30">, de 2006</segment>
    <segment id="31">, masmas apenas nos raros programas do SporTV feitos no Brasil há algum questionamento maior.</segment>
    <segment id="32">A Globo exibiu a Copa com exclusividade pela primeira vez em 1982 —na época</segment>
    <segment id="33">, o fato gerou uma enorme controvérsia.</segment>
    <segment id="34">Seu poder sobre a seleção chegou a pontos impressionantes.</segment>
    <segment id="35">Em 1998</segment>
    <segment id="36">, o técnico Zagallo foi docilmente comandado por um cinegrafista global para começar sincronizado com o boletim especial da emissora o anúncio de cortes e convocações no início da preparação</segment>
    <segment id="37">, no CT em Teresópolis.</segment>
    <segment id="38">Na Copa</segment>
    <segment id="39">, o QG da Globo ficava no estacionamento do hotel "exclusivo</segment>
    <segment id="40">" onde estavam os brasileiros.</segment>
    <segment id="41">Imagens do narrador Galvão BuenoMais    novamente         de   de  de  representando um</segment>
    <segment id="42">Na Copa de 2006</segment>
    <segment id="43">, jogadores na Europa deram entrevista ao vivo ao Jornal Nacional</segment>
    <segment id="44">, quando era cerca de 1h no horário local.</segment>
    <segment id="45">Os treinos eram abertos</segment>
    <segment id="46">, e na primeira fase</segment>
    <segment id="47">, em Weggis</segment>
    <segment id="48">, na Suíça.</segment>
    <segment id="49">Em 2010</segment>
    <segment id="50">, o técnico Dunga implantou um estilo disciplinador</segment>
    <segment id="51">, barrou as regalias da Globo</segment>
    <segment id="52">, quebrando a programação da emissora e ignorando o fato de ser a detentora dos direitos de transmissão.</segment>
    <segment id="53">A firmeza do treinador em não permitir privilégios provocou cenas inusitadas</segment>
    <segment id="54">, como</segment>
    <segment id="55">como o próprio chefe da comunicação da CBF tentando levar jogadores ao estúdio da emissora na África do Sul por baixo do queixo de Dunga.</segment>
    <segment id="56">Por fim</segment>
    <segment id="57">, em 2014</segment>
    <segment id="58">, aconteceu quase de tudo nos treinos da seleção em Teresópolis.</segment>
    <segment id="59">Os jogadores nem precisaram ir aos estúdios da Globo.</segment>
    <segment id="60">Seus apresentadores entraram no CT e gravaram o que quiseram.</segment>
    <segment id="61">Os treinos foram tumultuados do começo até quase o fim</segment>
    <segment id="62">, todos completamente aos olhos de todo mundo</segment>
    <segment id="63">, e deu no que deu.</segment>
    <segment id="64">Em 2006 e 2014</segment>
    <segment id="65">, a Globo contou com a boa vontade de Carlos Alberto Parreira</segment>
    <segment id="66">, como</segment>
    <segment id="67">como técnico e coordenador</segment>
    <segment id="68">, respectivamente.</segment>
    <segment id="69">Com Tite</segment>
    <segment id="70">, sese estabeleceu um meio termo entre Dunga e Parreira: acesso muito restrito</segment>
    <segment id="71">, masmas não zerado</segment>
    <segment id="72">, e relação muito cordial entre emissora e técnico.</segment>
    <segment id="73">A Globo</segment>
    <segment id="74">, sem o poder de antes</segment>
    <segment id="75">, entendeu o seu limite e aceitou.</segment>
    <segment id="76">Desde 2017</segment>
    <segment id="77">, pelo menos</segment>
    <segment id="78">, a Globo vem tratando Tite quase</segment>
    <segment id="79">comocomo um parceiro.</segment>
    <segment id="80">Nesta Copa</segment>
    <segment id="81">, só se</segment>
    <segment id="82">se questiona (pouco) os jogadores e prevalece a vontade de ver o "copo meio cheio"</segment>
    <segment id="83">, nas palavras de um de seus apresentadores.</segment>
    <segment id="84">Resta ver o que acontecerá</segment>
    <segment id="85">sese o Brasil cair nas oitavas (</segment>
    <segment id="86">comocomo em 1990)</segment>
    <segment id="87">, nas quartas (1982</segment>
    <segment id="88">, 1986</segment>
    <segment id="89">, 2006</segment>
    <segment id="90">, 2010 e 2018)</segment>
    <segment id="91">, nas semis (1974</segment>
    <segment id="92">, 1978 e 2014) ou na final (1998).</segment>
    <segment id="93">Se o hexa vier</segment>
    <segment id="94">, não haverá surpresa.</segment>
  </rst>
</analysis>