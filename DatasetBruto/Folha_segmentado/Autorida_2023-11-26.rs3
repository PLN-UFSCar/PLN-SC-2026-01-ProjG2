  </header>
  <rst>
    <segment id="1">Alto e com barba rala</segment>
    <segment id="2">, Jihad Imtoor é o orgulhoso filho de um combatente morto na primeira intifada</segment>
    <segment id="3">, ou levante</segment>
    <segment id="4">, contra Israel.</segment>
    <segment id="5">Seu pai era membro do Fatah</segment>
    <segment id="6">, a facção política que controla a Autoridade Nacional Palestina (ANP).</segment>
    <segment id="7">Mas ele já teve o suficiente do seu governo na Cisjordânia.</segment>
    <segment id="8">Em um dia recente</segment>
    <segment id="9">, Imtoor</segment>
    <segment id="10">, 32, proprietário de um pequeno negócio</segment>
    <segment id="11">, ficou do lado de fora de sua loja</segment>
    <segment id="12">, observando uma marcha pelos muitos palestinos detidos em prisões israelenses</segment>
    <segment id="13">, que o Hamas diz estar tentando libertar</segment>
    <segment id="14">comocomo parte de um acordo de cessar-fogo na Faixa de Gaza.</segment>
    <segment id="15">Pessoas olham estragos provocados na cidade de Gaza após bombardeio de Israel - Samar Abu Elouf/NYT"Eu não sou do Hamas</segment>
    <segment id="16">, masmas espero que eles venham aqui"</segment>
    <segment id="17">, disse.</segment>
    <segment id="18">"</segment>
    <segment id="19">A Autoridade Palestina nos tirou muito</segment>
    <segment id="20">, e está na hora de eles irem</segment>
    <segment id="21">embora</segment>
    <segment id="22">embora.</segment>
    <segment id="23">"Referindo-</segment>
    <segment id="24">sese ao monumento no centro de Ramallah</segment>
    <segment id="25">, ele disse:</segment>
    <segment id="26">"</segment>
    <segment id="27">A Autoridade Palestina está funcionando bem para proteger os quatro leões na Praça Manara</segment>
    <segment id="28">, masmas eles não podem proteger o povo de Israel.</segment>
    <segment id="29">"</segment>
    <segment id="30">O presidente Joe Biden e o secretário de Estado Antony Blinken disseram que</segment>
    <segment id="31">, após a última guerra</segment>
    <segment id="32">, Gaza deveria ser unificada com a Cisjordânia ocupada por Israel sob uma Autoridade Palestina</segment>
    <segment id="33">"revitalizada"</segment>
    <segment id="34">, que controla grandes partes da Cisjordânia em estreita coordenação —alguns dizem colaboração— com Israel.</segment>
    <segment id="35">Hoje, poucas pessoas na Cisjordânia ou em Israel consideram a autoridade capaz de governar uma Gaza pós-conflito.</segment>
    <segment id="36">A ANP é profundamente impopular mesmo onde tem controle na Cisjordânia</segment>
    <segment id="37">, porque</segment>
    <segment id="38">porque é vista</segment>
    <segment id="39">comocomo uma subcontratada da longa ocupação israelense.</segment>
    <segment id="40">Seu apoio é tão frágil</segment>
    <segment id="41">, na verdade</segment>
    <segment id="42">, que dificilmente sobreviveria sem a segurança fornecida pelo Exército de Israel.</segment>
    <segment id="43">Criada após os Acordos de Oslo de 1993</segment>
    <segment id="44">, a Autoridade Palestina foi concebida</segment>
    <segment id="45">comocomo uma administração temporária rumo a um Estado palestino independente.</segment>
    <segment id="46">É dominada pela facção Fatah</segment>
    <segment id="47">, exclui o Hamas e</segment>
    <segment id="48">, durante grande parte desse tempo</segment>
    <segment id="49">, foi liderada pelo presidente Mahmoud Abbas</segment>
    <segment id="50">, também conhecido</segment>
    <segment id="51">comocomo Abu Mazen</segment>
    <segment id="52">, que agora tem 88 anos.</segment>
    <segment id="53">Guerra transforma Gaza em cemitério para criançasMais    novamente         de   de  de  representando um  Abbas garantiu que não houvesse eleições nacionais desde que o Fatah perdeu uma votação legislativa para o Hamas em 2006.</segment>
    <segment id="54">No ano anterior</segment>
    <segment id="55">, ele foi eleito presidente para o que deveria ser um mandato de quatro anos.</segment>
    <segment id="56">Na opinião de muitas das pessoas que</segment>
    <segment id="57">, em tese</segment>
    <segment id="58">, representa</segment>
    <segment id="59">, a ANP</segment>
    <segment id="60">sese tornou uma administração autoritária</segment>
    <segment id="61">, corrupta e antidemocrática que</segment>
    <segment id="62">sese senta em um trono de ferro construído por Israel.</segment>
    <segment id="63">Restaurar a credibilidade da entidade</segment>
    <segment id="64">, dizem palestinos e especialistas</segment>
    <segment id="65">, exigiria ampliar sua base para incluir o Hamas e outros grupos palestinos</segment>
    <segment id="66">, realizar eleições para formar uma nova liderança e insistir na reunificação da Cisjordânia e Gaza sob algum tipo de paradigma de dois Estados com Israel.</segment>
    <segment id="67">Mas os ataques liderados pelo Hamas em 7 de outubro quase destruíram a confiança israelense na governança palestina</segment>
    <segment id="68">, e se</segment>
    <segment id="69">se as eleições fossem realizadas hoje</segment>
    <segment id="70">, é provável</segment>
    <segment id="71">, segundo especialistas e pesquisas</segment>
    <segment id="72">, que o Hamas venceria novamente.</segment>
    <segment id="73">Quando questionada</segment>
    <segment id="74">sese a ANP poderia governar Gaza</segment>
    <segment id="75">, Asala Khdour</segment>
    <segment id="76">, 30, dona de casa de Ramallah</segment>
    <segment id="77">, foi categórica.</segment>
    <segment id="78">"</segment>
    <segment id="79">Absolutamente não.</segment>
    <segment id="80">A Autoridade Palestina está apenas sentada.</segment>
    <segment id="81">Aquele que faz pelo povo deve estar no comando do povo"</segment>
    <segment id="82">, disse.</segment>
    <segment id="83">O sucesso do Hamas em infligir um grande golpe a Israel humilhou Abbas</segment>
    <segment id="84">, que ao mesmo tempo está tentando manter a paz na Cisjordânia com os israelenses</segment>
    <segment id="85">, por mais difícil e impopular que isso possa ser.  Guerra Israel e HamasO boletim diário para você entender o que acontece no conflito entre Israel e o grupo terrorista HamasCarregando...</segment>
    <segment id="86">A Cisjordânia está repleta de assentamentos israelenses e postos de controle</segment>
    <segment id="87">, dividindo a terra e tornando a viagem para os palestinos um percurso de obstáculos e bloqueios de estradas.</segment>
    <segment id="88">Há um aumento da violência contra os palestinos por colonos israelenses e agora constantes incursões que o Exército israelense diz serem direcionadas a membros e combatentes do Hamas</segment>
    <segment id="89">, especialmente ao redor de Nablus e Jenin.</segment>
    <segment id="90">Mesmo entre uma classe média em ascensão que cresceu na relativa estabilidade da Cisjordânia</segment>
    <segment id="91">, há pouco respeito pela ANP.</segment>
    <segment id="92">Com problemas financeiros e um orçamento apertado</segment>
    <segment id="93">, ela já reduziu os salários que paga em cerca de 30%</segment>
    <segment id="94">, reconheceu Sabri Saidam</segment>
    <segment id="95">, membro influente do Comitê Central do Fatah.</segment>
    <segment id="96">"</segment>
    <segment id="97">Como eles podem governar Gaza?</segment>
    <segment id="98">", perguntou Iyad Masrouji</segment>
    <segment id="99">, CEO da Jerusalem Pharmaceuticals</segment>
    <segment id="100">, que opera na Cisjordânia e em Gaza.</segment>
    <segment id="101">"</segment>
    <segment id="102">Os americanos falam com a retórica de 30 anos atrás.</segment>
    <segment id="103">Mas vivemos em uma realidade diferente.</segment>
    <segment id="104">Se tivéssemos uma eleição justa</segment>
    <segment id="105">, o Hamas venceria.</segment>
    <segment id="106">"</segment>
    <segment id="107">As pessoas veem a liderança palestina</segment>
    <segment id="108">"negociando por anos por sua própria sobrevivência política</segment>
    <segment id="109">, não pelo bem de suas aspirações nacionais"</segment>
    <segment id="110">, disse Zakaria al-Qaq</segment>
    <segment id="111">, cientista político palestino.</segment>
    <segment id="112">"</segment>
    <segment id="113">Eles não conseguiram alcançar nenhum dos dois.</segment>
    <segment id="114">"</segment>
    <segment id="115">Embora o Fatah tenha</segment>
    <segment id="116">sese comprometido com o reconhecimento de Israel</segment>
    <segment id="117">, uma solução de dois Estados agora parece um sonho distante para muitos</segment>
    <segment id="118">, minada pelos assentamentos israelenses na Cisjordânia e pelos governos de direita do país.</segment>
    <segment id="119">A falta de um acordo de paz negociado tornou a outra alternativa óbvia —a resistência armada palestina à ocupação israelense— mais aceitável e popular.</segment>
    <segment id="120">Apesar da brutalidade do Hamas em 7 de outubro</segment>
    <segment id="121">, quando Israel diz ter matado cerca de 1.200 pessoas e feito cerca de 240 reféns</segment>
    <segment id="122">, os palestinos na Cisjordânia em geral saudaram o grupo por romper a dominação de Israel e trazer o destino dos palestinos de volta ao foco internacional.</segment>
    <segment id="123">Guerra em Gaza eleva tensão na CisjordâniaMais    novamente         de   de  de  representando um  "</segment>
    <segment id="124">Do ponto de vista palestino</segment>
    <segment id="125">, parecia um milagre"</segment>
    <segment id="126">, disse Sari Nusseibeh</segment>
    <segment id="127">, um palestino moderado que foi presidente da Universidade Al Quds.</segment>
    <segment id="128">"</segment>
    <segment id="129">Esta fortaleza de Israel de repente parecia vulnerável.</segment>
    <segment id="130">"</segment>
    <segment id="131">Nusseibeh disse que abominava a violência perpetrada pelo Hamas em 7 de outubro</segment>
    <segment id="132">, masmas é claro sobre o impacto.</segment>
    <segment id="133">"</segment>
    <segment id="134">Quem é a liderança palestina agora?</segment>
    <segment id="135">É o Hamas</segment>
    <segment id="136">, goste ou não"</segment>
    <segment id="137">, disse Nusseibeh.</segment>
    <segment id="138">"</segment>
    <segment id="139">No momento</segment>
    <segment id="140">, o Hamas é visto pelos palestinos</segment>
    <segment id="141">comocomo o principal representante dos interesses palestinos.</segment>
    <segment id="142">"</segment>
    <segment id="143">E por quê?</segment>
    <segment id="144">"</segment>
    <segment id="145">Porque ninguém mais é.</segment>
    <segment id="146">A Autoridade Palestina não figura na mente das pessoas.</segment>
    <segment id="147">"</segment>
    <segment id="148">No entanto</segment>
    <segment id="149">, o que manteve a Autoridade Palestina viva através de anos de negligência internacional e domínio israelense é a falta de alternativas.  "</segment>
    <segment id="150">A ANP tem</segment>
    <segment id="151">sese segurado com unhas e dentes há algum tempo"</segment>
    <segment id="152">, disse Diana Buttu</segment>
    <segment id="153">, advogada que já foi conselheira jurídica da Organização para a Libertação da Palestina</segment>
    <segment id="154">, masmas</segment>
    <segment id="155">sese tornou crítica.</segment>
    <segment id="156">"</segment>
    <segment id="157">Ninguém na comunidade internacional quer assinar o atestado de óbito</segment>
    <segment id="158">, porque</segment>
    <segment id="159">porque significa o fim do processo de paz</segment>
    <segment id="160">, da solução de dois Estados e deste corpo muito conveniente ao qual eles podem culpar e canalizar dinheiro.</segment>
    <segment id="161">"</segment>
    <segment id="162">Biden não fez praticamente nada por Abbas ou pela ANP</segment>
    <segment id="163">, diz Buttu.</segment>
    <segment id="164">"E agora aqui estamos</segment>
    <segment id="165">, e de repente ele é a esperança deles.</segment>
    <segment id="166">É simplesmente inacreditável.</segment>
    <segment id="167">É um pensamento dos anos 1990 que não pode mais ser revivido.</segment>
    <segment id="168">"</segment>
    <segment id="169">Para os israelenses</segment>
    <segment id="170">, a ANP tem</segment>
    <segment id="171">sese mostrado uma ferramenta útil para acalmar a raiva popular em relação à guerra em Gaza.</segment>
    <segment id="172">Mas as tensões estão aumentando</segment>
    <segment id="173">, disse um alto funcionário de segurança israelense sob condição de anonimato</segment>
    <segment id="174">, com a autoridade perdendo influência em partes do norte</segment>
    <segment id="175">, especialmente em torno de Jenin</segment>
    <segment id="176">, onde as forças israelenses tentaram retomar o controle.</segment>
    <segment id="177">Veja as armas de IsraelMais    novamente         de   de  de  representando um</segment>
    <segment id="178">As tensões também estão altas</segment>
    <segment id="179">porque</segment>
    <segment id="180">porque algumas centenas dos 500 mil colonos israelenses na Cisjordânia estão usando a guerra em Gaza para atacar os palestinos</segment>
    <segment id="181">, disse o mesmo funcionário</segment>
    <segment id="182">, e a violência está aumentando.  Autoridades da Autoridade Palestina afirmam que</segment>
    <segment id="183">, apesar da pressão popular para confrontar Israel</segment>
    <segment id="184">, eles estão agindo para proteger seu próprio povo.</segment>
    <segment id="185">Hussein al-Sheikh</segment>
    <segment id="186">, secretário-geral da Organização para a Libertação da Palestina e um assessor próximo de Abbas</segment>
    <segment id="187">, disse em uma entrevista que</segment>
    <segment id="188">, ao contrário da "reação extrema" de Israel em Gaza</segment>
    <segment id="189">, "do lado da ANP</segment>
    <segment id="190">, a decisão foi manter a calma</segment>
    <segment id="191">, a segurança e a estabilidade</segment>
    <segment id="192">, bem como</segment>
    <segment id="193">como a paz".</segment>
    <segment id="194">Khalil Shikaki</segment>
    <segment id="195">, um proeminente pesquisador palestino</segment>
    <segment id="196">, disse que em sua última pesquisa</segment>
    <segment id="197">, ainda não publicada</segment>
    <segment id="198">, 66% dos palestinos na Cisjordânia consideram a ANP um fardo.</segment>
    <segment id="199">Cerca de 85% querem que Abbas renuncie —e isso significa "mais de 60% de sua própria base" no Fatah quer que ele vá</segment>
    <segment id="200">embora</segment>
    <segment id="201">embora</segment>
    <segment id="202">, disse Shikaki.</segment>
    <segment id="203">Lá foraReceba no seu email uma seleção semanal com o que de mais importante aconteceu no mundoCarregando...</segment>
    <segment id="204">A Autoridade em seu estado atual poderia assumir Gaza?</segment>
    <segment id="205">"</segment>
    <segment id="206">Claro que não"</segment>
    <segment id="207">, disse ele.</segment>
    <segment id="208">"</segment>
    <segment id="209">Governar é estabelecer a lei e a ordem e fazer cumprir as regras</segment>
    <segment id="210">, e a ANP não consegue fazer isso.</segment>
    <segment id="211">"</segment>
    <segment id="212">A única solução</segment>
    <segment id="213">, muitos palestinos dizem</segment>
    <segment id="214">, é encontrar uma maneira de trazer o Hamas para a Organização para a Libertação da Palestina e para a Autoridade Palestina</segment>
    <segment id="215">, ambas lideradas por Abbas e pelo Fatah.</segment>
    <segment id="216">Uma OLP mais representativa poderia realizar novas eleições para uma Autoridade Palestina mais representativa</segment>
    <segment id="217">, que teria muito mais credibilidade tanto em Gaza quanto na Cisjordânia</segment>
    <segment id="218">, segundo essa linha de pensamento.</segment>
    <segment id="219">Mas também exigiria que o Hamas enfraquecido concordasse em aceitar a existência de Israel e</segment>
    <segment id="220">sese comprometesse a negociar um Estado palestino ao lado dele.</segment>
    <segment id="221">"</segment>
    <segment id="222">No momento</segment>
    <segment id="223">, o povo palestino não tem esperança</segment>
    <segment id="224">, masmas um processo de paz real poderia proporcionar isso</segment>
    <segment id="225">, e o Hamas poderia fazer parte disso"</segment>
    <segment id="226">, disse Qadura Fares</segment>
    <segment id="227">, ex-ministro da ANP.</segment>
    <segment id="228">"</segment>
    <segment id="229">Na OLP</segment>
    <segment id="230">, precisamos de todas as facções palestinas juntas.</segment>
    <segment id="231">"</segment>
    <segment id="232">Incluir o Hamas em uma nova Autoridade Palestina também poderia ser uma maneira de contornar o que fazer com o grupo</segment>
    <segment id="233">, que é rejeitado por Israel e pelo Ocidente.</segment>
    <segment id="234">"</segment>
    <segment id="235">Não podem acabar com o Hamas</segment>
    <segment id="236">; não se</segment>
    <segment id="237">se pode acabar com algo nos corações das pessoas"</segment>
    <segment id="238">, disse Munir Zughir</segment>
    <segment id="239">, que tem um filho prisioneiro proeminente do Hamas e outro que está evitando a prisão por seu envolvimento com o grupo.</segment>
    <segment id="240">"</segment>
    <segment id="241">O mundo não lidará com o Hamas</segment>
    <segment id="242">, masmas eles o farão através da ANP.</segment>
    <segment id="243">"</segment>
    <segment id="244">Residentes palestinos assistem entrada de soldados israelenses na vizinhança de Huwara</segment>
    <segment id="245">, na Cisjordânia - Samar Abu Elouf/NYTMas quem pode suceder Abbas?</segment>
    <segment id="246">Alguns têm</segment>
    <segment id="247">sese concentrado em Marwan Barghouti</segment>
    <segment id="248">, 64, que está cumprindo cinco penas de prisão perpétua consecutivas em uma prisão israelense por assassinatos cometidos durante a primeira e segunda intifadas</segment>
    <segment id="249">, que ele liderou</segment>
    <segment id="250">, masmas que poderia fazer parte de uma troca de prisioneiros maior para ajudar a encerrar a guerra.</segment>
    <segment id="251">As últimas pesquisas do Arab Barometer</segment>
    <segment id="252">, que estuda a opinião no Oriente Médio e no Norte da África</segment>
    <segment id="253">, mostram que Barghouti é consideravelmente mais popular em Gaza do que Ismail Haniyeh</segment>
    <segment id="254">, o ex-líder do Hamas em Gaza</segment>
    <segment id="255">, ou Abbas.</segment>
    <segment id="256">Outra alternativa</segment>
    <segment id="257">, embora</segment>
    <segment id="258">embora ele continue sendo uma figura divisiva</segment>
    <segment id="259">, poderia ser Mohammed Dahlan</segment>
    <segment id="260">, um ex-líder do Fatah de Gaza</segment>
    <segment id="261">, derrubado pelo Hamas em 2007 e desde então excluído por Abbas.</segment>
    <segment id="262">Dahlan</segment>
    <segment id="263">, 62, agora vive nos Emirados Árabes Unidos.</segment>
    <segment id="264">O que mais importa é um novo compromisso dos Estados Unidos em fornecer aos palestinos uma perspectiva realista de um estado independente</segment>
    <segment id="265">, disse Saidam</segment>
    <segment id="266">, o alto funcionário do Fatah.</segment>
    <segment id="267">"</segment>
    <segment id="268">A marginalização dos palestinos pelos Estados Unidos</segment>
    <segment id="269">, o corte de fundos e os sucessivos governos israelenses de direita levaram a essa situação desesperadamente perigosa"</segment>
    <segment id="270">, disse Saidam.</segment>
    <segment id="271">"</segment>
    <segment id="272">A administração dos EUA será séria desta vez?</segment>
    <segment id="273">"  "</segment>
    <segment id="274">Qualquer solução política que leve à criação de um Estado palestino será um fator tranquilizador"</segment>
    <segment id="275">, disse ele.</segment>
    <segment id="276">"Mas se</segment>
    <segment id="277">se voltarmos a 'um processo'</segment>
    <segment id="278">, a conversas vazias</segment>
    <segment id="279">, à falta de seriedade</segment>
    <segment id="280">, a outra rodada de sessões de fotos</segment>
    <segment id="281">, isso não nos levará a lugar nenhum.</segment>
    <segment id="282">"</segment>
  </rst>
</analysis>