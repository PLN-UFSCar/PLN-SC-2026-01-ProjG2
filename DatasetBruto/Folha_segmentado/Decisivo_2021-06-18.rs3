  <rst>
    <segment id="1">Neymar demonstrou emoção após a vitória por 4 a 0 da seleção brasileira sobre o Peru</segment>
    <segment id="2">, na noite de quinta-feira (17).</segment>
    <segment id="3">O atacante participou de todos os gols do tranquilo triunfo verde-amarelo no estádio Nilton Santos</segment>
    <segment id="4">, no Rio de Janeiro</segment>
    <segment id="5">, pela Copa América</segment>
    <segment id="6">, e chegou a levar as mãos ao rosto</segment>
    <segment id="7">comocomo</segment>
    <segment id="8">sese estivesse contendo lágrimas.</segment>
    <segment id="9">“</segment>
    <segment id="10">É óbvio que</segment>
    <segment id="11">, para mim</segment>
    <segment id="12">, é uma honra muito grande fazer parte da história da seleção brasileira.</segment>
    <segment id="13">Para ser bem sincero</segment>
    <segment id="14">, meu sonho sempre foi jogar na seleção</segment>
    <segment id="15">, vestir esta camisa.</segment>
    <segment id="16">Nunca imaginei chegar a esses números”</segment>
    <segment id="17">, disse o jogador.</segment>
    <segment id="18">Agora com 68 bolas na rede pelo time nacional</segment>
    <segment id="19">, ele está apenas nove atrás de Pelé</segment>
    <segment id="20">, de quem recebeu uma série de elogios (leia mais abaixo).</segment>
    <segment id="21">Neymar procurou reiterar seu orgulho de defender a seleção - Mauro Pimentel/AFP“Para mim</segment>
    <segment id="22">, é até emocionante</segment>
    <segment id="23">, porque</segment>
    <segment id="24">porque passei por muita coisa nesses dois anos que são bem difíceis</segment>
    <segment id="25">, complicadas</segment>
    <segment id="26">, e esses números não são nada.</segment>
    <segment id="27">[O que importa é] a felicidade que eu tenho de jogar pelo Brasil</segment>
    <segment id="28">, de representar meu país</segment>
    <segment id="29">, minha família.</segment>
    <segment id="30">Espero que todo o mundo que gosta de futebol goste de mim”</segment>
    <segment id="31">, acrescentou.</segment>
    <segment id="32">Nos últimos dois anos</segment>
    <segment id="33">, Neymar teve problemas físicos que o afastaram de momentos importantes do Paris Saint-Germain e da própria seleção.</segment>
    <segment id="34">Também viveu situações conturbadas fora de campo</segment>
    <segment id="35">, com uma acusação de estupro que acabou sendo arquivada pela Polícia Civil e outra de ataque sexual</segment>
    <segment id="36">, que veio à tona recentemente.</segment>
    <segment id="37">O jogador de 29 anos negou as acusações e entrou em guerra com a Nike</segment>
    <segment id="38">, seu antigo patrocinador</segment>
    <segment id="39">, que confirmou ter investigado o suposto ataque.</segment>
    <segment id="40">Ele chegou a esconder o logotipo da empresa no uniforme de treino da seleção</segment>
    <segment id="41">, antes de conseguir uma sequência bastante positiva com a camisa verde-amarela.</segment>
    <segment id="42">Ele balançou a rede nas quatro partidas disputadas desde então (2 a 0 no Equador e 2 a 0 no Paraguai</segment>
    <segment id="43">, pelas Eliminatórias</segment>
    <segment id="44">, 3 a 0 na Venezuela e 4 a 0 no Peru</segment>
    <segment id="45">, pela Copa América).</segment>
    <segment id="46">E recordou que</segment>
    <segment id="47">sese apresentou para essa sequência com várias incertezas</segment>
    <segment id="48">, já que o grupo de jogadores chegou a ameaçar um boicote ao torneio continental</segment>
    <segment id="49">, transferido às pressas para o Brasil.</segment>
    <segment id="50">Brasil 4 x 0</segment>
    <segment id="51">Peru   novamente         de   de  de  representando um  “Chegamos aqui sem saber muito o que estava acontecendo.</segment>
    <segment id="52">Não sabíamos</segment>
    <segment id="53">sese teria Copa América ou não.</segment>
    <segment id="54">Mas, desde o começo</segment>
    <segment id="55">, respeitamos muito a hierarquia”</segment>
    <segment id="56">, afirmou</segment>
    <segment id="57">, procurando minimizar a ameça de não jogar o campeonato –que realmente foi feita– e reiterando seu desejo de defender a seleção.</segment>
    <segment id="58">“Nunca vamos dizer não a esta camisa.</segment>
    <segment id="59">Há pouco</segment>
    <segment id="60">, eu me emocionei ao dizer o que ela representa.</segment>
    <segment id="61">Jamais vou dizer não ao meu país.</segment>
    <segment id="62">Discordar ou ter opinião diferente da que têm os demais acho que é respeito um pelo outro.</segment>
    <segment id="63">Tínhamos nossa opinião.</segment>
    <segment id="64">Expressamos.</segment>
    <segment id="65">Mas estamos aqui.</segment>
    <segment id="66">Foi bem complicado</segment>
    <segment id="67">, masmas a alegria de estar em campo pela seleção sempre vai existir”</segment>
    <segment id="68">, concluiu.</segment>
    <segment id="69">Pelé se</segment>
    <segment id="70">se diz encantado por sorrisos e gols  ​Terminada a vitória do Brasil sobre o Peru</segment>
    <segment id="71">, Pelé publicou uma mensagem carinhosa dirigida a Neymar.</segment>
    <segment id="72">O ex-jogador elogiou o semblante apresentado pelo atacante dentro de campo e afirmou estar torcendo</segment>
    <segment id="73">para que</segment>
    <segment id="74">para que sua marca de gols pela seleção brasileira seja logo superada.</segment>
    <segment id="75">“</segment>
    <segment id="76">Toda vez que vejo esse menino</segment>
    <segment id="77">, ele está sorrindo.</segment>
    <segment id="78">É impossível não sorrir de volta.</segment>
    <segment id="79">É contagiante.</segment>
    <segment id="80">Eu, assim</segment>
    <segment id="81">comocomo todos os brasileiros</segment>
    <segment id="82">, sempre fico feliz quando o vejo jogar bola”</segment>
    <segment id="83">, publicou o rei do futebol.</segment>
    <segment id="84">“</segment>
    <segment id="85">Hoje, ele deu mais um passo em direção ao meu recorde de gols pela seleção.</segment>
    <segment id="86">E estou na torcida</segment>
    <segment id="87">para que</segment>
    <segment id="88">para que ele chegue lá</segment>
    <segment id="89">, com a mesma alegria que tenho desde que o vi jogando pela primeira vez”</segment>
    <segment id="90">, concluiu o ex-atleta de 80 anos.</segment>
  </rst>
</analysis>