  <rst>
    <segment id="1">A dívida pública federal do Brasil cresceu 2</segment>
    <segment id="2">,95% em junho em relação ao mês anterior</segment>
    <segment id="3">, a R$ 6</segment>
    <segment id="4">,191 trilhões</segment>
    <segment id="5">, divulgou o Tesouro Nacional nesta sexta-feira (21)</segment>
    <segment id="6">, citando ambiente favorável para emissões.</segment>
    <segment id="7">No mesmo período</segment>
    <segment id="8">, a dívida pública mobiliária interna teve alta de 3</segment>
    <segment id="9">,3%, a R$ 5</segment>
    <segment id="10">,957 trilhões</segment>
    <segment id="11">, sob o impacto de emissão líquida no valor de R$ 145</segment>
    <segment id="12">,33 bilhões e de apropriação positiva de juros de R$ 44</segment>
    <segment id="13">,93 bilhões.</segment>
    <segment id="14">Em entrevista a jornalistas para comentar o Relatório Mensal da Dívida</segment>
    <segment id="15">, o coordenador de operações da dívida pública do Tesouro</segment>
    <segment id="16">, Roberto Lobarinhas</segment>
    <segment id="17">, citou um ambiente muito favorável para a emissão de dívida em junho.</segment>
    <segment id="18">Cédulas de real - Gabriel Cabral - 21.ago.2019/Reuters"Mês de junho foi extremamente positivo para os mercados</segment>
    <segment id="19">, positivo para a emissão de dívidas</segment>
    <segment id="20">; percebemos aumento do apetite por risco após a resolução do impasse da dívida dos Estados Unidos"</segment>
    <segment id="21">, avaliou ele.</segment>
    <segment id="22">Além disso</segment>
    <segment id="23">, pesaram positivamente fatores domésticos</segment>
    <segment id="24">comocomo a redução das expectativas de inflação e a melhora da perspectiva de nota de crédito do Brasil pela agência de classificação de risco S&amp;amp</segment>
    <segment id="25">;P, bem</segment>
    <segment id="26">comocomo o avanço da agenda econômica do governo no Congresso</segment>
    <segment id="27">, disse Lobarinhas.</segment>
    <segment id="28">Folha MercadoReceba no seu email o que de mais importante acontece na economia</segment>
    <segment id="29">; aberta para não assinantes.</segment>
    <segment id="30">Carregando...</segment>
    <segment id="31">A participação dos papéis prefixados no total da dívida subiu em junho a 27</segment>
    <segment id="32">,04%, de 26</segment>
    <segment id="33">,17% no mês anterior.</segment>
    <segment id="34">Já os títulos atrelados a índices de preços passou a 29</segment>
    <segment id="35">,46%, de 29</segment>
    <segment id="36">,76% antes</segment>
    <segment id="37">, e os corrigidos pela taxa Selic recuaram a 39</segment>
    <segment id="38">,52%, de 39</segment>
    <segment id="39">,74%.</segment>
    <segment id="40">Enquanto isso</segment>
    <segment id="41">, o colchão de liquidez do Tesouro teve um aumento</segment>
    <segment id="42">, em termos nominais</segment>
    <segment id="43">, de 13</segment>
    <segment id="44">,76%, para R$ 1</segment>
    <segment id="45">,118 trilhão em junho</segment>
    <segment id="46">, informou o Tesouro.</segment>
    <segment id="47">O valor é suficiente para cobrir os pagamentos de 8</segment>
    <segment id="48">,52 meses de vencimentos de dívida</segment>
    <segment id="49">, acima do limite de três meses que o Tesouro considera prudencial para a gestão da dívida.</segment>
    <segment id="50">Reportagem adicional de Luana Maria Benedito</segment>
  </rst>
</analysis>