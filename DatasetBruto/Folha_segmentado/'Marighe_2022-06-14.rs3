  <rst>
    <segment id="1">A Academia Brasileira de Cinema e Artes Audiovisuais divulgou nesta terça-feira (14) a lista dos finalistas à 21ª edição do Grande Prêmio do Cinema Brasileiro.</segment>
    <segment id="2">A cerimônia</segment>
    <segment id="3">, que acontece na Cidade das Artes</segment>
    <segment id="4">, no Rio de Janeiro</segment>
    <segment id="5">, em 10 de agosto</segment>
    <segment id="6">, terá transmissão ao vivo pelo Canal Brasil</segment>
    <segment id="7">, YouTube e Instagram.</segment>
    <segment id="8">Neste ano</segment>
    <segment id="9">, a lista reúne 200 profissionais indicados</segment>
    <segment id="10">, 17 longas-metragens brasileiros e 10 longas estrangeiros</segment>
    <segment id="11">, além de curtas</segment>
    <segment id="12">, produções ibero-americanas e séries de televisão ou do streaming.</segment>
    <segment id="13">Seu Jorge e Adriana Esteves em cena do filme &amp;#039</segment>
    <segment id="14">;Marighella</segment>
    <segment id="15">, de Wagner Moura - DivulgaçãoConcorrendo a 17 prêmios</segment>
    <segment id="16">, "Marighella"</segment>
    <segment id="17">, filme dirigido por Wagner Moura sobre o guerrilheiro homônimo que lutou contra a ditadura militar</segment>
    <segment id="18">, foi o título mais lembrado pelos votantes</segment>
    <segment id="19">, seguido por "</segment>
    <segment id="20">O Silêncio da Chuva"</segment>
    <segment id="21">, de Daniel Filho</segment>
    <segment id="22">, com 11 indicações</segment>
    <segment id="23">, e "7 Prisioneiros"</segment>
    <segment id="24">, de Alexandre Moratto</segment>
    <segment id="25">, e "Veneza"</segment>
    <segment id="26">, de Miguel Falabella</segment>
    <segment id="27">, com 9 cada um.</segment>
    <segment id="28">Confira abaixo os indicados nas principais categorias.</segment>
    <segment id="29">A lista completa de indicações está disponível no site da Academia Brasileira de Cinema.</segment>
