  <rst>
    <segment id="1">Comandado pelo DJ Pedro Sampaio</segment>
    <segment id="2">, o Bloco da Favorita levou um baile funk a céu aberto para uma multidão no centro do Rio de Janeiro na manhã deste domingo (4)</segment>
    <segment id="3">, o último do pré-Carnaval.</segment>
    <segment id="4">O megabloco tem a tradição de reunir famosas.</segment>
    <segment id="5">Desta vez</segment>
    <segment id="6">, a atriz Paolla Oliveira abriu o evento animando os foliões do alto de um trio elétrico</segment>
    <segment id="7">, por volta das 9h.</segment>
    <segment id="8">Em seguida</segment>
    <segment id="9">, coube a Pedro Sampaio assumir o controle da festa.</segment>
    <segment id="10">O DJ usou uma roupa em homenagem à apresentadora Xuxa.</segment>
    <segment id="11">Bloco da Favorita</segment>
    <segment id="12">, comandado pelo DJ Pedro Sampaio e com Paolla Oliveira</segment>
    <segment id="13">, desfila no Rio de Janeiro - João Oliveira/RioturDe imediato</segment>
    <segment id="14">, a multidão de foliões começou a pular</segment>
    <segment id="15">, gritar e descer até o chão na rua Primeiro de Março</segment>
    <segment id="16">, de onde saiu o desfile.</segment>
    <segment id="17">Ao longo da festa</segment>
    <segment id="18">, o funk foi intercalado com outros ritmos</segment>
    <segment id="19">, como</segment>
    <segment id="20">como o axé.</segment>
    <segment id="21">Os foliões Bruno Matedi</segment>
    <segment id="22">, 28, e Poliana Barbosa</segment>
    <segment id="23">, 32, passam a lua de mel no Rio e aproveitaram a ocasião especial para ir ao evento.</segment>
    <segment id="24">O casal do Espírito Santo aprovou a organização da festa.</segment>
    <segment id="25">"</segment>
    <segment id="26">Acho que é meu primeiro bloco na vida"</segment>
    <segment id="27">, afirmou Matedi</segment>
    <segment id="28">, sorrindo.</segment>
    <segment id="29">Por se</segment>
    <segment id="30">se tratar de um megabloco</segment>
    <segment id="31">, a Polícia Militar fez revista utilizando detectores de metal em quem acessava a área da folia.</segment>
    <segment id="32">Agentes também atuaram na segurança espalhados ao longo do desfile.</segment>
    <segment id="33">A polícia afirma que apreendeu cinco facas e outros 30 objetos perfurocortantes nos pontos de revista.</segment>
    <segment id="34">Não houve registro de prisões</segment>
    <segment id="35">, segundo a corporação.</segment>
    <segment id="36">O folião Roberto Santos</segment>
    <segment id="37">, 36, vestiu uma fantasia de Jesus para aproveitar a festa.</segment>
    <segment id="38">Segundo o morador de Niterói</segment>
    <segment id="39">, na região metropolitana do Rio</segment>
    <segment id="40">, ter barba ajudou na escolha.</segment>
    <segment id="41">"</segment>
    <segment id="42">O cabelo é do camelô"</segment>
    <segment id="43">, brincou.</segment>
    <segment id="44">Manhã movimentada no centro do Rio</segment>
    <segment id="45">A folia no centro do Rio não</segment>
    <segment id="46">sese limitou à multidão no Bloco da Favorita.</segment>
    <segment id="47">Outras atrações também movimentaram a região na manhã deste domingo.</segment>
    <segment id="48">Foliões coloriram ruas e avenidas com suas fantasias.</segment>
    <segment id="49">Um dos destaques foi o tradicional cortejo do Cordão do Boitatá</segment>
    <segment id="50">, que atraiu cariocas</segment>
    <segment id="51">comocomo o servidor público Paulo Fraiz</segment>
    <segment id="52">, 39.</segment>
    <segment id="53">"Estava excelente.</segment>
    <segment id="54">É o bloco mais lindo da cidade</segment>
    <segment id="55">, uma alegria grande</segment>
    <segment id="56">, todo mundo fantasiado</segment>
    <segment id="57">, feliz"</segment>
    <segment id="58">, afirmou.</segment>
    <segment id="59">Foi a primeira vez que Fraiz tocou um instrumento musical no Cordão do Boitatá.</segment>
    <segment id="60">Ele carregava um banjo.</segment>
    <segment id="61">Veja imagens dos desfiles dos blocos no Rio de Janeiro neste domingo (4)Mais    novamente         de   de  de  representando um</segment>
    <segment id="62">O bloco Fogo e Paixão</segment>
    <segment id="63">, por sua vez</segment>
    <segment id="64">, lotou o Largo São Francisco de Paula.</segment>
    <segment id="65">Com a temperatura na casa dos 30ºC</segment>
    <segment id="66">, jatos de água foram a saída encontrada para refrescar o público.</segment>
    <segment id="67">"</segment>
    <segment id="68">No Carnaval</segment>
    <segment id="69">, a gente nem sente calor"</segment>
    <segment id="70">, brincou a foliã Jacy Dias</segment>
    <segment id="71">, 53, que participou do bloco.</segment>
  </rst>
</analysis>