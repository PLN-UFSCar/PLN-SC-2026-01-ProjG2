  <rst>
    <segment id="1">O Cade (Conselho Administrativo de Defesa Econômica) considerou complexa a venda da faculdade UniCesumar à Vitru</segment>
    <segment id="2">, que já controla grandes instituições de ensino</segment>
    <segment id="3">comocomo a Uniasselvi</segment>
    <segment id="4">, e pediu mais detalhes para avaliar os riscos à concorrência no setor.</segment>
    <segment id="5">A transação de R$ 3</segment>
    <segment id="6">,2 bilhões foi anunciada em agosto do ano passado.</segment>
    <segment id="7">Segundo a análise do Cade</segment>
    <segment id="8">, até o momento</segment>
    <segment id="9">, a compra resultaria em concentrações elevadas com indicativos de baixa rivalidade em alguns mercados importantes.</segment>
    <segment id="10">Instituição de ensino superior</segment>
    <segment id="11">Uniasselvi - DivulgaçãoO órgão apontou preocupação em relação à qualidade</segment>
    <segment id="12">, padronização e massificação do ensino</segment>
    <segment id="13">, além de uma possível redução no quadro de docentes.</segment>
    <segment id="14">"</segment>
    <segment id="15">Para atuar de forma sólida no setor de educação superior privada são necessários investimentos grandes e constantes em publicidade e marca e</segment>
    <segment id="16">, em havendo aquisições e fusões tais</segment>
    <segment id="17">comocomo esta</segment>
    <segment id="18">, as instituições locais</segment>
    <segment id="19">, regionais</segment>
    <segment id="20">, pequenas e médias enfrentam ainda mais dificuldades comparativas"</segment>
    <segment id="21">, disse o órgão em sua nota técnica</segment>
    <segment id="22">, publicada nesta quinta (17).  Colunas e BlogsReceba no seu email uma seleção de colunas e blogs da Folha</segment>
    <segment id="23">; exclusiva para assinantes.</segment>
    <segment id="24">Carregando...</segment>
    <segment id="25">O Cade pediu que as empresas apresentem informações sobre as eficiências econômicas geradas pela operação e que sejam aprofundadas as análises sobre os pontos que causam preocupação.</segment>
    <segment id="26">Joana Cunha com Andressa Motter e Ana Paula Branco</segment>
  </rst>
