  <rst>
    <segment id="1">A coluna de hoje fala de um tema polêmico: a bissexualidade.</segment>
    <segment id="2">E com um detalhe: quando a pessoa</segment>
    <segment id="3">sese sente bi somente em situações especiais</segment>
    <segment id="4">, como</segment>
    <segment id="5">como em baladas e festas.</segment>
    <segment id="6">Ou seja</segment>
    <segment id="7">, é "bi de festinha"</segment>
    <segment id="8">, como</segment>
    <segment id="9">como se</segment>
    <segment id="10">se diz por aí.</segment>
    <segment id="11">Mas que história é essa?</segment>
    <segment id="12">Tudo bem ser assim?</segment>
    <segment id="13">Colunas e BlogsReceba no seu email uma seleção de colunas e blogs da FolhaCarregando...</segment>
    <segment id="14">Vamos por partes pra entender direitinho essa temática.</segment>
    <segment id="15">A pessoa é bissexual quando sente desejo erótico por ambos os sexos.</segment>
    <segment id="16">Ou seja</segment>
    <segment id="17">, quando</segment>
    <segment id="18">sese interessa amorosa e sexualmente por homens e mulheres.</segment>
    <segment id="19">Lembrando que homossexual é quem sente interesse sexual por pessoas do mesmo sexo</segment>
    <segment id="20">, heterossexual é quem</segment>
    <segment id="21">sese interessa por pessoas do outro sexo</segment>
    <segment id="22">, e pansexual é quem</segment>
    <segment id="23">sese interessa por pessoas de variados sexos e gêneros.</segment>
    <segment id="24">E não há nada de errado em ser de um jeito ou de outro.</segment>
    <segment id="25">Precisamos lembrar também que estamos falando das variadas possibilidades de</segment>
    <segment id="26">sese apaixonar e de sentir desejo e amor por outra pessoa.</segment>
    <segment id="27">E o que define isso em nós?</segment>
    <segment id="28">Um misto de vivências e experiências</segment>
    <segment id="29">, além do jeito de ser de cada um.</segment>
    <segment id="30">Cada pessoa nasce com um jeito único de ser</segment>
    <segment id="31">, só dela</segment>
    <segment id="32">, e vai crescendo e estabelecendo relações que vão dando novos coloridos e significados à vida</segment>
    <segment id="33">comocomo um todo</segment>
    <segment id="34">, o que inclui a vida afetiva e sexual.</segment>
    <segment id="35">É com esse jeito único de ser e com a nossa bagagem (a história de vida) que chegamos ao momento atual e às novas experiências a serem vividas.</segment>
    <segment id="36">E é com esse jeito único que sentimos o desejo</segment>
    <segment id="37">, que brota em nós meio que sem explicação.</segment>
    <segment id="38">Ele pode brotar por pessoas do mesmo sexo</segment>
    <segment id="39">, do outro sexo</segment>
    <segment id="40">, de ambos os sexos</segment>
    <segment id="41">, de variados sexos e gêneros etc.</segment>
    <segment id="42">Entendido isso</segment>
    <segment id="43">, podemos voltar a olhar para a ideia de "bi de festinha".</segment>
    <segment id="44">É a pessoa que vive relacionamentos com alguém do outro sexo</segment>
    <segment id="45">, masmas que</segment>
    <segment id="46">, quando</segment>
    <segment id="47">sese joga na balada</segment>
    <segment id="48">, beija</segment>
    <segment id="49">, fica e talvez chegue até a outras práticas sexuais com alguém do mesmo sexo.</segment>
    <segment id="50">Casal se</segment>
    <segment id="51">se beija - Alexander Grey/UnsplashMas tem algo de errado nisso?</segment>
    <segment id="52">Claro que não</segment>
    <segment id="53">, desde que a pessoa esteja realmente a fim.</segment>
    <segment id="54">Só não é saudável quando ela</segment>
    <segment id="55">sese obriga a viver histórias que não quer por motivos</segment>
    <segment id="56">comocomo</segment>
    <segment id="57">, por exemplo</segment>
    <segment id="58">, ceder a uma pressão do grupo de amigos</segment>
    <segment id="59">, ou seguir a um modismo</segment>
    <segment id="60">, ou algo do tipo.</segment>
    <segment id="61">Mas há quem seja bissexual de carteirinha</segment>
    <segment id="62">, ou seja</segment>
    <segment id="63">, bissexual não só em alguns eventos</segment>
    <segment id="64">, e que</segment>
    <segment id="65">sese incomode com quem é bi de festinha.</segment>
    <segment id="66">O que dizer disso?</segment>
    <segment id="67">O que eu sempre digo nas nossas colunas por aqui: cada pessoa pode e deve ser</segment>
    <segment id="68">comocomo preferir ser.</segment>
    <segment id="69">Cada um pode e deve agir na vida amorosa e sexual</segment>
    <segment id="70">comocomo</segment>
    <segment id="71">sese sentir confortável.</segment>
    <segment id="72">E isso precisa ser respeitado!</segment>
    <segment id="73">O que significa cada letra da sigla LGBTQIA+?Mais    novamente         de   de  de  representando um  Respeito a si e às outras pessoas é a palavra de ordem para vivermos bem em sociedade.</segment>
    <segment id="74">Estou falando aqui de respeito e tolerância à diversidade de jeitos de ser e de viver a vida com amor e prazer.</segment>
    <segment id="75">Resumindo:</segment>
    <segment id="76">sese você é bi de festinha e curte isso</segment>
    <segment id="77">, não há mal algum nessa história.  E quem não é?</segment>
    <segment id="78">Também está tudo certo.</segment>
    <segment id="79">Cada pessoa é única!</segment>
    <segment id="80">Que bom que somos assim</segment>
    <segment id="81">, diversos</segment>
    <segment id="82">, e cada um com um jeito único de ser.</segment>
    <segment id="83">Se você tem alguma pergunta ou sugestão</segment>
    <segment id="84">, escreva para folhateen@grupofolha.com.br.</segment>
    <segment id="85">Até a próxima coluna!</segment>
    <segment id="86">Como parte da iniciativa Todas</segment>
    <segment id="87">, a Folha presenteia mulheres com dois meses de assinatura digital grátis</segment>
  </rst>
