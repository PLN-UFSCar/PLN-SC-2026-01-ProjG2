  <rst>
    <segment id="1">O BNDES  (Banco Nacional de Desenvolvimento Econômico e Social) quer regulamentar um modelo de gestão e sustentabilidade financeira para museus</segment>
    <segment id="2">, bibliotecas e outros tipos de equipamentos culturais.  LUCRO</segment>
    <segment id="3">O banco tem ajudado a Casa Civil a aprimorar o texto de um projeto de lei que cria um modelo brasileiro de “endowments” —fundos provenientes de doação e filantropia em que o dinheiro fica protegido em uma aplicação financeira.</segment>
    <segment id="4">As instituições só podem usar os rendimentos para custear as despesas.</segment>
    <segment id="5">LONGO PRAZO   “</segment>
    <segment id="6">Na Europa</segment>
    <segment id="7">, esse tipo de fundo existe desde o século 16.</segment>
    <segment id="8">No geral</segment>
    <segment id="9">, eles cobrem de 30% a 40% dos custos dos equipamentos culturais.</segment>
    <segment id="10">E como</segment>
    <segment id="11">como só é usado o que entra de rendimento</segment>
    <segment id="12">, os ‘endowments’ proporcionam uma fonte de rende quase infinita”</segment>
    <segment id="13">, afirma Luciane Gorgulho</segment>
    <segment id="14">, chefe do departamento de economia da cultura do BNDES.</segment>
    <segment id="15">AGENDA</segment>
    <segment id="16">O banco também vai patrocinar e sediar o 2º Fórum Internacional de Endowments Culturais</segment>
    <segment id="17">, em novembro deste ano.</segment>
    <segment id="18">A atriz Samantha Schmutz - Leo Martins/FolhapressMICROFONE</segment>
    <segment id="19">A atriz</segment>
    <segment id="20">, cantora e humorista Samantha Schmütz estreia no reality PopStar</segment>
    <segment id="21">, da Globo</segment>
    <segment id="22">, no dia 16 de setembro</segment>
    <segment id="23">; ela também está gravando a próxima temporada do programa Samantha Canta</segment>
    <segment id="24">, do Bis   MÃOS DE TESOURA</segment>
    <segment id="25">A Presidência da República vai gastar R$ 6 milhões por ano em serviços de jardinagens.</segment>
    <segment id="26">Segundo o edital publicado</segment>
    <segment id="27">, devem ser contratados dez funcionários para trabalharem nos 808.145 m² de área.</segment>
    <segment id="28">O contrato ainda prevê um gasto de R$ 16 mil por mês para a compra de vasos</segment>
    <segment id="29">, flores e sementes.</segment>
    <segment id="30">CAMPO ABERTO</segment>
    <segment id="31">O documento afirma que o serviço</segment>
    <segment id="32">sese faz necessário por alguns motivos: segurança para “proporcionar ampla visibilidade das equipes” e “assegurar a adoção de medidas de preservação</segment>
    <segment id="33">, conservação e manutenção dos projetos paisagísticos”.</segment>
    <segment id="34">PRIORIDADES</segment>
    <segment id="35">O texto justifica ainda a contratação dos jardineiros com o fato de os palácios serem residências oficiais e pontos turísticos tombados de Brasília</segment>
    <segment id="36">, que devem ser preservados conforme o projeto original</segment>
    <segment id="37">, “mantendo sua autenticidade</segment>
    <segment id="38">, de modo que permaneça seu valor histórico</segment>
    <segment id="39">, cultural</segment>
    <segment id="40">, arquitetônico</segment>
    <segment id="41">, ambiental</segment>
    <segment id="42">, paisagísticos</segment>
    <segment id="43">, entre outros”.</segment>
    <segment id="44">Show</segment>
    <segment id="45">Ícone seta para esquerdaÍcone seta para direita   novamenteÍcone seta para esquerda</segment>
    <segment id="46">VoltarÍcone seta para cimaÍcone seta para baixoÍcone seta para esquerda Voltar       de  PinterestPinterestÍcone  de  de  representando um  TUPINIQUIM</segment>
    <segment id="47">A cantora Adriana Calcanhotto apresentou o show “A Mulher do Pau Brasil” no Sesc Pinheiros</segment>
    <segment id="48">, na quinta (6).</segment>
    <segment id="49">A atriz Bruna Miglioranza</segment>
    <segment id="50">, o publicitário José Alves e o coordenador de comunicação do SescTV João Cotrim passaram por lá.   PÁGINAS</segment>
    <segment id="51">O livro que vai contar a vida do doleiro Alberto Youssef está em fase de finalização.</segment>
    <segment id="52">Escrito pelo jornalista Pedro Marcondes</segment>
    <segment id="53">, a obra vai retratar desde a infância do doleiro até os bastidores da Operação Lava Jato.</segment>
    <segment id="54">PÁGINAS 2   Foram entrevistadas mais de 200 pessoas</segment>
    <segment id="55">, entre familiares</segment>
    <segment id="56">, amigos</segment>
    <segment id="57">, ex-funcionários</segment>
    <segment id="58">, conhecidos e pessoas que ficaram presas com ele em Curitiba.</segment>
    <segment id="59">A editora responsável pela publicação é a Companhia das Letras.  DE OLHO</segment>
    <segment id="60">O Ministério da Educação assinou um termo de cooperação com a Sociedade Brasileira de Urologia para normatizar e fiscalizar os programas de residência médica na área.</segment>
    <segment id="61">A ideia do acordo é a manutenção da qualidade no ensino e treinamento da Urologia.</segment>
    <segment id="62">PARA SEMPRE</segment>
    <segment id="63">O Instituto do Patrimônio Histórico e Artístico Nacional (Iphan) vai apreciar o tombamento do acervo de Arthur Bispo do Rosário (1909-1989) em reunião no dia 19 deste mês.</segment>
    <segment id="64">PARA SEMPRE 2</segment>
    <segment id="65">O conjunto reúne 805 peças produzidas pelo artista sergipano</segment>
    <segment id="66">, como</segment>
    <segment id="67">como estandartes</segment>
    <segment id="68">, indumentárias e móveis.</segment>
    <segment id="69">Sua obra “Manto da Apresentação” é uma das que devem ser tombadas</segment>
    <segment id="70">comocomo patrimônio cultural brasileiro.</segment>
    <segment id="71">ESQUENTA</segment>
    <segment id="72">O cantor Zeca Pagodinho fará dois shows no camarote Bar Brahma Carnaval 2019</segment>
    <segment id="73">, no Anhembi</segment>
    <segment id="74">, em SP.</segment>
    <segment id="75">Na primeira data (1º/3)</segment>
    <segment id="76">, ele recebe Maria Rita.</segment>
    <segment id="77">Na segunda (2/3)</segment>
    <segment id="78">, cantará acompanhado de sua banda.</segment>
    <segment id="79">Carlinhos Brown</segment>
    <segment id="80">, ao lado do grupo Timbalada</segment>
    <segment id="81">, vai animar o espaço no desfile das campeãs</segment>
    <segment id="82">, no dia 8 de março.  ENQUADRADO</segment>
    <segment id="83">O Museu da Imagem e do Som</segment>
    <segment id="84">, em SP</segment>
    <segment id="85">, começa a vender os ingressos da megaexposição “Quadrinhos” a partir de sexta (14).</segment>
    <segment id="86">A mostra apresenta uma retrospectiva do gênero —super-heróis</segment>
    <segment id="87">, terror</segment>
    <segment id="88">, faroeste</segment>
    <segment id="89">, mangás e outros.</segment>
    <segment id="90">Festa para curadores e artistas da 33ª Bienal de SPÍcone seta para esquerdaÍcone seta para direita</segment>
    <segment id="91">novamenteÍcone seta para esquerda</segment>
    <segment id="92">VoltarÍcone seta para cimaÍcone seta para baixoÍcone seta para esquerda Voltar       de  PinterestPinterestÍcone  de  de  representando</segment>
    <segment id="93">um  ENTRE</segment>
    <segment id="94">OBRAS</segment>
    <segment id="95">O ator Marcos Damigo e o professor Alexandre Nepomuceno foram à festa para curadores e artistas da 33ª Bienal de SP</segment>
    <segment id="96">, em frente à Fundação Bienal</segment>
    <segment id="97">, na quarta (5).</segment>
    <segment id="98">As artistas Sofia Borges</segment>
    <segment id="99">, Claudia Fontes e Katrin Sigurdardóttir compareceram</segment>
    <segment id="100">, assim</segment>
    <segment id="101">comocomo o galerista Anthony Reynolds.   CURTO-CIRCUITO</segment>
    <segment id="102">O ex-vice prefeito de São Paulo e professor da USP Regis Fernandes de Oliveira lança o livro “</segment>
    <segment id="103">As Águas Não São Impetuosas”.</segment>
    <segment id="104">Hoje, às 19h</segment>
    <segment id="105">, na livraria Martins Fontes da av. Paulista.</segment>
    <segment id="106">A Trupe Benkady apresenta o espetáculos “Nimba”.</segment>
    <segment id="107">Hoje, às 13h</segment>
    <segment id="108">, na Praça da Liberdade.</segment>
    <segment id="109">A mostra coletiva “Provence en Hiver” abre amanhã.</segment>
    <segment id="110">Às 19h</segment>
    <segment id="111">, na Lombardi Galeria.  com BRUNA NARCIZO</segment>
    <segment id="112">, BRUNO B. SORAGGI E VICTORIA AZEVEDO</segment>
  </rst>
