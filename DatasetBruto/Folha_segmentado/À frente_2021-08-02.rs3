  <rst>
    <segment id="1">Cris Amin</segment>
    <segment id="2">, 52, produtora cultural.</segment>
    <segment id="3">Celia Ferreira</segment>
    <segment id="4">, 55, matem&amp;aacute</segment>
    <segment id="5">;tica.</segment>
    <segment id="6">Livia Souto</segment>
    <segment id="7">, 57, arquiteta.</segment>
    <segment id="8">Aline Souza</segment>
    <segment id="9">, 33, advogada.</segment>
    <segment id="10">Rosana Romano</segment>
    <segment id="11">, 71, bailarina.</segment>
    <segment id="12">Em comum</segment>
    <segment id="13">, essas mulheres de forma&amp;ccedil</segment>
    <segment id="14">;&amp;otilde</segment>
    <segment id="15">;es e idades t&amp;atilde</segment>
    <segment id="16">;o diversas t&amp;ecirc</segment>
    <segment id="17">;m uma paix&amp;atilde</segment>
    <segment id="18">;o: a cacha&amp;ccedil</segment>
    <segment id="19">;a.</segment>
    <segment id="20">O universo da bebida</segment>
    <segment id="21">, considerada o primeiro destilado das Am&amp;eacute</segment>
    <segment id="22">;ricas</segment>
    <segment id="23">, nunca foi t&amp;atilde</segment>
    <segment id="24">;o feminino.</segment>
    <segment id="25">Elas ocuparam seus lugares na marra</segment>
    <segment id="26">, com disposi&amp;ccedil</segment>
    <segment id="27">;&amp;atilde</segment>
    <segment id="28">;o para enfrentar s&amp;eacute</segment>
    <segment id="29">;culos de preconceitos arraigados</segment>
    <segment id="30">, e trabalham unidas para mudar a imagem da cacha&amp;ccedil</segment>
    <segment id="31">;a e das cachaceiras.</segment>
    <segment id="32">Celia Ferreira prepara uma dose da sua Cachaça Wiba - Gabriel Cabral/Folhapress&amp;ldquo</segment>
    <segment id="33">;Sempre que me perguntam o que eu fa&amp;ccedil</segment>
    <segment id="34">;o, respondo que sou cachaceira.</segment>
    <segment id="35">As pessoas ainda estranham</segment>
    <segment id="36">, riem</segment>
    <segment id="37">, o que a gente n&amp;atilde</segment>
    <segment id="38">;o v&amp;ecirc</segment>
    <segment id="39">;</segment>
    <segment id="40">quando algu&amp;eacute</segment>
    <segment id="41">;m diz que &amp;eacute</segment>
    <segment id="42">; cervejeira&amp;rdquo</segment>
    <segment id="43">;, compara Amin</segment>
    <segment id="44">, produtora da Ti&amp;ecirc</segment>
    <segment id="45">;, eleita a melhor cacha&amp;ccedil</segment>
    <segment id="46">;a branca do Brasil</segment>
    <segment id="47">, em 2020</segment>
    <segment id="48">, pelo 4&amp;ordm</segment>
    <segment id="49">;</segment>
    <segment id="50">Ranking da C&amp;uacute</segment>
    <segment id="51">;pula da Cacha&amp;ccedil</segment>
    <segment id="52">;a.</segment>
    <segment id="53">Amin faz quest&amp;atilde</segment>
    <segment id="54">;o de circular com o broche &amp;ldquo</segment>
    <segment id="55">;Cachaceira&amp;rdquo</segment>
    <segment id="56">; no peito</segment>
    <segment id="57">, disposta mesmo a provocar.</segment>
    <segment id="58">Nas fotos que divulga nas redes sociais</segment>
    <segment id="59">, capricha na produ&amp;ccedil</segment>
    <segment id="60">;&amp;atilde</segment>
    <segment id="61">;o e na maquiagem.</segment>
    <segment id="62">&amp;ldquo</segment>
    <segment id="63">;Quero mostrar que meu produto &amp;eacute</segment>
    <segment id="64">; nobre</segment>
    <segment id="65">, que sou cachaceira</segment>
    <segment id="66">, linda e chique.&amp;rdquo</segment>
    <segment id="67">;  &amp;#039</segment>
    <segment id="68">;Quero mostrar que meu produto é nobre</segment>
    <segment id="69">, que sou cachaceira</segment>
    <segment id="70">, linda e chique&amp;#039</segment>
    <segment id="71">;, diz Cris Amin</segment>
    <segment id="72">, produtora da Cachaça Tiê - Gabriel Cabral/FolhapressMineira da Zona da Mata</segment>
    <segment id="73">, Livia Souto conta que vem de uma fam&amp;iacute</segment>
    <segment id="74">;lia de cachaceiros e que a branquinha produzida pelo av&amp;ocirc</segment>
    <segment id="75">;, que nem r&amp;oacute</segment>
    <segment id="76">;tulo tinha</segment>
    <segment id="77">, sempre estava presente &amp;agrave</segment>
    <segment id="78">; mesa.</segment>
    <segment id="79">Com o passar dos anos</segment>
    <segment id="80">, a produ&amp;ccedil</segment>
    <segment id="81">;&amp;atilde</segment>
    <segment id="82">;o caseira foi</segment>
    <segment id="83">sese aprimorando e</segment>
    <segment id="84">, nas m&amp;atilde</segment>
    <segment id="85">;os do pai dela</segment>
    <segment id="86">, ganhou o r&amp;oacute</segment>
    <segment id="87">;tulo Colombina.</segment>
    <segment id="88">Mas s&amp;oacute</segment>
    <segment id="89">; bem mais tarde</segment>
    <segment id="90">, quando assumiu o alambique</segment>
    <segment id="91">, em 2016</segment>
    <segment id="92">, Souto sentiu</segment>
    <segment id="93">, pela primeira vez</segment>
    <segment id="94">, que pisava em terreno dominado pelos homens.</segment>
    <segment id="95">&amp;ldquo</segment>
    <segment id="96">;Para n&amp;oacute</segment>
    <segment id="97">;s, l&amp;aacute</segment>
    <segment id="98">; em casa</segment>
    <segment id="99">, nunca teve essa hist&amp;oacute</segment>
    <segment id="100">;ria.</segment>
    <segment id="101">Minha m&amp;atilde</segment>
    <segment id="102">;e era mestre-alambiqueira&amp;rdquo</segment>
    <segment id="103">;, recorda.  Celia Ferreira</segment>
    <segment id="104">, ao contr&amp;aacute</segment>
    <segment id="105">;rio, demorou a ter contato com boas cacha&amp;ccedil</segment>
    <segment id="106">;as artesanais.</segment>
    <segment id="107">Incentivada pelo marido</segment>
    <segment id="108">, tomou os primeiros goles</segment>
    <segment id="109">, experimentou drinques e acabou</segment>
    <segment id="110">sese apaixonando.</segment>
    <segment id="111">Hoje, o casal produz a cacha&amp;ccedil</segment>
    <segment id="112">;a Wiba!</segment>
    <segment id="113">e, com base na pr&amp;oacute</segment>
    <segment id="114">;pria viv&amp;ecirc</segment>
    <segment id="115">;ncia, Ferreira</segment>
    <segment id="116">sese dedica a dobrar a resist&amp;ecirc</segment>
    <segment id="117">;ncia de quem ainda torce o nariz para a bebida.</segment>
    <segment id="118">O processo criado pela Wiba! foi batizado de Caipirinha na Boca &amp;ndash</segment>
    <segment id="119">;as pessoas</segment>
    <segment id="120">s&amp;atilde</segment>
    <segment id="121">;o convidadas a morder frutas in natura</segment>
    <segment id="122">, com a&amp;ccedil</segment>
    <segment id="123">;&amp;uacute</segment>
    <segment id="124">;car, mastigar um pouquinho e completar com um gole de cacha&amp;ccedil</segment>
    <segment id="125">;a.</segment>
    <segment id="126">&amp;ldquo</segment>
    <segment id="127">;Nas degusta&amp;ccedil</segment>
    <segment id="128">;&amp;otilde</segment>
    <segment id="129">;es,</segment>
    <segment id="130">vemos que as mulheres s&amp;atilde</segment>
    <segment id="131">;o as mais interessadas em aprender.</segment>
    <segment id="132">Elas chegam achando que caipirinha de vodca &amp;eacute</segment>
    <segment id="133">; melhor</segment>
    <segment id="134">, masmas mudam de opini&amp;atilde</segment>
    <segment id="135">;o depois de provar uma boa cacha&amp;ccedil</segment>
    <segment id="136">;a&amp;rdquo</segment>
    <segment id="137">;, diz a produtora</segment>
    <segment id="138">, que pessoalmente prefere uma boa purinha envelhecida em carvalho.</segment>
    <segment id="139">S&amp;atilde</segment>
    <segment id="140">;o tantas as cachaceiras assumidas que a ConVida &amp;ndash</segment>
    <segment id="141">; Confraria Mulheres da Cacha&amp;ccedil</segment>
    <segment id="142">;a j&amp;aacute</segment>
    <segment id="143">;</segment>
    <segment id="144">soma 504 membros e tem fila de espera para novas associadas.</segment>
    <segment id="145">O grupo</segment>
    <segment id="146">, fundado pela bailarina mineira Rosana Romano em 2017</segment>
    <segment id="147">, come&amp;ccedil</segment>
    <segment id="148">;ou com apenas oito mulheres.</segment>
    <segment id="149">Nos encontros</segment>
    <segment id="150">, que n&amp;atilde</segment>
    <segment id="151">;o t&amp;ecirc</segment>
    <segment id="152">;m periodicidade fixa e tamb&amp;eacute</segment>
    <segment id="153">;m acontecem no formato virtual</segment>
    <segment id="154">, as confreiras fazem degusta&amp;ccedil</segment>
    <segment id="155">;&amp;otilde</segment>
    <segment id="156">;es harmonizadas e</segment>
    <segment id="157">sese divertem com os olhares curiosos.</segment>
    <segment id="158">&amp;ldquo</segment>
    <segment id="159">;H&amp;aacute</segment>
    <segment id="160">;</segment>
    <segment id="161">40 anos</segment>
    <segment id="162">, eu ia aos restaurantes com meu marido e ped&amp;iacute</segment>
    <segment id="163">;amos uma cacha&amp;ccedil</segment>
    <segment id="164">;a e uma cerveja.</segment>
    <segment id="165">O gar&amp;ccedil</segment>
    <segment id="166">;om sempre entregava a cerveja para mim e ficava surpreso ao ver que eu havia pedido justamente a cacha&amp;ccedil</segment>
    <segment id="167">;a.</segment>
    <segment id="168">At&amp;eacute</segment>
    <segment id="169">; hoje</segment>
    <segment id="170">, por incr&amp;iacute</segment>
    <segment id="171">;vel que pare&amp;ccedil</segment>
    <segment id="172">;a, as pessoas ainda estranham um grupo de mulheres reunidas bebendo cacha&amp;ccedil</segment>
    <segment id="173">;a&amp;rdquo</segment>
    <segment id="174">;, conta Romano</segment>
    <segment id="175">, produtora da cacha&amp;ccedil</segment>
    <segment id="176">;a Bem me Quer.  Se depender da advogada Aline Souza</segment>
    <segment id="177">, o territ&amp;oacute</segment>
    <segment id="178">;rio feminino nesse universo ainda tem muito a crescer.</segment>
    <segment id="179">Casada com o sommelier Bruno Videira</segment>
    <segment id="180">, fundador do movimento Viva Cacha&amp;ccedil</segment>
    <segment id="181">;a, ela vem liderando campanhas para mostrar que as cachaceiras n&amp;atilde</segment>
    <segment id="182">;o est&amp;atilde</segment>
    <segment id="183">;o para brincadeira.</segment>
    <segment id="184">A mais recente</segment>
    <segment id="185">, postada no Instagram do movimento na forma de v&amp;iacute</segment>
    <segment id="186">;deos testemunhais</segment>
    <segment id="187">, recebeu o t&amp;iacute</segment>
    <segment id="188">;tulo de &amp;ldquo</segment>
    <segment id="189">;S&amp;eacute</segment>
    <segment id="190">;rie #M&amp;atilde</segment>
    <segment id="191">;eCachaceira&amp;rdquo</segment>
    <segment id="192">;.</segment>
    <segment id="193">&amp;ldquo</segment>
    <segment id="194">;O primeiro v&amp;iacute</segment>
    <segment id="195">;deo que postei</segment>
    <segment id="196">, no Dia da Mulher</segment>
    <segment id="197">, foi uma virada de chave para mim.</segment>
    <segment id="198">Eu, que sempre me via</segment>
    <segment id="199">comocomo coadjuvante do Bruno</segment>
    <segment id="200">, apareci toda vestida de advogada</segment>
    <segment id="201">, assumindo que sou cachaceira</segment>
    <segment id="202">, e a mensagem bombou.</segment>
    <segment id="203">A gente precisa assumir o protagonismo&amp;rdquo</segment>
    <segment id="204">;, diz Souza.</segment>
    <segment id="205">O mundo da cachaça é cada vez mais feminino   novamente         de   de  de  representando um</segment>
    <segment id="206">As mulheres tamb&amp;eacute</segment>
    <segment id="207">;m j&amp;aacute</segment>
    <segment id="208">; ocuparam terreno na outra ponta da cadeia &amp;mdash</segment>
    <segment id="209">;o bar.</segment>
    <segment id="210">No Espa&amp;ccedil</segment>
    <segment id="211">;o Zebra</segment>
    <segment id="212">, a mixologista N&amp;eacute</segment>
    <segment id="213">;li Pereira</segment>
    <segment id="214">, 42, tenta conquistar o paladar da clientela para a cacha&amp;ccedil</segment>
    <segment id="215">;a a partir dos drinques.</segment>
    <segment id="216">&amp;ldquo</segment>
    <segment id="217">;As pessoas t&amp;ecirc</segment>
    <segment id="218">;m um baita preconceito</segment>
    <segment id="219">, pagam caro por qualquer destilado e n&amp;atilde</segment>
    <segment id="220">;o querem pagar por uma boa cacha&amp;ccedil</segment>
    <segment id="221">;a.</segment>
    <segment id="222">No balc&amp;atilde</segment>
    <segment id="223">;o, gosto de oferecer experi&amp;ecirc</segment>
    <segment id="224">;ncias</segment>
    <segment id="225">, &amp;eacute</segment>
    <segment id="226">; uma viagem sem volta.&amp;rdquo</segment>
    <segment id="227">;  S&amp;oacute</segment>
    <segment id="228">;cia do restaurante e bar Jiquitaia</segment>
    <segment id="229">, Nina Bastos</segment>
    <segment id="230">, 38, bate na mesma tecla desde a inaugura&amp;ccedil</segment>
    <segment id="231">;&amp;atilde</segment>
    <segment id="232">;o da casa</segment>
    <segment id="233">, em 2012.</segment>
    <segment id="234">Ela sugere cacha&amp;ccedil</segment>
    <segment id="235">;a n&amp;atilde</segment>
    <segment id="236">;o s&amp;oacute</segment>
    <segment id="237">;</segment>
    <segment id="238">para as caipirinhas &amp;ndash</segment>
    <segment id="239">;a bebida tamb&amp;eacute</segment>
    <segment id="240">;m entra em coquet&amp;eacute</segment>
    <segment id="241">;is cl&amp;aacute</segment>
    <segment id="242">;ssicos revisitados.</segment>
    <segment id="243">De tanta insist&amp;ecirc</segment>
    <segment id="244">;ncia, diz</segment>
    <segment id="245">, o cen&amp;aacute</segment>
    <segment id="246">;rio j&amp;aacute</segment>
    <segment id="247">; mudou.</segment>
    <segment id="248">&amp;ldquo</segment>
    <segment id="249">;No come&amp;ccedil</segment>
    <segment id="250">;o, eu vendia 90% de caipiroscas.</segment>
    <segment id="251">Com esse trabalho de formiguinha</segment>
    <segment id="252">, 95% dos pedidos j&amp;aacute</segment>
    <segment id="253">;</segment>
    <segment id="254">s&amp;atilde</segment>
    <segment id="255">;o caipirinhas</segment>
    <segment id="256">, que fa&amp;ccedil</segment>
    <segment id="257">;o com uma cacha&amp;ccedil</segment>
    <segment id="258">;a branca desenvolvida para n&amp;oacute</segment>
    <segment id="259">;s.</segment>
    <segment id="260">Tem teor alco&amp;oacute</segment>
    <segment id="261">;lico alto</segment>
    <segment id="262">, 47%, para aguentar a dilui&amp;ccedil</segment>
    <segment id="263">;&amp;atilde</segment>
    <segment id="264">;o.&amp;rdquo</segment>
    <segment id="265">;  Consultora de bebidas brasileiras</segment>
    <segment id="266">, Isadora Fornari</segment>
    <segment id="267">, 35, treina equipes de bares</segment>
    <segment id="268">para que</segment>
    <segment id="269">para que aprendam a reconhecer e valorizar boas cacha&amp;ccedil</segment>
    <segment id="270">;as.</segment>
    <segment id="271">E n&amp;atilde</segment>
    <segment id="272">;o sese surpreende ao constatar que o crescimento do p&amp;uacute</segment>
    <segment id="273">;blico feminino</segment>
    <segment id="274">, nos cursos</segment>
    <segment id="275">, chegou a 60% em cinco anos.</segment>
    <segment id="276">&amp;ldquo</segment>
    <segment id="277">;A mulher</segment>
    <segment id="278">sempre foi protagonista.</segment>
    <segment id="279">A cacha&amp;ccedil</segment>
    <segment id="280">;a do Jo&amp;atilde</segment>
    <segment id="281">;o era feita pela Maria</segment>
    <segment id="282">, porque</segment>
    <segment id="283">porque ele cuidava da ro&amp;ccedil</segment>
    <segment id="284">;a enquanto ela ficava no alambique.</segment>
    <segment id="285">As mulheres tamb&amp;eacute</segment>
    <segment id="286">;m gostavam de beber</segment>
    <segment id="287">, s&amp;oacute</segment>
    <segment id="288">; n&amp;atilde</segment>
    <segment id="289">;o podiam demonstrar&amp;rdquo</segment>
    <segment id="290">;, afirma.</segment>
    <segment id="291">Hoje, n&amp;atilde</segment>
    <segment id="292">;o s&amp;oacute</segment>
    <segment id="293">; podem</segment>
    <segment id="294">comocomo</segment>
    <segment id="295">fazem quest&amp;atilde</segment>
    <segment id="296">;o de se</segment>
    <segment id="297">se exibir.</segment>
    <segment id="298">Que o diga Luisa Saliba</segment>
    <segment id="299">, 65, propriet&amp;aacute</segment>
    <segment id="300">;ria do restaurante e bar Rota do Acaraj&amp;eacute</segment>
    <segment id="301">;, cuja carta de cacha&amp;ccedil</segment>
    <segment id="302">;as lista 1.119 r&amp;oacute</segment>
    <segment id="303">;tulos.</segment>
    <segment id="304">Duas vezes por semana</segment>
    <segment id="305">, &amp;agrave</segment>
    <segment id="306">;s quartas e sextas</segment>
    <segment id="307">, ela e a jornalista Denise Marcolino recebem grupos de at&amp;eacute</segment>
    <segment id="308">;</segment>
    <segment id="309">oito pessoas para a experi&amp;ecirc</segment>
    <segment id="310">;ncia Rota da Cacha&amp;ccedil</segment>
    <segment id="311">;a, comercializada pelo Airbnb.</segment>
    <segment id="312">Clientes do Brasil e do exterior pagam R$ 72 por pessoa para assistir &amp;agrave</segment>
    <segment id="313">; aula tril&amp;iacute</segment>
    <segment id="314">;ngue portugu&amp;ecirc</segment>
    <segment id="315">;s/ingl&amp;ecirc</segment>
    <segment id="316">;s/espanhol</segment>
    <segment id="317">, com direito a degusta&amp;ccedil</segment>
    <segment id="318">;&amp;atilde</segment>
    <segment id="319">;o de cinco r&amp;oacute</segment>
    <segment id="320">;tulos.</segment>
    <segment id="321">Em geral</segment>
    <segment id="322">, a plateia &amp;eacute</segment>
    <segment id="323">;</segment>
    <segment id="324">50% feminina.</segment>
    <segment id="325">&amp;ldquo</segment>
    <segment id="326">;Desde que come&amp;ccedil</segment>
    <segment id="327">;amos a trabalhar a ideia de que as mulheres podem entender de cacha&amp;ccedil</segment>
    <segment id="328">;a e apreciar a bebida</segment>
    <segment id="329">, elas est&amp;atilde</segment>
    <segment id="330">;o bebendo mais.</segment>
    <segment id="331">Tanto que</segment>
    <segment id="332">, de uns anos para c&amp;aacute</segment>
    <segment id="333">;, passaram a pedir cacha&amp;ccedil</segment>
    <segment id="334">;a pura</segment>
    <segment id="335">, em doses&amp;rdquo</segment>
    <segment id="336">;, brinda Saliba.</segment>
    <segment id="337">As cachaceiras tamb&amp;eacute</segment>
    <segment id="338">;m est&amp;atilde</segment>
    <segment id="339">;o unidas em torno de uma quest&amp;atilde</segment>
    <segment id="340">;o etimol&amp;oacute</segment>
    <segment id="341">;gica.</segment>
    <segment id="342">Aline Souza</segment>
    <segment id="343">, do Viva Cacha&amp;ccedil</segment>
    <segment id="344">;a, lidera um movimento para exigir que os dicion&amp;aacute</segment>
    <segment id="345">;rios brasileiros mudem a defini&amp;ccedil</segment>
    <segment id="346">;&amp;atilde</segment>
    <segment id="347">;o da palavra cachaceiro.</segment>
    <segment id="348">&amp;ldquo</segment>
    <segment id="349">;Nos principais dicion&amp;aacute</segment>
    <segment id="350">;rios, cervejeiro &amp;eacute</segment>
    <segment id="351">; o produtor ou apreciador de cerveja</segment>
    <segment id="352">, enquanto cachaceiro &amp;eacute</segment>
    <segment id="353">;</segment>
    <segment id="354">quem bebe de forma exagerada.</segment>
    <segment id="355">O mesmo acontece na pesquisa de imagens do Google</segment>
    <segment id="356">, s&amp;oacute</segment>
    <segment id="357">; aparecem fotos de b&amp;ecirc</segment>
    <segment id="358">;bados ca&amp;iacute</segment>
    <segment id="359">;dos&amp;rdquo</segment>
    <segment id="360">;, chia a advogada.</segment>
    <segment id="361">Com ajuda de linguistas e historiadores</segment>
    <segment id="362">, Souza est&amp;aacute</segment>
    <segment id="363">; elaborando um dossi&amp;ecirc</segment>
    <segment id="364">;, que pretende encaminhar &amp;agrave</segment>
    <segment id="365">;s equipes gestoras dos dicion&amp;aacute</segment>
    <segment id="366">;rios e ao site de buscas.</segment>
    <segment id="367">&amp;ldquo</segment>
    <segment id="368">;Esse lado pejorativo tem raz&amp;otilde</segment>
    <segment id="369">;es hist&amp;oacute</segment>
    <segment id="370">;ricas</segment>
    <segment id="371">, masmas est&amp;aacute</segment>
    <segment id="372">; na hora de ressaltar que a cacha&amp;ccedil</segment>
    <segment id="373">;a tem muitos valores positivos.&amp;rdquo</segment>
    <segment id="374">;   Primeiros goles</segment>
    <segment id="375">Aprenda a preparar dois drinques do bar do Jiquitaia &amp;mdash</segment>
    <segment id="376">;na opini&amp;atilde</segment>
    <segment id="377">;o da s&amp;oacute</segment>
    <segment id="378">;cia e especialista em bebidas Nina Bastos</segment>
    <segment id="379">, eles s&amp;atilde</segment>
    <segment id="380">;o uma &amp;oacute</segment>
    <segment id="381">;tima porta de entrada para o mundo da cacha&amp;ccedil</segment>
    <segment id="382">;a.</segment>
    <segment id="383">Flor da Para&amp;iacute</segment>
    <segment id="384">;ba</segment>
    <segment id="385">Na releitura do Sherry Martini v&amp;atilde</segment>
    <segment id="386">;o 20 ml de cacha&amp;ccedil</segment>
    <segment id="387">;a paraibana Serra Limpa armazenada em freij&amp;oacute</segment>
    <segment id="388">;, 50 ml de vinho fortificado Manzanilla La Guita</segment>
    <segment id="389">, 10 ml de vermute seco e 10 ml de &amp;aacute</segment>
    <segment id="390">;gua de azeitona.</segment>
    <segment id="391">Misture os ingredientes com bastante gelo e sirva em ta&amp;ccedil</segment>
    <segment id="392">;a de dry martini</segment>
    <segment id="393">, com uma azeitona.</segment>
    <segment id="394">Drinque</segment>
    <segment id="395">Flor da Paraíba</segment>
    <segment id="396">, de Nina Bastos</segment>
    <segment id="397">, feito com a cachaça Serra Limpa - DivulgaçãoCaju Amigo  Aqui n&amp;atilde</segment>
    <segment id="398">;o entra vodca.</segment>
    <segment id="399">S&amp;oacute</segment>
    <segment id="400">; 60 ml de cacha&amp;ccedil</segment>
    <segment id="401">;a Princesa Isabel Aquarela</segment>
    <segment id="402">, 50 ml de suco natural de caju</segment>
    <segment id="403">, 20 ml de suco de lim&amp;atilde</segment>
    <segment id="404">;o e 20 ml de calda de compota de caju &amp;ndash</segment>
    <segment id="405">;</segment>
    <segment id="406">coloque as frutas da compota no fundo do copo e complete com os outros ingredientes</segment>
    <segment id="407">, batidos na coqueteleira.</segment>
