  <rst>
    <segment id="1">A Feturismo (federação que reúne empresas de hospedagem e lazer) vai pedir ao governo de Ratinho Júnior (PSD)</segment>
    <segment id="2">, no Paraná</segment>
    <segment id="3">, que a futura Ponte de Guaratuba receba o nome de Rei Pelé.</segment>
    <segment id="4">"</segment>
    <segment id="5">É uma importante obra.</segment>
    <segment id="6">O nome do rei Pelé viraria até ponto turístico e ajudaria o litoral"</segment>
    <segment id="7">, diz o presidente da Feturismo</segment>
    <segment id="8">, Fábio Aguayo.</segment>
    <segment id="9">Painel S.A.Receba no seu email as informações exclusivas da coluna</segment>
    <segment id="10">Painel S.A.Carregando...</segment>
    <segment id="11">A ponte terá cerca de 1</segment>
    <segment id="12">,2 km de extensão.</segment>
    <segment id="13">A licitação para a construção da obra</segment>
    <segment id="14">, que vai ligar Guaratuba e Matinhos</segment>
    <segment id="15">, no litoral sul do estado</segment>
    <segment id="16">, teve idas e vindas com os órgãos locais.</segment>
    <segment id="17">Joana Cunha com Paulo Ricardo Martins e Diego</segment>
    <segment id="18">Felix  Lance de Pelé na Copa do Mundo de 1970</segment>
