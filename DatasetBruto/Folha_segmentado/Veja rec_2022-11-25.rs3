  <rst>
    <segment id="1">Nos jogos</segment>
    <segment id="2">, existem diferentes perfis de torcedores.</segment>
    <segment id="3">Tem aquele tio ou amigo cervejeiro que enche o balde de gelo e dá bronca em quem abre a gelada que ainda estava quente.</segment>
    <segment id="4">Tem a pessoa —geralmente é apenas uma mesmo— que assiste ao jogo num silêncio monástico</segment>
    <segment id="5">, vela cada passe dos jogadores e deixa para revelar sua natureza selvagem apenas e tão somente no momento do gol</segment>
    <segment id="6">, quando o berro avisa antes do narrador que o placar mudou.</segment>
    <segment id="7">Pão não queijo</segment>
    <segment id="8">, receita da colunista Luisa Mafei - Luisa MafeiEu sempre fui da turma mais preocupada com os quitutes do que com o jogo ou a bebida.</segment>
    <segment id="9">Tem coisa melhor do que interromper o expediente para comer uma pipoquinha durante 90 minutos?</segment>
    <segment id="10">A pipoca</segment>
    <segment id="11">, por sinal</segment>
    <segment id="12">, é uma das muitas iguarias que é naturalmente vegana.</segment>
    <segment id="13">Milho, óleo e sal: três ingredientes acessíveis e vegetais</segment>
    <segment id="14">, para que</segment>
    <segment id="15">para que ninguém mais ouse dizer que não gosta de "comida vegana"</segment>
    <segment id="16">, ou que tudo que é vegano custa caro.</segment>
    <segment id="17">A paçoca —amendoim e açúcar— também pode compor a mesa dos acepipes veganos</segment>
    <segment id="18">, assim</segment>
    <segment id="19">comocomo os famosos ovinhos de amendoim coloridos.</segment>
    <segment id="20">Azeitonas</segment>
    <segment id="21">, tremoços</segment>
    <segment id="22">, tomatinhos</segment>
    <segment id="23">, milho verde cozido</segment>
    <segment id="24">, torradinhas com azeite</segment>
    <segment id="25">, alho e orégano…</segment>
    <segment id="26">a mesa vegana da copa</segment>
    <segment id="27">sese enche facilmente e agrada todas as torcidas.</segment>
    <segment id="28">Para quem quiser impressionar os amigos</segment>
    <segment id="29">, trago duas receitas práticas em verde e amarelo.</segment>
    <segment id="30">Enquanto o pão de queijo vegano assa</segment>
    <segment id="31">, você prepara o homus de espinafre e em quarenta minutos o banquete está pronto.</segment>
    <segment id="32">Tanto um petisco quanto o outro podem ser congelados para outras ocasiões.</segment>
    <segment id="33">Para quem já estiver pensando na ceia do Natal</segment>
    <segment id="34">, vale a pena guardar o homus.</segment>
    <segment id="35">Servido numa tigela vermelha</segment>
    <segment id="36">, o homus de espinafre ganha um ar natalino.</segment>
    <segment id="37">Seja para comer com palitos de vegetais</segment>
    <segment id="38">, como</segment>
    <segment id="39">como a cenoura</segment>
    <segment id="40">, o pepino e o salsão</segment>
    <segment id="41">, seja para passar no pão</segment>
    <segment id="42">, o homus</segment>
    <segment id="43">sese transforma numa entrada simples e elegante.</segment>
    <segment id="44">Vamos às receitas.</segment>
    <segment id="45">Pão de não queijo  INGREDIENTES  1 xícara de mandioquinha cozida e amassada em purê (pode ser também batata</segment>
    <segment id="46">, batata doce ou mandioca)  1 xícara de polvilho azedo  ½ xícara de polvilho doce  ¼ de xícara de azeite  ¼ de xícara de água  ½ colher de chá de cúrcuma em pó  1 colher de chá de sal  Opcionais:  3 colheres de sopa de manjericão fresco picadinho  1 colher de chá de orégano seco  2 colheres de sopa de levedura nutricional</segment>
    <segment id="47">, para remeter ao sabor do queijo  PREPARO</segment>
    <segment id="48">Pré-aqueça o forno a 180 ºC.</segment>
    <segment id="49">Adicione todos os ingredientes numa tigela média e misture com as mãos</segment>
    <segment id="50">, até obter uma massa.</segment>
    <segment id="51">Se observar que a massa está seca</segment>
    <segment id="52">, adicione mais água</segment>
    <segment id="53">, colher por colher</segment>
    <segment id="54">, até obter a textura de uma massinha de modelar.</segment>
    <segment id="55">Faça bolinhas pequenas e leve numa forma untada com azeite para assar por 25 minutos</segment>
    <segment id="56">, ou até os pãezinhos ficarem ligeiramente dourados.    DICAS</segment>
    <segment id="57">Caso queira congelar</segment>
    <segment id="58">, distribua os pãezinhos crus numa tábua ou assadeira e leve para o congelador por 2 horas.</segment>
    <segment id="59">Quando os pãezinhos estiverem congelados</segment>
    <segment id="60">, transfira para um saco e armazene no congelador por até 3 meses.</segment>
    <segment id="61">Na hora de assar os pãezinhos congelados</segment>
    <segment id="62">, basta levar ao forno pré-aquecido a 180 graus até ficarem dourados.</segment>
    <segment id="63">Aprenda a fazer homus de abóboraMais    novamente         de   de  de  representando um  Homus de espinafre  INGREDIENTES  300 g de folhas de espinafre  2 xícaras de grão de bico cozido e escorrido  ⅓ xícara de tahine</segment>
    <segment id="64">Suco de 1 limão pequeno  ½ dente de alho</segment>
    <segment id="65">1 colher de chá de sal  PREPARO</segment>
    <segment id="66">Leve uma panela grande com água para o fogo.</segment>
    <segment id="67">Assim que a água ferver</segment>
    <segment id="68">, adicione as folhas de espinafre.</segment>
    <segment id="69">Empure com a colher de pau</segment>
    <segment id="70">para que</segment>
    <segment id="71">para que todas as folhas fiquem submersas e cozinhe em fogo médio por 3 minutos.</segment>
    <segment id="72">Enquanto isso</segment>
    <segment id="73">, prepare o choque térmico (uma tigela grande com água e gelo).</segment>
    <segment id="74">Escorra os espinafres cozidos e transfira para o banho de gelo —esse processo ajuda a interromper a cocção do vegetal e a preservar a cor esverdeada e vibrante.</segment>
    <segment id="75">Conte um minuto de choque térmico e em seguida escorra os espinafres.</segment>
    <segment id="76">Esprema bem com as mãos para retirar todo o excesso de água.</segment>
    <segment id="77">Adicione os espinafres no copo do processador de alimentos.</segment>
    <segment id="78">Junte os demais ingredientes no processador de alimentos e triture até obter uma textura lisa</segment>
    <segment id="79">, homogênea e cremosa.    DICA</segment>
    <segment id="80">Essa receita vai render uma bela porção de homus</segment>
    <segment id="81">, aproveite para congelar!</segment>
    <segment id="82">A validade é de 5 dias na geladeira</segment>
    <segment id="83">, e de 3 meses no congelador.</segment>
    <segment id="84">Descongele na geladeira um dia antes de servir.</segment>
  </rst>
</analysis>