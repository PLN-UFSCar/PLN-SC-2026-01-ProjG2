  <rst>
    <segment id="1">O MIS, o Museu da Imagem e do Som</segment>
    <segment id="2">, exibe gratuitamente o filme "Êxtase" (2020)</segment>
    <segment id="3">, dirigido por Moara Passoni</segment>
    <segment id="4">, na próxima terça-feira (11)</segment>
    <segment id="5">, às 19h</segment>
    <segment id="6">, como</segment>
    <segment id="7">como parte do Ciclo de Cinema e Psicanálise.</segment>
    <segment id="8">Com apoio da Folha</segment>
    <segment id="9">, o evento é realizado em parceria com a SBPSP (Sociedade Brasileira de Psicanálise de São Paulo) e</segment>
    <segment id="10">, nesta edição</segment>
    <segment id="11">, com a Descoloniza Filmes.  Moara Passoni</segment>
    <segment id="12">, diretora do filme &amp;#039</segment>
    <segment id="13">;Êxtase&amp;#039</segment>
    <segment id="14">;, durante estreia e debate do filme no Espaço Itaú Frei Caneca - Jardiel Carvalho - 1.dez.2022/FolhapressInspirado em experiências vividas pela própria diretora e por outras mulheres que tiveram transtornos alimentares</segment>
    <segment id="15">, o longa conta a história de Clara durante o período em que a jovem sofreu com anorexia</segment>
    <segment id="16">, dos 7 aos 17 anos.</segment>
    <segment id="17">Para lidar com sentimentos</segment>
    <segment id="18">comocomo vulnerabilidade e medo</segment>
    <segment id="19">, a protagonista cria um mundo paralelo em que consegue controlar emoções e privar-</segment>
    <segment id="20">sese de comer</segment>
    <segment id="21">, levando o corpo ao limite até que o delírio seja interrompido.</segment>
    <segment id="22">Com a autoficção</segment>
    <segment id="23">, Moara foi a única brasileira selecionada para o festival Doc Fortnight</segment>
    <segment id="24">, do MoMA</segment>
    <segment id="25">, o Museu de Arte Moderna de Nova York</segment>
    <segment id="26">, realizado em março de 2021.</segment>
    <segment id="27">Ao lado da cineasta Petra Costa</segment>
    <segment id="28">, que atua</segment>
    <segment id="29">comocomo produtora em "Êxtase"</segment>
    <segment id="30">, ela é roteirista e produtora associada do documentário "Democracia em Vertigem"</segment>
    <segment id="31">, indicado ao Oscar em 2020.</segment>
    <segment id="32">Transtornos alimentares mais comuns entre adolescentesMais    novamente         de   de  de  representando um  Com mediação da psicanalista Luciana Saddi</segment>
    <segment id="33">, a edição conta com a participação da diretora Moara Passoni e da psicanalista Marina Ramalho Miranda</segment>
    <segment id="34">, membro efetivo da SBPSP.</segment>
    <segment id="35">O evento acontece no auditório do MIS (avenida Europa</segment>
    <segment id="36">, 158, na zona oeste de São Paulo)</segment>
    <segment id="37">, e os ingressos ficam disponíveis na bilheteria com uma hora de antecedência.</segment>
    <segment id="38">Ciclo de Cinema e Psicanálise - Filme &amp;#039</segment>
    <segment id="39">;Êxtase&amp;#039</segment>
    <segment id="40">;Quando Terça-feira</segment>
    <segment id="41">, 11 de abril</segment>
    <segment id="42">, às 19hOnde Auditório do Museu da Imagem e do Som - av. Europa</segment>
    <segment id="43">, 158, São PauloPreço Grátis</segment>
  </rst>
