  <rst>
    <segment id="1">Tudo pensado nos mínimos detalhes.</segment>
    <segment id="2">Foi assim durante os 147 dias que Emanuelly Yasmin passou internada no Hospital Municipal Vila Santa Catarina</segment>
    <segment id="3">, em São Paulo.</segment>
    <segment id="4">Afinal</segment>
    <segment id="5">, era preciso adaptar os cuidados para atender a prematura extrema</segment>
    <segment id="6">, hoje considerada o menor bebê com desfecho positivo a sair de uma UTI neonatal de hospital público.</segment>
    <segment id="7">Emanuelly nasceu com 26 semanas e dois dias.</segment>
    <segment id="8">Ela chegou às 14h46 do dia 18 de novembro de 2022</segment>
    <segment id="9">, pesando 335 gramas e 25 centímetros.</segment>
    <segment id="10">Era tão pequena que seus pés mediam 3</segment>
    <segment id="11">,5 centímetros</segment>
    <segment id="12">, o tamanho do polegar da mãe</segment>
    <segment id="13">, Camila Soares</segment>
    <segment id="14">, 27 anos.</segment>
    <segment id="15">Emanuelly ficou cinco meses no hospital e teve alta na última quinta-feira (13) - Divulgação/HMVSCCamila conta que a gravidez de Manu foi uma surpresa.</segment>
    <segment id="16">Em maio de 2021</segment>
    <segment id="17">, ela ficou grávida de um menino</segment>
    <segment id="18">, Miguel Henrique.</segment>
    <segment id="19">A previsão era que o bebê nascesse em fevereiro de 2022</segment>
    <segment id="20">, masmas aos cinco meses ela descobriu que o coraçãozinho não estava mais batendo.</segment>
    <segment id="21">Na época</segment>
    <segment id="22">, Camila foi encaminhada para o Vila Santa Catarina para fazer a curetagem e foi diagnosticada com hipertensão.</segment>
    <segment id="23">Pouco tempo depois</segment>
    <segment id="24">, veio a segunda gravidez e novamente a gestação não evoluiu</segment>
    <segment id="25">comocomo o esperado.</segment>
    <segment id="26">Ela e o marido</segment>
    <segment id="27">, o sushiman Fernando de Sousa Silva</segment>
    <segment id="28">, 28, chegaram a pensar que não conseguiriam ter um filho.</segment>
    <segment id="29">Foi quando surgiu a notícia de Emanuelly.</segment>
    <segment id="30">Como Miguel</segment>
    <segment id="31">, a pequena estava prevista para fevereiro</segment>
    <segment id="32">, masmas começou a sofrer com a variação de pressão da mãe.</segment>
    <segment id="33">Dessa vez</segment>
    <segment id="34">, porém</segment>
    <segment id="35">porém, Camila tinha conhecimento do problema e</segment>
    <segment id="36">, quando um ultrassom indicou que a criança não estava crescendo adequadamente</segment>
    <segment id="37">, procurou o hospital.</segment>
    <segment id="38">Camila</segment>
    <segment id="39">, Fernando e a pequena Emanuelly Yasmin - Arquivo pessoal"Pensei:</segment>
    <segment id="40">‘</segment>
    <segment id="41">O coração dela ainda está batendo.</segment>
    <segment id="42">Seja o que Deus quiser’"</segment>
    <segment id="43">, recorda a mãe.</segment>
    <segment id="44">Camila procurou o pronto-socorro e foi internada no mesmo dia.</segment>
    <segment id="45">No local</segment>
    <segment id="46">, passou a receber corticoides e sulfato de magnésio</segment>
    <segment id="47">, que respectivamente ajudam a estimular a maturação dos pulmões e tem efeito neuroprotetor.</segment>
    <segment id="48">Depois de quatro dias</segment>
    <segment id="49">, a equipe decidiu por uma cesárea de emergência.</segment>
    <segment id="50">"</segment>
    <segment id="51">A mãe e o bebê não estavam bem.</segment>
    <segment id="52">A discussão era</segment>
    <segment id="53">sese seria possível salvar</segment>
    <segment id="54">, sese conseguiríamos ajudá-la a respirar</segment>
    <segment id="55">, masmas a pressão da Camila estava muito difícil de controlar e a Manu estava sofrendo"</segment>
    <segment id="56">, lembra Luísa Zagne</segment>
    <segment id="57">, coordenadora médica da pediatria e neonatologia do hospital.</segment>
    <segment id="58">Manu foi intubada com a menor cânula do mercado.</segment>
    <segment id="59">Depois</segment>
    <segment id="60">, foi levada para uma incubadora que umidifica e aquece o ar e possibilita a realização de alguns exames sem necessidade de remoção.</segment>
    <segment id="61">Era necessário evitar ao máximo qualquer manipulação e simular o útero da melhor forma possível</segment>
    <segment id="62">, afirma Zagne.</segment>
    <segment id="63">LEIA MAISAvanço na medicina e atuação dos pais impactam a sobrevivência de prematurosIndústria usa desconhecimento de mães para elevar venda de fórmulas infantis</segment>
    <segment id="64">, dizem pesquisadoresPesquisa identifica possível causa de partos prematurosO Vila Santa Catarina é administrado pela Sociedade Beneficente Israelita Brasileira Albert Einstein</segment>
    <segment id="65">, e o Einstein emprestou alguns dos equipamentos usados durante a internação</segment>
    <segment id="66">, entre eles um respirador que acompanha o fluxo do bebê</segment>
    <segment id="67">, propiciando movimentos mais naturais</segment>
    <segment id="68">, e um aparelho que funciona em sincronia com o diafragma e contribui para a extubação.  "</segment>
    <segment id="69">Com a Manu tivemos que adaptar.</segment>
    <segment id="70">Foi um desafio único"</segment>
    <segment id="71">, diz Zagne.</segment>
    <segment id="72">As tabelas que estimam a taxa de sobrevivência de prematuros</segment>
    <segment id="73">, por exemplo</segment>
    <segment id="74">, partem de bebês com 400 gramas</segment>
    <segment id="75">, acima do peso de Emanuelly.</segment>
    <segment id="76">Foi necessário aguardar mais alguns dias para a extubação</segment>
    <segment id="77">porque</segment>
    <segment id="78">porque não havia dispositivo que</segment>
    <segment id="79">sese encaixasse no rosto da pequena e mesmo a touca de prematuros sobrava em sua cabeça.</segment>
    <segment id="80">"</segment>
    <segment id="81">Ela era tão pequenininha.</segment>
    <segment id="82">Vê-la na incubadora era de partir o coração"</segment>
    <segment id="83">, recorda Camila.</segment>
    <segment id="84">A fragilidade da neném era tamanha que a mãe teve de pedir ajuda à psicóloga quando autorizaram que tocasse a filha</segment>
    <segment id="85">, uma semana após o parto.</segment>
    <segment id="86">Tinha medo de contaminá-la com alguma bactéria.  "</segment>
    <segment id="87">O primeiro toque foi muito bom.</segment>
    <segment id="88">Foi uma sensação tão gostosa!</segment>
    <segment id="89">Ali eu tive a certeza de que ela ia sair da UTI"</segment>
    <segment id="90">, relata.</segment>
    <segment id="91">Veja o antes e depois de crianças que venceram a prematuridadeMais    novamente         de   de  de  representando um</segment>
    <segment id="92">Os meses seguintes foram de pequenas conquistas e alguns sustos</segment>
    <segment id="93">, como</segment>
    <segment id="94">como quando a saturação da neném baixou de repente bem na hora em que a equipe havia autorizado Fernando a colocá-la no contato pele a pele.  "</segment>
    <segment id="95">Foi desesperador.</segment>
    <segment id="96">Tudo apita</segment>
    <segment id="97">, os médicos correm"</segment>
    <segment id="98">, conta Camila.</segment>
    <segment id="99">"</segment>
    <segment id="100">Saber que agora posso pegá-la e que nenhum fio vai desconectar é muito bom</segment>
    <segment id="101">, é tranquilizador</segment>
    <segment id="102">"</segment>
    <segment id="103">, relata enquanto segura a filha</segment>
    <segment id="104">, que agora pesa 2</segment>
    <segment id="105">,340 kg e mede 43 centímetros.</segment>
    <segment id="106">Desde o último dia 13</segment>
    <segment id="107">, Camila está com Emanuelly na casa de sua mãe</segment>
    <segment id="108">, no bairro</segment>
    <segment id="109">São Judas</segment>
    <segment id="110">, que possui melhor estrutura para os cuidados que a bebê precisa.</segment>
    <segment id="111">Manu ainda utiliza oxigênio e uma vez por semana recebe uma equipe de saúde.</segment>
    <segment id="112">Como outros prematuros</segment>
    <segment id="113">, ela também será encaminhada para acompanhamento com pediatra</segment>
    <segment id="114">, neurologista</segment>
    <segment id="115">, oftalmologista e fonoaudiólogo para estimular e monitorar seu desenvolvimento.</segment>
    <segment id="116">Por enquanto</segment>
    <segment id="117">, Manu é um</segment>
    <segment id="118">casocaso isolado</segment>
    <segment id="119">, masmas a equipe de saúde espera dividir o aprendizado em publicações e congressos e ajudar a replicar o cuidado em outros locais.</segment>
    <segment id="120">"</segment>
    <segment id="121">Torcemos</segment>
    <segment id="122">para que</segment>
    <segment id="123">para que nossa experiência ajude"</segment>
    <segment id="124">, diz Zagne.</segment>
  </rst>
</analysis>