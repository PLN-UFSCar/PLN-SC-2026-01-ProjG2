  <rst>
    <segment id="1">Não é pouca coisa ser eleita a melhor pizzaria de São Paulo pelo Datafolha.</segment>
    <segment id="2">Afinal</segment>
    <segment id="3">, ninguém tem um nível de exigência tão alto quanto o paulistano.</segment>
    <segment id="4">Mas o reconhecimento da rede também vem de fora.</segment>
    <segment id="5">Em 2022</segment>
    <segment id="6">, a Bráz foi apontada</segment>
    <segment id="7">comocomo a quinta melhor do mundo pelo ranking italiano 50 Top World Artisan Pizza Chains.</segment>
    <segment id="8">Criação da Bráz Pizzaria</segment>
    <segment id="9">, a &amp;#</segment>
    <segment id="10">039;em carola&amp;#039</segment>
    <segment id="11">;</segment>
    <segment id="12">é metade pizza e metade calzone -Lila Batista/DilvulgaçãoCompletando 25 anos de história</segment>
    <segment id="13">, a marca lançou novos sabores.</segment>
    <segment id="14">Um deles é o 50 Top</segment>
    <segment id="15">, que, além de molho de tomate</segment>
    <segment id="16">, leva cinco queijos especiais: Tulha</segment>
    <segment id="17">, da fazenda Atalaia</segment>
    <segment id="18">;</segment>
    <segment id="19">cuesta azul</segment>
    <segment id="20">, da Pardinho Artesanal</segment>
    <segment id="21">; ricota de búfala</segment>
    <segment id="22">, da Almeida Prado</segment>
    <segment id="23">; flor di latte</segment>
    <segment id="24">, da Bonfiore Latteria</segment>
    <segment id="25">; e Catupiry.</segment>
    <segment id="26">A pizza</segment>
    <segment id="27">, que seria apenas uma edição comemorativa</segment>
    <segment id="28">, fez tanto sucesso que passou a integrar oficialmente o cardápio das casas em agosto —hoje</segment>
    <segment id="29">, é a quinta mais vendida.</segment>
    <segment id="30">Veja os melhores restaurantes de São Paulo segundo o DatafolhaMais    novamente         de   de  de  representando um</segment>
    <segment id="31">Também em celebração ao aniversário</segment>
    <segment id="32">, foi elaborado o vinho Brás 25 anos</segment>
    <segment id="33">, feito com uvas merlot</segment>
    <segment id="34">, cabernet franc e marcelan</segment>
    <segment id="35">, e voltou para o menu uma criação de 2006</segment>
    <segment id="36">, chamada em carola (metade pizza</segment>
    <segment id="37">, metade calzone).</segment>
    <segment id="38">Além disso</segment>
    <segment id="39">, a primeira unidade da rede</segment>
    <segment id="40">, em Moema</segment>
    <segment id="41">, foi repaginada.</segment>
    <segment id="42">O grupo tem outras sete pizzarias na capital paulista</segment>
    <segment id="43">, uma em Campinas e outra no Rio.</segment>
    <segment id="44">Em julho</segment>
    <segment id="45">, abriu mais uma Bráz Trattoria na região da avenida Paulista</segment>
    <segment id="46">, dividindo o espaço com os bares Astor e SubAstor.</segment>
    <segment id="47">Bráz Pizzaria  R. Graúna</segment>
    <segment id="48">, 125, Moema</segment>
    <segment id="49">, região sul</segment>
    <segment id="50">, tel. (11)</segment>
    <segment id="51">5561-1736</segment>
    <segment id="52">, @brazpizzaria</segment>
  </rst>
