  <rst>
    <segment id="1">Terra e PaixãoClassificação 14 anosAutoria Walcyr Carrasco e Thelma GuedesElenco Tony Ramos</segment>
    <segment id="2">, Glória Pires</segment>
    <segment id="3">, Cauã ReymondProdução Brasil</segment>
    <segment id="4">, 2022"Terra e Paixão" termina</segment>
    <segment id="5">comocomo uma das mais exageradas telenovelas da TV Globo —e isso não é um defeito.</segment>
    <segment id="6">O folhetim</segment>
    <segment id="7">, cujo último capítulo foi exibido na noite desta sexta-feira</segment>
    <segment id="8">, trouxe alta dose de vilania</segment>
    <segment id="9">, com malfeitores ordenando atentados</segment>
    <segment id="10">, sequestros e assassinatos.</segment>
    <segment id="11">Também apostou nas relações homoafetivas</segment>
    <segment id="12">, com vários casais</segment>
    <segment id="13">sese formando</segment>
    <segment id="14">, inclusive inter-raciais</segment>
    <segment id="15">, justo em uma emissora que tinha dificuldade para aprovar selinhos.</segment>
    <segment id="16">A novela ainda valorizou em todos os capítulos o agronegócio e</segment>
    <segment id="17">, no mesmo caminho</segment>
    <segment id="18">, o merchandising</segment>
    <segment id="19">, com a Globo usando seus estúdios para gravar cenas para marcas de carro</segment>
    <segment id="20">, cerveja</segment>
    <segment id="21">, produtos de beleza e chegando ao requinte de uma inserção mudar o rumo de um capítulo.</segment>
    <segment id="22">Cauã Reymond e Barbara Reis em cena da novela &amp;#039</segment>
    <segment id="23">;Terra e Paixão&amp;#039</segment>
    <segment id="24">; - Estevam Avellar/DivulgaçãoFoi justamente o caldeirão de excessos que garantiu o interesse da novela.</segment>
    <segment id="25">O último capítulo</segment>
    <segment id="26">, como</segment>
    <segment id="27">como de hábito</segment>
    <segment id="28">, começou com o esperado ajuste de contas entre o bem e o mal</segment>
    <segment id="29">, justamente com o assassinato de Antonio La Selva —vivido por Tony Ramos—</segment>
    <segment id="30">, a personificação da família rica branca que tentava desde maio</segment>
    <segment id="31">, quando estreou a novela</segment>
    <segment id="32">, destruir Aline —papel de Bárbara Reis—</segment>
    <segment id="33">, a moça negra trabalhadeira e honesta.</segment>
    <segment id="34">A pauta racial</segment>
    <segment id="35">, no entanto</segment>
    <segment id="36">, ficou em segundo plano</segment>
    <segment id="37">, abafada pela luta pela posse da terra</segment>
    <segment id="38">, ou seja</segment>
    <segment id="39">, o fator econômico sobrepujou o social.</segment>
    <segment id="40">Como de hábito em encerramento de novelas</segment>
    <segment id="41">, também foi finalmente revelado o assassino —na verdade</segment>
    <segment id="42">, a dupla— de Agatha</segment>
    <segment id="43">, vivida por Eliane Giardini.</segment>
    <segment id="44">Seguindo o discutível lema "os fins justificam os meios" que tanto marca o cinema americano atual</segment>
    <segment id="45">, os responsáveis não foram punidos</segment>
    <segment id="46">, cientes de que combateram o mal com o próprio mal.</segment>
    <segment id="47">&amp;#039;Terra e Paixão&amp;#039</segment>
    <segment id="48">;</segment>
    <segment id="49">fica sexy em busca de audiênciaMais    novamente         de   de  de  representando um  Escrita por Walcyr Carrasco</segment>
    <segment id="50">, especialista em tramas marcadas por grandes sobressaltos</segment>
    <segment id="51">, a novela teve a valiosa contribuição de Thelma Guedes que</segment>
    <segment id="52">, hábil nos diálogos</segment>
    <segment id="53">, soube costurar os altos e baixos</segment>
    <segment id="54">, mantendo uma coerência na estrutura que garantisse uma certa verossimilhança.</segment>
    <segment id="55">Não foi uma tarefa fácil</segment>
    <segment id="56">, pois</segment>
    <segment id="57">pois o folhetim estreou com a missão de alavancar a péssima audiência deixada por "Travessia".</segment>
    <segment id="58">Para isso</segment>
    <segment id="59">, retomou o ambiente do cerrado</segment>
    <segment id="60">, que consagrou "Pantanal"</segment>
    <segment id="61">, masmas sem tuiuiú e profusão de machos sem camisa.</segment>
    <segment id="62">O excesso de reviravoltas na trama</segment>
    <segment id="63">, porém</segment>
    <segment id="64">porém, desagradou boa parte do público</segment>
    <segment id="65">, com uma parcela reconquistada a partir da segunda fase da novela</segment>
    <segment id="66">, quando</segment>
    <segment id="67">, já com a colaboração de Guedes</segment>
    <segment id="68">, Walcyr promoveu a aparição de alguns personagens em poucos capítulos</segment>
    <segment id="69">, como</segment>
    <segment id="70">como a trambiqueira Emengarda</segment>
    <segment id="71">, vivida por Claudia Raia</segment>
    <segment id="72">, e o abusador Dirceu</segment>
    <segment id="73">, papel de Eriberto Leão</segment>
    <segment id="74">, para dar um respiro na história e afastar o perigoso clima de mesmice.</segment>
    <segment id="75">O trunfo só foi possível</segment>
    <segment id="76">, na verdade</segment>
    <segment id="77">, graças ao talento do elenco.</segment>
    <segment id="78">Veteranos</segment>
    <segment id="79">comocomo Gloria Pires</segment>
    <segment id="80">, Eliane Giardini e Tony Ramos capturavam a atenção do espectador que</segment>
    <segment id="81">, manipulado pela habilidade cênica do trio</segment>
    <segment id="82">, descobriu-</segment>
    <segment id="83">sese simpatizando com figuras odiosas.</segment>
    <segment id="84">Cenas da novela Terra e PaixãoMais    novamente         de   de  de  representando um  Inspirado em Gilberto Braga</segment>
    <segment id="85">, que mostrou em "Vale</segment>
    <segment id="86">Tudo"</segment>
    <segment id="87">a vitória do mau-caratismo</segment>
    <segment id="88">, Walcyr reservou um destino feliz para Irene</segment>
    <segment id="89">, a ex-prostituta que</segment>
    <segment id="90">sese casou com um milionário e sustentou seu reinado à base de assassinatos encomendados e corrupção.</segment>
    <segment id="91">Agora, vivendo no Rio de Janeiro</segment>
    <segment id="92">, ela conseguiu um novo milionário e ainda adotou um filho.</segment>
    <segment id="93">Vitória da impunidade.</segment>
    <segment id="94">A novela revelou também nomes</segment>
    <segment id="95">comocomo Débora Ozório</segment>
    <segment id="96">, Diego Martins e Amaury Lorenzo</segment>
    <segment id="97">, que flertaram com o exagerado</segment>
    <segment id="98">, sem perder a humanidade</segment>
    <segment id="99">, especialmente ao tratar de assuntos</segment>
    <segment id="100">comocomo doenças comportamentais</segment>
    <segment id="101">, amor sem distinção de gênero e matadores contumazes.</segment>
    <segment id="102">Destaque ainda para Tatá Werneck.</segment>
    <segment id="103">Como Anely</segment>
    <segment id="104">, ela teve liberdade para exercitar seu humor sem noção</segment>
    <segment id="105">, provocando risos inclusive dos colegas de cena com trocadilhos</segment>
    <segment id="106">comocomo "há uma Petra no meio do caminho"</segment>
    <segment id="107">, referindo-</segment>
    <segment id="108">sese à rival na disputa pelo amor de Luigi —vivido por Rainer Cadete—</segment>
    <segment id="109">, ou ao afirmar</segment>
    <segment id="110">, diante da sua nem sempre controlada ânsia sexual</segment>
    <segment id="111">, que não é fácil garantir "o pau de cada dia".</segment>
    <segment id="112">Personagens &amp;#</segment>
    <segment id="113">039;esquecidos&amp;#039</segment>
    <segment id="114">; de &amp;#039</segment>
    <segment id="115">;Terra e Paixão&amp;#039</segment>
    <segment id="116">;Mais    novamente         de   de  de  representando um</segment>
    <segment id="117">Foi justamente em uma cena de Anely com o sobrinho que a Globo foi além na intervenção do marketing no drama.</segment>
    <segment id="118">Uma discussão entre eles foi simplesmente aliviada depois que a imagem de um produto de beleza interrompeu a cena para estimular a conversa</segment>
    <segment id="119">comocomo melhor caminho.</segment>
    <segment id="120">Anely citou a marca do produto</segment>
    <segment id="121">comocomo responsável pela solução.</segment>
    <segment id="122">Na contramão</segment>
    <segment id="123">, o núcleo indígena deixou a impressão de que a feitiçaria de um pajé visionário dos perigos é a solução contra os males da humanidade</segment>
    <segment id="124">, algo fantasioso demais diante da crua realidade vivida por diversas aldeias brasileiras</segment>
    <segment id="125">, em luta constante pela vida.</segment>
    <segment id="126">Mesmo assim</segment>
    <segment id="127">, a cena final mostra o pajé pregando tempo de harmonia e de paz.</segment>
    <segment id="128">O exagero final de uma novela de excessos.</segment>
  </rst>
</analysis>