  <rst>
    <segment id="1">Quer tirar um tarô?</segment>
    <segment id="2">,</segment>
    <segment id="3">perguntei à uma amiga em estado terminal.</segment>
    <segment id="4">Nessa fase</segment>
    <segment id="5">, ela ainda estava assustada</segment>
    <segment id="6">, já que o processo de metástase afetou sua visão e sua lucidez.</segment>
    <segment id="7">Ironicamente</segment>
    <segment id="8">, alguns dias depois</segment>
    <segment id="9">, dias antes de sua partida</segment>
    <segment id="10">, ela ganhou uma visão e uma lucidez de outra ordem</segment>
    <segment id="11">, quando passou a dizer somente a verdade.</segment>
    <segment id="12">Publicada nesta segunda-feira</segment>
    <segment id="13">, 12 de dezembro de 2022 - Silvis  Mas esse texto não é sobre a verdade</segment>
    <segment id="14">, muito pelo contrário.</segment>
    <segment id="15">Vamos voltar à beira da cama</segment>
    <segment id="16">, enquanto embaralho cartas de tarô.</segment>
    <segment id="17">Estava acompanhada de outra amiga</segment>
    <segment id="18">, Ana, e pedi para ela segurar algumas cartas que havia separado.</segment>
    <segment id="19">Cartas que geralmente dão um cagaço e cuja interpretação é mais complexa.</segment>
    <segment id="20">Percebendo que nossa amiga estava confusa e com medo</segment>
    <segment id="21">, entendi que a mensagem deveria ser de conforto.</segment>
    <segment id="22">Ela sorriu ouvindo sobre o significado da carta</segment>
    <segment id="23">O Mundo —o fim de um ciclo</segment>
    <segment id="24">, um final feliz.</segment>
    <segment id="25">Mas quando saímos de lá</segment>
    <segment id="26">, Ana me deu um sermão.</segment>
    <segment id="27">Não achou legal o fato de eu ter mentido para nossa amiga e manipulado o jogo.</segment>
    <segment id="28">Honestamente</segment>
    <segment id="29">, não fiz questão alguma de me defender</segment>
    <segment id="30">, masmas defendi a mentira com unhas e dentes.</segment>
    <segment id="31">Sem mentiras</segment>
    <segment id="32">, o que aconteceria com as relações sociais?</segment>
    <segment id="33">Mais    novamente         de   de  de  representando um</segment>
    <segment id="34">Essa visão moralista da mentira me tira do sério.</segment>
    <segment id="35">O que determina</segment>
    <segment id="36">sese uma mentira é boa ou ruim é o seu objetivo.</segment>
    <segment id="37">Esse objetivo pode ser destrutivo</segment>
    <segment id="38">, ou seja</segment>
    <segment id="39">, sese você mente para prejudicar alguém em benefício próprio</segment>
    <segment id="40">, você está sendo o famoso saco de vacilo.</segment>
    <segment id="41">No entanto</segment>
    <segment id="42">, sese as pessoas só dissessem a verdade umas para as outras</segment>
    <segment id="43">, o resultado seria a barbárie.</segment>
    <segment id="44">A mentira é uma estratégia de sobrevivência</segment>
    <segment id="45">, e mais do que isso: ela nos torna mais humanos.</segment>
    <segment id="46">Em uma entrevista</segment>
    <segment id="47">, Dilma Rousseff foi acusada de "mentir adoidado na ditadura militar".</segment>
    <segment id="48">Dilma respondeu que mentiu</segment>
    <segment id="49">, sob tortura</segment>
    <segment id="50">, para salvar a vida de seus companheiros</segment>
    <segment id="51">, e que</segment>
    <segment id="52">sese orgulhava imensamente de ter mentido.</segment>
    <segment id="53">Aqui, o objetivo da mentira é a proteção</segment>
    <segment id="54">, e não a destruição.  Dilma na ditaduraMais    novamente         de   de  de  representando um  Isso me faz lembrar do filme "</segment>
    <segment id="55">A Vida É Bela"</segment>
    <segment id="56">, uma comédia dramática na qual o protagonista é mandado para um campo de concentração junto com seu filho e</segment>
    <segment id="57">, para protegê-lo daquele cenário de horror</segment>
    <segment id="58">, inventa para a criança que tudo aquilo é uma grande brincadeira.</segment>
    <segment id="59">Imagino minha amiga Ana</segment>
    <segment id="60">, chamando esse personagem em um canto e dizendo</segment>
    <segment id="61">, "poxa</segment>
    <segment id="62">, mentir não é legal"</segment>
    <segment id="63">, e acho a maior graça.</segment>
    <segment id="64">É esse o poder da mentira</segment>
    <segment id="65">, revelar a beleza e a graça na dor</segment>
    <segment id="66">, e assim resistir à ela.</segment>
    <segment id="67">Colunas e BlogsReceba no seu email uma seleção de colunas e blogs da Folha</segment>
    <segment id="68">; exclusiva para assinantes.</segment>
    <segment id="69">Carregando...</segment>
  </rst>
