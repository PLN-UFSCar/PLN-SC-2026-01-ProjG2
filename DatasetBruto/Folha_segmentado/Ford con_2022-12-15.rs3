  <rst>
    <segment id="1">As montadoras começam a revelar seus planos para 2023.</segment>
    <segment id="2">Nesta quarta (14)</segment>
    <segment id="3">, a Ford confirmou o lançamento de 10 novos produtos ao longo do próximo ano</segment>
    <segment id="4">, com destaque para os utilitários produzidos na América Latina.</segment>
    <segment id="5">A empresa projeta um crescimento médio de 5% do mercado nacional no próximo ano</segment>
    <segment id="6">, masmas acredita que irá registrar resultados melhores.</segment>
    <segment id="7">Entre janeiro e novembro</segment>
    <segment id="8">, a empresa comercializou 18</segment>
    <segment id="9">,4 mil carros de passeio e veículos comerciais leves no Brasil.</segment>
    <segment id="10">É um volume baixo quando comparado aos números obtidos nos tempos de produção nacional</segment>
    <segment id="11">, masmas alinhado à estratégia global da empresa</segment>
    <segment id="12">, com maior foco em rentabilidade.</segment>
    <segment id="13">Nova geração da picape média Ford Ranger chega ao Brasil em 2023 - DivulgaçãoA principal novidade será a nova geração da picape média Ranger</segment>
    <segment id="14">, com fabricação confirmada na Argentina.</segment>
    <segment id="15">Além do desenho e do interior atualizados</segment>
    <segment id="16">, o modelo terá painel digital e novos motores a diesel.</segment>
    <segment id="17">O utilitário é o veículo mais competitivo da marca americana no mercado brasileiro.</segment>
    <segment id="18">A opção atual teve 12</segment>
    <segment id="19">,7 mil unidades emplacadas entre janeiro e novembro</segment>
    <segment id="20">, sendo a quarta colocada em vendas no seu segmento.</segment>
    <segment id="21">A picape média a diesel que lidera o mercado nacional é a Toyota Hilux</segment>
    <segment id="22">, com 42</segment>
    <segment id="23">,8 mil unidades licenciadas no acumulado de 2022.</segment>
    <segment id="24">Os dados são da Fenabrave (associação dos distribuidores de veículos).</segment>
    <segment id="25">A Ford terá ainda novas versões do furgão Transit</segment>
    <segment id="26">, que é montado no Uruguai.</segment>
    <segment id="27">Já a versão híbrida da picape Maverick também está confirmada para 2023.</segment>
    <segment id="28">Produzida no México</segment>
    <segment id="29">, é equipada com um motor 2.5 a gasolina</segment>
    <segment id="30">, que trabalha em conjunto com o sistema a eletricidade.</segment>
    <segment id="31">Ford Maverick 2022Mais    novamente         de   de  de  representando um  Já o SUV 100% elétrico Mustang Mach-E virá dos Estados Unidos com autonomia para rodar aproximadamente 400 quilômetros.</segment>
    <segment id="32">A Ford testa no Brasil a opção GT</segment>
    <segment id="33">, capaz de ir do zero aos 100 km/h em menos de quatro segundos.</segment>
    <segment id="34">Outro modelo "made in USA" é a picape grande F-150</segment>
    <segment id="35">, também confirmada para o próximo ano.</segment>
    <segment id="36">Seu público está no agronegócio</segment>
    <segment id="37">, setor que encara fila de espera para comprar os modelos da marca RAM</segment>
    <segment id="38">, únicos disponíveis oficialmente nesse nicho de mercado.</segment>
    <segment id="39">Outras estreias ainda são segredo</segment>
    <segment id="40">, masmas é possível afirmar que a nova geração do SUV</segment>
    <segment id="41">Territory estará entre os lançamentos.</segment>
    <segment id="42">O modelo vai crescer e receber nova motorização para tentar superar seus pontos fracos</segment>
    <segment id="43">, que são o porta-malas pequeno e o desempenho tímido.</segment>
    <segment id="44">Bajaj lança motocicletas no Brasil</segment>
    <segment id="45">;</segment>
    <segment id="46">Dominar 160 é o modelo mais em conta - DivulgaçãoNo setor de motocicletas</segment>
    <segment id="47">, o destaque é a chegada da gigante indiana Bajaj ao mercado nacional.</segment>
    <segment id="48">A marca estreia com três modelos e cinco concessionárias no estado de São Paulo.</segment>
    <segment id="49">As primeiras motos</segment>
    <segment id="50">, todas do segmento street</segment>
    <segment id="51">, custam a partir de R$ 18.860 –preço sugerido para a Dominar 160</segment>
    <segment id="52">, equipada com motor de 17 cv.</segment>
    <segment id="53">Há ainda as opções Dominar 200 (R$ 19.637) e Dominar 400 (R$ 24</segment>
    <segment id="54">,2 mil).</segment>
    <segment id="55">Os modelos são montados na fábrica da Dafra</segment>
    <segment id="56">, em Manaus.</segment>
    <segment id="57">Para 2023</segment>
    <segment id="58">, a Bajaj planeja a expansão da rede de revendedores</segment>
    <segment id="59">, com lojas confirmadas em Belo Horizonte</segment>
    <segment id="60">, Brasília</segment>
    <segment id="61">, Florianópolis e no Rio de Janeiro.</segment>
    <segment id="62">Bajaj Dominar 400 é o modelo mais potente da marca indiana no Brasil - Divulgação</segment>
  </rst>
</analysis>