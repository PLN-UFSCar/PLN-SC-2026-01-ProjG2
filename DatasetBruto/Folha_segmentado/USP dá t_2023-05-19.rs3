  <rst>
    <segment id="1">A Faculdade de Educação da USP realizará na próxima terça-feira (23) a cerimônia de entrega do título de professora emérita a Roseli Fischmann.</segment>
    <segment id="2">O evento ocorrerá às 16h no auditório da faculdade (av. da Universidade</segment>
    <segment id="3">, 308, Cidade Universitária</segment>
    <segment id="4">, Butantã) e poderá ser acompanhado também pelo canal da instituição no YouTube.</segment>
    <segment id="5">Roseli Fischmann durante audiência pública em 2015 - Carlo Humberto/SCO/STF</segment>
    <segment id="6">A distinção acadêmica</segment>
    <segment id="7">, segundo o estatuto da USP</segment>
    <segment id="8">, é concedida "a seus professores aposentados que</segment>
    <segment id="9">sese hajam distinguido por atividades didáticas e de pesquisa ou contribuído</segment>
    <segment id="10">, de modo notável</segment>
    <segment id="11">, para o progresso da universidade".</segment>
    <segment id="12">Fischmann ingressou na USP em 1971</segment>
    <segment id="13">, um ano depois de ser fundada a Faculdade de Educação.</segment>
    <segment id="14">Formou-</segment>
    <segment id="15">sese lá em 1974 e</segment>
    <segment id="16">, na mesma casa</segment>
    <segment id="17">, obteve o mestrado em 1982</segment>
    <segment id="18">, com o trabalho "</segment>
    <segment id="19">Estrutura administrativa da Secretaria Municipal de Educação da Prefeitura do Município de São Paulo".</segment>
    <segment id="20">Em 1989</segment>
    <segment id="21">, na mesma faculdade</segment>
    <segment id="22">, concluiu o doutorado em filosofia e história da educação com a tese "Vida e identidade da escola pública: um estudo preliminar da resistência à mudança na burocracia estatal em São Paulo".</segment>
    <segment id="23">Tornou-</segment>
    <segment id="24">sese professora titular em 1997 e</segment>
    <segment id="25">, nos últimos anos</segment>
    <segment id="26">, tem se</segment>
    <segment id="27">se dedicado</segment>
    <segment id="28">, entre outros temas</segment>
    <segment id="29">, a pesquisas sobre ensino religioso em escolas públicas.</segment>
    <segment id="30">Entre seus livros mais recentes estão "Crianças e Adolescentes:</segment>
    <segment id="31">Construindo uma Cultura da Tolerância" (Edusp</segment>
    <segment id="32">, 2021) e "</segment>
    <segment id="33">Estado Laico</segment>
    <segment id="34">, Doutrinas Religiosas</segment>
    <segment id="35">, Cidadania e Educação" (Metodista</segment>
    <segment id="36">, 2017).</segment>
    <segment id="37">Veja imagens do campus da USPMais    novamente         de   de  de  representando um</segment>
  </rst>
