  <rst>
    <segment id="1">Exatos 30 anos após sua dissolução</segment>
    <segment id="2">, a União Soviética passa bem</segment>
    <segment id="3">, obrigado.</segment>
    <segment id="4">O império comunista</segment>
    <segment id="5">, experimento inédito na história humana</segment>
    <segment id="6">, implantado a partir dos escombros ensanguentados da brutal Guerra Civil Russa em 1922</segment>
    <segment id="7">, foi encerrado formalmente quando o estandarte vermelho da foice e martelo foi arriado do Kremlin às 19h32 do dia 25 de dezembro de 1991.</segment>
    <segment id="8">Estátua de Lênin</segment>
    <segment id="9">, fundador da União Soviética</segment>
    <segment id="10">, no Parque das Esculturas que reúne monumentos derrubados do período soviético em Moscou - Alexander Nenemov - 8.dez.2021/AFP</segment>
    <segment id="11">A morte do regime foi um processo bem mais longo</segment>
    <segment id="12">, anabolizado pelos anos de abertura descontrolada promovida por Mikhail Gorbatchov (1985-91)</segment>
    <segment id="13">, seu último líder.</segment>
    <segment id="14">Mas seu espírito segue firme e forte</segment>
    <segment id="15">, ao menos</segment>
    <segment id="16">comocomo elemento de impacto geopolítico.</segment>
    <segment id="17">No mundo real</segment>
    <segment id="18">, basta ver a crise em torno das tropas enviadas por Vladimir Putin para pressionar por um acordo final no leste da Ucrânia.</segment>
    <segment id="19">Em 1991</segment>
    <segment id="20">, o segundo principal país da União foi instrumental em seu desmantelamento</segment>
    <segment id="21">, ao buscar independência e rejeitar uma reformulação do regime centrado em Moscou.</segment>
    <segment id="22">Lá foraReceba no seu email uma seleção semanal com o que de mais importante aconteceu no mundo</segment>
    <segment id="23">; aberta para não assinantes.</segment>
    <segment id="24">Carregando...</segment>
    <segment id="25">Em 2005</segment>
    <segment id="26">, o presidente russo famosamente disse que o rompimento da União Soviética havia sido a "maior catástrofe geopolítica do século 20".</segment>
    <segment id="27">A frase usualmente é pinçada sem seu contexto</segment>
    <segment id="28">, essencial para entender parte do impasse atual.</segment>
    <segment id="29">"</segment>
    <segment id="30">Para o povo russo</segment>
    <segment id="31">, tornou-</segment>
    <segment id="32">sese um drama real.</segment>
    <segment id="33">Dezenas de milhões dos nossos cidadãos e compatriotas</segment>
    <segment id="34">sese encontraram fora de território russo [com o rompimento da União].</segment>
    <segment id="35">A epidemia da desintegração também</segment>
    <segment id="36">sese espalhou pela própria Rússia"</segment>
    <segment id="37">, afirmou então.</segment>
    <segment id="38">Símbolos da URSS em Moscou</segment>
    <segment id="39">, 25 anos depoisMais    novamente         de   de  de  representando um</segment>
    <segment id="40">Dois pontos centrais da doutrina putinista estão ali colocados.</segment>
    <segment id="41">Primeiro</segment>
    <segment id="42">, a noção de que a grande porcentagem de russos étnicos espalhados por repúblicas ex-soviéticas fazem parte</segment>
    <segment id="43">, na sua visão</segment>
    <segment id="44">, da pátria-mãe.</segment>
    <segment id="45">Isso não explica o centro da questão ucraniana</segment>
    <segment id="46">, que é a necessidade de manter os territórios perdidos com o fim da União</segment>
    <segment id="47">comocomo parte de sua esfera de influência ou neutros</segment>
    <segment id="48">, masmas nunca</segment>
    <segment id="49">comocomo integrantes da estrutura militar ocidental —nominalmente</segment>
    <segment id="50">, a Organização do Tratado do Atlântico Norte.</segment>
    <segment id="51">Essa premissa orientou o uso dos dois territórios étnicos russos na Geórgia</segment>
    <segment id="52">comocomo justificativa para uma guerra em 2008</segment>
    <segment id="53">, que deixou o pequeno país do Cáucaso fora da Otan.</segment>
    <segment id="54">Em 2014</segment>
    <segment id="55">, a receita</segment>
    <segment id="56">sese repetiu na pivotal Ucrânia</segment>
    <segment id="57">, cujo governo simpático a Putin fora derrubado</segment>
    <segment id="58">, com a anexação da Crimeia e o início da autonomia "manu militari" do Donbass (leste do país</segment>
    <segment id="59">, pró-Rússia).  China</segment>
    <segment id="60">, terra do meioReceba no seu email os grandes temas da China explicados e contextualizados</segment>
    <segment id="61">; exclusiva para assinantes.</segment>
    <segment id="62">Carregando...</segment>
    <segment id="63">O outro extrato da frase</segment>
    <segment id="64">sese comprovou na ascensão de Putin.</segment>
    <segment id="65">Com truques ou não</segment>
    <segment id="66">, aí depende do freguês</segment>
    <segment id="67">, ele ascendeu ao Kremlin</segment>
    <segment id="68">comocomo premiê em 1999 e presidente na virada de 2000 amparado no discurso de evitar a desintegração física da Rússia —no</segment>
    <segment id="69">casocaso</segment>
    <segment id="70">, com a brutal segunda guerra contra separatistas na Tchetchênia.</segment>
    <segment id="71">Problema resolvido</segment>
    <segment id="72">, a ideia de restauração de áreas tampão nos limites do que foi o Império Russo e</segment>
    <segment id="73">, depois</segment>
    <segment id="74">, a União das Repúblicas Socialistas Soviéticas</segment>
    <segment id="75">, sese fez um imperativo.</segment>
    <segment id="76">Crise entre Rússia e Ucrânia em 2021Mais    novamente         de   de  de  representando um    Geografia</segment>
    <segment id="77">, diz o chavão</segment>
    <segment id="78">, é destino.</segment>
    <segment id="79">Fechado com saídas precárias ao mar</segment>
    <segment id="80">, o maior país do mundo sempre foi vulnerável a invasões pela Europa</segment>
    <segment id="81">, pelo Cáucaso e pela Ásia Central.</segment>
    <segment id="82">O ponto mais sensível sempre foi</segment>
    <segment id="83">, contudo</segment>
    <segment id="84">contudo</segment>
    <segment id="85">, o Ocidente.</segment>
    <segment id="86">Agora, com as conversas previstas para janeiro acerca de algum tipo de acerto que evite o uso da força contra Kiev</segment>
    <segment id="87">, Putin tenta estabelecer o que já tem na aliada ditadura de Belarus: uma separação entre suas tropas e as da Otan.</segment>
    <segment id="88">No Cáucaso</segment>
    <segment id="89">, ele solucionou a questão mantendo tropas em pontos chaves da região: a guerra em que sua aliada Armênia perdeu espaço para o rival Azerbaijão em 2020 foi encerrada com a presença de forças de paz de Moscou.</segment>
    <segment id="90">Mesmo com a Turquia com grande olho sobre a região</segment>
    <segment id="91">, na prática</segment>
    <segment id="92">Putin mantém a rédea.</segment>
    <segment id="93">Na Ásia Central</segment>
    <segment id="94">, que de resto serve de tampão contra uma China cada vez mais aliada da Rússia</segment>
    <segment id="95">, a instabilidade no Quirguistão foi equacionada</segment>
    <segment id="96">, e os russos viraram chave para o arranjo regional após a retirada dos Estados Unidos do Afeganistão.</segment>
    <segment id="97">Tudo isso ecoa a 1991</segment>
    <segment id="98">, quando o grande rival de Washington por quatro décadas desmilinguiu-</segment>
    <segment id="99">sese após um processo de decadência acelerado nos anos anteriores —a Guerra Fria começa a acabar na prática em 1987</segment>
    <segment id="100">, com o agora desprezado acordo para vetar mísseis nucleares de alcance intermediário na Europa</segment>
    <segment id="101">, e dois anos depois o muro de Berlim estaria no chão.</segment>
    <segment id="102">Marcas da Guerra Fria na AlemanhaMais    novamente         de   de  de  representando um</segment>
    <segment id="103">Um outro aspecto soviético é a perenidade de sua faceta assustadora ante políticos e eleitores conservadores mundo afora.</segment>
    <segment id="104">Partidos sem pudores de usar estrela</segment>
    <segment id="105">, foice e martelo e afins seguiram em alta pelo mundo</segment>
    <segment id="106">, sempre vestindo roupagem social-democrata.</segment>
    <segment id="107">Em lugares que foram oprimidos</segment>
    <segment id="108">, como</segment>
    <segment id="109">como os Estados Bálticos</segment>
    <segment id="110">, soam</segment>
    <segment id="111">comocomo acinte</segment>
    <segment id="112">, masmas da Europa à América Latina ainda</segment>
    <segment id="113">sese vendem</segment>
    <segment id="114">comocomo libertários.</segment>
    <segment id="115">Até que</segment>
    <segment id="116">, em 2016</segment>
    <segment id="117">, a ascensão das forças de Donald Trump e seus parceiros mundo afora</segment>
    <segment id="118">, de Jair Bolsonaro a Rodrigo Duterte nas Filipinas</segment>
    <segment id="119">, trouxe de volta à moda o discurso dos anos 1950 e 1960 acerca do risco do comunismo.</segment>
    <segment id="120">É algo ilusório e farsesco</segment>
    <segment id="121">, claro</segment>
    <segment id="122">, dado que regimes comunistas de fato sobraram poucos: Cuba</segment>
    <segment id="123">, Coreia do Norte</segment>
    <segment id="124">, Laos</segment>
    <segment id="125">, Vietnã e China.</segment>
    <segment id="126">Naturalmente</segment>
    <segment id="127">, alguém poderia</segment>
    <segment id="128">sese sentir tentado a colocar Pequim</segment>
    <segment id="129">comocomo herdeira de Moscou</segment>
    <segment id="130">, masmas as condições objetivas são incomparáveis.</segment>
    <segment id="131">Os chineses</segment>
    <segment id="132">, para começar</segment>
    <segment id="133">, só são a segunda economia do mundo pela interligação com o comércio internacional</segment>
    <segment id="134">, algo que os soviéticos nunca sonharam em ter.</segment>
    <segment id="135">Além disso</segment>
    <segment id="136">, o sistema lá é misto</segment>
    <segment id="137">, com um capitalismo de Estado forte e alguns bolsões liberalizados nas finanças</segment>
    <segment id="138">, como</segment>
    <segment id="139">como a de resto enjaulada Hong Kong</segment>
    <segment id="140">, para estabelecer parcerias com o resto do planeta.</segment>
    <segment id="141">Putin, 20 anos no poderMais    novamente         de   de  de  representando um    Ideologicamente</segment>
    <segment id="142">, Xi Jinping fala grosso</segment>
    <segment id="143">, masmas sobre um sistema para os chineses.</segment>
    <segment id="144">Nunca, ao contrário da Moscou soviética</segment>
    <segment id="145">, promoveu sua leitura do socialismo para outros países.</segment>
    <segment id="146">Negócios são negócios.</segment>
    <segment id="147">Seja como</segment>
    <segment id="148">como for</segment>
    <segment id="149">, o grande espectro cantado por Karl Marx e Friedrich Engels em 1848 segue assombrando a Europa</segment>
    <segment id="150">, aí na forma de restos a pagar geopolíticos</segment>
    <segment id="151">, masmas também de forma fantasmagórica outros pontos do mundo —</segment>
    <segment id="152">comocomo as eleições chilenas provaram</segment>
    <segment id="153">, e as brasileiras</segment>
    <segment id="154">, de 2022</segment>
    <segment id="155">, provarão.</segment>
  </rst>
</analysis>