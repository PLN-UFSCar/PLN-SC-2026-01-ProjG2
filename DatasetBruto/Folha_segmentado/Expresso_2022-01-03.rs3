  <rst>
    <segment id="1">Roteiro criado em 2009</segment>
    <segment id="2">, o Expresso Turístico oferecido pela CPTM (Companhia Paulista de Trens Metropolitanos) voltará às atividades normais no próximo sábado (8).</segment>
    <segment id="3">O trem</segment>
    <segment id="4">, que parte da estação da Luz</segment>
    <segment id="5">, na capital</segment>
    <segment id="6">, com destino a Paranapiacaba</segment>
    <segment id="7">, Jundiaí e Mogi das Cruzes</segment>
    <segment id="8">, já tinha retomado nos últimos meses o roteiro</segment>
    <segment id="9">, masmas apenas para os turistas que tinham adquirido os bilhetes antes da paralisação por conta da pandemia</segment>
    <segment id="10">, em março do ano passado</segment>
    <segment id="11">, e não tinham conseguido viajar por conta da suspensão das rotas.</segment>
    <segment id="12">CPTM retomará a partir do próximo sábado (8) as viagens do Expresso Turístico para Paranapiacaba</segment>
    <segment id="13">, Jundiaí e Mogi das Cruzes - DivulgaçãoO roteiro ficou totalmente suspenso por praticamente um ano e meio.</segment>
    <segment id="14">Agora, o embarque está aberto a todos novamente.</segment>
    <segment id="15">Os roteiros são oferecidos aos finais de semana</segment>
    <segment id="16">, masmas não de forma simultânea para os três destinos.</segment>
    <segment id="17">Colunas e BlogsReceba no seu email uma seleção de colunas e blogs da Folha</segment>
    <segment id="18">; exclusiva para assinantes.</segment>
    <segment id="19">Carregando...</segment>
    <segment id="20">A primeira viagem será para Jundiaí</segment>
    <segment id="21">, no sábado.</segment>
    <segment id="22">Para Paranapiacaba</segment>
    <segment id="23">, os trens partirão domingo (9) e dias 15 e 16.</segment>
    <segment id="24">Mogi das Cruzes tem viagem programada para o dia 22.</segment>
    <segment id="25">Segundo a CPTM</segment>
    <segment id="26">, há mais datas previstas para Paranapiacaba pelo fato de a histórica vila de Santo André ser o local mais procurado pelo público.</segment>
    <segment id="27">Restauro em estação abandonada há duas décadas é concluído em ParanapiacabaMais    novamente         de   de  de  representando um</segment>
    <segment id="28">A rota é feita numa locomotiva a diesel</segment>
    <segment id="29">, modelo Alco</segment>
    <segment id="30">, fabricada em 1952</segment>
    <segment id="31">, que conduz dois carros de passageiros</segment>
    <segment id="32">, de aço</segment>
    <segment id="33">, fabricados no Brasil pela Budd - Mafersa nos anos 60.</segment>
    <segment id="34">Eles foram cedidos pela ABPF (Associação Brasileira de Preservação Ferroviária).</segment>
    <segment id="35">São levados até 172 passageiros por viagem.</segment>
    <segment id="36">Além de apreciar a paisagem por ângulos normalmente não vistos</segment>
    <segment id="37">, o turista também conhece no trajeto parte da história da ferrovia e das estações.</segment>
    <segment id="38">Vila de ParanapiacabaMais    novamente         de   de  de  representando um  ​​Expresso Turístico</segment>
    <segment id="39">Quando: sábados e domingos Horário: 8h30</segment>
    <segment id="40">, na plataforma 4 da estação da Luz</segment>
    <segment id="41">; retorno das cidades visitadas ocorre às 16h30</segment>
    <segment id="42">Destinos: Paranapiacaba</segment>
    <segment id="43">, Jundiaí e Mogi das Cruzes</segment>
    <segment id="44">Preço: R$ 50 (1 passageiro)</segment>
    <segment id="45">; R$ 82 (1 passageiro e 1 acompanhante)</segment>
    <segment id="46">, R$ 115 (1 passageiro e 2 acompanhantes) e R$ 148 (1 passageiro e 3 acompanhantes) Informações: 0800-055-0121</segment>
  </rst>
