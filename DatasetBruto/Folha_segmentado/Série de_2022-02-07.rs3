  <rst>
    <segment id="1">Quase adolescente.</segment>
    <segment id="2">É assim que o quarteto que protagoniza a versão com atores da "Turma da Mônica" surge na primeira imagem de divulgação da série que o Globoplay prepara a partir da franquia.</segment>
    <segment id="3">O projeto sucede dois filmes de sucesso com a turminha</segment>
    <segment id="4">, baseados em graphic novels dos irmãos Vitor Cafaggi e Lu Cafaggi.</segment>
    <segment id="5">São eles</segment>
    <segment id="6">"</segment>
    <segment id="7">Turma da Mônica:</segment>
    <segment id="8">Laços"</segment>
    <segment id="9">, lançado em 2019</segment>
    <segment id="10">, e "Turma da Mônica: Lições"</segment>
    <segment id="11">, que estreou no final do ano passado.</segment>
    <segment id="12">Do primeiro para o segundo filme</segment>
    <segment id="13">, os atores cresceram</segment>
    <segment id="14">, e muito —selecionados entre 7.000 crianças quando tinham entre 9 e 11 anos</segment>
    <segment id="15">, eles hoje têm entre 13 e 15 anos.</segment>
    <segment id="16">Os atores Kevin Vechiatto</segment>
    <segment id="17">, Giulia Benite</segment>
    <segment id="18">, Laura Rauseo</segment>
    <segment id="19">, Gabriel Moreira durante as filmagens da série &amp;#039</segment>
    <segment id="20">;Turma da Mônica&amp;#039</segment>
    <segment id="21">;, do Globoplay</segment>
    <segment id="22">, em Poços de Caldas (MG) - Fabio Braga/DivulgaçãoAlém da trupe principal</segment>
    <segment id="23">, formada por Giulia Benite (Mônica)</segment>
    <segment id="24">, Kevin Vechiatto (Cebolinha)</segment>
    <segment id="25">, Laura Rauseo (Magali) e Gabriel Moreira (Cascão)</segment>
    <segment id="26">, também o diretor</segment>
    <segment id="27">, Daniel Rezende</segment>
    <segment id="28">, é o mesmo do par de filmes anteriores.</segment>
    <segment id="29">Em nota</segment>
    <segment id="30">, ele afirma que o roteiro será original</segment>
    <segment id="31">, criado especialmente para a série.</segment>
    <segment id="32">Mas não adianta mais detalhes da trama.</segment>
    <segment id="33">Confira cenas de &amp;#039</segment>
    <segment id="34">;Turma da Mônica: Lições&amp;#039</segment>
    <segment id="35">;Mais    novamente         de   de  de  representando um</segment>
    <segment id="36">As filmagens da série já começaram</segment>
    <segment id="37">, e acontecem entre duas cidades paulistas perto da divisa com Minas Gerais</segment>
    <segment id="38">, Águas da Prata e São João da Boa Vista</segment>
    <segment id="39">, e na cidade mineira de Poços de Caldas</segment>
    <segment id="40">, onde "Lições" foi gravado em 2020.  TODO MUNDO LÊ JUNTO  Texto com este selo é indicado para ser lido por responsáveis e educadores com a criança</segment>
  </rst>
</analysis>