  <rst>
    <segment id="1">Uma embarcação com estudantes e a professora de uma universidade do Pará naufragou nesta sexta-feira (29) no rio Tapajós</segment>
    <segment id="2">, em Santarém (a cerca de 1.120 km de Belém).</segment>
    <segment id="3">Todos sobreviveram.</segment>
    <segment id="4">A Capitania Fluvial de Santarém</segment>
    <segment id="5">, da Marinha do Brasil</segment>
    <segment id="6">, instaurou inquérito para apurar o motivo do naufrágio.</segment>
    <segment id="7">Passageiros são resgatados após embarcação naufragar em Santarém (PA) - ReproduçãoA embarcação</segment>
    <segment id="8">, batizada Surucuá 2</segment>
    <segment id="9">, transportava 34 alunos e uma professora do curso de Ciências Biológicas do ICTA (Instituto de Ciências e Tecnologia das Águas)</segment>
    <segment id="10">, da Ufopa (Universidade Federal do Oeste do Pará).</segment>
    <segment id="11">O grupo ia para uma atividade de campo na comunidade Surucuá</segment>
    <segment id="12">, à margem esquerda do rio.</segment>
    <segment id="13">O barco de linha afundou próximo da comunidade de Solimões.</segment>
    <segment id="14">De acordo com a universidade</segment>
    <segment id="15">, todos os passageiros estavam de colete salva-vidas.</segment>
    <segment id="16">Vídeos que circulam nas redes sociais mostram que havia ao menos uma criança entre os resgatados.</segment>
    <segment id="17">O grupo foi salvo por embarcações que passavam pelo local e depois foi levado para a comunidade de Solimões.</segment>
    <segment id="18">A universidade disse que "entrou em contato com a Capitania dos Portos de Santarém/Marinha e o Corpo de Bombeiros para informar sobre o incidente e solicitar auxílio no resgate".  "</segment>
    <segment id="19">A CFS instaurou Inquérito Administrativo sobre Acidentes e Fatos da Navegação para apurar as circunstâncias do naufrágio"</segment>
    <segment id="20">, afirmou a Marinha do Brasil</segment>
    <segment id="21">, em nota.</segment>
    <segment id="22">Os alunos e a docente permanecem na comunidade e aguardam para voltar a Santarém.</segment>
    <segment id="23">"</segment>
    <segment id="24">A Ufopa está trabalhando</segment>
    <segment id="25">para que</segment>
    <segment id="26">para que todos os discentes e a docente retornem de forma segura para Santarém e já acionou o contrato de seguro estudantil e seus profissionais de saúde</segment>
    <segment id="27">, a fim de prestar a todos o auxílio necessário"</segment>
    <segment id="28">, declarou a universidade</segment>
    <segment id="29">, em nota assinada pela reitora Aldenize Ruela Xavier.</segment>
  </rst>
</analysis>