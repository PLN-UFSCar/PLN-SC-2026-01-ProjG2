  <rst>
    <segment id="1">O prefeito de Araucária (PR)</segment>
    <segment id="2">, Hissam Hussein Dehaini (Cidadania)</segment>
    <segment id="3">, 65, se</segment>
    <segment id="4">se casou neste mês com uma adolescente de 16 anos e</segment>
    <segment id="5">, na mesma semana</segment>
    <segment id="6">, promoveu a sogra ao cargo de secretária municipal de Cultura e Turismo.</segment>
    <segment id="7">Hissam está no segundo mandato</segment>
    <segment id="8">comocomo prefeito da cidade</segment>
    <segment id="9">, que fica na região metropolitana de Curitiba</segment>
    <segment id="10">, e é empresário.</segment>
    <segment id="11">Nas eleições de 2020</segment>
    <segment id="12">, informou à Justiça Eleitoral ter um patrimônio de mais de R$ 14 milhões.</segment>
    <segment id="13">A esposa adolescente é estudante.</segment>
    <segment id="14">Pela legislação brasileira</segment>
    <segment id="15">, o casamento só é autorizado a partir dos 16 anos.</segment>
    <segment id="16">Abaixo desta idade</segment>
    <segment id="17">, não há qualquer permissão.</segment>
    <segment id="18">Além disso</segment>
    <segment id="19">, artigo do Código Civil define que</segment>
    <segment id="20">, para quem tem entre 16 e 18 anos (incompletos)</segment>
    <segment id="21">, o casamento depende de autorização dos pais ou responsáveis legais.</segment>
    <segment id="22">O prefeito de Araucária (PR)</segment>
    <segment id="23">, Hissam Hussein Dehaini</segment>
    <segment id="24">, 65 - @hissamoficial no InstagramA mãe da adolescente</segment>
    <segment id="25">sese tornou secretária de Cultura e Turismo no último dia 14.</segment>
    <segment id="26">Dois dias antes</segment>
    <segment id="27">, em 12 de abril</segment>
    <segment id="28">, o Jornal Oficial dos Cartórios de Registro Civil do Brasil publicava o ato que informa que o casal apresentou os documentos para realização do casamento (edital de proclamas).</segment>
    <segment id="29">Ela não foi a primeira pessoa da família a ganhar um cargo.</segment>
    <segment id="30">Em outubro de 2022</segment>
    <segment id="31">, uma tia da adolescente</segment>
    <segment id="32">sese tornou secretária de Planejamento do município.</segment>
    <segment id="33">Procurada</segment>
    <segment id="34">, a Prefeitura de Araucária afirmou que as duas possuem ampla experiência no serviço público.</segment>
    <segment id="35">"</segment>
    <segment id="36">A decisão acerca da composição de seu secretariado é ato discricionário do chefe do Poder Executivo</segment>
    <segment id="37">, o qual entendeu que a servidora em questão [a mãe da adolescente] reúne as condições necessárias para o exercício do cargo"</segment>
    <segment id="38">, diz nota enviada à reportagem.</segment>
    <segment id="39">Sobre a tia</segment>
    <segment id="40">, a gestão afirma que ela é "servidora concursada no município há mais de dez anos".</segment>
    <segment id="41">Segundo a prefeitura</segment>
    <segment id="42">, antes de assumir o comando do Planejamento ela já havia exercido outros dois cargos de chefia na mesma pasta</segment>
    <segment id="43">, de superintendente de projetos e inovação e de diretora-geral.</segment>
    <segment id="44">Ainda segundo o município</segment>
    <segment id="45">, antes de assumir a pasta da Cultura</segment>
    <segment id="46">, a mãe da jovem exerceu dois cargos na secretaria de Educação</segment>
    <segment id="47">, primeiro</segment>
    <segment id="48">comocomo assessora (nomeada em agosto de 2021) e depois</segment>
    <segment id="49">comocomo diretora-geral (nomeada em janeiro de 2022).</segment>
    <segment id="50">Como diretora-geral da Educação</segment>
    <segment id="51">, ela recebia quase R$ 15 mil (R$ 14.917</segment>
    <segment id="52">,38, valor bruto).</segment>
    <segment id="53">No cargo de secretária</segment>
    <segment id="54">, o salário bruto sobe para R$ 21.416.</segment>
    <segment id="55">Histórico</segment>
    <segment id="56">A contratação de parentes ou pessoas ligadas à família é uma prática adotada por Hissam Hussein Dehaini desde o primeiro mandato.</segment>
    <segment id="57">Em 2019</segment>
    <segment id="58">, a Oscip (Organização da Sociedade Civil de Interesse Público)</segment>
    <segment id="59">Vigilantes da Gestão Pública chegou a entrar com uma reclamação no STF (Supremo Tribunal Federal) questionando nomeações</segment>
    <segment id="60">, masmas o processo foi arquivado no mesmo ano.</segment>
    <segment id="61">A Corte entendeu que as contratações não feriam a súmula antinepotismo</segment>
    <segment id="62">poispois diziam respeito a cargos de natureza política.</segment>
    <segment id="63">Na época</segment>
    <segment id="64">, a Oscip apontava as nomeações de Cristiane Inez Martins Dehaini (então esposa do prefeito)</segment>
    <segment id="65">comocomo secretária de Assistência Social</segment>
    <segment id="66">; de Ryam Hissam Dehaini (filha do prefeito)</segment>
    <segment id="67">, como</segment>
    <segment id="68">como secretária de Gestão de Pessoas</segment>
    <segment id="69">; de José Roberto Martins (cunhado do prefeito)</segment>
    <segment id="70">, como</segment>
    <segment id="71">como secretário de Trabalho e Emprego</segment>
    <segment id="72">; e de Eduardo Rogriguez Mello (genro do prefeito)</segment>
    <segment id="73">, como</segment>
    <segment id="74">como secretário de Administração.</segment>
    <segment id="75">Atualmente</segment>
    <segment id="76">, além de Ryam</segment>
    <segment id="77">, que segue no comando da pasta de Gestão de Pessoas</segment>
    <segment id="78">, Yasmim Hissam Dehaini</segment>
    <segment id="79">, outra filha do prefeito</segment>
    <segment id="80">, está na cadeira de secretária de Administração.</segment>
    <segment id="81">Há, ainda</segment>
    <segment id="82">, Cilmara Maria do Rosário</segment>
    <segment id="83">, nora do prefeito</segment>
    <segment id="84">, no cargo de secretária de Comunicação.</segment>
  </rst>
</analysis>