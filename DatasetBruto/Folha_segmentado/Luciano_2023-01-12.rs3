  <rst>
    <segment id="1">Depois de condenar os ataques golpistas em Brasília e dizer que torce pelo "piloto" –em referência a Lula–</segment>
    <segment id="2">, Luciano Hang</segment>
    <segment id="3">, dono da Havan e um dos empresários mais próximos de Jair Bolsonaro</segment>
    <segment id="4">, virou alvo de piadas na internet.</segment>
    <segment id="5">Painel S.A.Receba no seu email as informações exclusivas da coluna</segment>
    <segment id="6">Painel S.A.Carregando...</segment>
    <segment id="7">No Twitter</segment>
    <segment id="8">, internautas passaram a chamá-lo de "veio de Havana"</segment>
    <segment id="9">, para associá-lo ao governo cubano em uma paródia com o apelido "velho da Havan"</segment>
    <segment id="10">, que o empresário assumiu nos últimos anos.</segment>
    <segment id="11">Algumas mensagens também alteraram as roupas de Hang</segment>
    <segment id="12">, que costuma usar um terno verde e amarelo.</segment>
    <segment id="13">Nelas, ele aparece vestido de vermelho e com a estrela do partido de Lula</segment>
    <segment id="14">, o PT.</segment>
    <segment id="15">Um dos maiores apoiadores de Bolsonaro no empresariado</segment>
    <segment id="16">, Hang surpreendeu internautas na semana passada</segment>
    <segment id="17">, quando desejou ao governo Lula que faça uma "ótima administração".</segment>
    <segment id="18">Sem mencionar o nome do petista</segment>
    <segment id="19">, também disse esperar que "o piloto faça um belo voo".</segment>
    <segment id="20">Joana Cunha com Paulo Ricardo Martins e Diego Felix  Luciano Hang</segment>
    <segment id="21">, dono da rede de lojas Havan - Antonio Molina - 27.abr.22/Folhapress</segment>
  </rst>
</analysis>