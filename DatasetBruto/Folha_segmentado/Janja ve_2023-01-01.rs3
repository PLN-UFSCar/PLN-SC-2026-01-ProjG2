  <rst>
    <segment id="1">A primeira-dama Rosângela Lula da Silva</segment>
    <segment id="2">, a Janja</segment>
    <segment id="3">, usou no tradicional desfile da posse presidencial do marido Lula um terno bege com adornos marrons.</segment>
    <segment id="4">O modelo é uma criação da estilista gaúcha Helô Rocha</segment>
    <segment id="5">, de 42 anos.</segment>
    <segment id="6">Terno da primeira-dama foi feito pela estilista Helô Rocha.</segment>
    <segment id="7">-(Ricardo Stuckert/Divulgação)Rocha</segment>
    <segment id="8">, que nasceu em Porto Alegre</segment>
    <segment id="9">masmas foi criada em Natal</segment>
    <segment id="10">, também foi responsável pelo vestido de noiva de Janja</segment>
    <segment id="11">, que casou com Lula em maio do ano passado.</segment>
    <segment id="12">A peça tinha bordados que foram produzidos por trabalho artesanal em Seridó</segment>
    <segment id="13">, no Rio Grande do Norte.</segment>
    <segment id="14">A badalada estilista</segment>
    <segment id="15">sese formou em moda em São Paulo</segment>
    <segment id="16">, na Faculdade Santa Marcelina</segment>
    <segment id="17">, e tem</segment>
    <segment id="18">comocomo tio-avô o fundador das lojas Riachuelo.</segment>
    <segment id="19">Veja detalhes do terno que Janja usou na posse de LulaMais    novamente         de   de  de  representando um    Janja</segment>
    <segment id="20">sese interessa por moda brasileira e costuma utilizar de sua exposição midiática para chamar atenção para essa indústria no país.</segment>
    <segment id="21">Nas peças que veste</segment>
    <segment id="22">, ela busca representar a si e a cultura popular.</segment>
    <segment id="23">Em entrevista para o Fantástico</segment>
    <segment id="24">, da TV Globo</segment>
    <segment id="25">, em novembro</segment>
    <segment id="26">, a socióloga usou uma camisa de seda branca com desenhos vermelhos do estilista Airon Martin.</segment>
    <segment id="27">Em poucas horas</segment>
    <segment id="28">, a peça</segment>
    <segment id="29">sese esgotou na internet.</segment>
  </rst>
