  <rst>
    <segment id="1">Rita Lee</segment>
    <segment id="2">, morta nesta segunda-feira (8) aos 75 anos</segment>
    <segment id="3">, tinha carinha de anjo</segment>
    <segment id="4">, masmas cultivou a atitude rock’n’roll desde bem pequena.</segment>
    <segment id="5">Nas festas de aniversário</segment>
    <segment id="6">, estourava bexigas no ouvido dos adultos e roubava presentes que depois destruía.</segment>
    <segment id="7">Na saída das missas</segment>
    <segment id="8">, fingia ter deficiência física e pedia esmolas.</segment>
    <segment id="9">Eram os anos 1950</segment>
    <segment id="10">, na tranquila Vila Mariana</segment>
    <segment id="11">, em São Paulo.</segment>
    <segment id="12">Nascida em 1947</segment>
    <segment id="13">, ela passou a infância e a adolescência em um sobrado na rua Joaquim Távora</segment>
    <segment id="14">, onde havia um porão que a deixava longe da vigília dos pais</segment>
    <segment id="15">, com as paredes cobertas por fotos de artistas</segment>
    <segment id="16">, quartel-general de sonhos e da sensação de liberdade.</segment>
    <segment id="17">A cantora e compositora Rita Lee em fotografia de 1998 - Evelson de Freitas/FolhapressA mãe</segment>
    <segment id="18">, Romilda Padula</segment>
    <segment id="19">, de origem italiana</segment>
    <segment id="20">, era,</segment>
    <segment id="21">comocomo Rita dizia</segment>
    <segment id="22">, mais católica do que o papa.</segment>
    <segment id="23">O pai, Charles Jones</segment>
    <segment id="24">, dentista</segment>
    <segment id="25">, descendente de americanos</segment>
    <segment id="26">, tinha a ufologia</segment>
    <segment id="27">comocomo fé.</segment>
    <segment id="28">Certa vez</segment>
    <segment id="29">, disse a Rita</segment>
    <segment id="30">, quando viram luzes no céu:</segment>
    <segment id="31">"Vou te contar: Papai Noel</segment>
    <segment id="32">, Coelho da Páscoa</segment>
    <segment id="33">, Deus e o Diabo</segment>
    <segment id="34">, céu e inferno</segment>
    <segment id="35">, essas bobagens não existem.</segment>
    <segment id="36">Quem compra os presentes é a sua mãe.</segment>
    <segment id="37">O que você viu não foi Peter Pan.</segment>
    <segment id="38">Você viu um disco voador".</segment>
    <segment id="39">Entre o catolicismo e a ufologia</segment>
    <segment id="40">, Rita escolheu o segundo.</segment>
    <segment id="41">Caçula</segment>
    <segment id="42">, tinha duas irmãs</segment>
    <segment id="43">, Mary e Virgínia Lee Jones.</segment>
    <segment id="44">O sobrenome do meio foi dado em homenagem a Robert Lee</segment>
    <segment id="45">, general da Guerra de Secessão.</segment>
    <segment id="46">Mais duas mulheres</segment>
    <segment id="47">, Luiza e Carolina</segment>
    <segment id="48">, que ajudavam a cuidar das meninas e da casa e</segment>
    <segment id="49">sese agregaram à família</segment>
    <segment id="50">, integravam o universo predominantemente feminino no qual Rita cresceu.</segment>
    <segment id="51">Imagens da cantora Rita LeeMais    novamente         de   de  de  representando um  Ficou guardado entre elas um segredo trágico</segment>
    <segment id="52">, que a cantora revelou na autobiografia.</segment>
    <segment id="53">Aos seis anos</segment>
    <segment id="54">, Rita foi estuprada por um técnico que foi à sua casa consertar uma máquina de costura.</segment>
    <segment id="55">A mãe teve de atender ao telefone e</segment>
    <segment id="56">, quando voltou</segment>
    <segment id="57">, encontrou Rita sangrando com uma chave de fenda na vagina.</segment>
    <segment id="58">As mulheres decidiram não contar a Charles</segment>
    <segment id="59">, com medo de que ele matasse o homem e terminasse preso.</segment>
    <segment id="60">A partir daí</segment>
    <segment id="61">, conforme a cantora narrou sem autopiedade</segment>
    <segment id="62">, passaram a tratá-la "</segment>
    <segment id="63">comocomo uma espécie de aleijadinha psicológica".</segment>
    <segment id="64">Das travessuras na infância às drogas na vida adulta</segment>
    <segment id="65">, tudo era relevado por elas</segment>
    <segment id="66">, acreditava Rita</segment>
    <segment id="67">, por ser consequência "daquilo</segment>
    <segment id="68">, tadinha".</segment>
    <segment id="69">Veja imagens históricas de Rita LeeMais    novamente         de   de  de  representando um  Rita</segment>
    <segment id="70">sese meteu em muita confusão</segment>
    <segment id="71">, a começar pelas do Liceu Pasteur</segment>
    <segment id="72">, tradicional colégio francês da Vila Mariana no qual estudou.</segment>
    <segment id="73">Seu histórico incluía fazer xixi nos sapatos deixados pelas alunas no vestiário durante as aulas de ginástica e uma tentativa de atear fogo ao teatro.</segment>
    <segment id="74">No universo escolar</segment>
    <segment id="75">, durante a adolescência</segment>
    <segment id="76">, decidiu também</segment>
    <segment id="77">sese meter com a música</segment>
    <segment id="78">, quando passou a</segment>
    <segment id="79">sese apresentar em bailinhos</segment>
    <segment id="80">, festas juninas e afins.</segment>
    <segment id="81">LEIA MAIS</segment>
    <segment id="82">SOBRE A MORTE DE RITA LEEMorre Rita Lee</segment>
    <segment id="83">, maior estrela do rock brasileiro e ícone dos Mutantes</segment>
    <segment id="84">, aos 75 anosComo Rita Lee</segment>
    <segment id="85">encarnou deusa pagã de SP e virou mãe menina da cidadeComo Rita Lee foi do hard rock esperto a uma química pop irretocávelRita</segment>
    <segment id="86">Lee virou poeta do rock e falou com crianças em livros espirituososEntenda a briga de Rita Lee com Zezé Di Camargo por causa de rodeiosDe &amp;#039</segment>
    <segment id="87">;Build Up&amp;#039</segment>
    <segment id="88">; a &amp;#039</segment>
    <segment id="89">;Reza&amp;#039</segment>
    <segment id="90">;, relembre os principais discos da carreira de Rita</segment>
    <segment id="91">LeeEra preciso</segment>
    <segment id="92">, para isso</segment>
    <segment id="93">, enfrentar a repressão em casa —ou fugir dela.</segment>
    <segment id="94">Com o "modelito show</segment>
    <segment id="95">" por baixo da camisola</segment>
    <segment id="96">,</segment>
    <segment id="97">Rita pulava a janela do quarto e dava os primeiros passos da carreira.</segment>
    <segment id="98">Acabou descoberta pelo pai quando passou mal em uma apresentação e foi levada ao hospital</segment>
    <segment id="99">, onde foi operada de apendicite.</segment>
    <segment id="100">Quando acordou</segment>
    <segment id="101">, Charles</segment>
    <segment id="102">, em vez de uma bronca</segment>
    <segment id="103">, lhe deu um violão.</segment>
    <segment id="104">É preferível à barulheira da bateria</segment>
    <segment id="105">, disse.</segment>
    <segment id="106">Da Vila Mariana</segment>
    <segment id="107">, passou a aprontar todas na Pompeia</segment>
    <segment id="108">, bairro da zona oeste da capital paulista onde ficava a casa do irmãos Dias Batista</segment>
    <segment id="109">, que ela conheceu em 1964 um festival escolar e com os quais formaria</segment>
    <segment id="110">Os Mutantes.</segment>
    <segment id="111">Além de Arnaldo Baptista e Sérgio</segment>
    <segment id="112">, integrantes do grupo</segment>
    <segment id="113">, o mais velho</segment>
    <segment id="114">, Cláudio César</segment>
    <segment id="115">, montou uma oficina na garagem para a fabricação de instrumentos</segment>
    <segment id="116">, em especial guitarras</segment>
    <segment id="117">, e de amplificadores.</segment>
    <segment id="118">Suas experimentações</segment>
    <segment id="119">, tanto técnicas quanto estéticas</segment>
    <segment id="120">, seriam uma das grandes sensações dos Mutantes.</segment>
    <segment id="121">LEIA MAIS</segment>
    <segment id="122">SOBRE A MORTE DE RITA LEEMorre Rita Lee</segment>
    <segment id="123">, maior estrela do rock brasileiro e ícone dos Mutantes</segment>
    <segment id="124">, aos 75 anosRita Lee</segment>
    <segment id="125">, rebelde desde a infância</segment>
    <segment id="126">, sese deixou guiar por drogas e discos voadoresComo Rita Lee foi do hard rock esperto a uma química pop irretocávelRita</segment>
    <segment id="127">Lee virou poeta do rock e falou com crianças em livros</segment>
    <segment id="128">espirituososCom</segment>
    <segment id="129">a oficina e os ensaios</segment>
    <segment id="130">, a casa virou point de roqueiros amadores e profissionais</segment>
    <segment id="131">, além de demais simpatizantes de rock e de maconha.</segment>
    <segment id="132">Entre uma viagem musical e outra</segment>
    <segment id="133">, Rita e os irmãos</segment>
    <segment id="134">Batista saíam de carro pela cidade jogando restos de comida em pessoas em pontos de ônibus</segment>
    <segment id="135">, atirando rojões em farmácias e em bancas de jornal.</segment>
    <segment id="136">Em meio a esta loucura toda e ao sucesso dos Mutantes</segment>
    <segment id="137">, Rita até tentou cursar comunicação na Universidade de São Paulo</segment>
    <segment id="138">, masmas logo desistiu.</segment>
    <segment id="139">O nível de piração foi para outra dimensão quando o LSD</segment>
    <segment id="140">sese tornou parte da banda</segment>
    <segment id="141">, após uma turnê que fizeram em Paris</segment>
    <segment id="142">, em 1970</segment>
    <segment id="143">, e música virou sinônimo de alucinação.</segment>
    <segment id="144">Rita, na volta da Europa para o Brasil</segment>
    <segment id="145">, passou pela alfândega na cara de pau com um colar colorido no pescoço todo feito de ácido</segment>
    <segment id="146">, como</segment>
    <segment id="147">como se</segment>
    <segment id="148">se fossem miçangas.</segment>
    <segment id="149">A comunidade que os Mutantes formaram em um terreno que compraram na Serra da Cantareira</segment>
    <segment id="150">, a Mutantolândia</segment>
    <segment id="151">, era de sexo</segment>
    <segment id="152">, muitas drogas e rock’n’roll.</segment>
    <segment id="153">Tinha aura hippie</segment>
    <segment id="154">, masmas não era só de paz e amor</segment>
    <segment id="155">, e as brigas envolvendo o casal Rita e Arnaldo</segment>
    <segment id="156">sese misturavam às da banda.</segment>
    <segment id="157">Com o parceiro musical e primeiro namorado</segment>
    <segment id="158">, ela tinha de guardar a sete chaves sentimentos "caretas"</segment>
    <segment id="159">, como</segment>
    <segment id="160">como o ciúme.</segment>
    <segment id="161">Era preciso posar de moderna</segment>
    <segment id="162">, devota da liberdade</segment>
    <segment id="163">, e Arnaldo podia namorar outras até na sua frente.</segment>
    <segment id="164">O paradoxo rebelde/romântico foi ilustrado pelo casamento dos dois</segment>
    <segment id="165">, em dezembro de 1971.</segment>
    <segment id="166">Na cerimônia</segment>
    <segment id="167">, Rita usou o vestido de noiva cenográfico que a atriz Leila Diniz lhe emprestara em 1968 para a apresentação dos Mutantes no 3º Festival Internacional da Canção</segment>
    <segment id="168">, o FIC.</segment>
    <segment id="169">Convidados para o programa da Hebe</segment>
    <segment id="170">, os pombinhos rasgaram a certidão de casamento no ar</segment>
    <segment id="171">, chocando a apresentadora e o público.</segment>
    <segment id="172">Gracinhas.</segment>
    <segment id="173">A separação real foi menos midiática e mais dramática</segment>
    <segment id="174">, quando Arnaldo expulsou Rita dos Mutantes</segment>
    <segment id="175">, em 1972.</segment>
    <segment id="176">A cantora já vinha fazendo projetos solo</segment>
    <segment id="177">, com escolhas mais pop do que as dos irmãos Batista</segment>
    <segment id="178">, que se</segment>
    <segment id="179">se voltaram ao rock progressivo e trocaram o deboche</segment>
    <segment id="180">, marca do grupo</segment>
    <segment id="181">, por uma espécie de messianismo lisérgico –a mistura de música e drogas era tida</segment>
    <segment id="182">comocomo um caminho artístico</segment>
    <segment id="183">, existencial e até político.</segment>
    <segment id="184">Em plena ditadura militar</segment>
    <segment id="185">, Rita</segment>
    <segment id="186">, conforme relatou em sua autobiografia</segment>
    <segment id="187">, zombava de tudo elaborando o seguinte</segment>
    <segment id="188">"projeto político": "</segment>
    <segment id="189">Jogar zilhões de LSD na caixa d’água da Vila Mariana".</segment>
    <segment id="190">Ainda que a participação dos Mutantes na tropicália fosse certamente política</segment>
    <segment id="191">, a cantora não</segment>
    <segment id="192">sese considerava adepta da luta contra a ditadura e</segment>
    <segment id="193">sese definia</segment>
    <segment id="194">comocomo "hiponga comunista com um pé no imperialismo":</segment>
    <segment id="195">"</segment>
    <segment id="196">Por que perder tempo lutando contra um filme de horror quando podia fazer da vida uma comédia?</segment>
    <segment id="197">"  Não tinha paciência com os jovens de esquerda que vaiavam nos festivais qualquer apresentação que não fosse de música de protesto:</segment>
    <segment id="198">"Vou é tomar um ácido</segment>
    <segment id="199">;</segment>
    <segment id="200">fodam-</segment>
    <segment id="201">sese vocês</segment>
    <segment id="202">, engajadinhos políticos"</segment>
    <segment id="203">, pensava</segment>
    <segment id="204">, como</segment>
    <segment id="205">como relatou no filme "Ovelha Negra".</segment>
    <segment id="206">Das tantas confusões que protagonizou envolvendo drogas</segment>
    <segment id="207">, algumas são até</segment>
    <segment id="208">, digamos</segment>
    <segment id="209">, folclóricas.</segment>
    <segment id="210">Dentre elas está a do dia em que foi reclamar com André Midani</segment>
    <segment id="211">, presidente da gravadora Philips</segment>
    <segment id="212">, com quem tinha um affair</segment>
    <segment id="213">, da decisão de não gravar um disco produzido sob o efeito de ácido.</segment>
    <segment id="214">Na sala de espera</segment>
    <segment id="215">, encontrou Tim Maia</segment>
    <segment id="216">, enfurecido com a foto sua que tinham escolhido para um disco.</segment>
    <segment id="217">Entraram na sala do executivo</segment>
    <segment id="218">, que não estava lá</segment>
    <segment id="219">, e quebraram tudo</segment>
    <segment id="220">, até discos de ouro emoldurados.</segment>
    <segment id="221">Saíram acendendo um "baurets"</segment>
    <segment id="222">, como</segment>
    <segment id="223">como o cantor chamava cigarros de maconha.</segment>
    <segment id="224">Já das passagens trágicas</segment>
    <segment id="225">, Rita</segment>
    <segment id="226">, na turnê do Rio de "Fruto Proibido"</segment>
    <segment id="227">, primeiro CD com que fez sucesso sem os Mutantes</segment>
    <segment id="228">, passou três dias cheirando cocaína no quarto do hotel</segment>
    <segment id="229">, sem conseguir fazer shows</segment>
    <segment id="230">, e ameaçou</segment>
    <segment id="231">sese atirar pela janela quando a droga acabou.</segment>
    <segment id="232">A vida seria repleta de loucuras assim</segment>
    <segment id="233">, até que</segment>
    <segment id="234">, em 2005</segment>
    <segment id="235">, o nascimento da primeira neta fosse o estímulo</segment>
    <segment id="236">para que</segment>
    <segment id="237">para que ela deixasse as drogas.</segment>
    <segment id="238">Perto dos 60</segment>
    <segment id="239">, a cantora</segment>
    <segment id="240">sese mostrava disposta a desdizer o que uma tia vaticinara na sua infância</segment>
    <segment id="241">, quando ela bebeu até cair no alambique da fazenda da família: "</segment>
    <segment id="242">O defeito de Ritinha é não saber parar".</segment>
  </rst>
</analysis>