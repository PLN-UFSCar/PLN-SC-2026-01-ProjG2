  </header>
  <rst>
    <segment id="1">Depois de um ano marcado por polêmicas em torno de rankings de comidas</segment>
    <segment id="2">, como</segment>
    <segment id="3">como o</segment>
    <segment id="4">casocaso do cuscuz paulista pontado</segment>
    <segment id="5">comocomo o pior prato do país</segment>
    <segment id="6">, as culinárias italiana</segment>
    <segment id="7">, japonesa e grega acabaram listadas</segment>
    <segment id="8">comocomo as melhores do mundo pelo site Taste Atlas (o Brasil ficou em 12º).</segment>
    <segment id="9">Ingredientes da feijoada da Universidade da Cachaça</segment>
    <segment id="10">, em São Paulo - Gui Mohallem/FolhapressApesar da grande atenção dada a esse tipo de lista na internet</segment>
    <segment id="11">, pode-</segment>
    <segment id="12">sese argumentar que toda a ideia de uma comida típica é uma fantasia.</segment>
    <segment id="13">"</segment>
    <segment id="14">Quanto mais pesquiso a relação entre nações e comidas</segment>
    <segment id="15">, mais essa ideia parece artificial</segment>
    <segment id="16">",</segment>
    <segment id="17">afirma a escritora russo-americana Anya von Bremzen</segment>
    <segment id="18">, em entrevista à Folha.</segment>
    <segment id="19">Apesar do que chama de compulsão das pessoas em vincular cada comida a seu lugar</segment>
    <segment id="20">, essa conexão tem mais a ver com mito e marketing do que com fatos históricos</segment>
    <segment id="21">, diz.</segment>
    <segment id="22">Autora do livro "</segment>
    <segment id="23">National Dish" (ed. Penguin Press</segment>
    <segment id="24">; 352 págs.</segment>
    <segment id="25">; 2023)</segment>
    <segment id="26">, ou prato nacional</segment>
    <segment id="27">, ela viajou por seis países em busca das histórias das suas comidas mais típicas.  FeijoadaMais    novamente         de   de  de  representando um</segment>
    <segment id="28">A obra</segment>
    <segment id="29">, ainda sem versão em português</segment>
    <segment id="30">, aponta que a maioria desses pratos nacionais é recente e promovida na tentativa de reforçar uma identidade nacional.</segment>
    <segment id="31">É o caso</segment>
    <segment id="32">caso da pizza na Itália</segment>
    <segment id="33">, do rámen no Japão e mesmo da feijoada no Brasil.</segment>
    <segment id="34">"</segment>
    <segment id="35">Como símbolo nacional</segment>
    <segment id="36">, a comida carrega a carga emocional de uma bandeira e de um hino</segment>
    <segment id="37">, aquelas tradições inventadas</segment>
    <segment id="38">, cruciais para construir e sustentar uma nação e suas raízes históricas"</segment>
    <segment id="39">, diz.</segment>
    <segment id="40">Entretanto</segment>
    <segment id="41">, esses pratos são "impulsionados por forças comerciais</segment>
    <segment id="42">, campanhas de marca-país e ideias neoliberais".</segment>
    <segment id="43">A chave da questão</segment>
    <segment id="44">, segundo Bremzen</segment>
    <segment id="45">, vem do estudo sobre a própria ideia de construção de nação e nacionalismos a partir de estudos consagrados de acadêmicos</segment>
    <segment id="46">comocomo Benedict Anderson (1936-2015) e Eric Hobsbawm (1917-2012).</segment>
    <segment id="47">Veja imagens da exposição</segment>
    <segment id="48">A Arte do Ramen Donburi</segment>
    <segment id="49">Mais    novamente         de   de  de  representando um  "</segment>
    <segment id="50">As pessoas tendem a projetar nossa ideia moderna de uma nação com fronteiras e Estados para uma época em que isso não existia.</segment>
    <segment id="51">A realidade era muito diferente em países</segment>
    <segment id="52">comocomo Itália e França</segment>
    <segment id="53">, mesmo nos séculos 18 e 19"</segment>
    <segment id="54">, diz.</segment>
    <segment id="55">Este processo</segment>
    <segment id="56">sese acelerou ainda mais no fim dos anos 1980</segment>
    <segment id="57">, quando diferentes países viram na defesa das suas tradições (inventadas) uma forma de ganhar poder econômico por mecanismos de proteção.</segment>
    <segment id="58">"Tratava-</segment>
    <segment id="59">sese de defender bens culturais</segment>
    <segment id="60">, seu valor econômico e de colocar um selo que diz ‘isto é nosso’"</segment>
    <segment id="61">, diz.</segment>
    <segment id="62">Em sua pesquisa</segment>
    <segment id="63">, Bremzen foi a Paris</segment>
    <segment id="64">, Nápoles</segment>
    <segment id="65">, Tóquio</segment>
    <segment id="66">, Sevilha</segment>
    <segment id="67">, Oaxaca (no México) e Istambul</segment>
    <segment id="68">, comeu comidas locais</segment>
    <segment id="69">, entrevistou chefs e acadêmicos e mergulhou em uma busca pela história das receitas.</segment>
    <segment id="70">O livro funciona</segment>
    <segment id="71">comocomo um interessante diário de viagem em torno de pratos</segment>
    <segment id="72">comocomo pizza</segment>
    <segment id="73">, rámen</segment>
    <segment id="74">, tapa e mezze.</segment>
    <segment id="75">Cada prato é desmistificado</segment>
    <segment id="76">, apontando sua origem e</segment>
    <segment id="77">comocomo foi usado nesse processo de reforçar a identidade nacional.</segment>
    <segment id="78">Veja imagens de pizzas e pizzarias paulistanasMais    novamente         de   de  de  representando um</segment>
    <segment id="79">Além disso</segment>
    <segment id="80">, ela também</segment>
    <segment id="81">sese debruça sobre a importância do símbolo gastronômico em momentos de conflito.</segment>
    <segment id="82">O último capítulo do livro aborda a disputa entre Rússia e Ucrânia pela bandeira do borsch</segment>
    <segment id="83">, sopa de carne e legumes</segment>
    <segment id="84">comocomo beterraba.</segment>
    <segment id="85">Desde o início da guerra</segment>
    <segment id="86">, o Kremlin promove a ideia de que o prato tem origem russa</segment>
    <segment id="87">, enquanto a Unesco o reconhece</segment>
    <segment id="88">comocomo ucraniano.</segment>
    <segment id="89">Mesmo sem incluir o Brasil em seu estudo</segment>
    <segment id="90">, Bremzen conta que veio várias vezes ao país e comeu feijoada pela primeira vez no Copacabana Palace nos anos 1980.</segment>
    <segment id="91">Para ela</segment>
    <segment id="92">, o prato nacional brasileiro também é uma construção.  "</segment>
    <segment id="93">A feijoada é um</segment>
    <segment id="94">casocaso realmente interessante</segment>
    <segment id="95">, promovida no início do século 20 na tentativa de criar um símbolo do Brasil.</segment>
    <segment id="96">Era apenas um prato básico de feijão que existia no imaginário popular e</segment>
    <segment id="97">, com a ajuda de elites românticas pós-coloniais</segment>
    <segment id="98">, foi transformado em símbolo nacional.</segment>
    <segment id="99">"</segment>
    <segment id="100">Aprenda a fazer estrogonofe de frangoMais    novamente         de   de  de  representando um</segment>
    <segment id="101">Apesar de sua pesquisa desconstruir esses símbolos</segment>
    <segment id="102">, Bremzen diz que rituais têm seu valor.</segment>
    <segment id="103">"</segment>
    <segment id="104">Algo pode ser uma tradição inventada</segment>
    <segment id="105">, masmas criar raízes e</segment>
    <segment id="106">sese tornar parte da celebração nacional e parte de uma espécie de consumo ritualista.</segment>
    <segment id="107">É um processo fluido</segment>
    <segment id="108">, de criação de identidades</segment>
    <segment id="109">, de marcas</segment>
    <segment id="110">, de cozinhas"</segment>
    <segment id="111">, diz.</segment>
    <segment id="112">Por mais que chame a ideia de autenticidade na busca pelos pratos tradicionais apenas de ferramenta de marketing</segment>
    <segment id="113">, ela diz acreditar que vale a pena viajar buscando conhecer comidas —</segment>
    <segment id="114">masmas que não é necessário</segment>
    <segment id="115">sese apegar à ideia das raízes históricas e intocáveis.</segment>
    <segment id="116">"</segment>
    <segment id="117">A internet está transformando a comida em algo completamente transnacional.</segment>
    <segment id="118">Há uma grande fluidez.</segment>
    <segment id="119">Podemos comer qualquer coisa em qualquer lugar".</segment>
    <segment id="120">Essa fluidez</segment>
    <segment id="121">, explica</segment>
    <segment id="122">, é positiva e pode levar a misturas entre as culturas gastronômicas que rompem as regras e levam à popularidade de pratos</segment>
    <segment id="123">comocomo o estrogonofe no Brasil</segment>
    <segment id="124">, rámen no México e outras comidas que podem ser criticadas</segment>
    <segment id="125">comocomo "bastardos" dos pratos originais.</segment>
    <segment id="126">"</segment>
    <segment id="127">Misturar culturas é parte natural do processo.</segment>
    <segment id="128">Falar sobre apropriação cultural quando tratamos de comidas é vazio.</segment>
    <segment id="129">Precisamos falar sobre injustiças raciais</segment>
    <segment id="130">, de classe e desequilíbrios de poder</segment>
    <segment id="131">, masmas não em torno de uma discussão sobre ‘quem roubou o espaguete de quem’"</segment>
    <segment id="132">, diz.</segment>
  </rst>
</analysis>