  <rst>
    <segment id="1">Motoristas que voltam na noite desta terça (2) da Baixada Santista para a capital paulista enfrentam congestionamentos</segment>
    <segment id="2">, principalmente na rodovia dos Imigrantes.</segment>
    <segment id="3">Os acessos do litoral norte e do interior para a cidade de São Paulo estão livres após um dia de tráfego intenso.</segment>
    <segment id="4">A estimativa da Artesp (Agência de Transporte do Estado de São Paulo)</segment>
    <segment id="5">, divulgada antes do feriado</segment>
    <segment id="6">, era de que 5</segment>
    <segment id="7">,8 milhões de veículos circulariam pelas estradas em função do Réveillon.</segment>
    <segment id="8">Veja abaixo as condições das estradas conforme atualização das concessionárias entre 20h50 e 21h30 desta terça:  Motoristas enfrentam congestionamento no sistema Anchieta-Imigrantes na volta do feriado de Ano Novo em SP - Ecovias/DivulgaçãoSistema Anchieta-Imigrantes</segment>
    <segment id="9">Fluxo intenso na volta do litoral pela Imigrantes no sentido da capital paulista</segment>
    <segment id="10">, com congestionamento do km 70 ao km 58 às 20h50.</segment>
    <segment id="11">No sentido litoral</segment>
    <segment id="12">, a Anchieta registrava congestionamento do km 37 ao km 55.</segment>
    <segment id="13">Há congestionamento na Padre Manoel da Nóbrega</segment>
    <segment id="14">, sentido capital</segment>
    <segment id="15">, do km 287 ao km 280.</segment>
    <segment id="16">No sentido Praia Grande</segment>
    <segment id="17">, do km 270 ao km 274.</segment>
    <segment id="18">A Cônego Domênico Rangoni está congestionada do km 248 ao km 270 no sentido capital.</segment>
    <segment id="19">Sistema Anhanguera-Bandeirantes</segment>
    <segment id="20">As rodovias Anhanguera e Bandeirantes possuem tráfego normal</segment>
    <segment id="21">, segundo verificação das 21h.</segment>
    <segment id="22">Ayrton Senna-Carvalho Pinto  No corredor Ayrton Senna-Carvalho Pinto</segment>
    <segment id="23">, o trânsito é normal</segment>
    <segment id="24">, de acordo com reporte das 21h25.</segment>
    <segment id="25">LEIA</segment>
    <segment id="26">TAMBÉMPosso dirigir descalço?</segment>
    <segment id="27">E comer ao volante?</segment>
    <segment id="28">Veja 20 dicas antes de pegar a estradaSistema Castello-Branco-Raposo Tavares e Rodoanel</segment>
    <segment id="29">Às 21h15 na Castello Branco</segment>
    <segment id="30">, a movimentação é lenta no sentido da capital</segment>
    <segment id="31">, do km 58 ao km 56</segment>
    <segment id="32">, devido ao grande volume de veículos</segment>
    <segment id="33">, e do km 51 ao km 38</segment>
    <segment id="34">, como</segment>
    <segment id="35">como reflexo de uma pane em um veículo</segment>
    <segment id="36">, já removido da pista.</segment>
    <segment id="37">O trecho oeste do Rodoanel apresenta tráfego normal em ambos os sentidos.</segment>
    <segment id="38">Dutra-Rio-Santos  Quem vai do Rio de Janeiro para São Paulo pela rodovia</segment>
    <segment id="39">Presidente Dutra</segment>
    <segment id="40">, principal ligação rodoviária entre as duas capitais</segment>
    <segment id="41">, enfrenta trânsito intenso em diversos pontos</segment>
    <segment id="42">, como</segment>
    <segment id="43">como em Pindamonhangaba</segment>
    <segment id="44">, Taubaté e Guarulhos.</segment>
    <segment id="45">Fernão Dias</segment>
    <segment id="46">Na Fernão Dias</segment>
    <segment id="47">, atualização das 21h10 indica trânsito bom nos dois sentidos.</segment>
    <segment id="48">Rodovias</segment>
    <segment id="49">Oswaldo Cruz e Mogi-Bertioga</segment>
    <segment id="50">De acordo com o DER-SP (Departamento de Estradas de Rodagem de São Paulo)</segment>
    <segment id="51">, o tráfego é normal na rodovia Oswaldo Cruz (SP-125).</segment>
    <segment id="52">Na Mogi-Bertioga (SP-098) o registro das 21h25 é de trânsito lento.</segment>
    <segment id="53">Fotos da chegada de 2024 pelo BrasilMais    novamente         de   de  de  representando um</segment>
