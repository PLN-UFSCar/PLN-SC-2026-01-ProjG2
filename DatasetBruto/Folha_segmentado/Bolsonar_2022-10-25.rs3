  <rst>
    <segment id="1">O presidente Jair Bolsonaro (PL)</segment>
    <segment id="2">, candidato à reeleição</segment>
    <segment id="3">, afirmou nesta terça-feira (25) que o voto no próximo dia 30 tem que ser dado com a razão</segment>
    <segment id="4">, e não com o coração.</segment>
    <segment id="5">Ele fez comício em Guanambi</segment>
    <segment id="6">, no sudoeste da Bahia</segment>
    <segment id="7">, uma região em que seu rival</segment>
    <segment id="8">, o ex-presidente Luiz Inácio Lula da Silva (PT)</segment>
    <segment id="9">, teve vitória expressiva em várias cidades.</segment>
    <segment id="10">Bolsonaro em evento na cidade de Guanambi (BA)- Jair Bolsonaro no FacebookBolsonaro pediu a eleitores que acompanharam o comício</segment>
    <segment id="11">, no centro da cidade</segment>
    <segment id="12">, que virassem votos junto a amigos e familiares.</segment>
    <segment id="13">"</segment>
    <segment id="14">Muita gente votou no PT sem saber direito o que é o nosso governo.</segment>
    <segment id="15">Mostrem para eles o que é o nosso governo</segment>
    <segment id="16">, que é o da paz</segment>
    <segment id="17">, do trabalho</segment>
    <segment id="18">, da prosperidade e da liberdade"</segment>
    <segment id="19">, discursou.</segment>
    <segment id="20">"Vamos conseguir cada um mais um voto entre amigos ou dentro da família</segment>
    <segment id="21">, e seremos vitoriosos no dia 30.</segment>
    <segment id="22">Não devemos votar com o coração.</segment>
    <segment id="23">Devemos votar com a razão.</segment>
    <segment id="24">"</segment>
    <segment id="25">A viagem à cidade faz parte de estratégia da campanha do presidente para tentar reduzir a diferença de votos para Lula.</segment>
    <segment id="26">Apesar de correligionários do presidente terem pedido</segment>
    <segment id="27">, no palanque</segment>
    <segment id="28">, voto para ACM Neto (União Brasil)</segment>
    <segment id="29">, que disputa o segundo turno da eleição para o Governo da Bahia contra Jerônimo Rodrigues (PT)</segment>
    <segment id="30">, o candidato não participou do ato.</segment>
    <segment id="31">Ao final</segment>
    <segment id="32">, Bolsonaro pediu votos para ACM Neto.</segment>
    <segment id="33">O candidato já afirmou que</segment>
    <segment id="34">, caso</segment>
    <segment id="35">caso ganhe a eleição</segment>
    <segment id="36">, governará tanto com Lula</segment>
    <segment id="37">comocomo Bolsonaro.</segment>
    <segment id="38">A última pesquisa Datafolha mostrou que Lula vence Bolsonaro por 67% a 29% no Nordeste.</segment>
    <segment id="39">A margem de erro é de quatro pontos percentuais.</segment>
    <segment id="40">Guanambi é uma cidade-polo</segment>
    <segment id="41">, com forte presença de empresas de energia solar e eólica</segment>
    <segment id="42">, e tem aproximadamente 85 mil habitantes.</segment>
    <segment id="43">O estado e a cidade impuseram derrotas expressivas a Bolsonaro no primeiro turno.</segment>
    <segment id="44">Na Bahia</segment>
    <segment id="45">, o presidente perdeu para Lula por 69</segment>
    <segment id="46">,73% a 24</segment>
    <segment id="47">,31% dos votos válidos.</segment>
    <segment id="48">Em Guanambi</segment>
    <segment id="49">, a derrota foi por 64</segment>
    <segment id="50">,43% a 30</segment>
    <segment id="51">,73% dos votos válidos.</segment>
    <segment id="52">A vitória mais expressiva de Lula na região ocorreu em Boquira</segment>
    <segment id="53">, a 230 quilômetros de Guanambi.</segment>
    <segment id="54">O ex-presidente teve 89</segment>
    <segment id="55">,74% dos votos válidos no município</segment>
    <segment id="56">, contra 7</segment>
    <segment id="57">,46% de Bolsonaro.</segment>
    <segment id="58">O candidato à reeleição foi recebido em Guanambi pelo prefeito Nilo Coelho (União)</segment>
    <segment id="59">, que é ex-governador da Bahia</segment>
    <segment id="60">, e tio da candidata a vice-governadora na chapa de ACM</segment>
    <segment id="61">, Ana Coelho (Republicanos).</segment>
    <segment id="62">Também estava no aeroporto o ex-ministro da Cidadania</segment>
    <segment id="63">, João Roma (PL-BA)</segment>
    <segment id="64">, e a candidata derrotada na eleição para o senado pela Bahia</segment>
    <segment id="65">, Raissa Soares (PL)</segment>
    <segment id="66">, conhecida</segment>
    <segment id="67">comocomo doutora cloroquina.</segment>
    <segment id="68">Médica</segment>
    <segment id="69">, a candidata ganhou esse nome por defender o uso do medicamento contra a Covid-19.</segment>
    <segment id="70">Não há qualquer evidência científica de que a cloroquina tenha eficácia no tratamento da doença.</segment>
    <segment id="71">O pastor Silas Malafaia acompanha o presidente na viagem.</segment>
    <segment id="72">Mais tarde no mesmo dia</segment>
    <segment id="73">, em entrevista a uma rádio de Barreiras (BA)</segment>
    <segment id="74">, Bolsonaro prometeu realizar obras nos municípios em que receber o maior porcentual de votos no segundo turno das eleições.</segment>
    <segment id="75">O mandatário foi questionado pelo jornalista quando retornaria à cidade do interior baiano.</segment>
    <segment id="76">Respondeu que fez uma promessa de retornar aos municípios em que tiver o maior porcentual de votos e "apresentando algo também de bom para cidade</segment>
    <segment id="77">, como</segment>
    <segment id="78">como obras do governo federal".</segment>
    <segment id="79">"</segment>
    <segment id="80">Se o senhor for reeleito</segment>
    <segment id="81">, pretende voltar a Barreiras quando?</segment>
    <segment id="82">", questionou o jornalista</segment>
    <segment id="83">, já na conclusão da entrevista.</segment>
    <segment id="84">"</segment>
    <segment id="85">Eu não posso garantir aqui</segment>
    <segment id="86">, né?</segment>
    <segment id="87">Eu já assumi um compromisso</segment>
    <segment id="88">, nós temos 26 estados no Brasil e o DF.</segment>
    <segment id="89">Assumi um compromisso [de]</segment>
    <segment id="90">, caso</segment>
    <segment id="91">caso reeleito</segment>
    <segment id="92">, as cidades onde tiver o maior percentual de votos</segment>
    <segment id="93">, visitar.</segment>
    <segment id="94">Só aí então são 26 visitas.</segment>
    <segment id="95">A gente quer visitar não apenas para agradecer os votos.</segment>
    <segment id="96">A gente quer visitar apresentando algo também de bom para cidade</segment>
    <segment id="97">, como</segment>
    <segment id="98">como obras do governo federal.</segment>
    <segment id="99">Então pretendemos fazer obras sim nesses municípios onde nós fomos melhor votados no Brasil"</segment>
    <segment id="100">, afirmou o chefe do Executivo.</segment>
    <segment id="101">Especialistas em direito eleitoral explicam que não é possível falar em compra ou oferecimento de vantagens em troca de votos</segment>
    <segment id="102">, o que poderia resultar em crime segundo o Código Eleitoral.</segment>
    <segment id="103">"</segment>
    <segment id="104">Bravata e promessa populista de candidato no término do processo eleitoral</segment>
    <segment id="105">, porém</segment>
    <segment id="106">porém não vislumbro qualquer ilícito"</segment>
    <segment id="107">, afirma o advogado e professor da UFPB (Universidade Federal da Paraíba) Marcelo Weick Pogliese.</segment>
    <segment id="108">Esses especialistas afirmam que a declaração dada de maneira isolada não representa uma ilegalidade</segment>
    <segment id="109">, pois</segment>
    <segment id="110">pois seriam necessários outros fatos conexos</segment>
    <segment id="111">para que</segment>
    <segment id="112">para que o conjunto pudesse começar a ser investigado.</segment>
    <segment id="113">Ainda em Barreiras</segment>
    <segment id="114">, Bolsonaro realizou um comício no centro histórico.</segment>
    <segment id="115">Ele usou sua fala para atacar Lula e o PT.</segment>
    <segment id="116">"</segment>
    <segment id="117">Onde tem PT eu estou do outro lado"</segment>
    <segment id="118">, declarou.</segment>
    <segment id="119">Ele pediu novamente que os baianos votem em ACM Neto para o governo estadual.</segment>
    <segment id="120">"</segment>
    <segment id="121">O PT significa a destruição dos lares brasileiros".</segment>
    <segment id="122">Na plateia</segment>
    <segment id="123">, gritos contra Lula eram constantes.</segment>
    <segment id="124">Ele ainda chamou o petista de "bandido".</segment>
    <segment id="125">"</segment>
    <segment id="126">Não é isso que eu quero para o Brasil</segment>
    <segment id="127">, Lula é um picareta.</segment>
    <segment id="128">Vai plantar batata</segment>
    <segment id="129">, Lula!</segment>
    <segment id="130">"</segment>
    <segment id="131">Lula e Bolsonaro em campanha no 2º turnoMais</segment>
    <segment id="132">novamente         de   de  de  representando um</segment>
  </rst>
</analysis>