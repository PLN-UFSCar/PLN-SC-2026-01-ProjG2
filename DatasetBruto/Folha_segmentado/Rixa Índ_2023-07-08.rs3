  <rst>
    <segment id="1">O caso</segment>
    <segment id="2">caso de amor por meio de uma das fronteiras mais protegidas do mundo começou em batalha virtuais de um game em que jogadores</segment>
    <segment id="3">sese ajudam contra emboscadas sangrentas para sobreviverem.</segment>
    <segment id="4">Mas quando Seema Ghulam Haider</segment>
    <segment id="5">, 27, uma muçulmana paquistanesa casada</segment>
    <segment id="6">, foi para a Índia com seus quatro filhos para ficar com Sachin Meena</segment>
    <segment id="7">, 22, um homem hindu</segment>
    <segment id="8">, o período juntos foi breve.</segment>
    <segment id="9">Dois meses após começar a viver no mesmo bairro perto de Nova Déli</segment>
    <segment id="10">, o casal</segment>
    <segment id="11">sese viu diante das autoridades indianas.</segment>
    <segment id="12">Cerimônia militar no posto fronteiriço de Attari-Wagah</segment>
    <segment id="13">, entre Índia e Paquistão - Atul Loke - 7.ago.22/The New York Times  Nesta semana</segment>
    <segment id="14">, Haider e seus filhos foram presos</segment>
    <segment id="15">, acusados de terem entrado ilegalmente na Índia</segment>
    <segment id="16">; Meena e seu pai também foram detidos</segment>
    <segment id="17">, sob acusações que equivalem a conspirar para abrigar um inimigo.</segment>
    <segment id="18">"</segment>
    <segment id="19">Não quero voltar"</segment>
    <segment id="20">, disse ela a repórteres enquanto era levada pela polícia</segment>
    <segment id="21">, com seus filhos confusos ao lado.</segment>
    <segment id="22">"</segment>
    <segment id="23">Quero me casar com Sachin.</segment>
    <segment id="24">Eu o amo muito.</segment>
    <segment id="25">Deixei tudo por ele.</segment>
    <segment id="26">"</segment>
    <segment id="27">Meena também declarou seu amor.</segment>
    <segment id="28">"</segment>
    <segment id="29">Só queremos que o governo nos deixe casar e construir uma família"</segment>
    <segment id="30">, disse ele enquanto era detido.</segment>
    <segment id="31">Lá foraReceba no seu email uma seleção semanal com o que de mais importante aconteceu no mundo</segment>
    <segment id="32">; aberta para não assinantes.</segment>
    <segment id="33">Carregando...</segment>
    <segment id="34">Entre os obstáculos que os amantes enfrentam</segment>
    <segment id="35">, talvez o maior seja a rivalidade entre as respectivas terras natais.</segment>
    <segment id="36">A Índia e o Paquistão –país que foi separado da Índia em 1947</segment>
    <segment id="37">comocomo último ato do domínio britânico– travaram muitas guerras.</segment>
    <segment id="38">A tensão é tão grande que até mesmo pombos que cruzaram a fronteira acabaram detidos sob a acusação de espionagem.</segment>
    <segment id="39">Conseguir um visto é</segment>
    <segment id="40">comocomo ganhar na loteria.</segment>
    <segment id="41">As relações interreligiosas nos países</segment>
    <segment id="42">sese tornaram um campo minado.</segment>
    <segment id="43">No Paquistão</segment>
    <segment id="44">, onde o extremismo islâmico está arraigado</segment>
    <segment id="45">, surgem relatos frequentes de meninas de minorias religiosas</segment>
    <segment id="46">, principalmente hindus</segment>
    <segment id="47">, casadas ainda jovens e convertidas à força ao islamismo</segment>
    <segment id="48">, segundo grupos de direitos humanos.</segment>
    <segment id="49">Na Índia</segment>
    <segment id="50">, um poderoso movimento de direita hindu condena qualquer relação interreligiosa entre um muçulmano e um hindu</segment>
    <segment id="51">, chamando essas uniões de "jihad do amor"</segment>
    <segment id="52">, ou uma tentativa de muçulmanos perseguirem mulheres hindus com a intenção de convertê-las ao islamismo.</segment>
    <segment id="53">Essa acusação tornou-</segment>
    <segment id="54">sese parte de uma demonização maior dos 200 milhões de muçulmanos do país.</segment>
    <segment id="55">Caxemira passou por turbulência em 2019Mais    novamente         de   de  de  representando um    Haider e Meena</segment>
    <segment id="56">sese conheceram em 2019 no jogo "Playerunknown's Battlegrounds"</segment>
    <segment id="57">, ou PUBG.</segment>
    <segment id="58">Eles passaram a</segment>
    <segment id="59">sese comunicar por Instagram e WhatsApp em 2020.</segment>
    <segment id="60">"</segment>
    <segment id="61">Os dois ficaram mais próximos</segment>
    <segment id="62">, então surgiu o desejo de</segment>
    <segment id="63">sese encontrarem"</segment>
    <segment id="64">, disse a polícia indiana em um comunicado.</segment>
    <segment id="65">Haider morava em Karachi</segment>
    <segment id="66">, onde teve quatro filhos com Ghulam Haider.</segment>
    <segment id="67">O romance transfronteiriço com Meena</segment>
    <segment id="68">parece ter começado depois que o marido de Haider</segment>
    <segment id="69">, com quem ela</segment>
    <segment id="70">sese casou em 2014</segment>
    <segment id="71">, mudou-</segment>
    <segment id="72">sese para a Arábia Saudita para trabalhar</segment>
    <segment id="73">, de acordo com a polícia e seu sogro.</segment>
    <segment id="74">"</segment>
    <segment id="75">Sachin costumava falar com alguém tarde da noite"</segment>
    <segment id="76">, disse Birbal Meena</segment>
    <segment id="77">, seu tio</segment>
    <segment id="78">, que vivia com o sobrinho e a família numa casa compartilhada em Rabupura</segment>
    <segment id="79">, cidade a cerca de 65 km a sudeste de Nova Déli.</segment>
    <segment id="80">Inicialmente</segment>
    <segment id="81">, Meena desviou de perguntas sobre seus telefonemas.</segment>
    <segment id="82">"</segment>
    <segment id="83">Então ele confessou que estava apaixonado por uma paquistanesa e que pretendia</segment>
    <segment id="84">sese casar com ela"</segment>
    <segment id="85">, disse seu tio.</segment>
    <segment id="86">"</segment>
    <segment id="87">Ele também disse que a mulher tinha quatro filhos e que seu marido a abandonou.</segment>
    <segment id="88">"</segment>
    <segment id="89">"</segment>
    <segment id="90">Nós perguntamos a ele</segment>
    <segment id="91">comocomo poderia trazer uma mulher de um país inimigo.</segment>
    <segment id="92">O avô de Sachin implorou: 'Por favor</segment>
    <segment id="93">, não faça isso'.</segment>
    <segment id="94">"</segment>
    <segment id="95">Com quase quatro anos de relacionamento a distância</segment>
    <segment id="96">, o casal</segment>
    <segment id="97">sese encontrou pela primeira vez em março</segment>
    <segment id="98">, no Nepal.</segment>
    <segment id="99">Eles ficaram num hotel em Katmandu durante uma semana.</segment>
    <segment id="100">Então ela voltou para o Paquistão</segment>
    <segment id="101">, e ele</segment>
    <segment id="102">, para a Índia</segment>
    <segment id="103">, com a promessa de que</segment>
    <segment id="104">sese reuniriam</segment>
    <segment id="105">, cruzando a fronteira porosa entre a Índia e o Nepal.</segment>
    <segment id="106">Muçulmanos na Índia protestam contra governo ModiMais    novamente         de   de  de  representando um</segment>
    <segment id="107">Como eles planejaram sua rota para Haider finalmente chegar à Índia</segment>
    <segment id="108">, com as crianças a reboque?</segment>
    <segment id="109">"</segment>
    <segment id="110">Pesquisando no YouTube"</segment>
    <segment id="111">, disseram ambos aos repórteres quando foram presos.</segment>
    <segment id="112">Na segunda vez que Haider partiu para o Nepal</segment>
    <segment id="113">, em maio</segment>
    <segment id="114">, ela levou os filhos –e não tinha intenção de voltar.</segment>
    <segment id="115">Sem o conhecimento de seu marido</segment>
    <segment id="116">, que ainda mora na Arábia Saudita</segment>
    <segment id="117">, Haider vendeu sua casa para financiar a viagem</segment>
    <segment id="118">, disse Mir Jan Jhakrani</segment>
    <segment id="119">, seu sogro.</segment>
    <segment id="120">"</segment>
    <segment id="121">De repente</segment>
    <segment id="122">, vi nas redes sociais a notícia de que o governo indiano a havia prendido"</segment>
    <segment id="123">, disse Jhakrani.</segment>
    <segment id="124">O casal pode enfrentar vários anos de prisão</segment>
    <segment id="125">, provavelmente seguidos pela deportação de Haider.</segment>
    <segment id="126">Policiais disseram que seu interrogatório mostrou que Meena</segment>
    <segment id="127">, que ganhava cerca de US$ 100 (R$ 488) por mês em uma loja de bairro</segment>
    <segment id="128">, não havia inflado sua história ou enganado Haider com promessas falsas.</segment>
    <segment id="129">"</segment>
    <segment id="130">Ela sabia que ele não tinha dinheiro"</segment>
    <segment id="131">, disse Sudhir Kumar</segment>
    <segment id="132">, chefe da delegacia de polícia de Rabupura.</segment>
    <segment id="133">"</segment>
    <segment id="134">Ela não ficou impressionada com o trabalho dele</segment>
    <segment id="135">, masmas com suas habilidades no PUBG.</segment>
    <segment id="136">"</segment>
  </rst>
</analysis>