  <rst>
    <segment id="1">João Silva</segment>
    <segment id="2">, filho do apresentador Faustão</segment>
    <segment id="3">, está negociando com a Band um programa na emissora após seu pai ter</segment>
    <segment id="4">sese despedido do canal em agosto.</segment>
    <segment id="5">Embora estejam conversando</segment>
    <segment id="6">, as partes ainda não chegaram a um acordo nem assinaram contrato.</segment>
    <segment id="7">De junho a agosto</segment>
    <segment id="8">, João Silva e Anne Lottermann apresentaram sozinhos o programa de Faustão na Band após o apresentador ter deixado o canal</segment>
    <segment id="9">, em maio.</segment>
    <segment id="10">João Guilherme Silva - Rodrigo Moraes 24.jan.2022/BandNo entanto</segment>
    <segment id="11">, ele voltou em 18 de agosto para apresentar a despedida da atração</segment>
    <segment id="12">, que estreou em janeiro de 2022.</segment>
    <segment id="13">Apesar de ter rendido boa audiência do começo</segment>
    <segment id="14">, o programa viu o índice desabar ao longo dos meses que esteve no ar.</segment>
    <segment id="15">No último programa</segment>
    <segment id="16">, Faustão reuniu todos os seus filhos.</segment>
    <segment id="17">Além de João</segment>
    <segment id="18">, estiveram presentes</segment>
    <segment id="19">Lara e Rodrigo.</segment>
    <segment id="20">Este é João Guilherme Silva</segment>
    <segment id="21">Mais    novamente         de   de  de  representando um</segment>
    <segment id="22">O programa foi gravado antes da internação do apresentador</segment>
    <segment id="23">, hospitalizado no último dia 5 no Albert Einstein</segment>
    <segment id="24">, em São Paulo</segment>
    <segment id="25">, para tratar um quadro de insuficiência cardíaca</segment>
    <segment id="26">, segundo uma nota divulgada pelos médicos que cuidam de Faustão.</segment>
    <segment id="27">Por essa razão</segment>
    <segment id="28">, precisou ser submetido a um transplante de coração.</segment>
    <segment id="29">Faustão no momento</segment>
    <segment id="30">sese recupera da cirurgia em uma UTI.</segment>
    <segment id="31">De acordo com os médicos</segment>
    <segment id="32">, o novo órgão está funcionando</segment>
    <segment id="33">comocomo o esperado e o apresentador passa bem.</segment>
  </rst>
