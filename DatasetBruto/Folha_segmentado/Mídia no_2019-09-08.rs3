  <rst>
    <segment id="1">A primeira página de sábado (7) da Folha</segment>
    <segment id="2">, com a cena da história em quadrinhos "</segment>
    <segment id="3">Vingadores - A Cruzada das Crianças" que foi alvo do prefeito do Rio</segment>
    <segment id="4">, Marcelo Crivella</segment>
    <segment id="5">, surgiu na home page do britânico The Guardian neste domingo (acima)</segment>
    <segment id="6">, entre outros no exterior.</segment>
    <segment id="7">O "beijo gay</segment>
    <segment id="8">" na capa foi também noticiado e reproduzido por veículos da França aos EUA e ao Peru —e em especial na vizinha Argentina</segment>
    <segment id="9">, por jornais</segment>
    <segment id="10">comocomo Clarín e Página/12.</segment>
    <segment id="11">O site da revista LGBT americana de maior alcance</segment>
    <segment id="12">, Out, reproduzido abaixo</segment>
    <segment id="13">, abriu seu relato afirmando que "o maior jornal do Brasil</segment>
    <segment id="14">sese posicionou contra a censura imprimindo uma foto do beijo proibido na primeira página".</segment>
    <segment id="15">PS 9/9</segment>
    <segment id="16">, 17h - A repercussão prossegue por Washington Post</segment>
    <segment id="17">, Newsweek</segment>
    <segment id="18">, Independent</segment>
    <segment id="19">, The Wire</segment>
    <segment id="20">, The Free Thinker  PS 10/9</segment>
    <segment id="21">, 18h30 - E por CNN</segment>
    <segment id="22">, inclusive via Instagram</segment>
    <segment id="23">, Le Monde</segment>
    <segment id="24">, El País</segment>
    <segment id="25">, Guacamoley  De maneira geral</segment>
    <segment id="26">, o noticiário sobre a tentativa de censura no Rio ecoou ao longo do fim de semana por sites</segment>
    <segment id="27">comocomo Hollywood Reporter e sob títulos</segment>
    <segment id="28">comocomo</segment>
    <segment id="29">, no New York Times</segment>
    <segment id="30">, "</segment>
    <segment id="31">Dois homens</segment>
    <segment id="32">sese beijam numa história em quadrinhos</segment>
    <segment id="33">, e um prefeito ordena batida policial".</segment>
    <segment id="34">Na CNN</segment>
    <segment id="35">, "</segment>
    <segment id="36">Prefeito do Rio tentou banir livro com beijo entre dois super-heróis homens.</segment>
