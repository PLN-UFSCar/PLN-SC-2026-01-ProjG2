  <rst>
    <segment id="1">Os candidatos à Presidência Ciro Gomes (PDT)</segment>
    <segment id="2">, Simone Tebet (MDB) e Jair Bolsonaro (PL) foram sabatinados pela Jovem Pan.</segment>
    <segment id="3">Os dois primeiros foram entrevistados no final de agosto</segment>
    <segment id="4">, e a sabatina do atual presidente</segment>
    <segment id="5">, que seria no último dia 29</segment>
    <segment id="6">, foi adiada para esta terça (6) devido ao debate na TV Band.</segment>
    <segment id="7">Lula (PT) foi convidado</segment>
    <segment id="8">, masmas não compareceu.</segment>
    <segment id="9">A Lupa checou declarações dos candidatos.    JAIR BOLSONARO (PL)  Outros falavam que apertavam 1 [na urna]</segment>
    <segment id="10">, aparecia a cara do Haddad e acabava a votaçãoJair Bolsonaro (PL)presidente e candidato à reeleição</segment>
    <segment id="11">, em entrevista à Jovem Pan em 6 de setembro de 2022FALSO</segment>
    <segment id="12">Bolsonaro refere-</segment>
    <segment id="13">sese a um vídeo manipulado que foi divulgado nas redes sociais no dia do primeiro turno das eleições em 2018.</segment>
    <segment id="14">A gravação foi desmentida pela Lupa na mesma data.</segment>
    <segment id="15">Na época</segment>
    <segment id="16">, foi possível detectar que houve uma montagem para parecer que a urna eletrônica tinha sido fraudada.</segment>
    <segment id="17">O Tribunal Regional Eleitoral de Minas Gerais (TRE-MG) publicou um vídeo mostrando</segment>
    <segment id="18">comocomo foi feita a edição.</segment>
    <segment id="19">Inicialmente</segment>
    <segment id="20">, a gravação mostra apenas a tela da urna.</segment>
    <segment id="21">Uma mão aperta um botão fora de quadro</segment>
    <segment id="22">, e o nome de Fernando Haddad (PT) aparece.</segment>
    <segment id="23">O programa de edição mostra que há dois sons de cliques distintos</segment>
    <segment id="24">, ou seja</segment>
    <segment id="25">, duas pessoas apertam as teclas praticamente ao mesmo tempo.</segment>
    <segment id="26">Posteriormente</segment>
    <segment id="27">, a gravação mostra o teclado inteiro.</segment>
    <segment id="28">Nesse trecho</segment>
    <segment id="29">, há indícios de que o vídeo que aparece na tela foi plantado.</segment>
    <segment id="30">Por fim</segment>
    <segment id="31">, há um corte de edição no final do registro.</segment>
    <segment id="32">Em nota</segment>
    <segment id="33">, o TRE-MG confirmou que o vídeo é falso.</segment>
    <segment id="34">"</segment>
    <segment id="35">Não existe a possibilidade de a urna autocompletar o voto do eleitor</segment>
    <segment id="36">, e isso pode ser comprovado pela auditoria de votação paralela"</segment>
    <segment id="37">, afirmou o tribunal.</segment>
    <segment id="38">Você vê a gasolina</segment>
    <segment id="39">, na maioria dos estados</segment>
    <segment id="40">, abaixo de R$ 5Jair Bolsonaro (PL)presidente e candidato à reeleição</segment>
    <segment id="41">, em entrevista à Jovem Pan em 6 de setembro de 2022FALSO</segment>
    <segment id="42">O preço médio de revenda da gasolina comum está abaixo dos R$ 5 em apenas 4 estados:</segment>
    <segment id="43">Amapá (R$ 4</segment>
    <segment id="44">,84), Sergipe (R$ 4</segment>
    <segment id="45">,91), Goiás (R$ 4</segment>
    <segment id="46">,97) e Rio Grande do Sul (R$ 4</segment>
    <segment id="47">,99).</segment>
    <segment id="48">Em outros 22 estados e no Distrito Federal</segment>
    <segment id="49">, o valor médio varia de R$ 5</segment>
    <segment id="50">,02 (no Mato Grosso do Sul) a R$ 5</segment>
    <segment id="51">,72 (no Acre).</segment>
    <segment id="52">Nacionalmente</segment>
    <segment id="53">, o preço médio da gasolina comum é de R$ 5</segment>
    <segment id="54">,17.</segment>
    <segment id="55">Os dados são do relatório mais recente da Agência Nacional de Petróleo</segment>
    <segment id="56">, Gás Natural e Biocombustíveis (ANP)</segment>
    <segment id="57">, que pesquisou o preço do combustível em 5.500 postos pelo país entre 28 de agosto e 3 de setembro.</segment>
    <segment id="58">Eleições</segment>
    <segment id="59">2022Um resumo com o que de mais importante a Folha destaca sobre a eleiçãoCarregando...</segment>
    <segment id="60">As propostas de manter zerados impostos federais da gasolina</segment>
    <segment id="61">, álcool</segment>
    <segment id="62">, diesel e gás já estão na peça orçamentáriaJair Bolsonaro (PL)presidente e candidato à reeleição</segment>
    <segment id="63">, em entrevista à Jovem Pan em 6 de setembro de 2022VERDADEIRO</segment>
    <segment id="64">A Proposta de Lei Orçamentária (Ploa) para 2023 prevê a continuidade das medidas que zeraram a incidência de PIS/Cofins sobre gasolina</segment>
    <segment id="65">, etanol</segment>
    <segment id="66">, gás natural</segment>
    <segment id="67">, óleo diesel</segment>
    <segment id="68">, biodiesel</segment>
    <segment id="69">, gás liquefeito de petróleo</segment>
    <segment id="70">, derivado de petróleo e de gás natural e querosene de aviação.</segment>
    <segment id="71">As leis complementares 192/2022 e 194/2022 suspenderam a cobrança dessas contribuições</segment>
    <segment id="72">, masmas só até o final do ano.</segment>
    <segment id="73">As medidas também suspenderam temporariamente a cobrança da Cide para gasolina</segment>
    <segment id="74">, etanol e gás natural —outros combustíveis já eram isentos desde 2018.</segment>
    <segment id="75">A mensagem presidencial encaminhada ao Congresso estima que essas desonerações terão impacto de R$ 52</segment>
    <segment id="76">,9 bilhões (página 22).</segment>
    <segment id="77">A Simone Tebet fala há alguns anos que precisava do voto impressoJair Bolsonaro (PL)presidente e candidato à reeleição</segment>
    <segment id="78">, em entrevista à Jovem Pan em 6 de setembro de 2022VERDADEIRO</segment>
    <segment id="79">, MAS  Em 2015</segment>
    <segment id="80">, em entrevista à TV Senado</segment>
    <segment id="81">, a senadora Tebet (MDB) questionou</segment>
    <segment id="82">sese os votos depositados na urna eletrônica realmente eram processados de maneira correta.</segment>
    <segment id="83">Em 2018</segment>
    <segment id="84">, durante audiência pública sobre a implantação do voto impresso</segment>
    <segment id="85">, ela disse que</segment>
    <segment id="86">, particularmente</segment>
    <segment id="87">, "confiava na urna eletrônica"</segment>
    <segment id="88">, masmas</segment>
    <segment id="89">sese preocupava com a possibilidade de um algoritmo alterar o resultado na transmissão de resultados.</segment>
    <segment id="90">Porém, a própria candidata reconheceu</segment>
    <segment id="91">, anos mais tarde</segment>
    <segment id="92">, que não entendia muito sobre o funcionamento das urnas eletrônicas.</segment>
    <segment id="93">Em entrevista recente ao Roda Viva</segment>
    <segment id="94">, da TV Cultura</segment>
    <segment id="95">, realizada em 8 de agosto</segment>
    <segment id="96">, a candidata explicou que</segment>
    <segment id="97">, em 2015</segment>
    <segment id="98">, o Senado estava discutindo uma minirreforma partidária e eleitoral.</segment>
    <segment id="99">"</segment>
    <segment id="100">Ali, queríamos trazer uma segurança para o eleitor</segment>
    <segment id="101">, que tinha um questionamento sobre a segurança das urnas"</segment>
    <segment id="102">, disse.</segment>
    <segment id="103">Na sequência</segment>
    <segment id="104">, reconheceu que</segment>
    <segment id="105">, há sete anos</segment>
    <segment id="106">, ela mesma não sabia que a urna não está ligada à internet.</segment>
    <segment id="107">"</segment>
    <segment id="108">Não sabíamos disso no momento</segment>
    <segment id="109">, faltou um tipo de esclarecimento antes da votação.</segment>
    <segment id="110">"</segment>
    <segment id="111">CIRO GOMES (PDT)</segment>
    <segment id="112">A mais bruta informalidade</segment>
    <segment id="113">, que atingiu 70%</segment>
    <segment id="114">, números redondos</segment>
    <segment id="115">, aproximadamente</segment>
    <segment id="116">, da força de trabalhoCiro Gomes (PDT)candidato à Presidência da República</segment>
    <segment id="117">, em entrevista ao Jornal da Manhã da Jovem Pan no dia 25 de agosto de 2022EXAGERADO</segment>
    <segment id="118">Segundo dados da Pnad</segment>
    <segment id="119">Contínua divulgados em 29 de julho</segment>
    <segment id="120">, 40% da população ocupada está na informalidade.</segment>
    <segment id="121">As cifras são referentes ao trimestre que vai de abril a junho</segment>
    <segment id="122">, os mais recentes disponíveis.</segment>
    <segment id="123">Segundo o relatório</segment>
    <segment id="124">, o total de trabalhadores informais nesse período chegou a 39</segment>
    <segment id="125">,3 milhões</segment>
    <segment id="126">, um recorde da série histórica do indicador</segment>
    <segment id="127">, iniciada em 2015.</segment>
    <segment id="128">A população ocupada no país somou 98</segment>
    <segment id="129">,3 milhões.</segment>
    <segment id="130">Quatro dos dez bancos mais lucrativos do planeta</segment>
    <segment id="131">Terra são brasileirosCiro Gomes (PDT)candidato à Presidência da República</segment>
    <segment id="132">, em entrevista ao Jornal da Manhã da Jovem Pan no dia 25 de agosto de 2022VERDADEIRO</segment>
    <segment id="133">Dados da empresa de análise de dados financeiros</segment>
    <segment id="134">Economatica mostram que</segment>
    <segment id="135">, em 2021</segment>
    <segment id="136">, quatro bancos brasileiros estiveram entre as dez instituições com maior rentabilidade do mundo.</segment>
    <segment id="137">São eles:</segment>
    <segment id="138">Santander no Brasil (3° lugar</segment>
    <segment id="139">, com rentabilidade sobre patrimônio de 18</segment>
    <segment id="140">,9%)</segment>
    <segment id="141">; Itaú Unibanco (5° lugar</segment>
    <segment id="142">, com rentabilidade sobre patrimônio de 17</segment>
    <segment id="143">,3%);</segment>
    <segment id="144">Banco do Brasil (7° lugar</segment>
    <segment id="145">, com rentabilidade sobre patrimônio de 15</segment>
    <segment id="146">,7%) e Bradesco (8° lugar</segment>
    <segment id="147">, com rentabilidade sobre patrimônio de 15</segment>
    <segment id="148">,2%).</segment>
    <segment id="149">Para o ranking</segment>
    <segment id="150">, o estudo considerou o percentual do retorno sobre o patrimônio (ROE) de cada instituição.</segment>
    <segment id="151">Ou seja</segment>
    <segment id="152">, comparou</segment>
    <segment id="153">, em porcentagem</segment>
    <segment id="154">, a capacidade que cada banco tem para gerar valor –tanto para a empresa</segment>
    <segment id="155">comocomo para investidores– com base nos recursos que possui.</segment>
    <segment id="156">Veja as fotos dos presidenciáveis que serão exibidas nas urnasMais    novamente         de   de  de  representando um  SIMONE TEBET (MDB)  Fui a primeira mulher a presidir a comissão mais importante do Congresso Nacional</segment>
    <segment id="157">, que é onde mexe com as emendas constitucionais [a Comissão de Constituição e Justiça do Senado]Simone Tebet (MDB)candidata à Presidência da República</segment>
    <segment id="158">, em entrevista no Jornal da Manhã</segment>
    <segment id="159">, da Jovem Pan</segment>
    <segment id="160">, no dia 26 de agosto de 2022VERDADEIRO</segment>
    <segment id="161">Considerando os ocupantes do cargo desde 1935</segment>
    <segment id="162">, Tebet foi a 31ª senadora a assumir a presidência da Comissão de Constituição e Justiça (CCJ)</segment>
    <segment id="163">, no biênio de 2019 e 2020.</segment>
    <segment id="164">Todos os outros 30 antecessores eram homens —assim</segment>
    <segment id="165">comocomo o atual presidente</segment>
    <segment id="166">, Davi Alcolumbre (União Brasil-AP).</segment>
    <segment id="167">A CCJ do Senado é responsável por dar parecer a todas as propostas de emenda à Constituição que tramitam na Casa</segment>
    <segment id="168">, assim</segment>
    <segment id="169">comocomo analisar a constitucionalidade de projetos de lei ordinária</segment>
    <segment id="170">, e é considerada uma das mais importantes do Congresso.</segment>
    <segment id="171">É o agricultor familiar que coloca quase 70% do feijão que nós comemos na mesaSimone Tebet (MDB)candidata à Presidência da República</segment>
    <segment id="172">, em entrevista no Jornal da Manhã</segment>
    <segment id="173">, da Jovem Pan</segment>
    <segment id="174">, no dia 26 de agosto de 2022EXAGERADO</segment>
    <segment id="175">De acordo com o último Censo Agropecuário</segment>
    <segment id="176">, feito em 2017 e 2018 pelo Instituto Brasileiro de Geografia e Estatística (IBGE)</segment>
    <segment id="177">, a agricultura familiar é responsável por 42% da produção de feijão no Brasil</segment>
    <segment id="178">, não 70%</segment>
    <segment id="179">, como</segment>
    <segment id="180">como afirmou a candidata.</segment>
    <segment id="181">Até 2006</segment>
    <segment id="182">, esse dado era correto.</segment>
    <segment id="183">No Censo daquele ano</segment>
    <segment id="184">, a participação da agricultura familiar na produção desse alimento representava 70%</segment>
    <segment id="185">, sendo 77% do feijão-preto</segment>
    <segment id="186">, 84% do feijão-fradinho</segment>
    <segment id="187">, caupi</segment>
    <segment id="188">, de corda ou macáçar e 54% do feijão de cor (página 20).</segment>
    <segment id="189">Entre 2006 e 2017</segment>
    <segment id="190">, porém</segment>
    <segment id="191">porém, houve redução de 9</segment>
    <segment id="192">,5% no número de estabelecimentos classificados de agricultura familiar.</segment>
    <segment id="193">A quantidade desse tipo de grão produzida pelas famílias acompanhou a queda.</segment>
    <segment id="194">Embora a Confederação Nacional de Agricultura Familiar (Conafer) divulgue o dado de 70% da produção da leguminosa</segment>
    <segment id="195">comocomo sendo atual</segment>
    <segment id="196">, a entidade baseia-</segment>
    <segment id="197">sese em um relatório antigo do Programa Nacional de Fortalecimento da Agricultura Familiar (Pronaf).</segment>
    <segment id="198">O documento</segment>
    <segment id="199">, publicado em janeiro de 2020 pela Controladoria Geral da União</segment>
    <segment id="200">, usou</segment>
    <segment id="201">comocomo referência o Censo Agropecuário de 2006.</segment>
    <segment id="202">Isso porque</segment>
    <segment id="203">porque</segment>
    <segment id="204">, naquela ocasião</segment>
    <segment id="205">, as informações da edição de 2017 do Censo ainda eram preliminares (rodapé da página 6).</segment>
  </rst>
</analysis>