  <rst>
    <segment id="1">Entre os destaques do ano da Malê</segment>
    <segment id="2">, editora que</segment>
    <segment id="3">sese dedica a jogar luz sobre autores negros de talento</segment>
    <segment id="4">, estão dois livros do mais recente vencedor do prêmio Goncourt</segment>
    <segment id="5">, o senegalês Mohamed Mbougar Sarr.</segment>
    <segment id="6">Primeiro escritor da África subsaariana a ganhar o mais prestigioso prêmio francófono</segment>
    <segment id="7">, o autor de 31 anos já tem o seu "Homens de Verdade" disponível nas lojas e até o fim do ano também traz "Terre Ceinte"</segment>
    <segment id="8">, algo</segment>
    <segment id="9">comocomo terra cingida.</segment>
    <segment id="10">O romancista Mohamed Mbougar Sarr</segment>
    <segment id="11">, após vencer o Goncourt - AFPJá o livro pelo qual Sarr ganhou o Goncourt</segment>
    <segment id="12">, "La Plus Secrète Mémoire des Hommes"</segment>
    <segment id="13">, ou a memória mais secreta dos homens</segment>
    <segment id="14">, vai sair pela Fósforo no ano que vem.</segment>
    <segment id="15">Esse tipo de bola dividida é normal para editoras independentes que projetam autores de qualidade.</segment>
    <segment id="16">Por exemplo</segment>
    <segment id="17">, outras apostas do ano da Malê são no compositor Martinho da Vila</segment>
    <segment id="18">, que também tem livros em outras casas</segment>
    <segment id="19">, e no volume de contos "</segment>
    <segment id="20">A Vestida"</segment>
    <segment id="21">, de Eliana Alves Cruz</segment>
    <segment id="22">, que acaba de lançar "Solitária" pela Companhia das Letras.</segment>
    <segment id="23">"</segment>
    <segment id="24">Quando comecei a Malê</segment>
    <segment id="25">, publicava autores desacreditados pelo mercado.</segment>
    <segment id="26">Hoje, esses autores estão disputados pelo mesmo mercado"</segment>
    <segment id="27">, diz o editor Vagner Amaro.</segment>
    <segment id="28">Ele não vê isso</segment>
    <segment id="29">comocomo um problema</segment>
    <segment id="30">, pelo contrário.</segment>
    <segment id="31">"</segment>
    <segment id="32">Um dos motivos de criar a editora foi fazer com que as grandes olhassem para esses autores.</segment>
    <segment id="33">"</segment>
    <segment id="34">Segundo ele</segment>
    <segment id="35">, quando uma autora</segment>
    <segment id="36">comocomo Alves Cruz publica um livro na Companhia</segment>
    <segment id="37">, a visibilidade gera mais interesse por suas obras anteriores.</segment>
    <segment id="38">A escritora Conceição Evaristo - Marcus Leoni - 3.out.2018/FolhapressÉ algo que Cristina Warth</segment>
    <segment id="39">, dona da Pallas</segment>
    <segment id="40">, também observa.</segment>
    <segment id="41">Quando a editora lançou "</segment>
    <segment id="42">Olhos d’Água" há oito anos</segment>
    <segment id="43">, Conceição Evaristo não era um nome amplamente conhecido</segment>
    <segment id="44">, apesar da longa carreira literária.</segment>
    <segment id="45">Hoje a obra tem status de clássico e</segment>
    <segment id="46">, quando sair o inédito "</segment>
    <segment id="47">Canção para Ninar Menino Grande"</segment>
    <segment id="48">, no segundo semestre</segment>
    <segment id="49">, será recebido</segment>
    <segment id="50">comocomo lançamento de uma das maiores autoras brasileiras.  "</segment>
    <segment id="51">Vejo com bons olhos outras editoras editarem autores negros</segment>
    <segment id="52">, estão tendo senso de oportunidade"</segment>
    <segment id="53">, diz Warth</segment>
    <segment id="54">, que comanda uma casa fundada em 1974.</segment>
    <segment id="55">"</segment>
    <segment id="56">Mas isso é um reconhecimento batalhado pela intelectualidade negra e relacionado a política de cotas.</segment>
    <segment id="57">A obrigação de falar de questões afro-brasileiras é uma conquista do movimento social.</segment>
    <segment id="58">"</segment>
    <segment id="59">Veja ilustrações da nova edição de &amp;#</segment>
    <segment id="60">039;O Cortiço&amp;#039</segment>
    <segment id="61">;Mais    novamente         de   de  de  representando um  FLOR DA PRIMEIRA</segment>
    <segment id="62">MÚSICA</segment>
    <segment id="63">A Companhia das Letras</segment>
    <segment id="64">, aliás</segment>
    <segment id="65">, tem duas boas apostas em autoras brasileiras em junho.</segment>
    <segment id="66">Primeiro</segment>
    <segment id="67">, Jarid Arraes prepara sua estreia nos romances após incursões bem-sucedidas</segment>
    <segment id="68">comocomo contista em "Redemoinho em Dia</segment>
    <segment id="69">Quente</segment>
    <segment id="70">"</segment>
    <segment id="71">, vencedor do prêmio da Biblioteca Nacional</segment>
    <segment id="72">, e poeta em "</segment>
    <segment id="73">Um Buraco com Meu Nome".</segment>
    <segment id="74">"</segment>
    <segment id="75">Corpo Desfeito"</segment>
    <segment id="76">, sobre uma teia de traumas numa família de mulheres</segment>
    <segment id="77">, sai com selo da Alfaguara.</segment>
    <segment id="78">SOMBRA DA VOZ DA MATRIARCA</segment>
    <segment id="79">E a carioca Juliana Leite</segment>
    <segment id="80">, que venceu o prêmio Sesc e o APCA por seu livro de estreia —"</segment>
    <segment id="81">Entre as Mãos"</segment>
    <segment id="82">, da Record—</segment>
    <segment id="83">, publica agora "Humanos Exemplares"</segment>
    <segment id="84">, história de uma mulher idosa que perde todos os amigos conforme envelhece sozinha —as memórias deles</segment>
    <segment id="85">sese tornam companhias invisíveis em sua casa vazia.</segment>
    <segment id="86">SOBRE OS AUTOMÓVEIS DE ROMA</segment>
    <segment id="87">Nos próximos meses</segment>
    <segment id="88">, a editora 34 traz primeiras edições brasileiras de duas obras de não ficção de autores essenciais.</segment>
    <segment id="89">No ensaio "</segment>
    <segment id="90">A Cidade das Colunas"</segment>
    <segment id="91">, o cubano Alejo</segment>
    <segment id="92">Carpentier analisa a capital de seu país</segment>
    <segment id="93">, Havana</segment>
    <segment id="94">, com tradução de Samuel Titan.</segment>
    <segment id="95">E a coletânea "</segment>
    <segment id="96">Somos Todos Canibais" reúne crônicas do antropólogo Claude Lévi-Strauss para o jornal italiano La Repubblica</segment>
    <segment id="97">, em tradução de Marília Scalzo.</segment>
  </rst>
</analysis>