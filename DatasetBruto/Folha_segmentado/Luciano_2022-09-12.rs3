  <rst>
    <segment id="1">Luciano Huck participará do Brazil</segment>
    <segment id="2">Climate Summit</segment>
    <segment id="3">, evento organizado por alunos e ex-alunos da Universidade Columbia</segment>
    <segment id="4">, em Nova York</segment>
    <segment id="5">, que será realizado na próxima quinta (15) e sexta (16).</segment>
    <segment id="6">O apresentador estará no painel "</segment>
    <segment id="7">Brazil</segment>
    <segment id="8">'s Green Identity" para debater</segment>
    <segment id="9">comocomo o país e a Amazônia podem</segment>
    <segment id="10">sese tornar um hub de oportunidades em negócios sustentáveis.</segment>
    <segment id="11">Imagens do apresentador Luciano HuckMais    novamente         de   de  de  representando um  Também vão participar da discussão as ativistas Samela Sateré Mawé e Kamila Camilo e o editor-chefe da revista Americas Quarterly</segment>
    <segment id="12">, Brian Winter.</segment>
    <segment id="13">ESTANTE</segment>
    <segment id="14">Lançamento do livro &amp;#039</segment>
    <segment id="15">;Newton&amp;#039</segment>
    <segment id="16">; do advogado Luís Francisco Carvalho FilhoMais    novamente         de   de  de  representando um</segment>
    <segment id="17">O advogado Luís Francisco Carvalho Filho recebeu convidados para o lançamento de seu livro "Newton" na Livraria Megafauna</segment>
    <segment id="18">, no centro de São Paulo</segment>
    <segment id="19">, no sábado (10).</segment>
    <segment id="20">Entre os presentes estavam o escritor Marcelo Rubens Paiva</segment>
    <segment id="21">, o apresentador Marcelo Tas</segment>
    <segment id="22">, a diretora Mika Lins</segment>
    <segment id="23">, o presidente do Conselho de Administração do Bradesco</segment>
    <segment id="24">, Luiz Carlos Trabuco</segment>
    <segment id="25">, e sua mulher</segment>
    <segment id="26">, a empresária Lucília Diniz.  com BIANKA VIEIRA</segment>
    <segment id="27">, KARINA MATIAS e MANOELLA SMITH</segment>
