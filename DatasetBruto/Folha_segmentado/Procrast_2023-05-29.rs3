  <rst>
    <segment id="1">Esta é a edição da newsletter FolhaCarreiras desta segunda-feira (29).</segment>
    <segment id="2">Quer recebê-la às segundas-feiras no seu email?</segment>
    <segment id="3">Inscreva-</segment>
    <segment id="4">sese abaixo.</segment>
    <segment id="5">Folha CarreirasReceba no seu email conteúdo para profissionais em início de carreira</segment>
    <segment id="6">, dicas e indicações de estágio e trainee</segment>
    <segment id="7">; aberta para não assinantes.</segment>
    <segment id="8">Carregando...</segment>
    <segment id="9">Sabe quando você planeja fazer uma tarefa importante</segment>
    <segment id="10">, masmas acaba</segment>
    <segment id="11">sese perdendo em sua caixa de emails?</segment>
    <segment id="12">Ou quando</segment>
    <segment id="13">, em vez de realmente trabalhar no conteúdo de uma apresentação</segment>
    <segment id="14">, você passa muito tempo ajustando a aparência dos slides?</segment>
    <segment id="15">Isso tem nome: "procrastiworking".</segment>
    <segment id="16">Significa evitar o trabalho que deveria estar sendo feito</segment>
    <segment id="17">, concentrando-</segment>
    <segment id="18">sese em outras tarefas.</segment>
    <segment id="19">Procrastiworking nem é percebido</segment>
    <segment id="20">comocomo algo ruim</segment>
    <segment id="21">porque</segment>
    <segment id="22">porque a pessoa</segment>
    <segment id="23">sese sente bem em fazer algo que considera</segment>
    <segment id="24">comocomo trabalho</segment>
    <segment id="25">, masmas na verdade está evitando tarefas importantes - Adobe StockO termo foi criado pela designer americana Jessica Hische</segment>
    <segment id="26">, e, muitas vezes</segment>
    <segment id="27">, nem é percebido</segment>
    <segment id="28">comocomo algo ruim.</segment>
    <segment id="29">Por quê?</segment>
    <segment id="30">Ao fazer algo que poderia ser considerado trabalho</segment>
    <segment id="31">, a pessoa acredita estar sendo produtiva e</segment>
    <segment id="32">sese sente bem</segment>
    <segment id="33">, mesmo não sendo o que precisa fazer.</segment>
    <segment id="34">Então, vamos tentar entender.</segment>
    <segment id="35">Por que procrastinamos?</segment>
    <segment id="36">Insegurança em realizar alguma tarefa para a qual não tem tanto conhecimento.</segment>
    <segment id="37">Medo de pedir ajuda para concluir uma tarefa que não sabe</segment>
    <segment id="38">comocomo fazer.    Distrações.</segment>
    <segment id="39">"</segment>
    <segment id="40">Elas já existiam antes</segment>
    <segment id="41">, masmas</segment>
    <segment id="42">, com o trabalho remoto</segment>
    <segment id="43">, surgiram outras.</segment>
    <segment id="44">Celular</segment>
    <segment id="45">, redes sociais</segment>
    <segment id="46">, email</segment>
    <segment id="47">, WhatsApp</segment>
    <segment id="48">, familiares"</segment>
    <segment id="49">, diz Vitor Silverio</segment>
    <segment id="50">, gerente sênior de parcerias estratégicas na consultoria Robert Half.</segment>
    <segment id="51">Falta de supervisão.</segment>
    <segment id="52">Se o gestor não mantém um acompanhamento próximo</segment>
    <segment id="53">, a cobrança é apenas individual.</segment>
    <segment id="54">Sentimentos negativos.</segment>
    <segment id="55">Se a pessoa já fez a tarefa antes e sabe que é desafiadora</segment>
    <segment id="56">, isso gera medo e preocupação.</segment>
    <segment id="57">A atividade pode ser adiada não pela complexidade</segment>
    <segment id="58">, masmas pelo sentimento que traz</segment>
    <segment id="59">, diz Juliana Seidl</segment>
    <segment id="60">, psicóloga e orientadora de carreiras.</segment>
    <segment id="61">Perfeccionismo.</segment>
    <segment id="62">Seidl também cita o perfil do procrastinador perfeccionista.</segment>
    <segment id="63">"</segment>
    <segment id="64">Precisa de todas as condições perfeitas para começar a tarefa</segment>
    <segment id="65">, assim vai sempre adiando"</segment>
    <segment id="66">, explica.</segment>
    <segment id="67">Os efeitos colaterais...   Sentimentos de frustração e incapacidade por não conseguir concluir as tarefas</segment>
    <segment id="68">, o que gera baixa autoestima</segment>
    <segment id="69">, afirma Bruna Garcia</segment>
    <segment id="70">, especialista de carreiras e cocriadora do podcast Foca no Trabalho.</segment>
    <segment id="71">Torna-</segment>
    <segment id="72">sese um ciclo vicioso deixar tudo para depois e acumular outras atividades</segment>
    <segment id="73">, complementa Garcia.</segment>
    <segment id="74">Veja o que já foi assunto na newsletter</segment>
    <segment id="75">FolhaCarreirasQuer ser nômade digital?</segment>
    <segment id="76">Veja o que é precisoSaiba</segment>
    <segment id="77">comocomo lidar com pessoas chatas no trabalhoEstagiário tira férias?</segment>
    <segment id="78">Entenda quais são os direitos da categoriaComo parar de procrastinar no trabalho?</segment>
    <segment id="79">Garcia e Silverio deram algumas dicas</segment>
    <segment id="80">; veja cinco delas:</segment>
    <segment id="81">Use a matriz de Eisenhower para priorizar os afazeres por urgência e importância.</segment>
    <segment id="82">Consiste em dividir as tarefas em quatro quadros distribuídos nesta ordem de prioridade: faça agora</segment>
    <segment id="83">, agende</segment>
    <segment id="84">, delegue e elimine.</segment>
    <segment id="85">Saiba negociar consigo mesmo.</segment>
    <segment id="86">Por exemplo: "vou procrastinar hoje</segment>
    <segment id="87">porque</segment>
    <segment id="88">porque tive um dia atribulado.</segment>
    <segment id="89">Teria que fazer esta atividade</segment>
    <segment id="90">, masmas estou muito cansado e não estou rendendo.</segment>
    <segment id="91">Vou deixar para amanhã".</segment>
    <segment id="92">Identifique o motivo da procrastinação.</segment>
    <segment id="93">É por estar cansado ou por querer uma recompensa mais fácil?</segment>
    <segment id="94">Você pode pensar:</segment>
    <segment id="95">"vou assistir a uma série hoje e faço a tarefa amanhã".</segment>
    <segment id="96">Mas, caso</segment>
    <segment id="97">caso tenha tempo e não esteja cansado</segment>
    <segment id="98">, isso não é o ideal.</segment>
    <segment id="99">Método Pomodoro.</segment>
    <segment id="100">É uma técnica que consiste em dividir o trabalho em períodos de 25 minutos</segment>
    <segment id="101">, intercalando com descansos de cinco minutos.</segment>
    <segment id="102">Peça ajuda a seu time.</segment>
    <segment id="103">Reflita sobre os motivos pelos quais é uma pessoa procrastinadora e esteja aberta a feedbacks e sugestões de melhorias.</segment>
    <segment id="104">O que fazer quando seu chefe é o procrastinador?</segment>
    <segment id="105">A procrastinação de um líder afeta de maneira negativa os funcionários</segment>
    <segment id="106">, segundo um estudo publicado na revista acadêmica Journal of Occupational and Organizational Psychology em 2018.</segment>
    <segment id="107">A pesquisa foi realizada com quase 550 funcionários por pesquisadores britânicos e australianos.</segment>
    <segment id="108">Por quê?</segment>
    <segment id="109">Para Garcia</segment>
    <segment id="110">, o líder que procrastina não delimita prazos.</segment>
    <segment id="111">Os funcionários vão realizando as tarefas conforme é possível.</segment>
    <segment id="112">O que fazer?</segment>
    <segment id="113">Aproveite os momentos de feedbacks com seu chefe para levantar o problema e trazer soluções para a procrastinação.</segment>
    <segment id="114">Se não houver um momento assim</segment>
    <segment id="115">, pense formas de fazer uma conversa acontecer.</segment>
    <segment id="116">Quando a procrastinação está ligada à saúde mental?</segment>
    <segment id="117">Dá um scroll e veja na seção Pergunte ao Especialista.</segment>
    <segment id="118">Pergunte ao Especialista  Espaço para responder dúvidas relacionadas ao Tema da Semana.</segment>
    <segment id="119">Renata Tavolaro</segment>
    <segment id="120">, líder da equipe de psicólogos da orienteme</segment>
    <segment id="121">, plataforma de gestão de saúde corporativa - DivulgaçãoA procrastinação no trabalho está ligada à saúde mental?</segment>
    <segment id="122">"</segment>
    <segment id="123">A procrastinação pode estar ligada a aspectos emocionais e traz</segment>
    <segment id="124">comocomo resultado a ansiedade</segment>
    <segment id="125">, sentimento de culpa</segment>
    <segment id="126">, baixa performance e até vergonha em relação aos outros</segment>
    <segment id="127">, pois</segment>
    <segment id="128">pois a pessoa não consegue cumprir suas responsabilidades.</segment>
    <segment id="129">De forma geral</segment>
    <segment id="130">, o cérebro humano "</segment>
    <segment id="131">sese rende" à procrastinação</segment>
    <segment id="132">porque</segment>
    <segment id="133">porque tem preferência pela recompensa imediata.</segment>
    <segment id="134">Por isso</segment>
    <segment id="135">, tende a lutar com tarefas que prometem vantagens futuras em troca de esforços no presente.</segment>
    <segment id="136">Há muitos estudos que consideram a procrastinação algo normal</segment>
    <segment id="137">, masmas que pode tornar-</segment>
    <segment id="138">sese um problema quando atrapalha o funcionamento normal do dia a dia da pessoa.</segment>
    <segment id="139">A procrastinação crônica pode ser um sinal de dificuldades a nível psicológico.</segment>
    <segment id="140">Vejo muitas pessoas com altos níveis de ansiedade e estresse e que não conseguem performar bem no dia a dia até reconhecerem e trabalharem essas demandas.</segment>
    <segment id="141">Podem existir diversas causas implícitas à procrastinação</segment>
    <segment id="142">, por exemplo: ansiedade em situações sociais</segment>
    <segment id="143">, dificuldade de gestão do tempo</segment>
    <segment id="144">, concentração</segment>
    <segment id="145">, crenças e pensamentos disfuncionais acerca de si próprio e/ou do outro</segment>
    <segment id="146">, falta de motivação</segment>
    <segment id="147">, entre outros.</segment>
    <segment id="148">"</segment>
    <segment id="149">O que fazer nesses casos?</segment>
    <segment id="150">Gerencie suas emoções através do autoconhecimento</segment>
    <segment id="151">; Defina em sua agenda períodos de descanso</segment>
    <segment id="152">;</segment>
    <segment id="153">Crie metas e estabeleça prazos.</segment>
  </rst>
</analysis>