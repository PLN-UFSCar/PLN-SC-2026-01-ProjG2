  <rst>
    <segment id="1">O apoio &amp;agrave</segment>
    <segment id="2">; quarentena</segment>
    <segment id="3">comocomo forma de evitar a dissemina&amp;ccedil</segment>
    <segment id="4">;&amp;atilde</segment>
    <segment id="5">;o do novo coronav&amp;iacute</segment>
    <segment id="6">;rus sofreu uma queda nas duas &amp;uacute</segment>
    <segment id="7">;ltimas semanas</segment>
    <segment id="8">, masmas ainda &amp;eacute</segment>
    <segment id="9">;</segment>
    <segment id="10">majorit&amp;aacute</segment>
    <segment id="11">;ria entre os brasileiros.</segment>
    <segment id="12">Segundo o Datafolha</segment>
    <segment id="13">, s&amp;atilde</segment>
    <segment id="14">;o 68% aqueles que dizem acreditar que ficar em casa para conter o v&amp;iacute</segment>
    <segment id="15">;rus &amp;eacute</segment>
    <segment id="16">;</segment>
    <segment id="17">mais importante</segment>
    <segment id="18">, ainda que isso prejudique a economia e gere desemprego.</segment>
    <segment id="19">No levantamento anterior do instituto</segment>
    <segment id="20">, feito de 1&amp;ordm</segment>
    <segment id="21">; a 3 de abril</segment>
    <segment id="22">, eram 76%.</segment>
    <segment id="23">A pesquisa atual ouviu 1.606 pessoas na sexta (17) e tem margem de erro de tr&amp;ecirc</segment>
    <segment id="24">;s pontos percentuais.</segment>
    <segment id="25">Essa queda n&amp;atilde</segment>
    <segment id="26">;o sese reverteu integralmente em apoio &amp;agrave</segment>
    <segment id="27">;</segment>
    <segment id="28">afirma&amp;ccedil</segment>
    <segment id="29">;&amp;atilde</segment>
    <segment id="30">;o contr&amp;aacute</segment>
    <segment id="31">;ria, de que vale a pena acabar com isolamento social em nome da reativa&amp;ccedil</segment>
    <segment id="32">;&amp;atilde</segment>
    <segment id="33">;o econ&amp;ocirc</segment>
    <segment id="34">;mica.</segment>
    <segment id="35">O &amp;iacute</segment>
    <segment id="36">;ndice dos que concordam com isso oscilou positivamente de 18% para 22%</segment>
    <segment id="37">, enquanto aqueles que n&amp;atilde</segment>
    <segment id="38">;o sabem foram de 6% para 10% no per&amp;iacute</segment>
    <segment id="39">;odo.</segment>
    <segment id="40">O debate</segment>
    <segment id="41">, visto por especialistas tanto em economia</segment>
    <segment id="42">comocomo em sa&amp;uacute</segment>
    <segment id="43">;de como</segment>
    <segment id="44">como desfocado e politizado</segment>
    <segment id="45">, tem pautado pol&amp;ecirc</segment>
    <segment id="46">;micas envolvendo Jair Bolsonaro (sem partido).</segment>
    <segment id="47">Depois de minimizar a gravidade da Covid-19</segment>
    <segment id="48">, a comparando a uma &amp;ldquo</segment>
    <segment id="49">;gripezinha&amp;rdquo</segment>
    <segment id="50">;, o presidente passou a insistir no foco do impacto econ&amp;ocirc</segment>
    <segment id="51">;mico das quarentenas.</segment>
    <segment id="52">No c&amp;aacute</segment>
    <segment id="53">;lculo</segment>
    <segment id="54">, est&amp;aacute</segment>
    <segment id="55">; o temor de que a recess&amp;atilde</segment>
    <segment id="56">;o que provavelmente seguir&amp;aacute</segment>
    <segment id="57">; a emerg&amp;ecirc</segment>
    <segment id="58">;ncia sanit&amp;aacute</segment>
    <segment id="59">;ria do Sars-CoV-2 solape seu apoio em cerca de um ter&amp;ccedil</segment>
    <segment id="60">;o do eleitorado.</segment>
    <segment id="61">Em oposi&amp;ccedil</segment>
    <segment id="62">;&amp;atilde</segment>
    <segment id="63">;o, governadores</segment>
    <segment id="64">comocomo Jo&amp;atilde</segment>
    <segment id="65">;o Doria (PSDB-SP) e Wilson Witzel (PSC-RJ)</segment>
    <segment id="66">, assumiram a linha de seguir as recomenda&amp;ccedil</segment>
    <segment id="67">;&amp;otilde</segment>
    <segment id="68">;es internacionais de sa&amp;uacute</segment>
    <segment id="69">;de, priorizando o isolamento.</segment>
    <segment id="70">O resultado &amp;eacute</segment>
    <segment id="71">; uma queda de bra&amp;ccedil</segment>
    <segment id="72">;o que marca a organiza&amp;ccedil</segment>
    <segment id="73">;&amp;atilde</segment>
    <segment id="74">;o do combate &amp;agrave</segment>
    <segment id="75">; pandemia no Brasil e j&amp;aacute</segment>
    <segment id="76">; deixou v&amp;iacute</segment>
    <segment id="77">;timas pol&amp;iacute</segment>
    <segment id="78">;ticas no caminho.</segment>
    <segment id="79">Luiz Henrique Mandetta perdeu o cargo de ministro da Sa&amp;uacute</segment>
    <segment id="80">;de na quinta (16)</segment>
    <segment id="81">, entre outros motivos</segment>
    <segment id="82">, por n&amp;atilde</segment>
    <segment id="83">;o concordar com as diretrizes de Bolsonaro sobre o isolamento social.</segment>
    <segment id="84">O Supremo Tribunal Federal interveio e decidiu na quarta (15) que os estados e munic&amp;iacute</segment>
    <segment id="85">;pios t&amp;ecirc</segment>
    <segment id="86">;m liberdade para impor as restri&amp;ccedil</segment>
    <segment id="87">;&amp;otilde</segment>
    <segment id="88">;es que decidirem durante a crise.</segment>
    <segment id="89">Isso contrariou o presidente Bolsonaro</segment>
    <segment id="90">, que se</segment>
    <segment id="91">se queixou de estar de m&amp;atilde</segment>
    <segment id="92">;os atadas na quest&amp;atilde</segment>
    <segment id="93">;o.</segment>
    <segment id="94">Ele queria editar decreto obrigando a reabertura do com&amp;eacute</segment>
    <segment id="95">;rcio.</segment>
    <segment id="96">Manteve o tom na sexta (17)</segment>
    <segment id="97">, quando sugeriu que as pessoas desobedecessem as ordens locais.</segment>
    <segment id="98">Com efeito</segment>
    <segment id="99">, o apoio ao relaxamento das restri&amp;ccedil</segment>
    <segment id="100">;&amp;otilde</segment>
    <segment id="101">;es &amp;eacute</segment>
    <segment id="102">; maior entre aqueles que consideram a gest&amp;atilde</segment>
    <segment id="103">;o de Bolsonaro na crise &amp;oacute</segment>
    <segment id="104">;tima ou boa: 43%</segment>
    <segment id="105">, empatando com os que acham que &amp;eacute</segment>
    <segment id="106">; importante ficar em casa</segment>
    <segment id="107">, 41%.</segment>
    <segment id="108">Um corte de redutos eleitorais diz o mesmo.</segment>
    <segment id="109">O apoio a ficar em casa &amp;eacute</segment>
    <segment id="110">; maior no oposicionista Nordeste (78%) e menor no reduto bolsonarista Sul (58%).</segment>
    <segment id="111">Empres&amp;aacute</segment>
    <segment id="112">;rios s&amp;atilde</segment>
    <segment id="113">;o o grupo que menos apoia o isolamento: 45%</segment>
    <segment id="114">, empatados com os 42% que querem o relaxamento.</segment>
    <segment id="115">O maior apoio proporcional &amp;agrave</segment>
    <segment id="116">; estadia em casa &amp;eacute</segment>
    <segment id="117">; entre estudantes (84%) e jovens (77%).</segment>
    <segment id="118">A clivagem pol&amp;iacute</segment>
    <segment id="119">;tica, que vem acompanhando a vida pol&amp;iacute</segment>
    <segment id="120">;tica brasileira h&amp;aacute</segment>
    <segment id="121">; anos e</segment>
    <segment id="122">sese acentuou em 2018</segment>
    <segment id="123">, sese observa em outro indicador aferido pelo Datafolha.</segment>
    <segment id="124">Os entrevistados foram indagados</segment>
    <segment id="125">sese pessoas que n&amp;atilde</segment>
    <segment id="126">;o fazem parte de grupos de risco para Covid-19</segment>
    <segment id="127">, como</segment>
    <segment id="128">como idosos ou portadores de doen&amp;ccedil</segment>
    <segment id="129">;as cr&amp;ocirc</segment>
    <segment id="130">;nicas</segment>
    <segment id="131">, deveriam sair &amp;agrave</segment>
    <segment id="132">;s ruas.</segment>
    <segment id="133">Esse &amp;eacute</segment>
    <segment id="134">;</segment>
    <segment id="135">o princ&amp;iacute</segment>
    <segment id="136">;pio, em linhas gerais</segment>
    <segment id="137">, do dito isolamento parcial que Bolsonaro vinha defendendo.</segment>
    <segment id="138">Ele n&amp;atilde</segment>
    <segment id="139">;o foi tentado com sucesso de forma integral em nenhum local do mundo &amp;mdash</segment>
    <segment id="140">;locais</segment>
    <segment id="141">comocomo a Coreia do Sul associaram quarentenas de vulner&amp;aacute</segment>
    <segment id="142">;veis a de regi&amp;otilde</segment>
    <segment id="143">;es mais afetadas pelo v&amp;iacute</segment>
    <segment id="144">;rus, por exemplo.</segment>
    <segment id="145">O Reino Unido ensaiou adotar a t&amp;aacute</segment>
    <segment id="146">;tica,</segment>
    <segment id="147">masmas voltou a atr&amp;aacute</segment>
    <segment id="148">;s quando o premi&amp;ecirc</segment>
    <segment id="149">; Boris Johnson</segment>
    <segment id="150">, que chegou a parar na UTI com a doen&amp;ccedil</segment>
    <segment id="151">;a, viu previs&amp;otilde</segment>
    <segment id="152">;es de at&amp;eacute</segment>
    <segment id="153">;</segment>
    <segment id="154">1 milh&amp;atilde</segment>
    <segment id="155">;o de mortos no seu pa&amp;iacute</segment>
    <segment id="156">;s sem o isolamento mais amplo.</segment>
    <segment id="157">Carreata contra Doria e em apoio a Bolsonaro em São Paulo   novamente         de   de  de  representando um</segment>
    <segment id="158">Na popula&amp;ccedil</segment>
    <segment id="159">;&amp;atilde</segment>
    <segment id="160">;o em geral</segment>
    <segment id="161">, a defesa da ideia oscilou de 37% para 41% desde o mais recente levantamento.</segment>
    <segment id="162">J&amp;aacute</segment>
    <segment id="163">;</segment>
    <segment id="164">entre quem aprova o trabalho do presidente</segment>
    <segment id="165">, o &amp;iacute</segment>
    <segment id="166">;ndice &amp;eacute</segment>
    <segment id="167">; de 71%.</segment>
    <segment id="168">Aqueles que defendem a manuten&amp;ccedil</segment>
    <segment id="169">;&amp;atilde</segment>
    <segment id="170">;o da horizontalidade do isolamento oscilaram de 60% para 56% do come&amp;ccedil</segment>
    <segment id="171">;o do m&amp;ecirc</segment>
    <segment id="172">;s para c&amp;aacute</segment>
    <segment id="173">;.</segment>
    <segment id="174">A diferen&amp;ccedil</segment>
    <segment id="175">;a regional tamb&amp;eacute</segment>
    <segment id="176">;m sese mant&amp;eacute</segment>
    <segment id="177">;m: o Sul &amp;eacute</segment>
    <segment id="178">;</segment>
    <segment id="179">o local com menor apoio a manter a quarentena para todos (42%)</segment>
    <segment id="180">, enquanto 64% dos nordestinos pensam assim.</segment>
    <segment id="181">Novamente</segment>
    <segment id="182">, os empres&amp;aacute</segment>
    <segment id="183">;rios integram a categoria de trabalhadores entrevistada que mais defende o fim da restri&amp;ccedil</segment>
    <segment id="184">;&amp;atilde</segment>
    <segment id="185">;o: 63%.&amp;ensp</segment>
    <segment id="186">;IG</segment>
  </rst>
</analysis>