  <rst>
    <segment id="1">A ministra da Gestão e da Inovação em Serviços Públicos</segment>
    <segment id="2">, Esther Dweck</segment>
    <segment id="3">, quer implementar espaços de amamentação nas sedes de ao menos 13 ministérios do governo federal</segment>
    <segment id="4">, em Brasília.</segment>
    <segment id="5">A iniciativa</segment>
    <segment id="6">, que já vinha sendo pensada por ela</segment>
    <segment id="7">, tem sido abertamente estimulada pela primeira-dama Rosângela da Silva</segment>
    <segment id="8">, a Janja.</segment>
    <segment id="9">Na semana passada</segment>
    <segment id="10">, Dweck participou da inauguração da primeira sala de apoio a lactantes do Palácio do Planalto.</segment>
    <segment id="11">A ideia é que o espaço sirva não só para aleitamento</segment>
    <segment id="12">, masmas também para ordenha e conservação do leite extraído.</segment>
    <segment id="13">A ministra da Gestão</segment>
    <segment id="14">, Esther Dweck</segment>
    <segment id="15">, em seu gabinete</segment>
    <segment id="16">, em Brasília - Pedro Ladeira - 13.fev.2023/Folhapress"Muitas carreiras não têm essa flexibilidade de poder ir para casa para amamentar e voltar [ao trabalho].</segment>
    <segment id="17">E, muitas vezes</segment>
    <segment id="18">, as mulheres</segment>
    <segment id="19">sese submetem a situações meio constrangedoras.</segment>
    <segment id="20">Mesmo quem faz ordenha não tem espaço.</segment>
    <segment id="21">Vai ao banheiro</segment>
    <segment id="22">, masmas não tem uma cadeira"</segment>
    <segment id="23">, afirma Dweck à coluna.</segment>
    <segment id="24">"</segment>
    <segment id="25">Algumas empresas estão mais avançadas nisso</segment>
    <segment id="26">, até mais que o governo.</segment>
    <segment id="27">E a gente</segment>
    <segment id="28">, desde o ano passado</segment>
    <segment id="29">, tinha a intenção de pensar um projeto para a Esplanada"</segment>
    <segment id="30">, acrescenta a ministra.</segment>
    <segment id="31">"</segment>
    <segment id="32">A própria Janja fez uma provocação</segment>
    <segment id="33">, falando:</segment>
    <segment id="34">'Vamos replicar isso'.</segment>
    <segment id="35">E eu falei: 'Realmente</segment>
    <segment id="36">, por que a gente não replica?</segment>
    <segment id="37">'.</segment>
    <segment id="38">"</segment>
    <segment id="39">No Planalto</segment>
    <segment id="40">, poltronas</segment>
    <segment id="41">, micro-ondas</segment>
    <segment id="42">, refrigerador e um trocador de fraldas foram disponibilizados</segment>
    <segment id="43">para que</segment>
    <segment id="44">para que o processo de amamentação e de ordenha possa ser realizado de forma mais confortável e privativa por servidoras</segment>
    <segment id="45">, colaboradoras e funcionárias terceirizadas.</segment>
    <segment id="46">Mulheres que trabalham deixam de amamentar exclusivamente no peitoMais    novamente         de   de  de  representando um</segment>
    <segment id="47">A ministra afirma que o mesmo projeto executado no Planalto pode ser replicado em outros ministérios</segment>
    <segment id="48">, destacando que os espaços são simples e não exigem muitos equipamentos.</segment>
    <segment id="49">Eventual produção excedente poderá até mesmo ser doada para bancos de leite</segment>
    <segment id="50">, diz Dweck.</segment>
    <segment id="51">Entre as pastas que devem ser contempladas até o fim deste ano estão os ministérios da Fazenda</segment>
    <segment id="52">, Planejamento</segment>
    <segment id="53">, Direitos Humanos</segment>
    <segment id="54">, Igualdade Racial</segment>
    <segment id="55">, Mulheres</segment>
    <segment id="56">, Povos Indígenas</segment>
    <segment id="57">, Turismo e Esporte.</segment>
    <segment id="58">"</segment>
    <segment id="59">Estamos dizendo às pessoas que amamentam que elas têm esse direito de serem respeitadas no seu espaço de trabalho</segment>
    <segment id="60">, sem gerar nenhum tipo de assédio ou de constrangimento.</segment>
    <segment id="61">A amamentação é um direito da criança também</segment>
    <segment id="62">, não só da mãe"</segment>
    <segment id="63">, afirma Dweck.   PASSARELA  Jantar do Iguatemi durante a Semana de Moda em ParisMais    novamente         de   de  de  representando um</segment>
    <segment id="64">O estilista Domenico Dolce e a executiva de moda Coco Brandolini d’Adda foram recebidos pelo empresário Carlos Jereissati em um jantar realizado na Maison Revka Paris</segment>
    <segment id="65">, na capital francesa</segment>
    <segment id="66">, na semana passada</segment>
    <segment id="67">, durante a Semana de Alta-Costura de Paris.</segment>
    <segment id="68">O evento foi organizado pelo grupo Iguatemi.</segment>
    <segment id="69">O consultor de moda Philippe Soussand e o CEO do grupo LVMH</segment>
    <segment id="70">, Michael Burke</segment>
    <segment id="71">, compareceram.</segment>
    <segment id="72">A diretora de luxo da Meta</segment>
    <segment id="73">, Morin Oluwole</segment>
    <segment id="74">, passou por lá.  com BIANKA VIEIRA</segment>
    <segment id="75">, KARINA MATIAS e MANOELLA SMITH</segment>
  </rst>
</analysis>