  <rst>
    <segment id="1">O Lobo da Estepe</segment>
    <segment id="2">, livro publicado pelo escritor alemão Hermann Hesse em 1927</segment>
    <segment id="3">, é o tema do último episódio da temporada do podcast Meu Inconsciente Coletivo.</segment>
    <segment id="4">No programa desta sexta (10)</segment>
    <segment id="5">, que estará disponível às 8h30</segment>
    <segment id="6">, a escritora e colunista da Folha Tati Bernardi recebe o psicanalista Daniel Kupermann para discutir o romance —uma leitura que marcou a juventude dos dois.</segment>
    <segment id="7">Kupermann é professor do Instituto de Psicologia da USP e autor do livro "</segment>
    <segment id="8">Por Que Ferenczi?</segment>
    <segment id="9">", sobre a obra do psicanalista húngaro Sándor Ferenczi.</segment>
    <segment id="10">Ao falar da releitura da obra</segment>
    <segment id="11">, Tati começa destacando que o livro apela a uma certa arrogância juvenil.</segment>
    <segment id="12">"</segment>
    <segment id="13">Pensei muito nessa arrogância</segment>
    <segment id="14">, que na verdade é um medo louco de pertencer ao mundo e sofrer"</segment>
    <segment id="15">, diz ela.</segment>
    <segment id="16">Kupermann aproveita para fazer um elogio dessa arrogância.</segment>
    <segment id="17">"</segment>
    <segment id="18">Temos inveja do adolescente</segment>
    <segment id="19">porque</segment>
    <segment id="20">porque ele tem uma arrogância</segment>
    <segment id="21">, uma ilusão de onipotência que é fundamental para ele acreditar que pode construir uma vida singular</segment>
    <segment id="22">, que não precisa</segment>
    <segment id="23">sese submeter aos imperativos sociais.</segment>
    <segment id="24">Eu faria uma defesa dessa arrogância"</segment>
    <segment id="25">, afirma ele.</segment>
    <segment id="26">Ouça o episódio:  Nesta temporada do programa em áudio</segment>
    <segment id="27">, Tati levou para o divã grandes protagonistas da literatura.</segment>
    <segment id="28">Entre as obras comentadas estão "</segment>
    <segment id="29">A Filha Perdida"</segment>
    <segment id="30">, de Elena Ferrante</segment>
    <segment id="31">, "</segment>
    <segment id="32">O Alienista"</segment>
    <segment id="33">, de Machado de Assis</segment>
    <segment id="34">, e "</segment>
    <segment id="35">A Paixão</segment>
    <segment id="36">Segundo G.H.</segment>
    <segment id="37">", de Clarice Lispector.</segment>
    <segment id="38">Além de Kupermann</segment>
    <segment id="39">, participaram desta temporada o psicanalista Alexandre Patrício</segment>
    <segment id="40">; a psicanalista e escritora Luciana Saddi</segment>
    <segment id="41">; a psicanalista e colunista da Folha Vera Iaconelli</segment>
    <segment id="42">; a psicanalista Luciana Salum</segment>
    <segment id="43">;</segment>
    <segment id="44">o escritor e psicanalista Robson Viturino</segment>
    <segment id="45">; a psicanalista e professora de literatura brasileira Yudith Rosenbaum</segment>
    <segment id="46">, o psicanalista e professor Christian Dunker</segment>
    <segment id="47">; a psicanalista e escritora Fernanda Hamann.</segment>
    <segment id="48">As três primeiras temporadas do Meu Inconsciente Coletivo também estão disponíveis nos aplicativos.</segment>
    <segment id="49">Os episódios tratam de temas</segment>
    <segment id="50">comocomo separação</segment>
    <segment id="51">, ansiedade</segment>
    <segment id="52">, síndrome do impostor e solidão na maternidade.</segment>
    <segment id="53">No podcast</segment>
    <segment id="54">Meu Inconsciente Coletivo</segment>
    <segment id="55">a escritora Tati Bernardi conversa com grandes psicanalistas- Editoria de Arte</segment>
  </rst>
</analysis>