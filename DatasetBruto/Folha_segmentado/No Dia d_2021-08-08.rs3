  <rst>
    <segment id="1">Pai de Sofia</segment>
    <segment id="2">, Aurora e Júlia</segment>
    <segment id="3">, Ferrugem é o mais novo compositor e intérprete de canções apropriadas para o Dia dos Pais.</segment>
    <segment id="4">“</segment>
    <segment id="5">Pai de Menina” já tocou mais de 30 milhões de vezes nas plataformas digitais.</segment>
    <segment id="6">Como canta na faixa</segment>
    <segment id="7">, seu mundo era todo azul e foi ficando aos poucos cor de rosa.</segment>
    <segment id="8">“Quando acordar e não me ver / Fica triste não</segment>
    <segment id="9">, tente entender / Pede pro papai do céu me proteger / Vou estar fazendo o mesmo por você”</segment>
    <segment id="10">, canta ele no hit.</segment>
    <segment id="11">​Quando Juliana</segment>
    <segment id="12">, mãe da primogênita</segment>
    <segment id="13">, Júlia</segment>
    <segment id="14">, morreu</segment>
    <segment id="15">, em 2015</segment>
    <segment id="16">, Ferrugem pensou até em abandonar a carreira para cuidar da pequena</segment>
    <segment id="17">, hoje com 10 anos.</segment>
    <segment id="18">A paternidade segue sendo um tema presente na sua trajetória.</segment>
    <segment id="19">Recentemente</segment>
    <segment id="20">, na gravação do DVD “Chão de Estrelas” ele convidou Thaís Vasconcellos</segment>
    <segment id="21">, sua parceira</segment>
    <segment id="22">, e as três filhas para acompanhá-lo no palco</segment>
    <segment id="23">, dos shows presenciais às lives pela internet.</segment>
    <segment id="24">VAMOS ESPIAR  Bonitonas</segment>
    <segment id="25">, empreendedoras e modelos requisitadas por marcas dispostas a saírem bem no Instagram</segment>
    <segment id="26">, as gêmeas Gabrielle e Valeska Araújo estão entre as poucas pessoas não exatamente famosas que Boninho</segment>
    <segment id="27">, diretor do “BBB”</segment>
    <segment id="28">, segue no Instagram.</segment>
    <segment id="29">Estariam elas cotadas para a próxima edição do reality?</segment>
    <segment id="30">No “BBB 17”</segment>
    <segment id="31">, o chefão levou para a casa as gêmeas Emilly e Mayla</segment>
    <segment id="32">, e Emilly foi até campeã da edição</segment>
    <segment id="33">, que também teve os gêmeos Antônio e Manoel Rafaski.</segment>
    <segment id="34">Boninho segue ainda as gêmeas Bia e Branca Feres</segment>
    <segment id="35">, do nado sincronizado</segment>
    <segment id="36">, acusando assim o seu fascínio por pessoas idênticas.</segment>
    <segment id="37">As belas de agosto passam por aquiMais    novamente         de   de  de  representando um  FRASE   "Mestre do canto revolucionário</segment>
    <segment id="38">, das sonoridades ecoadas pelos 5 mil alto-falantes das nossas vivas tropicálias</segment>
    <segment id="39">, leãozinho vanguardista</segment>
    <segment id="40">, gostamos muito de te ver caminhando sob o sol"     Carlinhos Brown</segment>
    <segment id="41">, em celebração aos 79 anos de Caetano Veloso   COMOÇÃO</segment>
    <segment id="42">Uma enxurrada de postagens nas redes sociais pede orações e torcida pelo casal Glória Menezes</segment>
    <segment id="43">, 86 anos</segment>
    <segment id="44">, e Tarcísio Meira</segment>
    <segment id="45">, 85, especialmente por ele</segment>
    <segment id="46">, que foi intubado no Hospital Israelita Albert Einstein.</segment>
    <segment id="47">Vacinados em janeiro em Porto Feliz</segment>
    <segment id="48">, no interior paulista</segment>
    <segment id="49">, ambos foram agora infectados pela Covid.</segment>
    <segment id="50">A atriz também está internada</segment>
    <segment id="51">, masmas em quarto comum</segment>
    <segment id="52">, com sintomas leves.</segment>
    <segment id="53">A imunização</segment>
    <segment id="54">, como</segment>
    <segment id="55">como se</segment>
    <segment id="56">se sabe</segment>
    <segment id="57">, inibe o agravamento da doença</segment>
    <segment id="58">, masmas não impede por completo a sua contaminação.</segment>
    <segment id="59">Tarcísio já apresentava saúde fragilizada quando foi infectado.</segment>
    <segment id="60">Há três anos</segment>
    <segment id="61">, ele deixou o elenco da novela “Orgulho e Paixão”</segment>
    <segment id="62">, a última de que participou</segment>
    <segment id="63">, por causa de uma infecção pulmonar.</segment>
    <segment id="64">Os dois foram dispensados pela Globo no ano passado</segment>
    <segment id="65">, após mais de 40 anos de serviços prestados à emissora.</segment>
    <segment id="66">O casal Tarcísio Meira e Glória MenezesMais    novamente         de   de  de  representando um  MISSÃO POSSÍVEL  Iniciado antes da pandemia</segment>
    <segment id="67">, retomado após alguns meses de isolamento e interrompido em mais de uma ocasião por problemas que foram da infecção de Covid à perturbação da vizinhança</segment>
    <segment id="68">, “Missão Impossível 7” finalmente teve suas filmagens encerradas</segment>
    <segment id="69">, como</segment>
    <segment id="70">como mostrou a atriz Rebecca Ferguson em foto nas redes sociais</segment>
    <segment id="71">, com o astro Tom Cruise.</segment>
    <segment id="72">“É um fim de gravações para mim em Missão Impossível 7!</segment>
    <segment id="73">Obrigada pela minha equipe maravilhosa e tolerante”</segment>
    <segment id="74">, disse ela.</segment>
    <segment id="75">A estreia nos cinemas deve ocorrer ainda este ano.</segment>
    <segment id="76">Tom Cruise volta a filmar &amp;#039</segment>
    <segment id="77">;Missão Impossível&amp;#039</segment>
    <segment id="78">; em RomaMais    novamente         de   de  de  representando um</segment>
  </rst>
