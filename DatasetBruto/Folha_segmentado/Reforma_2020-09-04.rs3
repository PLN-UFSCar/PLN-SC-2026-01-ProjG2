  <rst>
    <segment id="1">Apesar da determina&amp;ccedil</segment>
    <segment id="2">;&amp;atilde</segment>
    <segment id="3">;o do presidente Jair Bolsonaro (sem partido) de que a reforma administrativa atinja apenas futuros membros do servi&amp;ccedil</segment>
    <segment id="4">;o p&amp;uacute</segment>
    <segment id="5">;blico</segment>
    <segment id="6">, ao menos dois itens da proposta que altera as normas do funcionalismo</segment>
    <segment id="7">, apresentada nesta semana pelo governo</segment>
    <segment id="8">, devem valer para os atuais servidores.</segment>
    <segment id="9">Segundo ministros que participaram da elabora&amp;ccedil</segment>
    <segment id="10">;&amp;atilde</segment>
    <segment id="11">;o da proposta</segment>
    <segment id="12">, as regras que v&amp;atilde</segment>
    <segment id="13">;o regulamentar a demiss&amp;atilde</segment>
    <segment id="14">;o por mau desempenho e o novo modelo de avalia&amp;ccedil</segment>
    <segment id="15">;&amp;atilde</segment>
    <segment id="16">;o, que o governo pretende tornar mais r&amp;iacute</segment>
    <segment id="17">;gido, ser&amp;atilde</segment>
    <segment id="18">;o aplicados aos funcion&amp;aacute</segment>
    <segment id="19">;rios ativos.</segment>
    <segment id="20">A equipe econ&amp;ocirc</segment>
    <segment id="21">;mica argumenta</segment>
    <segment id="22">, no caso</segment>
    <segment id="23">caso das demiss&amp;otilde</segment>
    <segment id="24">;es por insufici&amp;ecirc</segment>
    <segment id="25">;ncia, que essa determina&amp;ccedil</segment>
    <segment id="26">;&amp;atilde</segment>
    <segment id="27">;o j&amp;aacute</segment>
    <segment id="28">;</segment>
    <segment id="29">existe na Constitui&amp;ccedil</segment>
    <segment id="30">;&amp;atilde</segment>
    <segment id="31">;o e apenas n&amp;atilde</segment>
    <segment id="32">;o est&amp;aacute</segment>
    <segment id="33">; regulamentada.</segment>
    <segment id="34">Portanto</segment>
    <segment id="35">, quando o governo propuser a regulamenta&amp;ccedil</segment>
    <segment id="36">;&amp;atilde</segment>
    <segment id="37">;o desse ponto</segment>
    <segment id="38">, a norma valer&amp;aacute</segment>
    <segment id="39">; para todos os servidores</segment>
    <segment id="40">, inclusive os atuais.</segment>
    <segment id="41">O que a reforma administrativa deve prever   novamente         de   de  de  representando um</segment>
    <segment id="42">A aplica&amp;ccedil</segment>
    <segment id="43">;&amp;atilde</segment>
    <segment id="44">;o de um terceiro item para os funcion&amp;aacute</segment>
    <segment id="45">;rios em atividade que veda a progress&amp;atilde</segment>
    <segment id="46">;o por tempo de servi&amp;ccedil</segment>
    <segment id="47">;o ser&amp;aacute</segment>
    <segment id="48">; alvo de discuss&amp;otilde</segment>
    <segment id="49">;es.</segment>
    <segment id="50">O governo incluiu essa proibi&amp;ccedil</segment>
    <segment id="51">;&amp;atilde</segment>
    <segment id="52">;o na PEC (proposta de emenda &amp;agrave</segment>
    <segment id="53">; Constitui&amp;ccedil</segment>
    <segment id="54">;&amp;atilde</segment>
    <segment id="55">;o) que encaminhou ao Congresso.</segment>
    <segment id="56">O Minist&amp;eacute</segment>
    <segment id="57">;rio da Economia n&amp;atilde</segment>
    <segment id="58">;o confirma oficialmente que as regras de progress&amp;atilde</segment>
    <segment id="59">;o e avalia&amp;ccedil</segment>
    <segment id="60">;&amp;atilde</segment>
    <segment id="61">;o de desempenho valer&amp;atilde</segment>
    <segment id="62">;o para os atuais servidores.</segment>
    <segment id="63">Um ministro que participou da elabora&amp;ccedil</segment>
    <segment id="64">;&amp;atilde</segment>
    <segment id="65">;o da proposta</segment>
    <segment id="66">, no entanto</segment>
    <segment id="67">, entende que</segment>
    <segment id="68">comocomo esse item est&amp;aacute</segment>
    <segment id="69">; regulamentado em leis e decretos &amp;mdash</segment>
    <segment id="70">;e n&amp;atilde</segment>
    <segment id="71">;o foi descrito na Constitui&amp;ccedil</segment>
    <segment id="72">;&amp;atilde</segment>
    <segment id="73">;o, diferentemente da estabilidade dos servidores&amp;mdash</segment>
    <segment id="74">; ele poderia</segment>
    <segment id="75">, sim, valer para aqueles que j&amp;aacute</segment>
    <segment id="76">; passaram em concurso.</segment>
    <segment id="77">Bolsonaro frisou mais de uma vez que a sua proposta de mudan&amp;ccedil</segment>
    <segment id="78">;as no funcionalismo n&amp;atilde</segment>
    <segment id="79">;o atingiria os atuais servidores.</segment>
    <segment id="80">A PEC foi inclusive desidratada por press&amp;atilde</segment>
    <segment id="81">;o de servidores e pol&amp;iacute</segment>
    <segment id="82">;ticos do centr&amp;atilde</segment>
    <segment id="83">;o para ter um impacto menor nas categorias</segment>
    <segment id="84">, como</segment>
    <segment id="85">como mostrou o Painel.</segment>
    <segment id="86">Ainda assim</segment>
    <segment id="87">, membros do governo entendem que esses trechos n&amp;atilde</segment>
    <segment id="88">;o s&amp;atilde</segment>
    <segment id="89">;o considerados vantagens ou direitos adquiridos dos servidores.</segment>
    <segment id="90">Por isso</segment>
    <segment id="91">, sese aplicariam aos que est&amp;atilde</segment>
    <segment id="92">;o em atividade.</segment>
    <segment id="93">O decreto 84.669</segment>
    <segment id="94">, que disciplina a evolu&amp;ccedil</segment>
    <segment id="95">;&amp;atilde</segment>
    <segment id="96">;o nas carreiras de autarquias federais</segment>
    <segment id="97">, professores</segment>
    <segment id="98">, policiais federais e diplomatas</segment>
    <segment id="99">, por exemplo</segment>
    <segment id="100">, diz que a progress&amp;atilde</segment>
    <segment id="101">;o na carreira</segment>
    <segment id="102">sese dar&amp;aacute</segment>
    <segment id="103">; &amp;quot</segment>
    <segment id="104">;50% por merecimento&amp;quot</segment>
    <segment id="105">; e &amp;quot</segment>
    <segment id="106">;50% por antiguidade&amp;quot</segment>
    <segment id="107">;.</segment>
    <segment id="108">Segundo auxiliares do presidente</segment>
    <segment id="109">, bastaria uma nova lei para alterar o teor do decreto</segment>
    <segment id="110">, o que tornaria a aplica&amp;ccedil</segment>
    <segment id="111">;&amp;atilde</segment>
    <segment id="112">;o das regras imediatas.</segment>
    <segment id="113">Uma ala do governo</segment>
    <segment id="114">, inclusive</segment>
    <segment id="115">, defende que a regra que impede a progress&amp;atilde</segment>
    <segment id="116">;o autom&amp;aacute</segment>
    <segment id="117">;tica de carreira por tempo de servi&amp;ccedil</segment>
    <segment id="118">;o valha para os atuais servidores para evitar que</segment>
    <segment id="119">sese crie regras de evolu&amp;ccedil</segment>
    <segment id="120">;&amp;atilde</segment>
    <segment id="121">;o na carreira muito d&amp;iacute</segment>
    <segment id="122">;spares dentro de um mesmo &amp;oacute</segment>
    <segment id="123">;rg&amp;atilde</segment>
    <segment id="124">;o.</segment>
    <segment id="125">O governo decidiu incluir na pr&amp;oacute</segment>
    <segment id="126">;pria PEC trecho que veda a progress&amp;atilde</segment>
    <segment id="127">;o por tempo de servi&amp;ccedil</segment>
    <segment id="128">;o para n&amp;atilde</segment>
    <segment id="129">;o dar margem</segment>
    <segment id="130">para que</segment>
    <segment id="131">para que</segment>
    <segment id="132">sese reavalie essa mudan&amp;ccedil</segment>
    <segment id="133">;a no futuro.</segment>
    <segment id="134">Embora n&amp;atilde</segment>
    <segment id="135">;o fosse nem necess&amp;aacute</segment>
    <segment id="136">;rio esperar a aprova&amp;ccedil</segment>
    <segment id="137">;&amp;atilde</segment>
    <segment id="138">;o da PEC para fazer certas altera&amp;ccedil</segment>
    <segment id="139">;&amp;otilde</segment>
    <segment id="140">;es, o governo vai aguardar a aprova&amp;ccedil</segment>
    <segment id="141">;&amp;atilde</segment>
    <segment id="142">;o da proposta para ent&amp;atilde</segment>
    <segment id="143">;o regulamentar as demais regras e evitar inseguran&amp;ccedil</segment>
    <segment id="144">;a jur&amp;iacute</segment>
    <segment id="145">;dica, diz um ministro em car&amp;aacute</segment>
    <segment id="146">;ter reservado.</segment>
    <segment id="147">Um t&amp;eacute</segment>
    <segment id="148">;cnico do Minist&amp;eacute</segment>
    <segment id="149">;rio da Economia que atua na formula&amp;ccedil</segment>
    <segment id="150">;&amp;atilde</segment>
    <segment id="151">;o das propostas afirma que essa &amp;eacute</segment>
    <segment id="152">; uma discuss&amp;atilde</segment>
    <segment id="153">;o que precisar&amp;aacute</segment>
    <segment id="154">; ser feita pelo governo no futuro</segment>
    <segment id="155">, quando efetivamente enviar esses projetos nas pr&amp;oacute</segment>
    <segment id="156">;ximas fases da reforma.</segment>
    <segment id="157">No caso</segment>
    <segment id="158">caso das progress&amp;otilde</segment>
    <segment id="159">;es, por exemplo</segment>
    <segment id="160">, al&amp;eacute</segment>
    <segment id="161">;m do decreto</segment>
    <segment id="162">, existem hoje dezenas de leis que tratam do mecanismo para carreiras espec&amp;iacute</segment>
    <segment id="163">;ficas.</segment>
    <segment id="164">De acordo com o t&amp;eacute</segment>
    <segment id="165">;cnico</segment>
    <segment id="166">, &amp;eacute</segment>
    <segment id="167">; poss&amp;iacute</segment>
    <segment id="168">;vel que uma futura lei sobre avalia&amp;ccedil</segment>
    <segment id="169">;&amp;otilde</segment>
    <segment id="170">;es e progress&amp;otilde</segment>
    <segment id="171">;es prevale&amp;ccedil</segment>
    <segment id="172">;a sobre as normas atuais</segment>
    <segment id="173">, gerando impacto tamb&amp;eacute</segment>
    <segment id="174">;m sobre os servidores que j&amp;aacute</segment>
    <segment id="175">;</segment>
    <segment id="176">est&amp;atilde</segment>
    <segment id="177">;o na ativa.</segment>
    <segment id="178">Ele afirma</segment>
    <segment id="179">, no entanto</segment>
    <segment id="180">, que isso depender&amp;aacute</segment>
    <segment id="181">; de avalia&amp;ccedil</segment>
    <segment id="182">;&amp;atilde</segment>
    <segment id="183">;o e decis&amp;atilde</segment>
    <segment id="184">;o do governo e do Congresso.</segment>
    <segment id="185">Atualmente</segment>
    <segment id="186">, algumas carreiras adotam a avalia&amp;ccedil</segment>
    <segment id="187">;&amp;atilde</segment>
    <segment id="188">;o de desempenho</segment>
    <segment id="189">comocomo crit&amp;eacute</segment>
    <segment id="190">;rio para definir quem progride primeiro dentro de um grupo de servidores.  N&amp;atilde</segment>
    <segment id="191">;o h&amp;aacute</segment>
    <segment id="192">;, por&amp;eacute</segment>
    <segment id="193">;m, casos em que um servidor fique travado em um determinado n&amp;iacute</segment>
    <segment id="194">;vel da carreira em raz&amp;atilde</segment>
    <segment id="195">;o de ter um desempenho inferior ao de seus colegas.</segment>
    <segment id="196">Nesse caso</segment>
    <segment id="197">caso, ele apenas demora mais para avan&amp;ccedil</segment>
    <segment id="198">;ar, mas</segment>
    <segment id="199">mas progride assim mesmo.</segment>
    <segment id="200">Questionado sobre esse ponto espec&amp;iacute</segment>
    <segment id="201">;fico, o Minist&amp;eacute</segment>
    <segment id="202">;rio da Economia</segment>
    <segment id="203">sese limitou a responder que &amp;quot</segment>
    <segment id="204">;est&amp;aacute</segment>
    <segment id="205">; concentrando esfor&amp;ccedil</segment>
    <segment id="206">;os na aprova&amp;ccedil</segment>
    <segment id="207">;&amp;atilde</segment>
    <segment id="208">;o da PEC&amp;quot</segment>
    <segment id="209">;.</segment>
    <segment id="210">No caso</segment>
    <segment id="211">caso das demiss&amp;otilde</segment>
    <segment id="212">;es, a proposta do governo j&amp;aacute</segment>
    <segment id="213">;</segment>
    <segment id="214">traz um ajuste na Constitui&amp;ccedil</segment>
    <segment id="215">;&amp;atilde</segment>
    <segment id="216">;o que afeta dos atuais servidores.</segment>
    <segment id="217">Pela proposta</segment>
    <segment id="218">, a regra que autoriza desligamentos ap&amp;oacute</segment>
    <segment id="219">;s senten&amp;ccedil</segment>
    <segment id="220">;a judicial ser&amp;aacute</segment>
    <segment id="221">; alterada.</segment>
    <segment id="222">Hoje, a demiss&amp;atilde</segment>
    <segment id="223">;o s&amp;oacute</segment>
    <segment id="224">; &amp;eacute</segment>
    <segment id="225">; feita ap&amp;oacute</segment>
    <segment id="226">;s a conclus&amp;atilde</segment>
    <segment id="227">;o de todo o processo</segment>
    <segment id="228">, com tr&amp;acirc</segment>
    <segment id="229">;nsito em julgado.</segment>
    <segment id="230">A nova regra permitir&amp;aacute</segment>
    <segment id="231">; o corte do servidor em etapa anterior</segment>
    <segment id="232">, ap&amp;oacute</segment>
    <segment id="233">;s a primeira decis&amp;atilde</segment>
    <segment id="234">;o colegiada.</segment>
    <segment id="235">A segunda mudan&amp;ccedil</segment>
    <segment id="236">;a viria nas demiss&amp;otilde</segment>
    <segment id="237">;es por desempenho</segment>
    <segment id="238">, algo comum na iniciativa privada</segment>
    <segment id="239">, masmas que</segment>
    <segment id="240">, na pr&amp;aacute</segment>
    <segment id="241">;tica, n&amp;atilde</segment>
    <segment id="242">;o ocorre no governo.</segment>
    <segment id="243">A Constitui&amp;ccedil</segment>
    <segment id="244">;&amp;atilde</segment>
    <segment id="245">;o define que o servidor</segment>
    <segment id="246">, mesmo com estabilidade</segment>
    <segment id="247">, poder&amp;aacute</segment>
    <segment id="248">; perder o cargo ap&amp;oacute</segment>
    <segment id="249">;s avalia&amp;ccedil</segment>
    <segment id="250">;&amp;atilde</segment>
    <segment id="251">;o peri&amp;oacute</segment>
    <segment id="252">;dica de desempenho.</segment>
    <segment id="253">O texto define</segment>
    <segment id="254">, por&amp;eacute</segment>
    <segment id="255">;m, que essa regra ser&amp;aacute</segment>
    <segment id="256">; regulamentada por meio de uma lei complementar</segment>
    <segment id="257">, o que nunca foi feito.</segment>
    <segment id="258">O governo quer negociar com o Congresso</segment>
    <segment id="259">para que</segment>
    <segment id="260">para que esse ponto passe a valer efetivamente.</segment>
    <segment id="261">Ao divulgar a proposta na quinta-feira (3)</segment>
    <segment id="262">, o Pal&amp;aacute</segment>
    <segment id="263">;cio do Planalto apresentou um resumo &amp;agrave</segment>
    <segment id="264">;</segment>
    <segment id="265">imprensa sem retirar edi&amp;ccedil</segment>
    <segment id="266">;&amp;otilde</segment>
    <segment id="267">;es anteriores feitas no texto.</segment>
    <segment id="268">Em uma delas</segment>
    <segment id="269">, o governo dizia que a reforma apresenta novas possibilidades de v&amp;iacute</segment>
    <segment id="270">;nculo sem alterar &amp;quot</segment>
    <segment id="271">;de forma relevante&amp;quot</segment>
    <segment id="272">; o regime dos atuais servidores.</segment>
    <segment id="273">No texto enviado &amp;agrave</segment>
    <segment id="274">; imprensa</segment>
    <segment id="275">, a express&amp;atilde</segment>
    <segment id="276">;o &amp;quot</segment>
    <segment id="277">;de forma relevante&amp;quot</segment>
    <segment id="278">; estava riscada e marcada em vermelho.</segment>
  </rst>
</analysis>