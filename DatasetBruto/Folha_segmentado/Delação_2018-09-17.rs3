  <rst>
    <segment id="1">A delação de Antonio Palocci preocupa o PT.</segment>
    <segment id="2">Líderes do partido buscam informações sobre o conteúdo dos depoimentos do ex-ministro à Polícia Federal.  DIRETO</segment>
    <segment id="3">Embora sigilosos</segment>
    <segment id="4">, trechos das falas têm vazado a conta-gotas para a imprensa.</segment>
    <segment id="5">Palocci teria afirmado que Lula</segment>
    <segment id="6">sese envolveu diretamente em esquemas de propina.</segment>
    <segment id="7">ÀS CEGAS</segment>
    <segment id="8">O partido até agora</segment>
    <segment id="9">, no entanto</segment>
    <segment id="10">, não tem informações precisas sobre o conteúdo das falas.</segment>
    <segment id="11">TE PERGUNTO   Lula já foi consultado</segment>
    <segment id="12">, na prisão</segment>
    <segment id="13">, sobre a possibilidade de uma delação de Palocci ter consistência suficiente para conturbar a campanha do partido na reta final das eleições</segment>
    <segment id="14">, caso</segment>
    <segment id="15">caso ela seja divulgada.</segment>
    <segment id="16">TE RESPONDO</segment>
    <segment id="17">O ex-presidente disse para o interlocutor que ficasse tranquilo</segment>
    <segment id="18">poispois ele havia reexaminado seu relacionamento com o ex-ministro —que não teria</segment>
    <segment id="19">comocomo comprometê-lo de forma comprovada em nenhum delito.</segment>
    <segment id="20">EM MARTE</segment>
    <segment id="21">A delação de Palocci já tinha sido descartada pelo Ministério Público Federal.</segment>
    <segment id="22">O procurador Carlos Fernando dos Santos Lima chegou a afirmar que ela estava “mais para o acordo do fim da picada”.</segment>
    <segment id="23">O ex-ministro acabou acertando colaboração com a PF.</segment>
    <segment id="24">NOSSO QUERIDO</segment>
    <segment id="25">O candidato João Amoêdo (Novo)</segment>
    <segment id="26">, que tinha a preferência de 1% em todas as classes sociais no começo do ano</segment>
    <segment id="27">, segundo o Datafolha</segment>
    <segment id="28">, deu um salto maior entre os mais abastados.  ANDAR</segment>
    <segment id="29">De acordo com a pesquisa do instituto divulgada na sexta (14)</segment>
    <segment id="30">, ele tem 3% do total do eleitorado —</segment>
    <segment id="31">masmas 7% entre os que ganham mais de dez salários mínimos.  MURCHOU</segment>
    <segment id="32">A performance de Geraldo Alckmin (PSDB-SP) entre os mais ricos foge da que tradicionalmente era registrada em eleições anteriores.</segment>
    <segment id="33">Ele tem 9% do total de votos —</segment>
    <segment id="34">masmas só 4% entre os que ganham mais de dez salários mínimos.</segment>
    <segment id="35">INFLOU</segment>
    <segment id="36">Já entre os que recebem até dois salários</segment>
    <segment id="37">, Alckmin tem 11% dos votos.  HERDOU</segment>
    <segment id="38">E Jair Bolsonaro</segment>
    <segment id="39">, entre os mais ricos</segment>
    <segment id="40">, chega a 36%.</segment>
    <segment id="41">Jantar Brasil que Dá Certo</segment>
    <segment id="42">, em prol do GRAACCMais    novamente         de   de  de  representando um  GARFO</segment>
    <segment id="43">E FACA</segment>
    <segment id="44">O ex-ministro da Fazenda Maílson da Nóbrega foi ao jantar Brasil que Dá Certo</segment>
    <segment id="45">, em prol do Graacc</segment>
    <segment id="46">, na quinta (13)</segment>
    <segment id="47">, no Palácio Tangará.</segment>
    <segment id="48">O presidente da entidade</segment>
    <segment id="49">, Sergio Amoroso</segment>
    <segment id="50">, o apresentador Celso Portiolli e os empresários Alexandre Costa e Fábio Auriemo</segment>
    <segment id="51">, ao lado da mulher</segment>
    <segment id="52">, Angela</segment>
    <segment id="53">, compareceram</segment>
    <segment id="54">, assim</segment>
    <segment id="55">comocomo o cantor Leo Chaves e a jornalista Mariana Godoy.    PORTAS...</segment>
    <segment id="56">Enquanto a concessão do Pacaembu não é definida</segment>
    <segment id="57">, paulistanos que já têm carteirinha de algum clube esportivo municipal poderão utilizar a piscina e as quadras daquele complexo sem a necessidade de realizarem um novo cadastro no local —o que era exigido antes.</segment>
    <segment id="58">A mudança consta em uma portaria da secretaria de Esportes e Lazer publicada na sexta (14).   ...</segment>
    <segment id="59">ABERTAS</segment>
    <segment id="60">A prefeitura também inicia</segment>
    <segment id="61">, em outubro</segment>
    <segment id="62">, o programa</segment>
    <segment id="63">Fim de Semana no Pacaembu</segment>
    <segment id="64">, que fará excursões de usuários dos outros 46 clubes da cidade ao complexo.</segment>
    <segment id="65">POP</segment>
    <segment id="66">Pela primeira vez no Brasil</segment>
    <segment id="67">, a cantora americana Kelela será a atração principal do festival MECABrás</segment>
    <segment id="68">, que acontece no dia 19 de novembro</segment>
    <segment id="69">, na antiga fábrica Orion</segment>
    <segment id="70">, em SP.</segment>
    <segment id="71">PÉ NA ESTRADA</segment>
    <segment id="72">A cantora e violonista Badi Assad estreia em SP a turnê “Volta ao Mundo em 80 Artistas”</segment>
    <segment id="73">, baseada em seu primeiro livro</segment>
    <segment id="74">, lançado em maio.</segment>
    <segment id="75">Ela se</segment>
    <segment id="76">se apresenta nos dias 11 e 12 de outubro</segment>
    <segment id="77">, no Sesc Pompeia</segment>
    <segment id="78">, e conta com participação de Filipe Catto.</segment>
    <segment id="79">PREVISÃO</segment>
    <segment id="80">O Museu do Amanhã</segment>
    <segment id="81">, no Rio</segment>
    <segment id="82">, vai inaugurar na quarta (19) a exposição temporária</segment>
    <segment id="83">“Ofisuka 2068</segment>
    <segment id="84">– Imaginando um Futuro do Trabalho”.</segment>
    <segment id="85">Os visitantes poderão conhecer cenários para a vida profissional daqui a 50 anos.</segment>
    <segment id="86">SONHOS   Serão apresentadas algumas possíveis novas profissões</segment>
    <segment id="87">comocomo Onironauta (mineradores de matéria onírica bruta) e Pensigner (designer de pensamentos).</segment>
    <segment id="88">EMPREGO</segment>
    <segment id="89">Segundo Marcela Sabino</segment>
    <segment id="90">, curadora da exposição e diretora do Laboratório de Atividades do Museu do Amanhã</segment>
    <segment id="91">, estima-</segment>
    <segment id="92">sese que 65% das crianças irão trabalhar em atividades que ainda não existem.</segment>
    <segment id="93">Jantar emhomenagem ao presidente da Infraero</segment>
    <segment id="94">, Antônio ClaretMais    novamente         de   de  de  representando um  MESA POSTA</segment>
    <segment id="95">O presidente da Infraero</segment>
    <segment id="96">, Antônio Claret</segment>
    <segment id="97">, foi homenageado em jantar na quinta (13)</segment>
    <segment id="98">, no qual estiveram a sua mulher</segment>
    <segment id="99">, Maria Cristina</segment>
    <segment id="100">, e o empresário Michael Klein e sua mulher</segment>
    <segment id="101">, Alice Klein.</segment>
    <segment id="102">O evento foi realizado na casa do advogado Nelson Wilians e da empresária Anne Wilians.</segment>
    <segment id="103">O ex-secretário estadual José Renato Nalini também passou por lá.    CURTO-CIRCUITO</segment>
    <segment id="104">O fotógrafo Ricardo de Vicq inaugura na segunda (17) a mostra</segment>
    <segment id="105">“Foto Synthese”</segment>
    <segment id="106">, na embaixada do Brasil em Berlim.</segment>
    <segment id="107">Os assessores econômicos de Álvaro Dias</segment>
    <segment id="108">, Ciro Gomes</segment>
    <segment id="109">, Geraldo Alckmin e Marina Silva participam de debate do Lide.</segment>
    <segment id="110">Na segunda (17)</segment>
    <segment id="111">, às 11h</segment>
    <segment id="112">, no Grand Hyatt.</segment>
    <segment id="113">O MIS inicia uma mostra em homenagem a Sophia Loren.</segment>
    <segment id="114">Na segunda (17)</segment>
    <segment id="115">, às 20h30.</segment>
    <segment id="116">Começa na segunda (17) o projeto</segment>
    <segment id="117">O Bloco do Povo Encantado</segment>
    <segment id="118">, com peças e oficinas.</segment>
    <segment id="119">Em Santos.  com  BRUNA NARCIZO</segment>
    <segment id="120">, BRUNO B. SORAGGI e VICTORIA AZEVEDO</segment>
  </rst>
</analysis>