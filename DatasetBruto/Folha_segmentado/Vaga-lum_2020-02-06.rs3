  <rst>
    <segment id="1">​​Quase 2.000 espécies de vaga-lumes voam</segment>
    <segment id="2">, rastejam e brilham ao redor do planeta.</segment>
    <segment id="3">Alguns desses insetos vão bem</segment>
    <segment id="4">, masmas outros</segment>
    <segment id="5">, nem tanto.</segment>
    <segment id="6">Uma pesquisa com 49 especialistas mundiais em vaga-lumes</segment>
    <segment id="7">, publicada na segunda (3) na revista científica BioScience</segment>
    <segment id="8">, identificou as ameaças mais graves a esses animais e constatou que perda de habitat é um problema em quase todas as regiões estudadas.</segment>
    <segment id="9">Entre as outras ameaças estão a luz artificial</segment>
    <segment id="10">, que perturba os rituais de acasalamento desses animais</segment>
    <segment id="11">, os pesticidas</segment>
    <segment id="12">, que podem prejudicar os insetos ou suas presas invertebradas</segment>
    <segment id="13">, e a poluição da água</segment>
    <segment id="14">, para as espécies que têm uma fase aquática.</segment>
    <segment id="15">Vaga-lumes em árvore na Tailândia  - Radim Schreiber/Tufts University/AFP</segment>
    <segment id="16">O relatório não é um censo da população mundial de vaga-lumes</segment>
    <segment id="17">, masmas a primeira vez que são reunidas informações sobre as ameaças mais importantes para esses bichos em diferentes partes do mundo</segment>
    <segment id="18">, segundo Sara M. Lewis</segment>
    <segment id="19">, bióloga na Universidade Tufts e autora do estudo.</segment>
    <segment id="20">“</segment>
    <segment id="21">Na última década ou mais</segment>
    <segment id="22">, as pessoas têm relatado que não veem mais vaga-lumes onde costumavam ver”</segment>
    <segment id="23">, afirma.</segment>
    <segment id="24">Existem bons dados de censo para algumas espécies</segment>
    <segment id="25">, como</segment>
    <segment id="26">como os vaga-lumes síncronos da Malásia e as larvas de fêmeas da Europa</segment>
    <segment id="27">, e sabe-</segment>
    <segment id="28">sese que essas populações estão</segment>
    <segment id="29">, de fato</segment>
    <segment id="30">, em declínio</segment>
    <segment id="31">, diz a bióloga.</segment>
    <segment id="32">Em outros lugares</segment>
    <segment id="33">, contudo</segment>
    <segment id="34">contudo</segment>
    <segment id="35">, a literatura sobre vaga-lumes permanece obscura</segment>
    <segment id="36">, e a comunidade de pesquisadores é relativamente pequena</segment>
    <segment id="37">, de acordo com Lewis.</segment>
    <segment id="38">O estudo foi “quase tão bom quanto” voltar no tempo para contar populações</segment>
    <segment id="39">, segundo o entomologista Marc Branham</segment>
    <segment id="40">, da Universidade da Flórida.</segment>
    <segment id="41">Ele soube de muitos casos de vaga-lumes desaparecidos.</segment>
    <segment id="42">“</segment>
    <segment id="43">Nós praticamente tomamos</segment>
    <segment id="44">comocomo certo que os vaga-lumes estarão aqui para sempre”</segment>
    <segment id="45">, afirma o naturalista Ben Pfeiffer</segment>
    <segment id="46">, fundador da organização sem fins lucrativos Firefly Conservation &amp;amp</segment>
    <segment id="47">; Research e um dos especialistas em vaga-lumes pesquisados.</segment>
    <segment id="48">“E estamos terrivelmente errados.</segment>
    <segment id="49">”  Em 2018</segment>
    <segment id="50">, a União Internacional para a Conservação da Natureza criou o Firefly Specialist Group</segment>
    <segment id="51">, copresidido por Lewis</segment>
    <segment id="52">, para determinar</segment>
    <segment id="53">sese certas espécies desses insetos devem ser listadas</segment>
    <segment id="54">comocomo ameaçadas ou em perigo.</segment>
    <segment id="55">“Isso é algo que nunca vimos acontecer com uma espécie de vaga-lume”</segment>
    <segment id="56">, diz Christopher Cratsley</segment>
    <segment id="57">, biólogo da Universidade Estadual de Fitchburg.</segment>
    <segment id="58">A pesquisa representa um primeiro passo nesse processo</segment>
    <segment id="59">, de acordo com Lewis.</segment>
    <segment id="60">Novas formas de visualizar animais ameaçados   novamente         de   de  de  representando</segment>
    <segment id="61">um</segment>
  </rst>
</analysis>