  <rst>
    <segment id="1">O MBL (Movimento Brasil Livre) decidiu priorizar nestas eleições o eleitorado que já o conhece em São Paulo.</segment>
    <segment id="2">Pesquisas internas apontam que</segment>
    <segment id="3">, embora</segment>
    <segment id="4">embora essa fatia</segment>
    <segment id="5">sese resuma a pouco mais de um terço da população</segment>
    <segment id="6">, seria o suficiente para eleger suas principais lideranças.</segment>
    <segment id="7">Um dos puxadores de voto será o deputado federal Kim Kataguiri (União-SP)</segment>
    <segment id="8">, que poderá eleger mais parlamentares.</segment>
    <segment id="9">Como o MBL não é um partido formal</segment>
    <segment id="10">, as outras vagas serão preenchidas pela coligação.</segment>
    <segment id="11">Em uma pesquisa qualitativa</segment>
    <segment id="12">, os entrevistados apontaram identificar-</segment>
    <segment id="13">sese com ele por ser jovem</segment>
    <segment id="14">, apreciar animes e ser geek</segment>
    <segment id="15">, expressão usada para definir pessoas tímidas</segment>
    <segment id="16">, que gostam de jogos e computadores.</segment>
    <segment id="17">Vem daí sua presença em feiras de games e quadrinhos</segment>
    <segment id="18">, entre elas a BGS (Brasil Game Show)</segment>
    <segment id="19">, uma das maiores sobre o assunto.</segment>
    <segment id="20">Deputado federal Kim Kataguiri (Foto: Sergio Lima / AFP) - AFPA estratégia é consequência do escândalo que abateu o ex-deputado estadual Arthur do Val e frustrou os planos do grupo de</segment>
    <segment id="21">sese tornar mais conhecido fora da sua bolha.</segment>
    <segment id="22">A notícia boa para o movimento é que o levantamento mostra que</segment>
    <segment id="23">, embora</segment>
    <segment id="24">embora as declarações sexistas tenham dado visibilidade a Do Val e ele tenha</segment>
    <segment id="25">sese tornado o integrante mais conhecido do grupo</segment>
    <segment id="26">, o efeito negativo</segment>
    <segment id="27">sese restringiu ao ex-deputado</segment>
    <segment id="28">, sem afetar o restante das lideranças.</segment>
    <segment id="29">Em 2022</segment>
    <segment id="30">, o MBL lançará três candidatos a deputados federais — além de Kim</segment>
    <segment id="31">, o vereador Rubinho Nunes em São Paulo e o empresário Samuel Chang em Santa Catarina.</segment>
    <segment id="32">Também planejam de 10 a 15 candidaturas a deputado estadual pelo país.</segment>
    <segment id="33">Para 2024</segment>
    <segment id="34">, o partido quer ter lideranças aptas a disputarem prefeituras.</segment>
  </rst>
</analysis>