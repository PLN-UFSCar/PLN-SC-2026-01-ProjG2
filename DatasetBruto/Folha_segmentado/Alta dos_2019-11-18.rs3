  <rst>
    <segment id="1">Uma cortina esconde metade do estúdio de Gina Han</segment>
    <segment id="2">, no Distrito de Artes de Los Angeles.</segment>
    <segment id="3">Sob o tecido</segment>
    <segment id="4">, estão centenas de telas</segment>
    <segment id="5">, trabalhos da artista e do marido que o casal levou meses para juntar</segment>
    <segment id="6">, catalogar e empacotar.</segment>
    <segment id="7">Eles se</segment>
    <segment id="8">se preparam para deixar o local desde abril</segment>
    <segment id="9">, quando foram avisados de que o preço do aluguel subiria em novembro.</segment>
    <segment id="10">De US$ 979 (R$ 4.105)</segment>
    <segment id="11">, o valor saltará para US$ 2.264 (R$  9.469) —aumento de 131%.</segment>
    <segment id="12">“</segment>
    <segment id="13">Não consegui fazer nada nos últimos dois meses</segment>
    <segment id="14">, de preocupação.</segment>
    <segment id="15">Trabalhamos aqui por 21 anos</segment>
    <segment id="16">, então o acúmulo de obras de arte é enorme</segment>
    <segment id="17">, masmas esse aumento é impossível para nós”</segment>
    <segment id="18">, conta Han.</segment>
    <segment id="19">O destino das obras ainda é incerto.</segment>
    <segment id="20">Alta dos aluguéis ameaça permanência de comunidades de arte em Los Angeles   novamente         de   de  de  representando</segment>
    <segment id="21">um  Eles estão instalados desde 1998 na Colônia de Artes Santa Fé</segment>
    <segment id="22">, uma das poucas comunidades de artistas que restaram na região</segment>
    <segment id="23">, que passa por um intenso processo de gentrificação.</segment>
    <segment id="24">Criada com recursos públicos e abrigada numa antiga fábrica de móveis</segment>
    <segment id="25">, a comunidade tem uma restrição legal que impede grandes aumentos no valor dos aluguéis.</segment>
    <segment id="26">Hoje ficam ali 72 artistas.</segment>
    <segment id="27">Em 2018</segment>
    <segment id="28">, no entanto</segment>
    <segment id="29">, o endereço foi comprado pela Fifteen Group</segment>
    <segment id="30">, empresa de investimentos de Miami que planeja aumentar numa média de 137% os valores cobrados a partir deste mês</segment>
    <segment id="31">, quando expiram as restrições legais sobre os aluguéis.</segment>
    <segment id="32">Han passou os últimos meses sentada</segment>
    <segment id="33">, enfileirando e empilhando centenas de cubos coloridos</segment>
    <segment id="34">, para lutar contra o estresse e a ansiedade.</segment>
    <segment id="35">As peças</segment>
    <segment id="36">, dentre as poucas que ainda não foram empacotadas</segment>
    <segment id="37">, fazem parte de sua última obra.</segment>
    <segment id="38">“</segment>
    <segment id="39">Alguns amigos já tiveram de ir</segment>
    <segment id="40">embora</segment>
    <segment id="41">embora e</segment>
    <segment id="42">, no lugar deles</segment>
    <segment id="43">, entraram pessoas que não são artistas.</segment>
    <segment id="44">Hoje qualquer um que conseguir pagar o aluguel pode ficar”</segment>
    <segment id="45">, diz Han.</segment>
    <segment id="46">Embora a artista não viva mais no apartamento</segment>
    <segment id="47">, usado apenas</segment>
    <segment id="48">comocomo estúdio</segment>
    <segment id="49">, outros locatários ainda fazem do prédio sua casa.</segment>
    <segment id="50">Caso saiam</segment>
    <segment id="51">, precisarão encontrar espaços onde possam morar e trabalhar</segment>
    <segment id="52">, o que alguns declaram ser inviável na atual Los Angeles.</segment>
    <segment id="53">Cubos de Gina Han - Gina Han/DivulgaçãoA associação de inquilinos da comunidade chegou a fazer uma proposta para comprar o prédio</segment>
    <segment id="54">, masmas os novos donos</segment>
    <segment id="55">sese recusam a negociar</segment>
    <segment id="56">, o que</segment>
    <segment id="57">, de acordo com a instituição</segment>
    <segment id="58">, seria contra a lei.</segment>
    <segment id="59">Procurado pela Folha</segment>
    <segment id="60">, o Fifteen Group não</segment>
    <segment id="61">sese manifestou.</segment>
    <segment id="62">“</segment>
    <segment id="63">A piada é que eles compraram a propriedade por US$ 15 milhões (R$ 63 milhões) há 14 meses</segment>
    <segment id="64">, masmas agora dizem que vale US$ 7 milhões (R$ 29 milhões) a mais</segment>
    <segment id="65">, sendo que não fizeram nenhuma melhoria”</segment>
    <segment id="66">, afirma a pintora Sylvia Tidwell</segment>
    <segment id="67">, presidente da associação.</segment>
    <segment id="68">Longe de ser um</segment>
    <segment id="69">casocaso isolado</segment>
    <segment id="70">, a comunidade é um dos últimos bastiões da luta dos artistas para permanecer em uma vizinhança que parece ostentar seu nome de forma cada vez mais esvaziada.</segment>
    <segment id="71">Nascido nos anos 1970</segment>
    <segment id="72">, quando artistas ocuparam espaços em fábricas abandonadas na região</segment>
    <segment id="73">, o Distrito de Artes sofreu uma valorização nos últimos anos.</segment>
    <segment id="74">Com isso</segment>
    <segment id="75">, muitos artistas não conseguiram arcar com os novos custos e precisaram deixar o bairro.</segment>
    <segment id="76">“</segment>
    <segment id="77">As pessoas estão sendo expulsas sem nenhuma preocupação com o fato de Los Angeles ser uma capital artística”</segment>
    <segment id="78">, diz Francesco Siqueiros</segment>
    <segment id="79">, que trabalha com gravuras.</segment>
    <segment id="80">“</segment>
    <segment id="81">O uso do termo arte foi apropriado pelas construtoras</segment>
    <segment id="82">, que promovem o estilo de vida do artista</segment>
    <segment id="83">comocomo luxuoso.</segment>
    <segment id="84">É uma inversão da ideia do artista boêmio.</segment>
    <segment id="85">”</segment>
    <segment id="86">Apartamento de Francesco Siqueiros - Wild Don Lewis/DivulgaçãoHá cerca de dois meses</segment>
    <segment id="87">, um vídeo com uma moradora de rua cantando ópera no metrô de Los Angeles chamou a atenção da comunidade internacional</segment>
    <segment id="88">, tornando-</segment>
    <segment id="89">sese um exemplo de</segment>
    <segment id="90">comocomo a crise de moradia na cidade pode afetar os artistas.</segment>
    <segment id="91">Se os que estão estabelecidos há anos ainda têm dificuldade de</segment>
    <segment id="92">sese manter</segment>
    <segment id="93">, poucos jovens que chegam hoje a Los Angeles têm recursos suficientes para bancar grandes luxos.</segment>
    <segment id="94">Não à toa</segment>
    <segment id="95">, empresas de coabitação têm concentrado esforços na cidade.</segment>
    <segment id="96">Nesses locais</segment>
    <segment id="97">, em troca de aluguéis abaixo da média</segment>
    <segment id="98">, os moradores dormem em espaços minúsculos e compartilham cômodos.</segment>
    <segment id="99">Ainda assim</segment>
    <segment id="100">, alguns cobram mais de US$ 1.000 (R$ 4.193) por mês.</segment>
    <segment id="101">A brasileira Victoria Pfeifer chegou em Los Angeles há quatro anos disposta a</segment>
    <segment id="102">sese lançar</segment>
    <segment id="103">comocomo cantora.</segment>
    <segment id="104">Incapaz de arcar com os altos preços</segment>
    <segment id="105">, viveu na casa de um amigo por meses até conseguir uma vaga no UP(st)ART</segment>
    <segment id="106">, espaço de coabitação voltado para artistas.</segment>
    <segment id="107">“Procurei apartamento por muito tempo</segment>
    <segment id="108">, masmas não tinha nada abaixo de US$ 1.000.</segment>
    <segment id="109">Quando você converte para dólar</segment>
    <segment id="110">, nosso dinheiro vira nada</segment>
    <segment id="111">, e aqui tudo é muito caro.</segment>
    <segment id="112">”</segment>
    <segment id="113">A UP(st)ART é uma das únicas empresas de coabitação a oferecer moradia apenas para artistas.</segment>
    <segment id="114">Seu criador</segment>
    <segment id="115">, Jeremiah Adler</segment>
    <segment id="116">, teve a ideia a partir de uma experiência própria.</segment>
    <segment id="117">“Vim para Los Angeles com o sonho de ser roteirista e diretor de TV.</segment>
    <segment id="118">Atuei na área por três anos</segment>
    <segment id="119">, masmas meu dinheiro acabou e tive que arrumar outro emprego.</segment>
    <segment id="120">Passei a trabalhar numa imobiliária</segment>
    <segment id="121">, na qual via jovens ambiciosos e criativos tendo propostas de aluguel negadas todos os dias por não ganharem o suficiente.</segment>
    <segment id="122">”  A empresa</segment>
    <segment id="123">, que hoje mantém sete propriedades em Los Angeles</segment>
    <segment id="124">, oferece</segment>
    <segment id="125">, além de moradia mais barata</segment>
    <segment id="126">, espaços onde os artistas podem</segment>
    <segment id="127">sese desenvolver</segment>
    <segment id="128">, como</segment>
    <segment id="129">como estúdios de gravação</segment>
    <segment id="130">, ateliês e salas de cinema.</segment>
    <segment id="131">Ali, Pfeifer paga US$ 700 (R$ 2.927) mensais para viver em um pod (cama embutida na parede)</segment>
    <segment id="132">, num quarto que divide com outras cinco jovens.</segment>
    <segment id="133">Artistas moradoras e espaço de coabitação em Los Angele - Apu Gomes/AFP“É bom ter gente em volta</segment>
    <segment id="134">, sempre há com quem conversar.</segment>
    <segment id="135">O lado ruim também é ter gente em volta</segment>
    <segment id="136">, porque</segment>
    <segment id="137">porque você precisa aprender a conviver com pessoas e barulho mesmo quando só quer ficar sozinho ou ensaiar”</segment>
    <segment id="138">, diz a cantora.</segment>
    <segment id="139">Além da Colônia de Arte Santa Fé</segment>
    <segment id="140">, o Art Share LA é outro dos poucos espaços remanescentes no Distrito de Artes a abrigar artistas a preços baixos.</segment>
    <segment id="141">São 30 apartamentos</segment>
    <segment id="142">, todos ocupados.</segment>
    <segment id="143">Na lista de espera constam 850 pessoas.</segment>
    <segment id="144">“</segment>
    <segment id="145">Há uns dez anos</segment>
    <segment id="146">, eu recebia diariamente emails de artistas vindos de vários locais pedindo um lugar para viver na cidade.</segment>
    <segment id="147">Essas mensagens já não chegam mais com tanta frequência”</segment>
    <segment id="148">, conta Cheyanne Sauter</segment>
    <segment id="149">, diretora-executiva da instituição.</segment>
    <segment id="150">“</segment>
    <segment id="151">As pessoas estão tão assustadas com os preços das casas e aluguéis que nem tentam mais vir.</segment>
    <segment id="152">Se não investirmos mais nos indivíduos criativos que vivem aqui</segment>
    <segment id="153">, eles encontrarão outros lugares</segment>
    <segment id="154">, o que ameaça o status de Los Angeles</segment>
    <segment id="155">comocomo nossa principal capital da arte.</segment>
    <segment id="156">”​</segment>
  </rst>
</analysis>