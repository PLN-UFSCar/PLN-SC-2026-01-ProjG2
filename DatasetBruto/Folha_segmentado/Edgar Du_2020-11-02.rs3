    <segment id="5">As estatuetas</segment>
    <segment id="6">, em bronze</segment>
    <segment id="7">, são inspiradas em uma fotografia de Mujica tomando chimarrão.</segment>
    <segment id="8">Elas terão cerca de 40 centímetros e serão numeradas</segment>
    <segment id="9">, em edição limitada de 50 peças.</segment>
