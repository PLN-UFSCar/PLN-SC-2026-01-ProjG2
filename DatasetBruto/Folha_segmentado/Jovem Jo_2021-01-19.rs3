  <rst>
    <segment id="1">Logo nos primeiros dias na escola preparatória Archmere Academy</segment>
    <segment id="2">, onde finalizou o ensino médio na cidade de Claymont</segment>
    <segment id="3">, estado do Delaware</segment>
    <segment id="4">, Joe Biden foi apelidado de "</segment>
    <segment id="5">Dash"</segment>
    <segment id="6">(palavra de vários significados</segment>
    <segment id="7">, entre eles colisão</segment>
    <segment id="8">, ímpeto e corrida).</segment>
    <segment id="9">Poderia ser</segment>
    <segment id="10">porque</segment>
    <segment id="11">porque corria rápido</segment>
    <segment id="12">, o que era verdade.</segment>
    <segment id="13">Mas foi pelo seu jeito atropelado de falar</segment>
    <segment id="14">, tropeçando nas palavras.</segment>
    <segment id="15">O garoto tinha gagueira crônica.</segment>
    <segment id="16">Nesta quarta-feira (20)</segment>
    <segment id="17">, aos 78 anos</segment>
    <segment id="18">, Biden toma posse</segment>
    <segment id="19">comocomo o 46º presidente dos Estados Unidos.</segment>
    <segment id="20">Joe Biden discursa</segment>
    <segment id="21">comocomo presidente eleito dos EUAMais    novamente         de   de  de  representando um</segment>
    <segment id="22">O adolescente que limpava janelas para ajudar os pais a pagar o prestigioso colégio encontrou no esporte uma maneira de</segment>
    <segment id="23">sese destacar.</segment>
    <segment id="24">Ele foi o astro do time de futebol americano na temporada de 1960.  Archmere</segment>
    <segment id="25">, que vinha de sucessivos campeonatos ruins</segment>
    <segment id="26">, terminou aquele ano invicto</segment>
    <segment id="27">, com oito vitórias em oito jogos e o título da conferência.</segment>
    <segment id="28">Como halfback (jogador que corre com a bola) ou wide receiver (recebedor de passes)</segment>
    <segment id="29">, Biden também passou a ter maior autoestima.  "</segment>
    <segment id="30">Apesar de eu não ter confiança na minha habilidade para me comunicar verbalmente</segment>
    <segment id="31">, sempre tive confiança na minha habilidade atlética.</segment>
    <segment id="32">Esporte era algo tão natural para mim quanto falar era não natural.</segment>
    <segment id="33">E o esporte foi meu ingresso para ser aceito —e mais.</segment>
    <segment id="34">Eu não era intimidado com facilidade em uma partida</segment>
    <segment id="35">, então</segment>
    <segment id="36">, mesmo</segment>
    <segment id="37">sese eu gaguejasse</segment>
    <segment id="38">, era o garoto que dizia: 'me dê a bola"'</segment>
    <segment id="39">, ele escreveu em seu livro de memórias "</segment>
    <segment id="40">Promises to keep: on life and politics" (Promessas a manter: na vida e política</segment>
    <segment id="41">, sem publicação no Brasil).</segment>
    <segment id="42">"</segment>
    <segment id="43">Joe era muito veloz.</segment>
    <segment id="44">Era o jogador para você procurar em campo nas situações difíceis.</segment>
    <segment id="45">Nas nossas oito vitórias</segment>
    <segment id="46">, ele foi peça fundamental"</segment>
    <segment id="47">, disse Robert Markel</segment>
    <segment id="48">, colega de Biden na equipe da Archmere Academy.</segment>
    <segment id="49">A trajetória de Joe BidenMais    novamente         de   de  de  representando um</segment>
    <segment id="50">Em entrevista ao The New York Times em 2008</segment>
    <segment id="51">, John Walsh</segment>
    <segment id="52">, técnico de Biden na mesma escola afirmou que o político era o melhor recebedor do time e poderia ter</segment>
    <segment id="53">sese destacado no college football</segment>
    <segment id="54">, o campeonato universitário.</segment>
    <segment id="55">"Biden é o realmente o wide receiver que mais</segment>
    <segment id="56">sese destaca"</segment>
    <segment id="57">, escreveu o The News Journal</segment>
    <segment id="58">, de Wilmington</segment>
    <segment id="59">, sobre os jogadores da academia durante a temporada em 1960.</segment>
    <segment id="60">Quando Walsh foi introduzido no hall da fama do esporte do Delaware</segment>
    <segment id="61">, em 2012</segment>
    <segment id="62">, o então vice-presidente dos EUA aceitou o convite para fazer um discurso em homenagem ao seu antigo treinador.</segment>
    <segment id="63">"</segment>
    <segment id="64">Walsh nos pediu para jogar da mesma forma</segment>
    <segment id="65">comocomo vivíamos a nossa vida</segment>
    <segment id="66">, com paixão e integridade"</segment>
    <segment id="67">, disse.</segment>
    <segment id="68">"</segment>
    <segment id="69">Não importa o quão bom você é</segment>
    <segment id="70">, o importante é fazer parte de uma equipe.</segment>
    <segment id="71">"</segment>
    <segment id="72">Com a mudança na Casa Branca</segment>
    <segment id="73">, sede do governo americano</segment>
    <segment id="74">, o comando do país muda de um ex-cartola para um ex-atleta amador.</segment>
    <segment id="75">Donald Trump foi dono</segment>
    <segment id="76">, de 1984 a 1985</segment>
    <segment id="77">, do New Jersey Generals</segment>
    <segment id="78">, franquia de futebol americano que fazia parte da extinta USFL</segment>
    <segment id="79">, campeonato criado para competir com a NFL (a liga profissional predominante do esporte).</segment>
    <segment id="80">O documentário "Small</segment>
    <segment id="81">Potatoes: who killed the USFL?</segment>
    <segment id="82">" diz ter sido Trump o responsável pelo fim da entidade por insistir que ela</segment>
    <segment id="83">, que realizava seu torneio no verão americano e concorria com a temporada de beisebol</segment>
    <segment id="84">, mudasse para a época de outono e inverno para bater de frente com a NFL.</segment>
    <segment id="85">Joe Biden discursa em Wilmington</segment>
    <segment id="86">, Delaware</segment>
    <segment id="87">, estado onde morou na juventude - Tom Brenner-14.jan.21/ReutersInstigados pelo dono dos Generals</segment>
    <segment id="88">, os demais dirigentes da USFL entraram com processo de US$ 567 milhões (R$ 3</segment>
    <segment id="89">,3 bilhões em valores atuais) contra a NFL por suposto monopólio.</segment>
    <segment id="90">Tiveram decisão favorável</segment>
    <segment id="91">, masmas a indenização determinada pelo juiz foi de US$ 1.</segment>
    <segment id="92">Com a multa aplicada</segment>
    <segment id="93">, o valor passou a US$ 3.</segment>
    <segment id="94">A USFL faliu.</segment>
    <segment id="95">Dirigentes depois acusaram Trump de querer promover um acordo que lhe desse uma franquia da NFL</segment>
    <segment id="96">, de preferência em Las Vegas</segment>
    <segment id="97">, onde tinha cassino.</segment>
    <segment id="98">Não deu certo.</segment>
    <segment id="99">A decepção o teria empurrado para a política e</segment>
    <segment id="100">, em 2016</segment>
    <segment id="101">, para a eleição presidencial que venceu.</segment>
    <segment id="102">Esperava-</segment>
    <segment id="103">sese que o novo presidente fosse destaque em campo também na Universidade do Delaware</segment>
    <segment id="104">, onde</segment>
    <segment id="105">sese matriculou para estudar história e ciências políticas.</segment>
    <segment id="106">Ele conseguiu ser selecionado para a equipe</segment>
    <segment id="107">, masmas foi um wide receiver discreto.</segment>
    <segment id="108">Biden foi criticado em 2012 por veículos de imprensa conservadores ao falar a respeito de sua participação em um jogo contra a Universidade de Ohio.</segment>
    <segment id="109">O então vice-presidente deu detalhes do confronto e o placar (corretamente).</segment>
    <segment id="110">Mas os registros da Universidade de Delaware mostram que ele não atuou na partida.</segment>
    <segment id="111">O político admite que não teve boa carreira esportiva universitária.</segment>
    <segment id="112">Além de ser pouco escalado</segment>
    <segment id="113">, suas notas foram ruins em 1962.</segment>
    <segment id="114">Seu pai</segment>
    <segment id="115">, então</segment>
    <segment id="116">, pediu que ele deixasse a equipe e focasse os estudos.  Joe Biden</segment>
    <segment id="117">comocomo jogador de futebol americano na Archmere Academy - ReproduçãoDepois de mais de dois anos parado</segment>
    <segment id="118">, Biden resolveu tentar novamente e foi selecionado para a equipe</segment>
    <segment id="119">comocomo defensor</segment>
    <segment id="120">, algo que o surpreendeu.</segment>
    <segment id="121">Nas férias seguintes</segment>
    <segment id="122">, na Flórida</segment>
    <segment id="123">, ele conheceu Neilia Hunter e</segment>
    <segment id="124">sese apaixonou.</segment>
    <segment id="125">Entre passar os finais de semana com a namorada</segment>
    <segment id="126">, com quem</segment>
    <segment id="127">sese casaria em 1966</segment>
    <segment id="128">, ou jogar futebol</segment>
    <segment id="129">, Biden escolheu Neilia e abandonou de vez o time.</segment>
    <segment id="130">Após deixar a universidade</segment>
    <segment id="131">, ele trabalhou</segment>
    <segment id="132">comocomo advogado.</segment>
    <segment id="133">Aos 30 anos</segment>
    <segment id="134">, em 1972</segment>
    <segment id="135">, tornou-</segment>
    <segment id="136">sese senador</segment>
    <segment id="137">, cargo que manteve em eleições sucessivas por 36 anos.</segment>
    <segment id="138">Em 2008</segment>
    <segment id="139">, foi eleito</segment>
    <segment id="140">comocomo vice na chapa liderada por Barack Obama e</segment>
    <segment id="141">, no ano passado</segment>
    <segment id="142">, derrotou Trump no pleito presidencial.</segment>
  </rst>
</analysis>