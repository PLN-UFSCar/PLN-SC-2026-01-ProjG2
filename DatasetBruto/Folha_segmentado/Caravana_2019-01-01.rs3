  <rst>
    <segment id="1">“Vou passar um negocinho no visor</segment>
    <segment id="2">, quem quiser</segment>
    <segment id="3">sese emocionar pode.</segment>
    <segment id="4">Solta o som</segment>
    <segment id="5">, DJ!</segment>
    <segment id="6">”</segment>
    <segment id="7">A viagem completava duas horas e meia das 18 que levaria quando Marcia Cristina</segment>
    <segment id="8">, 53, anunciou aos 25 passageiros que o espetáculo ia começar.</segment>
    <segment id="9">A única TV do ônibus passou a exibir montagens com o homem que motivou o grupo a sair de São Paulo às 17h30 do último dia de 2018 rumo ao que</segment>
    <segment id="10">, nas palavras do funcionário público Alexandre Barbosa</segment>
    <segment id="11">, 40, “talvez seja o evento mais importante da história do país desde as Diretas Já”: a posse presidencial de Jair Bolsonaro.</segment>
    <segment id="12">“</segment>
    <segment id="13">A Caravana da Esperança” é</segment>
    <segment id="14">comocomo Marcia batizou o comboio que faria um bate-volta São Paulo-Brasília.</segment>
    <segment id="15">Seriam quase 40 horas e 2.000 km a bordo para ficarem menos de oito horas na capital brasileira.</segment>
    <segment id="16">Pelo “mito”</segment>
    <segment id="17">, diziam</segment>
    <segment id="18">, vale tudo.</segment>
    <segment id="19">Apoiadores de Bolsonaro fazem caravana para assistir à posse   novamente         de   de  de  representando um  “Do You Hear the People Sing?</segment>
    <segment id="20">”, tema do musical “</segment>
    <segment id="21">Os Miseráveis” sobre “a canção dos homens furiosos”</segment>
    <segment id="22">, ecoou no veículo que trazia na lateral a inscrição</segment>
    <segment id="23">“super luxo”.</segment>
    <segment id="24">Muitos ali vieram de periferias ou cidades vizinhas da capital paulista e penaram para pagar os R$ 300 cobrados.</segment>
    <segment id="25">Para o jantar numa parada de ônibus em Ribeirão Preto</segment>
    <segment id="26">, parte foi de comida a quilo com “My Heart Will Go On” (o tema de “Titanic”) de trilha.</segment>
    <segment id="27">Para a ceia</segment>
    <segment id="28">, improvisada já à 1h num posto de beira de estrada</segment>
    <segment id="29">, cada um trouxe algo: torta de frango</segment>
    <segment id="30">, pirulito</segment>
    <segment id="31">, uvas.</segment>
    <segment id="32">Houve brindes com espumante</segment>
    <segment id="33">, sidra e “vinho baratinho”.</segment>
    <segment id="34">“Chama um macho para ajudar a Beth”</segment>
    <segment id="35">, alguém pediu</segment>
    <segment id="36">, e homens apareceram para abrir a garrafa que nem vencedor de Fórmula 1</segment>
    <segment id="37">, bandeiras de Israel e Brasil tremulando ao fundo.</segment>
    <segment id="38">O desemprego anabolizado pela crise econômica fez com que vários deles —e não são poucos com passado petista— abraçassem o bolsonarismo.</segment>
    <segment id="39">A dona de casa e ex-modelo plus size Geruza Celestino</segment>
    <segment id="40">, 49, viu 60 colegas perderem o emprego numa casa noturna onde trabalhou</segment>
    <segment id="41">comocomo caixa.</segment>
    <segment id="42">Em seu Ceará natal então</segment>
    <segment id="43">, nem se</segment>
    <segment id="44">se fala.</segment>
    <segment id="45">Ela é cética quando lhe dizem que Bolsonaro perdeu no Nordeste.</segment>
    <segment id="46">Tudo o que é canto de lá foi de 17 na eleição</segment>
    <segment id="47">, ao menos é o que mostravam os vídeos que recebia pelo WhatsApp.</segment>
    <segment id="48">O nordestino é um povo batalhador</segment>
    <segment id="49">, masmas “existe uma coisa muito errada nele”</segment>
    <segment id="50">, disse Geruza.</segment>
    <segment id="51">“</segment>
    <segment id="52">O Bolsa Família estragou um pouco</segment>
    <segment id="53">, ninguém quer trabalhar mais.</segment>
    <segment id="54">”</segment>
    <segment id="55">“</segment>
    <segment id="56">Fui petista</segment>
    <segment id="57">, acreditava muito.</segment>
    <segment id="58">Mas como</segment>
    <segment id="59">como um partido do trabalhador deixou milhões de desempregados?</segment>
    <segment id="60">”, questionou a dona do “vinho baratinho</segment>
    <segment id="61">, masmas gostoso”</segment>
    <segment id="62">, um Goés (cerca de R$ 25 a garrafa).</segment>
    <segment id="63">Foi a segurança pública que fez o servidor Alexandre definir a posse de Bolsonaro</segment>
    <segment id="64">comocomo o principal acontecimento da história recente do país.</segment>
    <segment id="65">Veja seu</segment>
    <segment id="66">casocaso: só em 2018</segment>
    <segment id="67">, foi assaltado três vezes.</segment>
    <segment id="68">Numa delas</segment>
    <segment id="69">, levaram a moto que usava no trabalho.</segment>
    <segment id="70">“Cheguei a tomar tapa.</segment>
    <segment id="71">”</segment>
    <segment id="72">Gostou de ouvir que o novo presidente será duro com criminosos e decretará o armamento civil.</segment>
    <segment id="73">Quer uma arma para si —já aprendeu a atirar com seis modelos</segment>
    <segment id="74">, inclusive uma espingarda calibre 12</segment>
    <segment id="75">, “uma maravilha</segment>
    <segment id="76">, estoura uma cabeça”.</segment>
    <segment id="77">De Praia Grande (litoral paulista)</segment>
    <segment id="78">, Alexandre é também “mago iniciado na magia dos arcanjos”</segment>
    <segment id="79">, formado pela Escola Esotérica Luz da Lua.</segment>
    <segment id="80">Com um pingente de pentagrama sobre a camisa amarela com o lema bolsonarista</segment>
    <segment id="81">“meu partido é o Brasil”</segment>
    <segment id="82">, contou que</segment>
    <segment id="83">, a duas semanas da eleição</segment>
    <segment id="84">, as cartas do tarô lhe revelaram a vitória de seu candidato.</segment>
    <segment id="85">Não titubeou ao “embarcar nessa energia boa” que</segment>
    <segment id="86">, apostou</segment>
    <segment id="87">, fluirá em Brasília nesta terça (1º).</segment>
    <segment id="88">Com ele trouxe bolo de chocolate de massa pronta e chá gelado: é um “cara simples”</segment>
    <segment id="89">comocomo Bolsonaro</segment>
    <segment id="90">, que toma café no copo americano</segment>
    <segment id="91">, afirmou.</segment>
    <segment id="92">O trajeto começou com uma oração puxada por uma lacrimejante Marcia</segment>
    <segment id="93">, fiel da primeira das Assembleias de Deus</segment>
    <segment id="94">, fundada em 1911 em sua terra</segment>
    <segment id="95">, Belém do Pará.</segment>
    <segment id="96">Marcia também era fiel ao PT</segment>
    <segment id="97">, a sindicatos</segment>
    <segment id="98">, o “pacote vermelho” todo.</segment>
    <segment id="99">Com o petismo</segment>
    <segment id="100">sese desiludiu antes da eleição de Lula</segment>
    <segment id="101">, quando a cúpula forçou diretórios locais a coligações indecorosas.</segment>
    <segment id="102">Acha que Lula</segment>
    <segment id="103">sese transformou “num burguês por excelência”.</segment>
    <segment id="104">Marcia contou que viu o PSOL nascer.</segment>
    <segment id="105">O pai da filha</segment>
    <segment id="106">, de quem já</segment>
    <segment id="107">sese separou</segment>
    <segment id="108">, ainda é ligado à sigla repudiada pela massa bolsonarista.</segment>
    <segment id="109">Agora ali está ela</segment>
    <segment id="110">, a ex-petista que perdeu até a fome de tanto nervoso que passou organizando a caravana.</segment>
    <segment id="111">“</segment>
    <segment id="112">A direita nasceu em 2018.</segment>
    <segment id="113">Antes era a falsa direita.</segment>
    <segment id="114">”  Priscila Colturato</segment>
    <segment id="115">, 31, disse que nunca caiu no papo esquerdista.</segment>
    <segment id="116">Estava mais inclinada ao tucanato quando achava que ser PSDB</segment>
    <segment id="117">“era de direita”.</segment>
    <segment id="118">Hoje milita no movimento Direita São Paulo.</segment>
    <segment id="119">Morou anos na periferia</segment>
    <segment id="120">, e lá</segment>
    <segment id="121">, segundo ela</segment>
    <segment id="122">, “o PT não ajudava coisa nenhuma”.</segment>
    <segment id="123">Também não acha que o discurso da esquerda bastou quando</segment>
    <segment id="124">, segundo relata</segment>
    <segment id="125">, foi estuprada há quatro anos por um colega de faculdade que</segment>
    <segment id="126">sese aproveitou de sua deficiência visual (ela tem cegueira parcial).</segment>
    <segment id="127">Tomava 12 medicamentos para superar o trauma.</segment>
    <segment id="128">Para ela</segment>
    <segment id="129">, a esquerda zela mais pelos direitos do bandido do que pelos da vítima.</segment>
    <segment id="130">O ativismo na direita</segment>
    <segment id="131">, disse</segment>
    <segment id="132">, a resgatou.</segment>
    <segment id="133">Cita o fato de Bolsonaro ter dito que estuprador tinha que sofrer castração química.</segment>
    <segment id="134">“Pensei: nossa</segment>
    <segment id="135">, um homem defendendo as mulheres?</segment>
    <segment id="136">”  Até ficava ressabiada quando via o deputado Bolsonaro dizer à colega Maria do Rosário (PT) que não a estuprava</segment>
    <segment id="137">porque</segment>
    <segment id="138">porque “você não merece”.</segment>
    <segment id="139">Mas foi à internet</segment>
    <segment id="140">“para pesquisar” e agora acha que ela provocou primeiro.</segment>
    <segment id="141">Priscila</segment>
    <segment id="142">, que se</segment>
    <segment id="143">se diz ativista</segment>
    <segment id="144">, oscilou quando questionada sobre a promessa do novo presidente de “botar um ponto final em todos os ativismos no Brasil”.</segment>
    <segment id="145">Acha que no futuro “as pessoas vão</segment>
    <segment id="146">sese conscientizar”</segment>
    <segment id="147">, e sua luta será desnecessária.</segment>
    <segment id="148">Agora, disse ela</segment>
    <segment id="149">, que é evangélica</segment>
    <segment id="150">, nada de “kit gay nem kit hétero”.</segment>
    <segment id="151">A TV do ônibus exibiu uma paródia que rebatizou a Folha de Foice de S.Paulo</segment>
    <segment id="152">, numa simulação da primeira página do jornal: uma invasão dos amarelos minions (para brincar com o apelido bolsominion) ao Distrito Federal.</segment>
    <segment id="153">Além do Hino Nacional Brasileiro e de jingles bolsonaristas</segment>
    <segment id="154">, uma montagem criticou a “campanha negativa” do outro lado</segment>
    <segment id="155">, com o mote #EleNão.</segment>
    <segment id="156">Em seguida</segment>
    <segment id="157">, o vídeo elencou prioridades (ser contra o comunismo</segment>
    <segment id="158">, o petismo) e fotos de personae non gratae</segment>
    <segment id="159">, como</segment>
    <segment id="160">como dois ícones LGBTQ</segment>
    <segment id="161">, Daniela Mercury e Pablo Vittar.</segment>
    <segment id="162">Para Geruza</segment>
    <segment id="163">, é simples.</segment>
    <segment id="164">“Tenho tios gays.</segment>
    <segment id="165">Não só um</segment>
    <segment id="166">, quatro.</segment>
    <segment id="167">Tenho um irmão gay.</segment>
    <segment id="168">Nunca comentaram nada em casa.</segment>
    <segment id="169">Dentro de casa existe uma coisa chamado respeito.</segment>
    <segment id="170">”</segment>
    <segment id="171">Tudo bem que Bolsonaro já declarou preferir um filho morto a gay.</segment>
    <segment id="172">Mas não o leve ao pé da letra</segment>
    <segment id="173">, propôs a ex-modelo.</segment>
    <segment id="174">“Militares são assim</segment>
    <segment id="175">, meio grosseirão</segment>
    <segment id="176">, masmas de bom coração.</segment>
    <segment id="177">”  Deu meia-noite e</segment>
    <segment id="178">, com o ônibus na estrada</segment>
    <segment id="179">, ouviu-</segment>
    <segment id="180">sese um “amém” ali</segment>
    <segment id="181">, outro “viva Bolsonaro” aqui.</segment>
    <segment id="182">Alguém sugeriu abrir um vídeo no YouTube com fogos de artifício.</segment>
    <segment id="183">Apagado no banco</segment>
    <segment id="184">, Leonardo</segment>
    <segment id="185">, 10, era a única criança do grupo.</segment>
    <segment id="186">Ainda em São Paulo</segment>
    <segment id="187">, sua mãe</segment>
    <segment id="188">, Vanuza Reis</segment>
    <segment id="189">, 45, contava que espera levá-lo em muitas posses de um Bolsonaro: primeiro a de Jair</segment>
    <segment id="190">, depois a de seus filhos</segment>
    <segment id="191">, um de cada vez</segment>
    <segment id="192">, até chegar a vez da caçula Laura</segment>
    <segment id="193">, 8, que brincou ser “a namoradinha” do filho.</segment>
    <segment id="194">Quando a Folha perguntou</segment>
    <segment id="195">sese o menino com camisa do Homem Aranha gostava de Bolsonaro</segment>
    <segment id="196">, ele deu de ombros.</segment>
    <segment id="197">A mãe ratificou:</segment>
    <segment id="198">“Ele foi comigo em todas as manifestações na Paulista”.</segment>
    <segment id="199">A simpatia por Israel manifestada pelo presidente contagiou sua base.</segment>
    <segment id="200">A noite terminou com um amigo oculto em que os passageiros (a maioria</segment>
    <segment id="201">sese conheceu ali mesmo) sorteavam uns para os outros pulseiras coloridas estilo fitinha do Senhor do Bonfim</segment>
    <segment id="202">, só que com palavras em português e hebraico: respeito</segment>
    <segment id="203">, amor etc.</segment>
    <segment id="204">A repórter ganhou uma laranja da alegria.</segment>
    <segment id="205">Todos caíram no sono.</segment>
    <segment id="206">Café da manhã já em Goiás</segment>
    <segment id="207">, e a organizadora Marcia</segment>
    <segment id="208">, depois de dar uma bronca coletiva</segment>
    <segment id="209">porque</segment>
    <segment id="210">porque ninguém mandava registros da “road trip” para o grupo de WhatsApp (“não tem uma única foto</segment>
    <segment id="211">, só uma no começo”)</segment>
    <segment id="212">, cortou um pão.</segment>
    <segment id="213">Pegou a faca e simulou que esfaquearia a amiga</segment>
    <segment id="214">, uma brincadeira com o atentado contra Bolsonaro.</segment>
    <segment id="215">A Caravana da Esperança só chegaria ao Planalto Central às 11h</segment>
    <segment id="216">, ultrapassando um comboio amigo que foi parado pela Polícia Rodoviária (os policiais só queriam dar as boas-vindas</segment>
    <segment id="217">, passar orientações e “tomar uma champanhe”</segment>
    <segment id="218">, explicou a organização do lado de lá).</segment>
    <segment id="219">Alexandre sabia desde o começo que seria puxado</segment>
    <segment id="220">, masmas que valeria a pena participar daquele momento de “resgate da civilidade” no Brasil.</segment>
    <segment id="221">Nem que seja para dar um tchauzinho para o capitão.</segment>
    <segment id="222">”</segment>
  </rst>
</analysis>