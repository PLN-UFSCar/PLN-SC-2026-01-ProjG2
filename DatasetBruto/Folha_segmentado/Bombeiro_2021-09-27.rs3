  <rst>
    <segment id="1">Dois cães foram resgatados de dentro de um bueiro na avenida Dom Aguirre</segment>
    <segment id="2">, em Sorocaba (99 km de SP)</segment>
    <segment id="3">, no último domingo (26).</segment>
    <segment id="4">Moradores da região tentaram fazer o resgate</segment>
    <segment id="5">, masmas não conseguiram e tiveram que contatar o Corpo de Bombeiros</segment>
    <segment id="6">, que enviou uma equipe e auxiliou na retirada da tampa de concreto.</segment>
    <segment id="7">Na manhã de domingo</segment>
    <segment id="8">, Patrícia Ortega Carneiro</segment>
    <segment id="9">, 46 anos</segment>
    <segment id="10">, estava passeando com o marido de bicicleta</segment>
    <segment id="11">, ouviu alguns latidos e viu que alguns garis estavam perto de uma boca de lobo no local.</segment>
    <segment id="12">“Eu escutei os cachorros chorando e vi um gari tentando levantar a tampa do bueiro.</segment>
    <segment id="13">Muitas pessoas pararam para ajudar</segment>
    <segment id="14">, masmas a tampa era muito pesada”</segment>
    <segment id="15">, relembra a auxiliar administrativa</segment>
    <segment id="16">, ao Agora.</segment>
    <segment id="17">“</segment>
    <segment id="18">Até que um menino correu até os bombeiros e pediu ajuda.</segment>
    <segment id="19">Eles vieram com alguns equipamentos e foi possível fazer o resgate”</segment>
    <segment id="20">, diz Patrícia.</segment>
    <segment id="21">Dois cachorros foram resgatados de bueiro em Sorocaba</segment>
    <segment id="22">, neste domingo (26) - Patrícia Carneiro/Arquivo Pessoal​Depois de retirarem o tampo de concreto</segment>
    <segment id="23">, os cachorros foram laçados com uma corda e puxados para fora.</segment>
    <segment id="24">Os animais não</segment>
    <segment id="25">sese feriram e foram devolvidos ao dono.</segment>
    <segment id="26">Segundo Patrícia</segment>
    <segment id="27">, os cães estavam perdidos desde a última quinta-feira (23) e foram encontrados no domingo de manhã.</segment>
    <segment id="28">“</segment>
    <segment id="29">Um dos meninos reconheceu os cachorros e me indicou que o dono era de uma marmoraria da região.</segment>
    <segment id="30">Imediatamente entreguei ao funcionário que reside no local”</segment>
    <segment id="31">, destaca.</segment>
  </rst>
</analysis>