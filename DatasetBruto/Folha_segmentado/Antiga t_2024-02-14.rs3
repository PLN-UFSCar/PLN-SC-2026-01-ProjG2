  <rst>
    <segment id="1">Do céu</segment>
    <segment id="2">, parecem enormes geoglifos em forma de círculo</segment>
    <segment id="3">, masmas são</segment>
    <segment id="4">, na realidade</segment>
    <segment id="5">, a marca de uma técnica pré-hispânica que agricultores resgataram para enfrentar a crise climática nos altos planaltos andinos de Puno</segment>
    <segment id="6">, na fronteira entre o Peru e a Bolívia.</segment>
    <segment id="7">Planeta em transeUma newsletter com o que você precisa saber sobre mudanças climáticasCarregando</segment>
    <segment id="8">...</segment>
    <segment id="9">Trata-</segment>
    <segment id="10">sese dos "waru waru" —palavra em quéchua que significa cume—</segment>
    <segment id="11">, um invento do passado para proteger as culturas de batata e quinoa.</segment>
    <segment id="12">Durante décadas</segment>
    <segment id="13">, as pessoas especularam que seriam geoglifos feitos por extraterrestres</segment>
    <segment id="14">, lembram os moradores.</segment>
    <segment id="15">Desenhos formados no solo pelo uso da técnica agrícola &amp;#</segment>
    <segment id="16">039;waru waru&amp;#039</segment>
    <segment id="17">; em Puno</segment>
    <segment id="18">, no Peru - Juan Carlos Cisneros/AFP"É um sistema agrícola para poder enfrentar a mudança climática</segment>
    <segment id="19">, que mudou as estações do ano.</segment>
    <segment id="20">É muito benéfico em tempos de seca e geadas"</segment>
    <segment id="21">, disse o agricultor César Cutipa</segment>
    <segment id="22">, 42.</segment>
    <segment id="23">Nas planícies alagáveis de Acora</segment>
    <segment id="24">, localidade a 3.812 metros de altitude</segment>
    <segment id="25">, vizinha do lago Titicaca</segment>
    <segment id="26">, as comunidades implementaram seis "waru waru".</segment>
    <segment id="27">Esse tipo de camada de terra rodeada de água atinge até 100 m de comprimento</segment>
    <segment id="28">, entre 4 m e 10 m de largura e 1 m de altura.</segment>
    <segment id="29">Cutipa faz parte da comunidade aimará de Acora</segment>
    <segment id="30">, onde</segment>
    <segment id="31">sese cultiva esta milenar técnica agrícola.</segment>
    <segment id="32">Para construir o "waru waru"</segment>
    <segment id="33">, os agricultores abrem sulcos em áreas inundáveis</segment>
    <segment id="34">, até formar uma plataforma retangular</segment>
    <segment id="35">, onde é feito o plantio.</segment>
    <segment id="36">A água ao redor cria um microclima que mitiga o efeito desfavorável das geadas</segment>
    <segment id="37">, permitindo o desenvolvimento dos cultivos.</segment>
    <segment id="38">Técnica agrícola milenar &amp;#</segment>
    <segment id="39">039;waru waru&amp;#039</segment>
    <segment id="40">;</segment>
    <segment id="41">é resgatada no Peru e na BolíviaMais    novamente         de   de  de  representando um  Nos canais</segment>
    <segment id="42">, a água absorve o calor do sol durante o dia e o irradia</segment>
    <segment id="43">, de novo</segment>
    <segment id="44">, à noite.</segment>
    <segment id="45">Em 2023</segment>
    <segment id="46">, a temperatura atingiu -20°C em Puno</segment>
    <segment id="47">, em razão das geadas.</segment>
    <segment id="48">Recuperando o passado  "</segment>
    <segment id="49">A habilidade dos colonos pré-hispânicos conseguiu desenvolver essa tecnologia que aproveita ao máximo a capacidade hídrica da região e os tempos de inundação</segment>
    <segment id="50">, como</segment>
    <segment id="51">como as chuvas"</segment>
    <segment id="52">, explica o arqueólogo Velko Marusic</segment>
    <segment id="53">, do Ministério da Cultura de Puno.</segment>
    <segment id="54">Segundo Marusic</segment>
    <segment id="55">, os solos do altiplano são pobres e secos para a atividade agrícola.</segment>
    <segment id="56">Com essa técnica</segment>
    <segment id="57">, porém</segment>
    <segment id="58">porém, os agricultores plantam batatas nativas</segment>
    <segment id="59">, quinoa e cañihua (da mesma família da quinoa)</segment>
    <segment id="60">, consideradas superalimentos.</segment>
    <segment id="61">Os benefícios são evidentes nesses tempos de aquecimento global e de variações inesperadas do clima</segment>
    <segment id="62">, segundo os pesquisadores.  "</segment>
    <segment id="63">Em épocas de chuva</segment>
    <segment id="64">, os 'waru waru' não podem ser inundados</segment>
    <segment id="65">, porque</segment>
    <segment id="66">porque têm um sistema de drenagem inteligente</segment>
    <segment id="67">, que chega ao rio.</segment>
    <segment id="68">Têm muitas vantagens</segment>
    <segment id="69">, são uma tradição e um costume"</segment>
    <segment id="70">, disse o agrônomo Gastón Quispe</segment>
    <segment id="71">, 43.  "</segment>
    <segment id="72">Essa técnica ajuda a combater geadas</segment>
    <segment id="73">, a fertilizar solos</segment>
    <segment id="74">, a gerar microclimas e fauna"</segment>
    <segment id="75">, acrescentou Marusic.</segment>
    <segment id="76">Suas origens remontam a 2.000 anos na região aimará</segment>
    <segment id="77">, masmas o Império Inca (no século 15) deixou essa técnica de lado.</segment>
    <segment id="78">Os "waru waru" começaram a ser reconstruídos apenas na década de 1990.</segment>
    <segment id="79">"É uma atividade agrícola que</segment>
    <segment id="80">sese desenvolveu por mais de dois milênios no nosso país e</segment>
    <segment id="81">, pela ocupação inca</segment>
    <segment id="82">, foi abandonada</segment>
    <segment id="83">, porque</segment>
    <segment id="84">porque</segment>
    <segment id="85">sese tornou inviável"</segment>
    <segment id="86">, explicou Marusic.</segment>
    <segment id="87">Ele destaca que</segment>
    <segment id="88">, quando os conquistadores espanhóis chegaram</segment>
    <segment id="89">, no século 16</segment>
    <segment id="90">, não encontraram evidências de sua existência.</segment>
    <segment id="91">Em 2023</segment>
    <segment id="92">, quando Puno sofreu um dos maiores períodos de seca em quase seis décadas pela falta de chuvas</segment>
    <segment id="93">, segundo o Serviço Nacional de Meteorologia</segment>
    <segment id="94">, o uso dessa técnica permitiu aos agricultores enfrentar o déficit hídrico e a escassez de alimentos.</segment>
    <segment id="95">Em Acora</segment>
    <segment id="96">, para ter uma boa colheita</segment>
    <segment id="97">, os camponeses realizam também um ritual denominado "luqta" (missa</segment>
    <segment id="98">, na língua aimará)</segment>
    <segment id="99">, com doces e folhas de coca que jogam ao ar para pedir à Mãe Terra uma boa produção e que não caia granizo.</segment>
    <segment id="100">"</segment>
    <segment id="101">Podemos viver tranquilos aqui</segment>
    <segment id="102">, porque</segment>
    <segment id="103">porque temos nossa batata</segment>
    <segment id="104">, nossa quinoa e a cevada.</segment>
    <segment id="105">Podemos ficar tranquilos sem ir à cidade"</segment>
    <segment id="106">, disse a agricultora Valeria Nahua</segment>
    <segment id="107">, 22.</segment>
  </rst>
</analysis>