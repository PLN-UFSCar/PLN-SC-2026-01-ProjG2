  <rst>
    <segment id="1">Era uma terça-feira</segment>
    <segment id="2">, dia 29 de maio de 1973</segment>
    <segment id="3">, quando o Jornal da Paraíba publicou um artigo sobre Zé Limeira.</segment>
    <segment id="4">Mas o que importa aqui não é tanto o que foi dito sobre o violeiro e poeta popular paraibano.</segment>
    <segment id="5">Lá pelas tantas do texto</segment>
    <segment id="6">, no sexto parágrafo</segment>
    <segment id="7">, há a transcrição de alguns versos do artista.</segment>
    <segment id="8">“Eu já morei no Recife/ bem pertinho de socorro./ Ganhei 200 mil réis./ Comprei 200 cachorros./</segment>
    <segment id="9">O ano passado eu morri./ Mas este ano eu não morro.</segment>
    <segment id="10">”  Qualquer pessoa que ficou acordada no Brasil nos últimos anos provavelmente teve uma sensação de déjà-vu ao ler essas frases.</segment>
    <segment id="11">E é bem possível que tenha reconhecido</segment>
    <segment id="12">, embora</segment>
    <segment id="13">embora em versão um pouco diferente</segment>
    <segment id="14">, o trecho mais pop da música “Sujeito de Sorte”</segment>
    <segment id="15">, composta por Belchior e lançada no disco “Alucinação”</segment>
    <segment id="16">, de 1976 —ou seja</segment>
    <segment id="17">, três anos depois da edição do Jornal da Paraíba.</segment>
    <segment id="18">BelchiorMais    novamente         de   de  de  representando um  Essas dez palavras de “ano passado eu morri</segment>
    <segment id="19">, masmas esse ano eu não morro” viveram um estouro de popularidade nos últimos anos.</segment>
    <segment id="20">Viraram hino da juventude progressista</segment>
    <segment id="21">, batizaram bloco de Carnaval em São Paulo</segment>
    <segment id="22">, foram sampleadas por Emicida na faixa “AmarElo” e ganharam ares de slogan de resitência contra o racismo</segment>
    <segment id="23">, a transfobia e o governo Bolsonaro.</segment>
    <segment id="24">Isso sem falar no verniz ainda mais recente de otimismo e de autoajuda instagramável em tempos de pandemia.</segment>
    <segment id="25">Décadas atrás</segment>
    <segment id="26">, com Belchior</segment>
    <segment id="27">, essa mesma frase tinha forte apelo político e dialogava com a repressão da ditadura militar brasileira.</segment>
    <segment id="28">Mas vamos falar disso mais adiante</segment>
    <segment id="29">, porque</segment>
    <segment id="30">porque esses versos tampouco foram inventados pelo compositor cearense</segment>
    <segment id="31">, como</segment>
    <segment id="32">como muitos acreditam.</segment>
    <segment id="33">O nascimento é anterior</segment>
    <segment id="34">, justamente com Zé Limeira.</segment>
    <segment id="35">A mensagem surgiu</segment>
    <segment id="36">, na verdade</segment>
    <segment id="37">, como</segment>
    <segment id="38">como uma brincadeira.</segment>
    <segment id="39">Nascido provavelmente no fim do século 19 e morto nos anos 1950</segment>
    <segment id="40">, Zé Limeira é a própria definição de literatura oral no Brasil —ele não deixou nada escrito</segment>
    <segment id="41">, não foi fotografado nem teve a sua voz gravada.</segment>
    <segment id="42">Tudo o que sabemos sobre ele foi passado no boca a boca ao longo de gerações.</segment>
    <segment id="43">Com obra ligada à cantoria e ao repente</segment>
    <segment id="44">, Zé Limeira é o que chamaríamos hoje de poeta nonsense.</segment>
    <segment id="45">Suas rimas</segment>
    <segment id="46">, embora</segment>
    <segment id="47">embora corretas e metrificadas</segment>
    <segment id="48">, jamais faziam sentido e brincavam com o absurdo.</segment>
    <segment id="49">Em seus poemas</segment>
    <segment id="50">, Pedro Álvares Cabral foi inventor do telefone</segment>
    <segment id="51">, dom Pedro 2º governava a Palestina e o rei Salomão conhecia Napoleão.</segment>
    <segment id="52">É essa a gênese de “ano passado eu morri</segment>
    <segment id="53">, masmas esse ano eu não morro” —um flerte com o nonsense e com um senso de humor que lembra o meme "morreu</segment>
    <segment id="54">, masmas passa bem".</segment>
    <segment id="55">Ou seja</segment>
    <segment id="56">, sem o viés político que surgiu com Belchior e a carga social que ganhou hoje em dia.</segment>
    <segment id="57">&amp;#</segment>
    <segment id="58">039;O Idolatrado&amp;#039</segment>
    <segment id="59">;, xilogravura de Antonio Henrique do Amaral</segment>
    <segment id="60">, pertencente ao acervo do Masp - Masp/ReproduçãoIsso faz com esse seja um dos casos mais curiosos da literatura e do cancioneiro brasileiro.</segment>
    <segment id="61">O autor italiano Umberto Eco costumava dizer que os textos literários funcionam</segment>
    <segment id="62">comocomo mensagens lançadas em garrafas por seus autores</segment>
    <segment id="63">, cabendo então aos leitores a tarefa de decodificar e decifrar —e leitores de diferentes épocas podem ter diferentes chaves de interpretação.</segment>
    <segment id="64">É o que ocorre com Zé Limeira.</segment>
    <segment id="65">“</segment>
    <segment id="66">Ele era uma espécie de Didi Mocó</segment>
    <segment id="67">, queria divertir”</segment>
    <segment id="68">, conta o escritor Braulio Tavares.</segment>
    <segment id="69">“</segment>
    <segment id="70">Pelo que sei</segment>
    <segment id="71">, era um cara inculto</segment>
    <segment id="72">, analfabeto</segment>
    <segment id="73">, sem muita informação.</segment>
    <segment id="74">E o público achava graça justamente</segment>
    <segment id="75">porque</segment>
    <segment id="76">porque percebia o nonsense.</segment>
    <segment id="77">”</segment>
    <segment id="78">A falta de documentação histórica e a obra sem registro escrito fizeram com que a figura de Limeira</segment>
    <segment id="79">sese tornasse uma espécie de heterônimo coletivo.</segment>
    <segment id="80">Quando repentistas e cantadores brincavam com o absurdo</segment>
    <segment id="81">, eles costumavam atribuir a autoria dessas gozações ao poeta.</segment>
    <segment id="82">As rimas eram incorporadas à obra dele</segment>
    <segment id="83">, replicadas</segment>
    <segment id="84">, alteradas</segment>
    <segment id="85">, como</segment>
    <segment id="86">como num telefone sem fio.</segment>
    <segment id="87">E aí nasce um complicador extra</segment>
    <segment id="88">, já que é impossível cravar que “ano passado eu morri</segment>
    <segment id="89">, masmas esse ano eu não morro” foi de fato criado pelo paraibano.</segment>
    <segment id="90">“Zé Limeira reúne versos de outros cantadores assim</segment>
    <segment id="91">comocomo Lampião aglutina crimes de outros cangaceiros”</segment>
    <segment id="92">, afirma o escritor e pesquisador Astier Basílio</segment>
    <segment id="93">, que diz ter encontrado a certidão de óbito de Limeira durante pesquisas para escrever a biografia de outro personagem central nesta história —o jornalista e escritor paraibano Orlando Tejo.</segment>
    <segment id="94">Foi Basílio também que encontrou o recorte do Jornal da Paraíba que abre esta reportagem.</segment>
    <segment id="95">Orlando Tejo morreu em 2018 e é autor de “Zé Limeira</segment>
    <segment id="96">, o Poeta do Absurdo”.</segment>
    <segment id="97">Principal obra sobre o artista popular</segment>
    <segment id="98">, o livro foi lançado em 1973 e mistura ficção e jornalismo.</segment>
    <segment id="99">Apesar de Tejo ter transcrito no livro muitas das estrofes atribuídas a Limeira</segment>
    <segment id="100">, ele também inventou uma porção de outras e convidou escritores a fazerem o mesmo.</segment>
    <segment id="101">Com tudo creditado ao poeta do absurdo</segment>
    <segment id="102">, o autor ajudou a borrar ainda mais as fronteiras entre realidade e ficção.</segment>
    <segment id="103">Tanto que no livro de Tejo</segment>
    <segment id="104">, atualmente esgotado e sem novas edições</segment>
    <segment id="105">, os famosos versos surgem ligeiramente diferentes.</segment>
    <segment id="106">“Eu já cantei no Recife</segment>
    <segment id="107">,/ Dentro do Pronto Socorro</segment>
    <segment id="108">,/</segment>
    <segment id="109">Ganhei 200 mil réis</segment>
    <segment id="110">,/</segment>
    <segment id="111">Comprei 200 cachorro</segment>
    <segment id="112">,/</segment>
    <segment id="113">Morri</segment>
    <segment id="114">no ano</segment>
    <segment id="115">passado</segment>
    <segment id="116">,/ Mais esse ano eu não morro”</segment>
    <segment id="117">, diz a nova letra.</segment>
    <segment id="118">Como o artigo do Jornal da Paraíba é anterior ao livro</segment>
    <segment id="119">, porém</segment>
    <segment id="120">porém, as chances de o trecho ser mesmo de Zé Limeira aumentam.</segment>
    <segment id="121">“</segment>
    <segment id="122">Belchior provavelmente pescou isso da obra do Orlando Tejo”</segment>
    <segment id="123">, acredita Jotabê Medeiros</segment>
    <segment id="124">, jornalista e biógrafo do cantor.</segment>
    <segment id="125">O autor de “Belchior - Apenas um Rapaz Latino-americano”</segment>
    <segment id="126">, publicado pela Todavia em 2017</segment>
    <segment id="127">, lembra que o título</segment>
    <segment id="128">sese tornou best-seller nos anos 1970.</segment>
    <segment id="129">“E Belchior é o compositor com maior background literário naquela época”</segment>
    <segment id="130">, acrescenta.</segment>
    <segment id="131">Com letras que trazem referências a Dante Alighieri</segment>
    <segment id="132">, Olavo Bilac e Beatles</segment>
    <segment id="133">, por exemplo</segment>
    <segment id="134">, o cearense dá outras camadas às palavras de Zé Limeira.</segment>
    <segment id="135">“Tenho sangrado demais</segment>
    <segment id="136">,/ Tenho chorado pra cachorro/</segment>
    <segment id="137">Ano passado eu morri</segment>
    <segment id="138">,/ Mas esse ano eu não morro”</segment>
    <segment id="139">, canta ele em “Sujeito de Sorte”</segment>
    <segment id="140">, mantendo a rima com a palavra “cachorro”</segment>
    <segment id="141">, masmas mudando o resto.</segment>
    <segment id="142">Lançada em 1976</segment>
    <segment id="143">, durante o governo Geisel</segment>
    <segment id="144">, a faixa ganhou fortes tons políticos e escancarou a repressão da ditadura militar</segment>
    <segment id="145">, sobretudo com o início da canção.</segment>
    <segment id="146">“</segment>
    <segment id="147">Presentemente eu posso me considerar um sujeito de sorte/</segment>
    <segment id="148">Porque apesar de muito moço</segment>
    <segment id="149">, me sinto são e salvo e forte.</segment>
    <segment id="150">”  “Mas ‘Sujeito de Sorte’ nunca foi hit”</segment>
    <segment id="151">, conta Jotabê Medeiros.</segment>
    <segment id="152">“Ela só fez sucesso depois que o Belchior morreu</segment>
    <segment id="153">, em 2017.</segment>
    <segment id="154">”  O mesmo não pode ser dito de Zé Limeira.</segment>
    <segment id="155">Ele influenciou o surrealismo sertanejo de Alceu Valença</segment>
    <segment id="156">, Ave Sangria e Zé Ramalho.</segment>
    <segment id="157">Esteve no repertório de grupos</segment>
    <segment id="158">comocomo Mestre Ambrósio</segment>
    <segment id="159">, que cantou “Se Zé Limeira Sambasse Maracatu”.</segment>
    <segment id="160">Fez parte da formação de nomes</segment>
    <segment id="161">comocomo Chico César.</segment>
    <segment id="162">E até José Sarney era visto por Brasília zanzando com um exemplar do livro de Orlando Tejo.</segment>
    <segment id="163">Mas quando "Sujeito de Sorte" bombou</segment>
    <segment id="164">, décadas depois</segment>
    <segment id="165">, “ano passado eu morri</segment>
    <segment id="166">, masmas esse ano eu não morro” eclipsou Zé Limeira e</segment>
    <segment id="167">sese tornou slogan de renascimento e resistência.</segment>
    <segment id="168">“É como</segment>
    <segment id="169">como um grafite de Maio de 1968</segment>
    <segment id="170">, virou uma espécie de síntese desses tempos”</segment>
    <segment id="171">, opina Medeiros.</segment>
    <segment id="172">Não à toa caiu no repertório de Emicida.</segment>
    <segment id="173">O rapper paulistano usou os versos na faixa “AmarElo”</segment>
    <segment id="174">, do álbum homônimo de 2019</segment>
    <segment id="175">, na qual são entoados por Pabllo Vittar e Majur.</segment>
    <segment id="176">Essas dez palavras na voz de uma drag queen e de uma artista transgênero ganham novos níveis de interpretação e reforçam a ideia de resistência que ecoa no resto da composição.</segment>
    <segment id="177">“Levanta essa cabeça/</segment>
    <segment id="178">Enxuga essas lágrimas</segment>
    <segment id="179">, certo?/ Respira fundo e volta pro ringue”</segment>
    <segment id="180">, fala um dos trechos do rap.</segment>
    <segment id="181">“É um grito de ‘chega’</segment>
    <segment id="182">, dado por pessoas cansadas do sistema e da opressão”</segment>
    <segment id="183">, diz Majur.</segment>
    <segment id="184">“Essa música deixou de ser só um projeto musical.</segment>
    <segment id="185">”</segment>
    <segment id="186">No YouTube</segment>
    <segment id="187">, o clipe de "AmarElo" já bateu 10 milhões de visualizações e tem mais de 20 mil comentários</segment>
    <segment id="188">, muitos com desabafos sobre racismo</segment>
    <segment id="189">, transfobia</segment>
    <segment id="190">, saúde mental</segment>
    <segment id="191">, falta de oportunidades das classes mais pobres e conquistas apesar das dificuldades.</segment>
    <segment id="192">“Essa intenção politizada não era a de Zé Limeira</segment>
    <segment id="193">, acho.</segment>
    <segment id="194">Mas todo verso</segment>
    <segment id="195">, depois que cai no mundo</segment>
    <segment id="196">, está sujeito a releituras que podem enriquecê-lo ou empobrecê-lo”</segment>
    <segment id="197">, pontua Braulio Tavares.</segment>
    <segment id="198">É como</segment>
    <segment id="199">como a tal mensagem lançada em uma garrafa.</segment>
    <segment id="200">Veja fotos do show de Emicida no Theatro MuinicipalMais    novamente         de   de  de  representando um</segment>
  </rst>
</analysis>