  <rst>
    <segment id="1">País de 45 milhões de habitantes —população semelhante à do estado de São Paulo—</segment>
    <segment id="2">, a Ucrânia ocupa o centro do xadrez geopolítico global após ser invadida pela Rússia</segment>
    <segment id="3">, país vizinho com o qual formou por décadas a União Soviética</segment>
    <segment id="4">, até que</segment>
    <segment id="5">, por meio de um referendo popular</segment>
    <segment id="6">, tornou-</segment>
    <segment id="7">sese independente.</segment>
    <segment id="8">Governada por um comediante sem experiência política</segment>
    <segment id="9">, o outsider Volodimir Zelenski</segment>
    <segment id="10">, o país tem economia essencialmente agrícola.</segment>
    <segment id="11">A história com a Rússia remonta ao século 17.</segment>
    <segment id="12">Ainda há</segment>
    <segment id="13">, na historiografia</segment>
    <segment id="14">, discussões sobre quando foi de fato formado o Estado ucraniano.</segment>
    <segment id="15">Soldados da Ucrânia na região norte de Kiev - Daniel Leal - 24.fev.22/AFPParte dos pesquisadores diz que ele já existia no século 17</segment>
    <segment id="16">; outros afirmam que nasceu na década de 1910</segment>
    <segment id="17">, na fase pré-União Soviética.</segment>
    <segment id="18">Há ainda os que defendem que só</segment>
    <segment id="19">sese deve falar em uma Ucrânia consolidada após o fim do bloco soviético.</segment>
    <segment id="20">Lá foraReceba no seu email uma seleção semanal com o que de mais importante aconteceu no mundo</segment>
    <segment id="21">; aberta para não assinantes.</segment>
    <segment id="22">Carregando...</segment>
    <segment id="23">O período anterior à União Soviética em 5 pontos  1)</segment>
    <segment id="24">A formação do Estado de Kiev</segment>
    <segment id="25">, nome hoje dado à capital da Ucrânia</segment>
    <segment id="26">, teve início no século 9º.</segment>
    <segment id="27">Importante rota de comércio</segment>
    <segment id="28">, o local esteve sob a influência da fé cristã ortodoxa.</segment>
    <segment id="29">O domínio regional definhou ao longo dos séculos seguintes</segment>
    <segment id="30">, quando Kiev foi ocupado por outros reinos</segment>
    <segment id="31">, entre eles o lituano e o polonês.</segment>
    <segment id="32">À época</segment>
    <segment id="33">, não havia diferenciação entre russos</segment>
    <segment id="34">, ucranianos e belarussos —fator usado pelo presidente Vladimir Putin para validar seu argumento de que russos e ucranianos são um povo só.  2)</segment>
    <segment id="35">Já em meados do século 17</segment>
    <segment id="36">, a relação com o então Czarado da Rússia —anterior ao Império Russo e à União Soviética— começou a</segment>
    <segment id="37">sese estreitar</segment>
    <segment id="38">, com um acordo firmado para a proteção do território.</segment>
    <segment id="39">Historiadores divergem até hoje sobre o assunto:</segment>
    <segment id="40">alguns dizem que o tratado da época legitimou o domínio russo</segment>
    <segment id="41">, enquanto outros dizem que houve</segment>
    <segment id="42">, já ali</segment>
    <segment id="43">, reconhecimento russo da autonomia da Ucrânia.  3)</segment>
    <segment id="44">Ainda no século 17</segment>
    <segment id="45">, masmas já nas décadas finais</segment>
    <segment id="46">, o chamado Tratado da Paz Eterna dividiu o território conhecido hoje</segment>
    <segment id="47">comocomo Ucrânia.</segment>
    <segment id="48">A maior parte do oeste foi absorvida pelo Império Russo ao longo do século seguinte</segment>
    <segment id="49">, por meio de divisões do reino da Polônia.  4)</segment>
    <segment id="50">A queda do Império Russo e o consequente estabelecimento de uma monarquia constitucional promoveu certa abertura para a vida nacional ucraniana.</segment>
    <segment id="51">A proibição do idioma ucraniano foi afrouxada</segment>
    <segment id="52">, e a introdução da Duma (uma assembleia na qual</segment>
    <segment id="53">, em tese</segment>
    <segment id="54">, representantes da sociedade local poderiam</segment>
    <segment id="55">sese manifestar) permitiu que ucranianos pressionassem e falassem sobre seu desejo de criar um Estado.  5)</segment>
    <segment id="56">Em novembro de 1917</segment>
    <segment id="57">, o Conselho Central da República Popular da Ucrânia declarou independência.</segment>
    <segment id="58">Logo, porém</segment>
    <segment id="59">porém, iniciou-</segment>
    <segment id="60">sese uma guerra com a Rússia bolchevique</segment>
    <segment id="61">, que não aceitou o desmembramento do território.</segment>
    <segment id="62">Em um manifesto ao povo ucraniano</segment>
    <segment id="63">, Vladimir Lênin disse que não poderia aceitar a existência de uma Ucrânia independente.</segment>
    <segment id="64">União Soviética através da câmeraMais    novamente         de   de  de  representando um</segment>
    <segment id="65">A UCRÂNIA NA</segment>
    <segment id="66">URSS</segment>
    <segment id="67">EM 3 PONTOS  1)</segment>
    <segment id="68">Após a guerra</segment>
    <segment id="69">, a República da Ucrânia entrou na órbita da URSS e foi acoplada ao bloco.</segment>
    <segment id="70">Data da época um dos episódios mais sombrios da história ucraniana</segment>
    <segment id="71">, o Holodomor ("holod"</segment>
    <segment id="72">, de fome</segment>
    <segment id="73">, e "mor"</segment>
    <segment id="74">, de praga ou morte)</segment>
    <segment id="75">, quando mais de 3</segment>
    <segment id="76">,3 milhões de ucranianos morreram de fome durante o regime soviético.  2)</segment>
    <segment id="77">Também foi durante a era soviética que ocorreu o acidente nuclear de Tchernóbil</segment>
    <segment id="78">, na cidade de Pripiat</segment>
    <segment id="79">, na ainda República Socialista Soviética da Ucrânia.</segment>
    <segment id="80">Trata-</segment>
    <segment id="81">sese do pior acidente nuclear da história.</segment>
    <segment id="82">Cerca de 30 pessoas morreram no episódio</segment>
    <segment id="83">, masmas as consequências da radiação deixaram sequelas e vitimaram milhares de pessoas posteriormente.</segment>
    <segment id="84">A tragédia virou tema de livros</segment>
    <segment id="85">, séries e filmes.  3) Leonid Kravchuk</segment>
    <segment id="86">, líder da Ucrânia</segment>
    <segment id="87">, declarou a independência do país em relação a Moscou em 1991</segment>
    <segment id="88">, em meio ao fim da União Soviética.</segment>
    <segment id="89">Um referendo popular foi realizado</segment>
    <segment id="90">, e mais de 90% dos participantes apoiou a independência.</segment>
    <segment id="91">Kravchuk foi eleito presidente.</segment>
    <segment id="92">Voltando a TchernóbilMais    novamente         de   de  de  representando um</segment>
    <segment id="93">O PÓS-INDEPENDÊNCIA</segment>
    <segment id="94">EM 5 PONTOS  1)</segment>
    <segment id="95">Em 1994</segment>
    <segment id="96">, Leonid Kuchma venceu a eleição presidencial.</segment>
    <segment id="97">Numa guinada autoritária</segment>
    <segment id="98">, ele conquistou outro pleito</segment>
    <segment id="99">, em 1999</segment>
    <segment id="100">, com suspeitas de irregularidades.</segment>
    <segment id="101">Anos depois</segment>
    <segment id="102">, em 2004</segment>
    <segment id="103">, o candidato pró-Rússia Viktor Ianukovich foi declarado presidente</segment>
    <segment id="104">, masmas as alegações de fraude eleitoral desencadearam protestos no que</segment>
    <segment id="105">sese tornou conhecido</segment>
    <segment id="106">comocomo a Revolução Laranja</segment>
    <segment id="107">, levando a uma nova votação.</segment>
    <segment id="108">O ex-premiê pró-Ocidente Viktor Iuschenko foi eleito presidente.  2)</segment>
    <segment id="109">Iuschenko assumiu em 2005 com promessas de tirar a Ucrânia da órbita de Moscou</segment>
    <segment id="110">, caminhando em direção à Otan</segment>
    <segment id="111">, a aliança militar ocidental</segment>
    <segment id="112">, e à União Europeia (UE).</segment>
    <segment id="113">Três anos depois</segment>
    <segment id="114">, a Otan deu sinais de que permitiria à Ucrânia</segment>
    <segment id="115">sese somar à aliança.  3)</segment>
    <segment id="116">Viktor Ianukovich é eleito presidente em 2010.</segment>
    <segment id="117">O presidente ucraniano</segment>
    <segment id="118">sese distanciou do Ocidente e reviveu laços econômicos e políticos com Moscou</segment>
    <segment id="119">, levando à insatisfação popular em 2014.</segment>
    <segment id="120">Os protestos tornaram-</segment>
    <segment id="121">sese violentos</segment>
    <segment id="122">, e dezenas morreram nas ruas da capital Kiev.</segment>
    <segment id="123">O Parlamento decidiu remover Ianukovich.  4)</segment>
    <segment id="124">Em resposta à retirada de um aliado do poder</segment>
    <segment id="125">, a Rússia decidiu anexar a península da Crimeia.</segment>
    <segment id="126">O período também inflamou a situação em porções leste da Ucrânia</segment>
    <segment id="127">, onde a população é majoritariamente russa e anseia por uma maior ligação com Moscou</segment>
    <segment id="128">, como</segment>
    <segment id="129">como na região do Donbass</segment>
    <segment id="130">, onde duas autoproclamadas repúblicas foram reconhecidas por Putin.  5)</segment>
    <segment id="131">Em 2019</segment>
    <segment id="132">, Volodimir Zelenski</segment>
    <segment id="133">, um comediante que interpretava um presidente bem-intencionado em uma popular série de TV</segment>
    <segment id="134">, foi eleito presidente.</segment>
    <segment id="135">Ele tem discurso favorável à UE e à Otan</segment>
    <segment id="136">, a quem pleiteia apoio e possibilidade de ingresso na aliança.</segment>
    <segment id="137">Famílias deixam a região da CrimeiaMais    novamente         de   de  de  representando um   CARACTERÍSTICAS GERAIS DO PAÍS  Grupos étnicos</segment>
    <segment id="138">A população da Ucrânia tem composição multinacional.</segment>
    <segment id="139">De acordo com dados do censo de 2001 (o último disponível</segment>
    <segment id="140">, sendo que uma nova edição está prevista para 2023)</segment>
    <segment id="141">, representantes de mais de 130 nacionalidades e grupos étnicos vivem ali.</segment>
    <segment id="142">Os principais:   Ucranianos: 77</segment>
    <segment id="143">,8% Russos: 17</segment>
    <segment id="144">,3% (majoritariamente concentrados no Leste)</segment>
    <segment id="145">Belarussos: 0</segment>
    <segment id="146">,6%   Economia  Composição do PIB*   serviços: 60% indústria: 28</segment>
    <segment id="147">,6% agricultura:</segment>
    <segment id="148">12,2%</segment>
    <segment id="149">O setor de agronegócios continua sendo o mais promissor da economia.</segment>
    <segment id="150">Com 41</segment>
    <segment id="151">,5 milhões de hectares de terras agrícolas</segment>
    <segment id="152">, cobrindo 70% do país e cerca de 25% das reservas mundiais de solo negro</segment>
    <segment id="153">, a agricultura é a maior indústria de exportação: em 2020</segment>
    <segment id="154">, o setor agrícola gerou aproximadamente 9</segment>
    <segment id="155">,3% do PIB.   * Estimativas de 2017  China</segment>
    <segment id="156">, terra do meioReceba no seu email os grandes temas da China explicados e contextualizados</segment>
    <segment id="157">; exclusiva para assinantes.</segment>
    <segment id="158">Carregando...</segment>
    <segment id="159">Outros pontos importantes**   Posição 74 entre 189 países no ranking de IDH (Índice de Desenvolvimento Humano)</segment>
    <segment id="160">, com nota 0</segment>
    <segment id="161">,779 —quanto mais perto de 1</segment>
    <segment id="162">, melhor</segment>
    <segment id="163">; Brasil é o 84º</segment>
    <segment id="164">;</segment>
    <segment id="165">Índice de liberdade 60</segment>
    <segment id="166">, numa escala que vai até 100 medida pela Freedom House e leva em conta liberdades políticas</segment>
    <segment id="167">, civis e de imprensa</segment>
    <segment id="168">; Brasil tem pontuação 74</segment>
    <segment id="169">;</segment>
    <segment id="170">Posição 97 no ranking de liberdade de imprensa da Repórteres Sem Fronteiras em 2021</segment>
    <segment id="171">;</segment>
    <segment id="172">Brasil é o 111.   **</segment>
    <segment id="173">Se consideradas somente as regiões rebeldes de Lugansk e Donetsk</segment>
    <segment id="174">, sob domínio russo</segment>
    <segment id="175">, todos esses índices recebem pontuação consideravelmente menor.</segment>
    <segment id="176">Fontes: Banco Mundial</segment>
    <segment id="177">, Enciclopédia Britannica</segment>
    <segment id="178">, PNUD</segment>
