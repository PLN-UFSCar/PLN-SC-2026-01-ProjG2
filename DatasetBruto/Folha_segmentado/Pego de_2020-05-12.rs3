  <rst>
    <segment id="1">Ao ser pego de surpresa pelo decreto de Jair Bolsonaro que inclui academias esportivas</segment>
    <segment id="2">, barbearias e sal&amp;otilde</segment>
    <segment id="3">;es de beleza na lista de servi&amp;ccedil</segment>
    <segment id="4">;os essenciais durante a pandemia do novo coronav&amp;iacute</segment>
    <segment id="5">;rus, o ministro Nelson Teich (Sa&amp;uacute</segment>
    <segment id="6">;de) disse que o tema n&amp;atilde</segment>
    <segment id="7">;o &amp;eacute</segment>
    <segment id="8">;</segment>
    <segment id="9">atribui&amp;ccedil</segment>
    <segment id="10">;&amp;atilde</segment>
    <segment id="11">;o de sua pasta.</segment>
    <segment id="12">&amp;quot;Isso a&amp;iacute</segment>
    <segment id="13">; &amp;eacute</segment>
    <segment id="14">; uma decis&amp;atilde</segment>
    <segment id="15">;o do presidente&amp;quot</segment>
    <segment id="16">;, afirmou.</segment>
    <segment id="17">No entanto</segment>
    <segment id="18">, apenas a primeira lista de servi&amp;ccedil</segment>
    <segment id="19">;os essenciais anunciada por Bolsonaro em 20 de mar&amp;ccedil</segment>
    <segment id="20">;o passou pelo crivo do Minist&amp;eacute</segment>
    <segment id="21">;rio da Sa&amp;uacute</segment>
    <segment id="22">;de, &amp;agrave</segment>
    <segment id="23">; &amp;eacute</segment>
    <segment id="24">;poca comandado por Luiz Henrique Mandetta.</segment>
    <segment id="25">Essa lista continha servi&amp;ccedil</segment>
    <segment id="26">;os banc&amp;aacute</segment>
    <segment id="27">;rios e postais</segment>
    <segment id="28">, transporte por t&amp;aacute</segment>
    <segment id="29">;xi e por ve&amp;iacute</segment>
    <segment id="30">;culos de aplicativos</segment>
    <segment id="31">, entre outros.</segment>
    <segment id="32">Depois da primeira lista vieram outras quatro</segment>
    <segment id="33">, cada uma acrescentando mais servi&amp;ccedil</segment>
    <segment id="34">;os entre os essenciais.</segment>
    <segment id="35">Elas tamb&amp;eacute</segment>
    <segment id="36">;m n&amp;atilde</segment>
    <segment id="37">;o passaram pelo Minist&amp;eacute</segment>
    <segment id="38">;rio da Sa&amp;uacute</segment>
    <segment id="39">;de.</segment>
    <segment id="40">Nelson Teich</segment>
    <segment id="41">, ministro da SaúdeMais    novamente         de   de  de  representando um</segment>
    <segment id="42">A decis&amp;atilde</segment>
    <segment id="43">;o tomada sem o aval de Teich acontece em um momento em que o ministro &amp;eacute</segment>
    <segment id="44">; alvo de cr&amp;iacute</segment>
    <segment id="45">;ticas por ser supostamente tutelado em suas a&amp;ccedil</segment>
    <segment id="46">;&amp;otilde</segment>
    <segment id="47">;es.</segment>
    <segment id="48">Ele &amp;eacute</segment>
    <segment id="49">; constantemente acompanhado por membros da Secretaria de Comunica&amp;ccedil</segment>
    <segment id="50">;&amp;atilde</segment>
    <segment id="51">;o de Bolsonaro e tem</segment>
    <segment id="52">comocomo n&amp;uacute</segment>
    <segment id="53">;mero 2 o militar Eduardo Pazuello.</segment>
    <segment id="54">Al&amp;eacute</segment>
    <segment id="55">;m disso</segment>
    <segment id="56">, diversos funcion&amp;aacute</segment>
    <segment id="57">;rios do Minist&amp;eacute</segment>
    <segment id="58">;rio da Sa&amp;uacute</segment>
    <segment id="59">;de foram recentemente trocados por militares.</segment>
    <segment id="60">Com Mariana Carneiro e Guilherme Seto</segment>
  </rst>
