  <rst>
    <segment id="1">Presidente do diretório paulista do Avante</segment>
    <segment id="2">, o deputado estadual Campos Machado (SP) vai convidar Paulo Skaf</segment>
    <segment id="3">, da Fiesp</segment>
    <segment id="4">, a ser candidato ao Senado pelo partido em 2022.</segment>
    <segment id="5">"É um nome forte</segment>
    <segment id="6">, e que já fez tanto por São Paulo</segment>
    <segment id="7">, que, tenho certeza</segment>
    <segment id="8">, como</segment>
    <segment id="9">como senador irá fazer ainda mais"</segment>
    <segment id="10">, diz o parlamentar.</segment>
    <segment id="11">Skaf deixará o comando da Fiesp no final do ano após quase 18 anos</segment>
    <segment id="12">, e será sucedido pelo empresário Josué Gomes da Silva.</segment>
    <segment id="13">Ele, que é filiado ao MDB</segment>
    <segment id="14">, já disputou três vezes eleições para o governo de São Paulo.</segment>
    <segment id="15">Em 2018</segment>
    <segment id="16">, foi ultrapassado na reta final do primeiro turno por Márcio França (PSB)</segment>
    <segment id="17">, que depois perdeu para João Doria (PSDB).</segment>
    <segment id="18">O MDB tende</segment>
    <segment id="19">, atualmente</segment>
    <segment id="20">, a apoiar a candidatura do vice-governador Rodrigo Garcia (PSDB) para o comando da administração paulista.</segment>
    <segment id="21">Skaf candidato ao governo de SPMais    novamente         de   de  de  representando um</segment>
  </rst>
