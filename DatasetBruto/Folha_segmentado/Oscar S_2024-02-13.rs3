  <rst>
    <segment id="1">Escritora suspeita de assassinato ou mulher de um nazista</segment>
    <segment id="2">, os holofotes do tapete vermelho estão sobre Sandra Hüller.</segment>
    <segment id="3">A atriz alemã protagoniza dois dos principais filmes do ano</segment>
    <segment id="4">, que acumulam</segment>
    <segment id="5">, juntos</segment>
    <segment id="6">, dez indicações ao Oscar.</segment>
    <segment id="7">A atriz Sandra Hüller em Cannes</segment>
    <segment id="8">, na França</segment>
    <segment id="9">, em entrevista coletiva do filme &amp;#039</segment>
    <segment id="10">;Zona de Interesse&amp;#039</segment>
    <segment id="11">;-</segment>
    <segment id="12">Yara Nardi/ReutersCom "</segment>
    <segment id="13">Anatomia de uma Queda"</segment>
    <segment id="14">, Hüller concorre à estatueta de melhor atriz</segment>
    <segment id="15">, e a França volta a ter o prestígio da Academia</segment>
    <segment id="16">, ainda que o longa não tenha sido selecionado pelo governo para concorrer a melhor filme internacional</segment>
    <segment id="17">, depois que a diretora</segment>
    <segment id="18">, Justine Triet</segment>
    <segment id="19">, fez um discurso crítico contra a agenda neoliberal do presidente Emmanuel Macron ao receber a Palma de Ouro</segment>
    <segment id="20">, em Cannes.</segment>
    <segment id="21">Veja fotos da atriz</segment>
    <segment id="22">Sandra HullerMais    novamente         de   de  de  representando um</segment>
    <segment id="23">É "Zona de Interesse" que concorre na categoria.</segment>
    <segment id="24">No filme do britânico Jonathan Glazer</segment>
    <segment id="25">, a atriz encarna Hedwig Höss</segment>
    <segment id="26">, mulher de Rudolf Höss</segment>
    <segment id="27">, que comandou o campo de extermínio de Auschwitz na Alemanha nazista.</segment>
    <segment id="28">"</segment>
    <segment id="29">Estou feliz que os filmes internacionais têm mais reconhecimento hoje em dia.</segment>
    <segment id="30">Isso abre espaço para outras formas [de fazer cinema] e de experimentos"</segment>
    <segment id="31">, diz Hüller em conversa por vídeo</segment>
    <segment id="32">, com a mesma sobriedade que contagia seus personagens e a faz esboçar poucos sorrisos nas premiações.</segment>
    <segment id="33">"Mas não acho que furei a bolha.</segment>
    <segment id="34">Hollywood jamais permitiria isso.</segment>
    <segment id="35">"</segment>
    <segment id="36">Cenas do filme &amp;#039</segment>
    <segment id="37">;Zona de Interesse&amp;#039</segment>
    <segment id="38">;, indicado ao OscarMais    novamente         de   de  de  representando um  Em 2016</segment>
    <segment id="39">, Hüller ganhou projeção internacional por "Toni Erdmann"</segment>
    <segment id="40">, de Maren Ade</segment>
    <segment id="41">, filme alemão em que interpreta uma consultora viciada em trabalho que aconselha executivos americanos sobre</segment>
    <segment id="42">comocomo fazer seus negócios prosperarem na Romênia –que</segment>
    <segment id="43">, até a queda do Muro de Berlim</segment>
    <segment id="44">, era socialista.</segment>
    <segment id="45">Sua rigidez</segment>
    <segment id="46">sese desfaz conforme ela convive com o pai</segment>
    <segment id="47">, um professor de música sensível e jocoso</segment>
    <segment id="48">, que leva a filha a encarar a vida com uma leveza proibida no mundo de metas e lucros.</segment>
    <segment id="49">Cena do filme &amp;#039</segment>
    <segment id="50">;Toni Erdmann&amp;#039</segment>
    <segment id="51">;, de Maren Ade - DivulgaçãoApesar do sucesso</segment>
    <segment id="52">, Hollywood não importou Hüller</segment>
    <segment id="53">, como</segment>
    <segment id="54">como aconteceu com o também alemão Christoph Waltz</segment>
    <segment id="55">, por exemplo</segment>
    <segment id="56">, ou com a própria Justine Triet</segment>
    <segment id="57">, que assinou recentemente um contrato com a agência americana CAA.</segment>
    <segment id="58">Agora, com sua onipresença em todas as premiações desta temporada</segment>
    <segment id="59">, pode ser que os ventos mudem.</segment>
    <segment id="60">O domínio de várias línguas é uma vantagem.</segment>
    <segment id="61">Além do alemão</segment>
    <segment id="62">, Hüller é fluente em inglês e fala francês</segment>
    <segment id="63">, assim</segment>
    <segment id="64">comocomo Sandra</segment>
    <segment id="65">, sua xará</segment>
    <segment id="66">, em "Anatomia de uma Queda".</segment>
    <segment id="67">"</segment>
    <segment id="68">Atuar em diferentes línguas é libertador</segment>
    <segment id="69">, porque</segment>
    <segment id="70">porque você não</segment>
    <segment id="71">sese apega a detalhes da linguagem.</segment>
    <segment id="72">Quando filmo em alemão</segment>
    <segment id="73">, me atento a cada palavrinha e analiso</segment>
    <segment id="74">sese ela é apropriada para a época e o local onde os personagens vivem"</segment>
    <segment id="75">, diz, séria.</segment>
    <segment id="76">Os olhos azuis</segment>
    <segment id="77">, cabelos loiros</segment>
    <segment id="78">, as maçãs do rosto avantajadas e o comedimento em sua voz a aproximam do estereótipo alemão</segment>
    <segment id="79">, despedaçado pela intensidade com que</segment>
    <segment id="80">, progressivamente</segment>
    <segment id="81">, ela transborda as emoções de seus personagens.</segment>
    <segment id="82">Confira cenas do filme &amp;#039</segment>
    <segment id="83">;Anatomia de Uma Queda&amp;#039</segment>
    <segment id="84">;, de Justine TrietMais    novamente         de   de  de  representando um  "</segment>
    <segment id="85">Eu preciso ser transparente o suficiente para fazer com que meus sentimentos e intenções sejam críveis.</segment>
    <segment id="86">A língua é só outra ferramenta de transporte"</segment>
    <segment id="87">, afirma.</segment>
    <segment id="88">Algo que ela aprendeu no teatro</segment>
    <segment id="89">, em que</segment>
    <segment id="90">, segundo ela</segment>
    <segment id="91">, a palavra é a última a ser usada.</segment>
    <segment id="92">Foi nos palcos de Berlim que Hüller</segment>
    <segment id="93">sese formou atriz</segment>
    <segment id="94">, ainda jovem</segment>
    <segment id="95">, quando</segment>
    <segment id="96">sese mudou para a capital alemã.</segment>
    <segment id="97">Apesar da carreira promissora no cinema</segment>
    <segment id="98">, que começou em 2006 com "Requiem"</segment>
    <segment id="99">, de Hans-Christian Schmid</segment>
    <segment id="100">, ela não pretende abandonar os palcos.</segment>
    <segment id="101">Há cinco anos</segment>
    <segment id="102">, ela deu vida a Hamlet no Schauspielhaus Bochum</segment>
    <segment id="103">, um dos teatros mais consagrados da Alemanha.</segment>
    <segment id="104">Na adaptação</segment>
    <segment id="105">, o corpo do príncipe era infectado pela podridão dos seus antecessores quando possuído pelo fantasma de seu pai.</segment>
    <segment id="106">Hüller era dois em um e</segment>
    <segment id="107">, com tremores e andar cambaleante</segment>
    <segment id="108">, contagiou todos os presentes com a perturbação de Hamlet</segment>
    <segment id="109">, descreveu a revista alemã Der Spiegel.  Sandra Hüller em cena do filme &amp;#039</segment>
    <segment id="110">;Anatomia de uma Queda&amp;#039</segment>
    <segment id="111">;, de Justine Triet - DivulgaçãoEm "</segment>
    <segment id="112">Anatomia de uma Queda"</segment>
    <segment id="113">, a mulher interpretada por Hüller é acusada de assassinato depois que seu marido é encontrado morto na neve.</segment>
    <segment id="114">O corpo despencou do último andar do chalé onde ela mora com ele e com o filho cego</segment>
    <segment id="115">, de 12 anos</segment>
    <segment id="116">, nos Alpes franceses.</segment>
    <segment id="117">Mas a investigação principal é</segment>
    <segment id="118">, na realidade</segment>
    <segment id="119">, sobre culpa e codependência numa relação carcomida pelo tempo –e o que</segment>
    <segment id="120">sese espera de uma mulher em um casamento.  Sandra</segment>
    <segment id="121">, a protagonista</segment>
    <segment id="122">, não abre mão da carreira em prol da família.</segment>
    <segment id="123">Tampouco esbanja feminilidade.</segment>
    <segment id="124">O rosto da atriz é por vezes enquadrado pela câmera</segment>
    <segment id="125">, enquanto ela transita entre raiva</segment>
    <segment id="126">, tristeza</segment>
    <segment id="127">, medo e sedução</segment>
    <segment id="128">, envolvendo quem vê em outra dúvida existencial</segment>
    <segment id="129">, quase um "ser ou não ser" —afinal</segment>
    <segment id="130">, matou ou não matou?</segment>
    <segment id="131">MaratonarUm guia com dicas de filmes e séries para assistir no streamingCarregando...</segment>
    <segment id="132">O ponto alto é uma discussão com o marido</segment>
    <segment id="133">, usada para a incriminar no tribunal</segment>
    <segment id="134">, em que Sandra exorciza</segment>
    <segment id="135">, em seu monólogo</segment>
    <segment id="136">, as cobranças do morto —seu rosto enrubesce e os olhos</segment>
    <segment id="137">sese arregalam</segment>
    <segment id="138">, enquanto suas mãos tremulam e o tom de voz sobe.</segment>
    <segment id="139">Já Hedwig</segment>
    <segment id="140">, sua personagem em "Zona de Interesse"</segment>
    <segment id="141">, está disposta a participar de um genocídio</segment>
    <segment id="142">sese isso beneficiar sua família.</segment>
    <segment id="143">Ela é culpada</segment>
    <segment id="144">, sabe disso</segment>
    <segment id="145">, e segue a façanha de viver uma vida pacata em uma casa ao lado de um campo de extermínio.</segment>
    <segment id="146">A câmera não dá importância às expressões de Hedwig ou de sua família</segment>
    <segment id="147">, e as cenas são filmadas a distância.</segment>
    <segment id="148">"Eu me recusei</segment>
    <segment id="149">, desde o início [das filmagens]</segment>
    <segment id="150">, a me envolver emocionalmente ou empaticamente com Hedwig</segment>
    <segment id="151">, então só tinha o corpo para atuar"</segment>
    <segment id="152">, diz.</segment>
    <segment id="153">Antes de membros do partido nazista</segment>
    <segment id="154">, Rudolf e Hedwig eram agricultores e</segment>
    <segment id="155">, para ela</segment>
    <segment id="156">, o casal ser o motivo do sofrimento de outras pessoas já tem um impacto sobre seus corpos.</segment>
    <segment id="157">A atriz Sandra Hüller em cena do filme &amp;#039</segment>
    <segment id="158">;Zona de Interesse&amp;#039</segment>
    <segment id="159">;, de Jonathan Glazer - Divulgação"Decidimos que eles não teriam um jeito elegante de andar.</segment>
    <segment id="160">Eu acredito fortemente que um personagem é definido mais pelo que ele não consegue fazer do que pelo que ele é capaz.</segment>
    <segment id="161">"</segment>
    <segment id="162">A guerra é um tema inesgotável para filmes</segment>
    <segment id="163">, vide a premiação de "1917" e "</segment>
    <segment id="164">Nada de Novo no Front" nas últimas edições do Oscar.</segment>
    <segment id="165">E, como</segment>
    <segment id="166">como artista alemã</segment>
    <segment id="167">, Hüller já recebeu vários convites para interpretar fascistas —que recusou</segment>
    <segment id="168">, por não concordar com o uso do tema</segment>
    <segment id="169">comocomo tela para dramas.</segment>
    <segment id="170">Mas ela aceitou dar vida a Hedwig</segment>
    <segment id="171">porque</segment>
    <segment id="172">porque sabia que "Zona de Interesse" traria desconforto.</segment>
    <segment id="173">"</segment>
    <segment id="174">O filme questiona a audiência sobre por que achamos que essas pessoas não têm nada em comum conosco e por que essa narrativa de monstros é tão forte"</segment>
    <segment id="175">, ela diz.</segment>
    <segment id="176">"</segment>
    <segment id="177">Minha herança alemã e as decisões de meus ancestrais estavam presentes o tempo todo durante as filmagens.</segment>
    <segment id="178">"</segment>
    <segment id="179">Hüller nasceu em 1978</segment>
    <segment id="180">, em Friedrichroda</segment>
    <segment id="181">, na Alemanha socialista</segment>
    <segment id="182">, quando o país estava fatiado entre Estados Unidos e União Soviética.</segment>
    <segment id="183">"</segment>
    <segment id="184">Eu tive sorte de nascer num país que</segment>
    <segment id="185">, apesar de não ser perfeito</segment>
    <segment id="186">, era antifascista"</segment>
    <segment id="187">, afirma</segment>
    <segment id="188">, categoricamente.</segment>
    <segment id="189">Foi durante sua infância do lado oriental do muro que aprendeu sobre a responsabilidade individual em uma comunidade</segment>
    <segment id="190">, e que a unidade faz a força.</segment>
    <segment id="191">"Não éramos bombardeados com produtos.</segment>
    <segment id="192">Todo mundo tinha as mesmas coisas</segment>
    <segment id="193">, e se</segment>
    <segment id="194">se você quisesse algo especial</segment>
    <segment id="195">, precisava entrar na fila</segment>
    <segment id="196">, e não era garantido que ainda estaria disponível quando chegasse a sua vez"</segment>
    <segment id="197">, disse à revista The New Yorker.</segment>
    <segment id="198">"E talvez essa seja a vida mesmo</segment>
    <segment id="199">, não podemos ter tudo o que queremos.</segment>
    <segment id="200">"</segment>
    <segment id="201">Quando o Muro de Berlim caiu</segment>
    <segment id="202">, havia alegria</segment>
    <segment id="203">, masmas as pessoas não sabiam</segment>
    <segment id="204">, disse ela</segment>
    <segment id="205">, que seus empregos seguros seriam esmagados pela mão invisível do mercado.</segment>
    <segment id="206">Hoje, o partido de extrema direita alemão Alternativa para a Alemanha tem uma quantidade considerável de votos no que antes foi a Alemanha Oriental.</segment>
    <segment id="207">O Festival de Berlim deste ano</segment>
    <segment id="208">, aliás</segment>
    <segment id="209">, gerou polêmica ao convidar dois membros do AfD para a cerimônia —a organização desistiu da ideia na semana passada.</segment>
    <segment id="210">"‘</segment>
    <segment id="211">Zona de Interesse’ é um aviso de que pequenas decisões equivocadas podem levar a enormes catástrofes"</segment>
    <segment id="212">, acrescenta Hüller</segment>
    <segment id="213">, antes de</segment>
    <segment id="214">sese interromper e colocar a mão no rosto.</segment>
    <segment id="215">"</segment>
    <segment id="216">Ai, desculpe</segment>
    <segment id="217">, por que estou falando tanto?</segment>
    <segment id="218">"</segment>
    <segment id="219">Foi meio sem jeito que a atriz recebeu a chuva de aplausos no European Film Awards</segment>
    <segment id="220">, ao ser eleita melhor atriz por "Anatomia de uma Queda".</segment>
    <segment id="221">No palco</segment>
    <segment id="222">, falou sobre a estatueta —"é uma mulher".</segment>
    <segment id="223">"</segment>
    <segment id="224">Trabalhar em grupo faz o sonho funcionar.</segment>
    <segment id="225">Atuar não acontece em algum lugar no espaço</segment>
    <segment id="226">, masmas é uma ação constantemente influenciada pelo que está acontecendo no mundo"</segment>
    <segment id="227">, disse</segment>
    <segment id="228">, com a voz nervosa</segment>
    <segment id="229">, antes de pedir um minuto de silêncio</segment>
    <segment id="230">para que</segment>
    <segment id="231">para que todos os presentes imaginassem a paz.</segment>
    <segment id="232">"</segment>
    <segment id="233">Não é tempo suficiente e vocês podem continuar tentando quando quiserem"</segment>
    <segment id="234">, disse.</segment>
    <segment id="235">E saiu de cena.</segment>
    <segment id="236">Zona de InteresseQuando Estreia nesta quinta (15) nos cinemasClassificação 14 anosElenco Christian Friedel</segment>
    <segment id="237">, Sandra Hüller</segment>
    <segment id="238">, Lilli FalkProdução EUA</segment>
    <segment id="239">, Reino Unido</segment>
    <segment id="240">, Polônia</segment>
    <segment id="241">, 2023Direção Jonathan</segment>
    <segment id="242">GlazerAnatomia</segment>
    <segment id="243">de uma QuedaQuando</segment>
    <segment id="244">Em cartaz nos cinemasClassificação 16 anosElenco Sandra Hüller</segment>
    <segment id="245">, Swann Arlaud</segment>
    <segment id="246">, Milo Machado-GranerProdução França</segment>
    <segment id="247">, 2023Direção Justine Triet</segment>
  </rst>
</analysis>