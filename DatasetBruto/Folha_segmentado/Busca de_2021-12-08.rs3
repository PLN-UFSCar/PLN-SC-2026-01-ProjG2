  <rst>
    <segment id="1">Tirar uma foto na Torre Eiffel</segment>
    <segment id="2">, visitar o Museu do Louvre</segment>
    <segment id="3">, passear pela Champs-Élysées.</segment>
    <segment id="4">Paris, a cidade luz</segment>
    <segment id="5">, sempre foi o destino mais procurado por brasileiros na Europa.</segment>
    <segment id="6">Agora, este e outros roteiros europeus voltaram ao topo das procuras.</segment>
    <segment id="7">"</segment>
    <segment id="8">O movimento começou devagar</segment>
    <segment id="9">, masmas estamos voltando.</segment>
    <segment id="10">Não atingimos ainda os números de 2019</segment>
    <segment id="11">, vamos precisar de um tempo para isso</segment>
    <segment id="12">, masmas o setor está</segment>
    <segment id="13">sese reaquecendo com a abertura das fronteiras"</segment>
    <segment id="14">, conta Magda Nassar</segment>
    <segment id="15">, presidente da ABAV (Associação Brasileira de Agências de Viagens).</segment>
    <segment id="16">O sol se</segment>
    <segment id="17">se põe e é visto em meio ao Arco do Triunfo</segment>
    <segment id="18">, em Paris - Aurelien Morissard/XinhuaA especialista acredita que o aumento da procura neste momento</segment>
    <segment id="19">sese deve ao fenômeno que ela chama de "vingança da pandemia".</segment>
    <segment id="20">"</segment>
    <segment id="21">O grande desejo das pessoas agora</segment>
    <segment id="22">, depois de tanto tempo presas</segment>
    <segment id="23">, é viajar.</segment>
    <segment id="24">Qualquer pesquisa de consumo mostra esse resultado"</segment>
    <segment id="25">, aposta.</segment>
    <segment id="26">Portugal aparece em segundo lugar na procura dos turistas brasileiros</segment>
    <segment id="27">; Lisboa e Porto são as cidades mais desejadas.</segment>
    <segment id="28">Atrativos que confirmem essa preferência não faltam.</segment>
    <segment id="29">Na capital</segment>
    <segment id="30">, a Torre de Belém</segment>
    <segment id="31">, classificada patrimônio mundial pela Unesco</segment>
    <segment id="32">, localizada às margens do rio Tejo</segment>
    <segment id="33">, é um dos pontos turísticos mais famosos do país.</segment>
    <segment id="34">Turistas passeiam por Lisboa</segment>
    <segment id="35">, em Portugal - Giuliana Miranda/FolhapressJá no Porto</segment>
    <segment id="36">, o turista precisa conhecer o Cais da Ribeira</segment>
    <segment id="37">, em frente ao Rio Douro</segment>
    <segment id="38">, a mais conhecida vista da cidade.</segment>
    <segment id="39">Em ambos destinos</segment>
    <segment id="40">, a gastronomia portuguesa também é um atrativo.  Espanha</segment>
    <segment id="41">, Reino Unido e Alemanha também estão entre os destinos mais procurados por brasileiros.</segment>
    <segment id="42">É o que conta Ronnie Corrêa</segment>
    <segment id="43">, diretor geral da agência Abreu no Brasil —e todos essts países estão com fronteiras abertas para o Brasil</segment>
    <segment id="44">, com diferentes regras.</segment>
    <segment id="45">"Temos visto um aumento na procura por viagens internacionais com essas aberturas.</segment>
    <segment id="46">Hoje podemos falar que nosso movimento é 50% maior do que era em 2019</segment>
    <segment id="47">, o que mostra uma crescente positiva"</segment>
    <segment id="48">, avalia Corrêa.</segment>
    <segment id="49">Para quem quiser conhecer os principais pontos turísticos da Espanha</segment>
    <segment id="50">, uma boa pedida é passar por Barcelona e Madrid</segment>
    <segment id="51">, que lideram a procura dos turistas.</segment>
    <segment id="52">Na capital</segment>
    <segment id="53">, o Palácio Real e a Puerta del Sol são os locais mais famosos da cidade.</segment>
    <segment id="54">Já em Barcelona</segment>
    <segment id="55">, além das praias e das ramblas (calçadões)</segment>
    <segment id="56">, o turista pode entrar no universo do famoso arquiteto Antoni Gaudí (1952-1926)</segment>
    <segment id="57">, visitando a imponente Casa Milà</segment>
    <segment id="58">, o Park Güell e a igreja da Sagrada Família</segment>
    <segment id="59">, que recentemente inaugurou sua estrela luminosa de 4</segment>
    <segment id="60">,5 toneladas no topo Torre da Virgem Maria.</segment>
    <segment id="61">El Siglo</segment>
    <segment id="62">, o maior sebo da EspanhaMais    novamente         de   de  de  representando um   Seguido pela Itália</segment>
    <segment id="63">, Reino Unido</segment>
    <segment id="64">, onde são aceitos todos os imunizantes disponíveis no Brasil</segment>
    <segment id="65">, também</segment>
    <segment id="66">sese encontra na lista de locais favoritos dos viajantes que saem do Brasil.  ​No Reino Unido</segment>
    <segment id="67">, Londres fica no topo do ranking de cidades mais visitadas.</segment>
    <segment id="68">A capital abriga o Palácio de Buckingham</segment>
    <segment id="69">, residência e sede da monarquia inglesa</segment>
    <segment id="70">, um dos principais pontos turísticos</segment>
    <segment id="71">, assim</segment>
    <segment id="72">comocomo a Tower Brigde e a London Tower</segment>
    <segment id="73">, dois de seus cartões postais mais famosos.</segment>
    <segment id="74">Por conta do momento delicado da pandemia</segment>
    <segment id="75">, a Alemanha anda em baixa nas buscas dos brasileiros.</segment>
    <segment id="76">"É um destino muito importante para a gente</segment>
    <segment id="77">, masmas a procura vem caindo.</segment>
    <segment id="78">As notícias de lá não ajudam</segment>
    <segment id="79">, acho que a situação epidemiológica do país tem tido um peso"</segment>
    <segment id="80">, entende Corrêa.</segment>
    <segment id="81">Por enquanto</segment>
    <segment id="82">, o país segue com as fronteiras abertas e ainda recebe turistas do Brasil.</segment>
  </rst>
</analysis>