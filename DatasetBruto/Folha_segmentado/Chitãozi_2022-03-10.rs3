  <rst>
    <segment id="1">A dupla sertaneja Chitãozinho e Xororó vai</segment>
    <segment id="2">sese apresentar no dia 3 de setembro no Radio City Music Hall</segment>
    <segment id="3">, em Nova York (EUA)</segment>
    <segment id="4">, para celebrar seus 50 anos de carreira.</segment>
    <segment id="5">A casa de espetáculos é uma das mais tradicionais da cidade.</segment>
    <segment id="6">Chitãozinho e Xororó no programa Altas Horas</segment>
    <segment id="7">, da TV Globo - DivulgaçãoESPERA</segment>
    <segment id="8">Os ingressos começarão a ser vendidos no próximo sábado (12).</segment>
    <segment id="9">A celebração das cinco décadas da dupla estava prevista para 2020</segment>
    <segment id="10">, masmas foi adiada por causa da Covid-19.</segment>
    <segment id="11">FORA DA TELINHA</segment>
    <segment id="12">Abertura do gexperience</segment>
    <segment id="13">, espaço interativo da Globo</segment>
    <segment id="14">, em São</segment>
    <segment id="15">PauloMais    novamente         de   de  de  representando um</segment>
    <segment id="16">A atriz Deborah Secco e a cantora Jojo Todynho foram à abertura do gexperience</segment>
    <segment id="17">, espaço interativo baseado em produções dos canais Globo</segment>
    <segment id="18">, no Shopping Market Place</segment>
    <segment id="19">, em São Paulo.</segment>
    <segment id="20">O ator Cauã Reymond e o apresentador Marcos Mion também compareceram à inauguração</segment>
    <segment id="21">, ocorrida na segunda-feira (7).  com BIANKA VIEIRA</segment>
    <segment id="22">, KARINA MATIAS e MANOELLA SMITH</segment>
  </rst>
