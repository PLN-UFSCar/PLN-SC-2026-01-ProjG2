  <rst>
    <segment id="1">Com seus 25.138 estabelecimentos voltados à alimentação</segment>
    <segment id="2">, São Paulo tem razão para</segment>
    <segment id="3">sese considerar a capital gastronômica do país.</segment>
    <segment id="4">Nenhuma outra cidade brasileira reúne cozinhas de tantos estados e países —passam de 50 diferentes</segment>
    <segment id="5">, pela estimativa do Observatório da Gastronomia da Prefeitura de São Paulo.</segment>
    <segment id="6">Tamanha diversidade é fruto da salada de povos que a cidade atraiu ao longo de 469 anos</segment>
    <segment id="7">, celebrados nesta quarta</segment>
    <segment id="8">, dia 25.</segment>
    <segment id="9">Aprendemos a comer polenta com italianos do norte</segment>
    <segment id="10">, esfiha com sírios e libaneses e sushi com japoneses.</segment>
    <segment id="11">Sushi de salmão do restaurante Oguru no Itaim</segment>
    <segment id="12">, que,</segment>
    <segment id="13">comocomo em muitos lugares</segment>
    <segment id="14">, é mergulhado no potinho de shoyu pelos clientes - Bruno Santos/FolhapressAgora</segment>
    <segment id="15">, experimente sentar à mesa de um restaurante em Nápoles e pedir pizza de frango com Catupiry.</segment>
    <segment id="16">Quem sabe um hot roll banhado em molho teriyaki em solo japonês?</segment>
    <segment id="17">É fato que o fenômeno da apropriação</segment>
    <segment id="18">sese repete em outras cidades</segment>
    <segment id="19">, masmas em São Paulo</segment>
    <segment id="20">, que se</segment>
    <segment id="21">se vende</segment>
    <segment id="22">comocomo meca da gastronomia mundial</segment>
    <segment id="23">, tudo ganha contornos particulares.</segment>
    <segment id="24">É fruto de um processo de adaptação que teve início com os imigrantes</segment>
    <segment id="25">, afirma o sushiman Jun Sakamoto.</segment>
    <segment id="26">"</segment>
    <segment id="27">A maioria dos sushimen de São Paulo aprendeu com o ajudante do ajudante do imigrante</segment>
    <segment id="28">, que também não era sushiman</segment>
    <segment id="29">, masmas um agricultor que passou a cozinhar por necessidade"</segment>
    <segment id="30">, argumenta.</segment>
    <segment id="31">O resultado</segment>
    <segment id="32">, emenda Sakamoto</segment>
    <segment id="33">, é um cardápio que passa longe da cozinha japonesa autêntica.</segment>
    <segment id="34">"</segment>
    <segment id="35">Sushi frito ou com cream cheese é</segment>
    <segment id="36">comocomo usar um kimono na festa à fantasia.</segment>
    <segment id="37">Você parece japonês</segment>
    <segment id="38">, masmas não é.</segment>
    <segment id="39">"</segment>
    <segment id="40">Veja imagens de pizzas e pizzarias paulistanasMais    novamente         de   de  de  representando um</segment>
    <segment id="41">O mesmo vale para o hábito de afundar sushis e sashimis no pratinho de shoyu —pela potência</segment>
    <segment id="42">, diz Sakamoto</segment>
    <segment id="43">, o molho de soja impede que</segment>
    <segment id="44">sese sinta o real sabor do peixe.</segment>
    <segment id="45">"</segment>
    <segment id="46">No Japão</segment>
    <segment id="47">, os pratos têm sabores sutis e equilibrados</segment>
    <segment id="48">, enquanto o brasileiro</segment>
    <segment id="49">, em especial o paulistano</segment>
    <segment id="50">, prefere que tudo seja muito doce ou salgado.</segment>
    <segment id="51">"</segment>
    <segment id="52">Sócio da rede Oguru</segment>
    <segment id="53">, com três restaurantes que operam em sistema de rodízio</segment>
    <segment id="54">, Gabriel Fullen nem discute —sabe que precisa deixar uma quantidade farta de shoyu nas mesas.</segment>
    <segment id="55">Por mês</segment>
    <segment id="56">, o consumo das três casas passa de 1.100 litros.</segment>
    <segment id="57">Entre os pratos</segment>
    <segment id="58">, diz Fullen</segment>
    <segment id="59">, nada</segment>
    <segment id="60">sese compara à demanda por salmão: o peixe está presente em metade dos pedidos.</segment>
    <segment id="61">"</segment>
    <segment id="62">Acabei de voltar do Japão e vi restaurantes oferecendo salmão</segment>
    <segment id="63">comocomo opção</segment>
    <segment id="64">, masmas quem pede é turista"</segment>
    <segment id="65">, diz Sakamoto.</segment>
    <segment id="66">Processo parecido</segment>
    <segment id="67">sese deu com a cozinha italiana.</segment>
    <segment id="68">Décadas de adaptações e improvisos resultaram em um receituário próprio da cidade.</segment>
    <segment id="69">Autora de "Sabores e Memórias:</segment>
    <segment id="70">Cozinha Italiana e Construção Identitária em São Paulo"</segment>
    <segment id="71">, tese de doutorado em antropologia social pela USP</segment>
    <segment id="72">, Janine Collaço conta que os italianos</segment>
    <segment id="73">sese admiraram ao constatar que</segment>
    <segment id="74">, na cidade</segment>
    <segment id="75">, quase não</segment>
    <segment id="76">sese consumiam verduras e legumes.</segment>
    <segment id="77">Não por acaso</segment>
    <segment id="78">, massas secas</segment>
    <segment id="79">, molho de tomate e pão</segment>
    <segment id="80">sese tornaram a base da alimentação dos imigrantes.</segment>
    <segment id="81">Comida japonesaMais    novamente         de   de  de  representando um</segment>
    <segment id="82">O preparo de receitas simples também esbarrou</segment>
    <segment id="83">, por anos a fio</segment>
    <segment id="84">, na dificuldade de acesso a produtos importados</segment>
    <segment id="85">, o que explica adaptações que</segment>
    <segment id="86">sese consolidaram por aqui.</segment>
    <segment id="87">É o caso</segment>
    <segment id="88">caso do fettuccine alfredo</segment>
    <segment id="89">, cuja receita original romana leva massa</segment>
    <segment id="90">, queijo parmigiano reggiano</segment>
    <segment id="91">, manteiga e só.</segment>
    <segment id="92">"</segment>
    <segment id="93">O parmigiano de verdade derrete fácil</segment>
    <segment id="94">, masmas quem usa um queijo alternativo precisa recorrer a outra gordura.</segment>
    <segment id="95">A solução que encontraram foi adicionar creme de leite"</segment>
    <segment id="96">, explica o chef italiano Marco Renzetti</segment>
    <segment id="97">, da Fame Osteria.</segment>
    <segment id="98">O item também foi parar na panela do espaguete à carbonara paulistano</segment>
    <segment id="99">, para desgosto dos italianos.</segment>
    <segment id="100">Mas por outra razão</segment>
    <segment id="101">, diz o chef.</segment>
    <segment id="102">"</segment>
    <segment id="103">Nós gostamos de preparos mornos e alguns molhos não podem ser muito aquecidos.</segment>
    <segment id="104">O carbonara deve sair da cozinha a 60ºC</segment>
    <segment id="105">, senão o ovo coagula.</segment>
    <segment id="106">Mas o paulistano não gosta de comida morna.</segment>
    <segment id="107">Para driblar o problema</segment>
    <segment id="108">, restaurantes introduziram o creme de leite.</segment>
    <segment id="109">"</segment>
    <segment id="110">Na cozinha do Métzi</segment>
    <segment id="111">, os chefs</segment>
    <segment id="112">Eduardo Ortiz e Luana Sabino</segment>
    <segment id="113">, ele mexicano e ela brasileira</segment>
    <segment id="114">, têm trabalho com pimentas e coentro.</segment>
    <segment id="115">São ingredientes praticamente obrigatórios em parte dos pratos da autêntica culinária do México</segment>
    <segment id="116">, para os quais o paulistano historicamente torce o nariz.</segment>
    <segment id="117">Aprenda a preparar espaguete à carbonaraMais    novamente         de   de  de  representando um  "Acho que as pessoas daqui não crescem comendo isso.</segment>
    <segment id="118">No meu país</segment>
    <segment id="119">, usamos coentro em muitas preparações</segment>
    <segment id="120">, crescemos com esse sabor"</segment>
    <segment id="121">, afirma o chef</segment>
    <segment id="122">, que tenta vencer a resistência na base do jeitinho.</segment>
    <segment id="123">A percepção tem respaldo científico.</segment>
    <segment id="124">Segundo a franco-brasileira Sophie Deram</segment>
    <segment id="125">, PhD em nutrição</segment>
    <segment id="126">, o paladar é um combinado de fatores genéticos e culturais.</segment>
    <segment id="127">Parte do que gostamos é geneticamente determinado</segment>
    <segment id="128">, masmas hábitos podem reforçar ou transformar essa programação.</segment>
    <segment id="129">"</segment>
    <segment id="130">Estudos mostram que</segment>
    <segment id="131">, às vezes</segment>
    <segment id="132">, é preciso apresentar um sabor até 15 vezes</segment>
    <segment id="133">para que</segment>
    <segment id="134">para que a criança comece a aceitá-lo"</segment>
    <segment id="135">, diz.</segment>
    <segment id="136">O coentro</segment>
    <segment id="137">, porém</segment>
    <segment id="138">porém, merece ser tratado de forma diferente.</segment>
    <segment id="139">"Já se</segment>
    <segment id="140">se comprovou que algumas pessoas sentem gosto de sabonete no coentro.</segment>
    <segment id="141">É importante respeitar.</segment>
    <segment id="142">"  Mas o chef paraibano Onildo Rocha</segment>
    <segment id="143">, do Notiê Priceless</segment>
    <segment id="144">, em São Paulo</segment>
    <segment id="145">, suspeita que o paulistano tem</segment>
    <segment id="146">, sim, certa má vontade com o coentro</segment>
    <segment id="147">, ingrediente que não fica de fora de seus menus.</segment>
    <segment id="148">Com tato</segment>
    <segment id="149">, descobriu que o item passa</segment>
    <segment id="150">, nem que seja com outro nome.</segment>
    <segment id="151">"</segment>
    <segment id="152">Faço um camarão servido com espuma de chicória-do-pará</segment>
    <segment id="153">, que não passa de um coentrão.</segment>
    <segment id="154">Os paulistanos comem e acham uma delícia"</segment>
    <segment id="155">, diz.</segment>
    <segment id="156">E nem é preciso insistir.</segment>
    <segment id="157">ONDE PROVAR RECEITAS</segment>
    <segment id="158">À MODA ORIGINAL  JAPONESA  Aizomê Al.</segment>
