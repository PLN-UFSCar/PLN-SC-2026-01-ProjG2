  <rst>
    <segment id="1">Os supostos assassinos do jornalista saudita Jamal Khashoggi comentaram</segment>
    <segment id="2">, em tom de brincadeira</segment>
    <segment id="3">, que "um açougueiro não corta sua carne no chão"</segment>
    <segment id="4">, pouco antes de executá-lo no consulado saudita em Istambul</segment>
    <segment id="5">, revelam testemunhas entrevistadas pela rede BBC.</segment>
    <segment id="6">Há um ano</segment>
    <segment id="7">, em 2 de outubro de 2018</segment>
    <segment id="8">, Khashoggi</segment>
    <segment id="9">, um jornalista crítico ao reino</segment>
    <segment id="10">, foi ao consulado saudita em Istambul para</segment>
    <segment id="11">, de acordo com a noiva</segment>
    <segment id="12">, resolver a papelada para seu casamento.</segment>
    <segment id="13">Ele nunca deixou o consulado</segment>
    <segment id="14">, e seus restos mortais ainda não foram encontrados.</segment>
    <segment id="15">Manequins desmembrados com coletes de imprensa colocados</segment>
    <segment id="16">comocomo forma de protesto pela organização Repórteres sem Fronteiras em frente ao consulado da Arábia Saudita em Paris   - Philippe Lopez/AFPA princípio</segment>
    <segment id="17">, Riad afirmou que o jornalista teria sido morto no consulado durante uma briga.</segment>
    <segment id="18">Posteriormente</segment>
    <segment id="19">, o príncipe herdeiro saudita mudou a versão e admitiu que ele foi morto e esquartejado por funcionários do reino sem seu conhecimento.</segment>
    <segment id="20">Helena Kennedy</segment>
    <segment id="21">, uma advogada britânica que participou da investigação da ONU realizada desde então</segment>
    <segment id="22">, ouviu uma gravação fornecida pelas autoridades turcas —que tinham microfones instalados no consulado—</segment>
    <segment id="23">, nas quais Khashoggi é descrito</segment>
    <segment id="24">comocomo "animal destinado ao sacrifício".</segment>
    <segment id="25">"</segment>
    <segment id="26">Eles se</segment>
    <segment id="27">se perguntavam '</segment>
    <segment id="28">sese o corpo e o quadril dariam dentro de uma bolsa'"</segment>
    <segment id="29">, disse ela à BBC no documentário transmitido no programa Panorama na noite de segunda-feira (30)</segment>
    <segment id="30">, um ano após o assassinato em 2 de outubro de 2018.</segment>
    <segment id="31">O médico legista suspeito de ter cortado o corpo em pedaços disse: "</segment>
    <segment id="32">Costumo ouvir música ao cortar cadáveres.</segment>
    <segment id="33">Às vezes</segment>
    <segment id="34">, com um café e um cigarro na mão"</segment>
    <segment id="35">, segundo Kennedy.</segment>
    <segment id="36">"</segment>
    <segment id="37">Ele disse:</segment>
    <segment id="38">'É a primeira vez na minha vida que tenho que cortar pedaços no chão —até um açougueiro que quer cortar um animal o pendura'"</segment>
    <segment id="39">, acrescentou.</segment>
    <segment id="40">"</segment>
    <segment id="41">Você os ouve rir</segment>
    <segment id="42">, é arrepiante"</segment>
    <segment id="43">, contou a advogada.</segment>
    <segment id="44">"</segment>
    <segment id="45">Você ouve</segment>
    <segment id="46">Khashoggi passar do sentimento de confiança ao medo</segment>
    <segment id="47">, depois a uma agonia crescente</segment>
    <segment id="48">, ao terror e</segment>
    <segment id="49">, finalmente</segment>
    <segment id="50">, à percepção de que algo vai acontecer"</segment>
    <segment id="51">, conta Kennedy.</segment>
    <segment id="52">A relatora especial da ONU Agnès Callamard</segment>
    <segment id="53">, que também ouviu a gravação</segment>
    <segment id="54">, disse que Khashoggi perguntou a seus carrascos "Vocês vão me dar uma injeção?</segment>
    <segment id="55">" e recebeu um "sim"</segment>
    <segment id="56">comocomo resposta.</segment>
    <segment id="57">"</segment>
    <segment id="58">O que ouvimos depois mostra que ele está sendo sufocado</segment>
    <segment id="59">, provavelmente com um saco plástico na cabeça"</segment>
    <segment id="60">, acrescentou ela.  "</segment>
    <segment id="61">Algum tempo depois</segment>
    <segment id="62">, alguém diz:</segment>
    <segment id="63">'É um cachorro</segment>
    <segment id="64">, ponha isso na cabeça dele</segment>
    <segment id="65">, e a envolva'.</segment>
    <segment id="66">Só podemos entender que eles cortaram a cabeça dele"</segment>
    <segment id="67">, explicou ela à BBC.</segment>
    <segment id="68">A Turquia entregou à ONU uma gravação de 45 minutos no contexto de sua investigação sobre o assassinato do jornalista</segment>
    <segment id="69">, um crítico ferrenho do regime de Riad.</segment>
    <segment id="70">O assassinato</segment>
    <segment id="71">, que supostamente envolveu 15 agentes sauditas</segment>
    <segment id="72">, provocou grande comoção.</segment>
    <segment id="73">A CIA e a especialista da ONU</segment>
    <segment id="74">Agnes</segment>
    <segment id="75">Callamard apontaram</segment>
    <segment id="76">comocomo responsável o príncipe herdeiro saudita</segment>
    <segment id="77">, Mohammed bin Salman.</segment>
    <segment id="78">Ele nega envolvimento no</segment>
    <segment id="79">casocaso.</segment>
    <segment id="80">Na tentativa de restaurar sua imagem</segment>
    <segment id="81">, o reino saudita levou 11 suspeitos à Justiça.</segment>
    <segment id="82">Cinco deles podem ser sentenciados à morte.</segment>
    <segment id="83">Entenda o</segment>
    <segment id="84">casocaso do jornalista saudita desaparecido   novamente         de   de  de  representando um  Manequins desmembrados  Para recordar um ano do assassinato de Khashoggi</segment>
    <segment id="85">, a ONG Repórteres Sem Fronteiras (RSF) espalhou nesta terça vários manequins desmembrados na frente do consulado saudita</segment>
    <segment id="86">, nos arredores de Paris</segment>
    <segment id="87">, exigindo que as circunstâncias de sua morte sejam esclarecidas.</segment>
    <segment id="88">Os militantes colocaram os manequins de plástico</segment>
    <segment id="89">, usando coletes com a palavra "Press"</segment>
    <segment id="90">, diante do consulado localizado em Neuilly-sur-Seine.</segment>
    <segment id="91">De acordo com o secretário-geral da RSF</segment>
    <segment id="92">, Christophe Deloire</segment>
    <segment id="93">, a ação também tem o objetivo de chamar a atenção para todos que buscam a liberdade de imprensa na Arábia Saudita.</segment>
    <segment id="94">Hoje, segundo Deloire</segment>
    <segment id="95">, cerca de 30 jornalistas e blogueiros estão detidos neste país.</segment>
    <segment id="96">Deloire</segment>
    <segment id="97">sese mostrou cético em relação às declarações do príncipe herdeiro saudita.</segment>
    <segment id="98">Ele negou ter ordenado o assassinato do jornalista</segment>
    <segment id="99">, masmas assumiu "a responsabilidade</segment>
    <segment id="100">comocomo líder da Arábia Saudita".</segment>
    <segment id="101">"É uma maneira de</segment>
    <segment id="102">sese livrar de perguntas sobre sua culpa pessoal e sua responsabilidade de</segment>
    <segment id="103">sese comprometer com a liberdade de imprensa na Arábia Saudita</segment>
    <segment id="104">, onde o jornalismo está sujeito a uma repressão feroz"</segment>
    <segment id="105">, afirmou o secretário-geral da ONG.</segment>
    <segment id="106">Um filho de Khashoggi</segment>
    <segment id="107">, Salah Khashoggi</segment>
    <segment id="108">, afirmou</segment>
    <segment id="109">, no entanto</segment>
    <segment id="110">, que confia na justiça da Arábia Saudita para resolver o crime e criticou as pessoas que tentam</segment>
    <segment id="111">sese aproveitar do</segment>
    <segment id="112">casocaso.</segment>
    <segment id="113">"</segment>
    <segment id="114">Passou um ano desde o falecimento de meu querido pai.</segment>
    <segment id="115">Durante este tempo</segment>
    <segment id="116">, opositores e inimigos do Leste e Oeste tentam aproveitar seu</segment>
    <segment id="117">casocaso (...) para prejudicar meu país e sua liderança"</segment>
    <segment id="118">, tuitou Salah Khashoggi</segment>
    <segment id="119">, que mora na Arábia Saudita.</segment>
    <segment id="120">"</segment>
    <segment id="121">Tenho total confiança no sistema judicial do reino e em sua habilidade para fazer justiça com os que estão por trás deste crime atroz"</segment>
    <segment id="122">, completou.</segment>
  </rst>
</analysis>