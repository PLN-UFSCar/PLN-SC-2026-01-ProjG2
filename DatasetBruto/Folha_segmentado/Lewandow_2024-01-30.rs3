  <rst>
    <segment id="1">O novo ministro da Justiça</segment>
    <segment id="2">, Ricardo Lewandowski</segment>
    <segment id="3">, deve ter ao menos cinco mulheres no primeiro escalão de sua equipe direta.</segment>
    <segment id="4">Elas devem ocupar secretarias e diretorias da pasta.</segment>
    <segment id="5">Ricardo Lewandowski em cerimônia no Ministério da Educação</segment>
    <segment id="6">, em Brasília</segment>
    <segment id="7">, que homenageou a sua carreira - Gabriela Biló - 11.abr.2023/FolhapressOFICIAL</segment>
    <segment id="8">Os nomes devem ser anunciados oficialmente na cerimônia de posse</segment>
    <segment id="9">, no Palácio do Planalto</segment>
    <segment id="10">, marcado para a quinta (1º).  XADREZ  Algumas delas</segment>
    <segment id="11">, como</segment>
    <segment id="12">como a advogada Sheila de Carvalho</segment>
    <segment id="13">, do Comitê Nacional para os Refugiados</segment>
    <segment id="14">, já integravam o ministério</segment>
    <segment id="15">, e serão deslocadas para novas missões.</segment>
    <segment id="16">A presidente do Comitê Nacional para os Refugiados (Conare) e assessora especial do Ministério da Justiça e Segurança Pública</segment>
    <segment id="17">, Sheila de Carvalho - Ministério da Justiça e Segurança Pública/DivulgaçãoXADREZ 2  Um dos desafios do governo Lula é aumentar o espaço das mulheres em cargos estratégicos.</segment>
    <segment id="18">CERTEZA</segment>
    <segment id="19">Na cerimônia em que anunciou o novo ministro</segment>
    <segment id="20">, o presidente da República afirmou que a primeira-dama Rosângela da Silva (Janja) tinha a expectativa de que Lewandowski nomeasse muitas mulheres para a pasta.</segment>
    <segment id="21">O novo ministro respondeu: "</segment>
    <segment id="22">Certamente".</segment>
    <segment id="23">Este é Ricardo LewandowskiMais    novamente         de   de  de  representando um  LEIA</segment>
    <segment id="24">TODOS OS TEMAS ABORDADOS PELA COLUNA NA EDIÇÃO IMPRESSA DESTA QUARTA (31)Lewandowski indicará cinco mulheres para cargos no primeiro escalão do Ministério da JustiçaPrerrogativas levará 77 advogados para posse de Lewandowski na JustiçaJulgamento no STF pode levar Pantanal a desmatamento sem precedentes</segment>
    <segment id="25">, afirmam entidadesBarroso diz que Chico Buarque já teria ganhado Nobel</segment>
    <segment id="26">sese língua portuguesa não fosse barreiraConfederação israelita propõe prisão de Breno Altman após apoio a GenoinoMarco Nanini apresentará &amp;#039</segment>
    <segment id="27">;Traidor&amp;#039</segment>
    <segment id="28">;</segment>
    <segment id="29">no Festival de CuritibaAna Cañas receberá Ney Matogrosso em show em SPRebeca Andrade estrelará capa da Marie Claire de fevereiro</segment>
    <segment id="30">SALTO</segment>
    <segment id="31">A ginasta Rebeca Andrade em ensaio para a revista Marie Claire - Marcus Sabah/DivulgaçãoA ginasta Rebeca Andrade estrelará a capa de fevereiro da revista Marie Claire.</segment>
    <segment id="32">Citada pela publicação</segment>
    <segment id="33">comocomo "uma das maiores promessas de medalha para o Brasil"</segment>
    <segment id="34">, a atleta falou sobre sua preparação para as Olimpíadas de Paris</segment>
    <segment id="35">, a infância pobre</segment>
    <segment id="36">, seus medos e seus sonhos.</segment>
    <segment id="37">"</segment>
    <segment id="38">Me orgulho demais em saber que posso continuar o legado da [ginasta americana] Simone Biles.</segment>
    <segment id="39">Não só eu</segment>
    <segment id="40">, masmas tantas outras.</segment>
    <segment id="41">É o esporte que a gente ama"</segment>
    <segment id="42">, disse.</segment>
    <segment id="43">A edição poderá ser conferida a partir desta quarta (31).  com BIANKA VIEIRA</segment>
    <segment id="44">, KARINA MATIAS e MANOELLA SMITH</segment>
