  <rst>
    <segment id="1">A primeira suspeita surge quando o gato começa a</segment>
    <segment id="2">sese coçar em excesso:</segment>
    <segment id="3">será que ele está com pulga?</segment>
    <segment id="4">Como os bichanos costumam ser muito peludinhos</segment>
    <segment id="5">, pode ser difícil identificar o parasita no corpo do animal.</segment>
    <segment id="6">A presença desses insetos também é notada pelas fezes que eles deixam na pele do felino</segment>
    <segment id="7">, com aspecto de areia fina e bem escura.</segment>
    <segment id="8">Pulgas são ectoparasitas</segment>
    <segment id="9">, ou seja</segment>
    <segment id="10">, parasitas externos</segment>
    <segment id="11">, que se</segment>
    <segment id="12">se alimentam do sangue do hospedeiro.</segment>
    <segment id="13">Quando há infestação</segment>
    <segment id="14">, 95% delas estão no ambiente e apenas no 5% do corpo do animal</segment>
    <segment id="15">, explica a veterinária Bárbara Duarte</segment>
    <segment id="16">, coordenadora técnica da farmacêutica MSD Saúde Animal.</segment>
    <segment id="17">Por gatos serem muito caseiros</segment>
    <segment id="18">, os tutores geralmente não acreditam que eles podem pegar pulga</segment>
    <segment id="19">, pois</segment>
    <segment id="20">pois não têm acesso à rua ou contato com outros bichos.</segment>
    <segment id="21">Mas não é bem assim.</segment>
    <segment id="22">"</segment>
    <segment id="23">As pulgas podem chegar até o gato por meio de cães que vivem na mesma casa</segment>
    <segment id="24">, masmas saem para passear</segment>
    <segment id="25">, ou mesmo virem grudadas nas roupas do tutor quando chega da rua"</segment>
    <segment id="26">, observa Duarte.</segment>
    <segment id="27">Meu gato está acima do peso?Mais    novamente         de   de  de  representando um</segment>
    <segment id="28">Elas transmitem doenças</segment>
    <segment id="29">comocomo verminoses e bartonelose (doença da arranhadura do gato)</segment>
    <segment id="30">, que podem ser transmissíveis também ao ser humano</segment>
    <segment id="31">, além de dermatites.</segment>
    <segment id="32">Para acabar com esses insetos é preciso entender o ciclo de vida deles</segment>
    <segment id="33">, conta a veterinária.</segment>
    <segment id="34">As pulgas nascem de ovos que ficam depositados em locais da casa onde o gato costuma</segment>
    <segment id="35">sese deitar</segment>
    <segment id="36">, como</segment>
    <segment id="37">como tapetes</segment>
    <segment id="38">, almofadas</segment>
    <segment id="39">, móveis e até mesmo na grama ou em vasos.</segment>
    <segment id="40">Desses ovos irão surgir larvas que</segment>
    <segment id="41">, quando adultas</segment>
    <segment id="42">, viram pulgas.</segment>
    <segment id="43">As fêmeas vão dar novos ovos e o ciclo irá</segment>
    <segment id="44">sese renovar.  "</segment>
    <segment id="45">O tempo</segment>
    <segment id="46">para que</segment>
    <segment id="47">para que os ovos tornem-</segment>
    <segment id="48">sese insetos costuma demorar de cinco a seis semanas"</segment>
    <segment id="49">, diz.</segment>
    <segment id="50">Para interromper esse desenvolvimento</segment>
    <segment id="51">, é necessário aplicar no bichano um antipulgas.</segment>
    <segment id="52">"</segment>
    <segment id="53">O Bravecto</segment>
    <segment id="54">, da MSD Saúde Animal</segment>
    <segment id="55">, oferece 12 semanas de proteção contra pulgas</segment>
    <segment id="56">, um tempo superior ao tempo médio do ciclo desses parasitas</segment>
    <segment id="57">, e, dessa forma</segment>
    <segment id="58">, atua atingindo todas as suas fases de evolução a partir do momento em que a pulga está apta para</segment>
    <segment id="59">sese alimentar.</segment>
    <segment id="60">Além disso</segment>
    <segment id="61">, o produto também trata a sarna otodécica</segment>
    <segment id="62">, responsável por 85% da causa das otites (inflamação ou infecção no ouvido) em gatos.</segment>
    <segment id="63">Outra vantagem é que o produto apresenta a versão Plus para gatos que também trata os principais vermes intestinais da espécie.</segment>
    <segment id="64">Ainda, é importante lembrar que o efeito prolongado evita esquecimentos e interrupção na prevenção e tratamento que aconteceria com medicamentos com menor duração de ação que as 12 semanas</segment>
    <segment id="65">, deixando brechas para a reincidência de uma infestação de pulgas"</segment>
    <segment id="66">, afirma a veterinária.</segment>
    <segment id="67">É indicado reaplicar o antiparasita regularmente</segment>
    <segment id="68">, a cada 12 semanas</segment>
    <segment id="69">, para que</segment>
    <segment id="70">para que os insetos não voltem a atacar.</segment>
    <segment id="71">O correto é passar o remédio no pescoço do felino</segment>
    <segment id="72">, na parte de trás</segment>
    <segment id="73">, para que</segment>
    <segment id="74">para que ele não consiga lamber.</segment>
    <segment id="75">Outro ponto importante é limpar bem o ambiente</segment>
    <segment id="76">, especialmente aqueles cantinhos onde seu gato costuma deitar</segment>
    <segment id="77">, para auxiliar na eliminação dos ovos das pulgas.  +</segment>
    <segment id="78">GaticesLeia mais sobre gatosDia do Gato:</segment>
    <segment id="79">veterinária ensina</segment>
    <segment id="80">comocomo tratar seu felino</segment>
    <segment id="81">comocomo um reiGatos precisam de cuidados especiais nos dias friosVômito em gatos: especialista em felinos explica causasSiga o blog Gatices no Twitter</segment>
    <segment id="82">, Instagram e Facebook.</segment>
  </rst>
</analysis>