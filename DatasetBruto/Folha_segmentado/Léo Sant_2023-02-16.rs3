  <rst>
    <segment id="1">Para o cantor Léo Santana</segment>
    <segment id="2">, o Carnaval de 2023 tem tudo para ser um dos melhores da história da festa de rua.</segment>
    <segment id="3">Ele se</segment>
    <segment id="4">se refere ao retorno pleno das atividades depois do período de isolamento social da pandemia de Covid-19 e do ano passado</segment>
    <segment id="5">, ainda com algumas restrições.  "</segment>
    <segment id="6">As pessoas estão ávidas pelo Carnaval.</segment>
    <segment id="7">Salvador está lotada de turistas do Brasil e do mundo</segment>
    <segment id="8">, o povo está com saudade de reviver a folia e a alegria"</segment>
    <segment id="9">, diz.</segment>
    <segment id="10">"</segment>
    <segment id="11">Acredito que vamos ter um dos melhores carnavais da história em todos os aspectos e estou mais do que pronto para levar alegria e muita diversão para o povo.</segment>
    <segment id="12">"</segment>
    <segment id="13">O cantor Léo Santana durante sua apresentação no circuito Osmar no Campo Grande</segment>
    <segment id="14">, que faz parte do Carnaval de Salvador - Raphael Muller - 21.fev.20/FolhapressO cantor baiano chega ao Carnaval deste ano com um dos maiores hits do verão</segment>
    <segment id="15">, "Zona de Perigo".</segment>
    <segment id="16">A música</segment>
    <segment id="17">, a princípio</segment>
    <segment id="18">, não era a aposta principal de Santana para fazer sucesso</segment>
    <segment id="19">, masmas acabou</segment>
    <segment id="20">sese impondo organicamente.</segment>
    <segment id="21">"</segment>
    <segment id="22">Estávamos trabalhando a canção 'Não</segment>
    <segment id="23">sese Vá'</segment>
    <segment id="24">, gravada em parceria com Pedro Sampaio</segment>
    <segment id="25">, masmas 'Zona de Perigo' começou a crescer bastante nos shows e acabou conquistando o público de uma maneira muito natural e orgânica"</segment>
    <segment id="26">, afirma. "</segment>
    <segment id="27">Aí gravei um vídeo</segment>
    <segment id="28">, publiquei no Instagram e TikTok e 'boom'</segment>
    <segment id="29">, explodiu!</segment>
    <segment id="30">"  Imagens do cantor</segment>
    <segment id="31">Léo SantanaMais    novamente         de   de  de  representando um  Um pagodão com elementos de bregadeira</segment>
    <segment id="32">, bachata e um arranjo de sax</segment>
    <segment id="33">, "Zona de Perigo" foi escrita e produzida por um coletivo de compositores baianos chamado Munição</segment>
    <segment id="34">, formado por Rafa Chagas</segment>
    <segment id="35">, Adriel Max</segment>
    <segment id="36">, Fella Brown</segment>
    <segment id="37">, Pierrot Junior e Yvees Santana.</segment>
    <segment id="38">Nas últimas semanas</segment>
    <segment id="39">, a faixa disparou para as primeiras posições nas paradas dos serviços de streaming.</segment>
    <segment id="40">"</segment>
    <segment id="41">Recebi a canção dos compositores e na mesma hora que ouvi</segment>
    <segment id="42">, gostei</segment>
    <segment id="43">, mandei para meu diretor musical e para Rafinha</segment>
    <segment id="44">, meu produtor musical"</segment>
    <segment id="45">, diz Santana.</segment>
    <segment id="46">"</segment>
    <segment id="47">Pedi para inserir alguns elementos e mexi em algumas coisas no ritmo.</segment>
    <segment id="48">Agora, inclusive</segment>
    <segment id="49">, ela ganhou algumas versões</segment>
    <segment id="50">comocomo lambada</segment>
    <segment id="51">, arrocha</segment>
    <segment id="52">, piseiro —e eu estou mais do que feliz com tudo isso.</segment>
    <segment id="53">"</segment>
    <segment id="54">De Zé Neto a Léo Santana</segment>
    <segment id="55">, veja as sungas de famosos que surpreenderam seus fãsMais    novamente         de   de  de  representando um  Uma das razões da viralização da música é a coreografia</segment>
    <segment id="56">, que impulsionou "Zona de Perigo" nos aplicativos de vídeos curtos</segment>
    <segment id="57">, como</segment>
    <segment id="58">como TikTok e Kwai.</segment>
    <segment id="59">O passinho foi criado por Edilene Alves</segment>
    <segment id="60">, bailarina e coreógrafa de Santana há mais de 15 anos</segment>
    <segment id="61">, que se</segment>
    <segment id="62">se destacou com movimentos mais fáceis de serem reproduzidos</segment>
    <segment id="63">, em contraste com a complexidade habitual do TikTok.</segment>
    <segment id="64">Representante mais famoso do pagode baiano atual</segment>
    <segment id="65">, Santana reconhece o crescimento do gênero</segment>
    <segment id="66">, que vem</segment>
    <segment id="67">sese destacando no Carnaval.</segment>
    <segment id="68">Além dele</segment>
    <segment id="69">, nomes</segment>
    <segment id="70">comocomo Oh Polêmico</segment>
    <segment id="71">, O Kannalha e O Poeta</segment>
    <segment id="72">, entre outros têm músicas entre as mais tocadas neste verão.</segment>
    <segment id="73">"</segment>
    <segment id="74">Acredito sim que hoje o pagode ganhou uma representatividade nacional e um respeito maior</segment>
    <segment id="75">, hoje chega a lugares a que antes não chegava</segment>
    <segment id="76">, como</segment>
    <segment id="77">como os grandes festivais —inclusive rodeios</segment>
    <segment id="78">, festas de peão e afins"</segment>
    <segment id="79">, diz Santana.</segment>
    <segment id="80">O cantor já falou sobre o pagodão ser vítima de preconceito por ser uma música da periferia de Salvador.</segment>
    <segment id="81">"</segment>
    <segment id="82">Hoje, [o pagode] atinge públicos que não atingia antes e isso tudo</segment>
    <segment id="83">sese reflete na forma</segment>
    <segment id="84">comocomo sou recebido por onde passo.</segment>
    <segment id="85">Acredito</segment>
    <segment id="86">, sim, que hoje o pagode é um ritmo que representa muito a música e o Carnaval.</segment>
    <segment id="87">"</segment>
  </rst>
</analysis>