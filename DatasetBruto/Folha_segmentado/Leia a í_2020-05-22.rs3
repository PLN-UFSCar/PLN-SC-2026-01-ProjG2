    <segment id="195">E nas viabilizadoras</segment>
    <segment id="196">, que são transversais na... em toda parte do programa</segment>
    <segment id="197">, nós temos finanças e tributação</segment>
    <segment id="198">, legislação e controle</segment>
    <segment id="199">, meio ambiente e a parte institucional e internacional.</segment>
    <segment id="200">Qual é a nossa</segment>
