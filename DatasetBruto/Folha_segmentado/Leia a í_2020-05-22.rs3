    <segment id="102">, readequar isso aí para</segment>
    <segment id="103">comocomo o governo deve reagir a este problema para achar uma solução para os dois</segment>
    <segment id="104">, as duas consequências negativas que ocorrem.</segment>
    <segment id="105">Próximo.</segment>
    <segment id="106">Então é um programa</segment>
    <segment id="107">, o programa</segment>
    <segment id="108">sese chama Pró-Brasil</segment>
    <segment id="109">, tá?</segment>
    <segment id="110">Volto, dou o crédito ao... o azar do Tarcísio foi ele ter conversado comigo (risos).</segment>
    <segment id="111">Eu gostei e roubei.  Jair Bolsonaro: Capitão</segment>
