  <rst>
    <segment id="1">O Prêmio Espírito Público</segment>
    <segment id="2">, que valoriza profissionais dedicados à promoção de serviços públicos de qualidade no país</segment>
    <segment id="3">, reconhece neste ano nove vencedores.</segment>
    <segment id="4">As pessoas e projetos que chegaram à final foram homenageados em cerimônia hoje (30) no Rio de Janeiro.</segment>
    <segment id="5">Nesta quinta edição</segment>
    <segment id="6">, com 27 finalistas</segment>
    <segment id="7">, foram premiados cinco servidores públicos pela categoria "Pessoas que Transformam"</segment>
    <segment id="8">, três equipes pela categoria "Projetos que Transformam" e um iniciativa de sucesso por votação popular.</segment>
    <segment id="9">Projeto Outubro Movimente: De Repente a Gente Muda a Mente vence na categoria Projetos que Transformam - DivulgaçãoO evento teve o ator e humorista Rafael Infante</segment>
    <segment id="10">comocomo mestre de cerimônias</segment>
    <segment id="11">, na Estação NET Botafogo</segment>
    <segment id="12">, e prestou homenagem ao indigenista Bruno Araújo Pereira</segment>
    <segment id="13">, servidor da Funai (Fundação Nacional do Índio)</segment>
    <segment id="14">, assassinado no Vale do Javari em junho deste ano.</segment>
    <segment id="15">Na categoria "Pessoas que Transformam"</segment>
    <segment id="16">, os vencedores são Renata Valéria Sousa</segment>
    <segment id="17">, Leandro Lira</segment>
    <segment id="18">, Felipe Guimarães</segment>
    <segment id="19">, Joel Andrade e Kelly Cristina Carvalho.</segment>
    <segment id="20">Em "</segment>
    <segment id="21">Projetos que Transformam" ganharam Programa Piauiense de Alfabetização na Idade Certa</segment>
    <segment id="22">, Painel Interativo de Higiene de Mãos do Hospital Universitário da Universidade Federal do Maranhão e Outubro Movimente: De Repente a Gente Muda a Mente.</segment>
    <segment id="23">E na votação popular</segment>
    <segment id="24">, que recebeu votos entre 5 e 31 de outubro</segment>
    <segment id="25">, venceu o projeto Educação Antirracista.</segment>
    <segment id="26">Pessoas que Transformam  Vencedora no eixo "Desenvolvimento Social"</segment>
    <segment id="27">, a recifense Renata Valéria Sousa</segment>
    <segment id="28">, 39, é professora da Universidade Federal Rural de Pernambuco (UFRPE) e desenvolve projetos de extensão com foco na promoção da sustentabilidade através do cultivo de abelhas.</segment>
    <segment id="29">Seus experimentos otimizaram a produção dos apicultores em 50% e ampliaram a criação entre famílias em situação de vulnerabilidade</segment>
    <segment id="30">, sobretudo mulheres.</segment>
    <segment id="31">Felipe Guimarães vence eixo &amp;#039</segment>
    <segment id="32">;Meio Ambiente&amp;#039</segment>
    <segment id="33">; na categoria Pessoas que Transformam - DivulgaçãoNo eixo "Intersetorial"</segment>
    <segment id="34">, o advogado e cientista da computação Leandro Lira</segment>
    <segment id="35">, 41, de Campina Grande (PB)</segment>
    <segment id="36">, desenvolveu o Projudi</segment>
    <segment id="37">, primeiro software brasileiro a implementar processos virtuais em larga escala.</segment>
    <segment id="38">O serviço modernizou e expandiu a informatização de cartórios e tribunais de justiça do país e trouxe mais agilidade</segment>
    <segment id="39">, eficiência e sustentabilidade ao meio jurídico.</segment>
    <segment id="40">Felipe Guimarães</segment>
    <segment id="41">, 44, venceu no eixo "Meio Ambiente".</segment>
    <segment id="42">Natural de Florianópolis (SC)</segment>
    <segment id="43">, o biólogo trabalhou no Ibama e percebeu um gargalo no processo de identificação de madeiras quando trabalhava em Ji-Paraná (RO).</segment>
    <segment id="44">Criou um curso para fiscais que impactou o combate à exploração ilegal não só no estado</segment>
    <segment id="45">, masmas no Brasil.</segment>
    <segment id="46">O catarinense Joel de Andrade</segment>
    <segment id="47">, 57, atuou por dez anos</segment>
    <segment id="48">comocomo médico intensivista antes de assumir a coordenação da Central Estadual de Transplantes de Santa Catarina.</segment>
    <segment id="49">Adotou um modelo de doação de órgãos revolucionário que impactou 20 mil vidas e levou o estado à liderança nacional em transplantes.</segment>
    <segment id="50">Vence no eixo "Saúde".</segment>
    <segment id="51">Prêmio Espírito Público anuncia vencedores de 2022Mais    novamente         de   de  de  representando um  E em "Segurança Pública"</segment>
    <segment id="52">, Kelly Carvalho</segment>
    <segment id="53">, 42, de São Luís (MA)</segment>
    <segment id="54">, como</segment>
    <segment id="55">como gestora na Secretaria de Administração Penitenciária do estado</segment>
    <segment id="56">, articulou mudanças estruturais que contribuíram para tornar o sistema prisional do Maranhão referência nacional em humanização de pessoas privadas de liberdade.</segment>
    <segment id="57">Projetos que Transformam  No eixo "Educação"</segment>
    <segment id="58">, o Programa Piauiense de Alfabetização na Idade Certa (PPAIC)</segment>
    <segment id="59">, de Teresina (PI)</segment>
    <segment id="60">, mobilizou</segment>
    <segment id="61">, em tempo recorde</segment>
    <segment id="62">, todos os 224 municípios do estado pela alfabetização na idade certa.</segment>
    <segment id="63">Dados preliminares indicam que</segment>
    <segment id="64">, em Língua Portuguesa</segment>
    <segment id="65">, a proficiência média alcançada em 2021 foi de 574</segment>
    <segment id="66">; em 2022</segment>
    <segment id="67">, aumentou para 599</segment>
    <segment id="68">, sendo 600 o número recomendado.</segment>
    <segment id="69">Já no eixo "</segment>
    <segment id="70">Enfrentamento à Covid-19"</segment>
    <segment id="71">, o Painel Interativo de Higiene de Mãos do Hospital Universitário da Universidade Federal do Maranhão (EBSERH)</segment>
    <segment id="72">, de São Luís (MA)</segment>
    <segment id="73">, estimulou a prática em unidades de saúde</segment>
    <segment id="74">, com adesão de 69% da comunidade hospitalar.</segment>
    <segment id="75">O simples ato de lavar as mãos para evitar a transmissão do vírus contribuiu para prevenir doenças e salvar vidas.</segment>
    <segment id="76">Programa Piauiense de Alfabetização na Idade Certa (PPAIC) vence na categoria Projetos que Transformam - DivulgaçãoO projeto "</segment>
    <segment id="77">Outubro</segment>
    <segment id="78">Movimente:</segment>
    <segment id="79">De Repente a Gente Muda a Mente"</segment>
    <segment id="80">, de Cuiabá (MT)</segment>
    <segment id="81">, venceu no eixo "Gestão de Pessoas" ao desmistificar ideias sobre inovação no setor público.</segment>
    <segment id="82">Uma equipe da Secretaria de Estado de Planejamento e Gestão do Mato Grosso organizou uma série de eventos com a participação de personalidades de destaque no tema.</segment>
    <segment id="83">A ação ganhou alta adesão e tomou proporção inédita</segment>
    <segment id="84">, inaugurando uma mudança de paradigma sobre empreendedorismo no setor público.  Votação Popular</segment>
    <segment id="85">Na categoria de voto aberto</segment>
    <segment id="86">, o projeto Educação Antirracista promoveu</segment>
    <segment id="87">, por meio da Secretaria de Educação de Cachoeira</segment>
    <segment id="88">, na Bahia</segment>
    <segment id="89">, ações de enfrentamento ao racismo e de promoção da equidade racial.</segment>
    <segment id="90">Lives, concursos literários e formações alcançaram a comunidade escolar</segment>
    <segment id="91">, do ensino infantil ao fundamental</segment>
    <segment id="92">, nas modalidades quilombola</segment>
    <segment id="93">, campo</segment>
    <segment id="94">, EJA e educação especial).</segment>
    <segment id="95">A iniciativa melhorou a autoestima de estudantes e aumentou o Índice de Desenvolvimento da Educação Básica (Ideb) do município.</segment>
    <segment id="96">"</segment>
    <segment id="97">Os anos difíceis que passamos serviram para escancarar a potência e a indispensabilidade do serviço público"</segment>
    <segment id="98">, diz Helena Wajnman</segment>
    <segment id="99">, diretora-executiva da República.org</segment>
    <segment id="100">, que realiza a premiação com Fundação Lemann e Instituto Humanize.  Projeto Educação Antirracista vence na categoria de votação popular - Divulgação  "</segment>
    <segment id="101">Os vencedores do Prêmio Espírito Público são a síntese do que há de melhor no Brasil: pessoas inspiradoras trabalhando para transformar para melhor nossa educação</segment>
    <segment id="102">, saúde</segment>
    <segment id="103">, meio ambiente</segment>
    <segment id="104">, segurança pública</segment>
    <segment id="105">, entre outros.</segment>
    <segment id="106">Queremos estender a todo o país o convite para</segment>
    <segment id="107">sese juntar a nós na celebração dessas trajetórias"</segment>
    <segment id="108">, completa.</segment>
    <segment id="109">Em sua quinta edição</segment>
    <segment id="110">, a premiação criada em 2018 já contemplou 75 pessoas e três instituições em todas as regiões do país.</segment>
    <segment id="111">Os nove ganhadores são beneficiados com valores em dinheiro (de R$ 10 mil a R$ 15 mil</segment>
    <segment id="112">, dependendo da categoria) e com uma imersão de aprendizagem com especialistas em gestão pública.</segment>
  </rst>
</analysis>