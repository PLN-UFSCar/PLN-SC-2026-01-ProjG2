  <rst>
    <segment id="1">Em show na Festa Literária de Penedo</segment>
    <segment id="2">, no Alagoas</segment>
    <segment id="3">, o cantor Zeca Baleiro discursava sobre a importância de artistas falarem sobre política quando foi interrompido por uma pessoa da plateia.</segment>
    <segment id="4">"E a Lei Rouanet?</segment>
    <segment id="5">", perguntou o espectador.  Zeca Baleiro em live no Festival #CulturaEmCasa - DivulgaçãoBaleiro</segment>
    <segment id="6">sese irritou.</segment>
    <segment id="7">"</segment>
    <segment id="8">Tu sabe o que é Lei Roaunet?</segment>
    <segment id="9">Se não sabe o que falar</segment>
    <segment id="10">, não fala.</segment>
    <segment id="11">Tem parente seu que foi beneficiado pela lei</segment>
    <segment id="12">, porque</segment>
    <segment id="13">porque ela gera trabalho para uma cadeia imensa de trabalhadores"</segment>
    <segment id="14">, retrucou o cantor.</segment>
    <segment id="15">Em entrevista ao jornal</segment>
    <segment id="16">O Globo</segment>
    <segment id="17">, Baleiro diz que sentiu o sangue subir quando ouviu a pessoa gritar.</segment>
    <segment id="18">"É um recurso dessa gente</segment>
    <segment id="19">, simpatizante do neofascismo brasileiro</segment>
    <segment id="20">, difundindo ódio e inverdades sem nenhum fundamento para descredibilizar fatos e pessoas.</segment>
    <segment id="21">Poucas coisas me incomodam tanto</segment>
    <segment id="22">comocomo a boçalidade dessa gente"</segment>
    <segment id="23">, afirmou o cantor ao jornal.</segment>
    <segment id="24">Veja imagens do cantor Zeca BaleiroMais    novamente         de   de  de  representando um</segment>
    <segment id="25">A Lei Rouanet foi sancionada em 1991 durante o governo de Fernando Collor (1990-1992).</segment>
    <segment id="26">A lei autoriza o uso de financiamento privado para projetos culturais</segment>
    <segment id="27">, como</segment>
    <segment id="28">como shows e peças de teatro</segment>
    <segment id="29">, sob isenção de parte do imposto de renda.</segment>
  </rst>
