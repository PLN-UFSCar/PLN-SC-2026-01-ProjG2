    <segment id="175">, às 18h30</segment>
    <segment id="176">, com o autor e Juliana Borges no YouTube da TodaviaO Projeto DecamerãoPreço R$ 79</segment>
    <segment id="177">,90 (336 págs.)</segment>
    <segment id="178">; R$ 39</segment>
    <segment id="179">,90 (ebook)Autor VáriosEditora Rocco</segment>
  </rst>
</analysis>