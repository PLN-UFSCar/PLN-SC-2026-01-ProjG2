  </header>
  <rst>
    <segment id="1">O Brasil "vai voltar a todo mundo"</segment>
    <segment id="2">, garantiu Mauro Vieira</segment>
    <segment id="3">, novo ministro das Relações Exteriores.</segment>
    <segment id="4">Não é a ideologia</segment>
    <segment id="5">, masmas o interesse nacional</segment>
    <segment id="6">, que guiará nossa política externa.</segment>
    <segment id="7">As declarações marcam uma nítida ruptura com a orientação bolsonarista</segment>
    <segment id="8">, que fechou-nos num casulo de relações preferenciais com governos da direita nacionalista e correntes do fundamentalismo cristão.</segment>
    <segment id="9">O que se</segment>
    <segment id="10">se fala é positivo.</segment>
    <segment id="11">O problema reside no que</segment>
    <segment id="12">sese cala.</segment>
    <segment id="13">Guerra Fria 2.0 entre EUA e China?</segment>
    <segment id="14">O Brasil rejeita a escolha</segment>
    <segment id="15">, anunciando uma "nova era" na parceria com Washington e o aprofundamento do intercâmbio com Pequim.</segment>
    <segment id="16">Mais: diante da polaridade entre as duas grandes potências</segment>
    <segment id="17">, o Brasil empenha-</segment>
    <segment id="18">sese em consolidar as relações com a Europa</segment>
    <segment id="19">, por meio da implementação do acordo Mercosul/União Europeia.</segment>
    <segment id="20">"</segment>
    <segment id="21">Não nos preocupamos com a ideologia</segment>
    <segment id="22">;</segment>
    <segment id="23">a ideologia é a integração"</segment>
    <segment id="24">, enfatizou Vieira</segment>
    <segment id="25">, abordando a América do Sul.</segment>
    <segment id="26">O indicado ao cargo de ministro das Relações Exteriores</segment>
    <segment id="27">, Mauro Vieira - Pedro Ladeira - 12.dez.22/Folhapress  Quem</segment>
    <segment id="28">, senão lunáticos</segment>
    <segment id="29">, pode</segment>
    <segment id="30">sese opor ao restabelecimento de relações com o governo Maduro</segment>
    <segment id="31">, que corresponde simplesmente ao reconhecimento de uma realidade?</segment>
    <segment id="32">Nações conversam com nações</segment>
    <segment id="33">, independentemente de seus regimes políticos.</segment>
    <segment id="34">Aqui, porém</segment>
    <segment id="35">porém, emerge uma lacuna: o primeiro silêncio.</segment>
    <segment id="36">O interesse nacional não</segment>
    <segment id="37">sese mede apenas por comércio e investimentos.</segment>
    <segment id="38">Nossa Constituição</segment>
    <segment id="39">, expressão do interesse nacional</segment>
    <segment id="40">, manda organizar a política exterior também em torno de valores: a defesa dos direitos humanos.</segment>
    <segment id="41">O novo governo violará o contrato constitucional</segment>
    <segment id="42">sese evitar a crítica às ditaduras</segment>
    <segment id="43">, especialmente no nosso entorno.</segment>
    <segment id="44">O chileno Boric as critica</segment>
    <segment id="45">, sem abandonar o diálogo.</segment>
    <segment id="46">Nos mandatos petistas anteriores</segment>
    <segment id="47">, o Brasil fez o oposto</segment>
    <segment id="48">, celebrando os regimes cubano</segment>
    <segment id="49">, venezuelano e nicaraguense.</segment>
    <segment id="50">Era "ideologia"</segment>
    <segment id="51">, não "integração".</segment>
    <segment id="52">O segundo silêncio é pior.</segment>
    <segment id="53">Dias atrás</segment>
    <segment id="54">, Lula conversou com Putin —</segment>
    <segment id="55">masmas não com Zelenski.</segment>
    <segment id="56">Na esfera diplomática</segment>
    <segment id="57">, o gesto indica uma preferência.</segment>
    <segment id="58">A palavra "paz" surgiu na conversa.</segment>
    <segment id="59">Outra palavra</segment>
    <segment id="60">, "negociações"</segment>
    <segment id="61">, pontua as declarações do presidente eleito e de Vieira</segment>
    <segment id="62">, quando</segment>
    <segment id="63">sese trata da guerra de conquista russa na Ucrânia.</segment>
    <segment id="64">Nunca,</segment>
    <segment id="65">porémporém</segment>
    <segment id="66">, proferem-</segment>
    <segment id="67">sese as expressões "soberania nacional"</segment>
    <segment id="68">, "integridade territorial" e "retirada das forças invasoras".</segment>
    <segment id="69">A Ucrânia resiste à invasão —e opera na contraofensiva</segment>
    <segment id="70">, retomando áreas ocupadas pela Rússia.</segment>
    <segment id="71">Nesse cenário</segment>
    <segment id="72">, Putin fala em "paz" e "negociações"</segment>
    <segment id="73">, senhas para o congelamento temporário do conflito até a reorganização das forças russas e a retomada do impulso ofensivo.  Turquia e Índia</segment>
    <segment id="74">, que optaram pela neutralidade</segment>
    <segment id="75">, também usam as duas palavras —</segment>
    <segment id="76">masmas as complementam com a defesa da integridade territorial ucraniana.</segment>
    <segment id="77">O Brasil não: sua condenação retórica da agressão inicial</segment>
    <segment id="78">, expressa na ONU</segment>
    <segment id="79">, desembocou na fórmula que interessa ao Kremlin.</segment>
    <segment id="80">"</segment>
    <segment id="81">Numa eventual negociação</segment>
    <segment id="82">, o Brasil defenderia que a Rússia devolva à Ucrânia os territórios anexados recentemente?</segment>
    <segment id="83">", perguntou-</segment>
    <segment id="84">sese a Vieira.</segment>
    <segment id="85">Sua resposta:</segment>
    <segment id="86">"Não se</segment>
    <segment id="87">se pode partir de nenhum princípio preestabelecido.</segment>
    <segment id="88">Ou dizer</segment>
    <segment id="89">, só sento para negociar</segment>
    <segment id="90">sese for assim".</segment>
    <segment id="91">Registre-</segment>
    <segment id="92">sese que a pergunta não abrange os territórios anexados pela Rússia em 2014</segment>
    <segment id="93">, masmas exclusivamente as novas anexações proclamadas em setembro.</segment>
    <segment id="94">O novo ministro trata a integridade territorial</segment>
    <segment id="95">comocomo um estorvo que atrapalha a "paz" putinista.</segment>
    <segment id="96">Quem disse que nossa política externa abandonou a ideologia?</segment>
    <segment id="97">Sob Bolsonaro</segment>
    <segment id="98">, o Brasil posicionou-</segment>
    <segment id="99">sese contra as sanções à Rússia.</segment>
    <segment id="100">Vieira foi mais longe</segment>
    <segment id="101">, tachando-as</segment>
    <segment id="102">comocomo "ilegais</segment>
    <segment id="103">".</segment>
    <segment id="104">A afirmação é falsa</segment>
    <segment id="105">, pois</segment>
    <segment id="106">pois elas —</segment>
    <segment id="107">comocomo a ajuda militar à Ucrânia— derivam do conceito jurídico de autodefesa coletiva</segment>
    <segment id="108">, inscrito na Carta da ONU.</segment>
    <segment id="109">O Brasil não precisa</segment>
    <segment id="110">sese somar às sanções ou à ajuda militar</segment>
    <segment id="111">, masmas condená-las equivale a legitimar a guerra imperial.</segment>
    <segment id="112">O chocante</segment>
    <segment id="113">, porém</segment>
    <segment id="114">porém, mais uma vez</segment>
    <segment id="115">, está naquilo que</segment>
    <segment id="116">sese silencia: o novo ministro esqueceu de qualificar</segment>
    <segment id="117">comocomo ilegais as anexações russas.</segment>
    <segment id="118">O silêncio grita.</segment>
  </rst>
</analysis>