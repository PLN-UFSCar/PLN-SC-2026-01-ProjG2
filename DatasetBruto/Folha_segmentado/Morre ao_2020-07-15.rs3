  <rst>
    <segment id="1">O ex-presidente da C&amp;acirc</segment>
    <segment id="2">;mara dos Deputados Severino Cavalcanti (PP)</segment>
    <segment id="3">, 89, morreu na madrugada desta quarta-feira (15) em sua casa no Recife.</segment>
    <segment id="4">De acordo com familiares</segment>
    <segment id="5">, Severino tinha problemas card&amp;iacute</segment>
    <segment id="6">;acos.</segment>
    <segment id="7">O pol&amp;iacute</segment>
    <segment id="8">;tico morreu enquanto dormia.</segment>
    <segment id="9">&amp;ldquo</segment>
    <segment id="10">;Ele usava marcapasso e sentia dores nos ossos&amp;rdquo</segment>
    <segment id="11">;, afirmou Jos&amp;eacute</segment>
    <segment id="12">; Maur&amp;iacute</segment>
    <segment id="13">;cio Cavalcanti</segment>
    <segment id="14">, um dos tr&amp;ecirc</segment>
    <segment id="15">;s filhos do pol&amp;iacute</segment>
    <segment id="16">;tico, que exerce o cargo de secret&amp;aacute</segment>
    <segment id="17">;rio-executivo da Casa Civil no governo Paulo C&amp;acirc</segment>
    <segment id="18">;mara (PSB)</segment>
    <segment id="19">, em Pernambuco.</segment>
    <segment id="20">No &amp;uacute</segment>
    <segment id="21">;ltimo dia 10</segment>
    <segment id="22">, o pol&amp;iacute</segment>
    <segment id="23">;tico recebeu familiares em casa para comemorar 64 anos de casamento.</segment>
    <segment id="24">&amp;quot;Fomos para l&amp;aacute</segment>
    <segment id="25">;, todos de m&amp;aacute</segment>
    <segment id="26">;scara e sem chegar muito perto.</segment>
    <segment id="27">Ele estava bem&amp;quot</segment>
    <segment id="28">;, diz o filho.</segment>
    <segment id="29">Morre aos 89 anos</segment>
    <segment id="30">Severino Cavalcanti</segment>
    <segment id="31">, ex-presidente da Câmara dos Deputados   novamente         de   de  de  representando um  Severino tem uma longa trajet&amp;oacute</segment>
    <segment id="32">;ria pol&amp;iacute</segment>
    <segment id="33">;tica por Pernambuco.</segment>
    <segment id="34">Pelos extintos PFL e PPB</segment>
    <segment id="35">, exerceu o mandato de deputado federal por tr&amp;ecirc</segment>
    <segment id="36">;s mandatos.</segment>
    <segment id="37">O &amp;ldquo</segment>
    <segment id="38">;rei do baixo clero&amp;rdquo</segment>
    <segment id="39">;, como</segment>
    <segment id="40">como ficou conhecido em 2005</segment>
    <segment id="41">,</segment>
    <segment id="42">aproveitou-</segment>
    <segment id="43">sese de um racha na base do PT e venceu a disputa naquele ano &amp;agrave</segment>
    <segment id="44">;</segment>
    <segment id="45">presid&amp;ecirc</segment>
    <segment id="46">;ncia da C&amp;acirc</segment>
    <segment id="47">;mara contra o candidato oficial do governo Lula</segment>
    <segment id="48">, Luiz Eduardo Greenhalgh.  At&amp;eacute</segment>
    <segment id="49">; aquele momento</segment>
    <segment id="50">, Severino</segment>
    <segment id="51">, com a ajuda da oposi&amp;ccedil</segment>
    <segment id="52">;&amp;atilde</segment>
    <segment id="53">;o, imp&amp;ocirc</segment>
    <segment id="54">;s a maior derrota pol&amp;iacute</segment>
    <segment id="55">;tica do petista no governo.</segment>
    <segment id="56">Ele havia constru&amp;iacute</segment>
    <segment id="57">;do sua candidatura com a promessa de elevar sal&amp;aacute</segment>
    <segment id="58">;rios e de melhorar as condi&amp;ccedil</segment>
    <segment id="59">;&amp;otilde</segment>
    <segment id="60">;es financeiras de atua&amp;ccedil</segment>
    <segment id="61">;&amp;atilde</segment>
    <segment id="62">;o dos colegas deputados.</segment>
    <segment id="63">Antes de</segment>
    <segment id="64">sese tornar presidente</segment>
    <segment id="65">, fez parte da mesa diretora da Casa por oito anos.</segment>
    <segment id="66">Tamb&amp;eacute</segment>
    <segment id="67">;m ocupou a corregedoria da C&amp;acirc</segment>
    <segment id="68">;mara.</segment>
    <segment id="69">Passou apenas sete meses no comando da C&amp;acirc</segment>
    <segment id="70">;mara.</segment>
    <segment id="71">Neste per&amp;iacute</segment>
    <segment id="72">;odo, barrou pedidos de abertura de impeachment contra o ent&amp;atilde</segment>
    <segment id="73">;o presidente Lula</segment>
    <segment id="74">, que vivia um bombardeio de acusa&amp;ccedil</segment>
    <segment id="75">;&amp;otilde</segment>
    <segment id="76">;es em raz&amp;atilde</segment>
    <segment id="77">;o do chamado &amp;ldquo</segment>
    <segment id="78">;mensal&amp;atilde</segment>
    <segment id="79">;o&amp;rdquo</segment>
    <segment id="80">;.</segment>
    <segment id="81">Tr&amp;ecirc</segment>
    <segment id="82">;s meses ap&amp;oacute</segment>
    <segment id="83">;s chegar ao posto m&amp;aacute</segment>
    <segment id="84">;ximo da Casa</segment>
    <segment id="85">, uma frase ficou famosa ao tentar emplacar no governo petista o nome de um conterr&amp;acirc</segment>
    <segment id="86">;neo, o engenheiro pernambucano Djalma Rodrigues</segment>
    <segment id="87">, na diretoria de Explora&amp;ccedil</segment>
    <segment id="88">;&amp;atilde</segment>
    <segment id="89">;o e Produ&amp;ccedil</segment>
    <segment id="90">;&amp;atilde</segment>
    <segment id="91">;o da Petrobras.</segment>
    <segment id="92">&amp;ldquo</segment>
    <segment id="93">;O que o presidente [Lula] me ofereceu foi aquela diretoria que fura po&amp;ccedil</segment>
    <segment id="94">;o e acha petr&amp;oacute</segment>
    <segment id="95">;leo.</segment>
    <segment id="96">&amp;Eacute</segment>
    <segment id="97">; essa que eu quero&amp;rdquo</segment>
    <segment id="98">;.</segment>
    <segment id="99">A frase teria sido dita por ele a ent&amp;atilde</segment>
    <segment id="100">;o ministra de Minas e Energia</segment>
    <segment id="101">, Dilma Rousseff.</segment>
    <segment id="102">O cargo</segment>
    <segment id="103">, segundo relatos de Severino</segment>
    <segment id="104">, tinha sido ventilado por Lula durante ida a Roma para entrerro do papa Jo&amp;atilde</segment>
    <segment id="105">;o Paulo 2&amp;ordm</segment>
    <segment id="106">;.</segment>
    <segment id="107">Em setembro de 2005</segment>
    <segment id="108">, Severino acabou sendo acusado por Sebasti&amp;atilde</segment>
    <segment id="109">;o Buani</segment>
    <segment id="110">, dono de um restaurante na C&amp;acirc</segment>
    <segment id="111">;mara, de receber R$ 10 mil reais por m&amp;ecirc</segment>
    <segment id="112">;s para que</segment>
    <segment id="113">para que o estabelecimento pudesse funcionar.</segment>
    <segment id="114">O epis&amp;oacute</segment>
    <segment id="115">;dio ficou conhecido</segment>
    <segment id="116">comocomo &amp;ldquo</segment>
    <segment id="117">;mensalinho&amp;rdquo</segment>
    <segment id="118">;.</segment>
    <segment id="119">Em 21 de setembro</segment>
    <segment id="120">, diante das den&amp;uacute</segment>
    <segment id="121">;ncias</segment>
    <segment id="122">, acabou renunciando ao mandato de deputado federal e deixou a presid&amp;ecirc</segment>
    <segment id="123">;ncia.</segment>
    <segment id="124">Em sua breve passagem</segment>
    <segment id="125">comocomo presidente</segment>
    <segment id="126">, foi alvo de protestos por</segment>
    <segment id="127">sese posicionar contra projetos de lei em favor do reconhecimento dos direitos civis dos homossexuais.</segment>
    <segment id="128">Em seu discurso de despedida</segment>
    <segment id="129">, no mesmo dia em que anunciou a ren&amp;uacute</segment>
    <segment id="130">;ncia, disse que iria voltar e seria absolvido pelo povo.</segment>
    <segment id="131">&amp;ldquo</segment>
    <segment id="132">;A queda do presidente do baixo clero</segment>
    <segment id="133">, l&amp;oacute</segment>
    <segment id="134">;gico, &amp;eacute</segment>
    <segment id="135">;</segment>
    <segment id="136">a vit&amp;oacute</segment>
    <segment id="137">;ria dessa elitezinha que fez tudo para derrub&amp;aacute</segment>
    <segment id="138">;-lo e ridiculariz&amp;aacute</segment>
    <segment id="139">;-lo&amp;quot</segment>
    <segment id="140">;, afirmou</segment>
    <segment id="141">, referindo-</segment>
    <segment id="142">sese a si mesmo.  Mas a popula&amp;ccedil</segment>
    <segment id="143">;&amp;atilde</segment>
    <segment id="144">;o n&amp;atilde</segment>
    <segment id="145">;o o absolveu.</segment>
    <segment id="146">Em 2006</segment>
    <segment id="147">, Severino tentou voltar a Bras&amp;iacute</segment>
    <segment id="148">;lia e foi derrotado nas urnas.</segment>
    <segment id="149">Dois anos depois</segment>
    <segment id="150">, foi eleito novamente prefeito de Jo&amp;atilde</segment>
    <segment id="151">;o Alfredo</segment>
    <segment id="152">, no interior de Pernambuco</segment>
    <segment id="153">, sua cidade natal.</segment>
    <segment id="154">Na campanha</segment>
    <segment id="155">, usou o ent&amp;atilde</segment>
    <segment id="156">;o presidente Lula</segment>
    <segment id="157">comocomo principal cabo eleitoral.</segment>
    <segment id="158">Em mar&amp;ccedil</segment>
    <segment id="159">;o de 2008</segment>
    <segment id="160">, em um evento p&amp;uacute</segment>
    <segment id="161">;blico no Recife</segment>
    <segment id="162">, Lula retribuiu as ajudas de Severino e fez um afago ao pol&amp;iacute</segment>
    <segment id="163">;tico.</segment>
    <segment id="164">Dirigindo-</segment>
    <segment id="165">sese ao ex-deputado do PP</segment>
    <segment id="166">, que estava na plateia</segment>
    <segment id="167">, o petista afirmou que as elites paulista e paranaense tinham o derrubado do poder.</segment>
    <segment id="168">&amp;quot;Elegeram o Severino.</segment>
    <segment id="169">N&amp;atilde</segment>
    <segment id="170">;o levou muito tempo e perceberam que ele n&amp;atilde</segment>
    <segment id="171">;o era oposi&amp;ccedil</segment>
    <segment id="172">;&amp;atilde</segment>
    <segment id="173">;o, e trataram de derrubar o Severino com a mesma facilidade com que o elegeram&amp;rdquo</segment>
    <segment id="174">;, discursou Lula.</segment>
    <segment id="175">Poucos meses depois</segment>
    <segment id="176">, usando o slogan &amp;quot</segment>
    <segment id="177">;o candidato de Lula&amp;quot</segment>
    <segment id="178">;, Severino obteve 52</segment>
    <segment id="179">,31% dos votos e derrotou o nome do PSDB na disputa pela prefeitura de Jo&amp;atilde</segment>
    <segment id="180">;o Alfredo.</segment>
    <segment id="181">Durante a campanha</segment>
    <segment id="182">, costumava sacar o celular e mostrar aos eleitores uma foto ao lado da maior estrela petista.</segment>
    <segment id="183">Foi o &amp;</segment>
    <segment id="184">uacute</segment>
    <segment id="185">;ltimo cargo eletivo que ele ocupou.</segment>
    <segment id="186">Exerceu o mandato de janeiro de 2009 a dezembro de 2012.</segment>
    <segment id="187">Ele foi enquadrado na chamada Lei da Ficha Limpa e impedido de concorrer &amp;agrave</segment>
    <segment id="188">;</segment>
    <segment id="189">reelei&amp;ccedil</segment>
    <segment id="190">;&amp;atilde</segment>
    <segment id="191">;o em Jo&amp;atilde</segment>
    <segment id="192">;o Alfredo.</segment>
    <segment id="193">A Justi&amp;ccedil</segment>
    <segment id="194">;a Eleitoral entendeu que</segment>
    <segment id="195">, por ter renunciado ao mandato de deputado para n&amp;atilde</segment>
    <segment id="196">;o ser cassado</segment>
    <segment id="197">, o pol&amp;iacute</segment>
    <segment id="198">;tico tornou-</segment>
    <segment id="199">sese ineleg&amp;iacute</segment>
    <segment id="200">;vel.</segment>
    <segment id="201">Na &amp;eacute</segment>
    <segment id="202">;poca, n&amp;atilde</segment>
    <segment id="203">;o quis recorrer da decis&amp;atilde</segment>
    <segment id="204">;o.</segment>
    <segment id="205">Em 2017</segment>
    <segment id="206">, o ex-deputado foi condenado em 2&amp;ordm</segment>
    <segment id="207">;</segment>
    <segment id="208">inst&amp;acirc</segment>
    <segment id="209">;ncia por improbidade administrativa por ter empregado uma neta em seu gabinete</segment>
    <segment id="210">, de 2003 a 2005</segment>
    <segment id="211">, sem que ela trabalhasse no local.  ​Integrante da UDN (Uni&amp;atilde</segment>
    <segment id="212">;o Democr&amp;aacute</segment>
    <segment id="213">;tica Nacional)</segment>
    <segment id="214">, partido que havia liderado oposi&amp;ccedil</segment>
    <segment id="215">;&amp;atilde</segment>
    <segment id="216">;o a Get&amp;uacute</segment>
    <segment id="217">;lio Vargas</segment>
    <segment id="218">, havia comandado o munic&amp;iacute</segment>
    <segment id="219">;pio pela primeira vez em 1964.</segment>
    <segment id="220">Na biografia de Severino</segment>
    <segment id="221">comocomo deputado estadual consta a den&amp;uacute</segment>
    <segment id="222">;ncia que levou o governo militar a expulsar do Brasil o padre italiano Vito Miracapillo</segment>
    <segment id="223">, em outubro de 1980.</segment>
    <segment id="224">O religioso</segment>
    <segment id="225">, ligado &amp;agrave</segment>
    <segment id="226">; ala progressista da Igreja Cat&amp;oacute</segment>
    <segment id="227">;lica, atuava em Ribeir&amp;atilde</segment>
    <segment id="228">;o, no interior de Pernambuco</segment>
    <segment id="229">, e havia</segment>
    <segment id="230">sese recusado a celebrar uma missa na cidade alusiva &amp;agrave</segment>
    <segment id="231">; Independ&amp;ecirc</segment>
    <segment id="232">;ncia.</segment>
    <segment id="233">Ap&amp;oacute</segment>
    <segment id="234">;s den&amp;uacute</segment>
    <segment id="235">;ncia formalizada por Severino Cavalcanti</segment>
    <segment id="236">, o ent&amp;atilde</segment>
    <segment id="237">;o presidente da Rep&amp;uacute</segment>
    <segment id="238">;blica</segment>
    <segment id="239">, Jo&amp;atilde</segment>
    <segment id="240">;o Baptista Figueiredo</segment>
    <segment id="241">, assinou a expuls&amp;atilde</segment>
    <segment id="242">;o.</segment>
    <segment id="243">Antes de</segment>
    <segment id="244">sese consolidar no PP</segment>
    <segment id="245">, passou por diversos partidos.</segment>
    <segment id="246">Em 1966</segment>
    <segment id="247">, entrou para a Arena (Alian&amp;ccedil</segment>
    <segment id="248">;a Renovadora Nacional)</segment>
    <segment id="249">, sigla de sustenta&amp;ccedil</segment>
    <segment id="250">;&amp;atilde</segment>
    <segment id="251">;o da ditadura militar.</segment>
    <segment id="252">Em 1980</segment>
    <segment id="253">, foi para o PDS e</segment>
    <segment id="254">, em 1987</segment>
    <segment id="255">, para o PDC (Partido Democrata Crist&amp;atilde</segment>
    <segment id="256">;o), onde permaneceu at&amp;eacute</segment>
    <segment id="257">; 1990</segment>
    <segment id="258">, quando entrou no PL (Partido Liberal).  Ficou pouco no PL</segment>
    <segment id="259">, apenas at&amp;eacute</segment>
    <segment id="260">; 1992</segment>
    <segment id="261">, quando foi para o PPR.</segment>
    <segment id="262">Em 1994</segment>
    <segment id="263">, transferiu-</segment>
    <segment id="264">sese para o PFL e logo em seguida para o PPB</segment>
    <segment id="265">, onde permaneceu at&amp;eacute</segment>
    <segment id="266">; 2003</segment>
    <segment id="267">, quando o partido mudou o nome para PP.</segment>
    <segment id="268">Nas redes sociais</segment>
    <segment id="269">, o governador de Pernambuco</segment>
    <segment id="270">, Paulo C&amp;acirc</segment>
    <segment id="271">;mara (PSB)</segment>
    <segment id="272">, disse que a morte dele deixa uma lacuna na pol&amp;iacute</segment>
    <segment id="273">;tica de Pernambuco.</segment>
    <segment id="274">O sepultamento do corpo aconteceu na tarde desta quarta-feira (15)</segment>
    <segment id="275">, em Jo&amp;atilde</segment>
    <segment id="276">;o Alfredo.</segment>
    <segment id="277">N&amp;atilde</segment>
    <segment id="278">;o houve vel&amp;oacute</segment>
    <segment id="279">;rio para evitar aglomera&amp;ccedil</segment>
    <segment id="280">;&amp;otilde</segment>
    <segment id="281">;es na cidade.</segment>
    <segment id="282">O pol&amp;iacute</segment>
    <segment id="283">;tico deixa a esposa</segment>
    <segment id="284">, tr&amp;ecirc</segment>
    <segment id="285">;s filhos</segment>
    <segment id="286">, seis netos e dois bisnetos.</segment>
  </rst>
</analysis>