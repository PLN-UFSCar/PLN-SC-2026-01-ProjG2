  <rst>
    <segment id="1">A indústria do livro está firme na defesa da lei que fixa preços de lançamentos e evita descontos que enxergam</segment>
    <segment id="2">comocomo abusivos e prejudiciais a toda a cadeia de produção.</segment>
    <segment id="3">É o que atestou o amplo Encontro de Editores</segment>
    <segment id="4">, Livreiros</segment>
    <segment id="5">, Distribuidores e Gráficos que aconteceu nesta semana em Campinas</segment>
    <segment id="6">, em São Paulo</segment>
    <segment id="7">, organizado pela Câmara Brasileira do Livro.</segment>
    <segment id="8">PISAVAS</segment>
    <segment id="9">NOS ASTROS DISTRAÍDA - ‘</segment>
    <segment id="10">O Lábaro’</segment>
    <segment id="11">, com trabalhos póstumos de Elifas Andreato</segment>
    <segment id="12">, está para sair pela Palavras</segment>
    <segment id="13">Projetos Editoriais com obras que o ilustrador deixou</segment>
    <segment id="14">comocomo esboços</segment>
    <segment id="15">, finalizados por sua filha Laura - DivulgaçãoPara</segment>
    <segment id="16">sese ter ideia</segment>
    <segment id="17">, a mesa que abriu o primeiro dia cheio do evento trouxe oito representantes de grandes entidades do livro</segment>
    <segment id="18">, de editores a industriais gráficos</segment>
    <segment id="19">, e, com ares de palanque</segment>
    <segment id="20">, mostrou um absoluto consenso em torno da promoção da Lei Cortez.</segment>
    <segment id="21">Este é o apelido do projeto de lei que tramita hoje no Senado</segment>
    <segment id="22">, escolhido em homenagem ao editor José Xavier Cortez.</segment>
    <segment id="23">A avaliação é que o nome é mais simpático do que a alcunha "Lei do Preço Fixo"</segment>
    <segment id="24">, que poderia soar mal ao público.</segment>
    <segment id="25">A proposta da norma é estabelecer que não</segment>
    <segment id="26">sese possa praticar descontos maiores que 10% no primeiro ano de um lançamento</segment>
    <segment id="27">, o que</segment>
    <segment id="28">, segundo os profissionais reunidos</segment>
    <segment id="29">, serviria para reequilibrar preços do mercado</segment>
    <segment id="30">comocomo um todo.</segment>
    <segment id="31">Livros e HQs ficam mais cara devido ao aumento de custos na indústria gráficaMais    novamente         de   de  de  representando um  É uma reclamação constante do setor que livros são usados</segment>
    <segment id="32">comocomo "bois de piranha" por gigantes</segment>
    <segment id="33">comocomo a Amazon</segment>
    <segment id="34">, que oferecem preços impraticáveis por livrarias para atrair clientes e acabam desvalorizando o produto</segment>
    <segment id="35">, forçando valores de capa mais altos.</segment>
    <segment id="36">Os reunidos também condenaram</segment>
    <segment id="37">, em coro</segment>
    <segment id="38">, eventos</segment>
    <segment id="39">comocomo a Feira do Livro da USP</segment>
    <segment id="40">, cuja próxima edição acontece a partir do dia 9 e abate ao menos 50% dos preços de obras expostas a um público maciço.</segment>
    <segment id="41">Vale lembrar que</segment>
    <segment id="42">, do lado dos leitores</segment>
    <segment id="43">, descontos estão longe de ser demonizados —pelo contrário</segment>
    <segment id="44">, ainda mais em tempos de perda do poder de compra.</segment>
    <segment id="45">Durante a mesa em que os representantes do setor defendiam a Lei Cortez</segment>
    <segment id="46">, havia mais votos contra ela do que a favor na enquete popular hospedada no site do Senado.</segment>
    <segment id="47">E o evento exibia um QR</segment>
    <segment id="48">Code da votação no telão instando os presentes a virarem o jogo.</segment>
    <segment id="49">Tudo a lerReceba no seu email uma seleção com lançamentos</segment>
    <segment id="50">, clássicos e curiosidades literárias</segment>
    <segment id="51">; aberta para não assinantes.</segment>
    <segment id="52">Carregando...</segment>
    <segment id="53">PITIBIRIBA</segment>
    <segment id="54">A escritora Amara Moira</segment>
    <segment id="55">, convidada da Flip</segment>
    <segment id="56">, expande seu monólogo "Neca"</segment>
    <segment id="57">, marco da literatura em pajubá —espécie de dialeto corrente na comunidade LGBTQIA+—</segment>
    <segment id="58">, em casa nova.</segment>
    <segment id="59">A Companhia das Letras lança a versão ampliada do livro que saiu pela editora</segment>
    <segment id="60">O Sexo da Palavra.  ESTEPE E a Record lança já em novembro um livro inédito de Hermann Hesse</segment>
    <segment id="61">, "</segment>
    <segment id="62">A Magia de Cada Começo"</segment>
    <segment id="63">, reunião de textos autobiográficos escritos pelo alemão ao longo da vida.</segment>
    <segment id="64">A tradução é de Lya Luft</segment>
    <segment id="65">, morta no ano passado.</segment>
  </rst>
</analysis>