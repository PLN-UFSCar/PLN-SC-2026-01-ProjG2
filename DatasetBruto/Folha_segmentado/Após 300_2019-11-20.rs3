  <rst>
    <segment id="1">A Polícia Civil de Minas Gerais identificou nesta quarta (20) a 255ª vítima do rompimento da barragem da Vale em Brumadinho (MG)</segment>
    <segment id="2">, em 25 de janeiro.</segment>
    <segment id="3">O nome da vítima encontrada</segment>
    <segment id="4">, porém</segment>
    <segment id="5">porém, só será divulgado depois que a família for contatada.</segment>
    <segment id="6">Com a identificação</segment>
    <segment id="7">, o número oficial de mortos na tragédia sobe para 255</segment>
    <segment id="8">, 15 pessoas ainda são dadas</segment>
    <segment id="9">comocomo desaparecidas.</segment>
    <segment id="10">Duas outras vítimas foram identificadas na semana passada.</segment>
    <segment id="11">Ainda de acordo com informações da polícia</segment>
    <segment id="12">, cerca de 90 fragmentos de corpos encontrados ainda aguardam identificação.</segment>
    <segment id="13">O corpo</segment>
    <segment id="14">, identificado pela arcada dentária pelo IML (Instituto Médico Legal)</segment>
    <segment id="15">, foi localizado na manhã desta quarta pelas equipes de buscas do Corpo de Bombeiros.</segment>
    <segment id="16">Local onde 255ª vítima da Vale foi localizada</segment>
    <segment id="17">, em Brumadinho - CBMMG/Divulgação</segment>
    <segment id="18">Este é o 300º dia de operações na área atingida pela lama no Córrego do Feijão</segment>
    <segment id="19">, onde ficava a barragem B1</segment>
    <segment id="20">, que se</segment>
    <segment id="21">se rompeu.</segment>
    <segment id="22">Segundo a corporação</segment>
    <segment id="23">, o corpo estava praticamente completo</segment>
    <segment id="24">, masmas não foi possível determinar sexo ou idade quando foi encontrado devido ao estado avançado de decomposição.</segment>
    <segment id="25">O corpo foi localizado em uma área chamada de BH1 (Barreira Hidráulica).</segment>
    <segment id="26">Com o início do período de chuvas</segment>
    <segment id="27">, as buscas podem ser dificultadas</segment>
    <segment id="28">, masmas não há previsão para o encerramento antes que todas as vítimas sejam localizadas.</segment>
    <segment id="29">A única possibilidade é</segment>
    <segment id="30">sese a decomposição dos corpos já não permitir identificação.</segment>
    <segment id="31">Desastre da Vale em Brumadinho   novamente         de   de  de  representando</segment>
    <segment id="32">um</segment>
  </rst>
</analysis>