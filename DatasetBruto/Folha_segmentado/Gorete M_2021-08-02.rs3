  <rst>
    <segment id="1">Gorete Milagres gravou um vídeo</segment>
    <segment id="2">comocomo Filó</segment>
    <segment id="3">, a personagem que lhe deu fama</segment>
    <segment id="4">, inicialmente pela “Praça</segment>
    <segment id="5">É Nossa”</segment>
    <segment id="6">, para reagir às acusações de ingratidão que Carlos Alberto de Nóbrega lhe fez durante uma entrevista a Rafinha Bastos no YouTube.</segment>
    <segment id="7">Gorete nega que tenha destratado o apresentador e atribui tudo a ego e inveja.</segment>
    <segment id="8">A personagem aproveitou para dizer que “em respeito a ocê</segment>
    <segment id="9">, Carlos Alberto</segment>
    <segment id="10">, dona Gorete nem falou”</segment>
    <segment id="11">, quando foi procurada por repórteres do UOL</segment>
    <segment id="12">, que "ocê deu aquele chutão na porta” e espantou a todos quando Sandy &amp;amp</segment>
    <segment id="13">; Júnior</segment>
    <segment id="14">, ainda crianças</segment>
    <segment id="15">, foram expulsos por Marcelo de Nóbrega</segment>
    <segment id="16">, seu filho</segment>
    <segment id="17">, antes de gravarem “</segment>
    <segment id="18">A Praça”.</segment>
    <segment id="19">A expulsão de Sandy e Júnior da “Praça” foi revelada por Xororó</segment>
    <segment id="20">, sem citar nomes e programa</segment>
    <segment id="21">, no documentário sobre seus filhos no GloboPlay.</segment>
    <segment id="22">Marcelo de Nóbrega assumiu a responsabilidade sobre o episódio</segment>
    <segment id="23">, tendo</segment>
    <segment id="24">sese desculpado por isso.</segment>
    <segment id="25">Na menção atual de Gorete</segment>
    <segment id="26">, não fica claro</segment>
    <segment id="27">sese Carlos Alberto foi cúmplice do ato do filho ou</segment>
    <segment id="28">sese também participou da ação.</segment>
    <segment id="29">FRIO?</segment>
    <segment id="30">QUE FRIO?</segment>
    <segment id="31">A vida não está fácil para ninguém</segment>
    <segment id="32">, masmas é sempre melhor para uns do que para outros.</segment>
    <segment id="33">Luciana Gimenez</segment>
    <segment id="34">, 51 anos</segment>
    <segment id="35">, que o diga.</segment>
    <segment id="36">Enquanto estamos aqui batendo os dentes de frio</segment>
    <segment id="37">, a bonitona</segment>
    <segment id="38">sese esparrama sob o sol da Croácia e da Espanha</segment>
    <segment id="39">, sempre sob a perspectiva de quem vê terra à vista a partir do mar</segment>
    <segment id="40">, com bons drinks a bordo.</segment>
    <segment id="41">Na volta ao batente pela RedeTV!</segment>
    <segment id="42">, assim</segment>
    <segment id="43">comocomo todos os apresentadores de televisão</segment>
    <segment id="44">, a bonitona</segment>
    <segment id="45">sese prepara para receber novamente o público presencial em seus programas</segment>
    <segment id="46">, ainda exigindo máscaras e dando preferência a quem estiver vacinado contra a Covid</segment>
    <segment id="47">As belas de agosto passam por aquiMais    novamente         de   de  de  representando um  FRASE   "</segment>
    <segment id="48">Rebeca Andrade traz consigo bem mais do que a medalha: uma trajetória de excelência</segment>
    <segment id="49">, orgulho e ousadia.</segment>
    <segment id="50">Rebeca Andrade</segment>
    <segment id="51">, você é inspiração</segment>
    <segment id="52">, é ouro e é Baile de Favela!</segment>
    <segment id="53">"</segment>
    <segment id="54">Taís Araújo no Instagram  Rebeca Andrade conquista medalha de ouro no saltoMais    novamente         de   de  de  representando um  PIQUE</segment>
    <segment id="55">Nos 80 anos de Ney Matogrosso</segment>
    <segment id="56">, celebrados neste domingo (1º)</segment>
    <segment id="57">, o Ecad—Escritório Central de Arrecadação e Distribuição— listou as músicas mais tocadas na sua voz.</segment>
    <segment id="58">“Poema”</segment>
    <segment id="59">, de Frejat e Cazuza</segment>
    <segment id="60">, lidera o ranking</segment>
    <segment id="61">, seguida por “Sangue Latino”</segment>
    <segment id="62">, de João Ricardo e Paulinho Mendonça</segment>
    <segment id="63">, “Tanto Amar”</segment>
    <segment id="64">, de Chico Buarque</segment>
    <segment id="65">, “Balada de Louco”</segment>
    <segment id="66">, de Arnaldo Baptista e Rita Lee</segment>
    <segment id="67">, e “Rosa de Hiroshima</segment>
    <segment id="68">, de Gerson Conrad e Vinicius de Moraes.</segment>
    <segment id="69">Veja fotos de &amp;#039</segment>
    <segment id="70">;Bloco na Rua&amp;#039</segment>
    <segment id="71">;Mais    novamente         de   de  de  representando um  ​VETO</segment>
    <segment id="72">O Lollapalooza de Chicago (EUA)</segment>
    <segment id="73">, cancelou a participação do rapper DaBaby no festival</segment>
    <segment id="74">, após o artista ter sustentado um discurso homofóbico em um show em Miami.</segment>
    <segment id="75">A organização informou que “o Lollapalooza foi fundado na diversidade</segment>
    <segment id="76">, inclusão</segment>
    <segment id="77">, respeito e amor”.  VACINA</segment>
    <segment id="78">, SIM</segment>
    <segment id="79">A banda Guns N’ Roses fez seu primeiro show desde o início da pandemia no sábado (31)</segment>
    <segment id="80">, em Hershey</segment>
    <segment id="81">, no estado da Pensilvânia (EUA).</segment>
    <segment id="82">O evento foi uma espécie de teste para o retorno às atividades culturais na região.</segment>
    <segment id="83">Houve mensagem pró-vacina na abertura e exigência de comprovante de vacinação.</segment>
    <segment id="84">Vídeo gravado por fã mostra telão do show do Guns &amp;#039</segment>
    <segment id="85">;n&amp;#039</segment>
    <segment id="86">;</segment>
    <segment id="87">Roses mostrando uma vacina - Reprodução/Twitter</segment>
