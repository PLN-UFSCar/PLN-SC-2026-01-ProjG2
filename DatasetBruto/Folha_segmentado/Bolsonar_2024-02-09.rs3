  <rst>
    <segment id="1">Buemba!</segment>
    <segment id="2">Buemba!</segment>
    <segment id="3">Macaco Simão Urgente!</segment>
    <segment id="4">O esculhambador-geral da República!</segment>
    <segment id="5">É Carnaval!</segment>
    <segment id="6">É Carnadengue!</segment>
    <segment id="7">De hoje em diante é proibido pensar!</segment>
    <segment id="8">Só pular!</segment>
    <segment id="9">Pular e copular.</segment>
    <segment id="10">Colunas e BlogsReceba no seu email uma seleção de colunas e blogs da FolhaCarregando...</segment>
    <segment id="11">Eu vou sair no bloco do "ose": artrose</segment>
    <segment id="12">, lordose e escoliose.</segment>
    <segment id="13">E a minha amiga vai sair em três: Acadêmicos da Netflix</segment>
    <segment id="14">, Unidos da Minha Cama e Come Tudo que Tiver na Geladeira!</segment>
    <segment id="15">E atenção!</segment>
    <segment id="16">Breaking news!</segment>
    <segment id="17">PF apreende passaporte de Bolsonaro e ele</segment>
    <segment id="18">sese torna INVIAJÁVEL!</segment>
    <segment id="19">Imbrochável e inviajável!</segment>
    <segment id="20">O Moraes botou o Bloco da PF na rua.</segment>
    <segment id="21">Ao som de "É dos Carecas que Elas Gostam Mais".</segment>
    <segment id="22">Piadas prontas!</segment>
    <segment id="23">Felipe Martins é preso em Ponta Grossa.</segment>
    <segment id="24">Bota grossa nisso.</segment>
    <segment id="25">Rarará!</segment>
    <segment id="26">Comandante das operações psicológicas do Exército desmaia ao ser alvo da PF.</segment>
    <segment id="27">Ou seja</segment>
    <segment id="28">, ele precisa de um psicólogo!</segment>
    <segment id="29">Rarará!Ilustração de Fê para coluna de José Simão de 9 de fevereiro de 2024 - Fê/FolhapressE esse golpe que o Bozo e os aliados milicos estavam tramando é o famoso golpe Tabajara!</segment>
    <segment id="30">Prende o Alexandre de Moraes</segment>
    <segment id="31">, prende o Gilmar Mendes</segment>
    <segment id="32">, prende o Pacheco e mela as eleições.</segment>
    <segment id="33">Tipo Guatemala</segment>
    <segment id="34">, Honduras!</segment>
    <segment id="35">Energúmenos!</segment>
    <segment id="36">E essa: "</segment>
    <segment id="37">Musa da Mocidade faz rejuvenescimento íntimo!</segment>
    <segment id="38">Quase virgem</segment>
    <segment id="39">, declara ela".</segment>
    <segment id="40">Adorei o quase!</segment>
    <segment id="41">Ou seja</segment>
    <segment id="42">, é virgem</segment>
    <segment id="43">masmas não é "viiiiiirgem"!</segment>
    <segment id="44">E mais esse bafo: "</segment>
    <segment id="45">PF prende Valdemar Costa Neto por posse irregular de arma".</segment>
    <segment id="46">Devia ser por porte irregular de mandato.</segment>
    <segment id="47">Pelo conjunto da obra!</segment>
    <segment id="48">E acharam uma pepita de ouro que</segment>
    <segment id="49">, diz ele</segment>
    <segment id="50">, era para dar sorte.</segment>
    <segment id="51">Claro que a pepita era de garimpo ilegal.</segment>
    <segment id="52">Rarará!  E a tuiteira Leila Germano revela os bloquinhos da semana: Unidos do Xandão</segment>
    <segment id="53">, A Papuda que Pariu e Me Beija que Eu Sou Federal!</segment>
    <segment id="54">Rarará!</segment>
    <segment id="55">Adoro nomes de blocos!</segment>
    <segment id="56">Direto de Belém:</segment>
    <segment id="57">Filhos de Glande.</segment>
    <segment id="58">O bloco mais democrático que existe.</segment>
    <segment id="59">Todos somos filhos de glande!</segment>
    <segment id="60">Direto do Recife: Cumêro Mãe!</segment>
    <segment id="61">Agora Eu</segment>
    <segment id="62">Tô Aqui.</segment>
    <segment id="63">Direto do Distrito Federal:</segment>
    <segment id="64">Filhos da Ema.</segment>
    <segment id="65">Deve ser aquela ema que bicou o Bolsonaro!</segment>
    <segment id="66">Rarará!</segment>
    <segment id="67">E tem o É Mole</segment>
    <segment id="68">, Mas É Meu!</segment>
    <segment id="69">O cúmulo da autoestima!</segment>
    <segment id="70">Nóis sofre</segment>
    <segment id="71">, masmas nóis goza!</segment>
    <segment id="72">Que eu vou pingar o meu colírio alucinógeno!</segment>
