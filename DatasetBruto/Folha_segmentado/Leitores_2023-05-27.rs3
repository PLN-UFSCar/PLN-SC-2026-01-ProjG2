  <rst>
    <segment id="1">Nesta semana</segment>
    <segment id="2">, a Folha questionou os leitores sobre quais medidas devem ser tomadas para combater o racismo no futebol.</segment>
    <segment id="3">Após a repercussão mundial das denúncias de ataques racistas contra o jogador Vinicius Junior</segment>
    <segment id="4">, do Real Madrid</segment>
    <segment id="5">, no último domingo (21)</segment>
    <segment id="6">, a principal reivindicação nas redes sociais é a de que os crimes não passem em branco.</segment>
    <segment id="7">Confira a seguir algumas respostas enviadas.</segment>
    <segment id="8">Multa alta</segment>
    <segment id="9">, estádio interditado e perda de pontos.</segment>
    <segment id="10">Nenhum torcedor quer seu time mais pobre e embaixo da tabela</segment>
    <segment id="11">, além de não poder assistir aos jogos.</segment>
    <segment id="12">José Carlos Duarte (El Dorado Hills</segment>
    <segment id="13">, Estados Unidos)    Penalizar os torcedores e os clubes com multas significativas</segment>
    <segment id="14">;</segment>
    <segment id="15">proibições vitalícias de frequentar estádios</segment>
    <segment id="16">; perda de pontos e mando de campo do clube</segment>
    <segment id="17">;</segment>
    <segment id="18">e campanhas educativas por parte da Fifa</segment>
    <segment id="19">, das ligas esportivas e dos clubes</segment>
    <segment id="20">, inclusive as equipes de base e amadoras.</segment>
    <segment id="21">Gildázio Garcia Vitor (Ipatinga</segment>
    <segment id="22">, MG)</segment>
    <segment id="23">O atacante Vinicius Jr. durante partida do Real Madrid contra o Valencia- Str/Xinhua  A abordagem do tema deve ser repensada</segment>
    <segment id="24">, com severas coberturas jornalísticas sobre a leniência das autoridades políticas</segment>
    <segment id="25">, jurídicas e esportivas com o racismo.</segment>
    <segment id="26">Na outra ponta</segment>
    <segment id="27">, os jogadores e comissão técnica devem</segment>
    <segment id="28">sese recusar</segment>
    <segment id="29">, por exemplo</segment>
    <segment id="30">, a entrar em campo ou prosseguir o jogo quando ofensas racistas forem proferidas a qualquer pessoa em campo.</segment>
    <segment id="31">Thiago Moreira (Belo Horizonte</segment>
    <segment id="32">, MG)    Leis e punições adequadas são os primeiros passos.</segment>
    <segment id="33">Clubes</segment>
    <segment id="34">, ligas</segment>
    <segment id="35">, patrocinadores</segment>
    <segment id="36">, segurança pública e privada precisam colaborar para a identificação dos criminosos.</segment>
    <segment id="37">Câmeras</segment>
    <segment id="38">, identificação e controle dos torcedores</segment>
    <segment id="39">, cadastro de participantes de torcidas organizadas devem ser medidas adotadas.</segment>
    <segment id="40">A princípio</segment>
    <segment id="41">, não acredito que clubes ou seleções devem pagar por um erro de uma minoria de racistas.</segment>
    <segment id="42">Em caso</segment>
    <segment id="43">caso de reincidência</segment>
    <segment id="44">, ou onde não for possível identificar os criminosos</segment>
    <segment id="45">, deve haver suspensão de torcidas no estádio</segment>
    <segment id="46">, multas ao clube</segment>
    <segment id="47">, W.O. na partida.</segment>
    <segment id="48">Lucas André Rack de Oliveira (São Paulo</segment>
    <segment id="49">, SP)    Terminar o jogo na hora</segment>
    <segment id="50">, punição para os que praticaram o ato racista e a interdição do estádio.</segment>
    <segment id="51">Pedro Valentim (Bauru</segment>
    <segment id="52">, SP)</segment>
    <segment id="53">Em casos de campeonatos</segment>
    <segment id="54">, qualquer ofensa racista vindo de torcedores deve automaticamente fazer o clube perder pontos.</segment>
    <segment id="55">Emily Rakely Franco Vieira (São Paulo</segment>
    <segment id="56">, SP)    Eu acho que os contratos dos jogadores negros em qualquer país do mundo deveria ter uma cláusula antirracismo.</segment>
    <segment id="57">A cada ataque de torcedores</segment>
    <segment id="58">, o clube teria que pagar uma multa.</segment>
    <segment id="59">A Fifa tem obrigação de regular isso.</segment>
    <segment id="60">No caso</segment>
    <segment id="61">caso de reincidência</segment>
    <segment id="62">, além da multa</segment>
    <segment id="63">, a federação deveria ficar suspensa de jogos oficiais tipo eliminatórias</segment>
    <segment id="64">, amistosos e</segment>
    <segment id="65">, sese não resolver</segment>
    <segment id="66">, desclassificar as seleções/clubes de torneios internacionais.</segment>
    <segment id="67">Janaina Bezerra (São Paulo</segment>
    <segment id="68">, SP)    Eu</segment>
    <segment id="69">, enquanto amante do futebol</segment>
    <segment id="70">, como</segment>
    <segment id="71">como alguém que o acompanha quase que diariamente</segment>
    <segment id="72">, penso que as federações</segment>
    <segment id="73">, árbitros</segment>
    <segment id="74">, jogadores e todos aqueles que trabalham numa partida de futebol</segment>
    <segment id="75">, diante de qualquer gesto racista</segment>
    <segment id="76">, devem</segment>
    <segment id="77">sese retirar imediatamente do campo.</segment>
    <segment id="78">A partida será dada</segment>
    <segment id="79">comocomo encerrada e não haverá</segment>
    <segment id="80">, portanto</segment>
    <segment id="81">, qualquer restituição de valor —a não ser</segment>
    <segment id="82">, talvez</segment>
    <segment id="83">, o moral!</segment>
    <segment id="84">Antes disso</segment>
    <segment id="85">, contudo</segment>
    <segment id="86">contudo</segment>
    <segment id="87">, dada a reincidência semanal de casos</segment>
    <segment id="88">, faz-</segment>
    <segment id="89">sese necessário que os profissionais da bola tenham algum tipo de letramento racial</segment>
    <segment id="90">, o que pode ser garantido por meio de palestras</segment>
    <segment id="91">, livros e filmes comentados por especialistas no assunto.</segment>
    <segment id="92">André Silva (São Paulo</segment>
    <segment id="93">, SP)    Quem pratica tais atos poderia sofrer um banimento dos jogos</segment>
    <segment id="94">, já que são registrados os nomes dos compradores dos ingressos.</segment>
    <segment id="95">Ou fazer um serviço comunitário para poder ajudar a quem precisa e assim ele irá aprender de alguma forma.</segment>
    <segment id="96">Jéssika Rocha da Costa (Foz do Iguaçu</segment>
    <segment id="97">, PR)</segment>
  </rst>
</analysis>