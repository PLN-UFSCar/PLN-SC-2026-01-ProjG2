  <rst>
    <segment id="1">Envolvido pelo tenente-coronel Mauro Cid em um suposto plano golpista</segment>
    <segment id="2">, o ex-assessor internacional da Presidência Filipe Martins foi convidado pelo PL para trabalhar no partido no começo do ano.</segment>
    <segment id="3">Filipe Martins</segment>
    <segment id="4">, ex-assessor para Assuntos Internacionais da Presidência no governo Bolsonaro - DivulgaçãoEle desempenharia na legenda função similar à que tinha no Palácio do Planalto</segment>
    <segment id="5">, sendo o responsável pela área de contatos externos da sigla.</segment>
    <segment id="6">O salário seria de cerca de R$ 15 mil.</segment>
    <segment id="7">Martins ensaiou aceitar</segment>
    <segment id="8">, masmas acabou recuando.</segment>
    <segment id="9">Disse que tinha outros projetos.</segment>
    <segment id="10">Segundo o Painel apurou</segment>
    <segment id="11">, pesou avaliação de que não seria prudente seguir nos holofotes em um momento em que já</segment>
    <segment id="12">sese desenhava um cerco judicial ao bolsonarismo.</segment>
    <segment id="13">Desde então</segment>
    <segment id="14">, ele submergiu.</segment>
    <segment id="15">Segundo Cid</segment>
    <segment id="16">, foi Martins quem levou ao então presidente Jair Bolsonaro uma minuta com proposta de golpe para ele analisar.</segment>
    <segment id="17">Durante o governo Bolsonaro</segment>
    <segment id="18">, o ex-assessor fazia parte do núcleo mais ideológico</segment>
    <segment id="19">, que tinha o filósofo Olavo de Carvalho</segment>
    <segment id="20">comocomo guru.</segment>
  </rst>
