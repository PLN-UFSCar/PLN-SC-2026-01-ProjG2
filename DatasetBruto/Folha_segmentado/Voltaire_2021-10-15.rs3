  <rst>
    <segment id="1">Sensualidade.</segment>
    <segment id="2">Pesquisa.</segment>
    <segment id="3">Prazer.</segment>
    <segment id="4">Um novo produto explora os desejos da mulher.</segment>
    <segment id="5">O yoni egg.</segment>
    <segment id="6">Yoni, na língua sagrada da Índia</segment>
    <segment id="7">, significa vagina.</segment>
    <segment id="8">Egg é ovo mesmo.</segment>
    <segment id="9">Na prática</segment>
    <segment id="10">, trata-</segment>
    <segment id="11">sese de um delicado globo de quartzo polido.</segment>
    <segment id="12">Introduzido na intimidade feminina</segment>
    <segment id="13">, ele promete mais satisfação na hora do amor.</segment>
    <segment id="14">Liana estudava o assunto em profundidade.</segment>
    <segment id="15">—Por que não?</segment>
    <segment id="16">Faz todo o sentido.</segment>
    <segment id="17">Em poucos dias</segment>
    <segment id="18">, Liana recebeu o pacote promissor.</segment>
    <segment id="19">—Quartzo rosa.</segment>
    <segment id="20">Mais romântico.</segment>
    <segment id="21">O marido</segment>
    <segment id="22">sese chamava Augusto.</segment>
    <segment id="23">—</segment>
    <segment id="24">O que é isso agora?</segment>
    <segment id="25">—Não é da sua conta… hihi.</segment>
    <segment id="26">No sorriso malicioso de Liana</segment>
    <segment id="27">, percebia-</segment>
    <segment id="28">sese uma ponta de angústia.</segment>
    <segment id="29">Anos de casamento.</segment>
    <segment id="30">Poucos minutos de prazer.</segment>
    <segment id="31">O glóbulo de cristal foi introduzido com delicadeza e esperança.</segment>
    <segment id="32">Liana começou logo a perceber transformações.</segment>
    <segment id="33">—Está se</segment>
    <segment id="34">se mexendo…</segment>
    <segment id="35">Ela apurou o ouvido.</segment>
    <segment id="36">—</segment>
    <segment id="37">Nhnh… nhnhiii.</segment>
    <segment id="38">Era melhor tirar.</segment>
    <segment id="39">No interior do cristal</segment>
    <segment id="40">, algo</segment>
    <segment id="41">sese agitava.</segment>
    <segment id="42">—</segment>
    <segment id="43">Um neném?</segment>
    <segment id="44">Como é possível? —</segment>
    <segment id="45">Ma...</segment>
    <segment id="46">ma…</segment>
    <segment id="47">Lindo.</segment>
    <segment id="48">Moreninho.</segment>
    <segment id="49">Sorridente.</segment>
    <segment id="50">—Acho que é indiano…</segment>
    <segment id="51">Liana está convencida.</segment>
    <segment id="52">—O Sidarta Gautama.</segment>
    <segment id="53">O novo Buda.</segment>
    <segment id="54">Aqui em Parelheiros.</segment>
    <segment id="55">Produtos</segment>
    <segment id="56">sese compram no mercado.</segment>
    <segment id="57">Mas os sonhos vêm sempre de dentro.</segment>
    <segment id="58">Ovo e mistério - Divulgação</segment>
  </rst>
