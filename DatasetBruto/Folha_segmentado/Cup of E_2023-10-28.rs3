  <rst>
    <segment id="1">Cafés de Minas Gerais e São Paulo foram eleitos neste sábado (28) os melhores do Brasil no Cup of Excellence</segment>
    <segment id="2">, o mais importante concurso do setor no mundo.</segment>
    <segment id="3">A premiação elege anualmente os cafés com maior qualidade sensorial do Brasil –ou seja</segment>
    <segment id="4">, os mais saborosos e pontuados</segment>
    <segment id="5">, conforme degustações às cegas feitas por juízes especializados (veja abaixo detalhes de</segment>
    <segment id="6">comocomo é feita essa escolha).</segment>
    <segment id="7">Um lote de café da fazenda Rio Verde</segment>
    <segment id="8">, da Ipanema Agrícola</segment>
    <segment id="9">, situado em Conceição do Rio Verde</segment>
    <segment id="10">, na Mantiqueira de Minas</segment>
    <segment id="11">, venceu na categoria via úmida</segment>
    <segment id="12">, que envolve os cafés cereja descascado</segment>
    <segment id="13">, despolpado ou desmucilado.</segment>
    <segment id="14">Ela conquistou uma pontuação de 92</segment>
    <segment id="15">,15 –a nota mais alta do concurso</segment>
    <segment id="16">, entre todas as categorias.</segment>
    <segment id="17">Cup of Excellence</segment>
    <segment id="18">, mais importante concurso do setor</segment>
    <segment id="19">, premiou cafés de MG</segment>
    <segment id="20">, SP, ES e BA - FolhapressJá um café da fazenda Fazenda Rainha</segment>
    <segment id="21">, em São Sebastião da Grama (SP)</segment>
    <segment id="22">, na Região Vulcânica</segment>
    <segment id="23">, foi o campeão na categoria via seca</segment>
    <segment id="24">, voltada aos cafés colhidos e secos com casca.</segment>
    <segment id="25">A propriedade pertence à Orfeu Cafés Especiais.</segment>
    <segment id="26">Por fim</segment>
    <segment id="27">, a fazenda Rio Verde também foi a campeã da categoria experimental</segment>
    <segment id="28">, que é uma novidade deste ano.</segment>
    <segment id="29">Esta premiação</segment>
    <segment id="30">sese destina aos grãos que passaram por um processo de fermentação induzida</segment>
    <segment id="31">, e surgiu</segment>
    <segment id="32">comocomo uma resposta à crescente demanda por esses cafés</segment>
    <segment id="33">, que têm sabores mais exóticos e ganharam bastante espaço no mercado.</segment>
    <segment id="34">Confira a lista completa de vencedores ao final deste texto.</segment>
    <segment id="35">O caminho do café do pé à xícaraMais    novamente         de   de  de  representando um</segment>
    <segment id="36">Os cafés vencedores são comercializados em um disputado leilão</segment>
    <segment id="37">, nos quais os produtores conseguem vender os grãos por preços muito além dos praticados no mercado convencional.</segment>
    <segment id="38">Em 2018</segment>
    <segment id="39">, por exemplo</segment>
    <segment id="40">, o campeão alcançou o maior valor pago por uma saca de café no país: R$ 73 mil.</segment>
    <segment id="41">O leilão deste ano ocorrerá em dezembro.</segment>
    <segment id="42">Muitas das empresas que compram esses cafés premiados são estrangeiras</segment>
    <segment id="43">, motivo pelo qual vários dos cafés podem não ser acessíveis ao consumidor brasileiro.</segment>
    <segment id="44">Alguns cafés</segment>
    <segment id="45">, contudo</segment>
    <segment id="46">contudo</segment>
    <segment id="47">, podem ser comercializados por torrefações e cafeterias no Brasil.</segment>
    <segment id="48">A Orfeu</segment>
    <segment id="49">, por exemplo</segment>
    <segment id="50">, que é a proprietária da fazenda Rainha</segment>
    <segment id="51">, informou ao Café na Prensa que pretende disponibilizar este lote vencedor</segment>
    <segment id="52">, da variedade geisha</segment>
    <segment id="53">, no próximo ano.</segment>
    <segment id="54">COMO É FEITA</segment>
    <segment id="55">A ESCOLHA</segment>
    <segment id="56">A escolha dos melhores cafés é feita por meio de avaliação às cegas.</segment>
    <segment id="57">Na última etapa do concurso</segment>
    <segment id="58">, 20 juízes certificados de todo o mundo degustam os cafés finalistas seguindo protocolos internacionais de avaliação de café.</segment>
    <segment id="59">Eles avaliam questões</segment>
    <segment id="60">comocomo doçura</segment>
    <segment id="61">, acidez e a complexidade das notas sensoriais de modo geral</segment>
    <segment id="62">, para atribuir uma nota final em uma escala de 0 a 100.</segment>
    <segment id="63">Colunas e BlogsReceba no seu email uma seleção de colunas e blogs da FolhaCarregando...</segment>
    <segment id="64">O Cup of Excellence é um concurso internacional –o mais respeitado do setor no mundo.</segment>
    <segment id="65">A etapa brasileira é organizada pela BSCA (Associação Brasileira de Cafés Especiais) e pela Apex (Agência Brasileira de Promoção de Exportações e Investimentos).</segment>
    <segment id="66">Confira abaixo a lista dos vencedores:</segment>
