  <rst>
    <segment id="1">Nesta semana</segment>
    <segment id="2">, um novo capítulo surgiu na disputa pela herança de Gugu Liberato</segment>
    <segment id="3">, morto há quatro anos.</segment>
    <segment id="4">O empresário Ricardo Rocha</segment>
    <segment id="5">, de 48 anos</segment>
    <segment id="6">, afirmou ser filho do apresentador</segment>
    <segment id="7">, conforme antecipado em furo de reportagem da coluna de Monica Bergamo na Folha.</segment>
    <segment id="8">Rocha afirmou à coluna que não pode falar sobre o processo de reconhecimento de paternidade "post mortem" que está movendo contra o apresentador</segment>
    <segment id="9">, pois</segment>
    <segment id="10">pois a ação está em segredo de Justiça.</segment>
    <segment id="11">Em entrevista ao Fantástico</segment>
    <segment id="12">, da TV Globo</segment>
    <segment id="13">, neste domingo</segment>
    <segment id="14">, as filhas do apresentador</segment>
    <segment id="15">, Marina e Sofia Liberato</segment>
    <segment id="16">, disseram achar improvável que Rocha seja filho de Gugu.  Marina e Sofia Liberato em entrevista ao Fantástico - Reprodução"Eu acho um pouco absurdo</segment>
    <segment id="17">, porque</segment>
    <segment id="18">porque esse cara é um pouco mais velho e meu pai teria 14 anos</segment>
    <segment id="19">sese isso realmente aconteceu"</segment>
    <segment id="20">, disse Marina.</segment>
    <segment id="21">"</segment>
    <segment id="22">Acho um pouco difícil</segment>
    <segment id="23">, né", completou.</segment>
    <segment id="24">Rocha solicitou que os supostos parentes</segment>
    <segment id="25">sese submetam a exame de DNA e defende que o corpo de Gugu seja exumado</segment>
    <segment id="26">para que</segment>
    <segment id="27">para que o teste seja realizado.</segment>
    <segment id="28">Audiência judicial em que Rose Miriam di Matteo pede reconhecimento da união estável com GuguMais    novamente         de   de  de  representando um</segment>
    <segment id="29">A herança do apresentador é estimada em R$ 1 bilhão.</segment>
    <segment id="30">Segundo seu testamento</segment>
    <segment id="31">, seus três filhos —João Augusto</segment>
    <segment id="32">, Marina e Sofia— têm acesso a 75% dos bens deixados por ele</segment>
    <segment id="33">, divididos de forma igualitária.</segment>
    <segment id="34">Caso o suposto quarto filho tenha o parentesco comprovado</segment>
    <segment id="35">, ele entra nessa divisão.</segment>
    <segment id="36">Mas, caso</segment>
    <segment id="37">caso seja comprovada uma união estável do apresentador com Rose Miriam</segment>
    <segment id="38">, a mãe dos três filhos de Gugu</segment>
    <segment id="39">, ou com Thiago Salvático</segment>
    <segment id="40">, chef que afirma ter tido um relacionamento com Gugu</segment>
    <segment id="41">, estes recebem metade da fortuna.</segment>
    <segment id="42">Ricardo Rocha</segment>
    <segment id="43">, suposto quarto filho de Gugu - ReproduçãoSalvático</segment>
    <segment id="44">, que mora na Europa</segment>
    <segment id="45">, enviou um vídeo ao Fantástico com uma mensagem direcionada a Rose.</segment>
    <segment id="46">"</segment>
    <segment id="47">Eu sinceramente peço encarecidamente que pare dez minutos e repense.</segment>
    <segment id="48">Fui eu que vivi vários altos e baixos</segment>
    <segment id="49">, foi comigo que ele passou o aniversário de 60 anos.</segment>
    <segment id="50">"  Marina e Sofia estão ao lado da mãe nessa briga.</segment>
    <segment id="51">"É bem difícil lidar com tudo isso</segment>
    <segment id="52">, masmas acho que o mais importante é ficarmos unidos"</segment>
    <segment id="53">, disse Sofia.</segment>
  </rst>
