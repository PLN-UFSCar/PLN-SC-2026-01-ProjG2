  <rst>
    <segment id="1">A Prefeitura do Rio de Janeiro confirmou nesta quarta-feira (14) a segunda morte por dengue na cidade em 2024.</segment>
    <segment id="2">Conforme a Secretaria Municipal de Saúde</segment>
    <segment id="3">, a vítima foi um homem de 23 anos que morava em Senador Camará</segment>
    <segment id="4">, bairro da zona oeste da cidade.</segment>
    <segment id="5">A pasta afirmou que o jovem apresentou sintomas</segment>
    <segment id="6">comocomo febre</segment>
    <segment id="7">, dores musculares</segment>
    <segment id="8">, vômito</segment>
    <segment id="9">, náuseas e dores nas articulações e atrás dos olhos.</segment>
    <segment id="10">Ele não tinha doenças pré-existentes</segment>
    <segment id="11">, segundo a secretaria.  "</segment>
    <segment id="12">O quadro evoluiu</segment>
    <segment id="13">, após três dias</segment>
    <segment id="14">, para sinais de alarme e gravidade</segment>
    <segment id="15">comocomo hipotensão postural</segment>
    <segment id="16">, ou seja</segment>
    <segment id="17">, ao mudar de posição</segment>
    <segment id="18">, [havia] sensação de perda de força muscular</segment>
    <segment id="19">, queda abrupta de plaquetas</segment>
    <segment id="20">, dor abdominal intensa</segment>
    <segment id="21">, sangramento espontâneo de mucosa e desidratação"</segment>
    <segment id="22">, afirmou a pasta.</segment>
    <segment id="23">O nome da vítima não foi divulgado.</segment>
    <segment id="24">Agente de saúde faz vistoria contra dengue em casas no bairro de Madureira</segment>
    <segment id="25">, na zona norte do Rio de Janeiro - Eduardo Anizelli - 8.fev.2024/FolhapressA cidade do Rio de Janeiro vive uma epidemia de dengue neste início de ano.</segment>
    <segment id="26">No momento</segment>
    <segment id="27">, há outros dois óbitos que podem estar associados à doença em investigação</segment>
    <segment id="28">, segundo a prefeitura.</segment>
    <segment id="29">O município decretou neste mês estado de emergência de saúde pública em decorrência do aumento de casos.</segment>
    <segment id="30">O número de internações por dengue chegou a 362 em janeiro.</segment>
    <segment id="31">É o maior da série histórica iniciada em 1974.</segment>
    <segment id="32">Cuide-seCiência</segment>
    <segment id="33">, hábitos e prevenção</segment>
    <segment id="34">numa newsletter para a sua saúde e bem-estarCarregando...</segment>
    <segment id="35">Neste ano</segment>
    <segment id="36">, a primeira morte por dengue na capital fluminense foi confirmada há uma semana</segment>
    <segment id="37">, no dia 7 de fevereiro.</segment>
    <segment id="38">Segundo o secretário municipal de Saúde</segment>
    <segment id="39">, Daniel Soranz</segment>
    <segment id="40">, a vítima era um homem de 45 anos</segment>
    <segment id="41">, dependente químico que vivia na Maré</segment>
    <segment id="42">, zona norte da cidade.</segment>
    <segment id="43">No estado do Rio</segment>
    <segment id="44">, quatro mortes pela doença já foram confirmadas neste ano.</segment>
    <segment id="45">Além dos dois óbitos na capital</segment>
    <segment id="46">, um foi verificado no município de Mangaratiba e outro em Itatiaia.</segment>
    <segment id="47">Conforme a Secretaria de Estado de Saúde do Rio de Janeiro</segment>
    <segment id="48">, foram registrados 39</segment>
    <segment id="49">,3 mil casos prováveis de dengue no estado neste ano</segment>
    <segment id="50">, com 1.225 internações</segment>
    <segment id="51">, somente até segunda (12).</segment>
    <segment id="52">Em 2023</segment>
    <segment id="53">, houve 51</segment>
    <segment id="54">,5 mil registros prováveis</segment>
    <segment id="55">, 3.181 internações e 32 mortes confirmadas</segment>
    <segment id="56">, de acordo com a pasta.</segment>
    <segment id="57">Com epidemia</segment>
    <segment id="58">, Rio enfrenta desafios no combate à dengueMais    novamente         de   de  de  representando um</segment>
  </rst>
