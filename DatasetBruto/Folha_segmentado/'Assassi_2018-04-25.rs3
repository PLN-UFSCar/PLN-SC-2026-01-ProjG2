  <rst>
    <segment id="1">O homem que aterrorizou a Califórnia</segment>
    <segment id="2">, acusado de matar 12 pessoas e estuprar 45 mulheres ao longo das décadas de 1970 e 1980</segment>
    <segment id="3">, pode estar</segment>
    <segment id="4">, enfim</segment>
    <segment id="5">, atrás das grades.</segment>
    <segment id="6">Homens do FBI</segment>
    <segment id="7">, a polícia federal americana</segment>
    <segment id="8">, anunciaram em Sacramento</segment>
    <segment id="9">, a capital do estado da costa oeste</segment>
    <segment id="10">, que encontraram e prenderam o suspeito conhecido</segment>
    <segment id="11">comocomo o “assassino do Golden State”.</segment>
    <segment id="12">Joseph James DeAngelo</segment>
    <segment id="13">, um ex-policial de 72 anos com “filhos já adultos”</segment>
    <segment id="14">, nas palavras de um policial</segment>
    <segment id="15">, foi identificado</segment>
    <segment id="16">comocomo o matador em série.</segment>
    <segment id="17">Ele não resistiu à prisão quando agentes bateram na porta de sua casa na cidade onde ele começou a fazer suas vítimas.</segment>
    <segment id="18">Joseph James Deangelo</segment>
    <segment id="19">, 72, preso nesta quarta-feira (24) pela polícia de Sacramento</segment>
    <segment id="20">, nos EUA</segment>
    <segment id="21">; testes de DNA apontam o homem</segment>
    <segment id="22">comocomo o &amp;quot</segment>
    <segment id="23">;assassino de Golden State&amp;quot</segment>
    <segment id="24">;, que matou 12 pessoas e estuprou 45 nos anos 1970 e 1980 - Departamento de Polícia de Sacramento/ReutersEle</segment>
    <segment id="25">, que teria amarrado</segment>
    <segment id="26">, amordaçado e estuprado uma primeira mulher em junho de 1976</segment>
    <segment id="27">, estava sempre de máscara.</segment>
    <segment id="28">Seus crimes eram ataques dessa natureza pelos dois anos seguintes</segment>
    <segment id="29">, quando então teria assassinado um casal não muito distante do lugar onde cometeu o primeiro crime.</segment>
    <segment id="30">Depois de Sacramento</segment>
    <segment id="31">, a polícia acredita que ele tenha fugido para a região de Santa Bárbara</segment>
    <segment id="32">, no sul do estado</segment>
    <segment id="33">, onde fez uma série de novas vítimas entre dezembro de 1979 e maio de 1986.</segment>
    <segment id="34">Semelhanças entre as táticas usadas nos ataques ali com os do norte do estado chamaram a atenção dos detetives do</segment>
    <segment id="35">casocaso</segment>
    <segment id="36">, que então desconfiaram que um mesmo homem poderia estar por trás de toda a onda de terror na Califórnia.</segment>
    <segment id="37">Décadas</segment>
    <segment id="38">sese passaram e seu rosto nunca foi identificado.</segment>
    <segment id="39">Vítimas o descreviam</segment>
    <segment id="40">comocomo um homem forte</segment>
    <segment id="41">, masmas discordavam sobre a cor do cabelo</segment>
    <segment id="42">, loiro para alguns e castanho escuro para outros</segment>
    <segment id="43">, e dos olhos</segment>
    <segment id="44">, que poderiam ser verdes</segment>
    <segment id="45">, castanhos ou até azuis.</segment>
    <segment id="46">No aniversário de 40 anos de seu primeiro crime</segment>
    <segment id="47">, o FBI passou a oferecer uma recompensa</segment>
    <segment id="48">, o equivalente a cerca de R$ 150 mil</segment>
    <segment id="49">, por pistas que pudessem levar à sua captura.</segment>
    <segment id="50">Mas o que virou o jogo na caçada ao assassino do Golden State foram as primeiras evidências de seu DNA.</segment>
    <segment id="51">Em 2001</segment>
    <segment id="52">, detetives chegaram à conclusão que o homem que estuprou e matou uma série de pessoas na região de Sacramento era o mesmo que cometeu os ataques mais ao sul.</segment>
    <segment id="53">Anúncio do FBI divulgado neste mês com retratos falados com suspeito conhecido por &amp;quot</segment>
    <segment id="54">;assassino de Golden State&amp;quot</segment>
    <segment id="55">;, acusado de 12 assassinatos e 45 estupros nos anos 1970 e 1980</segment>
    <segment id="56">, nos EUA - AFP</segment>
  </rst>
</analysis>