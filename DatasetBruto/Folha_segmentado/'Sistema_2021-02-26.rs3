  <rst>
    <segment id="1">Rec&amp;eacute</segment>
    <segment id="2">;m-eleita presidente da Comiss&amp;atilde</segment>
    <segment id="3">;o de Rela&amp;ccedil</segment>
    <segment id="4">;&amp;otilde</segment>
    <segment id="5">;es Exteriores e Defesa Nacional do Senado</segment>
    <segment id="6">, K&amp;aacute</segment>
    <segment id="7">;tia Abreu (PP-TO) critica o componente ideol&amp;oacute</segment>
    <segment id="8">;gico na pol&amp;iacute</segment>
    <segment id="9">;tica externa conduzida pelo chanceler Ernesto Ara&amp;uacute</segment>
    <segment id="10">;jo e afirma que n&amp;atilde</segment>
    <segment id="11">;o cabe ao governo brasileiro opinar sobre o sistema de governo na China.</segment>
    <segment id="12">&amp;quot;O ministro</segment>
    <segment id="13">Ernesto deve ter as suas qualidades</segment>
    <segment id="14">, ou n&amp;atilde</segment>
    <segment id="15">;o teria sido escolhido para o Itamaraty.</segment>
    <segment id="16">Eu s&amp;oacute</segment>
    <segment id="17">; acho que [ele] precisa repensar a respeito desses conceitos ideol&amp;oacute</segment>
    <segment id="18">;gicos&amp;quot</segment>
    <segment id="19">;, disse ela</segment>
    <segment id="20">, em entrevista &amp;agrave</segment>
    <segment id="21">;</segment>
    <segment id="22">Folha, em seu gabinete nesta quinta-feira (25).</segment>
    <segment id="23">A senadora Kátia Abreu dá entrevista no gabinete em Brasília - Raul Spinassé/Folhapress&amp;quot</segment>
    <segment id="24">;Se n&amp;atilde</segment>
    <segment id="25">;o funcionou no governo da esquerda</segment>
    <segment id="26">, n&amp;atilde</segment>
    <segment id="27">;o funcionar&amp;aacute</segment>
    <segment id="28">; no governo da direita&amp;quot</segment>
    <segment id="29">;, afirmou a senadora</segment>
    <segment id="30">, lembrando do per&amp;iacute</segment>
    <segment id="31">;odo em que as administra&amp;ccedil</segment>
    <segment id="32">;&amp;otilde</segment>
    <segment id="33">;es do PT eram criticadas por apostar suas fichas na coopera&amp;ccedil</segment>
    <segment id="34">;&amp;atilde</segment>
    <segment id="35">;o Sul-Sul.</segment>
    <segment id="36">Abreu foi ministra da Agricultura no governo Dilma Rousseff e candidata a vice na chapa de Ciro Gomes (PDT) em 2018.</segment>
    <segment id="37">Ligada ao agroneg&amp;oacute</segment>
    <segment id="38">;cio, foi escolhida para comandar a comiss&amp;atilde</segment>
    <segment id="39">;o no bi&amp;ecirc</segment>
    <segment id="40">;nio 2021-22.</segment>
    <segment id="41">A senadora defende que Ernesto precisa abandonar a ret&amp;oacute</segment>
    <segment id="42">;rica de confronta&amp;ccedil</segment>
    <segment id="43">;&amp;atilde</segment>
    <segment id="44">;o com a ditadura comunista chinesa.</segment>
    <segment id="45">O chanceler tem um hist&amp;oacute</segment>
    <segment id="46">;rico de choques com Pequim.</segment>
    <segment id="47">Ernesto j&amp;aacute</segment>
    <segment id="48">;</segment>
    <segment id="49">declarou que o Brasil &amp;quot</segment>
    <segment id="50">;n&amp;atilde</segment>
    <segment id="51">;o vender&amp;aacute</segment>
    <segment id="52">;</segment>
    <segment id="53">a alma&amp;quot</segment>
    <segment id="54">; para exportar min&amp;eacute</segment>
    <segment id="55">;rio de ferro e soja e</segment>
    <segment id="56">, mais recentemente</segment>
    <segment id="57">, atacou o que chamou de &amp;quot</segment>
    <segment id="58">;tecnototalitarismo&amp;quot</segment>
    <segment id="59">; de pa&amp;iacute</segment>
    <segment id="60">;ses com &amp;quot</segment>
    <segment id="61">;diferentes modelos de sociedade&amp;quot</segment>
    <segment id="62">;</segment>
    <segment id="63">&amp;</segment>
    <segment id="64">mdash;refer&amp;ecirc</segment>
    <segment id="65">;ncias &amp;agrave</segment>
    <segment id="66">; China.</segment>
    <segment id="67">Al&amp;eacute</segment>
    <segment id="68">;m do mais</segment>
    <segment id="69">, o chanceler praticamente rompeu o di&amp;aacute</segment>
    <segment id="70">;logo com a embaixada da China em Bras&amp;iacute</segment>
    <segment id="71">;lia.</segment>
    <segment id="72">Ele chegou a pedir a demiss&amp;atilde</segment>
    <segment id="73">;o do diplomata Yang Wanming.</segment>
    <segment id="74">A solicita&amp;ccedil</segment>
    <segment id="75">;&amp;atilde</segment>
    <segment id="76">;o foi ignorada.</segment>
    <segment id="77">&amp;quot;O sistema de governo chin&amp;ecirc</segment>
    <segment id="78">;s n&amp;atilde</segment>
    <segment id="79">;o me diz respeito.</segment>
    <segment id="80">O Brasil &amp;eacute</segment>
    <segment id="81">; um vendedor</segment>
    <segment id="82">, um comerciante de produtos agropecu&amp;aacute</segment>
    <segment id="83">;rios e de tantos outros.</segment>
    <segment id="84">N&amp;atilde</segment>
    <segment id="85">;o estamos l&amp;aacute</segment>
    <segment id="86">; para discutir isso [o sistema pol&amp;iacute</segment>
    <segment id="87">;tico da China]&amp;quot</segment>
    <segment id="88">;, afirmou Abreu.</segment>
    <segment id="89">&amp;quot;Queremos provar que nosso produto &amp;eacute</segment>
    <segment id="90">; bom, que tem consist&amp;ecirc</segment>
    <segment id="91">;ncia e que temos condi&amp;ccedil</segment>
    <segment id="92">;&amp;otilde</segment>
    <segment id="93">;es de entregar&amp;quot</segment>
    <segment id="94">;, disse a senadora.  &amp;quot</segment>
    <segment id="95">;Ent&amp;atilde</segment>
    <segment id="96">;o brigar com a China &amp;mdash</segment>
    <segment id="97">;ou dizer &amp;#39</segment>
    <segment id="98">;eu n&amp;atilde</segment>
    <segment id="99">;o gosto da China por causa do seu sistema de governo&amp;#39</segment>
    <segment id="100">;&amp;mdash</segment>
    <segment id="101">; n&amp;atilde</segment>
    <segment id="102">;o nos diz respeito.</segment>
    <segment id="103">Isso n&amp;atilde</segment>
    <segment id="104">;o &amp;eacute</segment>
    <segment id="105">; da nossa conta</segment>
    <segment id="106">, &amp;eacute</segment>
    <segment id="107">; da conta dos chineses.&amp;quot</segment>
    <segment id="108">;</segment>
    <segment id="109">Apesar das cr&amp;iacute</segment>
    <segment id="110">;ticas &amp;agrave</segment>
    <segment id="111">; ideologia da atual pol&amp;iacute</segment>
    <segment id="112">;tica externa</segment>
    <segment id="113">, ela disse que n&amp;atilde</segment>
    <segment id="114">;o lhe cabe avaliar</segment>
    <segment id="115">sese Ernesto tem ou n&amp;atilde</segment>
    <segment id="116">;o condi&amp;ccedil</segment>
    <segment id="117">;&amp;otilde</segment>
    <segment id="118">;es de permanecer no cargo.</segment>
    <segment id="119">&amp;quot;Eu n&amp;atilde</segment>
    <segment id="120">;o gostaria de dizer que nenhum ministro deve ou n&amp;atilde</segment>
    <segment id="121">;o sair</segment>
    <segment id="122">, isso &amp;eacute</segment>
    <segment id="123">;</segment>
    <segment id="124">uma prerrogativa presidencial.</segment>
    <segment id="125">Agora acho</segment>
    <segment id="126">, sim, que [ele] deve ter mudan&amp;ccedil</segment>
    <segment id="127">;as de comportamento&amp;quot</segment>
    <segment id="128">;, afirmou.  Senadora Kátia</segment>
    <segment id="129">Abreu</segment>
    <segment id="130">posa com saia feita a partir de gravatas de colegas senadoresMais    novamente         de   de  de  representando um  &amp;quot</segment>
    <segment id="131">;H&amp;aacute</segment>
    <segment id="132">;</segment>
    <segment id="133">coisas que n&amp;atilde</segment>
    <segment id="134">;o s&amp;atilde</segment>
    <segment id="135">;o mais op&amp;ccedil</segment>
    <segment id="136">;&amp;atilde</segment>
    <segment id="137">;o, s&amp;atilde</segment>
    <segment id="138">;o imposi&amp;ccedil</segment>
    <segment id="139">;&amp;atilde</segment>
    <segment id="140">;o.</segment>
    <segment id="141">N&amp;oacute</segment>
    <segment id="142">;s n&amp;atilde</segment>
    <segment id="143">;o temos a op&amp;ccedil</segment>
    <segment id="144">;&amp;atilde</segment>
    <segment id="145">;o de n&amp;atilde</segment>
    <segment id="146">;o querer a China</segment>
    <segment id="147">, n&amp;oacute</segment>
    <segment id="148">;s n&amp;atilde</segment>
    <segment id="149">;o temos a op&amp;ccedil</segment>
    <segment id="150">;&amp;atilde</segment>
    <segment id="151">;o de n&amp;atilde</segment>
    <segment id="152">;o querer a Uni&amp;atilde</segment>
    <segment id="153">;o Europeia&amp;quot</segment>
    <segment id="154">;</segment>
    <segment id="155">, disse a senadora.</segment>
    <segment id="156">A Comiss&amp;atilde</segment>
    <segment id="157">;o de Rela&amp;ccedil</segment>
    <segment id="158">;&amp;otilde</segment>
    <segment id="159">;es Exteriores e Defesa Nacional sabatina todos os diplomatas indicados para comandar embaixadas fora do pa&amp;iacute</segment>
    <segment id="160">;s.</segment>
    <segment id="161">O novo comando do colegiado gera apreens&amp;atilde</segment>
    <segment id="162">;o entre aliados de Ernesto no Itamaraty.</segment>
    <segment id="163">Abreu esteve no centro da maior derrota do chanceler no Senado: a rejei&amp;ccedil</segment>
    <segment id="164">;&amp;atilde</segment>
    <segment id="165">;o da indica&amp;ccedil</segment>
    <segment id="166">;&amp;atilde</segment>
    <segment id="167">;o do diplomata Fabio Marzano para chefiar a miss&amp;atilde</segment>
    <segment id="168">;o do Brasil junto &amp;agrave</segment>
    <segment id="169">; ONU (Organiza&amp;ccedil</segment>
    <segment id="170">;&amp;atilde</segment>
    <segment id="171">;o das Na&amp;ccedil</segment>
    <segment id="172">;&amp;otilde</segment>
    <segment id="173">;es Unidas) em Genebra.</segment>
    <segment id="174">A senadora garantiu que n&amp;atilde</segment>
    <segment id="175">;o comandou o voto negativo a Marzano.</segment>
    <segment id="176">Ela afirmou</segment>
    <segment id="177">, por&amp;eacute</segment>
    <segment id="178">;m, que houve solidariedade dos demais senadores ap&amp;oacute</segment>
    <segment id="179">;s uma desaven&amp;ccedil</segment>
    <segment id="180">;a dela com o diplomata.</segment>
    <segment id="181">Segundo Abreu</segment>
    <segment id="182">, o Senado deu uma &amp;quot</segment>
    <segment id="183">;sinaliza&amp;ccedil</segment>
    <segment id="184">;&amp;atilde</segment>
    <segment id="185">;o geral&amp;quot</segment>
    <segment id="186">; com a rejei&amp;ccedil</segment>
    <segment id="187">;&amp;atilde</segment>
    <segment id="188">;o.</segment>
    <segment id="189">A senadora disse tamb&amp;eacute</segment>
    <segment id="190">;m que o governo precisa &amp;quot</segment>
    <segment id="191">;abandonar o negacionismo&amp;quot</segment>
    <segment id="192">; nas quest&amp;otilde</segment>
    <segment id="193">;es ambientais para permitir o avan&amp;ccedil</segment>
    <segment id="194">;o do acordo comercial Uni&amp;atilde</segment>
    <segment id="195">;o Europeia-Mercosul.  &amp;quot</segment>
    <segment id="196">;Esse negacionismo</segment>
    <segment id="197">, de que [n&amp;atilde</segment>
    <segment id="198">;o] tem aquecimento global</segment>
    <segment id="199">, de que desmatamento [n&amp;atilde</segment>
    <segment id="200">;o] faz mal.</segment>
    <segment id="201">&amp;Eacute</segment>
    <segment id="202">; a bandeira universal</segment>
    <segment id="203">, que n&amp;oacute</segment>
    <segment id="204">;s todos estamos defendendo hoje.</segment>
    <segment id="205">Negar isso &amp;eacute</segment>
    <segment id="206">;</segment>
    <segment id="207">igual tentar negar direitos humanos</segment>
    <segment id="208">, algo indiscut&amp;iacute</segment>
    <segment id="209">;vel, que todos os pa&amp;iacute</segment>
    <segment id="210">;ses acreditam e que nem</segment>
    <segment id="211">sese discute mais&amp;quot</segment>
    <segment id="212">;, disse.</segment>
    <segment id="213">Uma das primeiras a&amp;ccedil</segment>
    <segment id="214">;&amp;otilde</segment>
    <segment id="215">;es prometidas pela senadora &amp;eacute</segment>
    <segment id="216">; organizar uma viagem a Bruxelas para convidar parlamentares europeus para uma visita &amp;agrave</segment>
    <segment id="217">; Amaz&amp;ocirc</segment>
    <segment id="218">;nia.</segment>
    <segment id="219">&amp;quot;Quando voc&amp;ecirc</segment>
    <segment id="220">;</segment>
    <segment id="221">vai produzir um produto</segment>
    <segment id="222">, qual a sua preocupa&amp;ccedil</segment>
    <segment id="223">;&amp;atilde</segment>
    <segment id="224">;o?</segment>
    <segment id="225">&amp;Eacute</segment>
    <segment id="226">; com seu cliente</segment>
    <segment id="227">, com quem vai comprar&amp;quot</segment>
    <segment id="228">;, afirmou.  &amp;quot</segment>
    <segment id="229">;Ent&amp;atilde</segment>
    <segment id="230">;o, se</segment>
    <segment id="231">se eu quero vender para a Europa</segment>
    <segment id="232">, o que o meu cliente europeu quer?</segment>
    <segment id="233">Ele quer que n&amp;atilde</segment>
    <segment id="234">;o tenha desmatamento ilegal de onde vem o produto.</segment>
    <segment id="235">&amp;Eacute</segment>
    <segment id="236">; um direito dele.</segment>
    <segment id="237">N&amp;oacute</segment>
    <segment id="238">;s podemos virar as costas e falar que a Europa n&amp;atilde</segment>
    <segment id="239">;o nos interessa</segment>
    <segment id="240">, que n&amp;atilde</segment>
    <segment id="241">;o queremos vender.</segment>
    <segment id="242">Ser&amp;aacute</segment>
    <segment id="243">; que n&amp;oacute</segment>
    <segment id="244">;s podemos [fazer] isso?</segment>
    <segment id="245">N&amp;atilde</segment>
    <segment id="246">;o.&amp;quot</segment>
    <segment id="247">;</segment>
  </rst>
</analysis>