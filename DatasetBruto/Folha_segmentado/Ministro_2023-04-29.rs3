  <rst>
    <segment id="1">Ministros do governo Luiz Inácio Lula da Silva (PT) têm aberto as portas da Esplanada para receber políticos locais</segment>
    <segment id="2">, como</segment>
    <segment id="3">como vereadores</segment>
    <segment id="4">, secretários municipais e prefeitos das suas bases eleitorais.</segment>
    <segment id="5">O levantamento é baseado na divulgação dos compromissos de cada ministério à CGU (Controladoria-Geral da União) entre os dias 1º de março e 25 de abril.</segment>
    <segment id="6">Somente no dia 1º de março</segment>
    <segment id="7">, o secretário de Comunicação</segment>
    <segment id="8">, Paulo Pimenta (PT)</segment>
    <segment id="9">, recebeu para um café da manhã vereadores de sete cidades do Rio Grande do Sul (Unistalda</segment>
    <segment id="10">, Piratini</segment>
    <segment id="11">, Taquari</segment>
    <segment id="12">, Tabaí</segment>
    <segment id="13">, Caçapava</segment>
    <segment id="14">, Santana do Livramento e Três de Maio) e</segment>
    <segment id="15">, à tarde</segment>
    <segment id="16">, esteve com vereadores de Santa Maria para tratar de "demandas do município".</segment>
    <segment id="17">Em 23 dias de expediente</segment>
    <segment id="18">, conforme a agenda divulgada em março</segment>
    <segment id="19">, o petista esteve reunido com políticos gaúchos em pelo menos 7.</segment>
    <segment id="20">Paulo Pimenta</segment>
    <segment id="21">, ministro da Secom</segment>
    <segment id="22">, recebeu caravanas com mais de 60 políticos do Rio Grande do Sul - Gabriela Biló - 18.jan.2023/FolhapressO pernambucano André de Paula</segment>
    <segment id="23">, da Pesca</segment>
    <segment id="24">, esteve com os presidentes das Câmaras de Gravatá e Bezerros no dia 3 de março e</segment>
    <segment id="25">, no dia 16</segment>
    <segment id="26">, com o gerente de convênios e projetos da cidade de Itapissuma.</segment>
    <segment id="27">O ministro também reservou o dia 14 na sua agenda para tratar sobre assuntos "inerentes à pesca e aquicultura no município de Paulista/PE"</segment>
    <segment id="28">, conforme descreve na agenda.</segment>
    <segment id="29">Em abril deste ano</segment>
    <segment id="30">, Paula esteve com o prefeito de Tacaratu (PE) para tratar de "propostas e pleitos de projetos municipais" no dia 12 e</segment>
    <segment id="31">, no dia 24</segment>
    <segment id="32">, foi contemplado com visita de cortesia dos vereadores de Orobó</segment>
    <segment id="33">, Machados</segment>
    <segment id="34">, Limoeiro</segment>
    <segment id="35">, Santa Cruz do Capibaribe</segment>
    <segment id="36">, Vicência</segment>
    <segment id="37">, Tracunhaém e Taquaritinga do Norte</segment>
    <segment id="38">, todos de Pernambuco.</segment>
    <segment id="39">O maranhense Juscelino Filho</segment>
    <segment id="40">, ministro das Comunicações</segment>
    <segment id="41">, recebeu os prefeitos de Timon e Bernardo de Mearim</segment>
    <segment id="42">, no dia 7 de março</segment>
    <segment id="43">, e o de Tuntum no dia 10 de abril —neste mesmo dia</segment>
    <segment id="44">, aliás</segment>
    <segment id="45">, ele teve audiência com o corregedor-geral da Justiça do Maranhão</segment>
    <segment id="46">, José de Ribamar Froz Sobrinho.</segment>
    <segment id="47">O ministro de Comunicações abriu as portas para um clã bastante conhecido da política maranhense.</segment>
    <segment id="48">Estiveram em seu gabinete a deputada e ex-governadora Roseana Sarney e Fernando Sarney</segment>
    <segment id="49">comocomo representante do grupo de mídia da família</segment>
    <segment id="50">, o Mirante.</segment>
    <segment id="51">Juscelino percorreu ao menos sete cidades maranhenses entre os dias 1º e 3 de abril para ações de apoio às vítimas das chuvas no Maranhão.</segment>
    <segment id="52">Outro que tem sido acolher com seus conterrâneos é o ministro dos Transportes</segment>
    <segment id="53">, o alagoano Renan Calheiros Filho (MDB).</segment>
    <segment id="54">Entre março e abril</segment>
    <segment id="55">, ele já esteve com prefeito de Piaçabuçu</segment>
    <segment id="56">, Porto Real</segment>
    <segment id="57">, Porto de Pedras</segment>
    <segment id="58">, São Miguel dos Milagres e</segment>
    <segment id="59">, em duas ocasiões</segment>
    <segment id="60">, o prefeito Júlio Cézar</segment>
    <segment id="61">, da cidade de Palmeira dos Índios.</segment>
    <segment id="62">A pernambucana Luciana Santos</segment>
    <segment id="63">, ministra da Ciência e Tecnologia</segment>
    <segment id="64">, recebeu Mauricélia Montenegro</segment>
    <segment id="65">, secretária da Ciência de Pernambuco</segment>
    <segment id="66">, em 13 de março</segment>
    <segment id="67">, Yves Ribeiro</segment>
    <segment id="68">, prefeito de Paulista (PE)</segment>
    <segment id="69">, em 16 de março</segment>
    <segment id="70">, e almoçou com a governadora Raquel Lyra (PSDB) em 22 de março.</segment>
    <segment id="71">No dia 19 de abril</segment>
    <segment id="72">, recebeu Carlos Uchôa</segment>
    <segment id="73">, prefeito de Araçoiaba.</segment>
    <segment id="74">Tais ministros também aproveitaram o evento Marcha dos Prefeitos para encontros com os políticos de suas bases eleitorais.</segment>
    <segment id="75">Pimenta recepcionou três caravanas com autoridades de quase 70 cidades do Rio Grande do Sul.</segment>
    <segment id="76">Juscelino esteve com prefeitos de 12 cidades maranhenses (Mangabeira</segment>
    <segment id="77">, Timon</segment>
    <segment id="78">, São Mateus</segment>
    <segment id="79">, Bernardo de Mearim</segment>
    <segment id="80">, Brejão</segment>
    <segment id="81">, Grajaú</segment>
    <segment id="82">, Turilândia</segment>
    <segment id="83">, Santa Filomena</segment>
    <segment id="84">, Brejo de Areia</segment>
    <segment id="85">, São Raimundo do Doca</segment>
    <segment id="86">,Tuntum</segment>
    <segment id="87">, Barra do Corda)</segment>
    <segment id="88">, além de</segment>
    <segment id="89">sese reunir com representantes da Federação dos Municípios do Estado do Maranhão no dia 29 de março.</segment>
    <segment id="90">André de Paula aproveitou o dia 28 de março para</segment>
    <segment id="91">sese reunir com vereadores</segment>
    <segment id="92">, prefeitos e secretários de 14 municípios do seu estado natal.</segment>
    <segment id="93">São eles:</segment>
    <segment id="94">Jurema</segment>
    <segment id="95">, Jaqueira</segment>
    <segment id="96">, Chã Grande</segment>
    <segment id="97">, Custódia</segment>
    <segment id="98">, Olinda</segment>
    <segment id="99">, Brejo Madre de Deus</segment>
    <segment id="100">, Itapissuma</segment>
    <segment id="101">, Santa Maria do Cambucá</segment>
    <segment id="102">, Casinhas</segment>
    <segment id="103">, Lagoa Grande</segment>
    <segment id="104">, Cabrobó</segment>
    <segment id="105">, Orocó</segment>
    <segment id="106">, Terra Nova e Ilha de Itamaracá.</segment>
    <segment id="107">Luciana Santos</segment>
    <segment id="108">sese encontrou com representantes de 25 cidades pernambucanas diferentes nos dias da Marcha</segment>
    <segment id="109">, entre prefeitos</segment>
    <segment id="110">, secretários e vereadores</segment>
    <segment id="111">, além de deputados de seu estado natal.</segment>
    <segment id="112">Veja fotos dos presidentes com as equipes de ministros no início de governoMais    novamente         de   de  de  representando um  outro lado</segment>
    <segment id="113">A assessoria do Ministério das Comunicações disse ao Painel que o Maranhão é "um dos estados brasileiros com os menores índices de inclusão digital</segment>
    <segment id="114">, de acordo com levantamentos da FGV</segment>
    <segment id="115">, IBGE e Anatel" e</segment>
    <segment id="116">, portanto</segment>
    <segment id="117">, "são justificadas as ações prioritárias naquela unidade federativa".</segment>
    <segment id="118">A pasta também afirma que é</segment>
    <segment id="119">, no mínimo</segment>
    <segment id="120">, malicioso afirmar que o ministro privilegia seu estado de origem.</segment>
    <segment id="121">Em relação à visita dos Sarneys</segment>
    <segment id="122">, o Ministério disse que é responsabilidade do "chefe executivo das Comunicações reunir-</segment>
    <segment id="123">sese com atores do setor de radiodifusão e telecomunicações para fomentar decisões no âmbito das políticas públicas.</segment>
    <segment id="124">"</segment>
    <segment id="125">À coluna</segment>
    <segment id="126">, a assessoria do Ministério dos Transportes disse que o ministro "tem recebido ou participado de agendas com parlamentares</segment>
    <segment id="127">, bancadas e governadores de diferentes estados</segment>
    <segment id="128">, a exemplo das bancadas do Paraná</segment>
    <segment id="129">, Ceará</segment>
    <segment id="130">, Mato Grosso do Sul e Santa Catarina".</segment>
    <segment id="131">A nota também ressalta que Renan Filho atendeu</segment>
    <segment id="132">, entre janeiro e março</segment>
    <segment id="133">, 11 governadores.</segment>
    <segment id="134">Em nota</segment>
    <segment id="135">, a assessoria de comunicação do Ministério da Ciência afirma que Luciana recebeu prefeitos e parlamentares de diversos estados do país e que as audiências foram intensificadas durante a Marcha dos Prefeitos.</segment>
    <segment id="136">Esclarece</segment>
    <segment id="137">, ainda</segment>
    <segment id="138">, que a agenda da ministra procura atender todos os setores da sociedade</segment>
    <segment id="139">, sem distinção política ou partidária.</segment>
    <segment id="140">PainelReceba no seu email as informações exclusivas da coluna PainelCarregando...</segment>
    <segment id="141">Procurados</segment>
    <segment id="142">, a Secom e o Ministério da Pesca não</segment>
    <segment id="143">sese manifestaram.</segment>
  </rst>
</analysis>