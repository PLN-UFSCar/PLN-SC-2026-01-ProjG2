  <rst>
    <segment id="1">O Museu da Imagem e do Som</segment>
    <segment id="2">, que deverá ser inaugurado no início de março</segment>
    <segment id="3">, começou nesta quarta-feira (27) a ser instalado no Palácio dos Campos Elíseos</segment>
    <segment id="4">, antiga sede do governo do estado de São Paulo.</segment>
    <segment id="5">Três salas na parte térrea do edifício em reforma passaram a ser ocupadas pelas seções técnicas do MIS.</segment>
    <segment id="6">Até o dia 4 de março</segment>
    <segment id="7">, mais três salas serão utilizadas.</segment>
    <segment id="8">Enquanto não</segment>
    <segment id="9">sese conclui a obra total do edifício</segment>
    <segment id="10">, destruído por um incêndio</segment>
    <segment id="11">, a administração do museu ficará instalada no prédio do Conselho Estadual de Cultura.</segment>
    <segment id="12">O MIS iniciará em breve a tomada de depoimentos de personalidades paulistas.</segment>
    <segment id="13">Primeira Página da Folha de 28 de janeiro de 1971 - Reprodução</segment>
  </rst>
</analysis>