    <segment id="1">Inspirada no modelo da escola de formação política brasileira RenovaBR</segment>
    <segment id="2">, a organização +</segment>
    <segment id="3">Costa Rica formou 51 lideranças locais para participarem das eleições no país da América Central.</segment>
    <segment id="4">Destas</segment>
    <segment id="5">, 13 foram eleitas.</segment>
    <segment id="6">"</segment>
