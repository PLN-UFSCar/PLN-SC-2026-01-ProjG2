  <rst>
    <segment id="1">Dias antes de fazer uma viagem a São Paulo</segment>
    <segment id="2">, a gaúcha Daiane Lima</segment>
    <segment id="3">, de 27 anos</segment>
    <segment id="4">, moradora de Erechim (RS) decidiu fazer uma limpeza de pele facial.</segment>
    <segment id="5">Ela só não imaginava que o procedimento de limpar os poros e diminuir a oleosidade do rosto iria ajudá-la a descobrir um câncer de pele.</segment>
    <segment id="6">Daiane relata que faz limpeza de pele rotineiramente e</segment>
    <segment id="7">, em meados de 2022</segment>
    <segment id="8">, agendou mais uma vez o procedimento com uma esteticista da cidade.</segment>
    <segment id="9">No entanto</segment>
    <segment id="10">, logo após o procedimento</segment>
    <segment id="11">, ela conta que ficou com a área próxima ao nariz sensível.</segment>
    <segment id="12">"</segment>
    <segment id="13">Depois de alguns dias</segment>
    <segment id="14">, surgiu uma ferida pequena</segment>
    <segment id="15">, masmas eu imaginei que era devido a algum cravo que foi removido ou algo assim e comecei a usar uma pomada para cicatrização"</segment>
    <segment id="16">, recorda.</segment>
    <segment id="17">Ao fazer limpeza de pele</segment>
    <segment id="18">, Daiane Lima descobriu que ferida no nariz era câncer de pele - Arquivo pessoal via BBC BrasilA body piercer (profissional que trabalha com aplicação de piercing) detalha que</segment>
    <segment id="19">, nas semanas seguintes</segment>
    <segment id="20">, a ferida cicatrizava</segment>
    <segment id="21">, masmas depois não desaparecia por completo.</segment>
    <segment id="22">Ficou assim por pouco mais de um mês.</segment>
    <segment id="23">E foi após um sangramento no local que ela ficou mais alerta para o machucado.</segment>
    <segment id="24">"Acordei e meu nariz estava sangrando muito.</segment>
    <segment id="25">Foi quando decidi marcar uma consulta com uma dermatologista"</segment>
    <segment id="26">, diz.</segment>
    <segment id="27">Por não ter plano de saúde</segment>
    <segment id="28">, a jovem</segment>
    <segment id="29">, que trabalha</segment>
    <segment id="30">comocomo autônoma</segment>
    <segment id="31">, precisou usar as economias para pagar uma consulta particular.</segment>
    <segment id="32">E foi logo na primeira visita ao médico que surgiu a suspeita de que aquela ferida no nariz que não cicatrizava poderia ser</segment>
    <segment id="33">, na verdade</segment>
    <segment id="34">, um câncer de pele.  "</segment>
    <segment id="35">Quando a médica falou dessa possibilidade</segment>
    <segment id="36">, eu já desabei a chorar.</segment>
    <segment id="37">Você pensa mil coisas.</segment>
    <segment id="38">Como eu era nova e não tinha casos de câncer de pele na família</segment>
    <segment id="39">, nunca imaginei que isso poderia acontecer comigo.</segment>
    <segment id="40">Meu mundo desabou naquele momento"</segment>
    <segment id="41">, conta a jovem.</segment>
    <segment id="42">O resultado da biópsia confirmou que Daiane estava com carcinoma basocelular</segment>
    <segment id="43">, um tipo de câncer de pele</segment>
    <segment id="44">, e precisava fazer uma cirurgia para retirá-lo.</segment>
    <segment id="45">Incidência de câncer no BrasilMais    novamente         de   de  de  representando um  Em janeiro</segment>
    <segment id="46">, ela fez o procedimento e parte da pele do rosto foi retirada para remover o tumor.</segment>
    <segment id="47">Foram necessários 27 pontos e ela precisou ficar dois meses sem trabalhar.</segment>
    <segment id="48">O diagnóstico também fez a jovem trancar o último semestre da faculdade de História.</segment>
    <segment id="49">"</segment>
    <segment id="50">Minha vida mudou completamente de um dia para o outro.</segment>
    <segment id="51">Não é só o diagnóstico</segment>
    <segment id="52">, masmas também todas as consequências que ele traz.</segment>
    <segment id="53">Além de paralisar a faculdade e o trabalho</segment>
    <segment id="54">, também tem a questão da autoestima que</segment>
    <segment id="55">sese acaba</segment>
    <segment id="56">, ainda mais por meu câncer ser no rosto</segment>
    <segment id="57">, um lugar muito visível"</segment>
    <segment id="58">, relata.</segment>
    <segment id="59">Além da marca na pele</segment>
    <segment id="60">, Daiane diz que o câncer também fez com que ela fosse diagnosticada com crise de ansiedade e depressão.</segment>
    <segment id="61">"Minha autoestima acabou.</segment>
    <segment id="62">Eu não conseguia me olhar no espelho e evitava sair na rua.</segment>
    <segment id="63">Todo mundo me pergunta o que fiz e o porquê da minha cicatriz.</segment>
    <segment id="64">Fiquei um bom tempo sem sair de casa por não querer ser vista.</segment>
    <segment id="65">Sem contar que as pessoas fazem piadas que me machucam</segment>
    <segment id="66">comocomo me chamar de gordinha.</segment>
    <segment id="67">Elas não têm noção do porquê meu corpo está assim"</segment>
    <segment id="68">, diz ela</segment>
    <segment id="69">, que aponta que os medicamentos a levaram a engordar.</segment>
    <segment id="70">O que é carcinoma basocelular</segment>
    <segment id="71">Segundo o Instituto Nacional de Câncer (Inca)</segment>
    <segment id="72">, o carcinoma basocelular é o tipo mais comum de câncer de pele não melanoma</segment>
    <segment id="73">, representando cerca de 80% dos diagnósticos.</segment>
    <segment id="74">Ele tem origem nas células basais da epiderme e</segment>
    <segment id="75">sese apresenta</segment>
    <segment id="76">, principalmente</segment>
    <segment id="77">, como</segment>
    <segment id="78">como uma lesão (ferida ou nódulo) com bordos róseos</segment>
    <segment id="79">, translúcidos ou perolados</segment>
    <segment id="80">, que não cicatriza</segment>
    <segment id="81">, podendo ulcerar e sangrar.</segment>
    <segment id="82">"É um câncer de pele considerado</segment>
    <segment id="83">, entre todos os tumores</segment>
    <segment id="84">, o mais benigno</segment>
    <segment id="85">, porque</segment>
    <segment id="86">porque dificilmente ele encaminha células tumorais para outros órgãos.</segment>
    <segment id="87">Isso só acontece quando o tratamento é bastante demorado e o tumor é agressivo</segment>
    <segment id="88">, invadindo a parte óssea</segment>
    <segment id="89">, por exemplo.</segment>
    <segment id="90">Porém, isso é raro"</segment>
    <segment id="91">, explica Reinaldo Tovo</segment>
    <segment id="92">, coordenador do núcleo de Dermatologia do Hospital Sírio-Libanês.</segment>
    <segment id="93">O principal fator de risco para o carcinoma basocelular é a exposição direta ao sol.</segment>
    <segment id="94">Pessoas de pele clara são as mais vulneráveis à doença</segment>
    <segment id="95">, que se</segment>
    <segment id="96">se manifesta normalmente após os 40 anos e aparece em áreas do corpo diretamente submetidas à radiação ultravioleta</segment>
    <segment id="97">, como</segment>
    <segment id="98">como face</segment>
    <segment id="99">, pescoço</segment>
    <segment id="100">, costas e peito</segment>
    <segment id="101">, por exemplo.</segment>
    <segment id="102">A doença afeta mais os homens do que as mulheres</segment>
    <segment id="103">, sendo rara em crianças</segment>
    <segment id="104">, adolescentes e pessoas negras.  "</segment>
    <segment id="105">O principal fator de risco é a exposição prolongada ao sol</segment>
    <segment id="106">, principalmente na fase da infância e adolescência.</segment>
    <segment id="107">O sol é uma questão cumulativa</segment>
    <segment id="108">, quanto mais sol você toma ao longo da vida</segment>
    <segment id="109">, maiores as chances de ter um câncer de pele na vida adulta.</segment>
    <segment id="110">Quem tem a pele mais clara</segment>
    <segment id="111">, aquela pessoa que ao tomar sol fica vermelha e não morena</segment>
    <segment id="112">, tem mais chances de desenvolver um câncer de pele também"</segment>
    <segment id="113">, acrescenta Vanessa D'Andretta Tanaka</segment>
    <segment id="114">, dermatologista do Hospital de Amor</segment>
    <segment id="115">, de Barretos.  Diagnóstico e tratamento</segment>
    <segment id="116">O diagnóstico geralmente é clínico.</segment>
    <segment id="117">O dermatologista avalia a lesão na pele e</segment>
    <segment id="118">sese houver dúvidas</segment>
    <segment id="119">, ele pode fazer uma dermatoscopia</segment>
    <segment id="120">, que é a colocação de uma lente sobre a lesão para análise mais detalhada.</segment>
    <segment id="121">Para confirmar o diagnóstico do carcinoma basocelular</segment>
    <segment id="122">, é feita uma biópsia.</segment>
    <segment id="123">O tratamento padrão do câncer de pele não melanoma é a cirurgia</segment>
    <segment id="124">, já que o procedimento permite maior controle das margens do tumor</segment>
    <segment id="125">, possibilitando assim</segment>
    <segment id="126">, maior garantia da cura.</segment>
    <segment id="127">O objetivo da cirurgia é retirar completamente a lesão e o tecido ao redor</segment>
    <segment id="128">comocomo margem de segurança.</segment>
    <segment id="129">"</segment>
    <segment id="130">Esse tipo de cirurgia costuma ser muito segura</segment>
    <segment id="131">, pois</segment>
    <segment id="132">pois a maioria das lesões normalmente é em fases iniciais</segment>
    <segment id="133">, com baixo risco de metástase"</segment>
    <segment id="134">, diz Tiago Kenji</segment>
    <segment id="135">, diretor técnico de Dasa Oncologia do Hospital Santa Paula.</segment>
    <segment id="136">Cuidados</segment>
    <segment id="137">Alguns cuidados</segment>
    <segment id="138">comocomo boa alimentação</segment>
    <segment id="139">, não ingestão de bebidas alcoólicas</segment>
    <segment id="140">, evitar fumar e</segment>
    <segment id="141">, principalmente</segment>
    <segment id="142">, evitar uma exposição solar agressiva ajudam a prevenir o câncer de pele.  "</segment>
    <segment id="143">As pessoas devem usar filtro solar em todas as áreas expostas e o filtro deve ser adequado ao tipo de pele</segment>
    <segment id="144">, sese for mais jovem ou madura</segment>
    <segment id="145">, oleosa ou com tendência a acne"</segment>
    <segment id="146">, acrescenta Tovo.</segment>
    <segment id="147">Também é importante</segment>
    <segment id="148">sese proteger usando roupas e acessórios com fotoproteção</segment>
    <segment id="149">, como</segment>
    <segment id="150">como camisetas</segment>
    <segment id="151">, bonés e chapéus.</segment>
    <segment id="152">Caso a pessoa não tenha condições de adquirir essas peças</segment>
    <segment id="153">, as roupas e acessórios comuns também ajudam a proteger a pele</segment>
    <segment id="154">, desde que façam a cobertura total da área.</segment>
  </rst>
</analysis>