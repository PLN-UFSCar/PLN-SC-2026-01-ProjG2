  <rst>
    <segment id="1">​  Todos os dias</segment>
    <segment id="2">, Ronaldo sai do seu apartamento em Madri</segment>
    <segment id="3">, caminha alguns metros e entra no escritório que serve</segment>
    <segment id="4">comocomo sede do Real Valladolid na capital espanhola.</segment>
    <segment id="5">Ele se</segment>
    <segment id="6">se tornou dono da equipe no início de setembro do ano passado por cerca de 30 milhões de euros (R$ 136</segment>
    <segment id="7">,5 milhões em valores atuais).</segment>
    <segment id="8">Lá o ex-atacante da seleção brasileira é informado de tudo o que ocorre no clube.</segment>
    <segment id="9">Os gastos</segment>
    <segment id="10">, investimentos</segment>
    <segment id="11">, planos a médio e longo prazo e problemas com o time em campo.</segment>
    <segment id="12">O emissário das boas e más notícias é o francês Matthieu Fenaert</segment>
    <segment id="13">, 41, nomeado CEO da agremiação no início desta semana.</segment>
    <segment id="14">Ele era diretor comercial desde o ano passado.</segment>
    <segment id="15">“[Ronaldo tem] Toda influência.</segment>
    <segment id="16">Eu me surpreendi muito.</segment>
    <segment id="17">Temos reuniões diárias e ele fica a par de tudo.</segment>
    <segment id="18">Mesmo quando está de férias</segment>
    <segment id="19">, recebe um relatório todos os dias de manhã.</segment>
    <segment id="20">Ronaldo sabe de tudo o que é decidido”</segment>
    <segment id="21">, afirma Fenaert à Folha</segment>
    <segment id="22">, falando português carregado de sotaque</segment>
    <segment id="23">, aprendido no tempo em que morou no Brasil.</segment>
    <segment id="24">Sua mulher e filha são brasileiras.</segment>
    <segment id="25">Gols e títulos de Ronaldo   novamente         de   de  de  representando um</segment>
    <segment id="26">A aquisição do clube criou em expectativa em parte da cidade de Valladolid (cerca de 300 mil habitantes) de que Ronaldo seria um investidor perdulário</segment>
    <segment id="27">, no estilo de bilionários árabes</segment>
    <segment id="28">, capaz de montar elenco para transformar o destino da equipe da noite para o dia.</segment>
    <segment id="29">Isso está fora de cogitação.</segment>
    <segment id="30">Os planos são a longo prazo.</segment>
    <segment id="31">O clube precisa ser sustentável e gastar só o que arrecada.</segment>
    <segment id="32">Os investimentos mais pesados deverão ser a construção de uma “cidade esportiva”</segment>
    <segment id="33">, que servirá</segment>
    <segment id="34">comocomo centro de treinamento para o elenco profissional e categorias de base</segment>
    <segment id="35">, orçada em 10 milhões de euros (R$ 45</segment>
    <segment id="36">,5 milhões) e a renegociação do uso do estádio José Zorrilla</segment>
    <segment id="37">, com capacidade para 27 mil pessoas.</segment>
    <segment id="38">A arena pertence ao município e o Real Valladolid paga aluguel.</segment>
    <segment id="39">A estrutura precisa de reformas e aqui entra a parte empresarial de Ronaldo.</segment>
    <segment id="40">Ele quer comprar a arena.</segment>
    <segment id="41">Se for para manter o esquema atual</segment>
    <segment id="42">, a Prefeitura tem de colocar a mão no bolso e quitar parte da obra.</segment>
    <segment id="43">Negócios são negócios.</segment>
    <segment id="44">Ronaldo insiste que o Real seja parte integrante da vida da cidade</segment>
    <segment id="45">, masmas sem sentimentalismos.</segment>
    <segment id="46">Ronaldo assiste a jogo do Real Madrid e Real Valladolid pelo Campeonato Espanhol da última temporada- Sergio Perez-10.mar.19/Reuters</segment>
    <segment id="47">O fornecedor de material esportivo é outro exemplo.</segment>
    <segment id="48">Quando o Real Valladolid rompeu com a Hummel</segment>
    <segment id="49">, recebeu sondagens de todas as principais empresas do setor.</segment>
    <segment id="50">Esperava-</segment>
    <segment id="51">sese que a Nike saísse vencedora.</segment>
    <segment id="52">Ronaldo tem contrato vitalício de patrocínio com a marca americana.</segment>
    <segment id="53">Foi escolhida a Adidas.</segment>
    <segment id="54">“</segment>
    <segment id="55">O Ronaldo fez o que foi melhor para o clube</segment>
    <segment id="56">, não para ele.</segment>
    <segment id="57">Pode até ter gerado um certo incômodo que o clube do Ronaldo tenha fechado com a Adidas e não com a Nike”</segment>
    <segment id="58">, constata Fenaert.</segment>
    <segment id="59">Na temporada passada</segment>
    <segment id="60">, o time jogou com o menor orçamento entre os 20 clubes da elite espanhola: 24 milhões de euros (R$ 109</segment>
    <segment id="61">,2 mi).</segment>
    <segment id="62">Terminou em 16º e escapou do rebaixamento apenas na penúltima rodada.</segment>
    <segment id="63">O campeão Barcelona poderia gastar 633 mi de euros (R$ 2</segment>
    <segment id="64">,9 bilhões).</segment>
    <segment id="65">O orçamento estimado pelo Flamengo</segment>
    <segment id="66">, time que Ronaldo sempre disse ser torcedor</segment>
    <segment id="67">, em dezembro do ano passado</segment>
    <segment id="68">, era de 164 mi de euros (R$ 750 mi).</segment>
    <segment id="69">Mexer com números</segment>
    <segment id="70">, negociações e contratos sempre fez parte da vida profissional de Fenaert.</segment>
    <segment id="71">Lidar com paixão do torcedor e o imponderável do futebol dentro de campo</segment>
    <segment id="72">, não.</segment>
    <segment id="73">Até 2018</segment>
    <segment id="74">, ele estava mais preocupado com a Copa do Mundo de rúgbi deste ano e os Jogos Olímpicos de Tóquio de 2020.</segment>
    <segment id="75">Executivo da Octagon</segment>
    <segment id="76">, empresa de marketing esportivo</segment>
    <segment id="77">, trabalhava com esses dois eventos</segment>
    <segment id="78">, que serão sediados no Japão.</segment>
    <segment id="79">Fenaert morava no país asiático quando recebeu o convite de Ronaldo para trabalhar no Real Valladolid.</segment>
    <segment id="80">Ronaldo Nazário</segment>
    <segment id="81">, o Fenômeno   novamente         de   de  de  representando um</segment>
    <segment id="82">A diferença de idade entre os dois é de apenas um ano (Ronaldo está com 42)</segment>
    <segment id="83">, masmas o executivo define o ex-centroavante</segment>
    <segment id="84">comocomo seu “ídolo de infância”.</segment>
    <segment id="85">“É um projeto concreto</segment>
    <segment id="86">, sem imediatismo.</segment>
    <segment id="87">É a longo prazo.</segment>
    <segment id="88">Não queria arriscar.</segment>
    <segment id="89">Estava há 10 anos na Octagon e feliz.</segment>
    <segment id="90">Não queria ficar em uma situação complicada</segment>
    <segment id="91">, masmas a visão que o Ronaldo tem para o clube me deu tranquilidade”</segment>
    <segment id="92">, explica.</segment>
    <segment id="93">A união empresarial e esportiva com o Valladolid e Ronaldo tem também a parte de implantar suas ideias</segment>
    <segment id="94">, sem intermediários.</segment>
    <segment id="95">Como executivo de marketing</segment>
    <segment id="96">, ele dava recomendações aos clientes</segment>
    <segment id="97">masmas estas poderiam não ser seguidas.</segment>
    <segment id="98">“Às vezes gerava um sentimento de frustração”</segment>
    <segment id="99">, confessa.</segment>
    <segment id="100">No cargo de CEO de clube que está na 1ª divisão de uma das principais ligas do mundo</segment>
    <segment id="101">, a conversa é outra.</segment>
    <segment id="102">Matthieu Fenaert (à esq.) e Ronaldo na sede do Real Valladolid  - Valladolid / Divulgação  “Tinha o sonho de trabalhar em um clube com relação era mais direta.</segment>
    <segment id="103">Mexe na vida dos torcedores.</segment>
    <segment id="104">A pressão é maior</segment>
    <segment id="105">porque</segment>
    <segment id="106">porque o torcedor</segment>
    <segment id="107">sese sente dono.</segment>
    <segment id="108">Tem uma parte irracional.</segment>
    <segment id="109">Tudo o que a gente faz tem uma visibilidade muito grande.</segment>
    <segment id="110">Nosso business é a felicidade do torcedor”</segment>
    <segment id="111">, compara.</segment>
    <segment id="112">Associada a Ronaldo</segment>
    <segment id="113">, essa visibilidade fica maior.</segment>
    <segment id="114">O Real Valladolid espera bater o recorde na venda de carnês com todos os jogos em casa da temporada.</segment>
    <segment id="115">Já são mais de 20 mil vendidos em um estádio para 27 mil pessoas.</segment>
    <segment id="116">Ele afirma também que o clube nunca vendeu tantos uniformes.</segment>
    <segment id="117">“Temos de reduzir a importância que os direitos de TV têm no orçamento</segment>
    <segment id="118">porque</segment>
    <segment id="119">porque é um risco colocar todos os ovos na mesma cesta.</segment>
    <segment id="120">A presença do Ronaldo aumenta nosso potencial global</segment>
    <segment id="121">, que outros clubes de médio porte não têm.</segment>
    <segment id="122">A chegada dele ao Valladolid mudou completamente essa equação.</segment>
    <segment id="123">”</segment>
    <segment id="124">Deu mais poder também para o time buscar reforços.</segment>
    <segment id="125">A boa relação com o presidente do Real Madrid</segment>
    <segment id="126">, Florentino Pérez</segment>
    <segment id="127">, fez com que o time da capital emprestasse três jogadores</segment>
    <segment id="128">, aliviando as finanças.</segment>
    <segment id="129">Mas isso não significa que Ronaldo seja econômico com tudo.</segment>
    <segment id="130">Para comemorar a permanência na elite espanhola</segment>
    <segment id="131">, ele convidou todos os jogadores para relaxar em Ibiza</segment>
    <segment id="132">, no mar Mediterrâneo.</segment>
    <segment id="133">Matthieu Fenaert ficou em Valladolid para planejar a nova temporada.</segment>
  </rst>
</analysis>