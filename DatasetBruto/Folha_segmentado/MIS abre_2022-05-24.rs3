  <rst>
    <segment id="1">Idealizada pelo curador Marcello Dantas e pelo compositor e crítico literário José Miguel Wisnik</segment>
    <segment id="2">, a exposição "Cem Anos Modernos" será aberta ao público no próximo dia 2</segment>
    <segment id="3">, no MIS (Museu da Imagem e do Som)</segment>
    <segment id="4">, em São Paulo.</segment>
    <segment id="5">O objetivo é mostrar</segment>
    <segment id="6">comocomo as ideias e reflexões da Semana de Arte Moderna de 1922 reverberaram na cultura brasileira nos últimos cem anos com ênfase na música</segment>
    <segment id="7">, no cinema e no teatro.</segment>
    <segment id="8">Os ingressos começam a ser vendidos nesta quarta (25).</segment>
    <segment id="9">Macunaíma (1969)Mais    novamente         de   de  de  representando um</segment>
    <segment id="10">Na exposição</segment>
    <segment id="11">, não há um caminho único traçado.</segment>
    <segment id="12">Cada visitante pode definir o seu próprio percurso</segment>
    <segment id="13">, passando por salas que levam a diferentes tipos de manifestações artísticas.</segment>
    <segment id="14">Em um dos espaços</segment>
    <segment id="15">, por exemplo</segment>
    <segment id="16">, é possível assistir a trechos do filme "Macunaíma" (1969)</segment>
    <segment id="17">, de Joaquim Pedro de Andrade.</segment>
    <segment id="18">Todos os caminhos</segment>
    <segment id="19">, porém</segment>
    <segment id="20">porém, levam o visitante para um ambiente comum: o Espaço Redondo do MIS</segment>
    <segment id="21">, onde será projetada uma filmagem em 360 graus do Theatro Municipal de São Paulo</segment>
    <segment id="22">, principal palco da Semana de 22.</segment>
    <segment id="23">PIPOCA</segment>
    <segment id="24">Estreia do curta &amp;#039</segment>
    <segment id="25">;A Senhora do Andador&amp;#039</segment>
    <segment id="26">;, no Centro Cultural SPMais    novamente         de   de  de  representando um</segment>
    <segment id="27">A atriz Paloma Bernardi é uma das protagonistas do curta-metragem "</segment>
    <segment id="28">A Senhora do Andador"</segment>
    <segment id="29">, que teve sua sessão de estreia realizada na semana passada</segment>
    <segment id="30">, no Centro Cultural SP</segment>
    <segment id="31">, na capital.</segment>
    <segment id="32">O curta é dirigido por Rogerio Boo</segment>
    <segment id="33">, que compareceu à première.</segment>
    <segment id="34">A multiartista Gabriela Bassani também esteve lá.  com BIANKA VIEIRA</segment>
    <segment id="35">, KARINA MATIAS e MANOELLA SMITH</segment>
  </rst>
