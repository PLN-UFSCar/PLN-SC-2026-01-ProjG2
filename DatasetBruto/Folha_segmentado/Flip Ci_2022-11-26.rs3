  <rst>
    <segment id="1">Quando o mundo quiser de você a mediocridade</segment>
    <segment id="2">, convém ouvir Itamar Assumpção.</segment>
    <segment id="3">O preto velho e sábio aparece</segment>
    <segment id="4">comocomo lenitivo para esse tipo de agressão</segment>
    <segment id="5">, escreve Cidinha da Silva em uma das crônicas de "Exuzilhar".</segment>
    <segment id="6">A autora continua o texto sobre o compositor e cantor</segment>
    <segment id="7">, que morreu em 2003.</segment>
    <segment id="8">"</segment>
    <segment id="9">Quando propuserem brincar de casinha</segment>
    <segment id="10">, enquanto você quer construir casa com fundação e alicerce para crescer rumo aos céus</segment>
    <segment id="11">, convém desenhar a planta sob supervisão de Itamar</segment>
    <segment id="12">, um gigante na arquitetura da palavra.</segment>
    <segment id="13">"Retrato da escritora Cidinha da Silva no centro historico de Paraty</segment>
    <segment id="14">, no Rio de Janeiro - Zanone Fraissat/Folhapress</segment>
    <segment id="15">Com 20 livros publicados</segment>
    <segment id="16">, entre crônicas</segment>
    <segment id="17">, contos</segment>
    <segment id="18">, textos para teatro e histórias voltadas ao público infantojuvenil</segment>
    <segment id="19">, a mineira radicada em São Paulo também tem</segment>
    <segment id="20">sese esmerado na "arquitetura da palavra".</segment>
    <segment id="21">Silva acaba de lançar uma versão ampliada de "Exuzilhar"</segment>
    <segment id="22">, livro publicado originalmente em 2019 e que sai agora com dez crônicas a mais.</segment>
    <segment id="23">A obra deve ser um dos temas da mesa "Encruzilhadas do Brasil"</segment>
    <segment id="24">, que acontece neste domingo</segment>
    <segment id="25">, ao meio-dia</segment>
    <segment id="26">, na Festa Literária Internacional de Paraty</segment>
    <segment id="27">, a Flip.</segment>
    <segment id="28">No encontro</segment>
    <segment id="29">, ela estará ao lado do escritor e crítico literário Cristhiano Aguiar.</segment>
    <segment id="30">Nascida em Belo Horizonte em 1967</segment>
    <segment id="31">, Silva</segment>
    <segment id="32">sese deu conta do ímpeto para escrever suas próprias histórias na passagem dos dez para os 11 anos</segment>
    <segment id="33">, quando cursava a quinta série.</segment>
    <segment id="34">Formada em história pela Universidade Federal de Minas Gerais</segment>
    <segment id="35">, publicou sua primeira obra de literatura</segment>
    <segment id="36">, "</segment>
    <segment id="37">Cada Tridente em seu Lugar e Outras Crônicas"</segment>
    <segment id="38">, em 2006</segment>
    <segment id="39">, aos 39 anos.</segment>
    <segment id="40">Lançado há três anos</segment>
    <segment id="41">, "</segment>
    <segment id="42">Um Exu em Nova York" venceu o prêmio da Biblioteca Nacional na categoria conto.</segment>
    <segment id="43">"</segment>
    <segment id="44">Transito tranquilamente entre os gêneros</segment>
    <segment id="45">, sempre atendendo ao que o texto me pede</segment>
    <segment id="46">, ao formato que ele quer ter.</segment>
    <segment id="47">Tenho um carinho grande pelas crônicas</segment>
    <segment id="48">, masmas os contos me desafiam mais"</segment>
    <segment id="49">, diz.</segment>
    <segment id="50">Na bibliografia de Silva</segment>
    <segment id="51">, alguns aspectos sobressaem</segment>
    <segment id="52">, como</segment>
    <segment id="53">como a presença da espiritualidade de matriz africana</segment>
    <segment id="54">, a exaltação da cultura negra no Brasil e a observação atenta da desigualdade de raça e de gênero.</segment>
    <segment id="55">Em relação ao estilo</segment>
    <segment id="56">, a capacidade de concisão</segment>
    <segment id="57">sese destaca</segment>
    <segment id="58">, assim</segment>
    <segment id="59">comocomo a prosa com um acento lírico.</segment>
    <segment id="60">Todo esse pacote está representado</segment>
    <segment id="61">, em maior ou menor grau</segment>
    <segment id="62">, no título do livro.</segment>
    <segment id="63">"</segment>
    <segment id="64">'Exuzilhar' não é um conceito</segment>
    <segment id="65">, é apenas um verbo-neologismo criado a partir de uma brincadeira com os nomes Exu e encruzilhada"</segment>
    <segment id="66">, ela escreve.</segment>
    <segment id="67">"'Exuzilhar' é um jeito de corpo que me ajuda a construir o movimento da minha escrita num fluxo de águas e ginga.</segment>
    <segment id="68">"</segment>
    <segment id="69">No livro</segment>
    <segment id="70">, Silva une memórias de sua convivência com figuras simbólicas da negritude no país e comentários sobre a relevância dessas pessoas.</segment>
    <segment id="71">Além de Itamar Assumpção</segment>
    <segment id="72">, surgem nomes</segment>
    <segment id="73">comocomo a ialorixá Mãe Stella de Oxóssi</segment>
    <segment id="74">, a cantora Elza Soares</segment>
    <segment id="75">, o coreógrafo e dançarino Ismael Ivo</segment>
    <segment id="76">, e os compositores Luiz Carlos da Vila e Marku Ribas.</segment>
    <segment id="77">Quem é Ismael Ivo</segment>
    <segment id="78">, brasileiro que brilhou no exteriorMais    novamente         de   de  de  representando um  Sueli Carneiro</segment>
    <segment id="79">, filósofa e fundadora da ONG Geledés - Instituto da Mulher Negra</segment>
    <segment id="80">, é tema de uma das suas crônicas.</segment>
    <segment id="81">"</segment>
    <segment id="82">Sueli é uma pessoa presente em todos os aspectos da minha vida desde que a conheci</segment>
    <segment id="83">, há 36 anos.</segment>
    <segment id="84">Quando a encontrei</segment>
    <segment id="85">, eu recém-entrara na vida adulta e</segment>
    <segment id="86">, desde então</segment>
    <segment id="87">, me beneficiei da maneira generosa e amorosa com que ela me acolheu em sua vida</segment>
    <segment id="88">, como</segment>
    <segment id="89">como uma filha"</segment>
    <segment id="90">, afirma Silva.</segment>
    <segment id="91">Segundo a escritora</segment>
    <segment id="92">, Carneiro ofereceu a ela "uma tela grande e ferramentas</segment>
    <segment id="93">para que</segment>
    <segment id="94">para que eu pudesse xilografar minha história".</segment>
    <segment id="95">Outras crônicas de "Exuzilhar"</segment>
    <segment id="96">trazem os orixás</segment>
    <segment id="97">, como</segment>
    <segment id="98">como Ogum</segment>
    <segment id="99">, Iansã e Oxum</segment>
    <segment id="100">, para o primeiro plano.</segment>
    <segment id="101">No entanto</segment>
    <segment id="102">, o leitor não deve esperar neste e em outros livros de Silva textos de introdução a essas divindades —sua literatura não busca o didatismo.</segment>
    <segment id="103">&amp;#</segment>
    <segment id="104">039;Contos dos Orixás&amp;#039</segment>
    <segment id="105">; transforma entidades em super-heróisMais    novamente         de   de  de  representando um  "</segment>
    <segment id="106">Meu interesse maior é construir mundos a partir das águas das africanidades e colocá-los para jogo</segment>
    <segment id="107">, em interação ou em confronto com as referências de quem me lê"</segment>
    <segment id="108">, afirma a escritora.</segment>
    <segment id="109">Chama a atenção</segment>
    <segment id="110">, por exemplo</segment>
    <segment id="111">, a forma</segment>
    <segment id="112">comocomo ela fala sobre Xangô</segment>
    <segment id="113">, conhecido por empunhar um machado de dois gumes.</segment>
    <segment id="114">No diálogo entre a umbanda e o catolicismo</segment>
    <segment id="115">, capítulo importante do sincretismo no Brasil</segment>
    <segment id="116">, esse orixá</segment>
    <segment id="117">, associado à justiça e ao fogo</segment>
    <segment id="118">, corresponde a são Jerônimo.</segment>
    <segment id="119">"</segment>
    <segment id="120">Xangô não sabe escrever um nome na areia</segment>
    <segment id="121">, esculpe-o na pedra.</segment>
    <segment id="122">Seu consolo é saber que a pedra um dia foi água e a natureza das coisas permanece</segment>
    <segment id="123">, mesmo quando muda de forma".  ​Exuzilhar Preço R$ 37Autor</segment>
    <segment id="124">Cidinha da SilvaEditora Pallas (88 págs.)</segment>
  </rst>
</analysis>