  <rst>
    <segment id="1">O fotógrafo Ian Cheibub apresenta sua primeira exposição individual</segment>
    <segment id="2">, este mês</segment>
    <segment id="3">, no Rio de Janeiro.</segment>
    <segment id="4">Ele foi o vencedor do prêmio Revelação: Leitura de Portfólio de 2022</segment>
    <segment id="5">, dado pelo FotoRio.</segment>
    <segment id="6">Fotografia de Ian Cheibub</segment>
    <segment id="7">, que registra a rotina no terreiro de umbanda chefiado por sua avó - Ian Cheibub/DivulgaçãoA obra de Cheibub está em cartaz na exposição "E</segment>
    <segment id="8">, no Entanto</segment>
    <segment id="9">, Aqui Estamos"</segment>
    <segment id="10">, em que ele revela a rotina de um terreiro de umbanda chefiado por sua avó.</segment>
    <segment id="11">As imagens estão em exibição até o dia 30 de novembro</segment>
    <segment id="12">, na Casa da Escada Colorida</segment>
    <segment id="13">, r. Manuel Carneiro</segment>
    <segment id="14">, 18, no centro do Rio de Janeiro.</segment>
    <segment id="15">Para a produção das fotos</segment>
    <segment id="16">, Cheibub</segment>
    <segment id="17">, que também é ogã</segment>
    <segment id="18">, usa procedimentos fisicamente ligados ao tema que ele retrata.</segment>
    <segment id="19">Ele, por exemplo</segment>
    <segment id="20">, ganha os filmes fotográficos em ervas que são usadas em vários rituais realizados nos terreiros que ele retrata.</segment>
    <segment id="21">&amp;#039;E</segment>
    <segment id="22">, no Entanto</segment>
    <segment id="23">, Aqui Estamos&amp;#039</segment>
    <segment id="24">;, de Ian CheibubMais    novamente         de   de  de  representando um</segment>
    <segment id="25">Segundo a curadora Márcia Mello</segment>
    <segment id="26">, na exposição</segment>
    <segment id="27">, o fotógrafo "traduz vivências em imagens que dialogam com conteúdos do inconsciente".</segment>
    <segment id="28">"</segment>
    <segment id="29">Véus, sombras</segment>
    <segment id="30">, filtros de luz:</segment>
    <segment id="31">suas fotografias imprimem sensações</segment>
    <segment id="32">, alinhadas à recusa veemente do artista em produzir imagens de viés descritivo e estereotipado das cerimônias e atividades cotidianas nesse espaço sagrado.</segment>
    <segment id="33">"  No ano passado</segment>
    <segment id="34">, Cheibub também realizou um projeto em que lida com a fé.</segment>
    <segment id="35">Ele é autor do projeto fotográfico</segment>
    <segment id="36">"</segment>
    <segment id="37">Pastores do Brasil"</segment>
    <segment id="38">, em que retratou pluralidade evangélica no Brasil.</segment>
    <segment id="39">Pastores do Brasil</segment>
    <segment id="40">, de Ian CheibubMais    novamente         de   de  de  representando</segment>
    <segment id="41">um</segment>
  </rst>
