  <rst>
    <segment id="1">Afastado da TV desde o início da pandemia</segment>
    <segment id="2">, Chico Pinheiro</segment>
    <segment id="3">, 67 anos</segment>
    <segment id="4">, tomou a primeira dose da vacina contra a Covid-19 na sexta-feira (2)</segment>
    <segment id="5">, em uma unidade de atendimento montada ao pé da favela da Rocinha</segment>
    <segment id="6">, no Rio.</segment>
    <segment id="7">Vacinado 2  “Viva o SUS!</segment>
    <segment id="8">”, anunciou Pinheiro</segment>
    <segment id="9">, em vídeo gravado na ocasião.</segment>
    <segment id="10">“</segment>
    <segment id="11">Graças a Deus</segment>
    <segment id="12">, hoje é sexta-feira”</segment>
    <segment id="13">,</segment>
    <segment id="14">arrematou</segment>
    <segment id="15">, retomando seu bordão ao final de toda sexta no “Bom Dia Brasil”.</segment>
    <segment id="16">O jornalista tomará a segunda dose no final de abril</segment>
    <segment id="17">, e terá de aguardar mais um mês até voltar ao ar.</segment>
    <segment id="18">VENDE-SE  Amado Batista</segment>
    <segment id="19">, 70 anos</segment>
    <segment id="20">, está vendendo suas duas fazendas em Cocalinho (MT)</segment>
    <segment id="21">, por R$ 350 milhões.</segment>
    <segment id="22">A informação foi dada pelo UOL e confirmada pela coluna.</segment>
    <segment id="23">Os imóveis estão disponíveis por imobiliárias da região</segment>
    <segment id="24">, somando 35 mil hectares.</segment>
    <segment id="25">O pacote inclui 20 mil cabeças de gado</segment>
    <segment id="26">, caminhão</segment>
    <segment id="27">, tratores e retroescavadeira.</segment>
    <segment id="28">As propriedades possuem quatro pistas de pouso de avião.</segment>
    <segment id="29">Fazenda Amado Batista em Cocalinhos (MT) - Reprodução/ImovelwebDE VOLTA</segment>
    <segment id="30">Após meses em licença-maternidade e só 40 dias depois de ter dado à luz Zaya</segment>
    <segment id="31">, Simone</segment>
    <segment id="32">, da dupla com Simaria</segment>
    <segment id="33">, volta a fazer show neste domingo de Páscoa.</segment>
    <segment id="34">Ela se</segment>
    <segment id="35">se apresenta com a irmã em sistema de live</segment>
    <segment id="36">, sob o patrocínio de uma grande rede de roupas e transmissão pelo canal da dupla no YouTube.</segment>
    <segment id="37">Simone e sua filha</segment>
    <segment id="38">, Zaya - Instagram/simonesesTORCIDA</segment>
    <segment id="39">Diretamente de Paris</segment>
    <segment id="40">, onde mora com seu atual marido</segment>
    <segment id="41">, o francês Olivier Murguet</segment>
    <segment id="42">, e o filho</segment>
    <segment id="43">, Max, 13 anos</segment>
    <segment id="44">, Patrícia de Sabrit tem acompanhado o “BBB 21” pelas redes sociais.</segment>
    <segment id="45">E não esconde sua torcida por Fiuk</segment>
    <segment id="46">, que foi seu enteado pelos cinco meses em que ela foi casada com Fábio Jr.</segment>
    <segment id="47">, em 2001.</segment>
    <segment id="48">“</segment>
    <segment id="49">O Fiuk é um fofo”</segment>
    <segment id="50">, disse ela.</segment>
    <segment id="51">“Adoro!</segment>
    <segment id="52">Ele é muito querido e de uma essência incrível.</segment>
    <segment id="53">Ele realmente tem essa pureza.</segment>
    <segment id="54">Acho ele muito parecido com o pai em vários aspectos positivos.</segment>
    <segment id="55">”  Parte 3 - Momentos do BBB 21   novamente         de   de  de  representando um  É TEMPO DE SEMEAR  Garota-propaganda de uma joalheiria</segment>
    <segment id="56">, Gisele Bündchen rouba a atenção de pulseiras e afins ao posar aqui para o ensaio publicitário da marca.</segment>
    <segment id="57">Sempre focalizada com elegância</segment>
    <segment id="58">, a modelo gaúcha</segment>
    <segment id="59">, de reconhecimento mundial</segment>
    <segment id="60">, pode muito bem ilustrar os nossos votos de Boa Páscoa e a torcida por dias melhores.</segment>
    <segment id="61">Vontade de la por um mundo melhor não falta.</segment>
    <segment id="62">Afinal</segment>
    <segment id="63">, ao completar 40 anos</segment>
    <segment id="64">, a mulher do craque Tom Brady pediu de presente aos amigos o plantio de algumas árvores para “a mãe Terra”</segment>
    <segment id="65">, como</segment>
    <segment id="66">como diz.</segment>
    <segment id="67">E não é que isso</segment>
    <segment id="68">sese transformou em uma campanha que trouxe 260 mil novas árvores ao planeta?</segment>
    <segment id="69">Elas estão na área   novamente         de   de  de  representando um  IMPRESSO  Rick Martin movimentou sua página no Instagram ao exibir a nova tatuagem que toma sua canela e pé direitos.</segment>
    <segment id="70">“Tinta com movimento”</segment>
    <segment id="71">, escreveu o cantor na legenda</segment>
    <segment id="72">, acrescentando:</segment>
    <segment id="73">“</segment>
    <segment id="74">Sua vibe</segment>
    <segment id="75">, seu talento</segment>
    <segment id="76">, sua amizade.</segment>
    <segment id="77">Você é uma lenda”</segment>
    <segment id="78">, disse.</segment>
    <segment id="79">Roxx, famosa tatuadora de Los Angeles (EUA)</segment>
    <segment id="80">, reagiu a Martin: “</segment>
    <segment id="81">Para um humano lindo</segment>
    <segment id="82">, obrigado por tudo que você faz por nós na comunidade LGBTQ+”.</segment>
    <segment id="83">Rick Martin apresenta nova tatuagem - @rickmartin no InstagramFRASE   "</segment>
    <segment id="84">Querem fazer um Pix solidário no Corinthians.</segment>
    <segment id="85">Vocês estão de sacanagem!</segment>
    <segment id="86">Os dirigentes arrebentam com o clube e querem que o torcedor pague a conta dos caras?</segment>
    <segment id="87">Neto, na Band</segment>
    <segment id="88">, sobre a dívida da Arena</segment>
    <segment id="89">Neo Química</segment>
  </rst>
