  <rst>
    <segment id="1">Aqui, no meio do Deserto do Saara</segment>
    <segment id="2">, passa um filme na minha cabeça</segment>
    <segment id="3">, sobre quando iniciei a minha jornada pelo mundo.</segment>
    <segment id="4">O ano era 2009.</segment>
    <segment id="5">Uma universitária curiosa pelos lugares</segment>
    <segment id="6">, além do Brasil.</segment>
    <segment id="7">Em 2011</segment>
    <segment id="8">, estava</segment>
    <segment id="9">, eu, sem menos esperar</segment>
    <segment id="10">, organizando uma viagem com minha prima para a África do Sul — na época em que o mundo da internet e smartphone estava em ascensão.</segment>
    <segment id="11">Era a revolução</segment>
    <segment id="12">, masmas sem muitas informações de destinos e roteiros.</segment>
    <segment id="13">Era uma época em que viajar era considerado algo de luxo</segment>
    <segment id="14">, em que parecia ser algo bem distante de pessoas que vieram de um contexto social</segment>
    <segment id="15">, financeiro</segment>
    <segment id="16">, de raça e de gênero excludente.</segment>
    <segment id="17">Além da minha história</segment>
    <segment id="18">, viajar pelo mundo e de uma forma intensa desde 2017</segment>
    <segment id="19">, a internet me possibilitou ser notada</segment>
    <segment id="20">, porém</segment>
    <segment id="21">porém não vista.</segment>
    <segment id="22">Fui notada por mulheres negras e pessoas que vivem no meu ciclo de amizades e familiares</segment>
    <segment id="23">comocomo viajante.</segment>
    <segment id="24">Ali estava</segment>
    <segment id="25">sese consolidando ser uma referência: a viajante negra!</segment>
    <segment id="26">Assim eu era apresentada nos espaços.</segment>
    <segment id="27">Viajar enquanto mulher negra sozinha era</segment>
    <segment id="28">, sim, uma exceção</segment>
    <segment id="29">, masmas nunca uma raridade.</segment>
    <segment id="30">No Lago Issyk-Kul</segment>
    <segment id="31">, no Quirquistão</segment>
    <segment id="32">, encontrei uma mulher negra viajando</segment>
    <segment id="33">, me fazendo brotar um sorriso!</segment>
    <segment id="34">No universo das redes sociais</segment>
    <segment id="35">, também via outras mulheres</segment>
    <segment id="36">comocomo eu inspirando viajar —</segment>
    <segment id="37">porémporém</segment>
    <segment id="38">, mais uma vez</segment>
    <segment id="39">, uma raridade.</segment>
    <segment id="40">Em 2018</segment>
    <segment id="41">, quando muitas mulheres começaram a ter visibilidade e compartilhar suas plataformas</segment>
    <segment id="42">, negócios</segment>
    <segment id="43">, era notório um universo desigual quando o assunto era viagem e mulheres negras.</segment>
    <segment id="44">Desigual no sentido de abertura</segment>
    <segment id="45">, visibilidade</segment>
    <segment id="46">, números de viagens realizadas</segment>
    <segment id="47">, locais</segment>
    <segment id="48">, questões financeiras</segment>
    <segment id="49">, nível de escolaridade e</segment>
    <segment id="50">, lógico</segment>
    <segment id="51">, cor da pele.</segment>
    <segment id="52">Mulheres viajantes</segment>
    <segment id="53">No Deserto do Saara</segment>
    <segment id="54">, a influenciadora digital Rebecca Aletheia reflete sobre sua trajetória de viajante - divulgação</segment>
    <segment id="55">Após muitos encontros presenciais e virtuais</segment>
    <segment id="56">, muitas mulheres negras não tinham voz em um diálogo</segment>
    <segment id="57">, sendo atropeladas pela entrevistadora</segment>
    <segment id="58">, colocando mais sobre o seu do que o meu.</segment>
    <segment id="59">Recordo de um</segment>
    <segment id="60">casocaso</segment>
    <segment id="61">, em que aconteceria uma live e</segment>
    <segment id="62">, no lugar da foto da entrevistada negra</segment>
    <segment id="63">, foi divulgada uma foto de uma mulher não brasileira.</segment>
    <segment id="64">Ao ser questionado pelo coletivo</segment>
    <segment id="65">, a empresa alegou que era pelo fato da viajante não ter foto no perfil da rede social com a paleta de cores da plataforma.</segment>
    <segment id="66">Vale ressaltar que nunca perguntaram para a mesma</segment>
    <segment id="67">sese ela tinha.</segment>
    <segment id="68">Um outro</segment>
    <segment id="69">casocaso foi quando uma entrevistadora perguntava a todo momento sobre viagens ao exterior</segment>
    <segment id="70">, principalmente a Europa</segment>
    <segment id="71">, quando a entrevistada queria muito falar sobre o Brasil —ou seja</segment>
    <segment id="72">, a todo momento era enaltecido "o fora"</segment>
    <segment id="73">, ou como</segment>
    <segment id="74">como se</segment>
    <segment id="75">se a viajante só ganhasse esse título</segment>
    <segment id="76">sese fosse ao exterior.</segment>
    <segment id="77">Mulheres negras viajantes</segment>
    <segment id="78">Grupos de mulheres negras não são novidade!</segment>
    <segment id="79">Temos grandes e brilhantes exemplos dos EUA e Reino Unido.</segment>
    <segment id="80">Movimentos inspiradores.</segment>
    <segment id="81">Porém, temos duas barreiras que nos distanciam: a língua inglesa e a moeda estrangeira.</segment>
    <segment id="82">Viver nos EUA ou na Europa pode ser menos difícil para percorrer e viajar o mundo.</segment>
    <segment id="83">E, quanto a nós</segment>
    <segment id="84">, mulheres negras viajantes das Américas do Sul e global</segment>
    <segment id="85">, onde ficamos?</segment>
    <segment id="86">Como diz Lélia Gonzalez</segment>
    <segment id="87">, nossa pensadora referência quando o assunto é amefricanidade</segment>
    <segment id="88">, somos tão similares quando o assunto é Américas.</segment>
    <segment id="89">Bitonga Travel</segment>
    <segment id="90">Entendendo a nossa amefricanidade e reconhecendo nossas irmãs da América do Sul e Caribe</segment>
    <segment id="91">, o coletivo Bitonga Travel tem esse enfoque que vai além de mulheres brasileiras.</segment>
    <segment id="92">Dá visibilidade à mulheres negras e</segment>
    <segment id="93">, desde dezembro de 2018</segment>
    <segment id="94">, conta com mulheres do Peru</segment>
    <segment id="95">, Colômbia</segment>
    <segment id="96">, República Dominicana.</segment>
    <segment id="97">Foi visto</segment>
    <segment id="98">comocomo ponte por mulheres africanas de países lusófonos</segment>
    <segment id="99">comocomo Moçambique</segment>
    <segment id="100">, Angola e Cabo Verde.</segment>
    <segment id="101">Aqui no Brasil</segment>
    <segment id="102">, o coletivo conta com mulheres de todos os estados</segment>
    <segment id="103">, tendo elas de 18 a 70 anos.</segment>
    <segment id="104">O coletivo</segment>
    <segment id="105">, além de potencializar empreendedorismo de pessoas pretas do turismo</segment>
    <segment id="106">, também dá asas</segment>
    <segment id="107">para que</segment>
    <segment id="108">para que mais mulheres conheçam suas histórias</segment>
    <segment id="109">, criando redes afetivas que vão além de viagens.</segment>
    <segment id="110">O objetivo é fazer com que mais mulheres negras viajem sozinhas e de forma autônoma.</segment>
    <segment id="111">Sabemos que a violência contra mulheres</segment>
    <segment id="112">, sexismo e feminicídio no Brasil são elevados e</segment>
    <segment id="113">, infelizmente</segment>
    <segment id="114">, as políticas públicas não nos protegem.</segment>
    <segment id="115">Para nos sentirmos mais seguras de uma sociedade racista</segment>
    <segment id="116">, realizamos viagens coletivas com mulheres negras</segment>
    <segment id="117">, propiciando o empoderamento por meio do pertencimento ao redor do Brasil e do mundo.</segment>
    <segment id="118">Encontros e conexões</segment>
    <segment id="119">Mulheres negras viajam juntas pela Colômbia em grupo organizado por Rebecca Aletheia - Alejofilms/Divulgação</segment>
    <segment id="120">Ao longo da minha jornada de viajante tenho percebido o quanto tenho potencializado mulheres negras e o afroempreendedorismo.</segment>
    <segment id="121">Uma das atividades que mais me orgulho é pensar que</segment>
    <segment id="122">, de maneira incontável</segment>
    <segment id="123">, mulheres negras foram impactadas com o movimento de mulheres negras viajantes e com Rebecca Aletheia.</segment>
    <segment id="124">Esse movimento vem ganhando forma com encontros no mundo virtual em âmbito nacional e internacional.</segment>
    <segment id="125">Quando estou presente muitas pessoas aparecem</segment>
    <segment id="126">, pois</segment>
    <segment id="127">pois se</segment>
    <segment id="128">se inspiram na forma que viajo: imersiva e espontânea.</segment>
    <segment id="129">Uma vida real de viajante</segment>
    <segment id="130">, que durante a semana economiza os centavos</segment>
    <segment id="131">, vai trabalhar de bicicleta</segment>
    <segment id="132">, leva lanche para o trabalho</segment>
    <segment id="133">, ou vice-e-versa</segment>
    <segment id="134">, e sempre que preciso for está luxando.</segment>
    <segment id="135">Considero as minhas viagens únicas e</segment>
    <segment id="136">, por isso</segment>
    <segment id="137">, entendo que muitas mulheres negras têm feito movimento de viajarem comigo</segment>
    <segment id="138">, já que mostro na prática sobre a possibilidade de poder.</segment>
    <segment id="139">Será realmente que não tem espaço para mulheres brancas e homens?</segment>
    <segment id="140">Não é sobre espaço</segment>
    <segment id="141">, a ideia é que também possamos formar possibilidades de poder construir uma sociedade que saiba nos respeitar enquanto mulheres e pretas.</segment>
    <segment id="142">No processo de um mundo melhor</segment>
    <segment id="143">, eu, Rebecca Aletheia</segment>
    <segment id="144">, estou disposta a mostrar que precisamos mudar.</segment>
    <segment id="145">Nesse momento</segment>
    <segment id="146">, o que temos feito é nos acolher e</segment>
    <segment id="147">, quando sairmos para viajar</segment>
    <segment id="148">, o mundo precisa estar preparado</segment>
    <segment id="149">para que</segment>
    <segment id="150">para que possamos viver em harmonia.</segment>
    <segment id="151">Posso contar contigo?</segment>
  </rst>
</analysis>