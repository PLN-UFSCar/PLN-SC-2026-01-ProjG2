  <rst>
    <segment id="1">O físico brasileiro Anderson Gomes</segment>
    <segment id="2">, da UFPE (Universidade Federal de Pernambuco)</segment>
    <segment id="3">, não se</segment>
    <segment id="4">se surpreendeu muito ao saber que sua antiga colega</segment>
    <segment id="5">, a francesa Anne L’Huillier</segment>
    <segment id="6">, tinha sido agraciada com o Prêmio Nobel de sua área em 2023.</segment>
    <segment id="7">"</segment>
    <segment id="8">Quando olho para trás</segment>
    <segment id="9">, fica claro que ela já sabia muito bem aonde queria chegar —não no sentido de ser uma ganhadora do Nobel</segment>
    <segment id="10">, porque</segment>
    <segment id="11">porque isso é muito difícil de planejar</segment>
    <segment id="12">, masmas na determinação de dominar profundamente aquela área"</segment>
    <segment id="13">, diz Gomes</segment>
    <segment id="14">, que trabalhou com Anne e publicou alguns estudos em parceria com ela entre o fim dos anos 1980 e começo dos anos 1990.</segment>
    <segment id="15">Foi justamente o período em que a pesquisadora estava começando a dominar a técnica que acabaria por lhe render a láurea neste ano.</segment>
    <segment id="16">A física Anne L&amp;#039</segment>
    <segment id="17">;Huillier</segment>
    <segment id="18">, pesquisadora da Universidade de Lund</segment>
    <segment id="19">, na Suécia</segment>
    <segment id="20">, foi uma das ganhadoras do Nobel de física deste ano - TT News Agency/Andreas Hillergren via ReutersGomes e L’Huillier conviveram no Centro de Pesquisa Nuclear Paris-Saclay</segment>
    <segment id="21">, instituição onde a pesquisadora trabalhava antes de</segment>
    <segment id="22">sese transferir para a Universidade de Lund</segment>
    <segment id="23">, na Suécia</segment>
    <segment id="24">, onde está até hoje.</segment>
    <segment id="25">"</segment>
    <segment id="26">Ela já tinha concluído o doutorado.</segment>
    <segment id="27">Era física teórica</segment>
    <segment id="28">, masmas queria aprender o máximo possível das técnicas de laboratório.</segment>
    <segment id="29">Como eu trabalhava com lasers e passava o tempo todo no laboratório</segment>
    <segment id="30">, nós nos encontrávamos com frequência por lá"</segment>
    <segment id="31">, diz o físico.</segment>
    <segment id="32">Ele conta que L’Huillier o ajudou</segment>
    <segment id="33">, inclusive</segment>
    <segment id="34">, a driblar a burocracia para continuar trabalhando.</segment>
    <segment id="35">"</segment>
    <segment id="36">As regras do centro de pesquisa estabeleciam horário certo para entrar e sair</segment>
    <segment id="37">, e ninguém trabalhava em feriados.</segment>
    <segment id="38">Um desses feriados ia cair numa sexta-feira</segment>
    <segment id="39">, masmas ela conversou com o diretor</segment>
    <segment id="40">para que</segment>
    <segment id="41">para que ele abrisse uma exceção</segment>
    <segment id="42">, permitindo que a gente trabalhasse durante o fim de semana nos experimentos.</segment>
    <segment id="43">"</segment>
    <segment id="44">O professor de física Anderson Gomes</segment>
    <segment id="45">, da Universidade Federal de Pernambuco</segment>
    <segment id="46">, que foi colega de laboratório da francesa Anne L’Huillier</segment>
    <segment id="47">, ganhadora do Nobel - Divulgação/UFPESegundo o físico</segment>
    <segment id="48">, que também é membro da Academia Brasileira de Ciências</segment>
    <segment id="49">, laboratórios nacionais também têm potencial para fazer medições do comportamento de partículas na escala dos attosegundos (quintilionésimos de segundo)</segment>
    <segment id="50">, façanha que</segment>
    <segment id="51">sese tornou possível graças aos trabalhos da francesa e dos outros ganhadores do Nobel da área neste ano.</segment>
    <segment id="52">"</segment>
    <segment id="53">Olhando para o Brasil</segment>
    <segment id="54">, por que não temos premiações semelhantes?</segment>
    <segment id="55">Não é falta de competência nem de conhecimento"</segment>
    <segment id="56">, pondera ele.</segment>
    <segment id="57">"</segment>
    <segment id="58">O que faz diferença é o planejamento e a continuidade.</segment>
    <segment id="59">Ela continua batalhando nisso sem parar desde os anos 1980.</segment>
    <segment id="60">Não é algo que você consegue fazer florescer em um</segment>
    <segment id="61">, dois</segment>
    <segment id="62">, três anos.</segment>
    <segment id="63">Essa constância</segment>
    <segment id="64">, com investimento em pessoas</segment>
    <segment id="65">, precisa</segment>
    <segment id="66">sese manter independentemente de mudanças de governantes.</segment>
    <segment id="67">"</segment>
    <segment id="68">Saiba tudo sobre o Prêmio NobelMais    novamente         de   de  de  representando</segment>
    <segment id="69">um</segment>
  </rst>
</analysis>