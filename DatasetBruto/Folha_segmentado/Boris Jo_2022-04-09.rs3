  <rst>
    <segment id="1">O premiê britânico</segment>
    <segment id="2">, Boris Johnson</segment>
    <segment id="3">, fez neste sábado (9) uma visita surpresa à Ucrânia</segment>
    <segment id="4">, durante a qual</segment>
    <segment id="5">sese reuniu em Kiev com Volodimir Zelenski.</segment>
    <segment id="6">A visita de Boris é "um gesto de solidariedade ao povo ucraniano" e foi realizada para "apresentar um novo pacote de ajuda financeira e militar"</segment>
    <segment id="7">, afirmou Downing Street.</segment>
    <segment id="8">A visita encerra semanas de lobby de Boris para encontrar o presidente do país ora invadido.</segment>
    <segment id="9">Os líderes têm conversado quase todos os dias desde o início da guerra</segment>
    <segment id="10">, segundo assessores do premiê britânico.</segment>
    <segment id="11">O premiê britânico</segment>
    <segment id="12">, Boris Johnson</segment>
    <segment id="13">, reúne-</segment>
    <segment id="14">sese com o presidente ucraniano</segment>
    <segment id="15">, Volodimir Zelenski</segment>
    <segment id="16">, em Kiev - Presidência da Ucrânia via ReutersNuma entrevista coletiva lado a lado</segment>
    <segment id="17">, com as bandeiras dos dois países ao fundo</segment>
    <segment id="18">, os líderes</segment>
    <segment id="19">sese elogiaram pela cooperação desde que a Rússia invadiu a Ucrânia</segment>
    <segment id="20">, em 24 de fevereiro.</segment>
    <segment id="21">O líder britânico tem sido um dos apoiadores mais vocais da Ucrânia em meio ao conflito.</segment>
    <segment id="22">Junto a outros países do Ocidente</segment>
    <segment id="23">, o Reino Unido lidera o esforço para enviar armas a Kiev e impor sanções contra Moscou —neste sábado</segment>
    <segment id="24">, Boris prometeu 120 veículos blindados e novos sistemas de mísseis antinavio.    "</segment>
    <segment id="25">Outros estados democráticos ocidentais deveriam seguir o exemplo"</segment>
    <segment id="26">, disse Zelenski</segment>
    <segment id="27">, acrescentando que é hora de os países imporem uma proibição completa do fornecimento de energia russo.  Guerra na UcrâniaO boletim diário para você entender o que acontece na guerra entre Rússia e UcrâniaCarregando...</segment>
    <segment id="28">Boris respondeu que</segment>
    <segment id="29">, junto a seus aliados</segment>
    <segment id="30">, aumentará a pressão econômica sobre a Rússia</segment>
    <segment id="31">, com novas sanções semana a semana.</segment>
    <segment id="32">Além das punições aos oligarcas russos e do congelamento de ativos bancários</segment>
    <segment id="33">, outra medida a ser adotada é abandonar o uso de hidrocarbonetos russos</segment>
    <segment id="34">, segundo o premiê.</segment>
    <segment id="35">A declaração é cômoda para Boris</segment>
    <segment id="36">, porque</segment>
    <segment id="37">porque</segment>
    <segment id="38">, segundo o governo britânico</segment>
    <segment id="39">, menos de 4% do produto usado no Reino Unido vem de Moscou</segment>
    <segment id="40">, diferentemente da Alemanha</segment>
    <segment id="41">, por exemplo</segment>
    <segment id="42">, cujo nível vai a 40%.</segment>
    <segment id="43">O apoio do primeiro-ministro visa a garantir que "a Ucrânia nunca mais seja intimidada</segment>
    <segment id="44">, nunca mais seja chantageada</segment>
    <segment id="45">, nunca mais seja ameaçada da mesma maneira"</segment>
    <segment id="46">, disse Boris.</segment>
    <segment id="47">Os corpos de civis mortos nas ruas de Bucha</segment>
    <segment id="48">, acrescentou</segment>
    <segment id="49">, mancharam permanentemente a reputação de Vladimir Putin.</segment>
    <segment id="50">Como foi a visita surpresa de Boris Johnson a ZelenskiMais    novamente         de   de  de  representando um  Depois de falarem com a imprensa</segment>
    <segment id="51">, os líderes andaram pelas ruas de Kiev.</segment>
    <segment id="52">Sempre acompanhado de Zelenski e de homens fazendo a escolta</segment>
    <segment id="53">, Boris</segment>
    <segment id="54">, sem colete a prova de balas</segment>
    <segment id="55">, conversou com moradores</segment>
    <segment id="56">, visitou um monumento aos mortos durante os protestos pró-União Europeia em 2014 e ganhou um galo de cerâmica de uma mulher</segment>
    <segment id="57">, encontrado entre os escombros de um prédio destruído em Borodianka.</segment>
    <segment id="58">Na sexta-feira (8)</segment>
    <segment id="59">, a presidente da Comissão Europeia</segment>
    <segment id="60">, Ursula Von der Leyen</segment>
    <segment id="61">, e o chefe das relações exteriores da União Europeia</segment>
    <segment id="62">, Josep Borrel</segment>
    <segment id="63">, visitaram a cidade de Butcha</segment>
    <segment id="64">, nos arredores da capital</segment>
    <segment id="65">, onde foram descobertos corpos nas ruas e em valas comuns após a retirada de tropas russas.</segment>
    <segment id="66">Em 15 de março</segment>
    <segment id="67">, os líderes de Polônia</segment>
    <segment id="68">, República Tcheca e Eslovênia também</segment>
    <segment id="69">sese reuniram com Zelenski em Kiev.</segment>
  </rst>
</analysis>