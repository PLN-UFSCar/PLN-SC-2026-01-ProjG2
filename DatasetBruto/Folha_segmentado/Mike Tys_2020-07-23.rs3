  <rst>
    <segment id="1">O ex-campeão mundial de boxe Mike Tyson</segment>
    <segment id="2">, 54, anunciou nesta quinta-feira (23) que retornará aos ringues para uma luta de exibição contra Roy Jones Jr.</segment>
    <segment id="3">, 51.</segment>
    <segment id="4">O combate entre os dois americanos está marcado para o dia 12 de setembro</segment>
    <segment id="5">, em Los Angeles.</segment>
    <segment id="6">Não há informações sobre a possibilidade de a Dignity Health Sports Arena</segment>
    <segment id="7">, local escolhido para a luta</segment>
    <segment id="8">, receber público.</segment>
    <segment id="9">"</segment>
    <segment id="10">Eu estou de volta"</segment>
    <segment id="11">, escreveu Tyson em seu Twitter.</segment>
    <segment id="12">Há semanas</segment>
    <segment id="13">, ele tem publicado nas redes sociais vídeos dos seus treinamentos para o retorno.</segment>
    <segment id="14">A bem-sucedida campanha de marketing mobilizou atenções da imprensa internacional</segment>
    <segment id="15">, masmas muitos já</segment>
    <segment id="16">sese questionavam</segment>
    <segment id="17">sese o pugilista realmente pretendia voltar.</segment>
    <segment id="18">A resposta veio com a confirmação do duelo em setembro.</segment>
    <segment id="19">A última luta</segment>
    <segment id="20">comocomo profissional do ex-campeão do peso-pesado</segment>
    <segment id="21">, ícone do esporte nos anos 1980 e 1990</segment>
    <segment id="22">, foi há 15 anos</segment>
    <segment id="23">, quando perdeu para o irlandês Kevin McBride.</segment>
    <segment id="24">Tyson venceu 50 combates na carreira (44 por nocaute) e perdeu 6.</segment>
    <segment id="25">Jones Jr. também carrega um currículo de peso.</segment>
    <segment id="26">Foi campeão mundial em quatro categorias</segment>
    <segment id="27">, de 1993 a 2004</segment>
    <segment id="28">, inclusive dos pesados.</segment>
    <segment id="29">Sua última luta ocorreu em 2018.</segment>
    <segment id="30">O cartel do americano tem 66 vitórias (47 por nocaute) e 9 derrotas.</segment>
    <segment id="31">Também foi medalhista olímpico nos Jogos de Seul-1988</segment>
    <segment id="32">, quando ficou com a prata.</segment>
    <segment id="33">Mike Tyson antes de luta que acompanhou em Las Vegas</segment>
    <segment id="34">, em fevereiro deste ano - Steve Marcus - 22.fev.20/Reuters</segment>
  </rst>
</analysis>