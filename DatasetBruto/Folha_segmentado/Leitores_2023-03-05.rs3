  <rst>
    <segment id="1">Batalha dos chips Excelente texto ("Brasil é uma das novas frentes na guerra dos chips entre EUA e China"</segment>
    <segment id="2">, Mundo</segment>
    <segment id="3">, 5/3)!</segment>
    <segment id="4">Mostra</segment>
    <segment id="5">comocomo as "potências" mexem suas peças no tabuleiro de xadrez do mercado de desenvolvimento no mundo.</segment>
    <segment id="6">E as dificuldades dos "peões" da indústria para administrarem o cabo de guerra entre elas.</segment>
    <segment id="7">Tais de Moraes Cavalheiro (São Paulo</segment>
    <segment id="8">, SP)  Falta de semicondutores afeta indústria de automóveis e eletrônicosMais    novamente         de   de  de  representando um  </segment>
    <segment id="9">Belo texto!</segment>
    <segment id="10">Pesquisa perfeita!</segment>
    <segment id="11">Já perdemos a oportunidade</segment>
    <segment id="12">, e o bonde já</segment>
    <segment id="13">sese foi...</segment>
    <segment id="14">Que tal pensar em outras áreas nas quais estamos mais ou menos bem?</segment>
    <segment id="15">Vamos entrar nesta para daqui a 10 ou 15 anos conseguirmos fabricar um chip básico?</segment>
    <segment id="16">E os outros fabricantes vão nos "esperar"?</segment>
    <segment id="17">Paulo Edson Mazzei (Sertãozinho</segment>
    <segment id="18">, SP) * Fica demonstrado que os EUA atuam no mundo todo de maneira beligerante e contrariando as regras da OMC.</segment>
    <segment id="19">Não devemos nos submeter a imposições ilícitas</segment>
    <segment id="20">comocomo as apontadas na reportagem.</segment>
    <segment id="21">Emanoel Tavares Costa (Marília</segment>
    <segment id="22">, SP)   Joias da Michelle</segment>
    <segment id="23">Esse lamentável evento com as joias da Michelle Bolsonaro demonstra a importância da estabilidade funcional dos servidores públicos</segment>
    <segment id="24">, que Paulo Guedes tanto queria abolir na reforma administrativa.</segment>
    <segment id="25">Um auditor da Receita Federal peitou não um</segment>
    <segment id="26">, masmas três pedidos —e até da Presidência— na defesa da legalidade ("Governo Bolsonaro tentou trazer ilegalmente joias de R$ 16</segment>
    <segment id="27">,5 mi para Michelle</segment>
    <segment id="28">, diz jornal"</segment>
    <segment id="29">, Política</segment>
    <segment id="30">, 4/3).</segment>
    <segment id="31">Ninguém acima da lei.</segment>
    <segment id="32">Mauricio de Oliveira e Silva (Salvador</segment>
    <segment id="33">, BA)</segment>
    <segment id="34">O deputado Paulo Pimenta postou em rede social</segment>
    <segment id="35">, colar e brincos de diamante</segment>
    <segment id="36">, no valor de R$ 16</segment>
    <segment id="37">,5 milhões</segment>
    <segment id="38">, alegando que Jair Bolsonaro tentou trazê-los ilegalmente para Michelle Bolsonaro -@Pimenta13Br  Precisa investigar a organização desses roteiros</segment>
    <segment id="39">, por que este destino</segment>
    <segment id="40">, e não outros ("Recibo mostra que outro pacote de joias enviado por sauditas a Bolsonaro foi entregue à Presidência"</segment>
    <segment id="41">, Política</segment>
    <segment id="42">, 5/3)?</segment>
    <segment id="43">O que fazia o clã em viagens rotineiras montado em tapetes mágicos</segment>
    <segment id="44">, bancado pelo dinheiro público?</segment>
    <segment id="45">Clã e seu cabeça foram às arábias</segment>
    <segment id="46">comocomo nós atravessamos a ponte</segment>
    <segment id="47">, sempre com comitiva de aproveitadores.</segment>
    <segment id="48">Elisabeth Schmidt (Cachoeira do Sul</segment>
    <segment id="49">, RS)</segment>
    <segment id="50">Uso político da Receita Federal</segment>
    <segment id="51">Agora sabemos o motivo do apoio incondicional a Bolsonaro pelos pastores adoradores de dízimo.</segment>
    <segment id="52">A Receita deve ser independente</segment>
    <segment id="53">, não puxadinho de políticos corruptos para brindar asseclas e chantagear desafetos ("Receita Federal beneficiou aliados e blindou familiares em 4 anos de Bolsonaro"</segment>
    <segment id="54">, Política</segment>
    <segment id="55">, 4/3).</segment>
    <segment id="56">Luiz Bartolotti (Campos dos Goytacazes</segment>
    <segment id="57">, RJ)  Veja apuração da Receita que Flávio Bolsonaro pretendia usar para tentar anular</segment>
    <segment id="58">casocaso das rachadinhasMais    novamente         de   de  de  representando um</segment>
    <segment id="59">Sucessor de Augusto Aras Bolsonaro fez escola ("PT atacou Bolsonaro e exaltou lista tríplice agora rejeitada por Lula na PGR"</segment>
    <segment id="60">, Política</segment>
    <segment id="61">, 4/3).</segment>
    <segment id="62">Se fazendo tudo o que fez</segment>
    <segment id="63">, nada aconteceu com Bolsonaro</segment>
    <segment id="64">, por que Lula teria que ter receio de qualquer medida para as coisas ficarem</segment>
    <segment id="65">comocomo ele quer que fiquem?</segment>
    <segment id="66">Se a lista tríplice é só sugestão</segment>
    <segment id="67">, e não é obrigado a seguir</segment>
    <segment id="68">, que faça o que tem direito de fazer.</segment>
    <segment id="69">Lula não pode confiar em quem não conhece.</segment>
    <segment id="70">Joaldo Costa (Chapecó</segment>
    <segment id="71">, SC)  Augusto Aras</segment>
    <segment id="72">, procurador-geral da RepúblicaMais    novamente         de   de  de  representando um   Paulo Caruso</segment>
    <segment id="73">Que tristeza ("Morre Paulo Caruso</segment>
    <segment id="74">, um dos maiores cartunistas brasileiros</segment>
    <segment id="75">, aos 73 anos"</segment>
    <segment id="76">, Ilustrada).</segment>
    <segment id="77">O Brasil fica mais pobre culturalmente.</segment>
    <segment id="78">Monique Rodrigues (Goiânia</segment>
    <segment id="79">, GO)  Veja fotos de Paulo Caruso</segment>
    <segment id="80">, um dos maiores cartunistas brasileiros</segment>
    <segment id="81">, morto neste sábado (4)Mais    novamente         de   de  de  representando um   Sueli Costa Mais uma joia preciosa da MPB que</segment>
    <segment id="82">sese vai ("Morre Sueli Costa</segment>
    <segment id="83">, que escreveu para Maria Bethânia e Elis Regina"</segment>
    <segment id="84">, Ilustrada</segment>
    <segment id="85">, 5/3).</segment>
    <segment id="86">Que continue viva através de suas lindas canções.</segment>
    <segment id="87">Marcia dos Santos P. Simon (Goiânia</segment>
    <segment id="88">, GO)</segment>
    <segment id="89">A cantora Sueli Costa no programa Um Cafe La</segment>
    <segment id="90">Em Casa- 5.mar.20/Um Cafe La</segment>
    <segment id="91">Em Casa no Youtube  Cerimônia de posse do escritor e jornalista Ruy Castro</segment>
    <segment id="92">, na Academia Brasileira de Letras - Tércio Teixeira/FolhapressImortal Adorei ver o Ruy Castro de fardão ("</segment>
    <segment id="93">Escritor e jornalista Ruy Castro toma posse na Academia Brasileira de Letras"</segment>
    <segment id="94">, Ilustrada</segment>
    <segment id="95">, 4/3)!</segment>
    <segment id="96">Lindo!</segment>
    <segment id="97">Jussara H. Beltreschi (Ribeirão Preto</segment>
    <segment id="98">, SP)  Confira fotos de Ruy CastroMais    novamente         de   de  de  representando um  </segment>
    <segment id="99">Parabenizo o magnífico Ruy Castro pela posse da cadeira nº 13 da Academia Brasileira de Letras.</segment>
    <segment id="100">Autor de memoriáveis páginas</segment>
    <segment id="101">, seja da música e da literatura</segment>
    <segment id="102">, seja da crônica e do memorialismo</segment>
    <segment id="103">, seja onde sua pena escreveu e escreverá.</segment>
    <segment id="104">Autor de leitura deliciosa</segment>
    <segment id="105">, acumulou cultura enorme e presenteou os leitores da Folha desde os "anos de chumbo".</segment>
    <segment id="106">Gesner Batista (Rio Claro</segment>
    <segment id="107">, SP)   Colunista Cristina Serra</segment>
    <segment id="108">, como</segment>
    <segment id="109">como seu fiel leitor</segment>
    <segment id="110">, este maestro deseja na sua nova empreitada o mesmo sucesso que teve na Folha ("Despedida"</segment>
    <segment id="111">, 4/3).</segment>
    <segment id="112">João Carlos Martins (São Paulo</segment>
    <segment id="113">, SP)   Humor x bala Assisti ao vídeo da Lívia</segment>
    <segment id="114">, ri muito e nem sabia que era sátira desse coach "famoso quem?</segment>
    <segment id="115">" ("‘</segment>
    <segment id="116">Se a arma dele é a bala</segment>
    <segment id="117">, a minha é o humor.</segment>
    <segment id="118">Eu não vou parar’</segment>
    <segment id="119">, diz Lívia La Gatto"</segment>
    <segment id="120">, Mônica Bergamo</segment>
    <segment id="121">, 5/30).</segment>
    <segment id="122">Se não tivesse armado todo esse mimimi</segment>
    <segment id="123">, nem saberia que ele diz essas coisas.</segment>
    <segment id="124">E é assim que as mulheres são colocadas: as loucas que levam as coisas para o lado errado.</segment>
    <segment id="125">Tatiana Bardassi (Ribeirão Preto</segment>
    <segment id="126">, SP)</segment>
    <segment id="127">Veja imagens da atriz e humorista Lívia La GattoMais    novamente         de   de  de  representando um   Telemedicina no SUS Espero que tenha no país todo ("Hospital público do Rio é o primeiro do país a oferecer consulta online a pacientes do SUS"</segment>
    <segment id="128">, Cotidiano).</segment>
    <segment id="129">Aparecida Alves (São Bernardo do Campo</segment>
    <segment id="130">, SP)</segment>
    <segment id="131">A psicóloga Luiny de Medeiros</segment>
    <segment id="132">, 26, conversa com a ginecologista Claudia Lunard (na tela) em simulação do uso do sistema no Centro de Teleconsulta do Hupe Digital</segment>
    <segment id="133">, no Rio de Janeiro   -Eduardo Anizelli/ Folhapress Desconfie!</segment>
