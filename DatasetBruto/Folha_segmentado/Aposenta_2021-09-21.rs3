  <rst>
    <segment id="1">A aposentada Maria Angela da Rocha Barros</segment>
    <segment id="2">, 71 anos</segment>
    <segment id="3">, da Chácara Santana</segment>
    <segment id="4">, Santo Amaro (zona sul)</segment>
    <segment id="5">, conta que</segment>
    <segment id="6">, em setembro do ano passado</segment>
    <segment id="7">, procurou a Caixa para fazer uma aplicação financeira.</segment>
    <segment id="8">Porém reclama que</segment>
    <segment id="9">, em vez de receber juros sobre o valor total</segment>
    <segment id="10">, foi informada de que</segment>
    <segment id="11">, sese retirar agora</segment>
    <segment id="12">, receberá menos do que o valor inicial.</segment>
    <segment id="13">A leitora afirma que</segment>
    <segment id="14">, no último dia 14 de setembro</segment>
    <segment id="15">, foi informada pelo gerente de sua agência que não rendeu nada de juros nesse período.</segment>
    <segment id="16">“Ele disse que</segment>
    <segment id="17">, para render alguma coisa</segment>
    <segment id="18">, eu teria que deixar meu dinheiro aplicado por mais 36 meses.</segment>
    <segment id="19">Achei um absurdo e não aceitei.</segment>
    <segment id="20">”</segment>
    <segment id="21">São Paulo (SP)</segment>
    <segment id="22">, 20/09/2021.</segment>
    <segment id="23">Defesa do Cidadão - Maria Angela da Rocha Barros reclama do atendimento da Caixa.</segment>
    <segment id="24">(Foto: Arquivo pessoal) - Arquivo pessoal</segment>
    <segment id="25">Maria Angela relata que</segment>
    <segment id="26">, à época</segment>
    <segment id="27">, solicitou ao gerente que fossem investidos R$ 30.100 disponíveis em sua conta-poupança em alguma aplicação que tivesse um retorno melhor.</segment>
    <segment id="28">“</segment>
    <segment id="29">O gerente fez uma simulação e disse que</segment>
    <segment id="30">, sese eu investisse os R$ 30.100</segment>
    <segment id="31">, além de R$ 100 por mês</segment>
    <segment id="32">, a partir de outubro de 2020</segment>
    <segment id="33">, após um ano</segment>
    <segment id="34">, eu receberia R$ 33.957</segment>
    <segment id="35">,72 se</segment>
    <segment id="36">se aplicasse na Caixa Previdência.</segment>
    <segment id="37">Ele deu até um papel</segment>
    <segment id="38">, masmas</segment>
    <segment id="39">, agora</segment>
    <segment id="40">, diz que</segment>
    <segment id="41">sese tratava apenas de uma simulação</segment>
    <segment id="42">, uma previsão.</segment>
    <segment id="43">Eles querem devolver apenas R$ 30.089.</segment>
    <segment id="44">”  Contudo</segment>
    <segment id="45">, afirma</segment>
    <segment id="46">, não foi dito que seria uma possibilidade de lucro.</segment>
    <segment id="47">“Deveriam ser</segment>
    <segment id="48">, pelo menos</segment>
    <segment id="49">, mais claros e objetivos.</segment>
    <segment id="50">Agora colocam a culpa na pandemia</segment>
    <segment id="51">, no mercado financeiro.</segment>
    <segment id="52">”</segment>
    <segment id="53">A aposentada solicitou a transferência do valor para outro banco.</segment>
    <segment id="54">“Estou aguardando que efetivem essa transação.</segment>
    <segment id="55">Estou me sentindo lesada</segment>
    <segment id="56">, pois</segment>
    <segment id="57">pois fizeram uma propaganda enganosa.</segment>
    <segment id="58">Exijo ser ressarcida com o valor que consta no contrato.</segment>
    <segment id="59">”  Reclamações - Veja</segment>
    <segment id="60">comocomo fazer Mais    novamente         de   de  de  representando um    Instituição entra em contato</segment>
    <segment id="61">A Caixa informa</segment>
    <segment id="62">, por meio de nota de sua assessoria de imprensa</segment>
    <segment id="63">, que já entrou em contato com a cliente e prestou todos os esclarecimentos necessários.</segment>
    <segment id="64">A instituição diz ainda que</segment>
    <segment id="65">, em respeito ao sigilo bancário</segment>
    <segment id="66">, os dados foram repassados diretamente para a cliente.</segment>
    <segment id="67">Em novo contato com o Agora</segment>
    <segment id="68">, a leitora disse que realizará a transferência para outro banco.</segment>
    <segment id="69">“</segment>
    <segment id="70">Mantiveram a questão de que teria que deixar o valor aplicado por 36 meses.</segment>
    <segment id="71">É um absurdo”</segment>
    <segment id="72">, afirmou Maria Angela.</segment>
  </rst>
</analysis>