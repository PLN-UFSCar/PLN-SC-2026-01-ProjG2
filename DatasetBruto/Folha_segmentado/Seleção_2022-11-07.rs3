  <rst>
    <segment id="1">A CBF divulgou nesta segunda-feira (7) a numeração dos jogadores da seleção brasileira na Copa do Mundo do Qatar.</segment>
    <segment id="2">No início desta tarde</segment>
    <segment id="3">, Tite já havia divulgado a lista dos 26 convocados.</segment>
    <segment id="4">Neymar (à dir) e Lucas Paquetá comemoram gol da seleção brasileira contra a Coreia do Sul - Jung Yeon-Je-2.jun22/AFPAssim</segment>
    <segment id="5">comocomo já havia acontecido nos Mundiais de 2014 e 2018</segment>
    <segment id="6">, Neymar vai vestir a camisa 10.</segment>
    <segment id="7">Richarlison será o 9.</segment>
    <segment id="8">Nome mais discutido da lista</segment>
    <segment id="9">, o lateral Daniel Alves ficará com a 13.</segment>
    <segment id="10">Veja abaixo a numeração de todos os jogadores:  1.</segment>
    <segment id="11">Alisson  2.</segment>
    <segment id="12">Danilo  3.</segment>
    <segment id="13">Thiago Silva  4.</segment>
    <segment id="14">Marquinhos  5.</segment>
    <segment id="15">Casemiro  6.</segment>
    <segment id="16">Alex Sandro  7.</segment>
    <segment id="17">Lucas Paquetá  8.</segment>
    <segment id="18">Fred  9.</segment>
    <segment id="19">Richarlison  10.</segment>
    <segment id="20">Neymar  11.</segment>
    <segment id="21">Raphinha  12.</segment>
    <segment id="22">Weverton  13.</segment>
    <segment id="23">Daniel Alves  14.</segment>
    <segment id="24">Eder Militão  15.</segment>
    <segment id="25">Fabinho  16.</segment>
    <segment id="26">Alex Telles  17.</segment>
    <segment id="27">Bruno Guimarães  18.</segment>
    <segment id="28">Gabriel Jesus  19.</segment>
    <segment id="29">Antony  20.</segment>
    <segment id="30">Vinicius Junior  21.</segment>
    <segment id="31">Rodrygo  22.</segment>
    <segment id="32">Éverto Ribeiro  23.</segment>
    <segment id="33">Ederson  24.</segment>
    <segment id="34">Bremer  25.</segment>
    <segment id="35">Pedro  26.</segment>
    <segment id="36">Martinelli</segment>
    <segment id="37">Após a convocação feita por Tite por meio de anúncio oral</segment>
    <segment id="38">, a CBF informou numeração dos inscritos</segment>
    <segment id="39">, masmas houve modificações na publicação no Instagram da entidade.</segment>
    <segment id="40">Segundo a Confederação</segment>
    <segment id="41">, esta última é a lista correta.</segment>
