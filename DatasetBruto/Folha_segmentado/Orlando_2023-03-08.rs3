  <rst>
    <segment id="1">As sirenes dos tratores e os guindastes que fazem do horizonte um canteiro de obras a perder de vista entregam que St.</segment>
    <segment id="2">Petersburg é a aposta da vez da Flórida</segment>
    <segment id="3">, a região dos Estados Unidos mais visitada por brasileiros</segment>
    <segment id="4">, para atrair o turista que quer ir além dos parques temáticos.  Mais conhecida por sua abreviação</segment>
    <segment id="5">, St.</segment>
    <segment id="6">Pete foi eleita em 2020 a praia preferida dos americanos.</segment>
    <segment id="7">Não é preciso consultar o TripAdivsor</segment>
    <segment id="8">, portal onde ocorreu a votação</segment>
    <segment id="9">, para descobrir isso.</segment>
    <segment id="10">A predominância do turismo local invade os ouvidos e os olhos</segment>
    <segment id="11">, seja por meio do "</segment>
    <segment id="12">R</segment>
    <segment id="13">"</segment>
    <segment id="14">retroflexo que marca o sotaque dos americanos</segment>
    <segment id="15">, seja pelo tom alaranjado de seus corpos</segment>
    <segment id="16">, tomados por bronzeamento artificial.</segment>
    <segment id="17">Conheças as praias da região de St.</segment>
    <segment id="18">Pete, nos Estados UnidosMais    novamente         de   de  de  representando um</segment>
    <segment id="19">Mas</segment>
    <segment id="20">St.</segment>
    <segment id="21">Pete também quer atrair estrangeiros.</segment>
    <segment id="22">Não à toa.</segment>
    <segment id="23">A cidade está a 170 quilômetros —ou 90 minutos— de Orlando</segment>
    <segment id="24">, o que faz dela um destino ideal para quem já conhece bem os castelos de Cinderela e de Harry Potter e quer belas praias para descansar da andança nos parques e nos outlets.</segment>
    <segment id="25">Embora seja uma cidade de médio porte</segment>
    <segment id="26">, com 250 mil habitantes</segment>
    <segment id="27">, a área onde</segment>
    <segment id="28">sese concentram os turistas</segment>
    <segment id="29">, conhecida</segment>
    <segment id="30">comocomo Downtown St.</segment>
    <segment id="31">Pete, não tem mais do que 20 mil moradores</segment>
    <segment id="32">, a maioria na casa dos 50 anos.</segment>
    <segment id="33">Não é, portanto</segment>
    <segment id="34">, a praia ideal para quem busca badalo</segment>
    <segment id="35">, como</segment>
    <segment id="36">como Miami</segment>
    <segment id="37">, masmas é uma boa aposta para famílias com crianças ou para qualquer um que procure tranquilidade.  especial para aproveitar os feriadosVeja dicas para economizar em passagens aéreas</segment>
    <segment id="38">, pacotes e aluguel de carro Roteiro por Dubai pode contemplar compras e atrações para toda a famíliaCruzeiro MSC</segment>
    <segment id="39">World Europa</segment>
    <segment id="40">, do Oriente Médio</segment>
    <segment id="41">, tem luxo</segment>
    <segment id="42">, toboágua e simulador de F1 Inaugurado há três anos</segment>
    <segment id="43">, o píer</segment>
    <segment id="44">, principal atração do município</segment>
    <segment id="45">, tem seu último andar ocupado por um bar</segment>
    <segment id="46">, o Pier Teaki.</segment>
    <segment id="47">Num contraste com o restaurante</segment>
    <segment id="48">, a cafeteria e a sorveteria dos pisos inferiores</segment>
    <segment id="49">, ali até</segment>
    <segment id="50">sese improvisa uma pista de dança com DJ ao entardecer</segment>
    <segment id="51">, masmas o verdadeiro charme do local está em</segment>
    <segment id="52">sese sentar para tomar um drinque com a vista para o Golfo do México.</segment>
    <segment id="53">Pudera.</segment>
    <segment id="54">Conhecida</segment>
    <segment id="55">comocomo a Cidade do Sol</segment>
    <segment id="56">, St.</segment>
    <segment id="57">Pete já registrou 768 dias ensolarados consecutivos</segment>
    <segment id="58">, uma marca superlativa do fim da década de 1960 que até hoje estampa o Livro Guinness dos Recordes.</segment>
    <segment id="59">O sol faz das praias</segment>
    <segment id="60">, que combinam água cristalina e morna com areia fina e branca</segment>
    <segment id="61">, a principal atração do destino —não só de St.</segment>
    <segment id="62">Pete, mas</segment>
    <segment id="63">mas também de cidades vizinhas</segment>
    <segment id="64">, localizadas a não mais do que 30 quilômetros de distância.</segment>
    <segment id="65">Um bom roteiro da região não pode deixar de fora</segment>
    <segment id="66">, portanto</segment>
    <segment id="67">, uma visita a Clearwater</segment>
    <segment id="68">, também tida outrora</segment>
    <segment id="69">comocomo a praia favorita dos americanos</segment>
    <segment id="70">, e a Dunedin</segment>
    <segment id="71">, uma cidade de influência escocesa que é a mais antiga do condado.</segment>
    <segment id="72">Vale ainda conhecer Pass-a-Grille</segment>
    <segment id="73">, talvez a melhor praia da região para assistir ao pôr do sol</segment>
    <segment id="74">, e Tarpon Springs</segment>
    <segment id="75">, de origem grega</segment>
    <segment id="76">, que é conhecida</segment>
    <segment id="77">comocomo a capital mundial das esponjas marítimas</segment>
    <segment id="78">, onde</segment>
    <segment id="79">sese pode fazer um passeio divertido de barco para mergulhar</segment>
    <segment id="80">, pescar ou mesmo coletar as esponjas.</segment>
    <segment id="81">Barco na cidade americana de Tarpon Springs</segment>
    <segment id="82">, ao lado de St.</segment>
    <segment id="83">Pete, conhecida</segment>
    <segment id="84">comocomo a capital mundial das esponjas marítimas - DivulgaçãoA paisagem ensolarada ganha contornos tão encantadores quanto ao ser vista por meio de uma caminhada ou de passeios guiados</segment>
    <segment id="85">, estes para quem tem menos medo de converter o real para dólar.</segment>
    <segment id="86">Em St.</segment>
    <segment id="87">Pete, uma boa aposta é o tour de bicicletas elétricas</segment>
    <segment id="88">, as eBikes</segment>
    <segment id="89">, que percorrem todo o centro turístico em três horas ao preço médio de US$ 200</segment>
    <segment id="90">, equivalentes a cerca de R$ 1.045</segment>
    <segment id="91">, por pessoa.</segment>
    <segment id="92">Para descansar ao fim de um passeio</segment>
    <segment id="93">, não há</segment>
    <segment id="94">comocomo não</segment>
    <segment id="95">sese encantar com os piqueniques cheios de charme feitos sob medida no gramado do Vinoy Park</segment>
    <segment id="96">, localizado em frente à orla da praia.</segment>
    <segment id="97">Os pacotes variam de US$ 300 para uma dupla a US$ 500 para um quarteto —há ainda versões luxuosas</segment>
    <segment id="98">, para ocasiões</segment>
    <segment id="99">comocomo um pedido de casamento</segment>
    <segment id="100">, por US$ 800.</segment>
    <segment id="101">Embora a paisagem natural seja seu principal atrativo</segment>
    <segment id="102">, St.</segment>
    <segment id="103">Pete também tem um lado cult.</segment>
    <segment id="104">A cidade</segment>
    <segment id="105">, que já serviu</segment>
    <segment id="106">comocomo cenário para centenas de filmes</segment>
    <segment id="107">, de "Winter</segment>
    <segment id="108">, o Golfinho" a "Magic Mike"</segment>
    <segment id="109">, tem um distrito de artes com dezenas de murais de grafite instagramáveis</segment>
    <segment id="110">, mais de 50 galerias e dois museus —o de Dale Chihuly</segment>
    <segment id="111">, artista americano que faz esculturas de vidro que parecem ter vindo do País das Maravilhas de Alice</segment>
    <segment id="112">, e o de Salvador Dalí.</segment>
    <segment id="113">Obras de arte feitas de vidro a partir de técnica de sopro criada pelo artista Dale Chihuly</segment>
    <segment id="114">, que tem um museu em St.</segment>
    <segment id="115">Pete, nos Estados Unidos - DivulgaçãoCriado a partir do acervo de uma família de colecionadores abastados da Flórida</segment>
    <segment id="116">, o Museu Dalí tem obras</segment>
    <segment id="117">comocomo "</segment>
    <segment id="118">Aranha da Noite" e "</segment>
    <segment id="119">Criança Geopolítica Observando</segment>
    <segment id="120">o Nascimento do Homem Novo"</segment>
    <segment id="121">,</segment>
    <segment id="122">as primeiras telas que o surrealista fez depois de</segment>
    <segment id="123">sese exilar nos Estados Unidos durante a Segunda Guerra Mundial</segment>
    <segment id="124">, além de "</segment>
    <segment id="125">A Desintegração da Persistência da Memória"</segment>
    <segment id="126">, uma releitura daquela que talvez seja uma de suas obras mais famosas.</segment>
    <segment id="127">Obra &amp;#</segment>
    <segment id="128">039;Criança</segment>
    <segment id="129">Geopolítica Observando</segment>
    <segment id="130">o Nascimento do Homem Novo&amp;#039</segment>
    <segment id="131">;, de Salvador Dalí</segment>
    <segment id="132">, exposta em museu em St.</segment>
    <segment id="133">Pete, nos Estados Unidos - DivulgaçãoCom o dólar acima dos R$ 5</segment>
    <segment id="134">, St.</segment>
    <segment id="135">Pete não é</segment>
    <segment id="136">, como</segment>
    <segment id="137">como qualquer cidade americana</segment>
    <segment id="138">, um dos destinos mais baratos para passar as férias.</segment>
    <segment id="139">No entanto</segment>
    <segment id="140">, para aqueles que já estão dispostos a quebrar o cofrinho numa visita à terra do Mickey</segment>
    <segment id="141">, uma esticadinha até o litoral será sem dúvida encantadora.</segment>
    <segment id="142">O jornalista viajou a convite do Visit Florida</segment>
