  <rst>
    <segment id="1">De acordo com várias estimativas</segment>
    <segment id="2">, até o final de 2024 começará a funcionar o terminal portuário multifuncional de Chancay</segment>
    <segment id="3">, considerado</segment>
    <segment id="4">comocomo uma das obras mais ambiciosas para impulsionar o comércio internacional na América do Sul.</segment>
    <segment id="5">Colunas e BlogsReceba no seu email uma seleção de colunas e blogs da Folha</segment>
    <segment id="6">; exclusiva para assinantes.</segment>
    <segment id="7">Carregando...</segment>
    <segment id="8">O projeto possui caráter privado e o investimento é estimado em mais de US$ 3</segment>
    <segment id="9">,6 bilhões.</segment>
    <segment id="10">Seus acionistas são a empresa de capital chinês Cosco Shipping Ports Limited (CSPL)</segment>
    <segment id="11">, com uma participação de 60%</segment>
    <segment id="12">, e a peruana Volcan Compañía Minera</segment>
    <segment id="13">, com 40%.</segment>
    <segment id="14">É o primeiro porto privado de uso público no Peru</segment>
    <segment id="15">, o que significa que o titular é proprietário do terreno onde o porto funcionará e pagará um tributo pelo uso da área aquática</segment>
    <segment id="16">, diferenciando-o assim dos portos de propriedade pública</segment>
    <segment id="17">, concessionados e operados inteiramente pelo setor privado.</segment>
    <segment id="18">Devido a suas características geográficas e de conectividade</segment>
    <segment id="19">, a localização do projeto é ideal para a construção desse tipo de megaprojeto</segment>
    <segment id="20">, pois</segment>
    <segment id="21">pois o distrito de Chancay está localizado apenas 80 km ao norte de Lima</segment>
    <segment id="22">, o que permitirá descongestionar as operações do porto de El Callao</segment>
    <segment id="23">, que se</segment>
    <segment id="24">se encontram saturadas</segment>
    <segment id="25">, apesar dos esforços de seus atuais operadores para ampliá-lo e torná-lo mais eficiente.</segment>
    <segment id="26">Por isso</segment>
    <segment id="27">, o terminal portuário multifuncional de Chancay pretende</segment>
    <segment id="28">sese posicionar</segment>
    <segment id="29">comocomo um dos espaços logísticos mais modernos e eficientes do Peru</segment>
    <segment id="30">, com tecnologia de ponta para receber os maiores navios porta-contêineres do mundo.</segment>
    <segment id="31">Projeto do porto de Chancay</segment>
    <segment id="32">, no Peru - DivulgaçãoPara o Peru</segment>
    <segment id="33">, os benefícios com esse projeto são inegáveis.</segment>
    <segment id="34">Em primeiro lugar</segment>
    <segment id="35">, o porto de Chancay contribuirá para um maior dinamismo de sua economia</segment>
    <segment id="36">, bem como</segment>
    <segment id="37">como para a melhoria da competitividade de suas exportações.</segment>
    <segment id="38">Ele também gerará novas oportunidades comerciais e de negócios para o Peru</segment>
    <segment id="39">, tornando-o o primeiro centro de logística do Pacífico na América Latina a fazer negócios com o continente asiático e</segment>
    <segment id="40">, em particular</segment>
    <segment id="41">, com a China.</segment>
    <segment id="42">Além disso</segment>
    <segment id="43">, e devido à sua localização e rotas de acesso</segment>
    <segment id="44">, o projeto gerará oportunidades para cargas provenientes do leste e da serra central do país</segment>
    <segment id="45">, aumentando assim sua competitividade frente a outros mercados.</segment>
    <segment id="46">Em segundo lugar</segment>
    <segment id="47">, os responsáveis pela obra afirmam que ela gerará 10.000 novos empregos tanto diretos</segment>
    <segment id="48">comocomo indiretos</segment>
    <segment id="49">, além de impulsionar o desenvolvimento do entorno e os intercâmbios comerciais</segment>
    <segment id="50">, embora</segment>
    <segment id="51">embora seus detratores alertem sobre seu impacto social e também denunciem danos ambientais</segment>
    <segment id="52">comocomo consequência de sua construção e posterior operação.</segment>
    <segment id="53">Em nível da região sul-americana</segment>
    <segment id="54">, o novo porto de Chancay é muito importante</segment>
    <segment id="55">porque</segment>
    <segment id="56">porque será um hub que movimentará cargas de e para o Chile</segment>
    <segment id="57">, Equador e Colômbia.</segment>
    <segment id="58">Além disso</segment>
    <segment id="59">, e como</segment>
    <segment id="60">como um grande objetivo estratégico</segment>
    <segment id="61">, o porto será uma das principais conexões da China com os países da costa oeste da América do Sul</segment>
    <segment id="62">, servindo assim</segment>
    <segment id="63">comocomo uma ponte para o crescente comércio de mercadorias dessa região com a Ásia-Pacífico</segment>
    <segment id="64">, hoje a mais dinâmica do mundo.</segment>
    <segment id="65">A relação do Peru com a China está em seu melhor momento.</segment>
    <segment id="66">O Peru assinou com este país um acordo de livre comércio que atualmente está em processo de otimização</segment>
    <segment id="67">, o que permitiu que o gigante asiático</segment>
    <segment id="68">sese tornasse seu primeiro parceiro comercial após a entrada em vigor do acordo.</segment>
    <segment id="69">Além disso</segment>
    <segment id="70">, há uma década</segment>
    <segment id="71">, ambos os países elevaram suas relações diplomáticas ao nível de Associação Estratégica Integral</segment>
    <segment id="72">, o que ajudou a consolidar a amizade e a cooperação em diferentes campos.</segment>
    <segment id="73">Finalmente</segment>
    <segment id="74">, no ano passado</segment>
    <segment id="75">, o Peru tornou-</segment>
    <segment id="76">sese formalmente membro do Banco Asiático de Investimento em Infraestrutura e</segment>
    <segment id="77">, em 2019</segment>
    <segment id="78">, assinou o Memorando para a participação do Peru na Iniciativa do Cinturão e Rota</segment>
    <segment id="79">, um plano de investimento massivo para construir grandes projetos de infraestrutura em todo o mundo</segment>
    <segment id="80">, lançado pelo presidente chinês Xi Jinping em 2013.Localização do porto de Chancay (em vermelho)</segment>
    <segment id="81">, no Peru - GoogleMapsPrecisamente</segment>
    <segment id="82">, para alguns</segment>
    <segment id="83">, o projeto do porto de Chancay está enquadrado na chamada Rota Marítima da Seda</segment>
    <segment id="84">, que poderia transformar o Peru em uma potência comercial na América Latina e será um valioso instrumento para o fortalecimento das relações de amizade e cooperação com a China nos próximos anos.</segment>
    <segment id="85">Para outros</segment>
    <segment id="86">, no entanto</segment>
    <segment id="87">, esse projeto faz parte do grande plano geopolítico da China para ampliar sua esfera de influência</segment>
    <segment id="88">, desenvolver seu comércio</segment>
    <segment id="89">, aumentar sua riqueza e aumentar seu poder diplomático e militar.</segment>
    <segment id="90">Nesse sentido</segment>
    <segment id="91">, existe uma grande preocupação por parte de alguns países</segment>
    <segment id="92">, especialmente dos Estados Unidos</segment>
    <segment id="93">, de que o aumento da presença e da influência da China na região por meio desses investimentos represente uma potencial ameaça ao criar uma excessiva dependência dos laços comerciais e creditícios com este país</segment>
    <segment id="94">, os quais geram</segment>
    <segment id="95">, além disso</segment>
    <segment id="96">, um alto déficit comercial e uma elevada dívida.</segment>
    <segment id="97">Como dissemos anteriormente</segment>
    <segment id="98">, a região da Ásia-Pacífico é altamente relevante para o desenvolvimento de nossa região e oferece oportunidades sem precedentes.</segment>
    <segment id="99">No entanto</segment>
    <segment id="100">, esse ainda é um mercado inexplorado e teria um impacto enorme na economia</segment>
    <segment id="101">, no comércio e nos investimentos.</segment>
    <segment id="102">Portanto</segment>
    <segment id="103">, a instalação do porto de Chancay contribuirá significativamente para esse processo</segment>
    <segment id="104">comocomo um elemento dinamizador</segment>
    <segment id="105">, especialmente no contexto atual de competição estratégica entre as duas maiores potências mundiais</segment>
    <segment id="106">, como</segment>
    <segment id="107">como são os Estados Unidos e a China.</segment>
    <segment id="108">Este texto foi publicado originalmente na página da Redcaem</segment>
  </rst>
</analysis>