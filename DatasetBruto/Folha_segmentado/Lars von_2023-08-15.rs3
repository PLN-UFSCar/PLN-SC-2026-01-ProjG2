  <rst>
    <segment id="1">O cineasta Lars von Trier</segment>
    <segment id="2">, conhecido pelos seus filmes sombrios</segment>
    <segment id="3">comocomo "Melancolia" (2011) e "Ninfomaníaca" (2013)</segment>
    <segment id="4">, publicou um vídeo em seu perfil do Instagram em que</segment>
    <segment id="5">sese diz à procura de "uma namorada e musa".</segment>
    <segment id="6">Lars von Trier em vídeo no seu Instagram - ReproduçãoNa gravação</segment>
    <segment id="7">, Trier inicia</segment>
    <segment id="8">sese apresentando: um homem de 67 anos</segment>
    <segment id="9">, dinamarquês</segment>
    <segment id="10">, cabelos grisalios</segment>
    <segment id="11">, divorciado duas vezes.</segment>
    <segment id="12">"</segment>
    <segment id="13">Eu tenho Parkinson</segment>
    <segment id="14">, TOC e</segment>
    <segment id="15">, no momento</segment>
    <segment id="16">, alcoolismo controlado"</segment>
    <segment id="17">, diz o diretor</segment>
    <segment id="18">, enquanto grava seu rosto de perto.</segment>
    <segment id="19">Trier diz ainda que pretende "fazer mais alguns filmes decentes na vida" e que pode ser um ótimo parceiro "</segment>
    <segment id="20">num bom dia</segment>
    <segment id="21">, na companhia</segment>
    <segment id="22">certa"</segment>
    <segment id="23">.</segment>
    <segment id="24">Ele ainda admite saber pouco sobre redes sociais e pede que as interessadas enviem um e-mail ao seu endereço eletrônico pessoal.</segment>
    <segment id="25">Ninfomaníaca</segment>
    <segment id="26">, de Lars von TrierMais    novamente         de   de  de  representando um</segment>
  </rst>
