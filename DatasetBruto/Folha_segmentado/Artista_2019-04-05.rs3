  <rst>
    <segment id="1">Paula Chimanovitch apresenta</segment>
    <segment id="2">, a partir desta sexta (5)</segment>
    <segment id="3">, sua primeira mostra individual em São Paulo.</segment>
    <segment id="4">"</segment>
    <segment id="5">Amarras - Entre Nós" reúne cerca de 20 obras</segment>
    <segment id="6">, entre pinturas</segment>
    <segment id="7">, desenhos</segment>
    <segment id="8">, objetos e instalações</segment>
    <segment id="9">, na Casa Bonita Colab</segment>
    <segment id="10">, no Brooklin.</segment>
    <segment id="11">Paula Chimanovitch   novamente         de   de  de  representando um</segment>
    <segment id="12">A poética de Chimanovitch lida com pares opostos de sensações corpóreas: tensão e relaxamento</segment>
    <segment id="13">, prazer e dor.</segment>
    <segment id="14">Os estados ganham expressão tanto em desenhos e pinturas</segment>
    <segment id="15">, que mesclam partes humanas a membros de animais</segment>
    <segment id="16">, quanto em objetos e instalações tridimensionais.</segment>
    <segment id="17">Nestes</segment>
    <segment id="18">, que podem tomar a forma de um avental ou de livros de artista customizados</segment>
    <segment id="19">, de até dois metros de extensão</segment>
    <segment id="20">, Chimanovitch explora a interação com os visitantes a partir de materiais</segment>
    <segment id="21">comocomo agulhas e borracha.</segment>
    <segment id="22">"</segment>
    <segment id="23">Meu trabalhos tratam do encontro do corpo com a obra.</segment>
    <segment id="24">Não são passivos.</segment>
    <segment id="25">"</segment>
    <segment id="26">A questão</segment>
    <segment id="27">, aliás</segment>
    <segment id="28">, está presente também no seu trabalho</segment>
    <segment id="29">comocomo tatuadora</segment>
    <segment id="30">, iniciado em 2017.</segment>
    <segment id="31">"</segment>
    <segment id="32">Tem gente que acha que a profissão</segment>
    <segment id="33">sese baseia simplesmente em desenhar.</segment>
    <segment id="34">Mas existe um encontro entre tatuador e tatuado que é muito mais interessante"</segment>
    <segment id="35">, diz.  Amarras - Entre nós - Casa Bonita Colab (Rua Indiana</segment>
    <segment id="36">, 1006</segment>
    <segment id="37">, Brooklin).</segment>
    <segment id="38">De 5/4 a 21/4.</segment>
    <segment id="39">Grátis.</segment>
  </rst>
</analysis>