  <rst>
    <segment id="1">Celso Portiolli jura que uma “lenda urbana” interna do SBT assegura que um dos estúdios da sede da emissora</segment>
    <segment id="2">, em Osasco</segment>
    <segment id="3">, na Grande São Paulo</segment>
    <segment id="4">, é mal-assombrado.</segment>
    <segment id="5">E buscou respaldo em uma antiga declaração de Hebe Camargo.</segment>
    <segment id="6">“</segment>
    <segment id="7">Tanto é que os paranormais que gravaram aqui também sentiram uma presença.</segment>
    <segment id="8">As pessoas até escutam vozes à noite”</segment>
    <segment id="9">, afirmou o apresentador.</segment>
    <segment id="10">O pessoal da ESPN</segment>
    <segment id="11">, que ocupa as antigas dependências do SBT no bairro do Sumaré</segment>
    <segment id="12">, em São Paulo</segment>
    <segment id="13">, onde funcionaram os estúdios da Tupi</segment>
    <segment id="14">, também conta</segment>
    <segment id="15">, há muito tempo</segment>
    <segment id="16">, que o edifício é mal-assombrado e guardaria o fantasma de Assis Chateaubriand no elevador.</segment>
    <segment id="17">Programa Passa ou Repassa 2020Mais    novamente         de   de  de  representando um  SOL DE FIM DE INVERNO  Bem-vinda seja a proximidade da primavera</segment>
    <segment id="18">, e com ela</segment>
    <segment id="19">, o avanço da vacinação contra a Covid-19 no Brasil.</segment>
    <segment id="20">Embora ainda seja tempo de tomar muitos cuidados</segment>
    <segment id="21">, já é possível botar o nariz para fora e deixar o sol bronzear a pele</segment>
    <segment id="22">, desde que seja assim</segment>
    <segment id="23">, sem aglomerações</segment>
    <segment id="24">, como</segment>
    <segment id="25">como consegue fazer Deborah Secco.</segment>
    <segment id="26">Aos 41 anos</segment>
    <segment id="27">, a atriz trabalha duro para ostentar uma musculatura à base de muita malhação.</segment>
    <segment id="28">E ela sabe</segment>
    <segment id="29">comocomo recompensar tanto esforço nesse finzinho de inverno</segment>
    <segment id="30">, já com cara de primavera</segment>
    <segment id="31">, com merecido descanso à luz do sol</segment>
    <segment id="32">, em desfile para os seus 22</segment>
    <segment id="33">,2 milhões de seguidores no Instagram  Quando entrar Setembro</segment>
    <segment id="34">, as gatas aí estãoMais    novamente         de   de  de  representando um  FRASE</segment>
    <segment id="35">"</segment>
    <segment id="36">Acho que</segment>
    <segment id="37">, para a Globo</segment>
    <segment id="38">, você precisa estar muito forte fora para entrar direito.</segment>
    <segment id="39">Claro, tem gente que entra e tudo bem.</segment>
    <segment id="40">Eu fiz duas incursões na Globo em que eu era muito jovem de TV"</segment>
    <segment id="41">Miá Mello a Zeca Camargo no Splash Entrevista</segment>
    <segment id="42">, do UOL</segment>
    <segment id="43">Talk</segment>
    <segment id="44">Show&amp;#039</segment>
    <segment id="45">;Posso Explicar&amp;#039</segment>
    <segment id="46">; com Miá MelloMais    novamente         de   de  de  representando um  LUTO  Josy Oliveira</segment>
    <segment id="47">, que participou do “BBB 9”</segment>
    <segment id="48">, morreu aos 43 anos</segment>
    <segment id="49">, em São Paulo</segment>
    <segment id="50">, nesta domingo (5).</segment>
    <segment id="51">A cantora teve complicações em uma cirurgia para tratar um aneurisma</segment>
    <segment id="52">, doença que descobriu em 2020.</segment>
    <segment id="53">Ela deixa o marido</segment>
    <segment id="54">, Daniel Ramos</segment>
    <segment id="55">, e um filho</segment>
    <segment id="56">, Mateus</segment>
    <segment id="57">, de 5 anos.</segment>
    <segment id="58">Mineira de Juiz de Fora</segment>
    <segment id="59">, Josy era cantora</segment>
    <segment id="60">, formada em psicologia.</segment>
    <segment id="61">2- Ex-BBB</segment>
    <segment id="62">Josy Oliveira morre após complicações durante cirurgia para tratar aneurisma - Instagram/ jeannebolivFARSA?</segment>
    <segment id="63">O romance da princesa Diana com Dodi Fayed</segment>
    <segment id="64">, seu namorado à época do acidente que acabou com a morte dos dois</segment>
    <segment id="65">, seria uma farsa: segundo um ex-funcionário da princesa</segment>
    <segment id="66">, ela e o milionário passaram férias e noites juntos após a separação dela e do príncipe Charles.</segment>
    <segment id="67">Mas um membro da equipe que trabalhava para os dois alegou que eles não estavam realmente envolvidos romanticamente</segment>
    <segment id="68">, segundo relatou ao Daily Star.</segment>
    <segment id="69">Tudo seria só obra de representação diante das câmeras.  ROMPIMENTO  Angelina Jolie</segment>
    <segment id="70">, 46 anos</segment>
    <segment id="71">, contou que ela e seu ex-marido Brad Pitt</segment>
    <segment id="72">, 57, brigaram por ele trabalhar com Harvey Weinstein</segment>
    <segment id="73">, condenado por abuso sexual por acusação de várias mulheres.</segment>
    <segment id="74">Jolie disse que discutiu com Pitt quando ele estrelou o filme de Quentin Tarantino</segment>
    <segment id="75">, “Bastardos Inglórios” em 2009</segment>
    <segment id="76">, coproduzido pela Weinstein Company.</segment>
  </rst>
