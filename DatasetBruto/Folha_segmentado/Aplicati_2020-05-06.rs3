  <rst>
    <segment id="1">O governo de São Paulo lançou nesta quarta-feira (6) o aplicativo Poupatempo Digital</segment>
    <segment id="2">,que permite a solicitação de seguro-desemprego e carteira de trabalho</segment>
    <segment id="3">, sem sair de casa.</segment>
    <segment id="4">A ferramenta foi lançada</segment>
    <segment id="5">comocomo medida de enfrentamento ao novo coronavírus</segment>
    <segment id="6">, já que as unidades do Poupatempo estão fechadas durante a pandemia.</segment>
    <segment id="7">As funções para renovar ou emitir a segunda via da CNH (carteira de habilitação)</segment>
    <segment id="8">, apesar de já constarem no aplicativo</segment>
    <segment id="9">, serão habilitadas</segment>
    <segment id="10">, segundo o Poupatempo</segment>
    <segment id="11">, somente após o término da quarentena</segment>
    <segment id="12">, decretada pelo governo estadual em 24 de março.</segment>
    <segment id="13">Isso ocorre pela necessidade da entrega de exames médicos</segment>
    <segment id="14">, presencialmente.</segment>
    <segment id="15">Poupatempo e Shopping Itaquera estão fechados por causa da pandemia - Cristiane Gercina - 19</segment>
    <segment id="16">,mar,20/FolhapresOs motoristas que tiveram os documentos de habilitação vencidos</segment>
    <segment id="17">, a partir de 19 de fevereiro deste ano</segment>
    <segment id="18">, podem ficar tranquilos</segment>
    <segment id="19">, pois</segment>
    <segment id="20">pois o Contran (Conselho Nacional de Trânsito) prorrogou por tempo indeterminado a permissão de uso destas CNHs.</segment>
    <segment id="21">Os condutores não serão penalizados</segment>
    <segment id="22">, segundo o Poupatempo</segment>
    <segment id="23">, e poderão renovar os documentos após o término da quarentena -- sem prazo ainda definido.</segment>
    <segment id="24">O aplicativo oferece 60 serviços públicos diferentes</segment>
    <segment id="25">, dos quais 25 são exclusivos para este período de isolamento social.</segment>
    <segment id="26">O Poupatempo Digital pode ser usado em celulares com sistemas iOS ou Android.</segment>
    <segment id="27">Quem já conta com cadastro no site do Poupatempo pode usar o mesmo login e senha para acessar o aplicativo.</segment>
    <segment id="28">Mutirão de emissão de RGs para moradores de rua</segment>
    <segment id="29">O governo estadual anunciou nesta quarta um mutirão para emissão de RGs (documentos de identidade) para pessoas em situação de rua.</segment>
    <segment id="30">Com os documentos</segment>
    <segment id="31">, eles podem ter acesso ao auxílio emergencial de R$ 600 do governo federal.</segment>
    <segment id="32">O governador João Doria (PSDB) afirmou durante coletiva de imprensa no Palácio dos Bandeirantes</segment>
    <segment id="33">, que as carteiras de identidade serão ofertadas a quem as perdeu</segment>
    <segment id="34">, ou que nunca as tenham emitido</segment>
    <segment id="35">, especialmente à população de rua do centro da capital paulista.</segment>
    <segment id="36">A forma</segment>
    <segment id="37">comocomo as pessoas serão abordadas não foi infirmada</segment>
    <segment id="38">, nem o tempo</segment>
    <segment id="39">para que</segment>
    <segment id="40">para que os documentos sejam emitidos.</segment>
    <segment id="41">​Poupatempo - aplicativo</segment>
    <segment id="42">Como baixar</segment>
    <segment id="43">Entre na loja de aplicativos de seu celular e busque por Poupatempo Digital</segment>
    <segment id="44">Em seguida é só baixar o app gratuitamente</segment>
    <segment id="45">Após isso</segment>
    <segment id="46">, é preciso digitar o CPF e criar uma senha    Serviços para motoristas (Detran.</segment>
    <segment id="47">SP)</segment>
    <segment id="48">Segunda via e renovação da CNH (serviço indisponível na quarentena)</segment>
    <segment id="49">Certidão de prontuário</segment>
    <segment id="50">, Consulta de pontos Consulta de multas</segment>
    <segment id="51">Outros serviços</segment>
    <segment id="52">Acompanhamento da emissão de RG.</segment>
    <segment id="53">Solicitação de seguro desemprego</segment>
    <segment id="54">Solicitação de Carteira de Trabalho Consulta de IPVA    Fonte:</segment>
    <segment id="55">Governo do Estado de São Paulo</segment>
  </rst>
