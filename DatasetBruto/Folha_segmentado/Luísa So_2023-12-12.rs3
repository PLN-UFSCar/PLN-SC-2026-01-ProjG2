  <rst>
    <segment id="1">Uma das estrelas pop brasileiras que mais</segment>
    <segment id="2">sese destacou neste último ano</segment>
    <segment id="3">, a gaúcha Luísa Sonza ganha uma minissérie documental e conta</segment>
    <segment id="4">comocomo começou sua carreira e alcançou o sucesso.</segment>
    <segment id="5">Cena da série documental &amp;#039</segment>
    <segment id="6">;Se</segment>
    <segment id="7">Eu Fosse Luísa Sonza&amp;#039</segment>
    <segment id="8">; - NetflixEm "</segment>
    <segment id="9">Se Eu Fosse Luísa Sonza"</segment>
    <segment id="10">, ela também fala das polêmicas em que</segment>
    <segment id="11">sese envolveu e das mensagens de recebidas nas redes sociais</segment>
    <segment id="12">, que abalam sua saúde mental.</segment>
    <segment id="13">Entre os depoimentos de amigos</segment>
    <segment id="14">, parentes e produtores</segment>
    <segment id="15">, sese destaca o de seu ex-marido</segment>
    <segment id="16">, Whindersson Nunes.</segment>
    <segment id="17">Direção de Isabel Nascimento e Silva.</segment>
    <segment id="18">Netflix</segment>
    <segment id="19">, 12 anos</segment>
    <segment id="20">Doctor Who Especial 3</segment>
    <segment id="21">O mais longevo personagem da TV britânica</segment>
    <segment id="22">, interpretado por uma dezena de atores ao longo de seis décadas</segment>
    <segment id="23">, ganhou três especiais neste final de ano</segment>
    <segment id="24">, todos já disponíveis na plataforma.</segment>
    <segment id="25">Neste, "</segment>
    <segment id="26">A Risadinha"</segment>
    <segment id="27">, ele combate um de seus antigos inimigos</segment>
    <segment id="28">, o sinistro Toymaker.</segment>
    <segment id="29">Com David Tennant e Neil Patrick Harris.  Disney+</segment>
    <segment id="30">, 12 anos</segment>
    <segment id="31">Estúdio ao Vivo  Román Laurito</segment>
    <segment id="32">, Iara Oliveira e Renato Tortorelli recebem a banda Jota Quest</segment>
    <segment id="33">, que apresenta a canção inédita "</segment>
    <segment id="34">Numa Boa"</segment>
    <segment id="35">, feita em parceria com o cantor e compositor Vitor Kley.</segment>
    <segment id="36">Veja imagens de integrantes da banda Jota Quest</segment>
    <segment id="37">, que lança álbum após oito anosMais    novamente         de   de  de  representando um  YouTube da Transamérica</segment>
    <segment id="38">, 16h, livre</segment>
    <segment id="39">Le Cordon Bleu: Gastronomia Sem Fronteiras</segment>
    <segment id="40">O documentário mostra o impacto da chegada ao Brasil da mais famosa rede de escolas de culinária do mundo.</segment>
    <segment id="41">Entre os depoimentos ouvidos estão os de André Cointreau</segment>
    <segment id="42">, presidente da instituição</segment>
    <segment id="43">, e Josimar Melo</segment>
    <segment id="44">, curador do canal e colaborador do jornal.</segment>
    <segment id="45">Sabor &amp;amp</segment>
    <segment id="46">; Arte</segment>
    <segment id="47">, 20h30</segment>
    <segment id="48">, livre</segment>
    <segment id="49">Legião Estrangeira</segment>
    <segment id="50">O jornalista Alberto Gaspar conversa com correspondentes estrangeiros sobre a tensão política atual entre as nações da Guiana e da Venezuela.</segment>
    <segment id="51">Moradores de Essequibo temem conflito com VenezuelaMais    novamente         de   de  de  representando um  Cultura</segment>
    <segment id="52">, 22h, livre   Galvão Bueno:</segment>
    <segment id="53">Olha o que Ele Fez</segment>
    <segment id="54">A emissora exibe uma versão condensada da minissérie documental</segment>
    <segment id="55">, disponível atualmente no Globoplay.</segment>
    <segment id="56">A produção relembra a imensa trajetória do mais importante locutor esportivo brasileiro das últimas décadas</segment>
    <segment id="57">, através de depoimentos de seus grandes amigos e de seus maiores desafetos.</segment>
    <segment id="58">Relembre momentos marcantes</segment>
    <segment id="59">, divertidos</segment>
    <segment id="60">, gafes e memes de Galvão BuenoMais    novamente         de   de  de  representando um  Globo</segment>
    <segment id="61">, 22h25</segment>
    <segment id="62">, 12 anos</segment>
