  <rst>
    <segment id="1">Todo fim de tarde</segment>
    <segment id="2">, dezenas de turistas sobem o morro da Caixa D'água</segment>
    <segment id="3">, em Guarujá</segment>
    <segment id="4">, no litoral sul de São Paulo</segment>
    <segment id="5">, em busca do cenário de verão recém-inaugurado sob medida para postar nas redes sociais.</segment>
    <segment id="6">O Mirante das Galhetas tem</segment>
    <segment id="7">comocomo principal atração a plataforma de vidro suspensa 45 metros acima do mar com vista panorâmica para as praias do Tombo e das Astúrias.</segment>
    <segment id="8">A atração mais concorrida</segment>
    <segment id="9">, porém</segment>
    <segment id="10">porém, é o balanço instalado no topo do morro que chega a formar fila de pessoas a espera da sua vez para tirar uma selfie emoldurada pelas flores de plástico e a placa "</segment>
    <segment id="11">Eu amo Guarujá".</segment>
    <segment id="12">Balanço no Mirante das Galhetas é atração do verão em Guarujá - Divulgação/Prefeitura de Guarujá/Regis LimaA família da dona de casa Jaíde Farias</segment>
    <segment id="13">, 32, não</segment>
    <segment id="14">sese importou em esperar cerca de meia hora debaixo do sol para tirar as fotos.</segment>
    <segment id="15">"É muito lindo</segment>
    <segment id="16">, não podemos ir</segment>
    <segment id="17">embora</segment>
    <segment id="18">embora sem registrar isso"</segment>
    <segment id="19">, disse ela</segment>
    <segment id="20">, que saiu de Campinas</segment>
    <segment id="21">, no interior paulista</segment>
    <segment id="22">, para passar férias no litoral.</segment>
    <segment id="23">A maioria apenas senta no balanço e abre um sorriso para a câmera com o mar azul ao fundo</segment>
    <segment id="24">, masmas há alguns visitantes que ousam impulsos mais altos para dar o efeito de estar flutuando na foto.</segment>
    <segment id="25">O movimento de carros</segment>
    <segment id="26">, bicicletas e moradores com seus cães começa a aumentar à medida que</segment>
    <segment id="27">sese aproxima o por do sol</segment>
    <segment id="28">, quando é formada fila para fazer fotos na ponta direita do mirante</segment>
    <segment id="29">, que garante imagens com a praia do Tombo ao fundo.</segment>
    <segment id="30">Os dias seguidos de tempo ruim no litoral neste início de ano frustraram os turistas que foram morro acima atrás de uma foto com o céu alaranjado de fim de tarde.</segment>
    <segment id="31">Mesmo assim</segment>
    <segment id="32">, os celulares seguem empunhados.</segment>
    <segment id="33">O balanço instagramável do Guarujá</segment>
    <segment id="34">sese junta a uma série de pontos turísticos com a mesma proposta</segment>
    <segment id="35">, como</segment>
    <segment id="36">como o "Balanço nas Nuvens"</segment>
    <segment id="37">, do parque Alto da Pedra</segment>
    <segment id="38">, no Rio Grande do Sul</segment>
    <segment id="39">, e o instalado no Buraco Azul</segment>
    <segment id="40">, em Jericoacoara (CE).</segment>
    <segment id="41">Em Itapema</segment>
    <segment id="42">, no litoral catarinense</segment>
    <segment id="43">, a prefeitura criou a "</segment>
    <segment id="44">Rota dos Balanços" com sete estruturas gigantes para tirar fotos.</segment>
    <segment id="45">Antes de passar pela reforma que incluiu nova pavimentação e iluminação</segment>
    <segment id="46">, o Morro da Caixa D'água já figurava entre os mirantes mais famosos em Guarujá.</segment>
    <segment id="47">Na lista</segment>
    <segment id="48">, estão o mirante Campina</segment>
    <segment id="49">, conhecido</segment>
    <segment id="50">comocomo Morro do Maluf</segment>
    <segment id="51">, e o Costão das Tartarugas.</segment>
    <segment id="52">Apesar de garantia de curtidas nas redes sociais</segment>
    <segment id="53">, o novo ponto turístico é alvo de reclamação entre os visitantes devido à falta de sombras disponíveis.</segment>
    <segment id="54">Nas horas mais quentes da tarde</segment>
    <segment id="55">, as pessoas</segment>
    <segment id="56">sese aglomeram no abrigo do sol formado pelo contêiner onde fica a equipe da secretaria de turismo municipal.</segment>
    <segment id="57">Não há banheiros nem bebedouros no mirante.</segment>
    <segment id="58">Mirante das Galhetas</segment>
    <segment id="59">, em Guarujá</segment>
    <segment id="60">, atrai turistas em busca da foto perfeitaMais    novamente         de   de  de  representando um  Inaugurado em maio do ano passado</segment>
    <segment id="61">, o Mirante das Galhetas custou R$ 2 milhões e recebeu recursos da União por meio de convênio entre a Prefeitura de Guarujá e o Ministério do Turismo.</segment>
    <segment id="62">No local</segment>
    <segment id="63">, também partem voos de paraglider.</segment>
    <segment id="64">Para chegar à plataforma de vidro</segment>
    <segment id="65">, o visitante sobe o pavimento asfaltado até o topo do morro.</segment>
    <segment id="66">Quem vai de carro</segment>
    <segment id="67">, ganha uma etiqueta com o número das 14 vagas disponíveis para estacionar</segment>
    <segment id="68">, masmas não há fiscalização e os espaços mais próximos são bastante disputados.</segment>
    <segment id="69">A entrada é gratuita e a prefeitura estimula a doação de um quilo de alimento não perecível por visitante.</segment>
    <segment id="70">O mirante funciona todos os dias das 8h às 20h.</segment>
    <segment id="71">É preciso usar máscaras e manter o distanciamento social no mirante.</segment>
  </rst>
</analysis>