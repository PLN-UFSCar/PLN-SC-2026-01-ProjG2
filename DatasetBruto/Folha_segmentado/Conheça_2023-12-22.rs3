  <rst>
    <segment id="1">Beyoncé esteve no Brasil na noite desta quinta-feira</segment>
    <segment id="2">, dia 21</segment>
    <segment id="3">, e participou do evento de lançamento do filme sobre a turnê "Renaissance" em Salvador</segment>
    <segment id="4">, na Bahia.</segment>
    <segment id="5">Ela voltou para Nova York</segment>
    <segment id="6">, nos Estados Unidos</segment>
    <segment id="7">, na mesma noite</segment>
    <segment id="8">, masmas sua presença deixou seus fãs eufóricos.</segment>
    <segment id="9">Quarto do jatinho</segment>
    <segment id="10">Bombardier Global</segment>
    <segment id="11">7500</segment>
    <segment id="12">, de Beyoncé - DivulgaçãoA passagem meteórica da cantora pelo país foi garantida pelo maior jato executivo no mercado</segment>
    <segment id="13">, que alcança 982 km/h.</segment>
    <segment id="14">A aeronave Bombardier Global 7500 é avaliada em US$ 75 milhões</segment>
    <segment id="15">, o equivalente a R$ 363 milhões.</segment>
    <segment id="16">Esse avião tem a maior autonomia para um jato executivo</segment>
    <segment id="17">, conseguindo fazer trajetos de até 14.260 quilômetros.</segment>
    <segment id="18">A distância de Nova York até Salvador é de 7.000 quilômetros.</segment>
    <segment id="19">A área para os passageiros ocupa 40 metros quadrados</segment>
    <segment id="20">, abrigando 19 pessoas.</segment>
    <segment id="21">Conheça o jatinho de Beyoncé</segment>
    <segment id="22">, avaliado em R$ 363 milhõesMais    novamente         de   de  de  representando um  Não há informações sobre a decoração do interior do jato de Beyoncé</segment>
    <segment id="23">, masmas a fabricante diz</segment>
    <segment id="24">, em seu site</segment>
    <segment id="25">, que a ideia é deixar o ambiente da aeronave mais agradável e iluminada.</segment>
    <segment id="26">Para tanto</segment>
    <segment id="27">, o avião dispõe de uma tecnologia especial</segment>
    <segment id="28">, que permite o controle da altura e da inclinação das poltronas.</segment>
    <segment id="29">Os proprietários podem optar por uma sala de estar com um sofá de três lugares e uma TV de 55 polegadas.</segment>
    <segment id="30">Há também a possibilidade de ter um quarto com banheiro privativo.</segment>
    <segment id="31">Veja como</segment>
    <segment id="32">como foi a visita de Beyoncé em SalvadorMais    novamente         de   de  de  representando um  Para amenizar o jet lag</segment>
    <segment id="33">, o mal-estar causado pela diferença de fusos horários</segment>
    <segment id="34">, a fabricante criou um sistema de iluminação</segment>
    <segment id="35">, que pode ser regulado pelo passageiro.</segment>
    <segment id="36">Afora o quarto e a sala</segment>
    <segment id="37">, o avião tem uma ampla cozinha</segment>
    <segment id="38">, com uma mesa para seis pessoas.</segment>
    <segment id="39">A título de comparação</segment>
    <segment id="40">, o jatinho que transportou Taylor Swift ao Brasil</segment>
    <segment id="41">, durante a "The Eras Tour" custa US$ 40 milhões</segment>
    <segment id="42">, o equivalente a R$ 200 milhões.</segment>
    <segment id="43">O Falcon 900 LX tem capacidade para 12 passageiros e chega a velocidade de 890 quilômetros por hora.</segment>
  </rst>
