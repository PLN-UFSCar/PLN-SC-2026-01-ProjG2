  <rst>
    <segment id="1">Cena 1 - lavanderia</segment>
    <segment id="2">Lula vê Sergio Moro lacrando seu estabelecimento.</segment>
    <segment id="3">Depois de enfrentar uma longa jornada burocrática</segment>
    <segment id="4">, Lula conhece Janja</segment>
    <segment id="5">, uma mulher extraordinária que lhe ensina a viajar pelo multiverso.</segment>
    <segment id="6">Eleito presidente</segment>
    <segment id="7">, Lula descobre seu inimigo real: Arthur Lira.</segment>
    <segment id="8">Em vertigem</segment>
    <segment id="9">, Lula tropeça e cai num arcabouço fiscal infinito.</segment>
    <segment id="10">Cena 2 - Banco Central  Lula derruba mesas</segment>
    <segment id="11">, cadeiras</segment>
    <segment id="12">, papéis</segment>
    <segment id="13">, escaninhos e armários de um imenso escritório.</segment>
    <segment id="14">Começa uma briga frenética com Roberto Campos Neto.</segment>
    <segment id="15">Centenas de investidores com colete da XP atacam o presidente.</segment>
    <segment id="16">No fundo</segment>
    <segment id="17">, um governador maníaco bate um martelo com força.</segment>
    <segment id="18">Entre braços</segment>
    <segment id="19">, pernas</segment>
    <segment id="20">, cadeiras e taxas de juros</segment>
    <segment id="21">, Lula avista Arthur Lira de longe.</segment>
    <segment id="22">Cena 3 - rampa infinita</segment>
    <segment id="23">Com um terceiro olho na testa</segment>
    <segment id="24">, Lula sobe uma rampa branca.</segment>
    <segment id="25">O fundo é branco</segment>
    <segment id="26">, o céu é branco.</segment>
    <segment id="27">Ao olhar para trás</segment>
    <segment id="28">, o presidente vê Geraldo Alckmin com meias multicoloridas.</segment>
    <segment id="29">Os poucos cabelos do vice-presidente</segment>
    <segment id="30">sese unem no cocuruto num formato de rosquinha.</segment>
    <segment id="31">Ao olhar para frente</segment>
    <segment id="32">, Lula vê Arthur Lira e corre em sua direção.</segment>
    <segment id="33">Mas não sai do lugar.</segment>
    <segment id="34">Ilustração de Débora Gonzales para a coluna de Renato Terra de 23.mar.23 - Débora GonzalesCena 4 - Alagoas  Terra descampada e árida.</segment>
    <segment id="35">Céu azul.</segment>
    <segment id="36">No alto de uma montanha</segment>
    <segment id="37">, duas pedras tentam</segment>
    <segment id="38">sese aproximar.</segment>
    <segment id="39">Em vão.</segment>
    <segment id="40">Nenhum acordo é feito.</segment>
    <segment id="41">Cena 5 - Itaquerão  Vestido com a camisa da seleção brasileira</segment>
    <segment id="42">, Lula</segment>
    <segment id="43">sese prepara para bater um pênalti.</segment>
    <segment id="44">Toma distância.</segment>
    <segment id="45">O estádio</segment>
    <segment id="46">, lotado</segment>
    <segment id="47">, está em silêncio.</segment>
    <segment id="48">Com exceção de um guaxinim</segment>
    <segment id="49">, que narra a partida.</segment>
    <segment id="50">Confiante</segment>
    <segment id="51">, o presidente</segment>
    <segment id="52">sese aproxima da bola e chuta forte</segment>
    <segment id="53">, no ângulo.</segment>
    <segment id="54">Arthur Lira defende.</segment>
    <segment id="55">Colunas e BlogsReceba no seu email uma seleção de colunas e blogs da Folha</segment>
    <segment id="56">; exclusiva para assinantes.</segment>
    <segment id="57">Carregando...</segment>
    <segment id="58">Cena 5 - gabinete presidencial</segment>
    <segment id="59">Lula caminha na penumbra.</segment>
    <segment id="60">Há muita fumaça</segment>
    <segment id="61">, quadros rasgados nas paredes</segment>
    <segment id="62">, goteiras caindo do teto.</segment>
    <segment id="63">Vidros quebrados.</segment>
    <segment id="64">Quando o campo de visão é aberto</segment>
    <segment id="65">, vê-se</segment>
    <segment id="66">se Arthur Lira sentado na cadeira presidencial.</segment>
    <segment id="67">Arthur Lira diz: "</segment>
    <segment id="68">Cada decepção e cada rejeição te trouxeram até aqui.</segment>
    <segment id="69">Até este momento.</segment>
    <segment id="70">Não deixe nada te distrair".</segment>
    <segment id="71">Lula responde: "</segment>
    <segment id="72">Eu poderia estar em vários lugares</segment>
    <segment id="73">, companheiro.</segment>
    <segment id="74">Mas só quero estar aqui com você".</segment>
    <segment id="75">Lula e Arthur Lira caminham para um acordo.</segment>
    <segment id="76">Mas, ao estenderem os braços</segment>
    <segment id="77">, os dois percebem que seus dedos viraram linguiça e são grandes demais para permitirem aperto de mãos.</segment>
    <segment id="78">Em vertigem</segment>
    <segment id="79">, Lula tropeça e cai num arcabouço fiscal infinito.</segment>
  </rst>
</analysis>