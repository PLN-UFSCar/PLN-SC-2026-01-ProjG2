  <rst>
    <segment id="1">Gente que come mocotó é puro mocotó</segment>
    <segment id="2">, anunciava uma conhecida marca desse produto industrializado nos anos 1970 e 1980.</segment>
    <segment id="3">Mas a receita tradicional do tempo do Brasil Colônia feita à base da canela e do pé do boi</segment>
    <segment id="4">, considerada uma das mais nutritivas refeições</segment>
    <segment id="5">, não saiu de moda.</segment>
    <segment id="6">Apenas deu lugar ao colágeno hidrolisado.</segment>
    <segment id="7">O novo pote da "fonte da juventude" hoje é facilmente encontrado à venda em forma de pó ou cápsulas.</segment>
    <segment id="8">Conhecida</segment>
    <segment id="9">por ser</segment>
    <segment id="10">um suplemento antienvelhecimento</segment>
    <segment id="11">, responsável por fornecer estrutura</segment>
    <segment id="12">, firmeza e elasticidade à pele e fortalecer os ossos</segment>
    <segment id="13">, tendões e ligamentos</segment>
    <segment id="14">, essa proteína concentrada</segment>
    <segment id="15">, considerada essencial ao corpo humano</segment>
    <segment id="16">, por ser considerada alimento</segment>
    <segment id="17">, é comercializada sem a necessidade de receita médica.</segment>
    <segment id="18">Jennifer Aniston</segment>
    <segment id="19">, garota-propaganda da Vital Proteins</segment>
    <segment id="20">, da Nestlé</segment>
    <segment id="21">, que compra colágeno produzido no Brasil - DivulgaçãoComo cadeia de fornecimento de matéria-prima</segment>
    <segment id="22">, o Brasil hoje já tem 15% mais bois do que gente</segment>
    <segment id="23">, e os rebanhos crescem rapidamente</segment>
    <segment id="24">, segundo dados do IBGE (Instituto Brasileiro de Geografia e Estatística) de 2022</segment>
    <segment id="25">, divulgados no último mês de setembro.</segment>
    <segment id="26">E como</segment>
    <segment id="27">como do boi até o berro é aproveitado em trilhas de filmes</segment>
    <segment id="28">, novelas e festas de peão</segment>
    <segment id="29">, o país não ficou de fora de um dos mercados mais rentáveis dos últimos anos: o de colágeno concentrado.</segment>
    <segment id="30">O valor comercial dessa proteína não era novidade aqui nem na Europa do século 19.</segment>
    <segment id="31">A Rousselot</segment>
    <segment id="32">, por exemplo</segment>
    <segment id="33">, hoje braço da Darling Ingredients</segment>
    <segment id="34">, uma das grandes do mundo em soluções à base de colágeno</segment>
    <segment id="35">, já trabalhava industrialmente com a molécula do produto desde ao menos 1891</segment>
    <segment id="36">, na produção de gelatina a partir da pele</segment>
    <segment id="37">, do couro e de ossos de bezerros</segment>
    <segment id="38">, aves</segment>
    <segment id="39">, porcos e até de peixes.</segment>
    <segment id="40">Aqui no país</segment>
    <segment id="41">, quando ainda pertencia à Vion</segment>
    <segment id="42">, a Rousselot comprou em 2008 as fábricas da Rebiére Gelatinas</segment>
    <segment id="43">, em Amparo</segment>
    <segment id="44">, na região de Campinas</segment>
    <segment id="45">, e em Presidente Epitácio</segment>
    <segment id="46">, extremo oeste de São Paulo</segment>
    <segment id="47">, na divisa com o Mato Grosso do Sul.</segment>
    <segment id="48">Atualmente pertencente à norte-americana Darling</segment>
    <segment id="49">, a antiga multinacional europeia</segment>
    <segment id="50">sese juntou agora à Gelnex</segment>
    <segment id="51">, que tinha fábricas em Goiás</segment>
    <segment id="52">, no Tocantins</segment>
    <segment id="53">, em Mato Grosso</segment>
    <segment id="54">, no Paraguai e nos Estados Unidos.</segment>
    <segment id="55">A empresa catarinense foi comprada pela multinacional por cerca de R$ 6 bilhões</segment>
    <segment id="56">, em negócio finalizado neste ano.</segment>
    <segment id="57">A JBS, gigante mundial de produção de proteína animal</segment>
    <segment id="58">, também entrou nessa corrida pela "fonte da juventude".</segment>
    <segment id="59">A empresa começou a produzir no segundo semestre do ano passado peptídeos de colágeno e gelatina a partir da pele de bovinos da cadeia de produção da empresa.</segment>
    <segment id="60">O investimento no negócio foi de R$ 400 milhões</segment>
    <segment id="61">, de olho em um mercado que movimenta US$ 4 bilhões e que cresceu acima de 15% anualmente nos últimos cinco anos</segment>
    <segment id="62">, segundo a consultoria americana Allied Market Research.</segment>
    <segment id="63">Construção da unidade da JBS que produz colágeno</segment>
    <segment id="64">, em Presidente Epitácio (SP)</segment>
    <segment id="65">;</segment>
    <segment id="66">fábrica foi inaugurada em agosto de 2022 - Cava Engenharia/DivulgaçãoA nova planta fabril</segment>
    <segment id="67">, reformada a partir de um antigo frigorífico em Presidente Epitácio</segment>
    <segment id="68">, produz peptídeos e gelatina para as indústrias alimentícia</segment>
    <segment id="69">, farmacêutica e de cosméticos.</segment>
    <segment id="70">Os peptídeos de colágeno são minúsculas partículas de proteína que agregam amionoácidos e ajudam na hidratação da pele</segment>
    <segment id="71">, redução de rugas</segment>
    <segment id="72">, regeneração de cartilagem e combate à perda de massa muscular.</segment>
    <segment id="73">"É uma empresa que já nasce grande</segment>
    <segment id="74">, sese posicionando entre os três maiores ‘players’ do mercado</segment>
    <segment id="75">, com 10% do mercado global de peptídeos e gelatina de pele bovina"</segment>
    <segment id="76">, contou Claudia Yamana</segment>
    <segment id="77">, diretora da nova empresa do grupo</segment>
    <segment id="78">, a Genu-In.</segment>
    <segment id="79">As maiores concorrentes da brasileira são a alemã Gelita e a própria Rousselot.</segment>
    <segment id="80">Todas têm operações no Brasil.</segment>
    <segment id="81">Segundo Thaise Mendes</segment>
    <segment id="82">, presidente da Abiad (Associação Brasileira da Indústria de Alimentos para Fins Especiais e Congêneres)</segment>
    <segment id="83">, "é interessante observar</segment>
    <segment id="84">comocomo o colágeno ganhou protagonismo na busca por saúde e bem estar nos últimos anos".  "</segment>
    <segment id="85">O mercado de suplementos de colágeno está em ascensão.</segment>
    <segment id="86">As pessoas estão cada vez mais conscientes dos benefícios que a proteína pode trazer para o bem estar geral do corpo</segment>
    <segment id="87">, com impacto positivo na saúde óssea e na prevenção do envelhecimento precoce.</segment>
    <segment id="88">"</segment>
    <segment id="89">Conheça os hidratantes avaliados pela seção Folha ProvaMais    novamente         de   de  de  representando um  "</segment>
    <segment id="90">Outro ponto importante é que</segment>
    <segment id="91">, à medida que o interesse pelo envelhecimento saudável continua a crescer</segment>
    <segment id="92">, o mercado</segment>
    <segment id="93">sese adequa para atender a essa demanda.</segment>
    <segment id="94">Isso representa um momento importante para a indústria</segment>
    <segment id="95">, pois</segment>
    <segment id="96">pois vemos mais pessoas priorizando a saúde e bem-estar à longo prazo.</segment>
    <segment id="97">O colágeno</segment>
    <segment id="98">, nesse contexto</segment>
    <segment id="99">, integra-</segment>
    <segment id="100">sese a essa tendência.</segment>
    <segment id="101">"</segment>
    <segment id="102">De acordo com dados do IBGE</segment>
    <segment id="103">, no ano passado em comparação com 2021</segment>
    <segment id="104">, o setor registrou um crescimento de 2</segment>
    <segment id="105">,4% na produção</segment>
    <segment id="106">, o que representa o valor total de R$ 3 bilhões.</segment>
    <segment id="107">Segundo o Euromonitor International</segment>
    <segment id="108">, em 2022</segment>
    <segment id="109">, o mercado global de suplementos para saúde das articulações e dos ossos atingiu a marca de US$ 10 bilhões</segment>
    <segment id="110">, cerca de R$ 50 bilhões.</segment>
    <segment id="111">Existe ainda uma projeção de aumento de 20% nas vendas de suplementos nos Estados Unidos para os próximos três anos.</segment>
    <segment id="112">Nos últimos anos</segment>
    <segment id="113">, o mercado de suplementos alimentares com um todo experimentou um crescimento notável</segment>
    <segment id="114">, mesmo durante e após a pandemia de Covid-19</segment>
    <segment id="115">, a tendência de alta demanda persistiu.</segment>
    <segment id="116">Segundo pesquisa de mercado "Hábitos de Consumo de Suplementos Alimentares"</segment>
    <segment id="117">, da Abiad</segment>
    <segment id="118">, o colágeno é amplamente procurado no Brasil.</segment>
    <segment id="119">"</segment>
    <segment id="120">Entre a variedade de suplementos alimentares disponíveis</segment>
    <segment id="121">, o colágeno</segment>
    <segment id="122">sese destacou com um crescimento de consumo de 167%"</segment>
    <segment id="123">, completa Thaise.</segment>
    <segment id="124">Folha MercadoReceba no seu email o que de mais importante acontece na economia</segment>
    <segment id="125">; aberta para não assinantes.</segment>
    <segment id="126">Carregando...</segment>
    <segment id="127">Chorume e pressão ambiental</segment>
    <segment id="128">A Folha esteve no ano passado e neste ano em frente às unidades da Rousselot e da JBS que processam a proteína em Presidente Epitácio.</segment>
    <segment id="129">Numa área rural nas proximidades do imponente rio Paraná</segment>
    <segment id="130">, onde ambas unidades são praticamente vizinhas</segment>
    <segment id="131">, um cheiro de cadáver putrefato anuncia a chegada de caminhões das mais diversas regiões do país</segment>
    <segment id="132">, principalmente do norte e do centro-oeste.</segment>
    <segment id="133">São cargas de carcaças de gado que estacionam no "chorume" antes de ganhar autorização para entrar na fábrica.</segment>
    <segment id="134">Enquanto o líquido escuro de alto nível poluidor proveniente de matérias orgânicas em putrefação é secado das carretas para um poço local</segment>
    <segment id="135">, motoristas vindos de Rondônia</segment>
    <segment id="136">, do sul do Pará</segment>
    <segment id="137">, de Mato Grosso ou da vizinha sul-matogrossense Bataguassu tiram cochilos de horas e jogam carteado enquanto aguardam sua vez</segment>
    <segment id="138">, que pode levar horas e até mais de um dia.</segment>
    <segment id="139">Segundo reportagens investigativas de um pool britânico que envolveu ONGs</segment>
    <segment id="140">, o jornal The Guardian e a rede ITV News</segment>
    <segment id="141">, dezenas de milhares de cabeças de gado que sustentam essa cadeia produtiva viriam de fazendas envolvidas em desmatamentos da Amazônia</segment>
    <segment id="142">, do cerrado ou até de reservas indígenas.</segment>
    <segment id="143">Leia maisComo saúde da pele pode ajudar a prever doenças Joanna Moura:</segment>
    <segment id="144">A verdade incômoda de envelhecer na internet</segment>
    <segment id="145">Como promover um boom de colágeno em peles maduras</segment>
    <segment id="146">Quantos produtos são realmente necessários para cuidar da pele?</segment>
    <segment id="147">Há pressão de alguns parlamentares europeus para aprimorar a produção do produto.</segment>
    <segment id="148">O colágeno</segment>
    <segment id="149">, subproduto da indústria pecuária</segment>
    <segment id="150">, não está sujeito aos mesmos padrões de rastreabilidade que a legislação europeia e britânica prevê para outros produtos ligados ao desmatamento e violações de direitos humanos</segment>
    <segment id="151">, como</segment>
    <segment id="152">como a carne</segment>
    <segment id="153">, a soja e o óleo de palma.</segment>
    <segment id="154">A Gelita</segment>
    <segment id="155">, em resposta à reportagem</segment>
    <segment id="156">, afirmou estar "comprometida com a rastreabilidade em toda a sua cadeia de suprimentos".</segment>
    <segment id="157">"</segment>
    <segment id="158">A empresa utiliza diversas tecnologias e adota as melhores práticas de mercado.</segment>
    <segment id="159">Hoje, é possível afirmar que as matérias-primas utilizadas pela Gelita na fabricação de colágeno</segment>
    <segment id="160">, fabricadas em solo brasileiro</segment>
    <segment id="161">, não são oriundas da região amazônica"</segment>
    <segment id="162">, diz a nota.</segment>
    <segment id="163">Segundo a empresa</segment>
    <segment id="164">, seu mais recente Relatório de Sustentabilidade lista "ações concretas em prol da proteção do meio ambiente e do desenvolvimento sustentável".</segment>
    <segment id="165">A Folha tentou por quase três meses entrevistar diretores de JBS e da Rousselot</segment>
    <segment id="166">, masmas não obteve resposta positiva das respectivas assessorias de imprensa.</segment>
    <segment id="167">À imprensa inglesa</segment>
    <segment id="168">, por exemplo</segment>
    <segment id="169">, a Nestlé</segment>
    <segment id="170">, dona da marca Vital Proteins</segment>
    <segment id="171">, informou ter entrado em contato com seus fornecedores para investigar mais a fundo a origem dos produtos no Brasil.</segment>
    <segment id="172">"E que está tomando medidas para garantir que seus produtos sejam livres de desmatamento até 2025.</segment>
    <segment id="173">"  Também citada pela reportagem britânica</segment>
    <segment id="174">, a JBS informou que suas compras são "totalmente compatíveis" com os protocolos de aquisição e monitoramento da cadeia de produção.</segment>
    <segment id="175">Como parte da iniciativa Todas</segment>
    <segment id="176">, a Folha presenteia mulheres com dois meses de assinatura digital grátis</segment>
  </rst>
</analysis>