    <segment id="614">Mas, enfim</segment>
    <segment id="615">, quais são os resultados disso</segment>
    <segment id="616">, que eu imagino e o que eu já estou vendo algumas evidências?</segment>
    <segment id="617">É que o partido vai focar em mulheres que trazem sozinhas muitos votos ou em pessoas negras que trazem sozinhas muitos votos.</segment>
    <segment id="618">Ou seja</segment>
    <segment id="619">, vai investir em pessoas que já têm visibilidade.</segment>
