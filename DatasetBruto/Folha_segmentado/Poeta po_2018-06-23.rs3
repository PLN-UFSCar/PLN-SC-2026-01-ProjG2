  <rst>
    <segment id="1">A 34 vai publicar</segment>
    <segment id="2">, em novembro</segment>
    <segment id="3">, a primeira antologia do poeta português Manuel António Pina no Brasil —a organização é de Leonardo Gandolfi</segment>
    <segment id="4">, poeta e professor de literatura portuguesa da Unifesp.</segment>
    <segment id="5">O livro deve sair em novembro</segment>
    <segment id="6">, quando autor que venceu o prêmio Camões em 2011</segment>
    <segment id="7">, um ano antes de morrer</segment>
    <segment id="8">, completaria 75 anos.</segment>
    <segment id="9">Pina foi um dos principais escritores portugueses contemporâneos.</segment>
    <segment id="10">Seus livros de poesia incluem</segment>
    <segment id="11">“</segment>
    <segment id="12">O Pássaro da Cabeça” (1983)</segment>
    <segment id="13">, “Nenhum Sítio” (1984) e “Atropelamento e Fuga” (2001)</segment>
    <segment id="14">, entre outros.</segment>
    <segment id="15">Inédito no Brasil</segment>
    <segment id="16">, ele também foi autor de teatro e atuou</segment>
    <segment id="17">comocomo cronista na imprensa lusitana.  RÚSSIA</segment>
    <segment id="18">A editora paulistana também publicará</segment>
    <segment id="19">, em breve</segment>
    <segment id="20">, uma nova tradução de “Humilhados e Ofendidos”</segment>
    <segment id="21">, de Dostoiévski.</segment>
    <segment id="22">A tradutora é Fátima Bianchi.</segment>
    <segment id="23">É um dos livros que o russo escreveu após voltar do exílio na Sibéria.</segment>
    <segment id="24">Ilustração de Odilon Moraes em seu novo livro</segment>
    <segment id="25">, ‘Olavo’ (ed. Jujuba)</segment>
    <segment id="26">, que conta a história de uma criança triste  - Reprodução   BUUU!</segment>
    <segment id="27">Um levantamento inédito da Nielsen mostra um crescimento sólido ano a ano das vendas dos livros de suspense e terror no Brasil.</segment>
    <segment id="28">De 2016 a 2018</segment>
    <segment id="29">, o número de exemplares comercializados saltou 17% e 18% a cada ano.</segment>
    <segment id="30">BUUU!</segment>
    <segment id="31">2</segment>
    <segment id="32">Já em faturamento</segment>
    <segment id="33">, o salto foi de 31% de 2016 para 2017</segment>
    <segment id="34">, e de 17</segment>
    <segment id="35">,6% de 2017 para 2018.</segment>
    <segment id="36">PRÊMIO</segment>
    <segment id="37">A Record comprou os direitos de “Less”</segment>
    <segment id="38">, de Andrew Sean Greer</segment>
    <segment id="39">, ganhador do Pulitzer de ficção deste ano.</segment>
    <segment id="40">O livro conta a história de um romancista cinquentão deixado pelo namorado —que ainda o convida para o seu casamento— e resolve viajar o mundo.</segment>
    <segment id="41">JAPÃO</segment>
    <segment id="42">A Autêntica lança “Patriotismo”</segment>
    <segment id="43">, conto de Yukio Mishima (1925-1970) inédito no país</segment>
    <segment id="44">, em tradução direta do japonês.</segment>
    <segment id="45">O conto narra história de um tenente que não vai a combate por estar de casamento marcado.</segment>
    <segment id="46">AFROFUTURISMO</segment>
    <segment id="47">A HarperCollins aproveita a vinda de Colson Whitehead à Flip para lançar “</segment>
    <segment id="48">A Intuicionista”</segment>
    <segment id="49">, romance de 1999 do autor.</segment>
    <segment id="50">É uma obra de ficção especulativa com viés afrofuturista</segment>
    <segment id="51">, tema que anda em alta no último ano.  AFROFUTURISMO 2</segment>
    <segment id="52">Numa realidade fantástica</segment>
    <segment id="53">, os elevadores são inspecionados por dois grupos em disputa: os Empiristas</segment>
    <segment id="54">, que verificam mecanicamente</segment>
    <segment id="55">sese os elevadores funcionam</segment>
    <segment id="56">, e os Intuicionistas</segment>
    <segment id="57">, que podem simplesmente intuir</segment>
    <segment id="58">sese há algum defeito.</segment>
    <segment id="59">Um elevador cai no turno da protagonista</segment>
    <segment id="60">, Lila Mae Watson</segment>
    <segment id="61">, que pertence ao segundo grupo e é a primeira negra no departamento.</segment>
  </rst>
</analysis>