  <rst>
    <segment id="1">Doze dias após receber o ex-deputado Jean Wyllys ao lado do presidente Luiz Inácio Lula da Silva (PT)</segment>
    <segment id="2">, o ministro Paulo Pimenta não sabe ainda qual função que ele exercerá na Secretaria de Comunicação Social.</segment>
    <segment id="3">Segundo Pimenta</segment>
    <segment id="4">, Wyllys ainda não começou a trabalhar e não há data</segment>
    <segment id="5">para que</segment>
    <segment id="6">para que isso aconteça.</segment>
    <segment id="7">Questionado</segment>
    <segment id="8">sese é 100% certo que o ex-deputado assumirá cargo na secretaria</segment>
    <segment id="9">, o ministro não respondeu.</segment>
    <segment id="10">Ex-deputado Jean Wyllys foi recebido por Lula e Paulo Pimenta em 6 de julho</segment>
    <segment id="11">, em Brasília.</segment>
    <segment id="12">( Foto: Cláudio Kbene/PR ) - PR</segment>
    <segment id="13">, divulgaçãoNo dia 6 de julho</segment>
    <segment id="14">, Pimenta retuitou a foto ao lado de Wyllys e do presidente</segment>
    <segment id="15">, em que o ex-deputado fala em reconstruir o Brasil pela comunicação.</segment>
    <segment id="16">Wyllys mantém relação próxima com a primeira-dama</segment>
    <segment id="17">, Rosângela da Silva</segment>
    <segment id="18">, a Janja</segment>
    <segment id="19">, que o recebeu em seu gabinete no Palácio do Planalto.</segment>
    <segment id="20">No final de semana passado</segment>
    <segment id="21">, Wyllys</segment>
    <segment id="22">sese envolveu em um bate-boca com o governador do Rio Grande do Sul</segment>
    <segment id="23">, Eduardo Leite (PSDB)</segment>
    <segment id="24">, a quem criticou pela decisão de manter as escolas cívico-militares do RS.</segment>
    <segment id="25">Jean disse que "gays com homofobia internalizada em geral desenvolvem libido e fetiche em relação ao autoritarismo e aos uniformes".</segment>
    <segment id="26">Leite respondeu que lamentava a "ignorância" do ex-deputado e classificou a fala</segment>
    <segment id="27">comocomo "manifestação deprimente e cheia de preconceitos em incontáveis direções".</segment>
    <segment id="28">Pimenta disse ao Painel que não tem opinião sobre a manifestação do possível servidor da Secom.</segment>
    <segment id="29">Wyllys foi eleito três vezes pelo PSOL</segment>
    <segment id="30">, masmas desistiu do terceiro mandato em 2019 e saiu do Brasil alegando perseguição política e temendo por sua segurança após o assassinato de Marielle Franco.</segment>
    <segment id="31">Em 2021</segment>
    <segment id="32">, ele se</segment>
    <segment id="33">se filiou ao PT e</segment>
    <segment id="34">, passadas das eleições de 2022</segment>
    <segment id="35">, retornou ao Brasil.</segment>
  </rst>
</analysis>