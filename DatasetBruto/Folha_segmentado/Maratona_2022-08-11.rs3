  <rst>
    <segment id="1">Diz o ditado que uma imagem vale mais do que mil palavras.</segment>
    <segment id="2">Antes de eu falar sobre a maratona mais difícil do Brasil</segment>
    <segment id="3">, veja a foto abaixo.</segment>
    <segment id="4">Serra do Rio do Rastro</segment>
    <segment id="5">, em Santa Catarina - Anders Marcio Duarte/</segment>
    <segment id="6">DivulgaçãoA estrada em questão é a SC-390</segment>
    <segment id="7">, no trecho que serpenteia a Serra do Rio do Rastro</segment>
    <segment id="8">, entre os municípios de Lauro Muller e Bom Jardim da Serra</segment>
    <segment id="9">, no sul de Santa Catarina.</segment>
    <segment id="10">As curvas fechadas cercadas por cachoeiras e natureza exuberante renderam fama à rodovia</segment>
    <segment id="11">, considerada ponto turístico e cartão-postal catarinense.</segment>
    <segment id="12">O diário britânico "The Guardian" chegou a incluir a SC-390 em uma reportagem sobre estradas espetaculares pouco conhecidas do mundo.</segment>
    <segment id="13">A impressão que</segment>
    <segment id="14">sese tem ao trafegar pela Serra do Rio do Rastro é que ali não deveria existir uma estrada.</segment>
    <segment id="15">As ladeiras são tão íngremes em alguns pontos que o asfalto precisa ser substituído por um concreto com ranhuras.</segment>
    <segment id="16">Isso evitar que os pneus dos carros girem em falso durante a subida.</segment>
    <segment id="17">É nesse cenário repleto de pirambeiras que acontece a maratona mais difícil do Brasil.</segment>
    <segment id="18">A próxima edição da Serra do Rio do Rastro Marathon acontece nos dias 6 e 7 de maio de 2023.</segment>
    <segment id="19">Apesar de acontecer só no ano que vem</segment>
    <segment id="20">, as inscrições para a prova abrem nesta quinta-feira (11).</segment>
    <segment id="21">A boa notícia é que os atletas terão nove meses para treinar para a corrida.</segment>
    <segment id="22">A parte ruim é que treinar pode não ser suficiente.</segment>
    <segment id="23">"</segment>
    <segment id="24">Você corre a prova com as pernas</segment>
    <segment id="25">, com a cabeça e com o coração.</segment>
    <segment id="26">Você precisa respeitar a serra</segment>
    <segment id="27">, masmas lembrar que a missão é difícil</segment>
    <segment id="28">, masmas não impossível"</segment>
    <segment id="29">, conta a médica e maratonista Érika Ferrari</segment>
    <segment id="30">, que completou a prova em 2018.</segment>
    <segment id="31">"</segment>
    <segment id="32">Eu via pessoas com experiência em Ironman que olhavam para a serra e diziam que desistiriam.</segment>
    <segment id="33">Apesar do preparo físico exemplar</segment>
    <segment id="34">, elas</segment>
    <segment id="35">sese deixavam intimidar pela ladeira".</segment>
    <segment id="36">Só sobe?</segment>
    <segment id="37">Nos primeiros 30 km</segment>
    <segment id="38">, o atleta</segment>
    <segment id="39">sese depara com subidas e descidas – mais subidas do que descidas</segment>
    <segment id="40">, é bem verdade.</segment>
    <segment id="41">A serra do cartão postal está reservada para os últimos 12 km</segment>
    <segment id="42">, justamente quando os atletas já estão cansados pela distância e pelo clima imprevisível da região.</segment>
    <segment id="43">"</segment>
    <segment id="44">Em 2018</segment>
    <segment id="45">, corri com temperatura de 12 graus</segment>
    <segment id="46">, debaixo de chuva.</segment>
    <segment id="47">No percurso</segment>
    <segment id="48">, vi pessoas desistindo por hipotermia e</segment>
    <segment id="49">, após a linha de chegada</segment>
    <segment id="50">, os atletas eram recebidos com chocolate quente</segment>
    <segment id="51">, em vez do tradicional isotônico"</segment>
    <segment id="52">, relembra Érika.</segment>
    <segment id="53">"</segment>
    <segment id="54">No ano anterior</segment>
    <segment id="55">, o calor era de 30 graus e o risco era de insolação".</segment>
    <segment id="56">Requintes de crueldade  Se o percurso desafiador não fosse o suficiente</segment>
    <segment id="57">, a organização do evento também adota limites de tempo dentro da prova.</segment>
    <segment id="58">Os primeiros 29</segment>
    <segment id="59">,5 km devem ser percorridos em até 3h50min.</segment>
    <segment id="60">A marca dos 37km precisa ser vencida em 5h15min.</segment>
    <segment id="61">E quem não cruzar a linha de chegada em até 6h20min é desclassificado e obrigado a terminar a corrida em uma van.</segment>
    <segment id="62">"</segment>
    <segment id="63">Isso obriga o corredor a</segment>
    <segment id="64">sese concentrar em um trecho de cada vez.</segment>
    <segment id="65">São três corridas dentro de uma só"</segment>
    <segment id="66">, explica Érica</segment>
    <segment id="67">, que completou a prova em 5h21.</segment>
    <segment id="68">Menos de três meses antes</segment>
    <segment id="69">, ela correra a maratona de Vancouver</segment>
    <segment id="70">, no Canadá</segment>
    <segment id="71">, em 4h05.</segment>
    <segment id="72">A diferença de 75 minutos entre uma prova e outra está nas ladeiras da Serra do Rio do Rastro.</segment>
    <segment id="73">Para explorar ainda mais a mística em torno da prova</segment>
    <segment id="74">, a organização também criou a categoria "</segment>
    <segment id="75">Missão dos Guardiões".</segment>
    <segment id="76">Nela, o atleta precisa completar 25 km no primeiro dia e 42 km no segundo para receber uma medalha especial.</segment>
    <segment id="77">Apenas 100 pessoas podem</segment>
    <segment id="78">sese inscrever para essa categoria.</segment>
    <segment id="79">Serviço</segment>
    <segment id="80">As inscrições para a edição 2023 da prova abrem nesta quinta-feira (11).</segment>
    <segment id="81">A organização espera até 2 mil atletas</segment>
    <segment id="82">, divididos nas provas de 12 km</segment>
    <segment id="83">, 25 km e 42 km.</segment>
    <segment id="84">Há ainda a possibilidade de percorrer 40 km de bicicleta</segment>
    <segment id="85">, sem divisão por categoria.</segment>
    <segment id="86">O kit para a maratona custa 5 x R$ 93 + taxas.</segment>
    <segment id="87">Para detalhes do regulamento e valor de todos os kits</segment>
    <segment id="88">, consulte o site https://riodorastromarathon.com.br/.</segment>
    <segment id="89">As inscrições podem ser feitas no site vemcorrer.com.</segment>
  </rst>
</analysis>