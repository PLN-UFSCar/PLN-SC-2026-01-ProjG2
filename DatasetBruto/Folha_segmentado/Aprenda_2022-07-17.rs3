  <rst>
    <segment id="1">O bolo de noiva pernambucano</segment>
    <segment id="2">, aquela maravilha inspirada no bolo inglês e que é presença obrigatória nos casamentos no Recife</segment>
    <segment id="3">, está prestes a virar Patrimônio Cultural Imaterial de Pernambuco.</segment>
    <segment id="4">Foi o que li recentemente em uma matéria no site da Uninassau.</segment>
    <segment id="5">Quem vai a Recife</segment>
    <segment id="6">, tem que provar.</segment>
    <segment id="7">Eu mesmo trouxe um bolo inteiro em minha última viagem</segment>
    <segment id="8">, é bom demais.  Fatia de bolo de noiva pernambucano - Divulgação</segment>
    <segment id="9">O bolo tem massa escura e densa</segment>
    <segment id="10">, graças ao uso de uva passa e ameixa seca.</segment>
    <segment id="11">O sabor adocicado vem do vinho moscatel e o arremate é feito com o glacê real</segment>
    <segment id="12">, doce e azedinho.</segment>
    <segment id="13">E dizem que ele ajuda a arrumar marido</segment>
    <segment id="14">, pense!</segment>
    <segment id="15">No Recife é possível degustá-lo em docerias e cafeterias</segment>
    <segment id="16">, masmas aqui em SP</segment>
    <segment id="17">, só fazendo mesmo.</segment>
    <segment id="18">Por isso</segment>
    <segment id="19">, publico abaixo a receita que fiz para o casamento de uma amiga há dez anos --e que deu certo.</segment>
    <segment id="20">É provar e</segment>
    <segment id="21">sese encantar</segment>
    <segment id="22">, bora aprender a receita!</segment>
    <segment id="23">•</segment>
    <segment id="24">Siga o Comes e Bebes no Instagram para mais receitas.</segment>
    <segment id="25">Bolo de Noiva Pernambucano</segment>
    <segment id="26">A receita rende muito</segment>
    <segment id="27">, pode fazer metade.</segment>
    <segment id="28">Uva passa e pasta de ameixa utilizadas no preparo do bolo de noiva pernambucano - FolhaPress  Deixe 500 g de uva passa de molho em 350 ml de vinho moscatel por 2 dias na geladeira.</segment>
    <segment id="29">Bata no liquidificador 500 g de ameixa seca com um pouco de água e adicione 1 xícara de açúcar.</segment>
    <segment id="30">Leve ao fogo para ferver por 3 minutos</segment>
    <segment id="31">, mexendo sempre.</segment>
    <segment id="32">Deixe esfriar.</segment>
    <segment id="33">Para a massa: bata 500 g de manteiga</segment>
    <segment id="34">, 500 g de acúcar e meia colher de sobremesa de sal até ficar esbranquiçada.</segment>
    <segment id="35">Junte 9 gemas (uma de cada vez) e depois meio litro de leite e 500 g de farinha de trigo.</segment>
    <segment id="36">Junte 400 g de achocolatado (ou chocolate em pó) e bata até ficar uniforme.</segment>
    <segment id="37">A massa do bolo de noiva pernambucano - FolhaPress  Adicione a pasta de ameixa</segment>
    <segment id="38">, 500 g de frutas cristalizadas (opcional)</segment>
    <segment id="39">, a uva passa hidratada e 1 xícara</segment>
    <segment id="40">desse vinho da uva</segment>
    <segment id="41">.</segment>
    <segment id="42">Acrescente 9 claras em neve delicadamente e disponha em formas untadas com manteiga e farinha.</segment>
    <segment id="43">Asse em forno médio-alto por 45 minutos e mais 30 com fogo baixo</segment>
    <segment id="44">, até enfiar o palito e ele sair limpo.</segment>
    <segment id="45">Espere esfriar totalmente para começar a montagem.</segment>
    <segment id="46">Essa receita rende muitos bolos</segment>
    <segment id="47">, pode fazer metade.</segment>
    <segment id="48">Preparo do glacê do bolo de noiva pernambucano - FolhaPress  Para o glacê real: junte 2 claras</segment>
    <segment id="49">, suco de 1 limão</segment>
    <segment id="50">, 150 g de Glaçúcar e bata por 4 minutos</segment>
    <segment id="51">, até ela ficar firme e não soltar da espátula.</segment>
    <segment id="52">Impermeabilize o bolo com uma pasta de clara (pasteurizada)</segment>
    <segment id="53">, limão e açúcar</segment>
    <segment id="54">, batidos na mão (fica líquido) e deixe secar por umas 4 horas.</segment>
    <segment id="55">Decoração com glacê real do bolo de noiva pernambucano - FolhaPress</segment>
    <segment id="56">Faça o mármore pegando parte do glacê real e adicionando mais açúcar refinado</segment>
    <segment id="57">, batendo com a mão até ele ficar</segment>
    <segment id="58">comocomo uma massinha modelável.</segment>
    <segment id="59">Cubra o bolo com esse mármore e depois confeite usando o glacê real.</segment>
    <segment id="60">Essa técnica do caminho sem fim (com um saco de confeitar e um bico fino) é boa</segment>
    <segment id="61">poispois disfarça imperfeições do mármore.</segment>
    <segment id="62">E sese aplicado diretamente sobre o bolo (naked</segment>
    <segment id="63">, sem o mármore) dá um bonito efeito</segment>
    <segment id="64">, como</segment>
    <segment id="65">como é possível ver na foto acima.</segment>
    <segment id="66">Agradecimentos à banqueteira pernambucana Ana Paiva</segment>
    <segment id="67">, que me ensinou o preparo do glacê real.</segment>
  </rst>
</analysis>