  <rst>
    <segment id="1">O ator Kevin Spacey foi acusado em um processo civil na quarta-feira (9) de agress&amp;atilde</segment>
    <segment id="2">;o sexual na d&amp;eacute</segment>
    <segment id="3">;cada de 1980 pelo ator Anthony Rapp e uma segunda pessoa n&amp;atilde</segment>
    <segment id="4">;o identificada</segment>
    <segment id="5">, quando ambos os queixosos tinham cerca de 14 anos.</segment>
    <segment id="6">O processo</segment>
    <segment id="7">, aberto no tribunal estadual de Nova York em Manhattan</segment>
    <segment id="8">, refere-</segment>
    <segment id="9">sese ao mesmo suposto incidente que Rapp relatou pela primeira vez em uma entrevista ao BuzzFeed de outubro de 2017 que desencadeou a queda de Spacey em Hollywood.</segment>
    <segment id="10">Spacey n&amp;atilde</segment>
    <segment id="11">;o respondeu imediatamente a um pedido de coment&amp;aacute</segment>
    <segment id="12">;rio.</segment>
    <segment id="13">Kevin Spacey   novamente         de   de  de  representando um</segment>
    <segment id="14">O ator</segment>
    <segment id="15">, que ganhou o Oscar pelos filmes &amp;quot</segment>
    <segment id="16">;Beleza Americana&amp;quot</segment>
    <segment id="17">; e &amp;quot</segment>
    <segment id="18">;Os Suspeitos&amp;quot</segment>
    <segment id="19">; e um Globo de Ouro pelo drama pol&amp;iacute</segment>
    <segment id="20">;tico &amp;quot</segment>
    <segment id="21">;House of Cards&amp;quot</segment>
    <segment id="22">;, sese retirou da vida p&amp;uacute</segment>
    <segment id="23">;blica nos &amp;uacute</segment>
    <segment id="24">;ltimos tr&amp;ecirc</segment>
    <segment id="25">;s anos.</segment>
    <segment id="26">Spacey em 2017 disse que n&amp;atilde</segment>
    <segment id="27">;o sese lembrava do encontro que Rapp descreveu</segment>
    <segment id="28">, masmas acrescentou &amp;ldquo</segment>
    <segment id="29">;sese eu me comportasse</segment>
    <segment id="30">comocomo ele descreve</segment>
    <segment id="31">, devo a ele as mais sinceras desculpas pelo que teria sido um comportamento b&amp;ecirc</segment>
    <segment id="32">;bado profundamente impr&amp;oacute</segment>
    <segment id="33">;prio&amp;rdquo</segment>
    <segment id="34">;.</segment>
    <segment id="35">House of Cards</segment>
    <segment id="36">6ª Temporada   novamente         de   de  de  representando um  Spacey</segment>
    <segment id="37">, agora com 61 anos</segment>
    <segment id="38">, sese assumiu gay em 2017.</segment>
    <segment id="39">Rapp, mais conhecido por estrelar o musical da Broadway &amp;quot</segment>
    <segment id="40">;Rent&amp;quot</segment>
    <segment id="41">;, disse na a&amp;ccedil</segment>
    <segment id="42">;&amp;atilde</segment>
    <segment id="43">;o judicial que Spacey &amp;quot</segment>
    <segment id="44">;engatou uma investida sexual indesejada&amp;quot</segment>
    <segment id="45">; com ele quando ele tinha 14 anos</segment>
    <segment id="46">, durante uma festa na casa de Spacey em 1986.</segment>
    <segment id="47">A segunda pessoa</segment>
    <segment id="48">, identificada apenas</segment>
    <segment id="49">comocomo C. D.</segment>
    <segment id="50">, alegou que ele e Spacey fizeram sexo oral e anal e</segment>
    <segment id="51">sese envolveram em outros atos sexuais em v&amp;aacute</segment>
    <segment id="52">;rias ocasi&amp;otilde</segment>
    <segment id="53">;es no in&amp;iacute</segment>
    <segment id="54">;cio dos anos 1980</segment>
    <segment id="55">, quando o querelante tinha aproximadamente 14 anos.</segment>
    <segment id="56">Ambos os homens est&amp;atilde</segment>
    <segment id="57">;o buscando indeniza&amp;ccedil</segment>
    <segment id="58">;&amp;otilde</segment>
    <segment id="59">;es por estresse emocional.</segment>
    <segment id="60">A acusa&amp;ccedil</segment>
    <segment id="61">;&amp;atilde</segment>
    <segment id="62">;o inicial de Rapp</segment>
    <segment id="63">, parte do movimento MeToo contra atos sexuais e m&amp;aacute</segment>
    <segment id="64">; conduta</segment>
    <segment id="65">, fez com que Spacey fosse demitido de &amp;quot</segment>
    <segment id="66">;House of Cards&amp;quot</segment>
    <segment id="67">; e que suas cenas no filme &amp;quot</segment>
    <segment id="68">;Todo o Dinheiro do Mundo&amp;quot</segment>
    <segment id="69">;</segment>
    <segment id="70">fossem refilmadas com o ator Christopher Plummer.</segment>
