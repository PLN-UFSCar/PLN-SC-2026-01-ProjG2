  <rst>
    <segment id="1">Tatiana Weston-Webb</segment>
    <segment id="2">, 23, tornou-</segment>
    <segment id="3">sese neste domingo (20) a primeira surfista do país garantida na Olimpíada de Tóquio-2020</segment>
    <segment id="4">, quando o esporte fará sua estreia nos Jogos.</segment>
    <segment id="5">Ela confirmou sua vaga ao avançar às quartas de final da etapa de Portugal da WSL (Liga Mundial de Surfe)</segment>
    <segment id="6">, ainda em disputa nas águas de Peniche.</segment>
    <segment id="7">Nascida em Porto Alegre e filha de pai inglês e mãe brasileira</segment>
    <segment id="8">, Tatiana vive no Havaí desde os dois anos de idade.</segment>
    <segment id="9">O sonho olímpico motivou a surfista a optar por defender a bandeira do Brasil em vez de a americana.</segment>
    <segment id="10">Sua primeira etapa</segment>
    <segment id="11">comocomo competidora do país foi em maio do ano passado.</segment>
    <segment id="12">Isto é Tatiana Weston-Webb   novamente         de   de  de  representando um    "</segment>
    <segment id="13">Tenho muito orgulho por representar o Brasil</segment>
    <segment id="14">, que foi onde eu nasci e é onde está o meu coração</segment>
    <segment id="15">, sem esquecer de onde eu cresci e que realmente me fez a surfista que sou hoje”</segment>
    <segment id="16">, afirmou.</segment>
    <segment id="17">Atualmente</segment>
    <segment id="18">, ela ocupa a oitava posição do ranking da WSL.</segment>
    <segment id="19">Silvana Lima</segment>
    <segment id="20">, 34, está na 12ª posição da temporada e ainda disputa a sua vaga em Tóquio.</segment>
    <segment id="21">Entre os homens</segment>
    <segment id="22">, os dois representantes serão conhecidos apenas na última etapa do Mundial</segment>
    <segment id="23">, em dezembro</segment>
    <segment id="24">, no Havaí.</segment>
    <segment id="25">Gabriel Medina</segment>
    <segment id="26">, 25, Filipe Toledo</segment>
    <segment id="27">, 24, e Italo Ferreira</segment>
    <segment id="28">, 25, concorrem.</segment>
    <segment id="29">Neste domingo (20)</segment>
    <segment id="30">, Medina perdeu a chance não só de confirmar sua presença no Japão</segment>
    <segment id="31">, masmas também de sair de Portugal com o tricampeonato mundial.</segment>
    <segment id="32">A temporada 2019 de Gabriel Medina   novamente         de   de  de  representando um</segment>
    <segment id="33">Nas oitavas de final</segment>
    <segment id="34">, ele liderava a bateria contra o compatriota Caio Ibelli</segment>
    <segment id="35">, masmas</segment>
    <segment id="36">sese confundiu ao achar que a prioridade de escolha era dele e atrapalhou o adversário na onda.</segment>
    <segment id="37">A interferência foi punida com a anulação de uma das notas da bateria</segment>
    <segment id="38">, e Medina acabou eliminado.</segment>
    <segment id="39">Mesmo que avançasse para as quartas de final</segment>
    <segment id="40">, o desempenho dos rivais o impediria de levar o troféu por antecipação.</segment>
    <segment id="41">Filipe e Italo</segment>
    <segment id="42">, além do sul-africano Jordy Smith e do americano Kolohe Andino</segment>
    <segment id="43">, concorrentes ao título de 2019</segment>
    <segment id="44">, ainda estão vivos na etapa portuguesa</segment>
    <segment id="45">, que deverá ter continuidade na manhã desta segunda (21).</segment>
    <segment id="46">A definição do campeão ocorrerá a partir do dia 8 de dezembro</segment>
    <segment id="47">, na etapa de Pipeline</segment>
    <segment id="48">, no Havaí.</segment>
  </rst>
</analysis>