  <rst>
    <segment id="1">No ano de 2065</segment>
    <segment id="2">, um casal que vive numa fazenda isolada recebe a visita de um desconhecido.</segment>
    <segment id="3">Ele informa que o marido</segment>
    <segment id="4">, vivido por Paul Mescal</segment>
    <segment id="5">, foi selecionado para participar de um misterioso programa espacial.</segment>
    <segment id="6">Em seu lugar</segment>
    <segment id="7">, sua mulher</segment>
    <segment id="8">, papel de Saoirse Ronan</segment>
    <segment id="9">, terá a companhia de um robô semelhante a ele.</segment>
    <segment id="10">Cena do filme &amp;#039</segment>
    <segment id="11">;Intruso&amp;#039</segment>
    <segment id="12">;, de Garth Davis - Divulgação</segment>
    <segment id="13">O drama de ficção científica "Intruso" é dirigido por Garth Davis</segment>
    <segment id="14">, de "Lion" e "Maria Madalena".</segment>
    <segment id="15">Prime Video</segment>
    <segment id="16">, 16 anos</segment>
    <segment id="17">Golpista do Amor</segment>
    <segment id="18">A internet facilitou o surgimento de um novo tipo de vigarista —o "amante serial"</segment>
    <segment id="19">, que usa identidades falsas para seduzir mulheres e limpar suas contas bancárias.</segment>
    <segment id="20">A minissérie belga em quatro episódios "</segment>
    <segment id="21">Golpista do Amor" conta a história de um deles</segment>
    <segment id="22">, que se</segment>
    <segment id="23">se passa por corretor</segment>
    <segment id="24">, jornalista</segment>
    <segment id="25">, cirurgião e piloto de avião para</segment>
    <segment id="26">sese envolver com diversas vítimas.</segment>
    <segment id="27">Até que uma delas resolve</segment>
    <segment id="28">sese vingar e convoca a ajuda de outras.</segment>
    <segment id="29">Um episódio novo toda sexta.  Globo</segment>
    <segment id="30">, 23h15</segment>
    <segment id="31">, 14 anos   Garoto Devora Universo</segment>
    <segment id="32">Com apenas 12 anos</segment>
    <segment id="33">, Eli Bell enfrenta problemas demais</segment>
    <segment id="34">, uma mãe viciada</segment>
    <segment id="35">, um padrasto traficante</segment>
    <segment id="36">, um irmão que não fala e por aí vai.</segment>
    <segment id="37">Mesmo assim</segment>
    <segment id="38">, ele tenta manter o bom senso e o bom humor.</segment>
    <segment id="39">Série australiana baseada no best-seller de Trent Dalton.</segment>
    <segment id="40">Netflix</segment>
    <segment id="41">, 16 anos</segment>
    <segment id="42">Verão Maior Paraná</segment>
    <segment id="43">Durante quatro sextas seguidas</segment>
    <segment id="44">, a emissora exibe ao vivo shows realizados na praia paranaense de Caiobá.</segment>
    <segment id="45">A estreia é com a dupla Hugo e Guilherme.</segment>
    <segment id="46">A apresentação é da Paloma Tocci.  Band</segment>
    <segment id="47">, 21h50</segment>
    <segment id="48">, livre   Agente 86: Bruce e Lloyd Fora de Controle</segment>
    <segment id="49">Dois agentes atrapalhados da C.O.N.T.R.O.L.E. desenvolvem um tecido que torna invisível quem o usa</segment>
    <segment id="50">, atraindo a cobiça e a fúria da organização rival</segment>
    <segment id="51">, a C.A.O.S.  SBT</segment>
    <segment id="52">, 23h15</segment>
    <segment id="53">, 12 anos</segment>
    <segment id="54">Diálogos com Mario Sergio Conti</segment>
    <segment id="55">O jornalista e colunista da Folha conversa com a atriz Ingrid Guimarães</segment>
    <segment id="56">, que acrescentou mais um campeão de bilheteria ao seu já extenso currículo</segment>
    <segment id="57">, a comédia "</segment>
    <segment id="58">Minha Irmã e Eu"</segment>
    <segment id="59">, co-estrelada por Tatá Werneck.</segment>
    <segment id="60">Veja cenas do filme &amp;#039</segment>
