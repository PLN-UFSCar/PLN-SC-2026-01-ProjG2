  <rst>
    <segment id="1">O consórcio AeroGru</segment>
    <segment id="2">, que reúne as empresas Aerom</segment>
    <segment id="3">, HTB, FBS e TSEA</segment>
    <segment id="4">, assinou contrato com a Marcopolo Rail para a produção de três trens para operar o People Mover do aeroporto internacional de Guarulhos.</segment>
    <segment id="5">O sistema que vai interligar a Linha 13-Jade da CPTM (Companhia Paulista de Trens Metropolitanos) ao aeroporto de Guarulhos deve entrar em operação nos primeiros meses de 2024.</segment>
    <segment id="6">Hoje, quem desembarca no terminal 2 do aeroporto precisa pegar um ônibus até a estação de trem da CPTM</segment>
    <segment id="7">, distante 2</segment>
    <segment id="8">,5 quilômetros.</segment>
    <segment id="9">Trem da Marcopolo Rail</segment>
    <segment id="10">, que assinou contrato com consórcio para a produção de composições do People Mover - Divulgação/MarcopoloColunas e BlogsReceba no seu email uma seleção de colunas e blogs da Folha</segment>
    <segment id="11">;</segment>
    <segment id="12">exclusiva para assinantes.</segment>
    <segment id="13">Carregando...</segment>
    <segment id="14">Segundo a Marcopolo</segment>
    <segment id="15">, o contrato prevê o fornecimento de três veículos para o sistema</segment>
    <segment id="16">, compostos por dois carros articulados</segment>
    <segment id="17">, com capacidade de transportar 200 passageiros e funcionamento autônomo.</segment>
    <segment id="18">Em fevereiro</segment>
    <segment id="19">, o então governador</segment>
    <segment id="20">, João Doria (PSDB)</segment>
    <segment id="21">, que já classificou essa distância entre o terminal e a estação de "bizarro"</segment>
    <segment id="22">, anunciou o início das obras do sistema de monotrilho</segment>
    <segment id="23">, masmas os passageiros efetivamente só conseguirão embarcar em 2024</segment>
    <segment id="24">, como</segment>
    <segment id="25">como reportagem da Folha mostrou.</segment>
    <segment id="26">Naquele mês</segment>
    <segment id="27">, o TCU (Tribunal de Contas da União) liberou que as obras fossem iniciadas pela GRU Airport</segment>
    <segment id="28">, responsável pelo aeroporto e por levar adiante o People Mover.</segment>
    <segment id="29">O investimento total no sistema é de R$ 272 milhões</segment>
    <segment id="30">, que serão custeados com recursos da outorga da concessionária —</segment>
    <segment id="31">comocomo diz o próprio TCU</segment>
    <segment id="32">, com recursos públicos.</segment>
    <segment id="33">Expresso para aeroporto de Cumbica (SP) fica vazioMais    novamente         de   de  de  representando um</segment>
    <segment id="34">O contrato foi assinado no início do mês num evento na sede da empresa</segment>
    <segment id="35">, em Caxias do Sul (RS)</segment>
    <segment id="36">, que contou com a presença do ministro Marcelo Sampaio (Infraestrutura).</segment>
    <segment id="37">Os modelos serão produzidos de agora até julho do ano que vem e</segment>
    <segment id="38">, conforme a empresa</segment>
    <segment id="39">, terão modernização das linhas externas.  IMBRÓGLIO</segment>
    <segment id="40">Sem o People Mover</segment>
    <segment id="41">, quem precisa fazer o trajeto entre Cumbica e a estação da Luz conta atualmente com o expresso da linha 13-Jade.</segment>
    <segment id="42">Só que os terminais do aeroporto ficam distantes da estação da CPTM</segment>
    <segment id="43">, o que obriga os usuários a pegarem um dos ônibus gratuitos cedidos pela concessionária para fazer o deslocamento.</segment>
    <segment id="44">A baldeação acaba aumentando o tempo de viagem.</segment>
    <segment id="45">Para ir da estação até o terminal 2</segment>
    <segment id="46">, o mais movimentado do aeroporto</segment>
    <segment id="47">, o ônibus leva quase 10 minutos.</segment>
    <segment id="48">Além de aumentar o tempo de viagem</segment>
    <segment id="49">, há o desconforto dos passageiros que</segment>
    <segment id="50">sese deslocam para os terminais de terem de levar malas normalmente pesadas pelas escadas e dentro dos coletivos.</segment>
  </rst>
</analysis>