  <rst>
    <segment id="1">A jornalista Giuliana Miranda</segment>
    <segment id="2">, que mora em Lisboa há cinco anos e é autora do blog '</segment>
    <segment id="3">Ora Pois'</segment>
    <segment id="4">, indica passeios na capital portuguesa que ainda não foram descobertos pelos turistas.</segment>
    <segment id="5">Mercado de Alvalade "</segment>
    <segment id="6">O espaço é frequentado por moradores do bairro</segment>
    <segment id="7">, que vão atrás de peixes recém-trazidos da costa e vegetais frescos.</segment>
    <segment id="8">Para os turistas</segment>
    <segment id="9">, não faltam opções gastronômicas.</segment>
    <segment id="10">Famoso no Brasil</segment>
    <segment id="11">, o chef Vítor Sobral inaugurou há pouco sua Padaria da Esquina.</segment>
    <segment id="12">Destaque para a broa com fermentação natural.</segment>
    <segment id="13">"</segment>
    <segment id="14">Av. Rio de Janeiro</segment>
    <segment id="15">, 1700-330.</segment>
    <segment id="16">Seg.</segment>
    <segment id="17">a sex.</segment>
    <segment id="18">, das 7h às 15h</segment>
    <segment id="19">; sáb.</segment>
    <segment id="20">, das 7h às 16h</segment>
    <segment id="21">Centro histórico de Carnide "</segment>
    <segment id="22">A região norte da cidade parece pertencer a uma Lisboa antiga</segment>
    <segment id="23">, com comércio de bairro e restaurantes que servem comida farta.</segment>
    <segment id="24">Os prédios baixos e coloridos do local são exemplares de uma arquitetura que já está em extinção no resto da capital.</segment>
    <segment id="25">"  Lisboa sem turistas    novamente         de   de  de  representando um  Marvila "</segment>
    <segment id="26">De bairro industrial decadente</segment>
    <segment id="27">, o lugar</segment>
    <segment id="28">sese converteu em um polo criativo</segment>
    <segment id="29">, com centro cultural</segment>
    <segment id="30">, restaurantes</segment>
    <segment id="31">, bares e até um "beer district".</segment>
    <segment id="32">Há três microcervejarias a poucos metros de distância uma da outra —Dois Corvos</segment>
    <segment id="33">, na rua Capitão Leitão</segment>
    <segment id="34">; Lince e Musa</segment>
    <segment id="35">, na rua do Açúcar.</segment>
    <segment id="36">"  Cúpula da Basílica da Estrela "</segment>
    <segment id="37">Vale a pena enfrentar 114 degraus para chegar ao topo da cúpula.</segment>
    <segment id="38">De lá é possível ver o parque do Jardim da Estrela</segment>
    <segment id="39">, o bairro de Alfama e o rio Tejo.</segment>
    <segment id="40">Dentro da cúpula</segment>
    <segment id="41">, há afrescos e o túmulo da rainha Maria 1ª." Praça da Estrela</segment>
    <segment id="42">, 1200-667.</segment>
    <segment id="43">Seg.</segment>
    <segment id="44">a dom.</segment>
    <segment id="45">, das 10h30 às 19h30.</segment>
    <segment id="46">Visita à cúpula</segment>
    <segment id="47">, € 4  Panorâmico de Monsanto "</segment>
    <segment id="48">Após duas décadas de abandono</segment>
    <segment id="49">, o prédio que já abrigou uma discoteca foi convertido em espaço cultural</segment>
    <segment id="50">, com vista de 360º da cidade.</segment>
    <segment id="51">Um painel de azulejos ajuda a identificar pontos de interesse.</segment>
    <segment id="52">"</segment>
    <segment id="53">Estrada Bela Vista s/n. Seg.</segment>
    <segment id="54">a dom, das 9h às 19h.</segment>
    <segment id="55">Grátis   Miradouro da capela de Santo Amaro "</segment>
    <segment id="56">A capela de Santo Amaro é uma joia arquitetônica renascentista de 1549.</segment>
    <segment id="57">Sua entrada é coberta por uma enorme (e fotogênica) coleção de azulejos decorativos.</segment>
    <segment id="58">Instalada no alto de uma colina em Alcântara</segment>
    <segment id="59">, a capela tem um miradouro com vista privilegiada para o rio Tejo e a ponte 25 de abril.</segment>
    <segment id="60">"</segment>
    <segment id="61">Rua Gil Vicente.</segment>
    <segment id="62">Fecha às segundas.</segment>
    <segment id="63">Grátis</segment>
