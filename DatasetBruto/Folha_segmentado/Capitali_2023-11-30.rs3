  <rst>
    <segment id="1">A Brasilcap</segment>
    <segment id="2">, dona de 21% do mercado de títulos de capitalização</segment>
    <segment id="3">, liderou as captações ajudando a injetar R$ 18 bilhões na economia entre janeiro e setembro.</segment>
    <segment id="4">O valor</segment>
    <segment id="5">sese refere a resgates e sorteios e teve um aumento de 10% em relação ao mesmo período do ano passado.</segment>
    <segment id="6">Redes de lojas e alguns shoppings do país fazem promoções para baixar estoques - 16.out.2015-Fábio Braga/FolhapressA empresa</segment>
    <segment id="7">, do BB Seguros</segment>
    <segment id="8">, faturou R$ 4</segment>
    <segment id="9">,7 bilhões</segment>
    <segment id="10">, acumulando R$ 11 bilhões em reservas.</segment>
    <segment id="11">No total</segment>
    <segment id="12">, o segmento girou R$ 22 bilhões em receitas.</segment>
    <segment id="13">Desde junho</segment>
    <segment id="14">, a Brasilcap diz que vem</segment>
    <segment id="15">sese mantendo com o maior faturamento do setor graças ao maior interesse dos brasileiros em usar esses papéis</segment>
    <segment id="16">comocomo forma de fazer uma poupança forçada.</segment>
    <segment id="17">Em setembro</segment>
    <segment id="18">, essa captação foi de R$ 543</segment>
    <segment id="19">,8 milhões</segment>
    <segment id="20">, à frente do Bradesco</segment>
    <segment id="21">, que registrou R$ 540</segment>
    <segment id="22">,7 milhões no período.</segment>
    <segment id="23">Com Paulo Ricardo Martins</segment>
  </rst>
