  <rst>
    <segment id="1">​Um bolinho assim</segment>
    <segment id="2">, tão gostoso e inclusivo</segment>
    <segment id="3">, merece um lugar especial em nossa cozinha.</segment>
    <segment id="4">Quando optamos por receitas veganas</segment>
    <segment id="5">, incluímos automaticamente na roda de quem saboreia não apenas as pessoas que são veganas</segment>
    <segment id="6">, masmas também aquelas que têm intolerância à lactose</segment>
    <segment id="7">, já que todos os ingredientes de origem animal —inclusive os leites</segment>
    <segment id="8">, queijos e iogurtes derivados da vaca— ficam de fora e cedem espaço para os substitutos vegetais.</segment>
    <segment id="9">Ao excluir também os ingredientes que contenham glúten</segment>
    <segment id="10">, como</segment>
    <segment id="11">como o trigo e o centeio</segment>
    <segment id="12">, damos chance aos celíacos e intolerantes ao glúten de provar a receita.</segment>
    <segment id="13">Nesses bolinhos —ou cupcakes— a farinha de trigo é substituída por uma mistura de farinha de arroz</segment>
    <segment id="14">, farinha de grão de bico e polvilho doce.</segment>
    <segment id="15">Bolo de cenoura vegano com receita de Luisa Mafei - Luisa MafeiA farinha de arroz fornece estrutura ao bolo e é uma farinha muito mais acessível do que outras que poderiam desempenhar essa função</segment>
    <segment id="16">, como</segment>
    <segment id="17">como a farinha de amaranto</segment>
    <segment id="18">, de quinoa ou de coco.</segment>
    <segment id="19">Ainda na linha acessível</segment>
    <segment id="20">, temos a opção da farinha de milho —para essa receita</segment>
    <segment id="21">, no entanto</segment>
    <segment id="22">, a de arroz é mais interessante</segment>
    <segment id="23">, pela neutralidade do sabor.</segment>
    <segment id="24">Menos conhecida e mais cara —um quilo custa em torno de R$14 nos supermercados</segment>
    <segment id="25">, masmas pode ser comprada por R$ 9</segment>
    <segment id="26">,00 na Zona Cerealista— a farinha de grão de bico também fornece estrutura</segment>
    <segment id="27">, além de atuar</segment>
    <segment id="28">comocomo um agente de "liga" que reúne os demais ingredientes do bolo.</segment>
    <segment id="29">Essa função de ligar moléculas é fundamental para o sucesso de um bom bolo</segment>
    <segment id="30">, e, por mais que ela seja creditada aos ovos</segment>
    <segment id="31">, é amplamente desempenhada pelo glúten</segment>
    <segment id="32">, que se</segment>
    <segment id="33">se "estica" à medida em que é umedecido —e amassado</segment>
    <segment id="34">, no caso</segment>
    <segment id="35">caso dos pães— criando teias elásticas que tudo interligam.</segment>
    <segment id="36">A farinha de grão de bico tem ainda o plus de trazer proteína à receita</segment>
    <segment id="37">, e pode ser utilizada para o preparo de outros pratos</segment>
    <segment id="38">, como</segment>
    <segment id="39">como a omelete vegana.</segment>
    <segment id="40">A farinha de polvilho</segment>
    <segment id="41">, por sua vez</segment>
    <segment id="42">, adiciona ao bolo a dose de "fofura" necessária —é um agente de leveza</segment>
    <segment id="43">, essencial</segment>
    <segment id="44">para que</segment>
    <segment id="45">para que o bolinho não vire uma sola de sapatinho.</segment>
    <segment id="46">Aliás, a dica é resistir à tentação de fazer um bolo grande</segment>
    <segment id="47">, porque</segment>
    <segment id="48">porque o tamanho altera a textura</segment>
    <segment id="49">, e as forminhas menores permitem um bolo macio</segment>
    <segment id="50">, úmido e firme.</segment>
    <segment id="51">A receita rende oito bolinhos</segment>
    <segment id="52">, que são uma ótima pedida para a lancheira das crianças</segment>
    <segment id="53">, ou mala térmica dos adultos.</segment>
    <segment id="54">Por isso</segment>
    <segment id="55">, a dica é dobrar a receita e congelar alguns.</segment>
    <segment id="56">No dia anterior ao consumo</segment>
    <segment id="57">, basta transferir para a geladeira (e aguardar pacientemente o descongelamento).</segment>
    <segment id="58">Colunas e BlogsReceba no seu email uma seleção de colunas e blogs da Folha</segment>
    <segment id="59">; exclusiva para assinantes.</segment>
    <segment id="60">Carregando...</segment>
    <segment id="61">Bolinho de cenoura com calda de chocolate  INGREDIENTES  1 xícara de farinha de arroz.  ½ xícara de farinha de grão de bico.  ½ xícara de polvilho doce.  3 xícaras de cenoura picada.</segment>
    <segment id="62">½ xícara de óleo de coco.  ½ xícara de leite vegetal</segment>
    <segment id="63">.</segment>
    <segment id="64">½ xícara de açúcar demerara.</segment>
    <segment id="65">2 colheres de sopa de melado (pode ser substituído por mais ¼ de xícara de açúcar) .</segment>
    <segment id="66">1 colher de sopa de fermento.</segment>
    <segment id="67">1 colher de chá de bicarbonato de sódio.  ½ colher de sopa de vinagre de maçã.</segment>
    <segment id="68">Noz moscada ralada</segment>
    <segment id="69">, a gosto</segment>
    <segment id="70">, masmas com capricho.</segment>
    <segment id="71">PREPARO   Pré-aqueça o forno a 200 graus.</segment>
    <segment id="72">Acrescente no copo do liquidificador a cenoura</segment>
    <segment id="73">, o leite vegetal</segment>
    <segment id="74">, o óleo de coco</segment>
    <segment id="75">, o açúcar demerara e o melado.</segment>
    <segment id="76">Peneire em uma tigela grande as farinhas e o polvilho.</segment>
    <segment id="77">Transfira o conteúdo do liquidificador para o bowl das farinhas.</segment>
    <segment id="78">Envolva.</segment>
    <segment id="79">Rale a noz moscada a gosto e envolva novamente.</segment>
    <segment id="80">Adicione o fermento</segment>
    <segment id="81">, o vinagre de maçã e o bicarbonato de sódio e envolva na massa</segment>
    <segment id="82">, com delicadeza.</segment>
    <segment id="83">Transfira a massa do bolo para as forminhas e leve para assar por 35 a 40 min.</segment>
    <segment id="84">Faça o teste do palito para</segment>
    <segment id="85">sese certificar de que o bolo está assado</segment>
    <segment id="86">, masmas evite abrir o forno antes da hora</segment>
    <segment id="87">, isso prejudica o cozimento do bolo.</segment>
    <segment id="88">Espere esfriar e desenforme.</segment>
    <segment id="89">CALDA</segment>
    <segment id="90">DE CHOCOLATE  INGREDIENTES  100 g de chocolate preto vegano.  80 ml de leite de amêndoa</segment>
    <segment id="91">, ou do leite vegetal da sua preferência.</segment>
    <segment id="92">1 colher de chá de óleo de coco.  PREPARO</segment>
    <segment id="93">Corte o chocolate em pedaços menores e transfira para uma tigela.</segment>
    <segment id="94">Leve para derreter em banho maria.</segment>
    <segment id="95">Quando o chocolate estiver derretido</segment>
    <segment id="96">, acrescente o leite vegetal e misture bem</segment>
    <segment id="97">, até formar uma calda homogênea.</segment>
    <segment id="98">Por fim</segment>
    <segment id="99">, acrescente o óleo de coco e desligue o fogo.</segment>
    <segment id="100">Espere a calda esfriar e espalhe por cima do bolo.</segment>
  </rst>
</analysis>