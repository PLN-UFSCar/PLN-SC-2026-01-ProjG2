  <rst>
    <segment id="1">Se havia uma coisa que Gillian sabia</segment>
    <segment id="2">, era que ela não queria um instrumento furador perto de sua genitália.</segment>
    <segment id="3">Assim, em 2018</segment>
    <segment id="4">, quando um ginecologista recomendou uma biópsia vulvar para averiguar a presença de sinais de câncer</segment>
    <segment id="5">, ela hesitou.</segment>
    <segment id="6">O médico desconfiava que uma pequena área de pele esbranquiçada que Gillian encontrara ao lado de seu clitóris era líquen escleroso</segment>
    <segment id="7">, uma doença de pele que normalmente é benigna.</segment>
    <segment id="8">Para Gillian</segment>
    <segment id="9">, enfermeira registrada</segment>
    <segment id="10">, retirar um pedaço da parte mais sensível de seu corpo lhe parecia um pouco extremo demais.</segment>
    <segment id="11">Um cartão de agradecimento da clínica da médica Rachel Rubin - Shuran Huang/The New York TimesMas ela acabou consentindo.</segment>
    <segment id="12">Ele era médico</segment>
    <segment id="13">, ela era enfermeira.</segment>
    <segment id="14">Ela supôs que ele fosse a autoridade em relação a essa parte do corpo.</segment>
    <segment id="15">"</segment>
    <segment id="16">Nunca trabalhei com ginecologia e obstetrícia"</segment>
    <segment id="17">, disse Gillian</segment>
    <segment id="18">, que pediu para ser identificada apenas pelo primeiro nome para proteger sua privacidade.</segment>
    <segment id="19">"</segment>
    <segment id="20">Eu não tinha muita noção das coisas.</segment>
    <segment id="21">"</segment>
    <segment id="22">Para a biópsia</segment>
    <segment id="23">, Gillian foi colocada numa mesa com apoios para as pernas e recebeu uma injeção epidural a fim de anestesiar a área.</segment>
    <segment id="24">Depois do procedimento</segment>
    <segment id="25">, para conter o sangramento</segment>
    <segment id="26">, o médico pôs uma mão sobre a outra e fez pressão forte sobre sua vulva –a genitália feminina externa</segment>
    <segment id="27">, incluindo os lábios grandes e pequenos</segment>
    <segment id="28">, a abertura da vagina e o clitóris.</segment>
    <segment id="29">Mesmo anestesiada</segment>
    <segment id="30">, Gillian sentiu a pressão sobre seu osso público.</segment>
    <segment id="31">Ela gritou.</segment>
    <segment id="32">Curiosidades sobre o sexo e o orgasmoMais    novamente         de   de  de  representando um</segment>
    <segment id="33">Um mês mais tarde</segment>
    <segment id="34">, Gillian estava na cama com seu namorado quando percebeu que não conseguia mais chegar ao orgasmo.</segment>
    <segment id="35">Ela ficava excitada</segment>
    <segment id="36">, masmas no momento xis</segment>
    <segment id="37">, "não dava em nada"</segment>
    <segment id="38">, contou.</segment>
    <segment id="39">"E é assim até hoje.</segment>
    <segment id="40">"  Quando ela informou seu ginecologista</segment>
    <segment id="41">, ele especulou que ela poderia estar com insensibilidade causada pela cicatrização e disse que o problema desapareceria com o tempo.</segment>
    <segment id="42">Não desapareceu.</segment>
    <segment id="43">Alarmada</segment>
    <segment id="44">, Gillian começou a procurar um especialista depois de outro em busca de uma explicação e</segment>
    <segment id="45">, ela esperava</segment>
    <segment id="46">, uma solução.</segment>
    <segment id="47">Foi quando ela descobriu que ninguém queria falar de seu clítoris.</segment>
    <segment id="48">Quando ouviu sobre a lesão que ela sofrera</segment>
    <segment id="49">, um urologista comparou Gillian a uma vítima de estupro e disse que ela possivelmente sofrera uma reação traumática à biópsia.</segment>
    <segment id="50">Em seguida</segment>
    <segment id="51">, uma especialista em saúde feminina fez o diagnóstico de perimenopausa e prescreveu creme de testosterona.</segment>
    <segment id="52">Outro ginecologista recomendou um procedimento de rejuvenescimento vaginal.</segment>
    <segment id="53">Quando Gillian tentava direcionar a conversa de volta para seu clítoris</segment>
    <segment id="54">, a reação dos especialistas era um olhar indiferente.</segment>
    <segment id="55">"</segment>
    <segment id="56">Eles me olhavam</segment>
    <segment id="57">comocomo</segment>
    <segment id="58">sese eu fosse completamente insana"</segment>
    <segment id="59">, contou.</segment>
    <segment id="60">"</segment>
    <segment id="61">Eu ficava repetindo que havia algo de errado com meu clitóris</segment>
    <segment id="62">, e eles faziam tudo menos reconhecer o clitóris.</segment>
    <segment id="63">"  "</segment>
    <segment id="64">Uma consideração secundária</segment>
    <segment id="65">, no máximo"</segment>
    <segment id="66">Segundo o urologista Irwin Goldstein</segment>
    <segment id="67">, pioneiro no campo da medicina sexual</segment>
    <segment id="68">, alguns urologistas comparam a vulva a "uma cidade pequena no Meio-Oeste".</segment>
    <segment id="69">Ou seja</segment>
    <segment id="70">, os médicos tendem a passar por ela</segment>
    <segment id="71">, mal parando para olhá-la</segment>
    <segment id="72">, a caminho de seu destino final: o colo do útero e o útero.</segment>
    <segment id="73">É ali que acontece a ação médica de verdade: ultrassonografias</segment>
    <segment id="74">, papa-nicolaus</segment>
    <segment id="75">, inserção de DIUs</segment>
    <segment id="76">, parto.  Se a vulva</segment>
    <segment id="77">comocomo um todo é uma cidadezinha à qual ninguém dá o devido valor</segment>
    <segment id="78">, o clitóris é o boteco local na beira da estrada: pouco conhecido</segment>
    <segment id="79">, raramente levado em conta</segment>
    <segment id="80">, o melhor a fazer é provavelmente evitá-lo.</segment>
    <segment id="81">"</segment>
    <segment id="82">Ele é completamente ignorado por praticamente todo o mundo"</segment>
    <segment id="83">, disse Rachel Rubin</segment>
    <segment id="84">, urologista e especialista em saúde sexual</segment>
    <segment id="85">, de Washington.</segment>
    <segment id="86">"</segment>
    <segment id="87">Não há nenhuma comunidade médica que tenha assumido as pesquisas</segment>
    <segment id="88">, os cuidados e o diagnóstico de problemas relacionados à vulva.</segment>
    <segment id="89">"</segment>
    <segment id="90">Questionada sobre o que aprendeu sobre o órgão na escola de medicina</segment>
    <segment id="91">, Rubin respondeu: "</segment>
    <segment id="92">Nada que tenha ficado na minha memória.</segment>
    <segment id="93">Se ele chegou a ser mencionado</segment>
    <segment id="94">, foi uma consideração secundária</segment>
    <segment id="95">, no máximo.</segment>
    <segment id="96">"</segment>
    <segment id="97">A urologista e especialista em saúde sexual Rachel Rubin - Shuran Huang/The New York TimesFoi apenas anos mais tarde</segment>
    <segment id="98">, quando estudou medicina sexual com Goldstein</segment>
    <segment id="99">, que ela aprendeu</segment>
    <segment id="100">comocomo examinar a vulva e a parte visível do clitóris</segment>
    <segment id="101">, conhecida</segment>
    <segment id="102">comocomo glande.</segment>
    <segment id="103">Ela aprendeu que o órgão inteiro é uma estrutura profunda</segment>
    <segment id="104">, composta principalmente de tecido erétil</segment>
    <segment id="105">, que se</segment>
    <segment id="106">se estende na pelve e circunda a vagina.</segment>
    <segment id="107">Hoje Rubin</segment>
    <segment id="108">sese nomeou a "clitorologista" máxima de Washington.</segment>
    <segment id="109">É uma brincadeira</segment>
    <segment id="110">, claro</segment>
    <segment id="111">, mesmo</segment>
    <segment id="112">porque</segment>
    <segment id="113">porque poucos competem pelo título –por constrangimento</segment>
    <segment id="114">, por falta de conhecimento ou por medo de faltar com o decoro com as pacientes.</segment>
    <segment id="115">"</segment>
    <segment id="116">Nós, médicos</segment>
    <segment id="117">, gostamos de enfocar o que sabemos"</segment>
    <segment id="118">, ela disse.</segment>
    <segment id="119">"E não gostamos de demonstrar fraqueza</segment>
    <segment id="120">, de deixar perceber que desconhecemos alguma coisa.</segment>
    <segment id="121">"</segment>
    <segment id="122">Essa atitude quase universal dos médicos de evitar o assunto clitóris tem consequências para as pacientes.</segment>
    <segment id="123">Em um estudo de 2018 publicado no periódico Sexual Medicine</segment>
    <segment id="124">, Rubin</segment>
    <segment id="125">, Goldstein e colegas constataram que o fato de não examinarem a vulva e o clítoris leva médicos a regularmente deixar de tomar nota de problemas de saúde sexual.</segment>
    <segment id="126">Quase uma em cada quatro mulheres que procuraram a clínica de Goldstein tinham adesões clitoridianas</segment>
    <segment id="127">, que ocorrem quando o capuz do clítoris adere à glande e pode provocar irritação</segment>
    <segment id="128">, dor e redução do prazer sexual.</segment>
    <segment id="129">Os autores concluíram que todos os médicos que atendem mulheres deveriam examinar o clitóris</segment>
    <segment id="130">comocomo questão de rotina.</segment>
    <segment id="131">Mas, escreveram</segment>
    <segment id="132">, é mais fácil recomendar isso que fazê-lo</segment>
    <segment id="133">, já que a maioria dos médicos "não sabe examinar o clitóris nem</segment>
    <segment id="134">sese sentem à vontade em fazê-lo".</segment>
    <segment id="135">Essa omissão pode prejudicar as mulheres</segment>
    <segment id="136">, além de homens trans</segment>
    <segment id="137">, e outras pessoas com vulva.</segment>
    <segment id="138">Já houve casos documentados de lesões ao clítoris em procedimentos que incluem cirurgias com malha pélvica</segment>
    <segment id="139">, episiotomias realizadas no parto e até mesmo cirurgias de quadril.</segment>
    <segment id="140">Quando é realizada incorretamente</segment>
    <segment id="141">, a labioplastia – um procedimento para reduzir o tamanho dos pequenos lábios</segment>
    <segment id="142">, uma das cirurgias plásticas que mais estão aumentando no mundo — também pode prejudicar nervos</segment>
    <segment id="143">, levando a dor genital e à perda de sensação sexual.</segment>
    <segment id="144">Para Rubin</segment>
    <segment id="145">, muitas dessas lesões poderiam ser evitadas</segment>
    <segment id="146">sese os médicos dedicassem mais tempo ao estudo do clitóris.</segment>
    <segment id="147">Uma tradição de descaso</segment>
    <segment id="148">Então por que não sabemos mais sobre o clitóris?</segment>
    <segment id="149">Para Rubin</segment>
    <segment id="150">, o motivo é simples: o órgão está intimamente envolvido com o prazer e o orgasmo da mulher.</segment>
    <segment id="151">E, até muito recentemente</segment>
    <segment id="152">, essas temas não estavam no topo da lista de prioridades da medicina</segment>
    <segment id="153">, nem sequer eram vistos</segment>
    <segment id="154">comocomo áreas apropriadas de pesquisa médica.</segment>
    <segment id="155">Helen O’Connell</segment>
    <segment id="156">, a primeira urologista de mulheres da Austrália</segment>
    <segment id="157">, lembrou que quando ela própria foi à escola de medicina</segment>
    <segment id="158">, o clitóris mal chegou a aparecer em cena.</segment>
    <segment id="159">Na edição de 1985 do livro didático médico "</segment>
    <segment id="160">Last’s Anatomy"</segment>
    <segment id="161">, que ela estudou</segment>
    <segment id="162">, um corte transversal da pelve feminina omitiu o clítoris por completo</segment>
    <segment id="163">, e aspectos da genitália feminina eram descritos</segment>
    <segment id="164">comocomo "mal desenvolvidos" e uma "falha" de formação genital masculina.</segment>
    <segment id="165">Já as descrições do pênis</segment>
    <segment id="166">sese alongavam por páginas.</segment>
    <segment id="167">Para O’Connell</segment>
    <segment id="168">, esse desinteresse médico generalizado ajuda a explicar por que seus pares urologistas</segment>
    <segment id="169">sese esforçavam para preservar nervos no pênis quando faziam cirurgias de próstata</segment>
    <segment id="170">, masmas não tinham o mesmo cuidado quando realizavam cirurgias pélvicas de mulheres.</segment>
    <segment id="171">O’Connell decidiu investigar a anatomia completa do clitóris</segment>
    <segment id="172">, usando microdissecação e ressonâncias magnéticas.</segment>
    <segment id="173">Em 2005 ela publicou um estudo abrangente mostrando que a ponta externa do órgão – a parte que pode ser vista e tocada — é apenas a ponta do iceberg</segment>
    <segment id="174">, equivalente à glande peniana.</segment>
    <segment id="175">O órgão completo</segment>
    <segment id="176">sese estende abaixo da superfície e abrange dois bulbos em formato de lágrima</segment>
    <segment id="177">, dois braços e uma coluna.</segment>
    <segment id="178">Quando deixam de apreciar essa anatomia</segment>
    <segment id="179">, ela avisou</segment>
    <segment id="180">, cirurgiões que operam nessa região correm o risco de lesionar os nervos sensíveis responsáveis pelo prazer e o orgasmo que percorrem o topo da coluna.</segment>
    <segment id="181">Em procedimentos</segment>
    <segment id="182">comocomo cirurgias com malha pélvica ou cirurgias da uretra</segment>
    <segment id="183">, "as coisas podem estar em um fogo cruzado"</segment>
    <segment id="184">, disse O’Connell.</segment>
    <segment id="185">"</segment>
    <segment id="186">É preciso pensar sempre no que está por baixo</segment>
    <segment id="187">, no que está oculto e que você pode estar alterando.</segment>
    <segment id="188">"</segment>
    <segment id="189">Cada vez mais mulheres estão vindo a público falar de lesões que sofreram nessa região durante procedimentos de rotina.</segment>
    <segment id="190">Uma delas é Julie</segment>
    <segment id="191">, 44 anos</segment>
    <segment id="192">, gerente de um escritório em Essex</segment>
    <segment id="193">, a leste de Londres.</segment>
    <segment id="194">Em 2012 ela fez uma cirurgia de quadril minimamente invasiva para resolver uma dor de costas</segment>
    <segment id="195">, e o procedimento a levou a perder a capacidade de chegar ao orgasmo.</segment>
    <segment id="196">No ano passado ela compartilhou sua história publicamente no jornal The Telegraph</segment>
    <segment id="197">, omitindo seu sobrenome para evitar a possibilidade de ser discriminada por empregadores futuros.</segment>
    <segment id="198">Numa ligação do Zoom em janeiro</segment>
    <segment id="199">, Julie contou que acordou da anestesia sentindo dor lancinante na região do clítoris.</segment>
    <segment id="200">O cirurgião lhe disse que ela ficara com um hematoma</segment>
    <segment id="201">, e que o problema desapareceria.</segment>
    <segment id="202">Alguns meses mais tarde</segment>
    <segment id="203">, ela descobriu que não conseguia mais chegar ao orgasmo.</segment>
    <segment id="204">Quando tentava</segment>
    <segment id="205">, "era literalmente</segment>
    <segment id="206">comocomo</segment>
    <segment id="207">sese alguém tivesse arrancado um fio da tomada"</segment>
    <segment id="208">, ela contou.</segment>
    <segment id="209">"</segment>
    <segment id="210">Morria tudo.</segment>
    <segment id="211">"</segment>
    <segment id="212">Julie passou dois anos fazendo buscas na internet até perceber que um poste cilíndrico posicionado entre suas pernas durante a cirurgia provavelmente esmagara seus nervos clitoridianos.</segment>
    <segment id="213">É sabido que o uso do dispositivo</segment>
    <segment id="214">, conhecido</segment>
    <segment id="215">comocomo poste perineal</segment>
    <segment id="216">, causa lesões aos nervos</segment>
    <segment id="217">, masmas esse fato não foi mencionado no formulário de consentimento que ela assinou antes da cirurgia.</segment>
    <segment id="218">Julie comparou sua lesão à perda do paladar ou do olfato –um prazer que consideramos</segment>
    <segment id="219">comocomo algo inato</segment>
    <segment id="220">, masmas que</segment>
    <segment id="221">, quando o perdemos</segment>
    <segment id="222">, muda tudo.</segment>
    <segment id="223">"</segment>
    <segment id="224">Já sese passaram dez anos e ainda não consigo acreditar"</segment>
    <segment id="225">, ela disse.</segment>
    <segment id="226">"E ainda não me conformei com isso.</segment>
    <segment id="227">"</segment>
    <segment id="228">Gillian ainda está tentando entender a causa de sua própria lesão.</segment>
    <segment id="229">Terá sido a biópsia?</segment>
    <segment id="230">A pressão esmagadora que o ginecologista aplicou depois?</segment>
    <segment id="231">Quatro anos e 12 especialistas mais tarde</segment>
    <segment id="232">, ela já</segment>
    <segment id="233">sese conformou com o fato de que talvez nunca recupere aquela sensação.</segment>
    <segment id="234">"</segment>
    <segment id="235">Isso mudou minha vida inteira"</segment>
    <segment id="236">, ela disse.</segment>
    <segment id="237">"</segment>
    <segment id="238">É arrasador</segment>
    <segment id="239">, é uma coisa da qual você não consegue</segment>
    <segment id="240">sese recuperar.</segment>
    <segment id="241">Nunca.</segment>
    <segment id="242">"</segment>
    <segment id="243">Um novo mapeamento médico</segment>
    <segment id="244">Quando Blair Peters</segment>
    <segment id="245">, cirurgião plástico de 33 anos da Oregon Health &amp;amp</segment>
    <segment id="246">;</segment>
    <segment id="247">Science University</segment>
    <segment id="248">, começou a realizar faloplastias para homens trans e pessoas não binárias</segment>
    <segment id="249">, surpreendeu-</segment>
    <segment id="250">sese ao ver</segment>
    <segment id="251">comocomo são grandes os nervos do clitóris:</segment>
    <segment id="252">cerca de 3 mm de diâmetro</segment>
    <segment id="253">, em média (a título de comparação</segment>
    <segment id="254">, o nervo sensorial do dedo indicador tem 1 mm de largura).</segment>
    <segment id="255">"</segment>
    <segment id="256">Quando fiz faculdade de medicina</segment>
    <segment id="257">, não aprendemos nada de específico sobre o clitóris</segment>
    <segment id="258">, tirando o fato de que ele existe</segment>
    <segment id="259">, basicamente"</segment>
    <segment id="260">, disse Peters.</segment>
    <segment id="261">Graças a isso</segment>
    <segment id="262">, ele criou "uma ideia subconsciente de que não era uma estrutura super aparente.</segment>
    <segment id="263">Mas é.</segment>
    <segment id="264">"</segment>
    <segment id="265">Peters faz parte de um grupo pequeno de médicos jovens</segment>
    <segment id="266">, adeptos das redes sociais</segment>
    <segment id="267">, que,</segment>
    <segment id="268">comocomo Rubin</segment>
    <segment id="269">, estão ajudando a ampliar o mapa médico desse território – e</segment>
    <segment id="270">, com isso</segment>
    <segment id="271">, a evitar que</segment>
    <segment id="272">sese repita o que aconteceu com Julie e Gillian.</segment>
    <segment id="273">Como parte de seus esforços para melhorar a sensibilidade sexual dos pacientes que passaram por faloplastia</segment>
    <segment id="274">, Peters recentemente ampliou os nervos clitoridianos e contou quantas fibras nervosas eles contêm.</segment>
    <segment id="275">O número que encontrou – embargado até ele apresentar suas descobertas numa conferência no final deste mês — foi "significativamente superior" a 8.000</segment>
    <segment id="276">,</segment>
    <segment id="277">o número frequentemente citado</segment>
    <segment id="278">, que é tirado de um estudo desatualizado sobre vacas.</segment>
    <segment id="279">Em 2020</segment>
    <segment id="280">, Victoria Gordon</segment>
    <segment id="281">, estudante de medicina na Kansas City University of Medicine and Biosciences</segment>
    <segment id="282">, comandou um estudo que procurou delimitar uma "zona de perigo" em volta do clítoris a ser evitada por cirurgiões plásticos.</segment>
    <segment id="283">Enquanto fazia dissecações de cadáveres</segment>
    <segment id="284">, ela observou que os nervos clitoridianos às vezes</segment>
    <segment id="285">sese abrem em ramos minúsculos e finos</segment>
    <segment id="286">, como</segment>
    <segment id="287">como raízes</segment>
    <segment id="288">, de maneiras que podem ser relevantes para cirurgiões</segment>
    <segment id="289">, masmas que não foram descritas anteriormente na literatura médica.</segment>
    <segment id="290">Ela espera que outros no campo da cirurgia plástica levem adiante o estudo de suas descobertas</segment>
    <segment id="291">, que foram publicadas num periódico de cirurgia plástica.</segment>
    <segment id="292">"Sou apenas uma estudante de medicina de quarto ano"</segment>
    <segment id="293">, ela disse no final de 2021.</segment>
    <segment id="294">"</segment>
    <segment id="295">Acho que não sou eu quem deveria estar encarando esse projeto.</segment>
    <segment id="296">Mas ninguém mais está.</segment>
    <segment id="297">"</segment>
    <segment id="298">Tradução de Clara Allain</segment>
  </rst>
</analysis>