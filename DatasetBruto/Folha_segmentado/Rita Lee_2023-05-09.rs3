  <rst>
    <segment id="1">O que vocês estão procurando</segment>
    <segment id="2">, queridos policiais?</segment>
    <segment id="3">, perguntou Rita Lee</segment>
    <segment id="4">, no último show de sua carreira</segment>
    <segment id="5">, em Aracaju</segment>
    <segment id="6">, em 2012.</segment>
    <segment id="7">No palco</segment>
    <segment id="8">, a cantora e compositora</segment>
    <segment id="9">, morta aos 75 anos nesta segunda-feira (8)</segment>
    <segment id="10">, sese incomodou ao ver policiais revistando seus fãs</segment>
    <segment id="11">, à procura de maconha.</segment>
    <segment id="12">Após a apresentação</segment>
    <segment id="13">, Rita foi presa por desacato à autoridade.</segment>
    <segment id="14">Cantora e compositora Rita Lee em show em São Paulo - Folhapress"Vocês não têm o direito de usar a força brutal na meninada que não está fazendo nada.</segment>
    <segment id="15">Este show é a minha despedida do palco e vocês continuam tendo que guardar as pessoas</segment>
    <segment id="16">, não tendo que agredir.</segment>
    <segment id="17">Seus cachorros.</segment>
    <segment id="18">Coitado dos cachorros.</segment>
    <segment id="19">Seus cafajestes.</segment>
    <segment id="20">Vocês estão fazendo de propósito.</segment>
    <segment id="21">Eu sou do tempo da ditadura.</segment>
    <segment id="22">Vocês acham que eu tenho medo?</segment>
    <segment id="23">As pessoas estão esperando eu cantar</segment>
    <segment id="24">, não a gracinha de vocês</segment>
    <segment id="25">, seus filhos da puta.</segment>
    <segment id="26">Agora vêm me prender.</segment>
    <segment id="27">"</segment>
    <segment id="28">Veja fotos de Rita Lee nos últimos anosMais    novamente         de   de  de  representando um  Rita comparava a atitude dos policiais à repressão que sofreu na ditadura</segment>
    <segment id="29">, sobretudo depois do AI-5.</segment>
    <segment id="30">Em seu último show</segment>
    <segment id="31">, reforçava seu posicionamento libertário</segment>
    <segment id="32">, contra o moralismo ainda vigente.</segment>
    <segment id="33">No palco</segment>
    <segment id="34">, era ato derradeiro de uma carreira marcada pela irreverência e o desbunde.</segment>
    <segment id="35">LEIA MAIS</segment>
    <segment id="36">SOBRE</segment>
    <segment id="37">A MORTE DE RITA LEEMorre Rita Lee</segment>
    <segment id="38">, maior estrela do rock brasileiro e ícone dos Mutantes</segment>
    <segment id="39">, aos 75 anosComo Rita Lee encarnou deusa pagã de SP e virou mãe menina da cidadeComo Rita Lee foi do hard rock esperto a uma química pop irretocávelRita</segment>
    <segment id="40">Lee virou poeta do rock e falou com crianças em livros espirituososRita Lee</segment>
    <segment id="41">, rebelde desde a infância</segment>
    <segment id="42">, sese deixou guiar por drogas e discos voadoresDe &amp;#039</segment>
    <segment id="43">;Build</segment>
    <segment id="44">Up&amp;#039</segment>
    <segment id="45">; a &amp;#039</segment>
    <segment id="46">;Reza&amp;#039</segment>
    <segment id="47">;, relembre os principais discos da carreira de Rita LeeRita Lee já sabia o epitáfio que queria em sua lápide depois que morresseNa delegacia</segment>
    <segment id="48">, a cantora assinou o boletim de ocorrência por desacato</segment>
    <segment id="49">, sendo liberada em seguida.</segment>
    <segment id="50">Na ocasião</segment>
    <segment id="51">, o governo de Sergipe deu razão à polícia</segment>
    <segment id="52">, emitindo uma nota oficial dizendo que "não foi registrada nenhuma ação dos policiais militares que justificasse os insultos proferidos pela cantora".</segment>
    <segment id="53">Na nota</segment>
    <segment id="54">, o governo lamentou ainda o "mal-estar provocado pela cantora" durante o show.</segment>
    <segment id="55">Na época</segment>
    <segment id="56">, o ex- governador de Sergipe</segment>
    <segment id="57">, Marcelo Déda</segment>
    <segment id="58">, do PT</segment>
    <segment id="59">, classificou o ocorrido</segment>
    <segment id="60">comocomo um "espetáculo deprimente".</segment>
    <segment id="61">De acordo com Déda</segment>
    <segment id="62">, Rita tentou colocar o público contra os policiais.</segment>
