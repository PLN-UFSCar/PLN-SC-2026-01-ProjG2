  <rst>
    <segment id="1">Indicado ao Oscar de melhor curta documental</segment>
    <segment id="2">, "</segment>
    <segment id="3">Onde eu</segment>
    <segment id="4">Moro" é um filme comovente e que mostra com um olhar bastante humano a crise de habitação nos Estados Unidos.</segment>
    <segment id="5">Acompanhando pessoas em situação de rua –as gravações foram feitas entre 2017 e 2020–</segment>
    <segment id="6">, o filme pincela problemas-chave na questão da falta de moradia americana: aumento do aluguel</segment>
    <segment id="7">, falta de emprego</segment>
    <segment id="8">, violência doméstica</segment>
    <segment id="9">, desarranjos familiares</segment>
    <segment id="10">, preconceito.</segment>
    <segment id="11">Tem, portanto</segment>
    <segment id="12">, grande mérito (e pode surpreender ainda mais</segment>
    <segment id="13">sese os diretores</segment>
    <segment id="14">, dentre eles um brasileiro</segment>
    <segment id="15">, cumprirem a promessa e levarem alguns dos entrevistados para o tapete vermelho da premiação).</segment>
    <segment id="16">Cena do documentário &amp;#039</segment>
    <segment id="17">;Onde Eu Moro&amp;#039</segment>
    <segment id="18">;, sobre moradores de rua dos EUA - Netflix/Divulgação  É impossível</segment>
    <segment id="19">, entretanto</segment>
    <segment id="20">, comparar o documentário com a situação dos moradores de rua no Brasil.</segment>
    <segment id="21">Especialmente na cidade de São Paulo</segment>
    <segment id="22">, onde essa população cresceu 31% durante a pandemia.</segment>
    <segment id="23">Enquanto o filme apresenta personagens aparentemente não adictos</segment>
    <segment id="24">, muitos brancos e que estão na rua por não conseguirem pagar o aluguel –</segment>
    <segment id="25">masmas que sairiam dessa condição</segment>
    <segment id="26">sese assim pudessem–</segment>
    <segment id="27">, São Paulo esbarra em uma situação um pouco diferente.</segment>
    <segment id="28">De acordo com o último censo da prefeitura</segment>
    <segment id="29">, divulgado em janeiro deste ano</segment>
    <segment id="30">, 70,8% das pessoas sem moradia por aqui são pardas ou pretas.</segment>
    <segment id="31">Mais de 75% delas têm as calçadas e albergues</segment>
    <segment id="32">comocomo "casa" há mais de dois anos</segment>
    <segment id="33">, podendo passar de dez.</segment>
    <segment id="34">Muitas (e arrisco dizer a maioria</segment>
    <segment id="35">, em meus quase quatro anos de trabalho semanal com pessoas vulneráveis)</segment>
    <segment id="36">, são usuárias de drogas ou álcool.</segment>
    <segment id="37">Estão nas ruas por causa disso</segment>
    <segment id="38">, ou se</segment>
    <segment id="39">se tornaram adictas</segment>
    <segment id="40">porque</segment>
    <segment id="41">porque foram parar nas ruas.</segment>
    <segment id="42">São esquecidas por serem vítimas de uma sociedade que exclui negros</segment>
    <segment id="43">, trans</segment>
    <segment id="44">, travestis.</segment>
    <segment id="45">Que sobrecarrega mulheres</segment>
    <segment id="46">, chefes de família.</segment>
    <segment id="47">Que não dá e nunca deu oportunidades iguais para todos.</segment>
    <segment id="48">Sairiam das ruas</segment>
    <segment id="49">sese conseguissem pagar aluguel?</segment>
    <segment id="50">Talvez.</segment>
    <segment id="51">Mas como</segment>
    <segment id="52">como bancar uma casa quando</segment>
    <segment id="53">, no Brasil</segment>
    <segment id="54">, morar na rua é reflexo de um problema estrutural e de saúde pública?</segment>
    <segment id="55">Veja fotos do documentário &amp;#039</segment>
    <segment id="56">;Onde Eu Moro&amp;#039</segment>
    <segment id="57">;, sobre moradores de rua</segment>
    <segment id="58">, indicado ao OscarMais    novamente         de   de  de  representando um    "</segment>
    <segment id="59">Onde eu</segment>
    <segment id="60">Moro</segment>
    <segment id="61">" joga luz</segment>
    <segment id="62">, com sensibilidade</segment>
    <segment id="63">, a quem está nas ruas por causa da crise econômica americana.</segment>
    <segment id="64">O filme desperta a compaixão de quem o assiste e</segment>
    <segment id="65">, quem sabe</segment>
    <segment id="66">, com o Oscar</segment>
    <segment id="67">, poderá atrair ainda mais olhares para essa condição.</segment>
    <segment id="68">É vitorioso por isso.</segment>
    <segment id="69">Mas não tente entender o que acontece com quem mora nas ruas ao redor de nossas casas só assistindo ao documentário.</segment>
    <segment id="70">Não estamos falando da mesma condição.</segment>
    <segment id="71">Resolver o problema de quem não tem moradia</segment>
    <segment id="72">, por aqui</segment>
    <segment id="73">, resvala em promover saúde</segment>
    <segment id="74">, acompanhamento psicológico</segment>
    <segment id="75">, trabalho</segment>
    <segment id="76">, casa e autonomia.</segment>
    <segment id="77">E os aparelhos sociais não promovem autonomia ao tratar todos</segment>
    <segment id="78">, seres humanos independentes</segment>
    <segment id="79">, como</segment>
    <segment id="80">como uma coisa só.</segment>
    <segment id="81">As ruas do país são habitadas por pessoas que carecem de um olhar humanizado</segment>
    <segment id="82">, masmas que encontram indiferença.</segment>
    <segment id="83">Não é filme</segment>
    <segment id="84">, não tem indicação ao Oscar</segment>
    <segment id="85">;</segment>
    <segment id="86">é só realidade.  *   "</segment>
    <segment id="87">Onde eu Moro".</segment>
    <segment id="88">Disponível na Netflix.</segment>
  </rst>
