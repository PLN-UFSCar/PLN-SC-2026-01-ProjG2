  <rst>
    <segment id="1">O sábado (11) em Buenos Aires começou com 31ºC às 9h e tinha previsão de alcançar 38ºC nos horários mais quentes</segment>
    <segment id="2">, um recorde para o mês de fevereiro em 79 anos —em 1944</segment>
    <segment id="3">, a cidade marcou 38</segment>
    <segment id="4">,7ºC.  Na capital</segment>
    <segment id="5">, o dia teve temperatura mínima de 27ºC</segment>
    <segment id="6">, em meio a uma onda de calor que colocou partes do país em alerta laranja</segment>
    <segment id="7">, como</segment>
    <segment id="8">como Corrientes</segment>
    <segment id="9">, Misiones</segment>
    <segment id="10">, San Luis</segment>
    <segment id="11">, Mendoza</segment>
    <segment id="12">, La Pampa e Buenos Aires</segment>
    <segment id="13">, e outras em alerta amarelo</segment>
    <segment id="14">, como</segment>
    <segment id="15">como Córdoba</segment>
    <segment id="16">, Entre Ríos e San Juan</segment>
    <segment id="17">, segundo o Serviço Meteorológico Nacional.</segment>
    <segment id="18">As cores sinalizam que o calor pode ser perigoso para idosos</segment>
    <segment id="19">, crianças e pessoas com doenças crônicas.</segment>
    <segment id="20">Casal descansa no parque Palermo</segment>
    <segment id="21">, em Buenos Aires - Alejandro Pagni - 13.jan.22/AFPHá vários dias a Argentina registra a oitava onda de calor deste verão</segment>
    <segment id="22">, com temperaturas de quase 40ºC.</segment>
    <segment id="23">Na última década</segment>
    <segment id="24">, não foram registradas mais do que quatro ou cinco episódios semelhantes por temporada</segment>
    <segment id="25">, de acordo com o órgão de meteorologia.</segment>
    <segment id="26">Considerando todos os trimestres de novembro a janeiro</segment>
    <segment id="27">, o atual foi o mais quente desde 1961</segment>
    <segment id="28">, com uma anomalia de mais de 1</segment>
    <segment id="29">,7ºC.  "</segment>
    <segment id="30">Uma única onda de calor cai dentro da faixa de variabilidade climática normal.</segment>
    <segment id="31">Mas com a mudança climática</segment>
    <segment id="32">, ondas mais persistentes e intensas são observadas em todos os continentes.</segment>
    <segment id="33">E na Argentina também estão ocorrendo na Patagônia"</segment>
    <segment id="34">, diz o meteorologista Enzo Campetella à agência de notícias AFP.</segment>
    <segment id="35">Lá foraReceba no seu email uma seleção semanal com o que de mais importante aconteceu no mundo</segment>
    <segment id="36">; aberta para não assinantes.</segment>
    <segment id="37">Carregando...</segment>
    <segment id="38">Na região</segment>
    <segment id="39">, ao sul do país</segment>
    <segment id="40">, as temperaturas chegaram a 42ºC na quinta (9)</segment>
    <segment id="41">, na costa da província de Rio Negro.</segment>
    <segment id="42">Mudanças nos ventos de oeste ou sudoeste</segment>
    <segment id="43">, porém</segment>
    <segment id="44">porém, amenizaram a situação e reduziram o calor.</segment>
    <segment id="45">Durante 2022</segment>
    <segment id="46">, o fenômeno climático La Niña elevou os recordes históricos de temperaturas em toda a Argentina</segment>
    <segment id="47">, onde a seca afetou o plantio e a colheita das lavouras</segment>
    <segment id="48">, podendo custar perdas superiores a US$ 10 bilhões (R$ 52</segment>
    <segment id="49">,5 bilhões)</segment>
    <segment id="50">, segundo um recente relatório da Bolsa de Cereais de Rosário.</segment>
    <segment id="51">De acordo com o SMN</segment>
    <segment id="52">, as temperaturas médias</segment>
    <segment id="53">sese alteraram no último período (1991-2020) em relação ao anterior (1981-2010).</segment>
    <segment id="54">"</segment>
    <segment id="55">Dependendo da variável</segment>
    <segment id="56">, da região</segment>
    <segment id="57">, do mês ou do trimestre</segment>
    <segment id="58">, essas mudanças podem ser muito leves ou bastante notórias"</segment>
    <segment id="59">, afirma o órgão em seu site.</segment>
    <segment id="60">Aumento da temperatura global já causa mais eventos extremosMais    novamente         de   de  de  representando um</segment>
    <segment id="61">A temperatura média do período iniciado em 1981</segment>
    <segment id="62">, por exemplo</segment>
    <segment id="63">, foi de 16</segment>
    <segment id="64">,1ºC, enquanto o do último ciclo foi de 16</segment>
    <segment id="65">,3ºC. "</segment>
    <segment id="66">Embora possa parecer uma mudança pequena</segment>
    <segment id="67">, deve-</segment>
    <segment id="68">sese considerar que todo o território do país está sendo levado em conta</segment>
    <segment id="69">, o que pode suavizar os valores</segment>
    <segment id="70">"</segment>
    <segment id="71">,</segment>
    <segment id="72">afirma.</segment>
    <segment id="73">"</segment>
    <segment id="74">No mapa anual</segment>
    <segment id="75">, há uma tendência geral de temperaturas mais quentes</segment>
    <segment id="76">, com o maior aquecimento em Jujuy e ao norte de Salta.</segment>
    <segment id="77">"</segment>
    <segment id="78">O aquecimento global está relacionado à maior ocorrência de eventos extremos</segment>
    <segment id="79">, como</segment>
    <segment id="80">como ondas de calor.</segment>
    <segment id="81">O domingo deve continuar com temperaturas altas em Buenos Aires</segment>
    <segment id="82">, masmas mais amenas que as de sábado.</segment>
  </rst>
