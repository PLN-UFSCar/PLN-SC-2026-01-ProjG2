  <rst>
    <segment id="1">Ao fim de uma semana de aumento da tensão na crise que</segment>
    <segment id="2">sese desenrola no entorno da Ucrânia</segment>
    <segment id="3">, após negociações infrutíferas entre Rússia e EUA</segment>
    <segment id="4">, o secretário-geral da Otan</segment>
    <segment id="5">, Jens Stoltenberg</segment>
    <segment id="6">, afirmou neste domingo (30) que não há planos de enviar tropas da aliança militar para o país do Leste Europeu.</segment>
    <segment id="7">Questionado pela rede britânica BBC</segment>
    <segment id="8">, o norueguês enfatizou que a aliança militar</segment>
    <segment id="9">sese concentra</segment>
    <segment id="10">, por ora</segment>
    <segment id="11">, em fornecer apoio</segment>
    <segment id="12">, como</segment>
    <segment id="13">como modernização da defesa e entrega de equipamentos.</segment>
    <segment id="14">"</segment>
    <segment id="15">Existe uma diferença entre ser membro da Otan e ser um parceiro forte e altamente valorizado</segment>
    <segment id="16">, como</segment>
    <segment id="17">como a Ucrânia"</segment>
    <segment id="18">, emendou Stoltenberg.</segment>
    <segment id="19">Soldado ucraniano posicionado na fronteira do país - 28.jan.2022/Forças Armadas da Ucrânia via Reuters</segment>
    <segment id="20">As declarações vêm no mesmo dia em que Moscou voltou a rechaçar a possibilidade da Ucrânia</segment>
    <segment id="21">sese juntar à aliança militar de 30 países liderada pelos EUA.</segment>
    <segment id="22">O chanceler russo</segment>
    <segment id="23">, Serguei Lavrov</segment>
    <segment id="24">, disse que o país "não está preparado" e que sua chegada "nem sequer contribuiria para um ganho de segurança na Otan".</segment>
    <segment id="25">As falas seguiram a alegação feita por Lavrov de que a Otan</segment>
    <segment id="26">, cuja força</segment>
    <segment id="27">, em termos de pessoal e equipamento</segment>
    <segment id="28">, é de duas a oito vezes maior que a da Rússia</segment>
    <segment id="29">, continua</segment>
    <segment id="30">sese movendo e está "muito perto" da Ucrânia.</segment>
    <segment id="31">O secretário-geral da aliança</segment>
    <segment id="32">, por sua vez</segment>
    <segment id="33">, disse que a Otan pretende continuar em busca de uma saída diplomática</segment>
    <segment id="34">, deixando claro à Rússia que mais sanções serão impostas para desencorajar o país a usar a força na Ucrânia</segment>
    <segment id="35">, como</segment>
    <segment id="36">como o fez na anexação da Crimeia</segment>
    <segment id="37">, em 2014.</segment>
    <segment id="38">Enquanto isso</segment>
    <segment id="39">, Kiev segue realizando treinamentos de centenas de civis que</segment>
    <segment id="40">sese juntaram aos reservistas do Exército ucraniano ao longo dos últimos meses para ajudar em uma eventual guerra.</segment>
    <segment id="41">Muitos são jovens e mulheres</segment>
    <segment id="42">, treinados por veteranos do país em espaços públicos para aprender a usar o armamento disponível.</segment>
    <segment id="43">Outro agente diplomático do conflito</segment>
    <segment id="44">, o Reino Unido comunicou que apresentará nesta semana um projeto de lei com sanções ao que chamou de um "amplo grupo de atividades econômicas russas"</segment>
    <segment id="45">, como</segment>
    <segment id="46">como parte dos esforços para dissuadir Moscou de uma invasão da Ucrânia.</segment>
    <segment id="47">A ministra das Relações Exteriores britânica</segment>
    <segment id="48">, Liz Truss</segment>
    <segment id="49">, sinalizou que o novo pacote deve ampliar as sanções já impostas por Londres de modo que abarque toda e qualquer empresa de interesse para o governo de Vladimir Putin.</segment>
    <segment id="50">"</segment>
    <segment id="51">Não vai haver nenhum lugar onde os oligarcas russos possam</segment>
    <segment id="52">sese esconder"</segment>
    <segment id="53">, disse a chanceler à rede Sky News.</segment>
    <segment id="54">Ucrânia treina civis para defender país em</segment>
    <segment id="55">casocaso de ataque da RússiaMais    novamente         de   de  de  representando um</segment>
    <segment id="56">Tanto Truss quanto o premiê britânico</segment>
    <segment id="57">, Boris Johnson</segment>
    <segment id="58">, devem visitar Kiev no início desta semana</segment>
    <segment id="59">, ainda que o político conservador enfrente uma crise doméstica</segment>
    <segment id="60">, com pedidos de renúncia</segment>
    <segment id="61">, após a realização de uma série de festas em Downing Street</segment>
    <segment id="62">, sede do governo</segment>
    <segment id="63">, durante períodos de rígidas restrições para conter o avanço da Covid.</segment>
    <segment id="64">Fontes da chancelaria britânica disseram ao jornal The Guardian que o regime de sanções hoje existente permite ao Reino Unido atacar somente aqueles diretamente ligados à desestabilização da Ucrânia.</segment>
    <segment id="65">Já a nova legislação</segment>
    <segment id="66">, que terá de ser aprovada pelo Parlamento</segment>
    <segment id="67">, permitiria sancionar um leque mais amplo dos interesses estratégicos de Moscou.</segment>
    <segment id="68">Novas sanções devem ser importas também pelos EUA.</segment>
    <segment id="69">À rede CNN parlamentares do Comitê de Relações Exteriores do Senado informaram que avançam as negociações</segment>
    <segment id="70">para que</segment>
    <segment id="71">para que um projeto de lei sobre sanções à Rússia e ajuda militar à Ucrânia seja aprovado ainda nesta semana</segment>
    <segment id="72">, com apoio de republicanos e democratas.</segment>
    <segment id="73">Algumas das medidas</segment>
    <segment id="74">, visando bancos russos</segment>
    <segment id="75">, poderiam ser aplicadas mesmo sem que uma invasão fosse efetivada</segment>
    <segment id="76">, como</segment>
    <segment id="77">como consequência do que os EUA consideram um esforço de Moscou para minar o governo ucraniano</segment>
    <segment id="78">, afirmou o senador democrata Bob Menendez.</segment>
    <segment id="79">Lá foraReceba no seu email uma seleção semanal com o que de mais importante aconteceu no mundo</segment>
    <segment id="80">; aberta para não assinantes.</segment>
    <segment id="81">Carregando...</segment>
    <segment id="82">O conflito na região do Leste Europeu escalou quando a Rússia moveu um contingente de 100 mil a 175 mil soldados às fronteiras ucranianas.</segment>
    <segment id="83">O país nega a intenção de invadir o vizinho</segment>
    <segment id="84">, masmas são frequentes os alertas internacionais de que essa possibilidade bate à porta.</segment>
    <segment id="85">​</segment>
    <segment id="86">Os EUA voltaram a afirmar</segment>
    <segment id="87">, neste sábado (29)</segment>
    <segment id="88">, que são concretos os indicativos de que Putin estaria pronto para invadir a Ucrânia.</segment>
    <segment id="89">Isso porque</segment>
    <segment id="90">porque o contingente militar russo na fronteira já reúne</segment>
    <segment id="91">, inclusive</segment>
    <segment id="92">, estoques de sangue e outros materiais médicos que permitiriam tratar eventuais vítimas</segment>
    <segment id="93">, disseram três autoridades do governo</segment>
    <segment id="94">, sob condição de anonimato</segment>
    <segment id="95">, à agência de notícias Reuters.</segment>
    <segment id="96">Crise entre Rússia e Ucrânia em 2021Mais    novamente         de   de  de  representando um</segment>
    <segment id="97">Durante as declarações feitas neste domingo</segment>
    <segment id="98">, o chanceler russo</segment>
    <segment id="99">, Serguei Lavrov</segment>
    <segment id="100">, voltou a negar que o país esteja ameaçando a Ucrânia e disse que deseja ter relações baseadas no "respeito mútuo" com os EUA.</segment>
    <segment id="101">"</segment>
    <segment id="102">Queremos relações boas</segment>
    <segment id="103">, igualitárias</segment>
    <segment id="104">, como</segment>
    <segment id="105">como com todos os países do mundo"</segment>
    <segment id="106">, disse ao Canal 1 da Rússia.</segment>
    <segment id="107">Putin tem uma lista de demandas para justificar o avanço russo na região.</segment>
    <segment id="108">Ele exige</segment>
    <segment id="109">, por exemplo</segment>
    <segment id="110">, que a Ucrânia nunca faça parte da Otan e que a aliança militar volte a seu formato de 1997</segment>
    <segment id="111">, anterior ao início de sua expansão a leste</segment>
    <segment id="112">, que aproximou tropas e armas das fronteiras russas.</segment>
    <segment id="113">Além disso</segment>
    <segment id="114">, no componente político</segment>
    <segment id="115">, o Kremlin vê risco de agitação interna</segment>
    <segment id="116">sese países antes aliados</segment>
    <segment id="117">sese tornarem democracias ocidentais.</segment>
  </rst>
</analysis>