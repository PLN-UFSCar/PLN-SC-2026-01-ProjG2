  <rst>
    <segment id="1">O presidente Luiz Inácio Lula da Silva rebateu indiretamente a fala de Carlos Alberto de Nóbrega sobre seu diploma.</segment>
    <segment id="2">Durante entrevista ao Roda Viva</segment>
    <segment id="3">, da TV Cultura</segment>
    <segment id="4">, na última segunda (3)</segment>
    <segment id="5">, o humorista disse que achava ruim que um homem sem graduação fosse eleito para governar</segment>
    <segment id="6">, pois</segment>
    <segment id="7">pois este afundava o país.</segment>
    <segment id="8">Em seu perfil no Twitter</segment>
    <segment id="9">, Lula comparou a história do Brasil com a da Argentina no campo da educação</segment>
    <segment id="10">, antes de reafirmar o compromisso de seus primeiros dois governos com a pauta.</segment>
    <segment id="11">O chefe do Executivo não citou Nóbrega.</segment>
    <segment id="12">O apresentador Carlos Alberto de Nóbrega no programa Roda Viva</segment>
    <segment id="13">, da TV Cultura - Divulgação"Em 1918</segment>
    <segment id="14">, a Argentina já tinha feito sua primeira reforma universitária e o Brasil não tinha sequer a sua primeira universidade"</segment>
    <segment id="15">, escreveu o presidente.</segment>
    <segment id="16">"</segment>
    <segment id="17">Quando xingarem que o Brasil é um país atrasado</segment>
    <segment id="18">, saibam que alguém quis que o país fosse assim.</segment>
    <segment id="19">Quando eu e o [José de] 'Zé' Alencar tomamos posse</segment>
    <segment id="20">, nós não tínhamos diploma</segment>
    <segment id="21">, masmas tínhamos a consciência de que nenhum país</segment>
    <segment id="22">sese desenvolve sem antes investir na educação.</segment>
    <segment id="23">"</segment>
    <segment id="24">No Roda Viva</segment>
    <segment id="25">, Nóbrega teceu críticas ao governo</segment>
    <segment id="26">, afirmando que brinca com Lula sem buscar a ofensa.</segment>
    <segment id="27">"</segment>
    <segment id="28">Quando o Lula trouxe o Maduro e colocaram um tapete vermelho para ele</segment>
    <segment id="29">, na mesma semana coloquei no 'A Praça'"</segment>
    <segment id="30">, afirmou.</segment>
    <segment id="31">Quando questionado sobre o que perguntaria ao presidente</segment>
    <segment id="32">casocaso ele participasse de seu podcast</segment>
    <segment id="33">, o humorista do "</segment>
    <segment id="34">A Praça</segment>
    <segment id="35">É Nossa" respondeu que gostaria de saber</segment>
    <segment id="36">comocomo um presidente da República</segment>
    <segment id="37">, ao receber o diploma do cargo</segment>
    <segment id="38">, chora e diz que é o primeiro diploma de sua vida.</segment>
    <segment id="39">Carlos Alberto de NóbregaMais    novamente         de   de  de  representando um  Ele ainda criticou gastos do governo</segment>
    <segment id="40">, afirmando que Lula teria comprado uma cama de R$ 60 mil.</segment>
    <segment id="41">O móvel que ele citava</segment>
    <segment id="42">, no caso</segment>
    <segment id="43">caso, dizia respeito a uma cama de R$ 42 mil.</segment>
    <segment id="44">Ditador Nicolás Maduro</segment>
    <segment id="45">sese encontra com Lula em Brasília Mais    novamente         de   de  de  representando um</segment>
