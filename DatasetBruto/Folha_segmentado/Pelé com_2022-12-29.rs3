  <rst>
    <segment id="1">Maior jogador de futebol do Brasil e considerado o atleta do século passado</segment>
    <segment id="2">, Pelé</segment>
    <segment id="3">, morto nesta quinta-feira</segment>
    <segment id="4">, aos 82 anos</segment>
    <segment id="5">, também</segment>
    <segment id="6">sese aventurou pela música.</segment>
    <segment id="7">O craque cantava</segment>
    <segment id="8">, tocava violão e escreveu mais de cem músicas</segment>
    <segment id="9">, além de ter feito parcerias com gigantes da música brasileira</segment>
    <segment id="10">, como</segment>
    <segment id="11">como Elis Regina</segment>
    <segment id="12">, Roberto Carlos e Sergio Mendes.</segment>
    <segment id="13">Pelé tocando violão em 1966 - FolhapressPelé teve seu interesse pela música despertado por seu pai</segment>
    <segment id="14">, Dondinho</segment>
    <segment id="15">, que tocava cavaquinho.</segment>
    <segment id="16">Ele aprendeu a tocar violão com o jogador Tite</segment>
    <segment id="17">, ponta esquerda do Santos e contemporâneo do Rei no clube paulista.</segment>
    <segment id="18">A estreia do Rei na música foi ainda nos anos 1960</segment>
    <segment id="19">, quando ele estava em atividade no futebol.</segment>
    <segment id="20">Ele lançou o compacto "Tabelinha"</segment>
    <segment id="21">, em 1969</segment>
    <segment id="22">, com duas músicas compostas pelo jogador e cantadas por Pelé e Elis em dueto.</segment>
    <segment id="23">Numa delas</segment>
    <segment id="24">, "</segment>
    <segment id="25">Perdão Não Tem Vez"</segment>
    <segment id="26">, uma bossa nova em estilo romântico</segment>
    <segment id="27">, Elis e Pelé têm um diálogo.</segment>
    <segment id="28">Ela perguntou quando ele fez a música</segment>
    <segment id="29">, o Rei diz que foi logo após uma excursão com o Santos.</segment>
    <segment id="30">"</segment>
    <segment id="31">Tenho uma certeza —quando você fez essa música</segment>
    <segment id="32">, você fez com dor de cotovelo"</segment>
    <segment id="33">, diz a cantora.</segment>
    <segment id="34">Na outra</segment>
    <segment id="35">, "Vexamão"</segment>
    <segment id="36">, Pelé narra</segment>
    <segment id="37">, com sua voz grave e desengonçada</segment>
    <segment id="38">, uma situação em que pedem</segment>
    <segment id="39">para que</segment>
    <segment id="40">para que ele toque violão e cante</segment>
    <segment id="41">, o que ele descreve na letra</segment>
    <segment id="42">comocomo um vexame.</segment>
    <segment id="43">"Mas o engraçado é que eu cantava errado</segment>
    <segment id="44">, e os ‘puxa’ achavam bom"</segment>
    <segment id="45">, ele canta.</segment>
    <segment id="46">Em agosto de 1969</segment>
    <segment id="47">, quando o compacto foi gravado</segment>
    <segment id="48">, o Brasil jogava as eliminatórias para a Copa do Mundo de 1970</segment>
    <segment id="49">, quando a seleção brasileira conquistou o tricampeonato mundial.</segment>
    <segment id="50">No dia em que eles</segment>
    <segment id="51">sese encontraram no estúdio</segment>
    <segment id="52">, o Brasil fez um jogo contra o Paraguai no Maracanã</segment>
    <segment id="53">, vencido por um a zero</segment>
    <segment id="54">, com gol de Pelé.</segment>
    <segment id="55">Ao longo dos anos</segment>
    <segment id="56">, não era raro ver o jogador empunhando um violão em imagens nas concentrações do Santos ou do Brasil.</segment>
    <segment id="57">E, apesar de a música ser um hobby para o atleta</segment>
    <segment id="58">, ele se</segment>
    <segment id="59">se apresentou diversas vezes na TV e em filmes</segment>
    <segment id="60">, incluindo o álbum "</segment>
    <segment id="61">Pelé", de 1977</segment>
    <segment id="62">, trilha sonora do documentário homônimo sobre ele</segment>
    <segment id="63">, em parceria com Sergio Mendes e participação do saxofonista Gerry Mulligan.</segment>
    <segment id="64">Das 13 faixas do disco</segment>
    <segment id="65">, seis são composições de Pelé.</segment>
    <segment id="66">Uma delas</segment>
    <segment id="67">, "Cidade Grande"</segment>
    <segment id="68">, foi regravada em 1981</segment>
    <segment id="69">, no álbum "</segment>
    <segment id="70">Alegria de um Povo"</segment>
    <segment id="71">, de Jair Rodrigues</segment>
    <segment id="72">, com participação do craque</segment>
    <segment id="73">,</segment>
    <segment id="74">quando</segment>
    <segment id="75">sese tornou um sucesso</segment>
    <segment id="76">.</segment>
    <segment id="77">Também em 1977</segment>
    <segment id="78">, ano em que Pelé</segment>
    <segment id="79">sese despediu dos gramados</segment>
    <segment id="80">, ele se</segment>
    <segment id="81">se apresentou com Roberto Carlos no especial do cantor na TV.</segment>
    <segment id="82">Eles tocaram violão e cantaram juntos a música "</segment>
    <segment id="83">Meu</segment>
    <segment id="84">Mundo</segment>
    <segment id="85">É uma Bola"</segment>
    <segment id="86">, lançada no álbum do jogador com Sergio Mendes</segment>
    <segment id="87">, em programa dedicado à Copa de 1978</segment>
    <segment id="88">, que aconteceria na Argentina.</segment>
    <segment id="89">Nos anos 1980</segment>
    <segment id="90">, Pelé foi um dos nomes que cantou no disco "Clube da Criança"</segment>
    <segment id="91">, um especial com músicas do programa homônimo apresentado por Xuxa na TV Manchete.</segment>
    <segment id="92">O Rei canta a música "</segment>
    <segment id="93">Recado à Criança"</segment>
    <segment id="94">, que ele mesmo compôs</segment>
    <segment id="95">, ao lado de Patrícia Marx e Luciano Nassyn</segment>
    <segment id="96">, que no ano seguinte integrariam o grupo musical infantil Trem da Alegria.</segment>
    <segment id="97">Além de Pelé</segment>
    <segment id="98">, músicos</segment>
    <segment id="99">comocomo Martinho da Vila</segment>
    <segment id="100">, Robertinho de Recife</segment>
    <segment id="101">, Sérgio Reis</segment>
    <segment id="102">, a banda Roupa Nova e</segment>
    <segment id="103">, claro</segment>
    <segment id="104">, Xuxa também cantam no álbum.</segment>
    <segment id="105">"</segment>
    <segment id="106">O futuro pertence a vocês</segment>
    <segment id="107">, respeitamos sua nobreza"</segment>
    <segment id="108">, canta Pelé na música.</segment>
    <segment id="109">Também mirando o público infantil</segment>
    <segment id="110">, Pelé gravou "</segment>
    <segment id="111">ABC do Bicho-Papão"</segment>
    <segment id="112">, agora com o Trem da Alegria</segment>
    <segment id="113">, em 1998.</segment>
    <segment id="114">"Que bom vai ser/ o nosso Brasil/ quando a maioria/ souber ler e escrever/ até parece conto de fada/</segment>
    <segment id="115">masmas acredito em vocês/ nossa criançada"</segment>
    <segment id="116">, diz a letra.</segment>
    <segment id="117">A música depois foi usada em 1998 pelo Ministério da Educação</segment>
    <segment id="118">, com Pelé</segment>
    <segment id="119">comocomo garoto-propaganda da campanha</segment>
    <segment id="120">, em vídeo exibido na TV.</segment>
    <segment id="121">Em 2006</segment>
    <segment id="122">, Pelé ainda lançou o álbum "</segment>
    <segment id="123">Pelé Ginga"</segment>
    <segment id="124">, com participações de Gilberto Gil e Rappin’ Hood.</segment>
    <segment id="125">O disco traz 13 composições do craque</segment>
    <segment id="126">, incluindo faixas antigas</segment>
    <segment id="127">, como</segment>
    <segment id="128">como "Cidade Grande".</segment>
    <segment id="129">Dez anos depois</segment>
    <segment id="130">, Pelé celebrou a realização dos Jogos Olímpicos no Rio de Janeiro com a música "Esperança"</segment>
    <segment id="131">, escrita e gravada por ele.</segment>
    <segment id="132">Novamente mirando a juventude</segment>
    <segment id="133">, ele é acompanhado por um coro de crianças e evoca a "festa brasileira" que "fará todo o mundo feliz".</segment>
    <segment id="134">LEIA MAIS SOBRE PELÉCâncer de Pelé progrediu</segment>
    <segment id="135">, e tratamento não surtiu efeitoPelé</segment>
    <segment id="136">sese revelou ao mundo aos 17 anos</segment>
    <segment id="137">, na Copa de 1958Preservado pela família</segment>
    <segment id="138">, Edson manteve a fé por saber que Pelé é imortalPelé só foi Pelé</segment>
    <segment id="139">porque</segment>
    <segment id="140">porque antes existiu o menino EdsonPelé fez história com gol 1.001</segment>
    <segment id="141">, não com o 1.000</segment>
    <segment id="142">, descobriu a Folha em 1995Pelé foi de estrela a deus do futebol na Copa de 1970Um acróstico para PeléPelé sempre foi referência para qualquer comparaçãoPelé e Santos dominaram o mundo em 1962 e 1963Pelé ficou mais próximo dos filhos com o passar dos anosEmbaixador da &amp;#</segment>
    <segment id="143">039;marca Brasil&amp;#039</segment>
    <segment id="144">;, Pelé faturou menos do que poderiaPelé foi astro no futebol</segment>
    <segment id="145">, masmas coadjuvante no cinemaAntes de a bola chegar</segment>
    <segment id="146">, pelo olhar</segment>
    <segment id="147">,</segment>
    <segment id="148">Pelé já me dizia o que pretendia fazerPelé faturou com comerciais até o fim da vidaPelé versão</segment>
    <segment id="149">Nostradamus fez previsões furadas que viraram piadaEm &amp;#039</segment>
    <segment id="150">;Pelépolis&amp;#039</segment>
    <segment id="151">;, todo morador tem uma história com o ReiAlckmin diz que Pelé era um atleta completo e lamenta morteTrês Corações e Santos guardam relíquias de PeléPelé foi personagem cercado de mitos e histórias inusitadasMito de que Santos parou guerra na África foi contestado após 50 anosPresidente da CBF promete &amp;#</segment>
    <segment id="152">039;todas homenagens possíveis&amp;#039</segment>
    <segment id="153">;</segment>
    <segment id="154">a PeléPara o homem negro que vive dentro do PeléPelé conviveu com lesões durante título de 1962 e fracasso de 1966Pelé transitou entre políticos</segment>
    <segment id="155">, masmas</segment>
    <segment id="156">sese frustrou quando foi um delesNeymar diz que Pelé &amp;#039</segment>
    <segment id="157">;transformou o futebol em arte&amp;#039</segment>
    <segment id="158">;Pelé impulsionou o &amp;#039</segment>
    <segment id="159">;soccer&amp;#039</segment>
    <segment id="160">; nos EUA ao</segment>
    <segment id="161">sese transferir para o CosmosLuto e agradecimento marcam repercussão da morte de Pelé nas redesFilhos e netos de Pelé</segment>
    <segment id="162">sese despedem:</segment>
    <segment id="163">&amp;#</segment>
    <segment id="164">039;Tudo o que somos é graças a você&amp;#039</segment>
    <segment id="165">;Messi e Cristiano Ronaldo prestam homenagem a Pelé: &amp;#039</segment>
    <segment id="166">;adeus ao eterno Rei&amp;#039</segment>
    <segment id="167">;Clubes brasileiros</segment>
    <segment id="168">homenageiam</segment>
    <segment id="169">Pelé pelas redes sociaisRei Pelé é homenageado com coroa em perfil do Santos nas redes sociaisRelembre frases de Pelé</segment>
    <segment id="170">, de seus admiradores e de desafetosMelhor jogador da história</segment>
    <segment id="171">, Pelé morre aos 82 anos</segment>
    <segment id="172">, em São Paulo</segment>
  </rst>
