  <rst>
    <segment id="1">A diretora do Instituto Marielle Franco</segment>
    <segment id="2">, Anielle Franco</segment>
    <segment id="3">, representantes da organização e parlamentares negras</segment>
    <segment id="4">sese reuniram nesta quinta (9)</segment>
    <segment id="5">, em Brasília</segment>
    <segment id="6">, com a ministra do TSE (Tribunal Superior Eleitoral)</segment>
    <segment id="7">Maria Claudia Bucchianeri e com o subprocurador-geral Carlos Vilhena.</segment>
    <segment id="8">Lambe-lambe em homenagem a Marielle Franco na escadaria da rua Cristiano Viana</segment>
    <segment id="9">, em Pinheiros</segment>
    <segment id="10">, na zona oeste de São Paulo - Danilo Verpa - 20.mar.2018/FolhapressPALAVRAS  Segundo participantes do encontro</segment>
    <segment id="11">, a ministra do TSE</segment>
    <segment id="12">sese comprometeu em avançar com a criação de uma comissão de combate à violência política</segment>
    <segment id="13">, além da adequação e criação de canais de denúncia específicos para combater a violência política de gênero e raça.</segment>
    <segment id="14">PALAVRAS 2</segment>
    <segment id="15">O subprocurador-geral Carlos Vilhena</segment>
    <segment id="16">, por sua vez</segment>
    <segment id="17">, falou em garantir a interlocução com instâncias do Ministério Público Federal para adotar sugestões feitas pelo instituto.</segment>
    <segment id="18">Da esquerda para a direita</segment>
    <segment id="19">, Mazeh Silva</segment>
    <segment id="20">, Professora Madalena</segment>
    <segment id="21">, Laura Sito</segment>
    <segment id="22">, Talíria Petrone</segment>
    <segment id="23">, Carlos Vilhena</segment>
    <segment id="24">, Anielle Franco</segment>
    <segment id="25">, Fabiana Pinto</segment>
    <segment id="26">, Tainá de Paula e Flávia Hellen - DivulgaçãoESPELHO</segment>
    <segment id="27">Na ocasião</segment>
    <segment id="28">, o instituto apresentou sua pesquisa "Violência Política de Gênero e Raça no Brasil 2021"</segment>
    <segment id="29">, que retrata a situação dos direitos políticos das mulheres negras e faz recomendações de atuação para organizações da sociedade civil e movimentos sociais</segment>
    <segment id="30">, partidos políticos</segment>
    <segment id="31">, casas legislativas e Judiciário.</segment>
    <segment id="32">LEIA</segment>
    <segment id="33">TODOS OS TEMAS ABORDADOS PELA COLUNA NA EDIÇÃO IMPRESSA</segment>
    <segment id="34">DESTA SEXTA (10)Baixo índice de vacinação no Norte e no Nordeste acende alerta no Ministério da SaúdeTSE e MPF recebem Instituto Marielle Franco para falar sobre violência política de gênero e raçaMãe de Paulo Gustavo participará de especial da Globo sobre famílias impactadas pela CovidGloria Pires apresenta no Festival do Rio o primeiro filme que produziu</segment>
    <segment id="35">, &amp;#039</segment>
    <segment id="36">;A</segment>
    <segment id="37">Suspeita&amp;#039</segment>
    <segment id="38">;Cartunista</segment>
    <segment id="39">Estela</segment>
    <segment id="40">May lança coleção de roupas com suas tirinhasESTANTE</segment>
    <segment id="41">Lançamento dos livros Mais    novamente         de   de  de  representando um  O jornalista Luis Erlanger</segment>
    <segment id="42">, ex-diretor de Comunicação da Globo</segment>
    <segment id="43">, recebeu o ator Eriberto Leão no lançamento de seus três novos livros</segment>
    <segment id="44">, "</segment>
    <segment id="45">Todo Tempo do Mundo"</segment>
    <segment id="46">, "</segment>
    <segment id="47">Salto Alto" e "</segment>
    <segment id="48">Agora e Na Hora"</segment>
    <segment id="49">, na segunda (6).</segment>
    <segment id="50">O evento ocorreu na Livraria da Travessa do Leblon</segment>
    <segment id="51">, no Rio</segment>
    <segment id="52">, e contou com a presença da atriz Maria Padilha e do roteirista George Moura.  com LÍGIA MESQUITA</segment>
    <segment id="53">, VICTORIA AZEVEDO</segment>
