  <rst>
    <segment id="1">Artistas</segment>
    <segment id="2">comocomo Anitta</segment>
    <segment id="3">, Doja Cat</segment>
    <segment id="4">, Lizzo passaram pelo tapete vermelho do Grammy 2023</segment>
    <segment id="5">, a mais consagrada premiação da música.</segment>
    <segment id="6">O evento</segment>
    <segment id="7">, que ocorre na noite deste domingo (5)</segment>
    <segment id="8">, em Los Angeles</segment>
    <segment id="9">, nos Estados Unidos</segment>
    <segment id="10">, terá shows de Harry Styles</segment>
    <segment id="11">, Lizzo e Bad Bunny.</segment>
    <segment id="12">Lizzo no tapete vermelho do Grammy 2023 - David Swanson/REUTERSO tapete vermelho teve looks inusitados e imponentes</segment>
    <segment id="13">, a começar pelo da cantora Doja Cat</segment>
    <segment id="14">, do hit "Say So"</segment>
    <segment id="15">, que usou um vestido preto de vinil brilhante da Versace</segment>
    <segment id="16">, com luvas até os braços e brincos da mesma cor.</segment>
    <segment id="17">Grammy 2023:</segment>
    <segment id="18">Veja looks das celebridades no eventoMais    novamente         de   de  de  representando um  Anitta foi indicada à estatueta de artista revelação</segment>
    <segment id="19">, umas das quatro principais do prêmio.</segment>
    <segment id="20">Ela é a primeira brasileira a ser nomeada para este troféu desde Astrud Gilberto</segment>
    <segment id="21">, em 1965.</segment>
    <segment id="22">Ela também chegou com um vestido preto da italiana Versace</segment>
    <segment id="23">, ostentando ainda joias da Tiffany &amp;amp</segment>
    <segment id="24">;</segment>
    <segment id="25">Co.</segment>
    <segment id="26">O vestido</segment>
    <segment id="27">, um modelo vintage de 2003 da marca</segment>
    <segment id="28">, era longo e sem alças</segment>
    <segment id="29">, destacando uma enorme cauda.</segment>
    <segment id="30">Já a americana Lizzo</segment>
    <segment id="31">, indicada a várias categorias do prêmio</segment>
    <segment id="32">, incluindo álbum do ano</segment>
    <segment id="33">, escolheu um look extravagante para a ocasião.</segment>
    <segment id="34">Ela vestiu uma espécie de capa laranja</segment>
    <segment id="35">, com capuz</segment>
    <segment id="36">, coberta de flores da mesma cor.</segment>
    <segment id="37">Seu rosto aparecia quase escondido no modelito</segment>
    <segment id="38">, masmas já na cerimônia ela tirou a parte coberta e transformou o look num modelo sem alças.</segment>
    <segment id="39">Harry Styles também chamou a atenção com um macacão de uma grife francesa feito em parceria com a Swarovski</segment>
    <segment id="40">, especialmente para o evento.</segment>
    <segment id="41">A peça brilhante é toda estampada com losangos coloridos.</segment>
    <segment id="42">Já durante a cerimônia ele trocou de vestimenta e optou por um paletó branco e lapela preta</segment>
    <segment id="43">, enquanto vestia uma camiseta toda prateada por baixo e uma calça de alfaitaria cáqui.</segment>
    <segment id="44">Harry Styles no Grammy 2023</segment>
    <segment id="45">, com macacão de grife francesa em parceria com a Swarovski - David Swanson/REUTERSTaylor Swift apostou em tons escuros</segment>
    <segment id="46">, com um vestido de mangas longas em azul escuro com brilhos</segment>
    <segment id="47">, com uma faixa transparente que deixa seu dorso à mostra.</segment>
    <segment id="48">Os brincos com brilhantes no formato de quatro losangos também roubaram a cena.</segment>
    <segment id="49">Confira os vencedores do Grammy 2023</segment>
    <segment id="50">Uma das primeiras famosas a ser entrevistada pela atriz foi a cantora Kelsea Ballerini</segment>
    <segment id="51">, que usava um vestido amarelo.</segment>
    <segment id="52">Ela disse que o look é inspirado numa faixa do seu disco "Subject to Change".</segment>
    <segment id="53">Sam Smith também chamou a atenção com um look extravagante da Valentino</segment>
    <segment id="54">, com uma capa vermelha volumosa</segment>
    <segment id="55">, com uma cartola e véu na altura dos olhos</segment>
    <segment id="56">, também vermelho</segment>
    <segment id="57">, junto de luvas e uma bengala decorada.</segment>
    <segment id="58">Kim Petras chegou junto com o cantor</segment>
    <segment id="59">, com um look no mesmo tom</segment>
    <segment id="60">, com um vestido curto e um longo véu translúcido.</segment>
    <segment id="61">Eles chegaram junto de outras pessoas</segment>
    <segment id="62">, com looks similares</segment>
    <segment id="63">, que devem fazer parte da apresentação da dupla no prêmio.</segment>
    <segment id="64">A canadense Shania Twain</segment>
    <segment id="65">, por sua vez</segment>
    <segment id="66">, investiu em um chapéu alto</segment>
    <segment id="67">, branco</segment>
    <segment id="68">, com bolas pretas e paetês</segment>
    <segment id="69">, combinando com a estampa do seu terno</segment>
    <segment id="70">, que contrasta com um longo cabelo vermelho.</segment>
  </rst>
</analysis>