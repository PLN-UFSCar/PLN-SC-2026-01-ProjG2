  <rst>
    <segment id="1">O parecer vinculante da AGU (Advocacia-Geral da União) que prevê pena de demissão para casos de assédio sexual na administração pública federal deveria servir de inspiração</segment>
    <segment id="2">para que</segment>
    <segment id="3">para que estados e municípios fizessem o mesmo</segment>
    <segment id="4">, defende a Fenamp (Federação Nacional dos Trabalhadores dos Ministérios Públicos dos Estados).</segment>
    <segment id="5">Protesto contra denúncias de assédio contra o ex-presidente da Caixa Econômica Federal Pedro Guimarães - Gabriela Biló/Folhapress</segment>
    <segment id="6">Para a entidade</segment>
    <segment id="7">, a adoção da medida poderia frear</segment>
    <segment id="8">"a onda de assédio que ocorre dentro dos mais variados órgãos</segment>
    <segment id="9">, principalmente dentro do Ministério Público dos Estados".</segment>
    <segment id="10">A federação cita pesquisa realizada com a 4.077 pessoas que trabalham nos MPEs no país e que indica que 5</segment>
    <segment id="11">,39% das servidoras disseram ter recebido atenção sexual indesejada.</segment>
    <segment id="12">"Reivindicamos que os MPEs e o CNMP (Conselho Nacional do Ministério Público)</segment>
    <segment id="13">sese engajem o quanto antes e adotem a iniciativa do governo federal</segment>
    <segment id="14">para que</segment>
    <segment id="15">para que possamos ter instituições mais humanas e funcionais"</segment>
    <segment id="16">, escreve a federação.</segment>
  </rst>
</analysis>