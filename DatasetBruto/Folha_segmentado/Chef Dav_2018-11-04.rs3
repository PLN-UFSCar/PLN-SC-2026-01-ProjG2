  <rst>
    <segment id="1">Um workshop sobre aproveitamento total dos alimentos comandado pelo chef David Hertz e sua equipe mostrou de forma lúdica</segment>
    <segment id="2">comocomo a Gastromotiva tem contribuído para mudar a relação de parte da população com o alimento que consome.</segment>
    <segment id="3">Integrante da Rede Folha de Empreendedores Socioambientais</segment>
    <segment id="4">, Hertz também participou do painel</segment>
    <segment id="5">Muito Além da Gastronomia.</segment>
    <segment id="6">Para ele</segment>
    <segment id="7">, a rede tem fortalecido o empreendedorismo e o impacto social ao longo dos últimos anos.</segment>
    <segment id="8">Hertz acredita que o Fiis é o lugar ideal para conhecer e aprender.</segment>
    <segment id="9">FESTIVAL</segment>
    <segment id="10">O Fiis ​acontece entre os dias 2 e 7 de novembro no Palace Cassino</segment>
    <segment id="11">, em Poços de Caldas (MG).</segment>
    <segment id="12">O evento agrega o encontro anual da Rede Folha de Empreendedores Socioambientais</segment>
    <segment id="13">, formada por cem líderes</segment>
    <segment id="14">, o Congresso Sorriso do Bem</segment>
    <segment id="15">, da Turma do Bem</segment>
    <segment id="16">, correalizadora desta edição</segment>
    <segment id="17">, e o Fórum Melhores Práticas para Saúde no Terceiro Setor</segment>
    <segment id="18">, da Aliança Latina.</segment>
    <segment id="19">Na programação</segment>
    <segment id="20">, temas</segment>
    <segment id="21">comocomo o futuro dos negócios sociais e das ONGs</segment>
    <segment id="22">, captação</segment>
    <segment id="23">, mobilização e conexão</segment>
    <segment id="24">, inovação e novo significado do voluntariado serão discutidos durante masterclasses</segment>
    <segment id="25">, workshops e painéis que contarão com a participação de empreendedores</segment>
    <segment id="26">, investidores e empresas que atuam por impacto positivo.</segment>
  </rst>
</analysis>