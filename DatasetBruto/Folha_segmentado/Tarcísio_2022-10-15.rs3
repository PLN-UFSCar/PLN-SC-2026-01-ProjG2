  <rst>
    <segment id="1">Candidato ao Governo de São Paulo</segment>
    <segment id="2">, Tarcísio de Freitas (Republicanos) tem dito que indicará secretários técnicos</segment>
    <segment id="3">casocaso vença as eleições</segment>
    <segment id="4">, masmas aliados preveem dificuldades para ele cumprir a promessa.</segment>
    <segment id="5">O ex-ministro será pressionado a acomodar bolsonaristas e a contemplar indicações de aliados</segment>
    <segment id="6">comocomo Republicanos</segment>
    <segment id="7">, PL e PSD.</segment>
    <segment id="8">Aliados mais recentes também pedem espaço.</segment>
    <segment id="9">O União Brasil quer manter a influência na secretaria de Logística e Transportes</segment>
    <segment id="10">, e o PP aceitou</segment>
    <segment id="11">sese juntar a Tarcísio com a certeza de que continuará no comando da pasta de Transportes Metropolitanos</segment>
    <segment id="12">, em negociação costurada pelo presidente do Republicanos</segment>
    <segment id="13">, Marcos Pereira.</segment>
    <segment id="14">Tarcísio de Freitas durante evento com Jair Bolsonaro no templo da Assembleia de Deus no bairro Belenzinho</segment>
    <segment id="15">, em SP  - Mathilde Missioneiro-4.out.2022/Folhapress  Como mostrou o Painel</segment>
    <segment id="16">, Rodrigo Garcia (PSDB) entregou a secretaria para o PP</segment>
    <segment id="17">, em junho</segment>
    <segment id="18">, para garantir o apoio da sigla à sua candidatura.</segment>
    <segment id="19">Em entrevista ao canal do YouTube Talk Churras</segment>
    <segment id="20">, do apresentador Paulo Mathias</segment>
    <segment id="21">, Tarcísio deu indicações fortes de que o ex-ministro Guilherme Afif Domingos</segment>
    <segment id="22">, coordenador de seu programa de governo</segment>
    <segment id="23">, estará no secretariado.</segment>
    <segment id="24">Também citou o ex-deputado Eleuses Paiva para a pasta da Saúde e afirmou que Rosana Valle</segment>
    <segment id="25">, que cuida de propostas para as mulheres</segment>
    <segment id="26">, é "um grande nome</segment>
    <segment id="27">, uma grande possibilidade" para a equipe de governo.</segment>
    <segment id="28">Na área econômica</segment>
    <segment id="29">, o mais cotado para a Fazenda é Samuel Kinoshita</segment>
    <segment id="30">, que trabalhou com o ministro Paulo Guedes</segment>
    <segment id="31">, enquanto Rafael Benini tende a ir para uma área de infraestrutura.</segment>
  </rst>
</analysis>