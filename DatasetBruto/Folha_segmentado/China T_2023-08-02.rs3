  <rst>
    <segment id="1">As tempestades que castigam o norte da China são as mais intensas em 140 anos</segment>
    <segment id="2">, ou desde o início da série histórica</segment>
    <segment id="3">, anunciaram autoridades nesta quarta (2).</segment>
    <segment id="4">As chuvas intermitentes têm provocado mortes e deixado um rastro de destruição</segment>
    <segment id="5">, levando à mobilização de milhares de socorristas para operações de emergência.</segment>
    <segment id="6">As precipitações na região de Pequim começaram no sábado (29)</segment>
    <segment id="7">, com a chegada do tufão Doksuri.</segment>
    <segment id="8">Em apenas 40 horas</segment>
    <segment id="9">, a capital chinesa acumulou o índice pluviométrico esperado para todo o mês de julho.</segment>
    <segment id="10">Em quatro dias</segment>
    <segment id="11">, foram 744</segment>
    <segment id="12">,8 mm de chuvas.</segment>
    <segment id="13">Trata-</segment>
    <segment id="14">sese do maior volume em mais de um século: o recorde anterior era de 1891</segment>
    <segment id="15">, quando 609 mm foram registrados</segment>
    <segment id="16">, segundo o Serviço Meteorológico de Pequim.</segment>
    <segment id="17">Socorristas</segment>
    <segment id="18">sese deslocam de bote em avenida alagada na província de Hebei</segment>
    <segment id="19">, no norte da China - Mu Yu/Xinhua</segment>
    <segment id="20">O tufão foi rebaixado a depressão tropical ainda no fim de semana e</segment>
    <segment id="21">, nas últimas horas</segment>
    <segment id="22">, as chuvas</segment>
    <segment id="23">sese tornaram mais fracas.</segment>
    <segment id="24">Elas continuam</segment>
    <segment id="25">, porém</segment>
    <segment id="26">porém, a provocar estragos</segment>
    <segment id="27">, e autoridades reiteram que os riscos de inundações e desastres geológicos permanecem.</segment>
    <segment id="28">Na véspera</segment>
    <segment id="29">, a imprensa estatal havia informado que ao menos 20 pessoas tinham morrido e 19 estavam desaparecidas na região —os números não foram atualizados nesta quarta.</segment>
    <segment id="30">Uma das províncias mais atingidas é Hebei</segment>
    <segment id="31">, a sudoeste da capital</segment>
    <segment id="32">, onde autoridades declararam estado de emergência.</segment>
    <segment id="33">Mais de 800 mil habitantes da região</segment>
    <segment id="34">tiveram de ser retiradas de suas casas</segment>
    <segment id="35">, sendo 130 mil delas —ou um sexto da população da província— somente em Zhuozhou.</segment>
    <segment id="36">O município tinha bairros inteiros alagados</segment>
    <segment id="37">, e o canal estatal CCTV transmitiu imagens de dezenas de moradores ilhados.</segment>
    <segment id="38">O departamento de segurança pública local disse que a cidade precisa de jangadas</segment>
    <segment id="39">, coletes salva-vidas e suprimentos de emergência com urgência.</segment>
    <segment id="40">Moradores disseram que as águas subiram até quatro metros</segment>
    <segment id="41">, e cerca de 9.000 socorristas foram enviados ao município.</segment>
    <segment id="42">As inundações provocaram ainda a interrupção do fornecimento de água e de energia elétrica na área.</segment>
    <segment id="43">Quase 650 hectares de terras agrícolas foram destruídos.</segment>
    <segment id="44">China, terra do meioReceba no seu email os grandes temas da China explicados e contextualizados</segment>
    <segment id="45">; exclusiva para assinantes.</segment>
    <segment id="46">Carregando...</segment>
    <segment id="47">Moradores de Zhuozhou que estão ilhados recorreram às redes sociais para reclamar da demora do resgate.</segment>
    <segment id="48">Funcionários de uma livraria</segment>
    <segment id="49">, por exemplo</segment>
    <segment id="50">, escreveram no app WeChat que estavam presos no quarto andar do prédio do estabelecimento</segment>
    <segment id="51">, onde mais de quatro milhões de livros estavam armazenados.</segment>
    <segment id="52">Apesar da crise</segment>
    <segment id="53">, o governo de Pequim suspendeu o alerta vermelho para inundações nesta quarta</segment>
    <segment id="54">, depois que o "fluxo na maioria dos rios voltou a ficar abaixo do sinal de alarme"</segment>
    <segment id="55">, segundo a agência de notícias oficial chinesa</segment>
    <segment id="56">, a Xinhua.</segment>
    <segment id="57">Na véspera</segment>
    <segment id="58">, o líder do país</segment>
    <segment id="59">, Xi Jinping</segment>
    <segment id="60">, pediu esforços para evitar outras mortes</segment>
    <segment id="61">, masmas buscou minimizar a situação</segment>
    <segment id="62">, orientando autoridades locais a restaurar a rotina habitual o mais rápido possível.</segment>
    <segment id="63">A atenção</segment>
    <segment id="64">sese volta agora para as operações de resgate: centenas de socorristas da Cruz Vermelha foram enviados às áreas mais afetadas para desbloquear vias e ajudar nas operações de salvamento.</segment>
    <segment id="65">Em visita ao distrito de Mentougou</segment>
    <segment id="66">, um dos mais afetados na capital</segment>
    <segment id="67">, o vice-primeiro-ministro</segment>
    <segment id="68">, Zhang Guoqing</segment>
    <segment id="69">, disse que "a prioridade era salvar vidas e lutar contra o tempo para encontrar desaparecidos e pessoas ilhadas".</segment>
    <segment id="70">No distrito de Fangshan</segment>
    <segment id="71">, também em Pequim</segment>
    <segment id="72">, repórteres da agência AFP descreveram um parque totalmente inundado.</segment>
    <segment id="73">Toneladas de resíduos</segment>
    <segment id="74">, arrastados pela água</segment>
    <segment id="75">, acumularam-</segment>
    <segment id="76">sese em áreas da cidade.</segment>
    <segment id="77">O tufão Doksuri chegou à China na sexta (28)</segment>
    <segment id="78">, tendo passado antes por Taiwan e pelas Filipinas.</segment>
    <segment id="79">Ele foi um dos poucos fenômenos do tipo a atingir Pequim desde que os registros de fenômenos do tipo começaram a ser feitos</segment>
    <segment id="80">, em 1951 —um deles</segment>
    <segment id="81">, em 1956</segment>
    <segment id="82">, provocou precipitações de quase 300 mm.</segment>
    <segment id="83">Tufão, temporais e onda de calor:</segment>
    <segment id="84">eventos climáticos extremos atingem ÁsiaMais    novamente         de   de  de  representando um    Meteorologistas alertam que outro tufão</segment>
    <segment id="85">, o Khanun</segment>
    <segment id="86">, está prestes a atingir a densamente povoada costa chinesa.</segment>
    <segment id="87">Segundo eles</segment>
    <segment id="88">, a nova tempestade pode agravar os prejuízos causados pelo Doksuri.</segment>
    <segment id="89">Com ventos de até 234 km/h</segment>
    <segment id="90">, o Khanun foi considerado "muito poderoso" pela Agência Meteorológica do Japão.</segment>
    <segment id="91">O tufão atingiu nesta quarta a região de Okinawa</segment>
    <segment id="92">, no sul japonês</segment>
    <segment id="93">, e quase 200 mil casas ficaram sem energia.</segment>
    <segment id="94">Um homem de 90 anos morreu depois de a garagem de sua casa desabar</segment>
    <segment id="95">, provavelmente devido às rajadas de vento</segment>
    <segment id="96">, segundo a imprensa local.</segment>
    <segment id="97">Outras 35 pessoas ficaram feridas.</segment>
    <segment id="98">Espera-</segment>
    <segment id="99">sese que o tufão</segment>
    <segment id="100">Khanun chegue à China no sábado (5).</segment>
    <segment id="101">A imprensa estatal alertou na semana passada que aproximadamente 130 milhões de habitantes seriam afetados pelas chuvas intensas no norte do país.</segment>
    <segment id="102">Lá foraReceba no seu email uma seleção semanal com o que de mais importante aconteceu no mundo</segment>
    <segment id="103">; aberta para não assinantes.</segment>
    <segment id="104">Carregando...  Dados da Organização Meteorológica Mundial (OMM)</segment>
    <segment id="105">, agência da ONU para questões do clima</segment>
    <segment id="106">, indicam que eventos climáticos extremos</segment>
    <segment id="107">comocomo secas</segment>
    <segment id="108">, enchentes</segment>
    <segment id="109">, deslizamentos de terra</segment>
    <segment id="110">, tempestades e incêndios mais do que triplicaram ao longo dos últimos 50 anos em consequência do aquecimento global.</segment>
    <segment id="111">A Ásia foi o continente mais afetado</segment>
    <segment id="112">, contabilizando mais de 3.400 desastres nesse período</segment>
    <segment id="113">, responsáveis por quase 1 milhão de mortes.</segment>
    <segment id="114">Outro órgão ligado à ONU</segment>
    <segment id="115">, o IPCC (Painel Intergovernamental para a Mudança de Clima)</segment>
    <segment id="116">, diz que hoje é inequívoco que parte dessas mudanças foi gerada por ações humanas.</segment>
  </rst>
</analysis>