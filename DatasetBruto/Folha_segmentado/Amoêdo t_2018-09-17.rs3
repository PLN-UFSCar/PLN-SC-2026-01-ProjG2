    <segment id="7">masmas 7% entre os que ganham mais de dez salários mínimos.  MURCHOU</segment>
    <segment id="8">A performance de Geraldo Alckmin (PSDB-SP) entre os mais ricos foge da que tradicionalmente era registrada em eleições anteriores.</segment>
    <segment id="9">Ele tem 9% do total de votos —</segment>
    <segment id="10">masmas só 4% entre os que ganham mais de dez salários mínimos.</segment>
    <segment id="11">INFLOU</segment>
    <segment id="12">Já entre os que recebem até dois salários</segment>
    <segment id="13">, Alckmin tem 11% dos votos.  HERDOU</segment>
    <segment id="14">E Jair Bolsonaro</segment>
    <segment id="15">, entre os mais ricos</segment>
