  <rst>
    <segment id="1">No Globo</segment>
    <segment id="2">Repórter desta semana</segment>
    <segment id="3">, vamos descobrir que ditadores</segment>
    <segment id="4">sese alimentam de exércitos e de narrativas.</segment>
    <segment id="5">Vamos acompanhar a migração de grupos autoritários que</segment>
    <segment id="6">sese espalham pelo Brasil adentro e pelo exterior.</segment>
    <segment id="7">Como vivem os malabaristas da oratória em Miami?</segment>
    <segment id="8">De que</segment>
    <segment id="9">sese alimentam os príncipes sofistas do ABC?</segment>
    <segment id="10">Até onde conseguem equilibrar argumentos autoritários para garantir sua sobrevivência?</segment>
    <segment id="11">Colunas e BlogsReceba no seu email uma seleção de colunas e blogs da Folha</segment>
    <segment id="12">; exclusiva para assinantes.</segment>
    <segment id="13">Carregando...</segment>
    <segment id="14">No MasterChef de hoje</segment>
    <segment id="15">, vamos preparar uma receita de ditadura gratinada: viole brutalmente os direitos humanos.</segment>
    <segment id="16">Imponha a censura.</segment>
    <segment id="17">Ataque a imprensa.</segment>
    <segment id="18">Destrua o Legislativo e o Judiciário.</segment>
    <segment id="19">Julgue</segment>
    <segment id="20">, prenda e torture sem prestar contas a ninguém.</segment>
    <segment id="21">Restrinja liberdades individuais.</segment>
    <segment id="22">Esfarele a democracia.</segment>
    <segment id="23">Tempere a gosto e coloque na panela de pressão.</segment>
    <segment id="24">Hoje, no Programa do Ratinho</segment>
    <segment id="25">, o teste de DNA vai comprovar que Nicolás Maduro</segment>
    <segment id="26">, Viktor Orbán</segment>
    <segment id="27">, Vladimir Putin</segment>
    <segment id="28">, Mohammed bin Salman e Kim Jong-un têm mais semelhanças do que diferenças.</segment>
    <segment id="29">Não perca a nova novela das nove: a incrível narrativa do presidente que foi eleito para salvar a democracia brasileira e que estende tapete vermelho para ditadores.</segment>
    <segment id="30">Ilustração de Débora Gonzales para coluna de Renato Terra de 1º de junho de 2023 - Débora Gonzales</segment>
    <segment id="31">No Masked Singer Brasil</segment>
    <segment id="32">, vamos receber um estadista mascarado.</segment>
    <segment id="33">Ele canta com sua voz rouca para embalar a militância com a indicação de seu próprio advogado para o Supremo Tribunal Federal.</segment>
    <segment id="34">Agora, no Cidade Alerta:</segment>
    <segment id="35">Jovem petista tenta criticar atitudes autocráticas de Lula e acaba internado no Sírio-Libanês.</segment>
    <segment id="36">"</segment>
    <segment id="37">Por sorte</segment>
    <segment id="38">, tinha um bom plano de saúde"</segment>
    <segment id="39">, diz José de Aguiar</segment>
    <segment id="40">, conhecido</segment>
    <segment id="41">comocomo Aguiarzinho.</segment>
    <segment id="42">Põe na tela!</segment>
    <segment id="43">Interrompemos a nossa entrevista de hoje no Roda Viva</segment>
    <segment id="44">porque</segment>
    <segment id="45">porque nosso convidado teve uma pane cognitiva e falou em línguas ao ser confrontado com uma pergunta sobre corrupção no governo Bolsonaro.</segment>
    <segment id="46">Ele foi encaminhado para o Sírio-Libanês.</segment>
    <segment id="47">"</segment>
    <segment id="48">Por sorte</segment>
    <segment id="49">, Deus tinha um bom plano para mim"</segment>
    <segment id="50">, disse o deputado cassado.</segment>
    <segment id="51">Uma pausa para nossos comerciais:</segment>
    <segment id="52">Você que está em casa já parou pra pensar nos traços impressionantemente semelhantes entre Hugo Chávez e Jair Bolsonaro?</segment>
    <segment id="53">A diferença é que Chávez conseguiu colocar seu plano em prática.</segment>
    <segment id="54">A inaptidão de Bolsonaro para trabalhar é tão grande que o capitão tentou sabotar o Exército</segment>
    <segment id="55">, a Câmara</segment>
    <segment id="56">, a Presidência e o seu cartão de vacinação sem sucesso.</segment>
    <segment id="57">Por isso</segment>
    <segment id="58">, tome Ginkgo biloba e aumente sua capacidade de concentração.</segment>
    <segment id="59">É hoje!</segment>
    <segment id="60">Quem você quer eliminar?</segment>
    <segment id="61">Prepare-</segment>
    <segment id="62">sese para mais um paredão triplo: você pode votar em Garrastazu Médici</segment>
    <segment id="63">, Getúlio Vargas ou Nicolás Maduro.</segment>
    <segment id="64">E aí, Brasil?</segment>
    <segment id="65">Já escolheu seu ditador favorito?</segment>
  </rst>
</analysis>