  <rst>
    <segment id="1">Talvez nenhum lugar ilustre melhor a uni&amp;atilde</segment>
    <segment id="2">;o entre passado e presente na Olimp&amp;iacute</segment>
    <segment id="3">;ada de T&amp;oacute</segment>
    <segment id="4">;quio como</segment>
    <segment id="5">como o novo est&amp;aacute</segment>
    <segment id="6">;dio ol&amp;iacute</segment>
    <segment id="7">;mpico.</segment>
    <segment id="8">O evento no Jap&amp;atilde</segment>
    <segment id="9">;o come&amp;ccedil</segment>
    <segment id="10">;ar&amp;aacute</segment>
    <segment id="11">; no pr&amp;oacute</segment>
    <segment id="12">;ximo dia 23 de julho e ir&amp;aacute</segment>
    <segment id="13">; at&amp;eacute</segment>
    <segment id="14">;</segment>
    <segment id="15">8 de agosto</segment>
    <segment id="16">, ap&amp;oacute</segment>
    <segment id="17">;s ter sido adiado de 2020 para 2021 em raz&amp;atilde</segment>
    <segment id="18">;o da pandemia.</segment>
    <segment id="19">Os Jogos Paraol&amp;iacute</segment>
    <segment id="20">;mpicos v&amp;atilde</segment>
    <segment id="21">;o de 24 de agosto a 5 de setembro.</segment>
    <segment id="22">A estrutura do principal palco de T&amp;oacute</segment>
    <segment id="23">;quio &amp;eacute</segment>
    <segment id="24">; recente</segment>
    <segment id="25">, foi inaugurada em dezembro de 2019</segment>
    <segment id="26">, masmas constru&amp;iacute</segment>
    <segment id="27">;da no lugar onde ficava o antigo est&amp;aacute</segment>
    <segment id="28">;dio ol&amp;iacute</segment>
    <segment id="29">;mpico</segment>
    <segment id="30">, posto de p&amp;eacute</segment>
    <segment id="31">; para a edi&amp;ccedil</segment>
    <segment id="32">;&amp;atilde</segment>
    <segment id="33">;o de 1964 do evento.</segment>
    <segment id="34">Neste ano</segment>
    <segment id="35">, o local receber&amp;aacute</segment>
    <segment id="36">; as cerim&amp;ocirc</segment>
    <segment id="37">;nias de abertura e encerramento</segment>
    <segment id="38">, jogos de futebol e provas de atletismo.  Locais de competição em Tóquio   novamente         de   de  de  representando um</segment>
    <segment id="39">Seu novo projeto arquitet&amp;ocirc</segment>
    <segment id="40">;nico, assinado por Kengo Kuma</segment>
    <segment id="41">, usa elementos de madeira que rementem &amp;agrave</segment>
    <segment id="42">; cultura tradicional japonesa e tamb&amp;eacute</segment>
    <segment id="43">;m um teto de vidro para melhor aproveitar a luz natural do sol.</segment>
    <segment id="44">H&amp;aacute</segment>
    <segment id="45">; outros seis locais utilizados durante a edi&amp;ccedil</segment>
    <segment id="46">;&amp;atilde</segment>
    <segment id="47">;o de 56 anos atr&amp;aacute</segment>
    <segment id="48">;s dos Jogos que ser&amp;atilde</segment>
    <segment id="49">;o reutilizados durante as competi&amp;ccedil</segment>
    <segment id="50">;&amp;otilde</segment>
    <segment id="51">;es deste ano.</segment>
    <segment id="52">O Gin&amp;aacute</segment>
    <segment id="53">;sio Metropolitano</segment>
    <segment id="54">, o est&amp;aacute</segment>
    <segment id="55">;dio Yoyogi e o lend&amp;aacute</segment>
    <segment id="56">;rio Nippon Budokan</segment>
    <segment id="57">, conhecido</segment>
    <segment id="58">comocomo o templo do jud&amp;ocirc</segment>
    <segment id="59">;, s&amp;atilde</segment>
    <segment id="60">;o alguns exemplos.</segment>
    <segment id="61">Os edif&amp;iacute</segment>
    <segment id="62">;cios s&amp;atilde</segment>
    <segment id="63">;o assinados por arquitetos renomados</segment>
    <segment id="64">, como</segment>
    <segment id="65">como Fumihiko Maki e Kenzo Tange.</segment>
    <segment id="66">A edi&amp;ccedil</segment>
    <segment id="67">;&amp;atilde</segment>
    <segment id="68">;o de 1964 simbolizou para o mundo o reestabelecimento do Jap&amp;atilde</segment>
    <segment id="69">;o, que ansiava retornar &amp;agrave</segment>
    <segment id="70">; elite das pot&amp;ecirc</segment>
    <segment id="71">;ncias globais ap&amp;oacute</segment>
    <segment id="72">;s a ocupa&amp;ccedil</segment>
    <segment id="73">;&amp;atilde</segment>
    <segment id="74">;o do pa&amp;iacute</segment>
    <segment id="75">;s pelas tropas aliadas que sucedeu o fim da Segunda Guerra Mundial.</segment>
    <segment id="76">Para a edi&amp;ccedil</segment>
    <segment id="77">;&amp;atilde</segment>
    <segment id="78">;o deste ano</segment>
    <segment id="79">, o pa&amp;iacute</segment>
    <segment id="80">;s n&amp;atilde</segment>
    <segment id="81">;o permitiu a entrada de p&amp;uacute</segment>
    <segment id="82">;blico estrangeiro em raz&amp;atilde</segment>
    <segment id="83">;o da pandemia.</segment>
    <segment id="84">Apenas jornalistas e outros trabalhadores do evento ter&amp;atilde</segment>
    <segment id="85">;o a oportunidade de observar n&amp;atilde</segment>
    <segment id="86">;o s&amp;oacute</segment>
    <segment id="87">;</segment>
    <segment id="88">as constru&amp;ccedil</segment>
    <segment id="89">;&amp;otilde</segment>
    <segment id="90">;es hist&amp;oacute</segment>
    <segment id="91">;ricas</segment>
    <segment id="92">, masmas tamb&amp;eacute</segment>
    <segment id="93">;m os enormes centros de conven&amp;ccedil</segment>
    <segment id="94">;&amp;otilde</segment>
    <segment id="95">;es e as ilhas artificiais</segment>
    <segment id="96">, fruto da expans&amp;atilde</segment>
    <segment id="97">;o comercial da capital japonesa no final do s&amp;eacute</segment>
    <segment id="98">;culo 20.</segment>
    <segment id="99">O cen&amp;aacute</segment>
    <segment id="100">;rio moderno tamb&amp;eacute</segment>
    <segment id="101">;m estar&amp;aacute</segment>
    <segment id="102">; presente no ambiente dos Jogos</segment>
    <segment id="103">, que ter&amp;aacute</segment>
    <segment id="104">; provas acontecendo</segment>
    <segment id="105">, por exemplo</segment>
    <segment id="106">, no F&amp;oacute</segment>
    <segment id="107">;rum Internacional de T&amp;oacute</segment>
    <segment id="108">;quio, um dos principais centros de neg&amp;oacute</segment>
    <segment id="109">;cios do pa&amp;iacute</segment>
    <segment id="110">;s.  J&amp;aacute</segment>
    <segment id="111">;</segment>
    <segment id="112">na ilha artificial de Odaiba</segment>
    <segment id="113">, situada na ba&amp;iacute</segment>
    <segment id="114">;a de T&amp;oacute</segment>
    <segment id="115">;quio, foram constru&amp;iacute</segment>
    <segment id="116">;das a Ariake Arena</segment>
    <segment id="117">, o Centro de Gin&amp;aacute</segment>
    <segment id="118">;stica</segment>
    <segment id="119">, o Parque de Esportes Urbanos e o Ariake Tennis Park.</segment>
    <segment id="120">A primeira</segment>
    <segment id="121">, que receber&amp;aacute</segment>
    <segment id="122">; o v&amp;ocirc</segment>
    <segment id="123">;lei, al&amp;eacute</segment>
    <segment id="124">;m do basquete em cadeira de rodas na Paraolimp&amp;iacute</segment>
    <segment id="125">;ada, &amp;eacute</segment>
    <segment id="126">; nova foi uma das &amp;uacute</segment>
    <segment id="127">;ltimas estruturas a ficar pronta</segment>
    <segment id="128">, junto com o Centro Aqu&amp;aacute</segment>
    <segment id="129">;tico.</segment>
    <segment id="130">O Parque de Esportes Urbanos de Ariake tamb&amp;eacute</segment>
    <segment id="131">;m &amp;eacute</segment>
    <segment id="132">; recente e receber&amp;aacute</segment>
    <segment id="133">; a estreia do skate.</segment>
    <segment id="134">Seu vizinho</segment>
    <segment id="135">, o Parque de Esportes Urbanos da ilha artificial de Aomi</segment>
    <segment id="136">, &amp;eacute</segment>
    <segment id="137">; uma das estruturas tempor&amp;aacute</segment>
    <segment id="138">;rias constru&amp;iacute</segment>
    <segment id="139">;das, assim</segment>
    <segment id="140">comocomo o Centro de Gin&amp;aacute</segment>
    <segment id="141">;stica.</segment>
    <segment id="142">Ambos ser&amp;atilde</segment>
    <segment id="143">;o desmontados ap&amp;oacute</segment>
    <segment id="144">;s a realiza&amp;ccedil</segment>
    <segment id="145">;&amp;atilde</segment>
    <segment id="146">;o do evento.</segment>
    <segment id="147">J&amp;aacute</segment>
    <segment id="148">; o Tennis Park n&amp;atilde</segment>
    <segment id="149">;o &amp;eacute</segment>
    <segment id="150">; novo.</segment>
    <segment id="151">Atualmente</segment>
    <segment id="152">, sedia um torneio da categoria ATP 500</segment>
    <segment id="153">, no circuito masculino</segment>
    <segment id="154">, e um Premier</segment>
    <segment id="155">, no circuito feminino.</segment>
    <segment id="156">Das 41 arenas (a organiza&amp;ccedil</segment>
    <segment id="157">;&amp;atilde</segment>
    <segment id="158">;o cita 43</segment>
    <segment id="159">, pois</segment>
    <segment id="160">pois contabiliza cada um dos tr&amp;ecirc</segment>
    <segment id="161">;s halls do centro de conven&amp;ccedil</segment>
    <segment id="162">;&amp;atilde</segment>
    <segment id="163">;o Mukahari Messe separadamente)</segment>
    <segment id="164">, 8 constru&amp;ccedil</segment>
    <segment id="165">;&amp;otilde</segment>
    <segment id="166">;es s&amp;atilde</segment>
    <segment id="167">;o novas e permanentes.</segment>
    <segment id="168">Outras 10 s&amp;atilde</segment>
    <segment id="169">;o tempor&amp;aacute</segment>
    <segment id="170">;rias.</segment>
    <segment id="171">Bem no centro do mapa das arenas ficar&amp;aacute</segment>
    <segment id="172">; a Vila Ol&amp;iacute</segment>
    <segment id="173">;mpica.</segment>
    <segment id="174">Os apartamentos que abrigar&amp;atilde</segment>
    <segment id="175">;o os atletas durante os Jogos ser&amp;atilde</segment>
    <segment id="176">;o vendidos ap&amp;oacute</segment>
    <segment id="177">;s o evento.</segment>
    <segment id="178">Apesar de a maioria dos locais de competi&amp;ccedil</segment>
    <segment id="179">;&amp;atilde</segment>
    <segment id="180">;o estar situada na capital japonesa</segment>
    <segment id="181">, n&amp;atilde</segment>
    <segment id="182">;o ser&amp;aacute</segment>
    <segment id="183">;</segment>
    <segment id="184">apenas T&amp;oacute</segment>
    <segment id="185">;quio que receber&amp;aacute</segment>
    <segment id="186">; provas ol&amp;iacute</segment>
    <segment id="187">;mpicas.</segment>
    <segment id="188">O futebol</segment>
    <segment id="189">, como</segment>
    <segment id="190">como de costume</segment>
    <segment id="191">, &amp;eacute</segment>
    <segment id="192">; o esporte que mais viajar&amp;aacute</segment>
    <segment id="193">;, passando tamb&amp;eacute</segment>
    <segment id="194">;m por Yokohama</segment>
    <segment id="195">, Rifu</segment>
    <segment id="196">, Kashima</segment>
    <segment id="197">, Saitama e Sapporo.</segment>
    <segment id="198">Esta &amp;uacute</segment>
    <segment id="199">;ltima cidade tamb&amp;eacute</segment>
    <segment id="200">;m receber&amp;aacute</segment>
    <segment id="201">; as maratonas e as disputas da marcha atl&amp;eacute</segment>
    <segment id="202">;tica.</segment>
    <segment id="203">As duas modalidades foram transferidas para o norte do pa&amp;iacute</segment>
    <segment id="204">;s, a mais de 800 km de dist&amp;acirc</segment>
    <segment id="205">;ncia de T&amp;oacute</segment>
    <segment id="206">;quio, em raz&amp;atilde</segment>
    <segment id="207">;o das altas temperaturas que a cidade registra no ver&amp;atilde</segment>
    <segment id="208">;o.</segment>
    <segment id="209">Dez boas possibilidades de medalha do Brasil em Tóquio-2020   novamente         de   de  de  representando um</segment>
    <segment id="210">A onda de calor do meio de 2019</segment>
    <segment id="211">, por exemplo</segment>
    <segment id="212">, causou a morte de 116 pessoas no Jap&amp;atilde</segment>
    <segment id="213">;o.</segment>
