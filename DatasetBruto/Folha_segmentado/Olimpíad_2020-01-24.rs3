    <segment id="216">, que far&amp;aacute</segment>
    <segment id="217">; sua estreia em Olimp&amp;iacute</segment>
    <segment id="218">;ada, ser&amp;aacute</segment>
    <segment id="219">; disputado a 100 km da capital</segment>
    <segment id="220">, na praia de Tsurigasaki.</segment>
    <segment id="221">S&amp;atilde</segment>
