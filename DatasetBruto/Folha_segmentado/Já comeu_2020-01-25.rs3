  <rst>
    <segment id="1">​Das burekas e burikitas ao bubble waffle e o takoyaki</segment>
    <segment id="2">, veja uma seleção de 14 petiscos gringos que você pode provar na cidade.</segment>
    <segment id="3">Salteña​   Comparada às suas irmãs latinas já famosas</segment>
    <segment id="4">, a empanada boliviana tem recheio úmido</segment>
    <segment id="5">, com caldo que escorre.</segment>
    <segment id="6">No Mercado de Pinheiros</segment>
    <segment id="7">, clientes lotam o balcão do box de Checho Gonzales</segment>
    <segment id="8">, 53, nascido em La Paz</segment>
    <segment id="9">, para provar as salteñas de frango (R$ 13)</segment>
    <segment id="10">, devidamente acompanhadas por chope ou vinho.</segment>
    <segment id="11">Uma variação é a pucacapa</segment>
    <segment id="12">, picante</segment>
    <segment id="13">, redonda</segment>
    <segment id="14">, recheada de queijos e cebolas.</segment>
    <segment id="15">Custa R$ 11 na Comedoria Gonzales e R$ 6 na Los Caporales</segment>
    <segment id="16">, comandada por Helen Nunez</segment>
    <segment id="17">, 56, que veio de Cochabamba.</segment>
    <segment id="18">Leia maisCozinha asiática ganha mais força e diversidade em São PauloCinco drinques de quatro países para provar pelos balcões da cidadeBares que produzem cervejas estrangeiras em São PauloSua família elabora um extenso menu de salteñas —a vegetariana leva batatas</segment>
    <segment id="19">, cenouras</segment>
    <segment id="20">, azeitonas e uvas-passas (R$ 6).</segment>
    <segment id="21">Encontre os Nunez numa das barracas mais concorridas da Kantuta</segment>
    <segment id="22">, principal feira da comunidade boliviana na cidade</segment>
    <segment id="23">, ou na lojinha que abriram na zona leste.</segment>
    <segment id="24">Comedoria Gonzales - Mercado Municipal de Pinheiros: r. Pedro Cristi</segment>
    <segment id="25">, 89, box 85</segment>
    <segment id="26">, Pinheiros</segment>
    <segment id="27">, tel. 3813-8719.</segment>
    <segment id="28">Seg.</segment>
    <segment id="29">a sáb.</segment>
    <segment id="30">: 11h às 19h.</segment>
    <segment id="31">Dom.</segment>
    <segment id="32">: 11h às 17h.  Los Caporales - Loja: av. Dr. Bernardino Brito Fonseca de Carvalho</segment>
    <segment id="33">, 722, Vila Matilde</segment>
    <segment id="34">, tel. 2651-2273.</segment>
    <segment id="35">Ter.</segment>
    <segment id="36">a sáb.</segment>
    <segment id="37">: 14h às 21h.</segment>
    <segment id="38">Dom.</segment>
    <segment id="39">:</segment>
    <segment id="40">9h às 13h.</segment>
    <segment id="41">Feira Kantuta - R. Pedro Vicente</segment>
    <segment id="42">, s/nº</segment>
    <segment id="43">, Canindé.</segment>
    <segment id="44">Dom.</segment>
    <segment id="45">: 11h às 19h.</segment>
    <segment id="46">Veja seleção de guloseimas gringas encontradas em São Paulo</segment>
    <segment id="47">Mais    novamente         de   de  de  representando um  ​Bánh Mì</segment>
    <segment id="48">No século 19</segment>
    <segment id="49">, a baguete foi introduzida pelos franceses no Vietnã</segment>
    <segment id="50">, então parte da Indochina.</segment>
    <segment id="51">Mas foi na Saigon já independente</segment>
    <segment id="52">, nos anos 1950</segment>
    <segment id="53">, que surgiu o báhn mì</segment>
    <segment id="54">, hoje o sanduíche número um em suas ruas.</segment>
    <segment id="55">Ele mistura o doce</segment>
    <segment id="56">, o salgado</segment>
    <segment id="57">, o azedo e o picante da cozinha vietnamita.</segment>
    <segment id="58">O do Bánh Mì Vietnam pode levar carne de porco</segment>
    <segment id="59">, frango ou tofu</segment>
    <segment id="60">, além de coentro</segment>
    <segment id="61">, patê caseiro e conservas agridoces (R$ 19).</segment>
    <segment id="62">No Bia Hoi</segment>
    <segment id="63">, que significa “chope” e emula os botecos de Hanói</segment>
    <segment id="64">, há três versões do sanduba.</segment>
    <segment id="65">O bun cha traz na baguete crocante bolinhas de lombo de porco grelhadas</segment>
    <segment id="66">, legumes em conserva</segment>
    <segment id="67">, ervas frescas</segment>
    <segment id="68">, maionese de coentro e pimenta opcional (R$ 25).</segment>
    <segment id="69">Bánh Mì Vietnam - R. Dr. Seng</segment>
    <segment id="70">, 44, Bela Vista</segment>
    <segment id="71">, tel. 97754-1856.</segment>
    <segment id="72">Qua.</segment>
    <segment id="73">a sex.</segment>
    <segment id="74">:</segment>
    <segment id="75">12h às 16h e 18h às 22h.</segment>
    <segment id="76">Sáb.</segment>
    <segment id="77">:</segment>
    <segment id="78">13h às 16h e 19h às 22h.</segment>
    <segment id="79">Bia Hoi - R. Rego Freitas</segment>
    <segment id="80">, 516, República</segment>
    <segment id="81">, tel. 3151-2508.</segment>
    <segment id="82">Ter.</segment>
    <segment id="83">a sex.</segment>
    <segment id="84">:</segment>
    <segment id="85">12h às 14h30 e 19h às 23h.</segment>
    <segment id="86">Sáb.</segment>
    <segment id="87">:</segment>
    <segment id="88">12h às 17h e 19h às 23h.</segment>
