    <segment id="300">: 14h às 19h.</segment>
    <segment id="301">Cannolo  Deixar a arma e pegar os cannoli talvez seja a maior contribuição do cinema ao imaginário gastronômico.</segment>
    <segment id="302">Pois bem: você vai encontrar os canudos do momento numa portinha do Bexiga</segment>
    <segment id="303">, onde Alexandre Leggieri</segment>
    <segment id="304">, 48, vende o doce-patrimônio da Sicília em seis versões</segment>
    <segment id="305">, da tradicional (creme de ricota) à com pasta de amendoim (R$ 7</segment>
    <segment id="306">,50 cada uma).</segment>
    <segment id="307">Na vizinha Moscatel</segment>
    <segment id="308">, especializada em guloseimas da Itália</segment>
    <segment id="309">, eles vêm em sabores</segment>
    <segment id="310">comocomo limão</segment>
    <segment id="311">, doce de leite e pistache (R$ 8).</segment>
    <segment id="312">Cannoleria do Bixiga - R. Treze de Maio</segment>
    <segment id="313">, 718, Bela Vista</segment>
    <segment id="314">, tel. 96610-6084.</segment>
    <segment id="315">Qui.</segment>
    <segment id="316">a sáb.</segment>
    <segment id="317">:</segment>
    <segment id="318">12h às 21h.</segment>
    <segment id="319">Dom.</segment>
    <segment id="320">:</segment>
    <segment id="321">12h às 18h.</segment>
