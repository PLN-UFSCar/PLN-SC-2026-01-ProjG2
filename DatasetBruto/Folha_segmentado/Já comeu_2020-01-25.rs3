    <segment id="330">Bureka</segment>
    <segment id="331">Imigrante icônica no mapa das gulodices paulistanas</segment>
    <segment id="332">, Lina Levi (1927-2018) inaugurou a Casa Búlgara em 1975 e trouxe as burekas para cá.</segment>
    <segment id="333">Alinhadas na vitrine</segment>
    <segment id="334">, as roscas de massa folhada alternam sabores tradicionais —batata e queijo feito no local— com invenções brasileiras</segment>
    <segment id="335">comocomo gorgonzola e chocolate (a partir de R$ 8</segment>
    <segment id="336">,90 cada unidade).</segment>
    <segment id="337">Após a morte da fundadora</segment>
    <segment id="338">, sua filha Shoshana Baruch</segment>
    <segment id="339">, 70, assumiu os fornos.</segment>
    <segment id="340">É ela quem informa a repórter sobre o retorno do famoso strudel de uva preta (R$ 12)</segment>
    <segment id="341">, sazonal:</segment>
    <segment id="342">“Chega no fim de janeiro”.</segment>
    <segment id="343">Casa Búlgara - R. Silva Pinto</segment>
    <segment id="344">, 356, Bom Retiro</segment>
    <segment id="345">, tel. 3222-9849.</segment>
    <segment id="346">Seg.</segment>
    <segment id="347">a sex.</segment>
    <segment id="348">:</segment>
    <segment id="349">9h30 às 18h.</segment>
    <segment id="350">Sáb.</segment>
    <segment id="351">:</segment>
    <segment id="352">9h30 às 14h30.</segment>
    <segment id="353">Burikita   Espécie de prima da bureka</segment>
    <segment id="354">, a burikita diferencia-</segment>
    <segment id="355">sese pelo formato: uma trouxinha</segment>
    <segment id="356">, e não uma rosca</segment>
    <segment id="357">, envolve o recheio.</segment>
    <segment id="358">Ainda hoje</segment>
    <segment id="359">, o salgado de raízes judaicas atrai habitués e curiosos à Burikita</segment>
    <segment id="360">, aberta por um casal de imigrantes iugoslavos em 1970.</segment>
    <segment id="361">De batata</segment>
    <segment id="362">, espinafre com queijo</segment>
    <segment id="363">, palmito</segment>
    <segment id="364">, carne e queijo (a melhor de todas)</segment>
    <segment id="365">, cada uma custa R$ 7.</segment>
    <segment id="366">Como quem avisa boa pessoa é</segment>
    <segment id="367">, guarde espaço para os doces</segment>
    <segment id="368">, que ficam seduzindo o público no balcão.</segment>
    <segment id="369">Também merece nota a lebênia (R$ 6)</segment>
    <segment id="370">, iogurte caseiro feito por David Ben Avram</segment>
    <segment id="371">, 73, filho dos fundadores que abraçou o negócio.</segment>
    <segment id="372">Doceria Burikita - R. Três Rios</segment>
    <segment id="373">, 138, Bom Retiro</segment>
    <segment id="374">, tel. 3227-2654.</segment>
