    <segment id="381">Pizza romana</segment>
    <segment id="382">Se as pizzas napolitanas fincaram pé em São Paulo</segment>
    <segment id="383">, as romanas (ou “al taglio”</segment>
    <segment id="384">, servidas em pedaços) ainda buscam o seu lugar ao sol.</segment>
    <segment id="385">Bom local para um almoço ou happy hour ítalo-paulistano é a casa dedicada ao estilo do mooquense Fellipe Zanuto</segment>
    <segment id="386">, 33, neto de italianos e chef do Hospedaria.</segment>
    <segment id="387">Tradicionais em Roma</segment>
    <segment id="388">, de massa alta</segment>
    <segment id="389">, base crocante e formato retangular</segment>
    <segment id="390">, elas são expostas na vitrine e aquecidas na hora</segment>
    <segment id="391">; não perca a de batata (mozarela branca</segment>
    <segment id="392">, batata assada em lâminas e alecrim</segment>
    <segment id="393">; R$ 10 o pedaço) e a clássica marguerita (R$ 10).</segment>
    <segment id="394">Da Mooca Pizza Shop - R. Fradique Coutinho</segment>
    <segment id="395">, 154, Pinheiros</segment>
    <segment id="396">, tel. 3062-0422.</segment>
    <segment id="397">Seg.</segment>
    <segment id="398">a sáb.</segment>
    <segment id="399">: 11h às 24h.</segment>
    <segment id="400">Dom.</segment>
    <segment id="401">: 16h às 23h.</segment>
    <segment id="402">Pastrami   É complicado entrar na Z Deli</segment>
    <segment id="403">, para muitos a melhor hamburgueria da cidade</segment>
    <segment id="404">, e rejeitar esse capítulo de seu menu.</segment>
    <segment id="405">Mas a casa ainda faz um excelente pastrami —carne bovina condimentada que nasceu nos Bálcãs e foi importada pelas delis judaicas para Nova York</segment>
    <segment id="406">, onde virou símbolo gastronômico local.</segment>
    <segment id="407">Solução:</segment>
    <segment id="408">pedir um burguer</segment>
    <segment id="409">, compartilhar as batatas fritas com pastrami</segment>
    <segment id="410">, queijo fundido</segment>
    <segment id="411">, sour cream e cebolinha (R$ 32) e levar para casa o sanduíche com fatias da carne curada mais saladinha de pepino</segment>
    <segment id="412">, maionese e mostarda (R$ 38).</segment>
    <segment id="413">Z Deli Sandwiches - R. Bento Freitas</segment>
    <segment id="414">, 314, República</segment>
    <segment id="415">, tel. 3129-3162.</segment>
    <segment id="416">Seg.</segment>
    <segment id="417">e ter.</segment>
    <segment id="418">:</segment>
    <segment id="419">12h às 23h.</segment>
    <segment id="420">Qua., qui. e dom.: 12h às 24h.</segment>
