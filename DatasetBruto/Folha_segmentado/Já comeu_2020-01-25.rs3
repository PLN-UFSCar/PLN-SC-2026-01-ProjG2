    <segment id="90">: 12h30 às 17h.</segment>
    <segment id="91">Poutine   Eis o “ménage à trois” canadense</segment>
    <segment id="92">, segundo famosa piada local:</segment>
    <segment id="93">batata frita</segment>
    <segment id="94">, molho gravy (à base de carne) e queijo derretido.</segment>
    <segment id="95">Inventada em Québec</segment>
    <segment id="96">, essa delícia figura até nos McDonald’s de lá.</segment>
    <segment id="97">E São Paulo tem uma poutinerie</segment>
    <segment id="98">, onde são preparadas 17 versões.</segment>
    <segment id="99">Além da original (R$ 24 o pequeno)</segment>
    <segment id="100">, a receita pode ser acrescida de itens</segment>
    <segment id="101">comocomo bacon (R$ 10)</segment>
    <segment id="102">, ovos mexidos (R$ 6) e shiitake (R$ 12).</segment>
    <segment id="103">Canuck’s Poutinerie - R. Tangará</segment>
    <segment id="104">, 145, Vila Mariana</segment>
    <segment id="105">, tel. 99271-8950.</segment>
    <segment id="106">Ter.</segment>
    <segment id="107">e qua.</segment>
    <segment id="108">: 17h30 às 22h.</segment>
    <segment id="109">Qui., sex.</segment>
    <segment id="110">e sáb.</segment>
    <segment id="111">: 17h30 às 23h30.</segment>
    <segment id="112">Takoyaki  Criado em Osaka</segment>
    <segment id="113">, o bolinho cremoso e assado de polvo é comida de rua emblemática da região japonesa de Kansai.</segment>
    <segment id="114">Despeja-</segment>
    <segment id="115">sese a massa numa chapa de ferro com cavidades esféricas</segment>
    <segment id="116">; ela recebe</segment>
    <segment id="117">, então</segment>
    <segment id="118">, o recheio: polvo cozido</segment>
    <segment id="119">, cebolinha</segment>
    <segment id="120">, gengibre.</segment>
    <segment id="121">Por fim</segment>
    <segment id="122">, vem a cobertura</segment>
    <segment id="123">, com flocos de peixe seco</segment>
    <segment id="124">, maionese</segment>
    <segment id="125">, molho de okonomiyaki e alga verde.</segment>
    <segment id="126">A porção custa R$ 29</segment>
    <segment id="127">,80 no Yu Yatai</segment>
    <segment id="128">, que começou</segment>
    <segment id="129">comocomo food truck (“yatai” em japonês) e evoluiu para restaurante especializado no petisco.</segment>
    <segment id="130">Já o quiosque na entrada da mercearia Kaisen guarda um dos tesouros da baixa gastronomia paulistana.</segment>
    <segment id="131">Peça seus takoyakis na janelinha (R$ 14 a embalagem com seis unidades)</segment>
    <segment id="132">, pague em dinheiro e tenha uma experiência genuinamente nipônica pelas ruas da Liberdade.</segment>
    <segment id="133">Quiosque da mercearia Kaisen - R. Galvão Bueno</segment>
    <segment id="134">, 270, Liberdade</segment>
    <segment id="135">, tel. 3271-7228.</segment>
    <segment id="136">Seg.</segment>
    <segment id="137">a dom.: 10h às 19h.</segment>
    <segment id="138">Yu Yatai - R. das Rosas</segment>
    <segment id="139">, 52, Mirandópolis</segment>
    <segment id="140">, tel. 5587-4530.</segment>
    <segment id="141">Qua.</segment>
    <segment id="142">a sex.</segment>
    <segment id="143">:</segment>
    <segment id="144">12h às 15h e 18h às 22h30.</segment>
    <segment id="145">Sáb.</segment>
    <segment id="146">:</segment>
    <segment id="147">12h às 22h30.</segment>
    <segment id="148">Dom.</segment>
    <segment id="149">:</segment>
    <segment id="150">12h às 17h.</segment>
    <segment id="151">Arepa</segment>
    <segment id="152">O pão de todo dia na Colômbia e na Venezuela tem cada vez mais adeptos por aqui.</segment>
    <segment id="153">No Bom Tequenho</segment>
    <segment id="154">, aberto pela venezuelana Paola Ramírez</segment>
    <segment id="155">, 33, os discos de milho assados na chapa aparecem em dezenas de sanduíches</segment>
    <segment id="156">, envolvendo hambúrguer (R$ 32)</segment>
    <segment id="157">, costela de porco (R$ 23) ou calabresa defumada (R$ 22).</segment>
    <segment id="158">Também o La Gorgona</segment>
    <segment id="159">, num sobrado colado à rua Frei Caneca</segment>
    <segment id="160">, sese orgulha de falar portunhol.</segment>
    <segment id="161">Tocado por três amigos colombianos</segment>
    <segment id="162">, o bar serve de porções de arepitas (R$ 8</segment>
    <segment id="163">,90) a combos com patacones (banana da terra crocante) e acompanhamentos (R$ 23</segment>
    <segment id="164">,90).</segment>
    <segment id="165">Boa novidade: os pacotes de arepas pré-prontas para esquentar em casa (a partir de R$ 6</segment>
    <segment id="166">,90).</segment>
    <segment id="167">Bom Tequenho - R. Maria Otília</segment>
    <segment id="168">, 241, Jd.</segment>
    <segment id="169">Anália Franco</segment>
    <segment id="170">, tel. 2096-0061.</segment>
    <segment id="171">Ter.</segment>
    <segment id="172">a qui.</segment>
    <segment id="173">: 16h às 23h.</segment>
    <segment id="174">Sex.</segment>
    <segment id="175">a dom.: 12h às 23h.   La Gorgona - R. São Miguel</segment>
    <segment id="176">, 22, Bela Vista</segment>
    <segment id="177">, tel. 3256-9215.</segment>
    <segment id="178">Seg.</segment>
    <segment id="179">a qui.</segment>
    <segment id="180">: 17h30 às 24h.</segment>
    <segment id="181">Sex.:</segment>
    <segment id="182">17h à 1h.</segment>
    <segment id="183">Sáb.</segment>
    <segment id="184">:</segment>
    <segment id="185">12h à 1h.</segment>
    <segment id="186">Taco  Tacos 100% mexicanos são raros na cidade</segment>
    <segment id="187">, onde reina o tex-mex —fusão das cozinhas do México</segment>
    <segment id="188">, do Texas e de outros estados americanos na fronteira com o país vizinho.</segment>
    <segment id="189">Mas a taquería La Sabrosa faz jus ao nome.</segment>
    <segment id="190">Sua dupla de tacos de carnitas combina carne de porco que desmancha na boca</segment>
    <segment id="191">, salsa verde e guacamole (R$ 19</segment>
    <segment id="192">,50).</segment>
    <segment id="193">Dá um match apimentado com as margaritas</segment>
    <segment id="194">, de tamarindo ou a tradicional (R$ 20</segment>
    <segment id="195">,50).</segment>
    <segment id="196">Taquería La Sabrosa - R. Augusta</segment>
    <segment id="197">, 1.474</segment>
    <segment id="198">, Consolação</segment>
    <segment id="199">, tel. 2925-6189.</segment>
    <segment id="200">Dom.</segment>
    <segment id="201">a qui.</segment>
    <segment id="202">:</segment>
    <segment id="203">12h às 24h.</segment>
    <segment id="204">Sex.</segment>
    <segment id="205">e sáb.</segment>
    <segment id="206">:</segment>
    <segment id="207">12h à 1h.</segment>
    <segment id="208">Gulrotkake   Pães artesanais</segment>
    <segment id="209">, tortas e bolos noruegueses?</segment>
    <segment id="210">Sim, temos também.</segment>
    <segment id="211">Nos arredores do Minhocão</segment>
    <segment id="212">, a Bakeri Nord homenageia a cozinha do país nórdico.</segment>
    <segment id="213">O menu</segment>
    <segment id="214">, rotativo</segment>
    <segment id="215">, tem gulrotkake</segment>
    <segment id="216">, bolo de cenoura com canela e cobertura de cream cheese (R$ 9 o pedaço)</segment>
    <segment id="217">, e fyrstekake</segment>
    <segment id="218">, torta de amêndoas com limão siciliano</segment>
    <segment id="219">, apelidada de “torta real” na Escandinávia (R$ 9</segment>
    <segment id="220">,50 a fatia e R$ 110 a inteira).</segment>
    <segment id="221">Bakeri Nord - R. Dr. Carvalho de Mendonça</segment>
    <segment id="222">, 200, Campos Elíseos</segment>
    <segment id="223">, s/ tel.</segment>
    <segment id="224">Qua.</segment>
    <segment id="225">a sex.</segment>
    <segment id="226">:</segment>
    <segment id="227">13h às 19h.</segment>
    <segment id="228">Sáb.</segment>
    <segment id="229">e dom.: 13h às 18h.</segment>
    <segment id="230">Currywurst  Estima-</segment>
    <segment id="231">sese que 800 milhões de porções de currywurst sejam consumidas por ano na Alemanha.</segment>
    <segment id="232">De tão incorporado a o cotidiano local</segment>
    <segment id="233">, o prato ganhou até um museu</segment>
    <segment id="234">, que funcionou por dez anos em Berlim.</segment>
    <segment id="235">Ali nasceu a salsicha de porco fatiada</segment>
    <segment id="236">, coberta por ketchup com curry e acompanhada de batatas fritas.</segment>
    <segment id="237">Era 1949</segment>
    <segment id="238">, logo após a Segunda Guerra</segment>
    <segment id="239">, e a inventora arrumou pó de curry com soldados ingleses.</segment>
    <segment id="240">Em Pinheiros</segment>
    <segment id="241">, o Fast Berlin foca a comida de rua germânica</segment>
    <segment id="242">, com frikadelle (almôndegas)</segment>
    <segment id="243">, paprika schnitzel (milanesa de porco com páprica) e</segment>
    <segment id="244">, claro</segment>
    <segment id="245">, currywurst (R$ 30)</segment>
    <segment id="246">, nas versões de porco</segment>
    <segment id="247">, boi e soja.</segment>
    <segment id="248">Fast Berlin - R. Mourato Coelho</segment>
    <segment id="249">, 24, Pinheiros</segment>
    <segment id="250">, tel. 3064-4652.</segment>
    <segment id="251">Ter.</segment>
    <segment id="252">a qui.</segment>
    <segment id="253">: 17h às 24h.</segment>
    <segment id="254">Sex.</segment>
    <segment id="255">e sáb.</segment>
    <segment id="256">:</segment>
    <segment id="257">12h à 1h.</segment>
    <segment id="258">Dom.</segment>
    <segment id="259">:</segment>
    <segment id="260">12h às 23h.</segment>
    <segment id="261">Bubble Waffle</segment>
    <segment id="262">Virou moda o doce de rua típico de Hong Kong</segment>
    <segment id="263">, um waffle à base de ovos</segment>
    <segment id="264">, cozido em chapas que formam bolhas aparentes.</segment>
    <segment id="265">Também chamado de “egg waffle”</segment>
    <segment id="266">, “egg puff” ou</segment>
    <segment id="267">, em cantonês</segment>
    <segment id="268">, “gai daan jai”</segment>
    <segment id="269">, costuma ser consumido puro no país de origem.</segment>
    <segment id="270">A graça aqui é fazer um cone com a massa</segment>
    <segment id="271">, recheá-la com sorvete e mandar ver nos toppings.</segment>
    <segment id="272">O personalizado custa R$ 19</segment>
    <segment id="273">,90 no Dr. Bubble e R$ 18 na Zhöu Zhöu.   Dr.</segment>
    <segment id="274">Bubble - R. Augusta</segment>
    <segment id="275">, 1.524</segment>
    <segment id="276">, loja 18</segment>
    <segment id="277">, Consolação</segment>
    <segment id="278">, tel. 3287-2022.</segment>
    <segment id="279">Seg.</segment>
    <segment id="280">:</segment>
    <segment id="281">12h às 19h.</segment>
    <segment id="282">Ter.</segment>
    <segment id="283">a sáb.</segment>
    <segment id="284">:</segment>
    <segment id="285">12h às 21h.</segment>
    <segment id="286">Dom.</segment>
    <segment id="287">: 14h às 20h.</segment>
    <segment id="288">Zhöu Zhöu - Al.</segment>
    <segment id="289">Jaú, 1.494</segment>
    <segment id="290">, Jd.</segment>
    <segment id="291">Paulista</segment>
