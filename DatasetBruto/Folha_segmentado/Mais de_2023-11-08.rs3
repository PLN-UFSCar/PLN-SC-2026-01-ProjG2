    <segment id="136">Washignton Quaquá (PT/RJ)   LOVE SONGS  DJ Zé Pedro lança o livro &amp;#039</segment>
    <segment id="137">;Mela Cueca:</segment>
    <segment id="138">As Canções de Amor que O Mundo Esqueceu&amp;#039</segment>
    <segment id="139">;Mais    novamente         de   de  de  representando um</segment>
    <segment id="140">O DJ Zé Pedro recebeu convidados para o lançamento de seu livro "Mela Cueca –</segment>
    <segment id="141">As Canções de Amor que O Mundo Esqueceu"</segment>
    <segment id="142">, realizado na casa de música Bona</segment>
    <segment id="143">, em São Paulo</segment>
    <segment id="144">, na segunda (6).</segment>
    <segment id="145">A apresentadora Adriane Galisteu e a cantora Zélia Duncan prestigiaram o evento.  com BIANKA VIEIRA</segment>
    <segment id="146">, KARINA MATIAS e MANOELLA SMITH</segment>
