  <rst>
    <segment id="1">Autoridades de Los Angeles</segment>
    <segment id="2">, na Califórnia</segment>
    <segment id="3">, fecharam um parque na cidade para remover um acampamento de moradores de rua que existe no local</segment>
    <segment id="4">, segundo informações publicadas pelo Independent.</segment>
    <segment id="5">Centenas de pessoas viviam no Echo Park Lake</segment>
    <segment id="6">, o que deixou o município em um dilema: cada vez mais moradores pedem ruas limpas e seguras enquanto a quantidade de quem não tem casa aumenta.</segment>
    <segment id="7">Trabalhadores limpam tendas no acampamento de moradores de rua no Echo Park</segment>
    <segment id="8">, em Los Angeles</segment>
    <segment id="9">, antes do fechamento completo do local - David Swanson/ReutersSegundo o site britânico</segment>
    <segment id="10">, o vereador democrata Mitch O’Farrell</segment>
    <segment id="11">, que confirmou nesta quinta (25) o fechamento temporário do parque a veículos e pedestres</segment>
    <segment id="12">, disse ter havido quatro mortes no local no ano passado.</segment>
    <segment id="13">“</segment>
    <segment id="14">As instalações do Echo Park</segment>
    <segment id="15">sese transformaram em um lugar muito perigoso para todos lá: overdoses de drogas</segment>
    <segment id="16">, agressões sexuais e físicas</segment>
    <segment id="17">, líderes autoproclamados tributando indivíduos sem-teto e vendedores</segment>
    <segment id="18">, abuso de animais</segment>
    <segment id="19">, famílias sem abrigo durante o clima frio e tiroteios no último outono [no hemisfério Norte]</segment>
    <segment id="20">, quando um morador de rua foi baleado na perna por membros de uma gangue enquanto crianças estavam por perto”</segment>
    <segment id="21">, disse o vereador</segment>
    <segment id="22">, em comunicado</segment>
    <segment id="23">, conforme publicação do Independent.</segment>
    <segment id="24">A interdição do parque</segment>
    <segment id="25">, porém</segment>
    <segment id="26">porém, gerou confusão.</segment>
    <segment id="27">Nesta quarta (24)</segment>
    <segment id="28">, as cercas ao redor da área começaram a ser instaladas</segment>
    <segment id="29">para que</segment>
    <segment id="30">para que o acampamento pudesse ser desmanchado</segment>
    <segment id="31">, e placas colocadas informavam que o fechamento começaria nesta quinta e que todos os itens pessoais deveriam ser retirados da área</segment>
    <segment id="32">, “incluindo</segment>
    <segment id="33">, masmas não</segment>
    <segment id="34">sese limitando a</segment>
    <segment id="35">, tendas</segment>
    <segment id="36">, cadeiras</segment>
    <segment id="37">, mesas</segment>
    <segment id="38">, mochilas</segment>
    <segment id="39">, bolsas e objetos e itens pessoais”.</segment>
    <segment id="40">A medida levou centenas de manifestantes</segment>
    <segment id="41">, entre moradores de rua e ativistas</segment>
    <segment id="42">, a protestar.</segment>
    <segment id="43">Houve confronto com policiais durante a noite</segment>
    <segment id="44">, segundo o site britânico.</segment>
    <segment id="45">Fotos e vídeos mostram agentes tentando empurrar manifestantes enquanto garrafas eram jogadas na direção das forças de segurança.</segment>
    <segment id="46">Em um certo momento</segment>
    <segment id="47">, ainda de acordo com o Independent</segment>
    <segment id="48">, vários policiais chegaram ao parque com equipamento antimotim para conter o protesto e foram recebidos sob gritos.</segment>
    <segment id="49">“Por que você está usando equipamento antimotim?</segment>
    <segment id="50">Não vejo motim aqui!</segment>
    <segment id="51">”</segment>
    <segment id="52">Confronto entre policiais e manifestantes após fechamento de parque em Los AngelesMais    novamente         de   de  de  representando um  O chefe da polícia de Los Angeles</segment>
    <segment id="53">, Michael Moore</segment>
    <segment id="54">, afirmou que os moradores de rua que já estavam no acampamento poderiam passar a noite lá</segment>
    <segment id="55">, masmas seriam obrigados a sair em 24 horas.</segment>
    <segment id="56">Alguns encararam a declaração</segment>
    <segment id="57">comocomo uma vitória</segment>
    <segment id="58">, segundo o Los Angeles Times.</segment>
    <segment id="59">“Ganhamos a noite”</segment>
    <segment id="60">, gritou um organizador.</segment>
    <segment id="61">“</segment>
    <segment id="62">Eu</segment>
    <segment id="63">moro aqui e considero a noite de hoje uma vitória”</segment>
    <segment id="64">, acrescentou um morador do local.</segment>
    <segment id="65">Por volta de 1h25 desta quinta</segment>
    <segment id="66">, o ato havia sido dispersado.</segment>
    <segment id="67">Em um comunicado</segment>
    <segment id="68">, a polícia de Los Angeles disse que a manifestação foi “em grande parte pacífica” e que não foi usado gás lacrimogêneo para dispersar o ato.</segment>
    <segment id="69">Um manifestante foi preso sob a acusação de não cumprir ordens de um policial</segment>
    <segment id="70">, acrescentou o comunicado</segment>
    <segment id="71">, de acordo com o site britânico.  "</segment>
    <segment id="72">Após expressarem seus direitos da Primeira Emenda [da Constituição americana]</segment>
    <segment id="73">, todos os manifestantes deixaram a área voluntariamente"</segment>
    <segment id="74">, disse a polícia.</segment>
    <segment id="75">Ativistas têm criticado a liderança da cidade por remover o acampamento sem avisar com antecedência suficiente</segment>
    <segment id="76">para que</segment>
    <segment id="77">para que as pessoas pudessem encontrar outro lugar para dormir.</segment>
    <segment id="78">O prefeito</segment>
    <segment id="79">, o democrata Eric Garcetti</segment>
    <segment id="80">, disse nesta quarta que</segment>
    <segment id="81">, embora</segment>
    <segment id="82">embora houvesse cerca de 120 barracas no parque</segment>
    <segment id="83">, havia apenas cerca de 19 pessoas vivendo no acampamento quando o local foi fechado.</segment>
    <segment id="84">As autoridades também divulgaram prejuízo estimado em US$ 500 mil (R$ 2</segment>
    <segment id="85">,8 milhões) devido ao acampamento.</segment>
    <segment id="86">Segundo comunicado de O’Farrell</segment>
    <segment id="87">, a reabertura do local ao público depende de uma avaliação de danos e da conclusão dos reparos necessários</segment>
    <segment id="88">para que</segment>
    <segment id="89">para que uma autorização possa ser emitida.</segment>
  </rst>
</analysis>