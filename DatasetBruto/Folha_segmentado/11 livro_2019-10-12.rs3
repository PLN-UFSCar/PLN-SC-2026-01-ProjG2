  <rst>
    <segment id="1">Se a infância passa rápido até demais</segment>
    <segment id="2">, fica uma dúvida: quais livros ler antes de crescer?</segment>
    <segment id="3">Não precisa sair correndo nem brigar contra o tempo</segment>
    <segment id="4">, masmas a Folhinha fez essa pergunta para um time de escritores e ilustradores.</segment>
    <segment id="5">A partir daí</segment>
    <segment id="6">, cada um preparou uma lista própria de dez livros essenciais para a infância.</segment>
    <segment id="7">E, da união delas</segment>
    <segment id="8">, chegou-</segment>
    <segment id="9">sese a um livro vencedor e mais dez leituras imperdíveis.</segment>
    <segment id="10">Veja 11 livros para ler antes de crescerMais    novamente         de   de  de  representando um  Participaram da seleção os escritores Pedro Bandeira</segment>
    <segment id="11">, Marina Colasanti</segment>
    <segment id="12">, Heloisa Prieto e Silvana Salerno</segment>
    <segment id="13">, além dos também ilustradores Mariana Massarani</segment>
    <segment id="14">, Odilon Moraes e Fernando Vilela (veja abaixo a lista de cada um).</segment>
    <segment id="15">Para isso</segment>
    <segment id="16">, cada número da lista dos autores recebeu uma pontuação.</segment>
    <segment id="17">O primeiro colocado recebeu 20 pontos —valor que foi diminuindo nos outros números do ranking: 2º (17 pontos)</segment>
    <segment id="18">, 3º (15 pontos)</segment>
    <segment id="19">, 4º (13 pontos)</segment>
    <segment id="20">, 5º (11 pontos)</segment>
    <segment id="21">, 6º (9 pontos)</segment>
    <segment id="22">, 7º (8 pontos)</segment>
    <segment id="23">, 8º (7 pontos)</segment>
    <segment id="24">, 9º (6 pontos) e 10º (5 pontos).</segment>
    <segment id="25">Da soma da pontuação de todas as listas</segment>
    <segment id="26">, foi formada um ranking final de 11 livros para ler antes de crescer.</segment>
    <segment id="27">O campeão não é nenhum conto de fadas antigo ou um clássico de Monteiro Lobato (</segment>
    <segment id="28">embora</segment>
    <segment id="29">embora eles estejam também na lista).</segment>
    <segment id="30">O vencedor é a história de uma árvore e de um menino: "</segment>
    <segment id="31">A Árvore Generosa"</segment>
    <segment id="32">, um dos principais livros ilustrados americanos</segment>
    <segment id="33">, escrito e ilustrado por Shel Silverstein.</segment>
    <segment id="34">O autor é o mesmo de "</segment>
    <segment id="35">A Parte que Falta"</segment>
    <segment id="36">, que virou best-seller no país depois de um vídeo da youtuber Jout Jout.</segment>
    <segment id="37">Mais do que uma seleção de melhores livros</segment>
    <segment id="38">, a lista serve de guia de leituras imperdíveis —de um dos títulos ilustrados mais cultuados ("</segment>
    <segment id="39">Onde</segment>
    <segment id="40">Vivem os Monstros")</segment>
    <segment id="41">a "Reinações de Narizinho"</segment>
    <segment id="42">, dos contos dos Irmãos Grimm a "</segment>
    <segment id="43">O Menino Maluquinho".</segment>
    <segment id="44">A maior parte deles pode ser encontrada em livrarias.</segment>
    <segment id="45">Dois estão esgotados no Brasil</segment>
    <segment id="46">, masmas ainda podem ser achados em sebos e na internet.</segment>
    <segment id="47">Um desses casos é "</segment>
    <segment id="48">Onde</segment>
    <segment id="49">Vivem os Monstros"</segment>
    <segment id="50">, de Maurice Sendak.</segment>
    <segment id="51">Publicado pela extinta Cosac Naify</segment>
    <segment id="52">, ele não recebeu outra edição no país até o momento —</segment>
    <segment id="53">embora</segment>
    <segment id="54">embora seja um dos títulos mais cultuados da literatura infantojuvenil e tenha virado filme em 2009.</segment>
    <segment id="55">Claro que esses livros todos podem ser lidos em qualquer idade.</segment>
    <segment id="56">Mas, antes de crescer</segment>
    <segment id="57">, tudo tem um gosto especial.  11 LIVROS PARA LER ANTES DE CRESCER   "</segment>
    <segment id="58">A Árvore Generosa" (Shel Silverstein)</segment>
    <segment id="59">"</segment>
