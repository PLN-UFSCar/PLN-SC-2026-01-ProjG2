  <rst>
    <segment id="1">Em 21 de junho de 1970</segment>
    <segment id="2">, ao entrar em campo para enfrentar o Brasil na final da Copa</segment>
    <segment id="3">, o zagueiro italiano Tarcisio Burgnich ainda tentava</segment>
    <segment id="4">sese convencer que era possível segurar Pelé:</segment>
    <segment id="5">"</segment>
    <segment id="6">Ele é de carne e osso</segment>
    <segment id="7">comocomo todos os outros"</segment>
    <segment id="8">, repetia para si mesmo.</segment>
    <segment id="9">Àquela altura</segment>
    <segment id="10">, em quase 950 partidas</segment>
    <segment id="11">comocomo profissional</segment>
    <segment id="12">, Pelé já havia feito 1.029 dos 1.283 gols que marcaria até o final da carreira.</segment>
    <segment id="13">Carregava a aura de uma lenda que conseguia tabelar na perna do adversário e chapelar quatro sem deixar a bola cair antes de mandar para a rede.</segment>
    <segment id="14">O resultado</segment>
    <segment id="15">, hoje todos sabem: o Brasil fez 4 a 1 na Itália e sagrou-</segment>
    <segment id="16">sese tricampeão mundial.</segment>
    <segment id="17">Ao sair de campo</segment>
    <segment id="18">, Burgnich</segment>
    <segment id="19">, rendeu-</segment>
    <segment id="20">sese: "</segment>
    <segment id="21">Eu estava errado".</segment>
    <segment id="22">Pelé podia até ser de carne e osso.</segment>
    <segment id="23">Mas não era</segment>
    <segment id="24">comocomo os outros.</segment>
    <segment id="25">Mesmo o Pelé de carne e osso era perpassado por lendas.</segment>
    <segment id="26">Há amigos que reclamavam (uns em tom de brincadeira</segment>
    <segment id="27">, outros nem tanto) que não dava para ir com ele a casas noturnas ou de entretenimento adulto.</segment>
    <segment id="28">O Rei monopolizava as atenções.</segment>
    <segment id="29">As mulheres só queriam saber dele</segment>
    <segment id="30">, dizia um antigo parceiro de farra.</segment>
    <segment id="31">Se gostasse do que via</segment>
    <segment id="32">, o ex-jogador dificilmente perdia o lance.</segment>
    <segment id="33">Só não partia para o abraço</segment>
    <segment id="34">sese estivesse em impedimento —no</segment>
    <segment id="35">casocaso</segment>
    <segment id="36">, sese atravessasse uma linha ética que traçara para si mesmo:</segment>
    <segment id="37">sese fosse casada ou virgem</segment>
    <segment id="38">, nada feito.</segment>
    <segment id="39">Por mais interessado que estivesse</segment>
    <segment id="40">, Pelé deixava a bola passar.</segment>
    <segment id="41">Quando visitava o Rio de Janeiro</segment>
    <segment id="42">, ele costumava</segment>
    <segment id="43">sese hospedar na casa do empresário Alfredo Saad.</segment>
    <segment id="44">Ali, conheceu</segment>
    <segment id="45">, no mesmo dia do início da década de 1980</segment>
    <segment id="46">, duas das mulheres mais cobiçadas da época</segment>
    <segment id="47">, as modelos Xuxa Meneghel e Luiza Brunet.</segment>
    <segment id="48">Xuxa foi uma das que</segment>
    <segment id="49">sese encantaram por Pelé - Acervo - 1986/FolhapressEncantou-</segment>
    <segment id="50">sese por Brunet.</segment>
    <segment id="51">Na hora</segment>
    <segment id="52">, convidou-a para ir a um show de Gal Costa naquela noite.</segment>
    <segment id="53">Ela disse que não podia</segment>
    <segment id="54">, o marido ia buscá-la.</segment>
    <segment id="55">Xuxa agiu rápido e</segment>
    <segment id="56">sese convidou para ir junto</segment>
    <segment id="57">, segundo Pelé contou ao jornalista Juca Kfouri em entrevista à revista "Playboy"</segment>
    <segment id="58">, publicada em agosto de 1993.</segment>
    <segment id="59">"Pensei que não era legal</segment>
    <segment id="60">, que a Xuxa era muito menina.</segment>
    <segment id="61">Bati um papo com ela e ficou ainda pior</segment>
    <segment id="62">, porque</segment>
    <segment id="63">porque me contou que era virgem"</segment>
    <segment id="64">, disse.</segment>
    <segment id="65">Nada feito</segment>
    <segment id="66">, portanto.</segment>
    <segment id="67">Mais tarde</segment>
    <segment id="68">, com a questão impeditiva resolvida</segment>
    <segment id="69">, os dois voltaram a</segment>
    <segment id="70">sese encontrar.</segment>
    <segment id="71">Viraram amigos</segment>
    <segment id="72">, apaixonaram-</segment>
    <segment id="73">sese, namoraram firme</segment>
    <segment id="74">, cogitaram morar juntos.</segment>
    <segment id="75">Quando Xuxa começou a trabalhar na TV</segment>
    <segment id="76">, o rei passou a defender a honra de sua dama.</segment>
    <segment id="77">"</segment>
    <segment id="78">Quem trabalha com crianças precisa</segment>
    <segment id="79">sese cuidar"</segment>
    <segment id="80">, ponderava.</segment>
    <segment id="81">Por iniciativa própria</segment>
    <segment id="82">, recolheu negativos de fotos em que Xuxa aparecia nua.</segment>
    <segment id="83">Ligou pessoalmente para os donos das editoras Abril e Bloch</segment>
    <segment id="84">, pediu a fotógrafos que lhes entregasse copiões e ampliações.</segment>
    <segment id="85">Recebeu malas de fotografias e as entregou a Xuxa.</segment>
    <segment id="86">Se o que realmente o motivou foi um enorme senso prático ou ciúme de carne e osso</segment>
    <segment id="87">, nunca</segment>
    <segment id="88">sese saberá.</segment>
    <segment id="89">Talvez os dois.</segment>
    <segment id="90">Com seu prestígio</segment>
    <segment id="91">, Pelé resolvia qualquer problema e abria qualquer porta.</segment>
    <segment id="92">Certa vez</segment>
    <segment id="93">, ao passar pela alfândega nos EUA</segment>
    <segment id="94">, sese deu conta de que perdera o passaporte.</segment>
    <segment id="95">Possivelmente o usou</segment>
    <segment id="96">comocomo apoio para dar um autógrafo e</segment>
    <segment id="97">, sem perceber</segment>
    <segment id="98">, entregou o documento com o papel.</segment>
    <segment id="99">Explicou a situação ao fiscal</segment>
    <segment id="100">, que o liberou</segment>
    <segment id="101">, após pedir um autógrafo para os filhos.</segment>
    <segment id="102">Da mesma forma</segment>
    <segment id="103">, sem apresentar um único documento</segment>
    <segment id="104">, ele circulou pelos bastidores do Vaticano para</segment>
    <segment id="105">sese encontrar com o papa.</segment>
    <segment id="106">Pelé e personalidadesMais    novamente         de   de  de  representando</segment>
    <segment id="107">um  Pelé parava qualquer ambiente.</segment>
    <segment id="108">Numa visita ao governo japonês</segment>
    <segment id="109">, integrou uma comitiva com Mikhail Gorbachev e Brooke Shields.</segment>
    <segment id="110">Gorbachev protagonizara a reforma política e econômica na ex-União Soviética.</segment>
    <segment id="111">Atriz de Hollywood</segment>
    <segment id="112">, Shields era uma das mulheres mais lindas do mundo.</segment>
    <segment id="113">Os organizadores do evento tiveram de pedir a Pelé que não saísse do lado dos dois.</segment>
    <segment id="114">"Senão ninguém fica com eles"</segment>
    <segment id="115">, justificaram-</segment>
    <segment id="116">sese.</segment>
    <segment id="117">Certa vez em Nova York</segment>
    <segment id="118">, o Rei levou sua filha</segment>
    <segment id="119">Kelly à estreia do filme "</segment>
    <segment id="120">O Beijo da Mulher Aranha"</segment>
    <segment id="121">, com Sonia Braga e William Hurt</segment>
    <segment id="122">, de quem Kelly era uma fã ardorosa.</segment>
    <segment id="123">Após a sessão</segment>
    <segment id="124">, veio o coquetel e a chance de Pelé e Kelly serem apresentados ao ator.</segment>
    <segment id="125">Assim que</segment>
    <segment id="126">sese viu diante do Rei</segment>
    <segment id="127">, Hurt</segment>
    <segment id="128">sese ajoelhou e beijou seus pés</segment>
    <segment id="129">, repetindo "</segment>
    <segment id="130">Eu te adoro</segment>
    <segment id="131">, eu te adoro".</segment>
    <segment id="132">Hurt podia ser o ídolo de Kelly e de muitos fãs de teatro e cinema</segment>
    <segment id="133">, masmas o pai dela era o ídolo de todo o mundo.</segment>
    <segment id="134">LEIA MAIS SOBRE PELÉCâncer de Pelé progrediu</segment>
    <segment id="135">, e tratamento não surtiu efeitoPelé</segment>
    <segment id="136">sese revelou ao mundo aos 17 anos</segment>
    <segment id="137">, na Copa de 1958Preservado pela família</segment>
    <segment id="138">, Edson manteve a fé por saber que Pelé é imortalPelé só foi Pelé</segment>
    <segment id="139">porque</segment>
