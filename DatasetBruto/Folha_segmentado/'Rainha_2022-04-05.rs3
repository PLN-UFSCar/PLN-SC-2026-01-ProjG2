  <rst>
    <segment id="1">De Rainha do Veganismo a ForagidaOnde Disponível na NetflixClassificação 12 anosProdução EUA</segment>
    <segment id="2">, 2022Direção Chris SmithEssa série de quatro episódios conta mais uma história centrada nos golpes de um vigarista</segment>
    <segment id="3">, como</segment>
    <segment id="4">como "Inventando Anna" e "</segment>
    <segment id="5">O Golpista do Tinder"</segment>
    <segment id="6">, todos lançados recentemente pela Netflix.</segment>
    <segment id="7">Alguém no comando do canal de streaming deve ter uma predileção por essas tramas.</segment>
    <segment id="8">Ou será que a atração por golpistas está no nosso zeitgeist e será analisada e explicada no futuro?</segment>
    <segment id="9">No caso</segment>
    <segment id="10">caso de "De Rainha do Veganismo a Foragida"</segment>
    <segment id="11">, péssima tradução para o muito sintético "</segment>
    <segment id="12">Bad Vegan: Fame.</segment>
    <segment id="13">Fraud.</segment>
    <segment id="14">Fugitives" —título original em inglês</segment>
    <segment id="15">, algo</segment>
    <segment id="16">comocomo vegana má: fama</segment>
    <segment id="17">, fraude e fugitivos—</segment>
    <segment id="18">, vários elementos</segment>
    <segment id="19">sese unem para revelar também as peculiaridades de uma curiosa bolha</segment>
    <segment id="20">, formada por gente que opta por</segment>
    <segment id="21">sese alimentar apenas com plantas.</segment>
    <segment id="22">E mais: cruas.  Sarma Melngailis em cena da minissérie documental &amp;#039</segment>
    <segment id="23">;De Rainha do Veganismo a Foragida&amp;#039</segment>
    <segment id="24">;, disponível na Netflix - Divulgação"No geral</segment>
    <segment id="25">, essas pessoas</segment>
    <segment id="26">sese sentem moralmente superiores ao resto de nós</segment>
    <segment id="27">, que provocamos a morte e o sofrimento dos animais</segment>
    <segment id="28">, e tendem a acreditar que há algo além desta realidade para quem adota esse estilo de vida"</segment>
    <segment id="29">, diz o jornalista Allen Salkin</segment>
    <segment id="30">, autor da reportagem da revista Vanity Fair</segment>
    <segment id="31">, publicada em 2016</segment>
    <segment id="32">, que inspirou a série documental.</segment>
    <segment id="33">O restaurante Pure Food and Wine</segment>
    <segment id="34">, criado em 2004 por Sarma e seu namorado na época</segment>
    <segment id="35">, o chef e empresário Matthew Kenney</segment>
    <segment id="36">, foi o pioneiro da comida vegana crua e sofisticada em Nova York.</segment>
    <segment id="37">Ficava na rua 17</segment>
    <segment id="38">, no Gramercy Park</segment>
    <segment id="39">, e era frequentado por Gisele e Tom Brady</segment>
    <segment id="40">, Chelsea Clinton</segment>
    <segment id="41">, Jamie Foxx</segment>
    <segment id="42">, Owen Wilson e Alec Baldwin —que teve uma participação involuntária</segment>
    <segment id="43">, masmas importante na história que culmina na prisão de Sarma e seu marido</segment>
    <segment id="44">, Anthony Strangis (ou Shane Fox</segment>
    <segment id="45">, como</segment>
    <segment id="46">como ela o conheceu)</segment>
    <segment id="47">, o vigarista da trama</segment>
    <segment id="48">, 12 anos depois.</segment>
    <segment id="49">A prisão foi um acontecimento que parecia feito sob medida para o noticiário sensacionalista.</segment>
    <segment id="50">A "rainha vegana"</segment>
    <segment id="51">, como</segment>
    <segment id="52">como a imprensa americana costumava rotulá-la</segment>
    <segment id="53">,</segment>
    <segment id="54">foi capturada numa cidadezinha no interior do Tennessee</segment>
    <segment id="55">, numa manhã de maio de 2016</segment>
    <segment id="56">, depois de pedir uma pizza na rede de fast food Domino's.</segment>
    <segment id="57">Ela estava foragida havia 10 meses.</segment>
    <segment id="58">Sarma é quem conduz a minissérie —eola dá uma longa entrevista que vai sendo comprovada</segment>
    <segment id="59">, ilustrada e enriquecida por outros depoimentos</segment>
    <segment id="60">, imagens reais ou encenadas e</segment>
    <segment id="61">, o mais impressionante de tudo</segment>
    <segment id="62">, áudios verdadeiros de mensagens e telefonemas que ela trocou com o marido</segment>
    <segment id="63">, Shane/Anthony</segment>
    <segment id="64">, que começaram a ser gravados quando ela percebeu que a história que ele contava era por demais inverossímil.</segment>
    <segment id="65">Veja cenas da série documental &amp;#039</segment>
    <segment id="66">;De Rainha do Veganismo a Foragida&amp;#039</segment>
    <segment id="67">;Mais    novamente         de   de  de  representando um</segment>
    <segment id="68">Entre outras maluquices</segment>
    <segment id="69">, Anthony dizia que ela estava sendo testada por seres de outra dimensão</segment>
    <segment id="70">, e que</segment>
    <segment id="71">, sese fosse aprovada</segment>
    <segment id="72">, viraria uma rainha imortal</segment>
    <segment id="73">, no que ele chama de "happily ever after"</segment>
    <segment id="74">, felizes para sempre.</segment>
    <segment id="75">Seu cachorro</segment>
    <segment id="76">, Leon</segment>
    <segment id="77">, um pitbull que ela havia adotado quando procurava uma companhia para Alec Baldwin</segment>
    <segment id="78">, também seria imortalizado.</segment>
    <segment id="79">O ator de "30 Rock" frequentava o restaurante de Sarma desde a inauguração</segment>
    <segment id="80">, ficou amigo dela e tinha interesse em ser mais do que isso.</segment>
    <segment id="81">Dizia a ela que estava em busca de um relacionamento sério</segment>
    <segment id="82">, de algo seguro e duradouro.</segment>
    <segment id="83">Daí a sugestão dela que ele adotasse um cachorro.</segment>
    <segment id="84">Para ajudá-lo</segment>
    <segment id="85">, pesquisou cães que estavam precisando de um lar</segment>
    <segment id="86">, e acabou ela mesma adotando Leon</segment>
    <segment id="87">, um pitbull.</segment>
    <segment id="88">E ele, uma noite</segment>
    <segment id="89">, num jantar no Pure Food and Wine</segment>
    <segment id="90">, notou uma morena bonita e elegante na mesa ao lado.</segment>
    <segment id="91">Foi até lá e</segment>
    <segment id="92">sese apresentou.</segment>
    <segment id="93">Ela era Hilaria</segment>
    <segment id="94">, uma professora de ioga que na verdade</segment>
    <segment id="95">sese chamava Hillary</segment>
    <segment id="96">, masmas que gostava de</segment>
    <segment id="97">sese apresentar</segment>
    <segment id="98">comocomo Hilaria e fingia ter ascendência espanhola.</segment>
    <segment id="99">Os dois começaram a namorar naquela noite mesmo</segment>
    <segment id="100">, sese casaram em 2012 e tiveram seis filhos.</segment>
    <segment id="101">Quando percebeu que Balwin tinha encontrado um amor e ela tinha sobrado com o cachorro</segment>
    <segment id="102">, sese aproximou pelo Twitter de Shane Fox</segment>
    <segment id="103">, um cara que ela não sabia quem era nem de onde vinha</segment>
    <segment id="104">, masmas que trocava mensagens divertidas e instigantes com o ator</segment>
    <segment id="105">, portanto</segment>
    <segment id="106">, pensou</segment>
    <segment id="107">, devia ser uma pessoa confiável.</segment>
    <segment id="108">Shane e Sarma passaram a</segment>
    <segment id="109">sese falar mais e mais</segment>
    <segment id="110">, trocaram o Twitter pelo telefone e depois de um tempo decidiram</segment>
    <segment id="111">sese encontrar.  MaratonarUm guia com dicas de filmes e séries para assistir no streamingCarregando...</segment>
    <segment id="112">Sem dar mais muitos spoilers</segment>
    <segment id="113">, principalmente o motivo pelo qual o casal acabou fugindo de Nova York em 2015</segment>
    <segment id="114">, pois</segment>
    <segment id="115">pois essa trama rocambolesca vale as quase quatro horas que leva para ser contada</segment>
    <segment id="116">, vou só fazer um resumo rápido do que foi dito até aqui.</segment>
    <segment id="117">Shane Fox na verdade</segment>
    <segment id="118">sese chama Anthony Strangis.</segment>
    <segment id="119">Ele e Sarma</segment>
    <segment id="120">sese casam.</segment>
    <segment id="121">Ele a convence de que tem contato com o além e que ela vai passar por uma série de testes.</segment>
    <segment id="122">Se for bem-sucedida</segment>
    <segment id="123">, vira rainha e seu cachorro será imortalizado.</segment>
    <segment id="124">Faltou também falar do golpe.</segment>
    <segment id="125">Entre 2012 e 2014</segment>
    <segment id="126">, Sarma transferiu da conta de seu restaurante para a de seu então marido mais de US$ 1</segment>
    <segment id="127">,7 milhão.</segment>
    <segment id="128">Mais tarde</segment>
    <segment id="129">, sua mãe foi convencida de que para ajudar a filha precisava transferir mais de US$ 400 mil para a conta de Anthony.</segment>
    <segment id="130">Em algum momento de 2015</segment>
    <segment id="131">, Sarma abandonou seu apartamento e o restaurante que criou e tocava sozinha e</segment>
    <segment id="132">, junto do marido e do cachorro Leon</segment>
    <segment id="133">, fugiu de Nova York.</segment>
    <segment id="134">Os dois foram presos quase um ano depois</segment>
    <segment id="135">, quando</segment>
    <segment id="136">, por um descuido</segment>
    <segment id="137">, Anthony pediu uma pizza usando seu nome verdadeiro.</segment>
    <segment id="138">Tem muitos outros detalhes surpreendentes nessa minissérie</segment>
    <segment id="139">, que faz lembrar o</segment>
    <segment id="140">casocaso da socialite americana Patty Hearst</segment>
    <segment id="141">, hoje com 68 anos</segment>
    <segment id="142">, que em 1974 foi sequestrada por um grupo de revolucionários que</segment>
    <segment id="143">sese chamavam de Exército Simbionês de Libertação</segment>
    <segment id="144">, e, após passar pelo que ela mesma chamou de uma lavagem cerebral</segment>
    <segment id="145">, foi gravada por câmeras de segurança em um assalto a banco</segment>
    <segment id="146">, com uma metralhadora na mão.</segment>
    <segment id="147">Culpadas ou inocentes?</segment>
    <segment id="148">Assista e dê o seu veredito.</segment>
  </rst>
</analysis>