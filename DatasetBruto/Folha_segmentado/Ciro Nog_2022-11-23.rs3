  <rst>
    <segment id="1">Entendida por alguns bolsonaristas</segment>
    <segment id="2">comocomo insinuação golpista</segment>
    <segment id="3">, a publicação de trecho da música "</segment>
    <segment id="4">Os Alquimistas Estão Chegando" nas redes sociais por Ciro Nogueira (PP-PI) foi</segment>
    <segment id="5">, segundo ele</segment>
    <segment id="6">, estocada no governo de transição petista</segment>
    <segment id="7">, com referência ao coordenador dela</segment>
    <segment id="8">, Geraldo Alckmin (PSB-SP).</segment>
    <segment id="9">Os aliados do ex-governador são conhecidos</segment>
    <segment id="10">comocomo "alckmistas".</segment>
    <segment id="11">O ministro da Casa Civil disse a interlocutores que o grupo de Lula (PT) não dialoga politicamente com o Congresso e quer fazer passar a PEC da Transição por mágica</segment>
    <segment id="12">, com propostas que ele classifica</segment>
    <segment id="13">comocomo inviáveis</segment>
    <segment id="14">, como</segment>
    <segment id="15">como uma autorização</segment>
    <segment id="16">para que</segment>
    <segment id="17">para que os gastos com o Bolsa Família ficassem fora do teto dos gastos de maneira permanente.</segment>
    <segment id="18">Como mostrou a Folha</segment>
    <segment id="19">, o PT tem sido criticado por seus aliados por falhas na negociação da proposta.</segment>
    <segment id="20">Nogueira publicou a mensagem após reunião de Alckmin com o conselho político da transição nesta quarta-feira (23).</segment>
    <segment id="21">Segundo o parlamentar argumentou</segment>
    <segment id="22">, a postagem tem até um viés democrático</segment>
    <segment id="23">, pois</segment>
    <segment id="24">pois diz que</segment>
    <segment id="25">, inevitavelmente</segment>
    <segment id="26">, os "alquimistas estão chegando"</segment>
    <segment id="27">, ou seja</segment>
    <segment id="28">, não há nada para além da sucessão presidencial de Jair Bolsonaro (PL) por Lula no horizonte.</segment>
    <segment id="29">Ciro Nogueira</segment>
    <segment id="30">, ministro da Casa Civil do governo Jair Bolsonaro</segment>
    <segment id="31">, durante entrevista em seu gabinete no Palácio do Planalto - Pedro Ladeira-19.out.2022/Folhapress</segment>
  </rst>
