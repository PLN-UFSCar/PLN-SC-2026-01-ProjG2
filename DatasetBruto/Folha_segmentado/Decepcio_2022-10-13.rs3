  <rst>
    <segment id="1">Após uma eleição frustrante para deputado federal</segment>
    <segment id="2">, em que teve pouco mais de 4.000 votos</segment>
    <segment id="3">, o ex-ministro da Educação Abraham Weintraub (PMB-SP) pretende</segment>
    <segment id="4">sese estabelecer definitivamente nos EUA</segment>
    <segment id="5">, onde vive desde que deixou o governo de Jair Bolsonaro (PL)</segment>
    <segment id="6">, em 2020.</segment>
    <segment id="7">O ex-ministro da Educação Abraham Weintraub</segment>
    <segment id="8">, que tentou</segment>
    <segment id="9">sese eleger deputado federal - Reprodução/UOL  "</segment>
    <segment id="10">Fiquei surpreso</segment>
    <segment id="11">, tive muito menos votos do que eu podia imaginar.</segment>
    <segment id="12">Achei que eu tinha chance de ganhar a eleição"</segment>
    <segment id="13">, afirma.</segment>
    <segment id="14">Weintraub tem desde abril direito a residência nos EUA</segment>
    <segment id="15">, masmas diz que só recentemente</segment>
    <segment id="16">, após todas as etapas do processo de imigração terem sido concluídas</segment>
    <segment id="17">, pôde deixar o país.</segment>
    <segment id="18">Por isso</segment>
    <segment id="19">, fez toda sua campanha remotamente</segment>
    <segment id="20">, dos arredores de Washington</segment>
    <segment id="21">, onde vive.</segment>
    <segment id="22">Em abril ele deixou o cargo no Banco Mundial que ocupava e ainda não decidiu qual será seu futuro profissional.</segment>
    <segment id="23">O ex-ministro fez carreira no setor financeiro</segment>
    <segment id="24">Weintraub atribui a baixa votação a um processo intenso de "destruição de imagem" que sofreu da esquerda e da direita bolsonarista</segment>
    <segment id="25">, com a qual está rompido.</segment>
    <segment id="26">"</segment>
    <segment id="27">O sistema me ameaçou e à minha família</segment>
    <segment id="28">, por isso não volto ao Brasil"</segment>
    <segment id="29">, diz.</segment>
    <segment id="30">Ele diz que não pretende votar no segundo turno entre Luiz Inácio Lula da Silva (PT) e Bolsonaro</segment>
    <segment id="31">, embora</segment>
    <segment id="32">embora tivesse a opção de comparecer à embaixada brasileira.</segment>
    <segment id="33">"</segment>
    <segment id="34">No dia da eleição</segment>
    <segment id="35">, não vou nem sair de casa"</segment>
    <segment id="36">, diz.</segment>
    <segment id="37">Embora à distância</segment>
    <segment id="38">, Weintraub diz que pretende seguir participando do debate público brasileiro</segment>
    <segment id="39">, por meio de lives e do instituto conservador Farol da Liberdade</segment>
    <segment id="40">, ao qual é ligado.</segment>
    <segment id="41">"</segment>
    <segment id="42">Fiquei seis anos</segment>
    <segment id="43">comocomo homem público.</segment>
    <segment id="44">Agora vou cuidar da família e das coisas que deixei de stand by"</segment>
    <segment id="45">, afirma.</segment>
  </rst>
</analysis>