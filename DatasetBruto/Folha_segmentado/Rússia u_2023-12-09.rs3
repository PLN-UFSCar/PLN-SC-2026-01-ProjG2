  <rst>
    <segment id="1">Vídeos de famosos</segment>
    <segment id="2">comocomo o lutador Mike Tyson e o ator Elijah Wood estão sendo usados em publicações de notícias falsas sobre Volodimir Zelenski</segment>
    <segment id="3">, presidente da Ucrânia</segment>
    <segment id="4">, na cobertura da guerra feita pela Rússia.</segment>
    <segment id="5">Conhecido por interpretar Frodo na saga "</segment>
    <segment id="6">O Senhor dos Anéis"</segment>
    <segment id="7">, Wood</segment>
    <segment id="8">, por exemplo</segment>
    <segment id="9">, surge em um vídeo no qual diz para um homem chamado Vladimir começar um tratamento para abuso de drogas e álcool.</segment>
    <segment id="10">A edição é feita para parecer que ele</segment>
    <segment id="11">sese dirige a Zelenski</segment>
    <segment id="12">, quando</segment>
    <segment id="13">sese trata de outra pessoa.</segment>
    <segment id="14">O ator americano Elijah Wood</segment>
    <segment id="15">, conhecido pela saga &amp;#039</segment>
    <segment id="16">;O Senhor dos Anéis&amp;#039</segment>
    <segment id="17">; - Valerie Macon/AFPSegundo reportagem do jornal The New York Times</segment>
    <segment id="18">, os vídeos são verdadeiros</segment>
    <segment id="19">, masmas reaproveitados e tirados de contexto</segment>
    <segment id="20">, sem o conhecimento das celebridades.</segment>
    <segment id="21">As gravações foram feitas no aplicativo Cameo</segment>
    <segment id="22">, onde usuários podem pagar por mensagens personalizadas de famosos.</segment>
    <segment id="23">Outras figuras exibidas em publicações incluem o músico Shavo Odadjian</segment>
    <segment id="24">, os atores Priscilla Presley</segment>
    <segment id="25">, John McGinley</segment>
    <segment id="26">, Dean Norris e Kate Flannery.</segment>
    <segment id="27">Esses e outros vídeos acabaram sendo divulgados por empresas de notícias controladas pelo governo russo e compartilhados nas redes sociais.</segment>
    <segment id="28">Veja fotos da guerra na UcrâniaMais    novamente         de   de  de  representando um</segment>
    <segment id="29">Em comunicado enviado ao jornal americano</segment>
    <segment id="30">, a Cameo disse que vídeos</segment>
    <segment id="31">comocomo esses violariam as diretrizes da comunidade da empresa.</segment>
    <segment id="32">"</segment>
    <segment id="33">Nos casos em que tais violações são comprovadas</segment>
    <segment id="34">, a Cameo normalmente tomará medidas para remover o conteúdo problemático e suspender a conta do comprador para ajudar a evitar problemas futuros.</segment>
    <segment id="35">"  Imagens do ator</segment>
    <segment id="36">Elijah WoodMais    novamente         de   de  de  representando</segment>
    <segment id="37">um</segment>
  </rst>
