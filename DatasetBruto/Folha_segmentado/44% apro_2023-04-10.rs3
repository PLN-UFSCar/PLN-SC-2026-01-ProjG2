  <rst>
    <segment id="1">BAIXAR PESQUISA COMPLETA</segment>
    <segment id="2">Após três meses à frente do governo do Estado de São Paulo</segment>
    <segment id="3">, Tarcísio de Freitas (Republicanos) é avaliado</segment>
    <segment id="4">comocomo ótimo ou bom por 44% dos paulistas.</segment>
    <segment id="5">Quatro em cada dez (39%) avaliam o governo</segment>
    <segment id="6">comocomo regular</segment>
    <segment id="7">, 11% como</segment>
    <segment id="8">como ruim ou péssimo e 6% não opinaram.</segment>
    <segment id="9">A taxa de aprovação do governo Tarcísio é mais alta entre os que têm 45 anos ou mais (53%)</segment>
    <segment id="10">, entre os empresários (67%)</segment>
    <segment id="11">, entre os simpatizantes do PL (86%) e entre os seus eleitores no segundo turno da eleição estadual do ano passado (60%).</segment>
    <segment id="12">Por outro lado</segment>
    <segment id="13">, a taxa de reprovação é mais alta entre os simpatizantes do PT (18%) e entre os eleitores de Fernando Haddad no segundo turno da eleição estadual do ano passado (17%).</segment>
    <segment id="14">Na análise por região do estado</segment>
    <segment id="15">, as taxas de avaliação do governo Tarcísio são próximas entre os moradores do interior e da região metropolitana.</segment>
    <segment id="16">Entre os moradores do interior</segment>
    <segment id="17">, 47% aprovam a gestão Tarcísio</segment>
    <segment id="18">, 36% a avaliam</segment>
    <segment id="19">comocomo regular e 11%</segment>
    <segment id="20">, a reprovam.</segment>
    <segment id="21">Já, entre os moradores da Região Metropolitana</segment>
    <segment id="22">, esses índices são</segment>
    <segment id="23">, respectivamente</segment>
    <segment id="24">, 41%, 42% e 12%.</segment>
    <segment id="25">Em comparação com avaliações de governos anteriores</segment>
    <segment id="26">, em período similar de tempo</segment>
    <segment id="27">, a taxa de aprovação do governo Tarcísio é mais alta do que a de Mario Covas (era 31% em março de 1995) e a de José Serra (era 39% em março de 2007)</segment>
    <segment id="28">, e, mais baixa do que a de Geraldo Alckmin (era 48% em março de 2011).</segment>
    <segment id="29">O atual levantamento foi realizado nos dias 03 a 05 de abril de 2023</segment>
    <segment id="30">, com 1.806 entrevistas presenciais em 65 municípios</segment>
    <segment id="31">, com população de 16 anos ou mais de todas as regiões do Estado de São Paulo.</segment>
    <segment id="32">A margem de erro da pesquisa é de 2 pontos percentuais para mais ou para menos considerando um nível de confiança de 95%.</segment>
    <segment id="33">Uma parcela de 12% avalia que Tarcísio fez pelo Estado de São Paulo mais do que</segment>
    <segment id="34">sese esperava</segment>
    <segment id="35">, 37% avaliam que fez o que</segment>
    <segment id="36">sese esperava e 45%</segment>
    <segment id="37">, menos do que</segment>
    <segment id="38">sese esperava.</segment>
    <segment id="39">Uma fração de 5% não opinou.</segment>
    <segment id="40">A avaliação do trabalho de Tarcísio nesses três primeiros meses de governo é mais positiva entre os seus eleitores no segundo turno da eleição estadual do ano passado: 17% avaliam que fez mais do que</segment>
    <segment id="41">sese esperava</segment>
    <segment id="42">, 43% que fez o que</segment>
    <segment id="43">sese esperava e 35%</segment>
    <segment id="44">, menos do que</segment>
    <segment id="45">sese esperava.</segment>
    <segment id="46">A respeito das promessas feitas durante a campanha de 2022</segment>
    <segment id="47">, 25% avaliam que Tarcísio irá cumprir a maioria dessas promessas</segment>
    <segment id="48">, 64% que irá cumprir parte dessas promessas</segment>
    <segment id="49">, masmas a maioria não</segment>
    <segment id="50">, e 8%</segment>
    <segment id="51">, que cumprirá nenhuma promessa.</segment>
    <segment id="52">Uma fração de 2% não opinou.</segment>
    <segment id="53">Entre os eleitores de Tarcísio</segment>
    <segment id="54">, a taxa daqueles que acreditam que o governador irá cumprir a maioria das promessas fica acima da média e alcança 39%.</segment>
  </rst>
</analysis>