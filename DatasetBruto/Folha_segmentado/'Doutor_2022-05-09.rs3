  <rst>
    <segment id="1">Quatro dias depois de estrear nos cinemas brasileiros</segment>
    <segment id="2">, o novo filme do super-herói</segment>
    <segment id="3">Doutor</segment>
    <segment id="4">Estranho</segment>
    <segment id="5">já foi pirateado em sites pornô na internet.</segment>
    <segment id="6">É "</segment>
    <segment id="7">Doutor</segment>
    <segment id="8">Estranho no Multiverso do Sexo"</segment>
    <segment id="9">, que goza com o título correto "</segment>
    <segment id="10">Doutor</segment>
    <segment id="11">Estranho no Multiverso da Loucura"</segment>
    <segment id="12">, masmas é a obra original da Marvel</segment>
    <segment id="13">, hoje sob comando da Disney</segment>
    <segment id="14">, e não uma paródia com atores fantasiados transando.</segment>
    <segment id="15">O que se</segment>
    <segment id="16">se vê é o filme dublado em português</segment>
    <segment id="17">, provavelmente gravado por um espectador com seu celular e um tripé em uma sessão neste fim de semana em algum lugar do Brasil.</segment>
    <segment id="18">Ilegalmente</segment>
    <segment id="19">, é claro.</segment>
    <segment id="20">Site pornô com &amp;quot</segment>
    <segment id="21">;Doutor Estranho no Multiverso da Loucura&amp;quot</segment>
    <segment id="22">; pirateado - ReproduçãoNa tarde desta segunda</segment>
    <segment id="23">, a pirataria podia ser vista no site Xvideos300.com.</segment>
    <segment id="24">Uma reportagem do jornal</segment>
    <segment id="25">O Estado de S. Paulo indicava que a versão também estava disponível em Xvideos.com</segment>
    <segment id="26">, com mais de 50 mil visualizações.</segment>
    <segment id="27">Questionada</segment>
    <segment id="28">, a Disney não havia</segment>
    <segment id="29">sese pronunciado até a publicação desta reportagem.</segment>
    <segment id="30">A pirataria de filmes de Hollywood é algo quase tão antigo quanto a internet</segment>
    <segment id="31">, masmas é curioso que o Doutor Estranho</segment>
    <segment id="32">, interpretado por Benedict Cumberbatch</segment>
    <segment id="33">, tenha ido parar num site de sexo explícito e que o filme apareça lá usando a linguagem típica desses sites.</segment>
