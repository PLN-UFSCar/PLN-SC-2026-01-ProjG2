    <segment id="660">"</segment>
    <segment id="661">, de 1870: Contos  "Ressurreição"</segment>
    <segment id="662">, de 1872:</segment>
    <segment id="663">Romance  "Histórias da Meia-Noite"</segment>
    <segment id="664">, de 1873: Contos  "</segment>
