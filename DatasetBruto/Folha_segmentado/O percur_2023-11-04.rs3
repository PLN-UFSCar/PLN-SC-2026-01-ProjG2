    <segment id="644">, de 1863:</segment>
    <segment id="645">Duas comédias  "</segment>
    <segment id="646">Quase Ministro</segment>
    <segment id="647">"</segment>
    <segment id="648">, de 1864</segment>
    <segment id="649">:</segment>
    <segment id="650">Peça de teatro  "</segment>
    <segment id="651">Crisálidas"</segment>
    <segment id="652">, de 1864:</segment>
    <segment id="653">Poesia  "</segment>
