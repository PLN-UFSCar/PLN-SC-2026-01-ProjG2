    <segment id="632">De 18/11 a 4/2Onde Itaú Cultural (av. Paulista</segment>
    <segment id="633">, 149;</segment>
    <segment id="634">São Paulo)Preço Entrada FrancaVisitação Terça a sábado</segment>
    <segment id="635">, das 11h às 20h</segment>
    <segment id="636">; domingos e feriados</segment>
    <segment id="637">, das 11h às 19hOcupação Machado de AssisEntrada FrancaItaú Cultural (av. Paulista</segment>
    <segment id="638">, 149; São Paulo) stars -"Ocupação</segment>
    <segment id="639">Machado de Assis"</segment>
    <segment id="640">Os 26 títulos da coleção  "Desencantos"</segment>
    <segment id="641">, de 1861:</segment>
    <segment id="642">Peça de teatro  "</segment>
