  <rst>
    <segment id="1">Único feriado nacional do mês de outubro</segment>
    <segment id="2">, o Dia de Nossa Senhora Aparecida</segment>
    <segment id="3">, comemorado no dia 12</segment>
    <segment id="4">, homenageia a padroeira do Brasil</segment>
    <segment id="5">, que também é uma das principais santas do catolicismo.</segment>
    <segment id="6">Em 1717</segment>
    <segment id="7">, segundo a história</segment>
    <segment id="8">, pescadores de Guaratinguetá</segment>
    <segment id="9">, no interior paulista</segment>
    <segment id="10">, buscavam peixes no rio Paraíba do Sul para um jantar especial</segment>
    <segment id="11">, sob ordens de Pedro Miguel de Almeida Portugal e Vasconcelos</segment>
    <segment id="12">, governante da Capitania de São Paulo e Minas de Ouro.</segment>
    <segment id="13">Fiel durante missa no santuário de Nossa Senhora Aparecida</segment>
    <segment id="14">, em Aparecida</segment>
    <segment id="15">, no interior do estado de São Paulo - Eduardo Anizelli/FolhapressQuando estavam prestes a partir</segment>
    <segment id="16">, um dos homens</segment>
    <segment id="17">, João Alves</segment>
    <segment id="18">, jogou a rede mais uma vez</segment>
    <segment id="19">, apanhando uma imagem de Virgem Maria</segment>
    <segment id="20">, que enrolou em um manto.</segment>
    <segment id="21">A partir de então</segment>
    <segment id="22">, suas redes</segment>
    <segment id="23">sese encheram de peixes</segment>
    <segment id="24">, sendo esta a primeira intercessão creditada à santa.</segment>
    <segment id="25">Durante 15 anos a imagem ficou exposta em uma casa na cidade.</segment>
    <segment id="26">A devoção foi crescendo entre o povo da região</segment>
    <segment id="27">, e houve relatos de milagres por aqueles que faziam pedidos diante da santa.</segment>
    <segment id="28">A fama da imagem</segment>
    <segment id="29">sese espalhou pelo país</segment>
    <segment id="30">, e uma capela foi erguida para a santa.</segment>
    <segment id="31">No dia 20 de abril de 1822</segment>
    <segment id="32">, o então príncipe regente do Brasil</segment>
    <segment id="33">, dom Pedro</segment>
    <segment id="34">, visitou a capela.</segment>
    <segment id="35">Como o número de fiéis seguiu aumentando</segment>
    <segment id="36">, em 1834 foi iniciada a construção de uma igreja maior</segment>
    <segment id="37">, a atual Basílica Velha de Aparecida</segment>
    <segment id="38">, inaugurada em 8 de dezembro de 1888.</segment>
    <segment id="39">Missa reúne fiéis em Aparecida no Dia de Nossa SenhoraMais    novamente         de   de  de  representando um  Nossa Senhora Aparecida foi proclamada rainha do Brasil e sua padroeira em 16 de julho de 1930</segment>
    <segment id="40">, por decreto do papa Pio 11.</segment>
    <segment id="41">Pela lei 6.802</segment>
    <segment id="42">, de 30 de junho de 1980</segment>
    <segment id="43">, foi decretado oficialmente feriado para devoção da santa o dia 12 de outubro.</segment>
    <segment id="44">Também nesta lei o Estado reconhece Nossa Senhora Aparecida</segment>
    <segment id="45">comocomo padroeira.</segment>
    <segment id="46">Devido à importância da santa no imaginário popular brasileiro</segment>
    <segment id="47">, em 1946 foi iniciada a construção de um santuário dedicado para ela na cidade de Aparecida</segment>
    <segment id="48">, no interior de São Paulo.</segment>
    <segment id="49">O município foi fundado em 1928 para homenagear a santa.</segment>
    <segment id="50">Em 1980</segment>
    <segment id="51">, ano da inauguração do santuário</segment>
    <segment id="52">, o papa João Paulo 2º</segment>
    <segment id="53">, em visita ao Brasil</segment>
    <segment id="54">, consagrou o local</segment>
    <segment id="55">comocomo basílica e santuário nacional.</segment>
    <segment id="56">Já em 2016</segment>
    <segment id="57">, o papa Francisco elevou a basílica a catedral da arquidiocese de Aparecida.</segment>
    <segment id="58">Todos os anos</segment>
    <segment id="59">, milhões de fiéis</segment>
    <segment id="60">sese dirigem ao santuário para fazer e pagar promessas.</segment>
    <segment id="61">Dia da Criança</segment>
    <segment id="62">O dia 12 de outubro também marca o Dia da Criança no Brasil.</segment>
    <segment id="63">A celebração</segment>
    <segment id="64">, no entanto</segment>
    <segment id="65">, não tem relação com religiosidade e surgiu antes do feriado de Nossa Senhora.</segment>
    <segment id="66">Em 1923</segment>
    <segment id="67">, a cidade do Rio de Janeiro</segment>
    <segment id="68">, então capital do país</segment>
    <segment id="69">, sediou o 3º Congresso Sul-Americano da Criança.</segment>
    <segment id="70">Galdino do Valle Filho</segment>
    <segment id="71">, deputado federal à época</segment>
    <segment id="72">, aproveitou a atmosfera que o congresso deixara para elaborar um projeto que tinha</segment>
    <segment id="73">comocomo objetivo a criação de um dia nacional dedicado aos pequenos.</segment>
    <segment id="74">A ideia do deputado era que houvesse reflexão sobre a situação das crianças brasileiras.</segment>
    <segment id="75">A proposta era de que a celebração fosse em 12 de outubro</segment>
    <segment id="76">, data em que Cristóvão Colombo chegou à América.</segment>
    <segment id="77">O projeto de Galdino foi aprovado</segment>
    <segment id="78">, e o Dia da Criança foi oficializado pelo presidente Artur Bernardes</segment>
    <segment id="79">, em decreto publicado em 5 de novembro de 1924.</segment>
    <segment id="80">Mas foi só a partir de 1955</segment>
    <segment id="81">, quando a fabricante de brinquedos</segment>
    <segment id="82">Estrela usou a data para lançar uma campanha nacional para a venda de seus produtos</segment>
    <segment id="83">, que o Dia da Criança passou a ser visto</segment>
    <segment id="84">comocomo uma data importante no calendário brasileiro e virou símbolo da distribuição de brinquedos às crianças.</segment>
    <segment id="85">Outros países</segment>
    <segment id="86">, como</segment>
    <segment id="87">como Japão e Portugal</segment>
    <segment id="88">, também possuem um feriado nacional para celebrar as crianças</segment>
    <segment id="89">, masmas em datas diferentes.</segment>
  </rst>
</analysis>