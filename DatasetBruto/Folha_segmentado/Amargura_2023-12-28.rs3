  <rst>
    <segment id="1">O presidente Lula (PT) superou ressentimentos e mágoas que tinha em relação ao Judiciário</segment>
    <segment id="2">, ao Ministério Público</segment>
    <segment id="3">, à imprensa e a outros atores a quem responsabilizava por seu infortúnio quando foi condenado e preso na Operação Lava Jato.</segment>
    <segment id="4">O presidente Lula participa do desfile de 7 de Setembro na Esplanada dos Ministérios</segment>
    <segment id="5">, em Brasília - Lucio Tavora - 7.set.2023/XinhuaCORAÇÃO LEVE</segment>
    <segment id="6">De acordo com um de seus principais ministros</segment>
    <segment id="7">, "a amargura foi diminuindo</segment>
    <segment id="8">, diminuindo</segment>
    <segment id="9">, diminuindo" neste primeiro ano de mandato</segment>
    <segment id="10">, "e desapareceu ao longo do tempo."</segment>
    <segment id="11">Na véspera do Ano Novo</segment>
    <segment id="12">, o presidente teria olhos apenas para o futuro —e também maior otimismo.  CORAÇÃO 2  Ministros e auxiliares de Lula</segment>
    <segment id="13">chegaram a</segment>
    <segment id="14">sese preocupar</segment>
    <segment id="15">, no início do governo</segment>
    <segment id="16">, com os sentimentos do presidente</segment>
    <segment id="17">, que ainda estava preso ao passado recente dos 580 dias na prisão.</segment>
    <segment id="18">REPETECO</segment>
    <segment id="19">O presidente repetia críticas aos operadores da Lava Jato e chegou a dizer em março</segment>
    <segment id="20">, em uma entrevista</segment>
    <segment id="21">, que repetia para si mesmo</segment>
    <segment id="22">, na prisão:</segment>
    <segment id="23">"</segment>
    <segment id="24">Só vou ficar bem quando f. o Moro".</segment>
    <segment id="25">Recepção a Lula em sindicato do ABC após 580 dias na prisãoMais    novamente         de   de  de  representando um  REPETECO 2</segment>
    <segment id="26">Com o tempo</segment>
    <segment id="27">, as citações a Sergio Moro foram desaparecendo</segment>
    <segment id="28">, bem como</segment>
    <segment id="29">como as queixas a outros atores da Lava Jato ou àqueles que</segment>
    <segment id="30">, no entendimento do presidente</segment>
    <segment id="31">, a apoiaram.</segment>
    <segment id="32">Afirmações de que tinha sido vítima de preconceito também já não são feitas com frequência.  NO PASSADO</segment>
    <segment id="33">"</segment>
    <segment id="34">Toda essa amargura sumiu</segment>
    <segment id="35">, das falas e do olhar do presidente.</segment>
    <segment id="36">Tudo foi</segment>
    <segment id="37">sese dissipando"</segment>
    <segment id="38">, afirma um dos mais próximos ministros de Lula.</segment>
    <segment id="39">LEIA</segment>
    <segment id="40">TODOS OS TEMAS ABORDADOS PELA COLUNA NA EDIÇÃO IMPRESSA</segment>
    <segment id="41">DESTA SEXTA (29)Amargura de Lula sumiu &amp;#</segment>
    <segment id="42">039;das falas e do olhar&amp;#039</segment>
    <segment id="43">;</segment>
    <segment id="44">depois de um ano de mandato</segment>
    <segment id="45">, diz ministroSete em cada dez brasileiros dizem saber discernir notícias falsas de verdadeiras</segment>
    <segment id="46">, mostra pesquisaAncine registra aumento de 17% em número de obras audiovisuais produzidas em 2023Suzana Herculano-Houzel lança site bilíngue sobre neurociênciaPalácios do Governo de SP terão exposições de Tarsila e Vicente do Rego Monteiro em 2024Revista da Biblioteca Nacional tem novo curador e conselho editorial formado só por mulheresClaudia Leitte prepara roupa em homenagem a São Paulo para show de Réveillon na avenida PaulistaCONTAGEM REGRESSIVA</segment>
    <segment id="47">A cantora Claudia Leitte durante ensaio fotográfico - Nara/DivulgaçãoA cantora Claudia Leitte</segment>
    <segment id="48">será uma das atrações da festa de Réveillon da avenida Paulista</segment>
    <segment id="49">, em São Paulo.</segment>
    <segment id="50">O look dela para o show será uma homenagem à própria cidade</segment>
    <segment id="51">, retratando a paisagem urbana e os fogos de artifício.</segment>
    <segment id="52">Como normalmente</segment>
    <segment id="53">sese apresenta no Ano Novo</segment>
    <segment id="54">, a artista diz que não tem superstições para a virada.</segment>
    <segment id="55">"</segment>
    <segment id="56">Costumo passar na estrada</segment>
    <segment id="57">, com a minha banda e minha equipe</segment>
    <segment id="58">, e a gente [está] sempre muito unido para fazer um show que leve para o público a positividade que a data pede"</segment>
    <segment id="59">, diz.  com BIANKA VIEIRA</segment>
    <segment id="60">, KARINA MATIAS e MANOELLA SMITH</segment>
