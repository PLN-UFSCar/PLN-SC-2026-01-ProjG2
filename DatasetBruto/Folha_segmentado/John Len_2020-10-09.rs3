  <rst>
    <segment id="1">Há exatos 40 anos</segment>
    <segment id="2">, o músico e empresário Marco Antônio Mallagoli</segment>
    <segment id="3">, na época com 27 anos</segment>
    <segment id="4">, pôs na cabeça que queria passar o aniversário de 40 anos de John Lennon</segment>
    <segment id="5">, no dia 9 de outubro de 1980</segment>
    <segment id="6">, ao lado do ídolo.</segment>
    <segment id="7">Fácil não seria</segment>
    <segment id="8">, pensou.</segment>
    <segment id="9">Mas não custava tentar.</segment>
    <segment id="10">Alguns amigos tentaram o dissuadir da ideia.</segment>
    <segment id="11">"Cara, ele odeia fã.</segment>
    <segment id="12">Vai cuspir na sua cara!</segment>
    <segment id="13">"</segment>
    <segment id="14">, argumentaram os mais exaltados.</segment>
    <segment id="15">Mallagoli deu de ombros.</segment>
    <segment id="16">Fã dos Beatles desde 1963</segment>
    <segment id="17">, quando ouviu</segment>
    <segment id="18">, pela primeira vez</segment>
    <segment id="19">, uma canção do quarteto britânico</segment>
    <segment id="20">, tomou as devidas precauções</segment>
    <segment id="21">, a primeira delas foi arranjar um lugar para ficar em Nova York.</segment>
    <segment id="22">Siga os passos dos Beatles em Liverpool   novamente         de   de  de  representando um  Não poderia ter encontrado um lugar melhor: Osni Omena</segment>
    <segment id="23">, o primo de um amigo que curtia os Fab Four</segment>
    <segment id="24">, morava na rua 71</segment>
    <segment id="25">, a um quarteirão do Dakota</segment>
    <segment id="26">, o prédio em que Lennon e sua mulher</segment>
    <segment id="27">, Yoko Ono</segment>
    <segment id="28">, moravam</segment>
    <segment id="29">, e abriu as portas do apartamento a ele.</segment>
    <segment id="30">O passo seguinte foi providenciar um presente para o aniversariante –um exemplar de "</segment>
    <segment id="31">Os Reis do Iê</segment>
    <segment id="32">, Iê, Iê"</segment>
    <segment id="33">, de 1965</segment>
    <segment id="34">, a versão brazuca da trilha-sonora do filme "</segment>
    <segment id="35">A Hard</segment>
    <segment id="36">Day's Night"</segment>
    <segment id="37">, com dedicatória e tudo.  Mallagoli chegou a Nova York por volta do dia 5 de outubro.</segment>
    <segment id="38">Todos os dias</segment>
    <segment id="39">, ele passava uma média de oito horas</segment>
    <segment id="40">, das quatro da tarde à meia-noite</segment>
    <segment id="41">, na frente do Dakota.</segment>
    <segment id="42">Na esquina da rua 72 com a Central Park West</segment>
    <segment id="43">, em Manhattan</segment>
    <segment id="44">, o Dakota entrou para a história</segment>
    <segment id="45">comocomo o edifício residencial mais famoso do mundo.</segment>
    <segment id="46">Com pé direito alto</segment>
    <segment id="47">, paredes revestidas em mogno e chão de mármore</segment>
    <segment id="48">, o lugar abrigou astros</segment>
    <segment id="49">comocomo a atriz Judy Garland</segment>
    <segment id="50">, o bailarino Rudolf Nureyev e o casal John Lennon e Yoko Ono</segment>
    <segment id="51">, que se</segment>
    <segment id="52">se mudou para lá em 1973.  John Lennon e Marco Antônio Mallagoli</segment>
    <segment id="53">sese encontraram no aniversário de 40 anos do músico - Osni Omena"Nos anos 1980</segment>
    <segment id="54">, o Dakota</segment>
    <segment id="55">sese tornou um dos pontos turísticos mais badalados de Nova York.</segment>
    <segment id="56">A qualquer hora do dia</segment>
    <segment id="57">, ou da noite</segment>
    <segment id="58">, havia curiosos na porta do edifício</segment>
    <segment id="59">, querendo ver seus moradores ilustres"</segment>
    <segment id="60">, relata Omena</segment>
    <segment id="61">, que mora em Nova York desde o verão de 1980 e trabalha</segment>
    <segment id="62">comocomo designer 3D.</segment>
    <segment id="63">Em pouco tempo</segment>
    <segment id="64">, Mallagoli</segment>
    <segment id="65">sese tornou "amigo de infância" de um dos porteiros do Dakota</segment>
    <segment id="66">, o cubano José Perdomo</segment>
    <segment id="67">, que na época tinha 45 anos.</segment>
    <segment id="68">Para selar a amizade</segment>
    <segment id="69">, deu de presente a ele "um maço de cigarros e uma garrafa de cachaça".</segment>
    <segment id="70">Em retribuição</segment>
    <segment id="71">, pediu a gentileza de entregar ao morador mais ilustre do prédio o LP que trouxera do Brasil.</segment>
    <segment id="72">No grande dia</segment>
    <segment id="73">, o do aniversário de John Lennon</segment>
    <segment id="74">, Mallagoli não era o único a querer dar os parabéns ao ídolo.</segment>
    <segment id="75">Uma pequena multidão</segment>
    <segment id="76">sese formou na frente do Dakota.</segment>
    <segment id="77">A certa altura</segment>
    <segment id="78">, o pequeno Sean</segment>
    <segment id="79">, que faz aniversário no mesmo dia em que o pai</segment>
    <segment id="80">, deu um grito da janela do sétimo andar.</segment>
    <segment id="81">"</segment>
    <segment id="82">Há uma surpresinha pra vocês na portaria!</segment>
    <segment id="83">"</segment>
    <segment id="84">O ex-beatle havia providenciado fatias de bolo</segment>
    <segment id="85">, embrulhadas em papel alumínio</segment>
    <segment id="86">, e balões coloridos autografados para os fãs.</segment>
    <segment id="87">Em vez de pegar seu pedaço</segment>
    <segment id="88">, Mallagoli puxou conversa com o sujeito que trouxera os presentes.</segment>
    <segment id="89">Quando descobriu que</segment>
    <segment id="90">sese tratava de Frederic Seaman</segment>
    <segment id="91">, secretário particular do artista</segment>
    <segment id="92">, perguntou</segment>
    <segment id="93">sese o aniversariante tinha gostado do presente que ele dera na véspera.</segment>
    <segment id="94">"</segment>
    <segment id="95">Ah, então</segment>
    <segment id="96">, foi você?</segment>
    <segment id="97">", ele</segment>
    <segment id="98">sese espantou.</segment>
    <segment id="99">"</segment>
    <segment id="100">John já ouviu umas três vezes.</segment>
    <segment id="101">Há muito tempo ele não ouvia um disco dos Beatles"</segment>
    <segment id="102">, disse.</segment>
    <segment id="103">Nessa hora</segment>
    <segment id="104">, Mallagoli</segment>
    <segment id="105">sese encheu de coragem para perguntar</segment>
    <segment id="106">sese não daria para ele subir um pouquinho e</segment>
    <segment id="107">, quem sabe</segment>
    <segment id="108">, conhecer o ídolo de perto.</segment>
    <segment id="109">"</segment>
    <segment id="110">Não, não daria"</segment>
    <segment id="111">, respondeu Seaman.  '</segment>
    <segment id="112">Gente como</segment>
    <segment id="113">como a gente'  No dia seguinte</segment>
    <segment id="114">, Mallagoli estava lá</segment>
    <segment id="115">, de novo.</segment>
    <segment id="116">Deu de cara com uma limusine</segment>
    <segment id="117">, estacionada na porta</segment>
    <segment id="118">, com o motor ligado.</segment>
    <segment id="119">"</segment>
    <segment id="120">Ele deve sair a qualquer momento"</segment>
    <segment id="121">, pensou.</segment>
    <segment id="122">Não deu outra.</segment>
    <segment id="123">Dali a pouco</segment>
    <segment id="124">, a moça com quem Mallagoli conversava emudeceu e arregalou os olhos.</segment>
    <segment id="125">Era a senha.</segment>
    <segment id="126">Atrás dele</segment>
    <segment id="127">, John Winston Ono Lennon</segment>
    <segment id="128">, com seus indefectíveis óculos de aro redondo.</segment>
    <segment id="129">Sem perder tempo</segment>
    <segment id="130">, Mallagoli</segment>
    <segment id="131">sese apresentou</segment>
    <segment id="132">comocomo o presidente do fã-clube Revolution</segment>
    <segment id="133">, do Brasil.</segment>
    <segment id="134">John retribuiu o cumprimento</segment>
    <segment id="135">, agradeceu pelo presente e os dois começaram a conversar.  John Lennon e Marco Antônio Mallagoli</segment>
    <segment id="136">sese encontraram no aniversário de 40 anos do músico - Osni Omena"Por que você nunca foi ao Brasil?</segment>
    <segment id="137">", Mallagoli puxou conversa.</segment>
    <segment id="138">"</segment>
    <segment id="139">Por que nunca me convidaram"</segment>
    <segment id="140">, respondeu John.</segment>
    <segment id="141">"</segment>
    <segment id="142">Então, a partir de agora</segment>
    <segment id="143">, considere-</segment>
    <segment id="144">sese convidado"</segment>
    <segment id="145">, sorriu.</segment>
    <segment id="146">Em seguida</segment>
    <segment id="147">, Mallagoli quis saber</segment>
    <segment id="148">sese Lennon estava trabalhando em algum disco novo.</segment>
    <segment id="149">"</segment>
    <segment id="150">Sim, ele vai</segment>
    <segment id="151">sese chamar 'Double Fantasy'"</segment>
    <segment id="152">, respondeu</segment>
    <segment id="153">, referindo-</segment>
    <segment id="154">sese ao seu quinto álbum de estúdio</segment>
    <segment id="155">, lançado em novembro de 1980.</segment>
    <segment id="156">Pouco depois</segment>
    <segment id="157">, contou alguns de seus planos para o futuro: lançar outro álbum</segment>
    <segment id="158">, "Milk and Honey"</segment>
    <segment id="159">, no início de 1981 e</segment>
    <segment id="160">, em seguida</segment>
    <segment id="161">, sair em turnê pelo Japão</segment>
    <segment id="162">, Europa</segment>
    <segment id="163">, EUA...</segment>
    <segment id="164">"E Brasil"</segment>
    <segment id="165">, interrompeu Mallagoli.</segment>
    <segment id="166">"</segment>
    <segment id="167">Pois é</segment>
    <segment id="168">, e Brasil"</segment>
    <segment id="169">, concordou o cantor.</segment>
    <segment id="170">Neste momento</segment>
    <segment id="171">, John contou algo que fez o coração de Mallagoli disparar: "</segment>
    <segment id="172">Depois que eu terminar a turnê</segment>
    <segment id="173">, vou ligar para Paul</segment>
    <segment id="174">, Ringo e George e ver o que nós vamos fazer da vida".</segment>
    <segment id="175">"</segment>
    <segment id="176">A ideia dele era reunir os Beatles para gravar mais alguns discos"</segment>
    <segment id="177">, recorda Mallagoli.</segment>
    <segment id="178">"</segment>
    <segment id="179">Cada um deles continuaria com sua carreira solo</segment>
    <segment id="180">, masmas</segment>
    <segment id="181">, de tempos em tempos</segment>
    <segment id="182">, os quatro</segment>
    <segment id="183">sese reuniriam para tocar juntos.</segment>
    <segment id="184">"</segment>
    <segment id="185">Veja fotos de John e Yoko   novamente         de   de  de  representando um  Dessa vez</segment>
    <segment id="186">, é Lennon quem faz uma pergunta:</segment>
    <segment id="187">"</segment>
    <segment id="188">De qual música da banda você mais gosta?</segment>
    <segment id="189">".</segment>
    <segment id="190">"</segment>
    <segment id="191">De todas"</segment>
    <segment id="192">, desconversou o fã.</segment>
    <segment id="193">"</segment>
    <segment id="194">Escolhe uma!</segment>
    <segment id="195">",</segment>
    <segment id="196">insistiu o ídolo.</segment>
    <segment id="197">Na hora</segment>
    <segment id="198">, Mallagoli pensou na primeira que ouviu</segment>
    <segment id="199">, em 1963</segment>
    <segment id="200">, quando tinha 11 anos: "</segment>
    <segment id="201">She Loves You".</segment>
    <segment id="202">"</segment>
    <segment id="203">Por quê?</segment>
    <segment id="204">", perguntou Lennon curioso.</segment>
    <segment id="205">"</segment>
    <segment id="206">Por nada...</segment>
    <segment id="207">", despistou Lennon</segment>
    <segment id="208">, com um sorriso maroto</segment>
    <segment id="209">, e acrescentou: "</segment>
    <segment id="210">Quando você volta para o Brasil?</segment>
    <segment id="211">".</segment>
    <segment id="212">"</segment>
    <segment id="213">Ainda hoje"</segment>
    <segment id="214">, lamentou</segment>
    <segment id="215">, consultando o relógio.</segment>
    <segment id="216">E sese despediram.</segment>
    <segment id="217">"Foram os 15 minutos mais mágicos da minha vida"</segment>
    <segment id="218">, garante Mallagoli</segment>
    <segment id="219">, hoje aos 67 anos.</segment>
    <segment id="220">"</segment>
    <segment id="221">Uma emoção difícil de explicar.</segment>
    <segment id="222">"</segment>
    <segment id="223">A caminho da limusine</segment>
    <segment id="224">, John parou</segment>
    <segment id="225">, voltou-</segment>
    <segment id="226">sese para Mallagoli e deu a impressão de que queria dizer algo.</segment>
    <segment id="227">No entanto</segment>
    <segment id="228">, mudou de ideia e entrou no carro.</segment>
    <segment id="229">Algum tempo depois</segment>
    <segment id="230">, Mallagoli perguntou a Seaman</segment>
    <segment id="231">sese, por acaso</segment>
    <segment id="232">, ele sabia o que John queria lhe dizer.</segment>
    <segment id="233">"</segment>
    <segment id="234">Bem, ele pensou em convidá-lo para assistir às gravações do disco no estúdio.</segment>
    <segment id="235">Mas, como</segment>
    <segment id="236">como você estava de viagem marcada</segment>
    <segment id="237">, não quis atrapalhar"</segment>
    <segment id="238">, explicou o assessor.</segment>
    <segment id="239">"</segment>
    <segment id="240">Puxa, meu</segment>
    <segment id="241">, sese soubesse disso</segment>
    <segment id="242">, nem voltaria mais para o Brasil!</segment>
    <segment id="243">",</segment>
    <segment id="244">cai na risada.</segment>
    <segment id="245">As fotos que registraram o encontro entre Lennon e Mallagoli foram tiradas por Omena.</segment>
    <segment id="246">"</segment>
    <segment id="247">Sim, também sou fã dos Beatles.</segment>
    <segment id="248">Mas, não tanto quanto o Mallagoli"</segment>
    <segment id="249">, diverte-</segment>
    <segment id="250">sese o amigo.</segment>
    <segment id="251">"</segment>
    <segment id="252">Minha primeira reação foi pegar a câmera da mão do Mallagoli para registrar o momento.</segment>
    <segment id="253">John Lennon foi muito atencioso e receptivo.</segment>
    <segment id="254">Gente como</segment>
    <segment id="255">como a gente"</segment>
    <segment id="256">, descreve.</segment>
    <segment id="257">Futebol na rua</segment>
    <segment id="258">Ao contrário do que dissera a John</segment>
    <segment id="259">, Mallagoli ficou mais um dia em Nova York.</segment>
    <segment id="260">Antes de regressar ao Brasil</segment>
    <segment id="261">, no dia 11</segment>
    <segment id="262">, deu uma última passada no Dakota</segment>
    <segment id="263">, para</segment>
    <segment id="264">sese despedir de José Perdomo.</segment>
    <segment id="265">Entre outras histórias</segment>
    <segment id="266">, o porteiro cubano contou que</segment>
    <segment id="267">, na Páscoa daquele ano</segment>
    <segment id="268">, Paul</segment>
    <segment id="269">, Linda e os filhos passaram alguns dias em companhia de John</segment>
    <segment id="270">, Yoko e Sean.</segment>
    <segment id="271">"</segment>
    <segment id="272">Certa noite</segment>
    <segment id="273">, John e Paul [McCartney] desceram com algumas crianças do prédio</segment>
    <segment id="274">, fecharam a rua e jogaram bola ali mesmo.</segment>
    <segment id="275">Não havia ninguém na rua"</segment>
    <segment id="276">, contou Perdomo.</segment>
    <segment id="277">Não parou por aí.</segment>
    <segment id="278">Segundo Lennon teria dito a ele</segment>
    <segment id="279">, o ex-Beatle planejava</segment>
    <segment id="280">, em breve</segment>
    <segment id="281">, pular o Carnaval no Brasil.</segment>
    <segment id="282">"</segment>
    <segment id="283">De máscara</segment>
    <segment id="284">, para não ser reconhecido"</segment>
    <segment id="285">, salientou o cubano.  John Lennon e Marco Antônio Mallagoli</segment>
    <segment id="286">sese encontraram no aniversário de 40 anos do músico - Osni OmenaDe volta ao Brasil</segment>
    <segment id="287">, Mallagoli recebeu</segment>
    <segment id="288">, depois de alguns dias</segment>
    <segment id="289">, um telefonema de Fred Seaman.</segment>
    <segment id="290">O secretário de Lennon confirmou a intenção do cantor de excursionar pelo Brasil.</segment>
    <segment id="291">"</segment>
    <segment id="292">A ideia era fazer show em todos os estados</segment>
    <segment id="293">, pegar o dinheiro da bilheteria</segment>
    <segment id="294">, pagar o cachê da banda e doar o resto da grana para alguma instituição de caridade local"</segment>
    <segment id="295">, recorda.</segment>
    <segment id="296">Mais alguns dias</segment>
    <segment id="297">sese passaram até Mallagoli receber uma encomenda pelos correios:</segment>
    <segment id="298">o disco de ouro de "She Loves You"</segment>
    <segment id="299">, acompanhado de um bilhete escrito por Simmons.</segment>
    <segment id="300">"</segment>
    <segment id="301">Lennon me disse que esse disco vai estar melhor em suas mãos do que nas dele".</segment>
    <segment id="302">Mallagoli ligou para agradecer.</segment>
    <segment id="303">"</segment>
    <segment id="304">Lennon gostou muito de você"</segment>
    <segment id="305">, confidenciou o secretário.</segment>
    <segment id="306">"</segment>
    <segment id="307">Era como</segment>
    <segment id="308">como se</segment>
    <segment id="309">se fossem dois velhos amigos que</segment>
    <segment id="310">, há anos</segment>
    <segment id="311">, não se</segment>
    <segment id="312">se viam.</segment>
    <segment id="313">"  Tiros em Manhattan  Osni Omena tinha acabado de voltar do trabalho quando</segment>
    <segment id="314">, na noite de 8 de dezembro de 1980</segment>
    <segment id="315">, escutou barulho de fogos de artifício na rua.</segment>
    <segment id="316">"</segment>
    <segment id="317">Ué, o que será que estão comemorando?</segment>
    <segment id="318">", pensou.</segment>
    <segment id="319">"</segment>
    <segment id="320">Será que são porto-riquenhos comemorando algum feriado nacional?</segment>
    <segment id="321">", especulou.</segment>
    <segment id="322">Alguns minutos depois</segment>
    <segment id="323">, Omena ouvia sua estação de rock favorita quando o locutor interrompeu a programação para dar uma notícia que ninguém queria ouvir: o ex-beatle John Lennon acabara de sofrer um atentado na porta do Dakota.</segment>
    <segment id="324">Omena não acreditou:</segment>
    <segment id="325">não eram fogos</segment>
    <segment id="326">, pensou</segment>
    <segment id="327">, eram tiros.</segment>
    <segment id="328">Atordoado</segment>
    <segment id="329">, fez questão de conferir de perto o que estava acontecendo.</segment>
    <segment id="330">"</segment>
    <segment id="331">Havia muita gente chorando.</segment>
    <segment id="332">Quando soubemos da morte dele</segment>
    <segment id="333">, foi um choque muito grande.</segment>
    <segment id="334">Uma verdadeira tragédia"</segment>
    <segment id="335">, recorda</segment>
    <segment id="336">, emocionado.</segment>
    <segment id="337">Anos depois</segment>
    <segment id="338">, Omena reencontrou Perdomo</segment>
    <segment id="339">, que contou detalhes daquela noite.</segment>
    <segment id="340">Fora ele</segment>
    <segment id="341">, dissera</segment>
    <segment id="342">, quem tirou o 38 das mãos de Mark David Chapman</segment>
    <segment id="343">, o assassino de John Lennon.</segment>
    <segment id="344">"</segment>
    <segment id="345">Você sabe o que você fez?</segment>
    <segment id="346">", perguntou o porteiro.</segment>
    <segment id="347">"</segment>
    <segment id="348">Sim, eu matei John Lennon"</segment>
    <segment id="349">, respondeu o sujeito que não tentou fugir da cena do crime</segment>
    <segment id="350">, nem ofereceu resistência aos policiais que deram voz de prisão a ele.</segment>
    <segment id="351">Mallagoli soube da morte de Lennon na terça</segment>
    <segment id="352">, dia 9.</segment>
    <segment id="353">Passava de uma da tarde quando ele chegou para abrir sua loja</segment>
    <segment id="354">, na avenida Brigadeiro Faria Lima</segment>
    <segment id="355">, em São Paulo</segment>
    <segment id="356">, e estranhou a multidão.</segment>
    <segment id="357">"Marcão</segment>
    <segment id="358">, como</segment>
    <segment id="359">como você está?</segment>
    <segment id="360">", perguntou um amigo.</segment>
    <segment id="361">"</segment>
    <segment id="362">Tudo bem</segment>
    <segment id="363">, um pouco cansado</segment>
    <segment id="364">, por quê?</segment>
    <segment id="365">", respondeu</segment>
    <segment id="366">, pegando as chaves no bolso.</segment>
    <segment id="367">"</segment>
    <segment id="368">Tá bem mesmo</segment>
    <segment id="369">, tem certeza?</segment>
    <segment id="370">",</segment>
    <segment id="371">insistiu outro.</segment>
    <segment id="372">"</segment>
    <segment id="373">Por quê?</segment>
    <segment id="374">O que houve?</segment>
    <segment id="375">", parou</segment>
    <segment id="376">, desconfiado.  John Lennon em Nova York</segment>
    <segment id="377">, por Bob Gruen   novamente         de   de  de  representando um</segment>
    <segment id="378">Foi quando o sujeito lhe mostrou a manchete do Jornal da Tarde: "</segment>
    <segment id="379">Tiros.</segment>
    <segment id="380">Lennon Cai.</segment>
    <segment id="381">Um Beatle Vai Morrer".</segment>
    <segment id="382">Mallagoni custou a acreditar.</segment>
    <segment id="383">"</segment>
    <segment id="384">Impossível"</segment>
    <segment id="385">, repetia para si mesmo.</segment>
    <segment id="386">Só sese convenceu da tragédia quando ligou para Nova York e</segment>
    <segment id="387">, depois de muito tempo</segment>
    <segment id="388">, conseguiu falar com Omena.</segment>
    <segment id="389">"É verdade</segment>
    <segment id="390">, sim.</segment>
    <segment id="391">Mataram o Lennon!</segment>
    <segment id="392">", confirmou o amigo do outro lado da linha.</segment>
    <segment id="393">Naquele dia</segment>
    <segment id="394">, a lojinha Revolution não abriu.</segment>
    <segment id="395">Mallagoli voltou para casa</segment>
    <segment id="396">, arrumou suas coisas e pegou o primeiro avião para Nova York.</segment>
    <segment id="397">Ainda deu tempo de ouvir a mãe reclamar: "</segment>
    <segment id="398">Quero ver</segment>
    <segment id="399">sese, no dia do meu enterro</segment>
    <segment id="400">, você vai chorar assim.</segment>
    <segment id="401">"     Mallagoli chegou a Nova York na manhã do dia 10.</segment>
    <segment id="402">Do JFK</segment>
    <segment id="403">, seguiu direto para o Dakota.</segment>
    <segment id="404">Os fãs reunidos na frente do edifício não falavam de outra coisa.</segment>
    <segment id="405">Mark Chapman</segment>
    <segment id="406">, o autor dos disparos</segment>
    <segment id="407">, não passava de um bode expiatório.</segment>
    <segment id="408">Segundo os conspiracionistas</segment>
    <segment id="409">, a CIA</segment>
    <segment id="410">, a agência de inteligência americana</segment>
    <segment id="411">, e o FBI</segment>
    <segment id="412">, a polícia federal</segment>
    <segment id="413">, estariam por trás do assassinato de Lennon</segment>
    <segment id="414">, considerado uma influência política perigosa.</segment>
    <segment id="415">A teoria virou livro</segment>
    <segment id="416">, "Who Killed John Lennon"</segment>
    <segment id="417">, escrito pelo jornalista britânico Fenton Bresler</segment>
    <segment id="418">, masmas nunca foi comprovada.</segment>
    <segment id="419">Naquele mesmo dia</segment>
    <segment id="420">, o corpo foi cremado no Cemitério de Ferncliff</segment>
    <segment id="421">, em Hartsdale</segment>
    <segment id="422">, em Nova York.</segment>
    <segment id="423">No Central Park</segment>
    <segment id="424">, a viúva Yoko Ono pediu à multidão que fizesse dez minutos de silêncio.</segment>
    <segment id="425">"</segment>
    <segment id="426">Quando tocaram "Imagine"</segment>
    <segment id="427">, não resisti.</segment>
    <segment id="428">Foi aí que desabei no choro.</segment>
    <segment id="429">Nunca chorei tanto na vida"</segment>
    <segment id="430">, relata.</segment>
  </rst>
</analysis>