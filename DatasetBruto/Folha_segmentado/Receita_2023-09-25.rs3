  <rst>
    <segment id="1">Finalmente com a cozinha equipada no meu lar provisório em Londres</segment>
    <segment id="2">, bora fazer umas comidas.</segment>
    <segment id="3">As receitas que vou apresentar nesse período têm dois limitadores: a disponibilidade de ingredientes e a estrutura da cozinha.</segment>
    <segment id="4">Quanto ao primeiro fator</segment>
    <segment id="5">, ele mais expande do que retrai os limites.</segment>
    <segment id="6">Os supermercados de Londres têm uma variedade fabulosa de alimentos de toda parte do mundo.</segment>
    <segment id="7">Só não é fácil encontrar aqui ingredientes que a gente dá de barato no Brasil</segment>
    <segment id="8">, como</segment>
    <segment id="9">como farinha de mandioca ou mamão.</segment>
    <segment id="10">Carne de porco com arroz e acelga chinesa - Marcos Nogueira/FolhapressTem muita coisa que não</segment>
    <segment id="11">sese vê no Brasil: ruibarbo</segment>
    <segment id="12">, carne de veado</segment>
    <segment id="13">, uns tubérculos diferentes</segment>
    <segment id="14">, tudo quanto é especiaria indiana.</segment>
    <segment id="15">Vou evitar esses ingredientes</segment>
    <segment id="16">, claro</segment>
    <segment id="17">, masmas quero também dar uma noção das possibilidades culinárias que Londres me oferece.</segment>
    <segment id="18">Aqui pertinho tem uma mercearia oriental incrível –um pouco menos incrível do que os mercados da Liberdade</segment>
    <segment id="19">, porém</segment>
    <segment id="20">porém duas a quadras de casa (em São Paulo</segment>
    <segment id="21">, preciso de metrô ou ônibus para ir ao centro).</segment>
    <segment id="22">Minha filha voltou de lá com uma coisa que eu nunca havia usado para cozinhar: uma pasta chinesa de soja preta e alho.</segment>
    <segment id="23">Eu havia pedido missô</segment>
    <segment id="24">, masmas sabe</segment>
    <segment id="25">comocomo são as crianças (ela tem 28 anos e veio cursar mestrado aqui).</segment>
    <segment id="26">Receitas do MarcãoMais    novamente         de   de  de  representando um  Bom</segment>
    <segment id="27">, essa pasta é facilmente encontrada nos mercados orientais do Brasil</segment>
    <segment id="28">, eu pesquisei.</segment>
    <segment id="29">Para quem mora em cidades menores ou sem uma comunidade asiática numericamente relevante</segment>
    <segment id="30">, dá para pedir pela internet.</segment>
    <segment id="31">O rótulo vem em inglês: "black bean and garlic sauce".</segment>
    <segment id="32">A única substituição possível é a pasta de soja preta sem o alho</segment>
    <segment id="33">, que você adiciona por conta própria.</segment>
    <segment id="34">Você pode omitir ou usar missô</segment>
    <segment id="35">, masmas o resultado será bem diferente.</segment>
    <segment id="36">Colunas e BlogsReceba no seu email uma seleção de colunas e blogs da Folha</segment>
    <segment id="37">; exclusiva para assinantes.</segment>
    <segment id="38">Carregando...</segment>
    <segment id="39">A receita eu tirei da minha cabeça</segment>
    <segment id="40">, simples demais</segment>
    <segment id="41">, com os ingredientes restantes bem corriqueiros: carne de porco</segment>
    <segment id="42">, shoyu</segment>
    <segment id="43">, broto de feijão</segment>
    <segment id="44">, cebola e cebolinha.</segment>
    <segment id="45">Para acompanhar</segment>
    <segment id="46">, arroz branco e acelga chinesa (também chamada bok choy ou pak choi).</segment>
    <segment id="47">Tudo muito fácil e</segment>
    <segment id="48">, não menos importante</segment>
    <segment id="49">, rápido.</segment>
    <segment id="50">Leva no máximo 15 minutos</segment>
    <segment id="51">, tempo em que você também cozinha o arroz.</segment>
    <segment id="52">Importante: tanto a pasta de soja quanto o shoyu são bem salgados.</segment>
    <segment id="53">Não use sal e</segment>
    <segment id="54">, para equilibrar</segment>
    <segment id="55">, prepare o arroz sem tempero algum.</segment>
    <segment id="56">MenuA newsletter de gastronomia exclusiva para assinantes da Folha no plano Digital PremiumCarregando...</segment>
    <segment id="57">Quanto às limitações da cozinha</segment>
    <segment id="58">, moro num apartamento de dois quartos dentro de uma residência estudantil.</segment>
    <segment id="59">É tudo propositalmente pouco ventilado</segment>
    <segment id="60">, para reter calor.</segment>
    <segment id="61">Tem alarme de incêndio</segment>
    <segment id="62">, que dispara quando o ambiente fica enfumaçado.</segment>
    <segment id="63">Foi o que aconteceu quando eu fritava o porco para este prato.</segment>
    <segment id="64">Bateram na porta</segment>
    <segment id="65">, fui ver e era o segurança da moradia querendo saber</segment>
    <segment id="66">sese estava tudo bem.</segment>
    <segment id="67">Resumo da ópera: não esperem mais receitas de carne frita enquanto eu estiver em Londres.    Porco com soja preta e broto de feijão</segment>
    <segment id="68">Rendimento: 4 porções Dificuldade: fácil  Ingredientes   700 g de copa-lombo em bifes 1 cebola em pétalas 1 colher (sopa) de óleo 2 colheres (sopa) de pasta de soja preta e alho 1 colher (sopa) de shoyu 100 g de broto de feijão (moyashi)</segment>
    <segment id="69">Cebolinha verde a gosto Sugestão de acompanhamento: arroz branco e acelga chinesa refogada</segment>
    <segment id="70">Modo de fazer</segment>
    <segment id="71">Aqueça uma frigideira funda (de preferência</segment>
    <segment id="72">, um wok) com o óleo</segment>
    <segment id="73">, em fogo alto.</segment>
    <segment id="74">Frite os bifes de porco sem os sobrepor (</segment>
    <segment id="75">sese necessário</segment>
    <segment id="76">, fala duas bateladas)</segment>
    <segment id="77">, dourando-os de ambos os lados.</segment>
    <segment id="78">Reserve a carne Frite a cebola até ficar macia e levemente tostada.</segment>
    <segment id="79">Corte a carne em tiras e a devolva à frigideira</segment>
    <segment id="80">Junte</segment>
    <segment id="81">a pasta de soja</segment>
    <segment id="82">, o shoyu e um copo d’água</segment>
    <segment id="83">.</segment>
    <segment id="84">Espere o molho ferver e espessar ligeiramente.</segment>
    <segment id="85">Junte o broto de feijão e a cebolinha</segment>
    <segment id="86">, mexendo até aquecer Desligue e sirva imediatamente</segment>
    <segment id="87">, com arroz e acelga chinesa</segment>
  </rst>
</analysis>