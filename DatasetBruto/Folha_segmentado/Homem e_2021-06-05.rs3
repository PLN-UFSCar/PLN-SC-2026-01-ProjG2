  <rst>
    <segment id="1">A polícia investiga as circunstâncias em que um homem de origem espanhola e uma menina</segment>
    <segment id="2">, de 6 anos</segment>
    <segment id="3">, caíram do 17º andar de um hotel no centro de São Paulo</segment>
    <segment id="4">, morrendo na calçada do edifício</segment>
    <segment id="5">, por volta das 5h deste sábado (5).</segment>
    <segment id="6">Uma carta de despedida foi encontrada em um caderno</segment>
    <segment id="7">, no quarto em que os dois estavam hospedados desde o último dia 31.</segment>
    <segment id="8">Não foi informado qual seria o grau de parentesco entre ambos.</segment>
    <segment id="9">A polícia agora investiga o que trouxe a dupla até a capital paulista e o que teria motivado o</segment>
    <segment id="10">casocaso</segment>
    <segment id="11">, por ora registrado</segment>
    <segment id="12">comocomo suicídio</segment>
    <segment id="13">, para o adulto</segment>
    <segment id="14">, e homicídio</segment>
    <segment id="15">, no caso</segment>
    <segment id="16">caso da criança.</segment>
    <segment id="17">Polícia Militar faz ronda pela região central de São Paulo - Ronny Santos - 24.set.20/Folhapress  Acredita-</segment>
    <segment id="18">sese que o homem saltou segurando a menina</segment>
    <segment id="19">, por conta da dinâmica da cena do crime relatada por policiais militares que chegaram primeiro ao local da ocorrência.</segment>
    <segment id="20">A investigação vai verificar em quais circunstâncias a criança estava no momento da queda (inconsciente</segment>
    <segment id="21">, desperta ou já morta).</segment>
    <segment id="22">No interior do quarto do hotel</segment>
    <segment id="23">, segundo boletim de ocorrência</segment>
    <segment id="24">, não foram encontrados sinais aparentes de violência.</segment>
    <segment id="25">Foram apreendidos documentos do homem e da criança</segment>
    <segment id="26">, como</segment>
    <segment id="27">como passaporte de origem espanhola</segment>
    <segment id="28">, além de outros documentos de identificação.</segment>
    <segment id="29">O caso</segment>
    <segment id="30">caso foi registrado e é investigado pelo 2º DP (Bom Retiro).</segment>
    <segment id="31">Polícia de Nova York nas ruas de SP?</segment>
    <segment id="32">novamente         de   de  de  representando um</segment>
  </rst>
