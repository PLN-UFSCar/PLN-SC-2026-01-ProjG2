  <rst>
    <segment id="1">De 1º a 6 de dezembro acontece a 6ª edição do Brasil Eco Fashion Week</segment>
    <segment id="2">, a semana de moda sustentável brasileira</segment>
    <segment id="3">, que foca em marcas preocupadas com esse diferencial.</segment>
    <segment id="4">Esta edição conta com a presença dos estilistas indígenas Weena Tikuna e Sioduhi.</segment>
    <segment id="5">Modelo baiano de origem indígena</segment>
    <segment id="6">Noah Alef desfila pela grife italiana DSQuared2 na Semana de Moda de Milão - Divulgação"Este evento é o primeiro a abraçar a causa e nos colocar</segment>
    <segment id="7">comocomo protagonistas da nossa própria arte</segment>
    <segment id="8">, sem apropriação cultural</segment>
    <segment id="9">, aldeando as passarelas.</segment>
    <segment id="10">Mostrando nossa luta.</segment>
    <segment id="11">Mostrando nosso estilo.</segment>
    <segment id="12">Quero muito que tenha mais indígenas na moda em outros eventos também" diz Weena Tikuna.</segment>
    <segment id="13">Com doçura e coragem</segment>
    <segment id="14">, Weena mostra que os povos indígenas podem estar onde quiserem e traz a preocupação de fazer uma moda que</segment>
    <segment id="15">sese importe com o meio ambiente</segment>
    <segment id="16">, com o social e com o nosso planeta.</segment>
    <segment id="17">A indústria da moda é a segunda mais poluente do mundo</segment>
    <segment id="18">, perdendo apenas para a de combustíveis fósseis.</segment>
    <segment id="19">O impacto no meio ambiente passa pela extração de matérias-primas</segment>
    <segment id="20">, o consumo de energia e água</segment>
    <segment id="21">, a emissão de carbono e o descarte de resíduos.</segment>
    <segment id="22">Consequência da lógica consumista capitalista</segment>
    <segment id="23">, a moda vem produzindo cada vez mais lixo</segment>
    <segment id="24">, com 80% dos têxteis sendo descartados anualmente</segment>
    <segment id="25">, e parece não</segment>
    <segment id="26">sese importar com suas consequências.</segment>
    <segment id="27">Além disso</segment>
    <segment id="28">, muitas das roupas de fast fashion são feitas com produtos derivados do petróleo.</segment>
    <segment id="29">A indústria da moda é responsável por 20% do desperdício total de água mundialmente</segment>
    <segment id="30">, e sua produção emite 8% dos gases de efeito estufa.</segment>
    <segment id="31">É importante citar que o impacto é enorme no social.</segment>
    <segment id="32">No mundo inteiro</segment>
    <segment id="33">, pessoas vivem em situação análoga à escravidão para a produção de roupas.</segment>
    <segment id="34">Marcas continuam produzindo peças com um alto custo humano que não é visto por quem paga a conta na hora de</segment>
    <segment id="35">sese vestir.</segment>
    <segment id="36">Veja marcas de moda que prezam pela diversidadeMais    novamente         de   de  de  representando um  Mas a conta chegará</segment>
    <segment id="37">, e a mudança do clima deve ser uma preocupação de todos os setores.</segment>
    <segment id="38">A moda é uma indústria poderosa</segment>
    <segment id="39">, pois</segment>
    <segment id="40">pois tem o poder de dizer o que deve ou não ser consumido.</segment>
    <segment id="41">A moda produz tendência e estilo de vida.</segment>
    <segment id="42">Mas não há tendência maior que viver em um mundo habitável e justo social e ambientalmente.</segment>
    <segment id="43">No entanto</segment>
    <segment id="44">, para que</segment>
    <segment id="45">para que uma mudança real aconteça de fato é preciso consciência e transformação de quem consome.</segment>
    <segment id="46">É necessário refletir sobre o processo do que estamos vestindo e as consequências disso na vida de muitas pessoas e no futuro do nosso planeta.</segment>
    <segment id="47">É preciso pensar em novas formas de consumir e de produzir moda.</segment>
    <segment id="48">É preciso valorizar quem trabalha de forma sustentável e</segment>
    <segment id="49">sese importa com as pessoas.</segment>
    <segment id="50">Devemos pensar em uma produção sem plástico</segment>
    <segment id="51">, com matéria orgânica</segment>
    <segment id="52">, materiais biodegradáveis naturais e reciclados.</segment>
    <segment id="53">Precisamos consumir menos</segment>
    <segment id="54">, reutilizar e reciclar mais.</segment>
  </rst>
</analysis>