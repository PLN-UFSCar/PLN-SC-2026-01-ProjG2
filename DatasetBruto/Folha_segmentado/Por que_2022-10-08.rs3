  <rst>
    <segment id="1">Da Silva</segment>
    <segment id="2">, Ferreira</segment>
    <segment id="3">, Pereira.</segment>
    <segment id="4">Esses sobrenomes</segment>
    <segment id="5">, muito populares no Brasil e em Portugal</segment>
    <segment id="6">, agora também são os mais comuns numa região da Suíça.</segment>
    <segment id="7">Na parte do país em que</segment>
    <segment id="8">sese fala francês</segment>
    <segment id="9">, eles aparecem nos três primeiros lugares.</segment>
    <segment id="10">Da Silva ocupa a primeira posição</segment>
    <segment id="11">, no nome de 10.220 pessoas.</segment>
    <segment id="12">Entre elas</segment>
    <segment id="13">, a brasileira Dulcimara Aparecida da Silva</segment>
    <segment id="14">, que ensina português para crianças e adultos.</segment>
    <segment id="15">A mineira de Boa Esperança</segment>
    <segment id="16">, que já morou na França</segment>
    <segment id="17">, na Itália</segment>
    <segment id="18">, na República Tcheca e em Portugal</segment>
    <segment id="19">, está há dez anos em Genebra e tem muita familiaridade com o sobrenome que</segment>
    <segment id="20">sese tornou o mais comum na Suíça romanda.</segment>
    <segment id="21">É que os dois avôs dela</segment>
    <segment id="22">, por parte de pai e mãe —o seu Joaquim e o seu Antônio—</segment>
    <segment id="23">, eram "da Silva".</segment>
    <segment id="24">Homem ergue bandeira da Suíça em frente ao Parlamento em Berna - Fabrice Coffrini - 19.set.22/AFPO sobrenome de Dulcimara também é o mais comum nos cantões de Vaud</segment>
    <segment id="25">, Genebra</segment>
    <segment id="26">, Friburgo e Neuchâtel.</segment>
    <segment id="27">Esses dados foram divulgados pela primeira vez pelo OFS</segment>
    <segment id="28">, o Departamento Federal de Estatística da Suíça</segment>
    <segment id="29">, e chamaram a atenção da imprensa local e de muita gente.</segment>
    <segment id="30">"</segment>
    <segment id="31">Eu fiquei muito surpresa.</segment>
    <segment id="32">Não sabia que existia isso na Suíça</segment>
    <segment id="33">, uma classificação dos sobrenomes —e</segment>
    <segment id="34">, para o meu espanto</segment>
    <segment id="35">, o meu é o que tem mais.</segment>
    <segment id="36">Para mim</segment>
    <segment id="37">, é uma honra</segment>
    <segment id="38">, porque</segment>
    <segment id="39">porque no Brasil mais da metade da população é 'da Silva'.</segment>
    <segment id="40">É um sobrenome supercomum.</segment>
    <segment id="41">Então, isso não é ser importante.</segment>
    <segment id="42">Na minha vida toda</segment>
    <segment id="43">, 'da Silva' não era um sobrenome de peso"</segment>
    <segment id="44">, diz.</segment>
    <segment id="45">À RFI, a brasileira conta</segment>
    <segment id="46">, rindo</segment>
    <segment id="47">, o que sentiu quando o marido chegou em casa falando da pesquisa: "</segment>
    <segment id="48">Eu fiquei extremamente orgulhosa.</segment>
    <segment id="49">O mais conhecido</segment>
    <segment id="50">, o maior número de pessoas que têm esse sobrenome na Suíça!</segment>
    <segment id="51">Então, é uma honra.</segment>
    <segment id="52">Não só no Brasil</segment>
    <segment id="53">, agora na Suíça também".</segment>
    <segment id="54">A professora acha interessante a pesquisa por "valorizar os estrangeiros</segment>
    <segment id="55">, a sua origem".</segment>
    <segment id="56">Dulcimara diz também que conhece muitos portugueses e brasileiros "da Silva" —</segment>
    <segment id="57">"comocomo o Ayrton" Senna da Silva— que moram na Suíça.</segment>
    <segment id="58">China, terra do meioReceba no seu email os grandes temas da China explicados e contextualizados</segment>
    <segment id="59">; exclusiva para assinantes.</segment>
    <segment id="60">Carregando...</segment>
    <segment id="61">No total</segment>
    <segment id="62">, 17 dos 20 sobrenomes mais comuns na Suíça francesa são de Portugal e do Brasil</segment>
    <segment id="63">; só Favre (6ª posição)</segment>
    <segment id="64">, Martin (8ª) e Muller (12ª) são do país.</segment>
    <segment id="65">Nos cinco primeiros lugares aparecem Da Silva (10.220)</segment>
    <segment id="66">, Ferreira (7.326)</segment>
    <segment id="67">, Pereira (6.537)</segment>
    <segment id="68">, Dos Santos (6.091) e Rodrigues (5.250).</segment>
    <segment id="69">Gomes, Fernandes</segment>
    <segment id="70">, Lopes</segment>
    <segment id="71">, Martins</segment>
    <segment id="72">, Oliveira</segment>
    <segment id="73">, Alves e somente Silva são outros que também dão as caras.</segment>
    <segment id="74">Apelidos (ou sobrenomes) portugueses</segment>
    <segment id="75">Uma das razões que explicam a predominância desses sobrenomes é que na Suíça francesa há muitos portugueses: mais de 150 mil</segment>
    <segment id="76">, o que significa 7% da população total e 22% da população estrangeira.</segment>
    <segment id="77">A arquiteta Maria Inês de Jesus Ferreira é uma delas.</segment>
    <segment id="78">"</segment>
    <segment id="79">Não tinha ideia de que [o sobrenome] era dos mais comuns na Suíça.</segment>
    <segment id="80">Em Portugal</segment>
    <segment id="81">, realmente</segment>
    <segment id="82">, é um nome de família que existe bastante.</segment>
    <segment id="83">Mas dizemos que toda gente é 'da Silva' em Portugal"</segment>
    <segment id="84">, diz.</segment>
    <segment id="85">A arquiteta achou curioso quando soube que o sobrenome era tão popular.</segment>
    <segment id="86">"</segment>
    <segment id="87">Não tinha mesmo noção de haver assim tanta gente.</segment>
    <segment id="88">Até porque</segment>
    <segment id="89">porque eu própria conheço só duas</segment>
    <segment id="90">, três pessoas.</segment>
    <segment id="91">"</segment>
    <segment id="92">Alpes suíços na região de BernaMais    novamente         de   de  de  representando um</segment>
    <segment id="93">O órgão responsável pela divulgação dos dados</segment>
    <segment id="94">, no entanto</segment>
    <segment id="95">, lembra que não é</segment>
    <segment id="96">porque</segment>
    <segment id="97">porque uma pessoa</segment>
    <segment id="98">sese chama "</segment>
    <segment id="99">Da Silva" que ela é necessariamente portuguesa ou brasileira —e</segment>
    <segment id="100">, por outro lado</segment>
    <segment id="101">, alguém que</segment>
    <segment id="102">sese chame "</segment>
    <segment id="103">Favre</segment>
    <segment id="104">"</segment>
    <segment id="105">pode muito bem ser.</segment>
    <segment id="106">A instituição também informou que só foi levado em conta o primeiro sobrenome de cada um.</segment>
    <segment id="107">Por exemplo</segment>
    <segment id="108">, uma pessoa com os sobrenomes "da Silva Ferreira Pereira" foi contada</segment>
    <segment id="109">comocomo sendo somente "da Silva".</segment>
    <segment id="110">Os sobrenomes da brasileira Amanda Pereira Santos</segment>
    <segment id="111">, que é de Aracaju</segment>
    <segment id="112">masmas mora há 15 anos na Suíça</segment>
    <segment id="113">, também aparecem nas listas dos mais populares.</segment>
    <segment id="114">"</segment>
    <segment id="115">Fiquei bastante surpresa e me perguntando</segment>
    <segment id="116">comocomo isso é visto pelos suíços —</segment>
    <segment id="117">sese de forma positiva ou não.</segment>
    <segment id="118">Não sei</segment>
    <segment id="119">sese eles tomam isso</segment>
    <segment id="120">comocomo uma espécie de invasão.</segment>
    <segment id="121">Eu tenho certa curiosidade em saber esse ponto de vista"</segment>
    <segment id="122">, afirma.</segment>
    <segment id="123">Os mais comuns na Suíça toda  Levando em conta a Suíça</segment>
    <segment id="124">comocomo um todo</segment>
    <segment id="125">, o nome Muller é o mais numeroso (53.686 pessoas)</segment>
    <segment id="126">, seguido por Meier (33.054) e Schmid (30.534).</segment>
    <segment id="127">Em nível nacional</segment>
    <segment id="128">, Da Silva aparece em 10º lugar (16.990).</segment>
    <segment id="129">Segundo dados oficiais</segment>
    <segment id="130">, a população suíça hoje é de 8</segment>
    <segment id="131">,7 milhões de pessoas.</segment>
    <segment id="132">A imprensa local destacou os resultados da pesquisa</segment>
    <segment id="133">, mostrando "o surgimento de uma tendência: a predominância de sobrenomes portugueses na Suíça francesa".</segment>
  </rst>
</analysis>