  <rst>
    <segment id="1">Candidato a governador do campo bolsonarista no Ceará</segment>
    <segment id="2">, o deputado federal Capitão Wagner (União Brasil) recebeu o apoio do Solidariedade</segment>
    <segment id="3">, que no plano nacional está alinhado a Luiz Inácio Lula da Silva (PT).</segment>
    <segment id="4">O candidato a governador do Ceará Capitão Wagner</segment>
    <segment id="5">, do União Brasil - DivulgaçãoWagner</segment>
    <segment id="6">, que vem liderando algumas pesquisas</segment>
    <segment id="7">, já tinha o apoio de Avante</segment>
    <segment id="8">, PTB e Pros.</segment>
    <segment id="9">Ele vem</segment>
    <segment id="10">sese aproveitando de uma divisão no campo da esquerda</segment>
    <segment id="11">, que governa o estado desde 2007.</segment>
    <segment id="12">O PDT vive uma crise interna entre os defensores da reeleição da atual governadora</segment>
    <segment id="13">, Izolda Cela</segment>
    <segment id="14">, e do ex-prefeito de Fortaleza Roberto Cláudio.</segment>
    <segment id="15">O apoio do Solidariedade a Wagner e Lula é parte da diretriz do presidente nacional do partido</segment>
    <segment id="16">, Paulinho da Força</segment>
    <segment id="17">, de liberar os diretórios estaduais para decidirem qual o melhor palanque.</segment>
    <segment id="18">Em São Paulo</segment>
    <segment id="19">, a legenda vai</segment>
    <segment id="20">sese coligar ao governador Rodrigo Garcia (PSDB).</segment>
  </rst>
