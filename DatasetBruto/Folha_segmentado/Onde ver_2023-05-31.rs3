  <rst>
    <segment id="1">A atriz e produtora Mary Tyler Moore talvez tenha sido a mulher mais importante de toda a história da TV dos EUA.</segment>
    <segment id="2">Ao longo de mais de 60 anos de carreira</segment>
    <segment id="3">, ela encarnou dois papéis icônicos em séries de humor: Laura Petrie</segment>
    <segment id="4">, em "The Dick Van Dyke</segment>
    <segment id="5">Show</segment>
    <segment id="6">", nos anos 1960</segment>
    <segment id="7">, e, na década seguinte</segment>
    <segment id="8">, em "The Mary Tyler Moore Show"</segment>
    <segment id="9">, Mary Richards</segment>
    <segment id="10">, que se</segment>
    <segment id="11">se tornou um símbolo feminista.</segment>
    <segment id="12">Mary Tyler Moore na série &amp;quot</segment>
    <segment id="13">;Mary Tyler Moore Show&amp;quot</segment>
    <segment id="14">; - Arquivo CBSMas sua vida pessoal foi marcada por dramas</segment>
    <segment id="15">, como</segment>
    <segment id="16">como o suicídio de um filho.</segment>
    <segment id="17">Vencedora de sete prêmios</segment>
    <segment id="18">Emmy, Moore é o assunto de "Mary Tyler Moore: A Dama da TV</segment>
    <segment id="19">"</segment>
    <segment id="20">documentário exclusivo da plataforma.  HBO Max</segment>
    <segment id="21">, 12 anos   Rita Lee:</segment>
    <segment id="22">Outra Autobiografia – o Podcast</segment>
    <segment id="23">A apresentadora Astrid Fontenelle e o jornalista Guilherme Samora comandam esta série em áudio</segment>
    <segment id="24">, que traz conteúdos inéditos e complementares ao livro recém-lançado em que a cantora e compositora conta sua experiência com o câncer.</segment>
    <segment id="25">Um novo episódio toda segunda</segment>
    <segment id="26">; serão cinco ao todo.</segment>
    <segment id="27">As modas de Rita LeeMais    novamente         de   de  de  representando um  Plataformas de áudio</segment>
    <segment id="28">, grátis</segment>
    <segment id="29">O Culto Secreto</segment>
    <segment id="30">A primeira minissérie da plataforma produzida na Austrália é baseada no livro "In The Clearing"</segment>
    <segment id="31">, de J. P. Pomare</segment>
    <segment id="32">, e fala de uma religião obscura que sequestra crianças e as submete a lavagem cerebral.</segment>
    <segment id="33">Com Miranda Otto</segment>
    <segment id="34">, que estrelou o filme brasileiro "Flores Raras".  Star+</segment>
    <segment id="35">, 14 anos</segment>
    <segment id="36">Tin e Tina</segment>
    <segment id="37">Neste filme de terror espanhol inédito nos cinemas brasileiros</segment>
    <segment id="38">, um jovem casal que não pode ter filhos adota um par de gêmeos órfãos.</segment>
    <segment id="39">Mas as crianças são fanáticas religiosas</segment>
    <segment id="40">, o que logo</segment>
    <segment id="41">sese torna um problema.</segment>
    <segment id="42">Netflix</segment>
    <segment id="43">, 16 anos</segment>
    <segment id="44">Tio Drew</segment>
    <segment id="45">Um jogador de basquete aposentado é convidado a disputar um torneio.</segment>
    <segment id="46">Ele aceita</segment>
    <segment id="47">, com a condição de chamar também seus antigos companheiros da NBA</segment>
    <segment id="48">, vividos por astros</segment>
    <segment id="49">comocomo Shaquille O’Neal e Chris Webber.</segment>
    <segment id="50">&amp;#039;Tio Drew&amp;#039</segment>
    <segment id="51">;Mais</segment>
    <segment id="52">novamente         de   de  de  representando um  Telecine Fun</segment>
    <segment id="53">, 22h, 12 anos</segment>
    <segment id="54">Da Mood</segment>
    <segment id="55">Nesta série portuguesa</segment>
    <segment id="56">, um professor insatisfeito resolve mudar de vida montando uma boy band</segment>
    <segment id="57">, e pede ajuda a um amigo</segment>
    <segment id="58">, que é agente artístico</segment>
    <segment id="59">, para encontrar os integrantes.</segment>
    <segment id="60">Um novo episódio toda quinta.  Cultura</segment>
    <segment id="61">, 23h, 16 anos</segment>
