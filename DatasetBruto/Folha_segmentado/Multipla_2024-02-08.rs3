  <rst>
    <segment id="1">Prestes a completar 50 anos</segment>
    <segment id="2">, a Multiplan</segment>
    <segment id="3">, gigante dos shopping centers</segment>
    <segment id="4">, registrou um lucrou recorde de R$ 1 bilhão no ano passado.</segment>
    <segment id="5">"</segment>
    <segment id="6">Tivemos o melhor resultado da história no ano passado"</segment>
    <segment id="7">, disse Armando d'Almeida Neto</segment>
    <segment id="8">, vice-presidente financeiro e de relações com investidores.</segment>
    <segment id="9">Foto do Morumbi Shopping</segment>
    <segment id="10">, da rede Multiplan</segment>
    <segment id="11">, em São Paulo - Mathilde Missioneiro/Folhapress - FolhapressO executivo afirma que</segment>
    <segment id="12">, além de distribuir o maior retorno da história para seus acionistas</segment>
    <segment id="13">, a Multiplan também reduziu seu endividamento.</segment>
    <segment id="14">Hoje, a dívida é de $ 3</segment>
    <segment id="15">,2 bilhões.</segment>
    <segment id="16">No ano anterior da pandemia</segment>
    <segment id="17">, o lucro da empresa tinha sido de R$ 471 milhões.</segment>
    <segment id="18">Com os resultados de 2023</segment>
    <segment id="19">, a empresa ampliou sua fatia no mercado de 10</segment>
    <segment id="20">,4%, em 2022</segment>
    <segment id="21">, para 11</segment>
    <segment id="22">,3%.</segment>
    <segment id="23">"</segment>
    <segment id="24">São diversos fatores que conjugados acabaram gerando o resultado dessa relevância"</segment>
    <segment id="25">, diz Neto.</segment>
    <segment id="26">O vice-presidente da companhia também cita que</segment>
    <segment id="27">, em 2023</segment>
    <segment id="28">, foram trocadas 584 lojas nos 20 shoppings do grupo no país</segment>
    <segment id="29">, o equivalente a mais de 80 mil metros quadrados de estabelecimentos novos.</segment>
    <segment id="30">"</segment>
    <segment id="31">Trouxemos novidades</segment>
    <segment id="32">, novas marcas</segment>
    <segment id="33">, novas operações"</segment>
    <segment id="34">, disse.</segment>
    <segment id="35">Todos os shoppings tiveram crescimento nas vendas ano passado</segment>
    <segment id="36">, que, somados</segment>
    <segment id="37">, chegaram a R$ 21</segment>
    <segment id="38">,9 bilhões.</segment>
    <segment id="39">Em janeiro deste ano</segment>
    <segment id="40">, houve um crescimento nas vendas de 8</segment>
    <segment id="41">,9% em relação ao mesmo período de 2023.</segment>
    <segment id="42">Com Diego</segment>
    <segment id="43">Felix e Matheus Teixeira</segment>
  </rst>
</analysis>