  <rst>
    <segment id="1">Esta cova em que estás</segment>
    <segment id="2">, com palmos medida</segment>
    <segment id="3">, é a conta menor que tiraste em vida</segment>
    <segment id="4">, é de bom tamanho</segment>
    <segment id="5">, nem largo</segment>
    <segment id="6">, nem fundo</segment>
    <segment id="7">, é a parte que te cabe deste latifúndio</segment>
    <segment id="8">, não é cova grande</segment>
    <segment id="9">, é cova medida</segment>
    <segment id="10">, é a terra que querias ver dividida...</segment>
    <segment id="11">Alô, povão</segment>
    <segment id="12">, agora é fé!</segment>
    <segment id="13">No mesmo dia que o arqui-inimigo Flamengo (com ajuda escandalosa do lixo do VAR) virou líder</segment>
    <segment id="14">, o Vasco ficou no 0 a 0 na Neo Química Arena e caiu pela quarta vez à Série B!</segment>
    <segment id="15">Corintiano Ramiro tenta</segment>
    <segment id="16">sese livrar da marcação da defesa vascaína no empate sem gols na Neo Química Arena - Rodrigo Coca/Ag.</segment>
    <segment id="17">CorinthiansNão foi desta vez</segment>
    <segment id="18">, na quinta visita a Itaquera</segment>
    <segment id="19">, que o Vasco fez seu primeiro gol na arena.</segment>
    <segment id="20">O primeiro ponto</segment>
    <segment id="21">, no entanto</segment>
    <segment id="22">, não foi suficiente.</segment>
    <segment id="23">A equipe caiu!</segment>
    <segment id="24">Não tem lixo escandaloso do VAR capaz de fazer</segment>
    <segment id="25">, além do Vasco vencer o Goiás e o Fortaleza perder para o Fluminense</segment>
    <segment id="26">, o time de Vanderlei</segment>
    <segment id="27">Luxemburgo tirar 12 gols de desvantagem no saldo em relação ao Fortaleza.</segment>
    <segment id="28">O jogo?</segment>
    <segment id="29">Não aconteceu nada digno de nota no 0 a 0!</segment>
    <segment id="30">Em 2007</segment>
    <segment id="31">, na penúltima rodada</segment>
    <segment id="32">, quando perdeu para o Vasco no Pacaembu e encaminhou o rebaixamento (confirmado no Olímpico)</segment>
    <segment id="33">, o Corinthians</segment>
    <segment id="34">, do técnico Nelsinho Baptista</segment>
    <segment id="35">, atuou com Felipe</segment>
    <segment id="36">; Fábio Ferreira</segment>
    <segment id="37">, Fábio Braz e Betão</segment>
    <segment id="38">;</segment>
    <segment id="39">Amaral (Héverton)</segment>
    <segment id="40">, Bruno Octávio</segment>
    <segment id="41">, Carlos Alberto (Vampeta)</segment>
    <segment id="42">, Dentinho (Wilson) e Éverton Ribeiro</segment>
    <segment id="43">; Arce e Lulinha.</segment>
    <segment id="44">Neste domingo (21)</segment>
    <segment id="45">, na Neo Química Arena</segment>
    <segment id="46">, na confirmação da quarta queda cruzmaltina à Série Baba</segment>
    <segment id="47">, Vanderlei Luxemburgo escalou Fernando Miguel</segment>
    <segment id="48">; Léo Matos</segment>
    <segment id="49">, Ricardo Graça</segment>
    <segment id="50">, Castán</segment>
    <segment id="51">, Henrique</segment>
    <segment id="52">; Bruno Gomes</segment>
    <segment id="53">, Andrey (Juninho)</segment>
    <segment id="54">, Carlinhos (Marcos Júnior)</segment>
    <segment id="55">, Yago Pikachu (Gabriel Pec)</segment>
    <segment id="56">;</segment>
    <segment id="57">Talles Magno (Ygor Catatau) e Cano (Tiago Reis).  Fica a pergunta: qual time é pior?</segment>
    <segment id="58">Timão-2007 ou Vasco-2020?</segment>
    <segment id="59">Certeza mesmo é que o Corinthians-2008 era muito mais forte do que será o Vasco 2021.</segment>
    <segment id="60">O maior problema vascaíno nem é esse.</segment>
    <segment id="61">É saber</segment>
    <segment id="62">sese a equipe será melhor que Cruzeiro</segment>
    <segment id="63">, Coritiba</segment>
    <segment id="64">, Botafogo</segment>
    <segment id="65">, Guarani</segment>
    <segment id="66">, Ponte Preta</segment>
    <segment id="67">, Brasil-RS</segment>
    <segment id="68">, Avaí</segment>
    <segment id="69">, Brusque</segment>
    <segment id="70">, Operário</segment>
    <segment id="71">, Londrina</segment>
    <segment id="72">, Náutico</segment>
    <segment id="73">, Vitória</segment>
    <segment id="74">, CSA, CRB</segment>
    <segment id="75">, Confiança</segment>
    <segment id="76">, Sampaio Corrêa</segment>
    <segment id="77">, Remo</segment>
    <segment id="78">, Vila Nova...    Charles Bukowski: "</segment>
    <segment id="79">Nunca espere demais</segment>
    <segment id="80">, da sorte ou dos outros</segment>
    <segment id="81">, no fim não há quem não decepcione você".</segment>
    <segment id="82">Eu sou o Vitor Guedes e tenho um nome a zelar.</segment>
    <segment id="83">E zelar</segment>
    <segment id="84">, claro</segment>
    <segment id="85">, vem de ZL.</segment>
    <segment id="86">É tudo nosso!</segment>
    <segment id="87">É nóis na banca!</segment>
    <segment id="88">No agora.com.br!</segment>
    <segment id="89">E no youtube.com/blogdovitao!    O CARA DA RODADA  RODRIGUINHO -Ao marcar os três primeiros e sofrer o pênalti que originou o 4º gol do 4 a 0 do Bahia em Fortaleza</segment>
    <segment id="90">, Rodriguinho também foi decisivo para a queda cruzmaltina.</segment>
    <segment id="91">É claro que o lixo do VAR (durante toda a campanha) e a ruindadade vascaína também colaboraram... - Felipe Santana/EC Bahia  Troféus  Moleza para o Tricolor</segment>
    <segment id="92">Na primeira partida após a confirmação matemática de que não ganharia nada e</segment>
    <segment id="93">, pois</segment>
    <segment id="94">pois, continuaria na incômoda fila</segment>
    <segment id="95">, o São Paulo (que jogou o título no lixo ao perder muito tempo com o dinizismo!) visita o que sobrou do lanterna Botafogo</segment>
    <segment id="96">, o rival ideal para vencer e confirmar vaga direta na fase de grupos da Libertadores.</segment>
    <segment id="97">Tudo que Crespo não precisa no início de trabalho são mata-matas de pré-Libertadores!</segment>
    <segment id="98">Palpite: Botafogo 0 x 2</segment>
    <segment id="99">São Paulo.</segment>
    <segment id="100">Jogo-treino</segment>
    <segment id="101">Após superar o apito (lixo do VAR incluso) e arrancar o 1 a 1 no Morumbi</segment>
    <segment id="102">, que sepultou as pretensões tricolores no VARgonhão-2021</segment>
    <segment id="103">, o Palmeiras não tem mais nada que fazer no Campeonato Brasileiro além de poupar os titulares e evitar contusões para as decisões da Copa do Brasil contra o Grêmio.</segment>
    <segment id="104">O Atlético-GO também já tem sua classificação à Sul-Americana consolidada e</segment>
    <segment id="105">, pois</segment>
    <segment id="106">pois, o jogo não vale nada!</segment>
    <segment id="107">Palpite: Palmeiras 1 x 1</segment>
    <segment id="108">Atlético-GO.</segment>
    <segment id="109">  Destaques da 37ª rodada do VARgonhão de VARtebol  VARmos</segment>
    <segment id="110">, VARmengo!</segment>
    <segment id="111">O Flamengo contou com a ajuda decisiva e escandalosa do lixo do VAR para vencer o Inter e assumir a liderança pela primeira vez.</segment>
    <segment id="112">O supervalorizado Raphael Claus</segment>
    <segment id="113">, de forma absurda</segment>
    <segment id="114">, foi chamado pelo VAR para expulsar Rodinei e</segment>
    <segment id="115">, de forma covarde e subserviente à cabine</segment>
    <segment id="116">, deu o vermelho que mudou a história do jogo e</segment>
    <segment id="117">, talvez</segment>
    <segment id="118">, do Brasileiro! VArgonha!</segment>
    <segment id="119">Mais uma!</segment>
    <segment id="120">Lembrando que na 36ª rodada</segment>
    <segment id="121">, o VARmengo venceu o Corinthians com um gol (em impedimento?</segment>
    <segment id="122">!) de Gabigol e o Inter venceu o Vasco com o famoso gol não checado pelo VAR descalibrado.</segment>
    <segment id="123">Quem defende o VAR é cúmplice!</segment>
    <segment id="124">Essa culpa eu não carrego!</segment>
    <segment id="125">Viva a memória!</segment>
    <segment id="126">Arte AgoraArte</segment>
    <segment id="127">Agora</segment>
  </rst>
</analysis>