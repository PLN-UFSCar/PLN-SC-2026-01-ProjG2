  <rst>
    <segment id="1">DogmanQuando</segment>
    <segment id="2">Estreia nesta quinta (4)</segment>
    <segment id="3">, nos cinemasClassificação 16</segment>
    <segment id="4">anosElenco Caleb Landry Jones</segment>
    <segment id="5">, Jojo T. Gibbs e Christopher DenhamProdução França</segment>
    <segment id="6">, 2023DireçãoLuc BessonÉ</segment>
    <segment id="7">um bocado difícil que um filme sobre o amor entre o ser humano e os cachorros não desperte pelo menos algum traço de afeição no espectador</segment>
    <segment id="8">, por mais estúpido que o longa eventualmente seja.</segment>
    <segment id="9">Mas "Dogman"</segment>
    <segment id="10">, dirigido pelo francês Luc Besson</segment>
    <segment id="11">, por vezes chega bem perto de infringir essa regra</segment>
    <segment id="12">, apesar da simpática presença de vários cãezinhos fofos</segment>
    <segment id="13">, inteligentes e fiéis a toda prova ao seu dono.</segment>
    <segment id="14">Cena do filme &amp;quot</segment>
    <segment id="15">;Dogman&amp;quot</segment>
    <segment id="16">;, de Luc Besson - DivulgaçãoMas tirando as criaturinhas de quatro patas</segment>
    <segment id="17">, não resta muita coisa digna de nota neste novo trabalho de Besson</segment>
    <segment id="18">, cuja carreira andou fortemente ameaçada nos últimos anos</segment>
    <segment id="19">, após um processo por denúncia de estupro.</segment>
    <segment id="20">A Justiça francesa já o inocentou</segment>
    <segment id="21">, reduzindo um pouco a mácula sobre sua reputação pessoal.</segment>
    <segment id="22">A profissional</segment>
    <segment id="23">, no entanto</segment>
    <segment id="24">, segue com a mancha acumulada por décadas de filmes de qualidade duvidosa</segment>
    <segment id="25">, e "Dogman" nada mais faz que contribuir para sua persistência.</segment>
    <segment id="26">O longa narra a história de um sujeito que</segment>
    <segment id="27">sese decepciona tanto com o resto da humanidade que</segment>
    <segment id="28">sese isola e prefere morar com seus cachorrinhos.</segment>
    <segment id="29">Até aí</segment>
    <segment id="30">, tudo bastante compreensível</segment>
    <segment id="31">, masmas a trama é de uma fragilidade e de um descompromisso com alguma discussão mais séria que nem a única razão não canina para ver o filme –a boa performance de Caleb Landry Jones– consegue prover alguma solidez ao todo.</segment>
    <segment id="32">Confira cenas do filme &amp;#039</segment>
    <segment id="33">;Dogman&amp;#039</segment>
    <segment id="34">;, de Luc BessonMais    novamente         de   de  de  representando um  Jones interpreta o desajustado Doug</segment>
    <segment id="35">, que teve uma infância brutal</segment>
    <segment id="36">, em um lar em que seu pai e seu irmão mais velho o agrediam de forma cruel</segment>
    <segment id="37">, tratando-o literalmente</segment>
    <segment id="38">comocomo um bicho.</segment>
    <segment id="39">A mãe até tenta ajudar o garoto quando pode</segment>
    <segment id="40">, masmas é outra a sofrer nas mãos dos dois fazedores de bullying da casa.</segment>
    <segment id="41">Chega um ponto em que Doug perde o movimento das pernas após uma agressão</segment>
    <segment id="42">, e o único acolhimento que recebe é de cães</segment>
    <segment id="43">, que ganham sua devoção para sempre.</segment>
    <segment id="44">Com vários traumas e problemas de mobilidade devido à violência que sofreu</segment>
    <segment id="45">, Doug vai crescendo com uma propensão à marginalidade.</segment>
    <segment id="46">Sua capacidade de amar é toda voltada aos seus cachorros</segment>
    <segment id="47">, com os quais passa a ter tamanho poder comunicativo que</segment>
    <segment id="48">sese entendem quase que telepaticamente.</segment>
    <segment id="49">Já adulto</segment>
    <segment id="50">, passa a ter o hábito de</segment>
    <segment id="51">sese vestir de drag queen e de</segment>
    <segment id="52">sese apresentar em casas noturnas.</segment>
    <segment id="53">Para aumentar os ganhos</segment>
    <segment id="54">, conta com a ajuda dos amiguinhos caninos na prática de roubos bastante sofisticados.</segment>
    <segment id="55">O longa começa quando</segment>
    <segment id="56">, um dia</segment>
    <segment id="57">, é flagrado em plena ação</segment>
    <segment id="58">, e vai parar na cadeia</segment>
    <segment id="59">, onde uma psiquiatra criminal tenta compreendê-lo</segment>
    <segment id="60">, ouvindo atentamente a sua história.</segment>
    <segment id="61">O filme é confuso e meio preguiçoso ao tomar algumas decisões dramatúrgicas.</segment>
    <segment id="62">A questão do gosto de Doug por</segment>
    <segment id="63">sese maquiar e</segment>
    <segment id="64">sese vestir com trajes femininos</segment>
    <segment id="65">, por exemplo.</segment>
    <segment id="66">O longa sugere que é uma mera tentativa de criar uma persona que o faça</segment>
    <segment id="67">sese sentir menos infeliz consigo mesmo –um personagem criado para Doug conseguir suportar melhor a vida.</segment>
    <segment id="68">Mas é um procedimento que soa meio barato</segment>
    <segment id="69">, como</segment>
    <segment id="70">como uma derivação mal alinhavada do personagem de Joaquin Phoenix em "Coringa"</segment>
    <segment id="71">–ou, na melhor das hipóteses</segment>
    <segment id="72">, uma estratégia pueril de conferir ao longa ares de modernidade</segment>
    <segment id="73">, com um personagem que não</segment>
    <segment id="74">sese fixa em nenhum gênero tradicional.  Fisicamente</segment>
    <segment id="75">, Jones tem alguma coisa do Macaulay Culkin adulto</segment>
    <segment id="76">, só que com uma presença cênica mais sombria</segment>
    <segment id="77">, ou pelo menos mais nuançada –é improvável que</segment>
    <segment id="78">, na infância</segment>
    <segment id="79">, ele conquistasse famílias mundo afora na pele do adorável pestinha Kevin dos filmes "Esqueceram de Mim"</segment>
    <segment id="80">;</segment>
    <segment id="81">provavelmente as travessuras feitas por ele pareceriam perversas além da conta.</segment>
    <segment id="82">Mas esse aspecto dúbio em sua figura o torna um ator de destaque.</segment>
    <segment id="83">Imagens de Macaulay CulkinMais    novamente         de   de  de  representando um  Mas a maneira expressionista</segment>
    <segment id="84">comocomo Besson explora a máscara facial de Jones desvia o foco do espectador.</segment>
    <segment id="85">Os traços já naturalmente marcantes do ator</segment>
    <segment id="86">sese tornam ainda mais fortes debaixo da maquiagem carregada que ele utiliza</segment>
    <segment id="87">, então quando Jones contorce os músculos da face e começa a falar de seus dramas</segment>
    <segment id="88">, sua figura perde qualquer humanidade e</segment>
    <segment id="89">sese torna quase que um personagem em estilo teatro macabro Grand Guignol.</segment>
    <segment id="90">Poderia até surtir um efeito de estranhamento interessante</segment>
    <segment id="91">, masmas a verdade é que</segment>
    <segment id="92">sese trata simplesmente de um desacerto visual.</segment>
    <segment id="93">Mas, apesar de tudo... há os cachorros.</segment>
    <segment id="94">E, apesar da tolice generalizada</segment>
    <segment id="95">, o filme tem alguns momentos genuinamente divertidos mostrando os cães agindo em equipe</segment>
    <segment id="96">, em defesa de seu dono.</segment>
    <segment id="97">Ali, eles salvam o protagonista</segment>
    <segment id="98">, masmas também estão salvando o filme.</segment>
  </rst>
</analysis>