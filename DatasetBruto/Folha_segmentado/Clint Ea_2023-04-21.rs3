  <rst>
    <segment id="1">O ator e diretor Clint Eastwood iniciará as gravações de um novo longa</segment>
    <segment id="2">, "</segment>
    <segment id="3">Jurado nº 2"</segment>
    <segment id="4">, no mês de junho</segment>
    <segment id="5">, e deve contar com a participação dos atores Toni Collette e Nicholas Hoult.</segment>
    <segment id="6">As informações são da revista The Hollywood Reporter.</segment>
    <segment id="7">Clint Eastwood em cena do filme &amp;#039</segment>
    <segment id="8">;Cry Macho:</segment>
    <segment id="9">O Caminho para Redenção&amp;#039</segment>
    <segment id="10">;, que ele mesmo dirige - Claire Folger/DivulgaçãoEastwood deve ter em "</segment>
    <segment id="11">Jurado nº 2</segment>
    <segment id="12">" o último filme de sua carreira</segment>
    <segment id="13">comocomo diretor</segment>
    <segment id="14">, que conta com quase 40 títulos.</segment>
    <segment id="15">Isso porque</segment>
    <segment id="16">porque as gravações terão início quando o artista já tiver completado 93 anos de idade</segment>
    <segment id="17">, o que fará do artista um dos profissionais mais longevos da indústria cinematográfica dos Estados Unidos.</segment>
    <segment id="18">Sem uma data prevista de lançamento</segment>
    <segment id="19">, acredita-</segment>
    <segment id="20">sese que o filme chegue aos cinemas ainda em 2023</segment>
    <segment id="21">, uma vez que o diretor sempre realiza filmagens rápidas com uma pós-produção de pouco mais de dois meses.</segment>
    <segment id="22">O lançamento ficará a cargo da Warner Bros.</segment>
    <segment id="23">e a produção será mais uma parceria entre o estúdio e a Malpaso Produções</segment>
    <segment id="24">, de Eastwood.</segment>
    <segment id="25">Veja imagens do filme &amp;#</segment>
    <segment id="26">039;Cry Macho - O Caminho para a Redenção&amp;#039</segment>
    <segment id="27">;Mais    novamente         de   de  de  representando um  "</segment>
    <segment id="28">Jurado nº</segment>
    <segment id="29">2" é um drama de tribunal que narra a história de um julgamento de assassinato.</segment>
    <segment id="30">Collete deverá viver a promotora de justiça</segment>
    <segment id="31">, enquanto Hoult dará vida ao jurado que dá título ao filme e que</segment>
    <segment id="32">, ao longo do julgamento</segment>
    <segment id="33">, percebe que ele na verdade é o culpado pela morte da vítima</segment>
    <segment id="34">, e permanece no dilema de deixar uma pessoa inocente pagar por seu crime ou assumir a culpa durante o processo.</segment>
    <segment id="35">Não há confirmações de que este seja de fato o último filme da carreira do diretor</segment>
    <segment id="36">, masmas seu último longa</segment>
    <segment id="37">, "Cry Macho"</segment>
    <segment id="38">, lançado em 2021</segment>
    <segment id="39">, foi ignorado nos cinemas dos Estados Unidos e não concorreu a nenhuma premiação.</segment>
    <segment id="40">Com dois Oscars e melhor diretor no currículo</segment>
    <segment id="41">, Eastwood passou a ser ignorado pela Academia desde que</segment>
    <segment id="42">sese posicionou contra as duas eleições de Barack Obama à presidência dos Estados Unidos.</segment>
  </rst>
