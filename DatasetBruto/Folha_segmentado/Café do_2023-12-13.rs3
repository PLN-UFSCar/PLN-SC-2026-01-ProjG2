  <rst>
    <segment id="1">A indústria cafeeira brasileira planeja ampliar a exportação do produto final</segment>
    <segment id="2">, que ainda tem patamares tímidos</segment>
    <segment id="3">sese comparado ao volume que é cultivado no país.</segment>
    <segment id="4">O Brasil é o maior produtor mundial do grão.</segment>
    <segment id="5">É também o líder global na exportação do grão verde</segment>
    <segment id="6">, que é industrializado —torrado</segment>
    <segment id="7">, moído e embalado— por empresas no exterior.</segment>
    <segment id="8">Sacas de café produzido no Brasil sendo preparadas para exportação em armazém em Santos (SP) - Paulo Whitaker/ReutersA Alemanha</segment>
    <segment id="9">, por exemplo</segment>
    <segment id="10">, é o segundo maior comprador de café do mundo.</segment>
    <segment id="11">Isto porque</segment>
    <segment id="12">porque a indústria alemã adquire os grãos verdes —sobretudo do Brasil—</segment>
    <segment id="13">, industrializa-os e vende-os para diversos países.</segment>
    <segment id="14">A ideia da Abic (Associação Brasileira da Indústria de Café) é que agora o país conquiste mais espaço neste mercado internacional de café já industrializado</segment>
    <segment id="15">, isto é</segment>
    <segment id="16">, pronto para consumo.</segment>
    <segment id="17">A questão foi mencionada pelo presidente da entidade</segment>
    <segment id="18">, Pavel Cardoso</segment>
    <segment id="19">, em discurso de abertura do 29º Encontro Nacional da Indústria de Café (Encafé)</segment>
    <segment id="20">, que reuniu alguns dos principais empresários do setor no município de Barra de Santo Antônio</segment>
    <segment id="21">, litoral norte de Alagoas</segment>
    <segment id="22">, em novembro.</segment>
    <segment id="23">Colunas e BlogsReceba no seu email uma seleção de colunas e blogs da FolhaCarregando...</segment>
    <segment id="24">Ao Café na Prensa</segment>
    <segment id="25">, Cardoso disse que este deve ser um dos focos da gestão nos próximos anos.</segment>
    <segment id="26">Ele afirma que</segment>
    <segment id="27">, embora</segment>
    <segment id="28">embora o Brasil seja o maior produtor mundial de café</segment>
    <segment id="29">, com cerca de 40% do que é cultivado em todo o mundo</segment>
    <segment id="30">, o país responde por apenas 16% do comércio global.</segment>
    <segment id="31">Cardoso diz que o setor está unido para desenvolver uma estratégia de promoção do café brasileiro.</segment>
    <segment id="32">A Abic tenta congregar várias entidades</segment>
    <segment id="33">, como</segment>
    <segment id="34">como o Cecafé (Conselho dos Exportadores de Café do Brasil)</segment>
    <segment id="35">, a fim de intensificar essa divulgação no exterior.</segment>
    <segment id="36">Filhos</segment>
    <segment id="37">sese unem aos pais para produzir café de qualidade no Vale do JequitinhonhaMais    novamente         de   de  de  representando um</segment>
    <segment id="38">Entre as iniciativas planejadas está até uma ação de marketing durante os Jogos Olímpicos de Paris</segment>
    <segment id="39">, masmas os detalhes desse projeto ainda estão sendo desenvolvidos.</segment>
    <segment id="40">O Cecafé deve ainda intensificar campanhas que já vinha realizando na China</segment>
    <segment id="41">, país cujo consumo de café tem crescido exponencialmente.</segment>
    <segment id="42">Os exportadores brasileiros veem um grande potencial no mercado chinês.</segment>
    <segment id="43">O Cecafé chegou a idealizar o Mês do Café Brasileiro</segment>
    <segment id="44">, campanha feita em parceria com a embaixada do Brasil em Pequim e a rede de cafeterias Mellower Coffee.  3 notícias sobre café&amp;#039</segment>
    <segment id="45">;Café di Preto&amp;#039</segment>
    <segment id="46">;</segment>
    <segment id="47">: jovem cria empresa para vender grãos só de fazendeiros negrosConsumo de café cresce no Oriente Médio</segment>
    <segment id="48">, que aumenta compras do grão brasileiroPressionada</segment>
    <segment id="49">, cafeicultura brasileira corre atrás de rastreabilidadeO case da Colômbia é apontado</segment>
    <segment id="50">comocomo exemplo.</segment>
    <segment id="51">Apesar de ter uma produção muito menor do que a do Brasil</segment>
    <segment id="52">, o país conseguiu criar uma imagem internacional de excelência do seu café.</segment>
    <segment id="53">Agora, a indústria brasileira tenta levar para o mundo a mensagem de que o Brasil não tem apenas quantidade</segment>
    <segment id="54">, masmas também qualidade.</segment>
    <segment id="55">De fato</segment>
    <segment id="56">, o Brasil sempre foi visto internacionalmente</segment>
    <segment id="57">comocomo produtor de café commodity –de qualidade inferior–</segment>
    <segment id="58">, e não de bebidas sensorialmente complexas –fama que acabava ficando com Colômbia e Etiópia</segment>
    <segment id="59">, por exemplo.</segment>
    <segment id="60">MenuA newsletter de gastronomia exclusiva para assinantes da Folha no plano Digital PremiumCarregando...</segment>
    <segment id="61">A realidade</segment>
    <segment id="62">, no entanto</segment>
    <segment id="63">, vem mudando.</segment>
    <segment id="64">Atualmente</segment>
    <segment id="65">, o Brasil tem um cultivo enorme de cafés especiais com elevadas pontuações na escala de avaliação sensorial da SCA (Specialty Coffee Association)</segment>
    <segment id="66">, considerado o principal padrão de verificação de qualidade do setor.</segment>
    <segment id="67">O jornalista viajou a convite da Abic.    Acompanhe o Café na Prensa também pelo Instagram @davidmclucena e pelo Twitter @davidlucena</segment>
    <segment id="68">Qual assunto você gostaria de ver aqui no blog?</segment>
    <segment id="69">Envie sugestões para david.lucena@folhapress.com.br</segment>
  </rst>
