  <rst>
    <segment id="1">O programa "Pemba: Residência Preta"</segment>
    <segment id="2">, voltado à pesquisa</segment>
    <segment id="3">, ao intercâmbio e à criação em artes visuais</segment>
    <segment id="4">, abre inscrições nesta sexta-feira (8) para artistas</segment>
    <segment id="5">, curadores</segment>
    <segment id="6">, críticos</segment>
    <segment id="7">, teóricos e educadores vinculados à produção afro-brasileira.</segment>
    <segment id="8">A proposta</segment>
    <segment id="9">, parte do projeto "Dos Brasis: Arte e Pensamento Negro"</segment>
    <segment id="10">, do Sesc</segment>
    <segment id="11">, tem como</segment>
    <segment id="12">como objetivos estimular trocas</segment>
    <segment id="13">, experimentações e reflexões</segment>
    <segment id="14">, além de ampliar o espaço e a visibilidade da produção artística e intelectual negra.</segment>
    <segment id="15">O programa</segment>
    <segment id="16">, com inscrições abertas até o dia 22 de abril</segment>
    <segment id="17">, selecionará até 150 candidatos de todas as regiões do país.</segment>
    <segment id="18">O resultado da seleção será divulgado em 3 de maio.</segment>
    <segment id="19">Cartaz do programa de residência artística &amp;quot</segment>
    <segment id="20">;Pemba&amp;quot</segment>
    <segment id="21">;, dirigido à criação afro-brasileira - ReproduçãoHistórias da Arte</segment>
    <segment id="22">; Curadoria e Raça na Arte Brasileira</segment>
    <segment id="23">;</segment>
    <segment id="24">Os Educativos</segment>
    <segment id="25">comocomo Plataforma de Pensamento sobre Arte e Racialização</segment>
    <segment id="26">; Arte Brasileira</segment>
    <segment id="27">, Racialização</segment>
    <segment id="28">, Dissidências</segment>
    <segment id="29">; e Mulheres Negras e Arte Contemporânea Brasileira são algumas das temáticas compreendidas</segment>
    <segment id="30">, em encontros online semanais com orientadores e atividades públicas entre maio e agosto</segment>
    <segment id="31">, com carga horária de 40 horas.</segment>
    <segment id="32">Os trabalhos terão orientação dos artistas/pesquisadores Yhuri Cruz</segment>
    <segment id="33">, Juliana dos Santos</segment>
    <segment id="34">, Rafael Bqueer</segment>
    <segment id="35">, Ariana Nuala e Renata Sampaio.</segment>
    <segment id="36">Também estão previstas aulas públicas com Kleber Amancio</segment>
    <segment id="37">, Diane Lima</segment>
    <segment id="38">, Rosana Paulino</segment>
    <segment id="39">, Denise Ferreira da Silva</segment>
    <segment id="40">, Rosane Borges</segment>
    <segment id="41">, Castiel Vitorino</segment>
    <segment id="42">, Renata Bitencourt e Renata Sampaio.</segment>
    <segment id="43">Os critérios de escolha para a residência serão</segment>
    <segment id="44">o "histórico artístico-cultural</segment>
    <segment id="45">"</segment>
    <segment id="46">dos candidatos para a categoria pretendida</segment>
    <segment id="47">e "a relevância da argumentação" que apresentarem na sua defesa da participação no programa</segment>
    <segment id="48">, afirma ao blog o analista de artes do Departamento Nacional do Sesc</segment>
    <segment id="49">, Jocelino Pessoa de Oliveira.</segment>
    <segment id="50">Na seleção</segment>
    <segment id="51">, serão consideradas ainda a equidade de gênero e a representatividade regional</segment>
    <segment id="52">, detalha.  "</segment>
    <segment id="53">Os participantes serão convidados a entregar contribuições no formato de ensaio visual</segment>
    <segment id="54">, ensaio crítico ou proposição educativa</segment>
    <segment id="55">, que poderão compor produtos resultantes do processo de residência.</segment>
    <segment id="56">"</segment>
    <segment id="57">O projeto "Dos Brasis" tem curadoria do professor e doutor em artes visuais Igor Simões e do curador e antropólogo Hélio Menezes.</segment>
    <segment id="58">Além da residência artística</segment>
    <segment id="59">, a iniciativa tem em seu cronograma</segment>
    <segment id="60">, entre outros projetos</segment>
    <segment id="61">, uma exposição coletiva em 2023 com trabalhos de artistas visuais de todo o Brasil.</segment>
  </rst>
</analysis>