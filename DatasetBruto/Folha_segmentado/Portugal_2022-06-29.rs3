  <rst>
    <segment id="1">Portugal</segment>
    <segment id="2">sese apresenta cada vez mais</segment>
    <segment id="3">comocomo um Estado brasileiro na Europa.</segment>
    <segment id="4">Os dois países parecem interessados nesse movimento: a língua portuguesa sendo instrumento de cidadania.</segment>
    <segment id="5">Será que a União Europeia vai permitir?</segment>
    <segment id="6">Hoje os sinais são fortes</segment>
    <segment id="7">comocomo os fatos.</segment>
    <segment id="8">A história</segment>
    <segment id="9">sese desenha em frente de nossos olhos</segment>
    <segment id="10">, e aquilo que era a intuição de poucos é hoje certeza e vontade de muitos.</segment>
    <segment id="11">Viver em Portugal está no topo da lista dos desejos de cada vez mais brasileiros.</segment>
    <segment id="12">Monumento aos Descobrimentos</segment>
    <segment id="13">, na região do Belém</segment>
    <segment id="14">, em Lisboa - Lalo de Almeida - 7.nov.17/Folhapress</segment>
    <segment id="15">Faça a experiência.</segment>
    <segment id="16">Perdendo-</segment>
    <segment id="17">sese pelas ruas de São Paulo</segment>
    <segment id="18">, no Uber</segment>
    <segment id="19">, em mercados</segment>
    <segment id="20">, teatros</segment>
    <segment id="21">, jardins</segment>
    <segment id="22">, academias e restaurantes</segment>
    <segment id="23">, não importa de que sofisticação ou preço</segment>
    <segment id="24">, da Mooca à Faria Lima</segment>
    <segment id="25">, popular ou elitizado</segment>
    <segment id="26">, sinta a reação ao nome "Portugal".</segment>
    <segment id="27">Ela se</segment>
    <segment id="28">se alterou substantivamente nos últimos anos.</segment>
    <segment id="29">Onde antes existia desconhecimento (ou mesmo vazio)</segment>
    <segment id="30">, hoje existe um desejo afável de proximidade que</segment>
    <segment id="31">sese expressa</segment>
    <segment id="32">, às vezes nervosa-miudinhamente</segment>
    <segment id="33">, em manifestações de carinho que vão</segment>
    <segment id="34">sese organizando à volta de uma ideia que</segment>
    <segment id="35">, cada vez mais</segment>
    <segment id="36">, todos sentem</segment>
    <segment id="37">comocomo normal —ir morar em Portugal.</segment>
    <segment id="38">Lá foraReceba no seu email uma seleção semanal com o que de mais importante aconteceu no mundo</segment>
    <segment id="39">; aberta para não assinantes.</segment>
    <segment id="40">Carregando...</segment>
    <segment id="41">Logo o sentimento das ruas</segment>
    <segment id="42">sese consolida.</segment>
    <segment id="43">Nas buscas no Google</segment>
    <segment id="44">, nas redes sociais</segment>
    <segment id="45">, nas estatísticas oficiais e —novidade maior— até na produção legislativa</segment>
    <segment id="46">, tendo o governo de Lisboa acabado de criar um instrumento migratório inovador.</segment>
    <segment id="47">Um novo visto</segment>
    <segment id="48">, com a duração de 180 dias</segment>
    <segment id="49">, é destinado exclusivamente a que</segment>
    <segment id="50">, falantes de português</segment>
    <segment id="51">, procurem —e encontrem— trabalho em Portugal.</segment>
    <segment id="52">Junta-</segment>
    <segment id="53">sese a fome com a vontade de comer</segment>
    <segment id="54">, como</segment>
    <segment id="55">como se</segment>
    <segment id="56">se diz lá na terrinha</segment>
    <segment id="57">, porque</segment>
    <segment id="58">porque as razões de tanta pressa são prosaicas e ponderosas e não estão</segment>
    <segment id="59">sese prendendo apenas com os romantismos do bicentenário da independência</segment>
    <segment id="60">; a descoberta de um ancestral avô nascido em Coimbra</segment>
    <segment id="61">;</segment>
    <segment id="62">nas inesperadas transumâncias do coração de D. Pedro ou ainda da súbita vontade de dizer "eu amo Portugal".</segment>
    <segment id="63">Lisboa</segment>
    <segment id="64">Mais    novamente         de   de  de  representando um  O país luso está envelhecendo inexoravelmente e sem "a gente" vai morrer.</segment>
    <segment id="65">Há 40 anos que a sociedade portuguesa vive abaixo da marca de reposição das gerações —que é de 2</segment>
    <segment id="66">,1 filhos por mulher fértil—</segment>
    <segment id="67">, girando atualmente em torno de 1</segment>
    <segment id="68">,4 (em 2019)</segment>
    <segment id="69">, o que tem causado sucessivas diminuições da população.</segment>
    <segment id="70">Com as projeções mais pessimistas apontando para uma queda demográfica de nível catastrófico</segment>
    <segment id="71">, Portugal "</segment>
    <segment id="72">sese vira" olhando com desejo para seus irmãos brasileiros do Hemisfério Sul</segment>
    <segment id="73">, no momento feliz em que</segment>
    <segment id="74">, por muitas razões sociais e econômicas de que falaremos oportunamente em esta coluna que hoje inaugura</segment>
    <segment id="75">, o Brasil também está olhando com interesse estratégico para os irmãos da Europa.</segment>
    <segment id="76">Portugal precisa de boa imigração e de investimento</segment>
    <segment id="77">, e o Brasil precisa de uma porta de entrada para um mercado europeu.</segment>
    <segment id="78">O premiê português sabe disso e vai lutar em Bruxelas por um regime especial de cidadania para os cidadãos dos países de língua portuguesa.</segment>
    <segment id="79">Será a primeira "cidadania da língua" na história universal.</segment>
  </rst>
