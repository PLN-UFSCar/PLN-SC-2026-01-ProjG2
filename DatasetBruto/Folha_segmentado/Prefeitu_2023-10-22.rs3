  <rst>
    <segment id="1">A Prefeitura de São Paulo conseguiu um financiamento de R$ 2</segment>
    <segment id="2">,5 bilhões no BNDES (Banco Nacional de Desenvolvimento Econômico e Social) para adquirir 1.600 ônibus elétricos.</segment>
    <segment id="3">Esses veículos fazem parte dos 2.400 previstos pela atual gestão para entrar no sistema até o final de 2024</segment>
    <segment id="4">, o que fará com que 20% da frota de ônibus da cidade utilize energia limpa.</segment>
    <segment id="5">Com a aprovação por parte do banco</segment>
    <segment id="6">, o financiamento segue para a Secretaria do Tesouro Nacional</segment>
    <segment id="7">, e o contrato deve ser assinado dentro de um mês.</segment>
    <segment id="8">Ônibus elétrico circula pela cidade de São Paulo</segment>
    <segment id="9">;</segment>
    <segment id="10">meta da Prefeitura é que 2.400 veículos desse tipo</segment>
    <segment id="11">, que não poluem</segment>
    <segment id="12">, entrem no sistema até o final de 2024- Marcelo Pereira/SECOM</segment>
    <segment id="13">Com isso</segment>
    <segment id="14">, a Prefeitura dá continuidade ao processo de troca dos ônibus atuais</segment>
    <segment id="15">, a diesel</segment>
    <segment id="16">, por veículos elétricos</segment>
    <segment id="17">, de energia sustentável</segment>
    <segment id="18">, que não poluem</segment>
    <segment id="19">, representando um ganho ambiental e de saúde</segment>
    <segment id="20">, pois</segment>
    <segment id="21">pois não emitem gás carbônico</segment>
    <segment id="22">, não produzem ruídos e têm tecnologias que aumentam o conforto</segment>
    <segment id="23">, como</segment>
    <segment id="24">como wi-fi e refrigeração.</segment>
    <segment id="25">Ao atingir a meta em 2024</segment>
    <segment id="26">, a cidade de São Paulo colocará o Brasil na liderança da América Latina e no segundo lugar do ranking mundial de eletrificação da frota de ônibus</segment>
    <segment id="27">, atrás apenas da China.</segment>
    <segment id="28">Para viabilizar o plano de substituição gradual da frota de ônibus movidos a diesel pelos elétricos</segment>
    <segment id="29">, além do empréstimo com o BNDES</segment>
    <segment id="30">, a Prefeitura busca outros financiamentos</segment>
    <segment id="31">, que devem totalizar R$ 3</segment>
    <segment id="32">,25 bilhões.</segment>
    <segment id="33">O município já obteve a confirmação de crédito externo de cerca de US$ 500 milhões junto ao Banco Interamericano de Desenvolvimento (BID) e ao Banco Mundial (BIRD).</segment>
    <segment id="34">Além da captação internacional</segment>
    <segment id="35">, a Prefeitura deve assinar em breve operações de crédito com o Banco do Brasil e a Caixa Econômica Federal.  *</segment>
    <segment id="36">Conteúdo patrocinado produzido pelo Estúdio Folha</segment>
  </rst>
</analysis>