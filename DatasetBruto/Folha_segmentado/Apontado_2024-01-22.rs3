  <rst>
    <segment id="1">Um homem apontado</segment>
    <segment id="2">comocomo chefe de uma milícia foi morto a tiros</segment>
    <segment id="3">, na noite deste domingo (21)</segment>
    <segment id="4">, na praia do Recreio dos Bandeirantes</segment>
    <segment id="5">, na zona oeste do Rio de Janeiro.</segment>
    <segment id="6">Sérgio da Costa Silva</segment>
    <segment id="7">, 44, conhecido</segment>
    <segment id="8">comocomo Sérgio Bomba</segment>
    <segment id="9">, chegou a ser preso em 2017</segment>
    <segment id="10">, após ser denunciado</segment>
    <segment id="11">comocomo liderança de uma milícia de Sepetiba</segment>
    <segment id="12">, também na zona oeste do Rio.</segment>
    <segment id="13">No processo</segment>
    <segment id="14">, a milícia é denunciada por cobrar taxas de comerciantes e moradores</segment>
    <segment id="15">, grilagem de terras e clonagem de carros.</segment>
    <segment id="16">Ele já foi apontado</segment>
    <segment id="17">comocomo braço direito de Carlos da Silva Braga</segment>
    <segment id="18">, o Carlinhos Três Pontes</segment>
    <segment id="19">, morto em abril de 2017.</segment>
    <segment id="20">Braga uniu o tráfico e a milícia e expandiu a organização chamada Família Braga para diversas regiões do estado</segment>
    <segment id="21">, de acordo com a polícia.</segment>
    <segment id="22">Sérgio Bomba</segment>
    <segment id="23">, 44, em foto de sua ficha criminal</segment>
    <segment id="24">; ele foi morto a tiros em quiosque do Recreio dos Bandeirantes</segment>
    <segment id="25">, no Rio</segment>
    <segment id="26">, neste domingo (21) - Reprodução Imagens de uma câmera de segurança mostram</segment>
    <segment id="27">Silva sentado em uma cadeira</segment>
    <segment id="28">, acompanhado de uma mulher.</segment>
    <segment id="29">Pedestres passeavam pelo calçadão da praia.</segment>
    <segment id="30">Em determinado momento</segment>
    <segment id="31">, um homem de boné</segment>
    <segment id="32">sese aproxima e faz quatro disparos com uma pistola.</segment>
    <segment id="33">O atirador corre em direção à via e foge.</segment>
    <segment id="34">A mulher que o acompanhava não</segment>
    <segment id="35">sese feriu.</segment>
    <segment id="36">Bombeiros constataram a morte no local</segment>
    <segment id="37">, por volta das 21h</segment>
    <segment id="38">, e a perícia foi acionada.</segment>
    <segment id="39">Em nota</segment>
    <segment id="40">, a Polícia Civil afirmou que a DHC (Delegacia de Homicídios da Capital) investiga o</segment>
    <segment id="41">casocaso.</segment>
    <segment id="42">"</segment>
    <segment id="43">Os agentes estão em busca de testemunhas e informações para identificar a autoria e esclarecer a motivação do crime"</segment>
    <segment id="44">, disse a corporação.</segment>
    <segment id="45">A Folha apurou que investigadores averiguam</segment>
    <segment id="46">sese a morte foi ocasionada por homens apontados</segment>
    <segment id="47">comocomo milicianos ligados a Luis Antonio da Silva Braga</segment>
    <segment id="48">, o Zinho</segment>
    <segment id="49">, preso na véspera de Natal após</segment>
    <segment id="50">sese entregar na sede da Polícia Federal do Rio.</segment>
    <segment id="51">A Polícia Militar</segment>
    <segment id="52">, também em nota</segment>
    <segment id="53">, disse que foi acionada para o local e</segment>
    <segment id="54">, ao chegar</segment>
    <segment id="55">, constatou que um homem estava morto com "várias perfurações de tiros".</segment>
    <segment id="56">A evolução da milícia no Rio de JaneiroMais    novamente         de   de  de  representando</segment>
    <segment id="57">um</segment>
  </rst>
</analysis>