  <rst>
    <segment id="1">Sempre Paris - Crônica de uma Cidade</segment>
    <segment id="2">, Seus Escritores e ArtistasPreço R$ 89</segment>
    <segment id="3">,90 (360 págs.)</segment>
    <segment id="4">; R$ 39</segment>
    <segment id="5">,90 (ebook)Autoria Rosa Freire d&amp;#039</segment>
    <segment id="6">;AguiarEditora Companhia das LetrasParis nos recebe de braços abertos</segment>
    <segment id="7">, e a anfitriã é a jornalista e tradutora Rosa Freire d’Aguiar</segment>
    <segment id="8">, que acaba de publicar "Sempre Paris"</segment>
    <segment id="9">, no qual relata sua vida</segment>
    <segment id="10">comocomo correspondente de grandes jornais e revistas brasileiros na capital francesa nas décadas de 1970 e 1980.</segment>
    <segment id="11">A jornalista e tradutora Rosa Freire d&amp;#039</segment>
    <segment id="12">;Aguiar em fotografia que integra o livro de memórias &amp;#</segment>
    <segment id="13">039;Sempre Paris&amp;#039</segment>
    <segment id="14">; - Arquivo pessoalNessas suculentas memórias</segment>
    <segment id="15">, a autora cede o protagonismo a escritores</segment>
    <segment id="16">, artistas e intelectuais com os quais teve o privilégio de dialogar</segment>
    <segment id="17">, embora</segment>
    <segment id="18">embora também comente com suas próprias palavras temas centrais da época</segment>
    <segment id="19">, que se</segment>
    <segment id="20">se repetem hoje</segment>
    <segment id="21">, como</segment>
    <segment id="22">como, por exemplo</segment>
    <segment id="23">, o eterno conflito na Faixa de Gaza.</segment>
    <segment id="24">Freire d’Aguiar recorda sua primeira viagem à região em 1982</segment>
    <segment id="25">, a partir de Paris</segment>
    <segment id="26">, quando "a política de colonização israelense causava outros dramas nos territórios ocupados</segment>
    <segment id="27">, onde desde 1967 os governos –fossem quais fossem– exasperavam a vida dos palestinos".  "</segment>
    <segment id="28">Em Rafá</segment>
    <segment id="29">, no sul da Faixa de Gaza</segment>
    <segment id="30">, encontrei a menininha Rollah</segment>
    <segment id="31">, de três anos</segment>
    <segment id="32">, que desaprendera a falar e só repetia alhudud —fronteira— desde que os israelenses tinham fincado diante de sua casa uma cerca de arame farpado de dois metros de altura"</segment>
    <segment id="33">, escreve.</segment>
    <segment id="34">Crianças palestinas brincam em praia de Gaza em trégua na guerraMais    novamente         de   de  de  representando um  Interessante pensar que "Sempre Paris" foi impresso um mês antes do início de um novo conflito na região.</segment>
    <segment id="35">Lendo os relatos e entrevistas do livro</segment>
    <segment id="36">, tem-</segment>
    <segment id="37">sese a impressão de que ao longo desses anos não saímos do lugar ou</segment>
    <segment id="38">, pior</segment>
    <segment id="39">, regredimos.</segment>
    <segment id="40">"</segment>
    <segment id="41">Sempre Paris" narra vários acontecimentos importantes da história recente</segment>
    <segment id="42">, que continuam cruciais.</segment>
    <segment id="43">Em 1981</segment>
    <segment id="44">, a jornalista entrevistou o escritor argentino Ernesto Sabato</segment>
    <segment id="45">, que, ao ser perguntado</segment>
    <segment id="46">sese a omissão e o escapismo da geração dele não teriam contribuído para a situação do país</segment>
    <segment id="47">, respondeu afirmativamente.</segment>
    <segment id="48">E complementou:</segment>
    <segment id="49">"É certo que na Argentina chegamos a este ponto</segment>
    <segment id="50">porque</segment>
    <segment id="51">porque muitos homens eminentes</segment>
    <segment id="52">sese negaram a participar da vida política.</segment>
    <segment id="53">Era tradicional</segment>
    <segment id="54">, na Argentina</segment>
    <segment id="55">comocomo em muitos outros países</segment>
    <segment id="56">, a ideia de que a política é suja.</segment>
    <segment id="57">A política é real</segment>
    <segment id="58">, e a realidade é suja.</segment>
    <segment id="59">Só o mundo platônico é limpo".</segment>
    <segment id="60">O escritor acreditava</segment>
    <segment id="61">, contudo</segment>
    <segment id="62">contudo</segment>
    <segment id="63">, que a Argentina estava farta dos militares.</segment>
    <segment id="64">Mas nem 50 anos</segment>
    <segment id="65">sese passaram e os argentinos defendem hoje a ideia de que só alguém afastado da política poderá salvar o país.</segment>
    <segment id="66">Parecem ter esquecido também os desaparecidos e da supressão das garantias constitucionais ao elegerem</segment>
    <segment id="67">comocomo presidente Javier Milei.</segment>
    <segment id="68">Veja imagens da posse de Javier Milei</segment>
    <segment id="69">, novo presidente da ArgentinaMais    novamente         de   de  de  representando um</segment>
    <segment id="70">A respeito do mundo literário</segment>
    <segment id="71">, Freire d’Aguiar conta que</segment>
    <segment id="72">, quando chegou a Paris</segment>
    <segment id="73">, editavam-</segment>
    <segment id="74">sese ali "nada menos que 150 suplementos e revistas literárias"</segment>
    <segment id="75">, que ela tentava acompanhar.</segment>
    <segment id="76">Entrevistou celebridades desse universo</segment>
    <segment id="77">, como</segment>
    <segment id="78">como Roland Barthes</segment>
    <segment id="79">, Eugène Ionesco e Michel Serres</segment>
    <segment id="80">, entre outros nomes que conhecemos ainda hoje.</segment>
    <segment id="81">Algumas entrevistas são inéditas</segment>
    <segment id="82">, outras foram publicadas à época no Brasil.</segment>
    <segment id="83">Na entrevista com Ionesco</segment>
    <segment id="84">, a morte e a velhice ganham destaque.</segment>
    <segment id="85">Para o dramaturgo</segment>
    <segment id="86">, os últimos anos de vida são os mais irritantes</segment>
    <segment id="87">, pois</segment>
    <segment id="88">pois "você já sabe tudo o que poderia saber</segment>
    <segment id="89">, ou seja</segment>
    <segment id="90">, nada sabe e não saberá mais nada".</segment>
    <segment id="91">"É terrível</segment>
    <segment id="92">, é inadmissível.</segment>
    <segment id="93">E você continua vivo</segment>
    <segment id="94">, você não quer ir</segment>
    <segment id="95">embora</segment>
    <segment id="96">embora.</segment>
    <segment id="97">"</segment>
    <segment id="98">O tema parece estar em voga na literatura contemporânea brasileira</segment>
    <segment id="99">, masmas talvez sem a profundidade e o humor característico de Ionesco.</segment>
    <segment id="100">Tudo a lerReceba no seu email uma seleção com lançamentos</segment>
    <segment id="101">, clássicos e curiosidades literáriasCarregando...</segment>
    <segment id="102">Duas mulheres entrevistadas pela autora chamam a atenção.</segment>
    <segment id="103">Élisabeth Badinter</segment>
    <segment id="104">, "voz atuante no feminismo dos anos 1960"</segment>
    <segment id="105">, provocou furor ao colocar em xeque a naturalidade do amor materno —mais um tema</segment>
    <segment id="106">, vale destacar</segment>
    <segment id="107">, que retornou em escritos contemporâneos</segment>
    <segment id="108">comocomo algo completamente novo e original.</segment>
    <segment id="109">A outra é Simone Veil</segment>
    <segment id="110">, que, nos anos 1970</segment>
    <segment id="111">, foi ministra da Saúde na França e lutou pela legalização do aborto e por outras causas que garantissem a liberdade feminina.</segment>
    <segment id="112">"</segment>
    <segment id="113">Sempre Paris" confirma na prática a teoria do filósofo italiano Giambattista Vico:</segment>
    <segment id="114">a história é circular e espiral —circular</segment>
    <segment id="115">porque</segment>
    <segment id="116">porque sempre</segment>
    <segment id="117">sese repete e espiral</segment>
    <segment id="118">porque</segment>
    <segment id="119">porque nunca</segment>
    <segment id="120">sese repete inteiramente da mesma forma.</segment>
    <segment id="121">Ao final da leitura</segment>
    <segment id="122">, o advérbio "sempre" do título fica parecendo viconiano</segment>
  </rst>
</analysis>