    <segment id="79">, biógrafo de Susan Sontag</segment>
    <segment id="80">, Fernanda Miranda e Tom Farias</segment>
    <segment id="81">, pesquisadores da obra de Carolina Maria de Jesus</segment>
    <segment id="82">, Ana Luísa Amaral</segment>
