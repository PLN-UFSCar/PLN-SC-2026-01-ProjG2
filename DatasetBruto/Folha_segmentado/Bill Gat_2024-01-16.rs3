  <rst>
    <segment id="1">O fundador da Microsoft e filantropo Bill Gates</segment>
    <segment id="2">sese reuniu com a ministra Marina Silva (Meio Ambiente) nesta terça-feira (16) em Davos e afirmou que quer visitar o Brasil antes da COP30</segment>
    <segment id="3">, que deve acontecer em Belém (PA) no próximo ano.</segment>
    <segment id="4">"</segment>
    <segment id="5">Ele tem investimentos na área de transição energética</segment>
    <segment id="6">, investimentos privados.</segment>
    <segment id="7">E na adaptação [climática</segment>
    <segment id="8">, esse tipo de repasse] é feito pela filantropia"</segment>
    <segment id="9">, afirmou.  Bill Gates e Marina Silva trocam aperto de mãos em reunião do Fórum Econômico Mundial</segment>
    <segment id="10">, em Davos</segment>
    <segment id="11">, Suíça - MMA - 16.jan.2023/Divulgação</segment>
    <segment id="12">Segundo a ministra</segment>
    <segment id="13">, que foi procurada pelo bilionário durante sua participação na reunião anual do Fórum Econômico Mundial</segment>
    <segment id="14">, Gates pretende avaliar uma doação para a adaptação à mudança climática.</segment>
    <segment id="15">Os dois conversaram sobre a experiência brasileira e eventuais contribuições de Gates</segment>
    <segment id="16">, masmas nenhum tipo de compromisso ou promessa foi feito.</segment>
    <segment id="17">O americano</segment>
    <segment id="18">, contudo</segment>
    <segment id="19">contudo</segment>
    <segment id="20">, pediu para</segment>
    <segment id="21">sese informar sobre a experiência brasileira ao lidar com as consequências das mudanças climáticas e afirmou</segment>
    <segment id="22">, segundo Marina</segment>
    <segment id="23">, que pretende</segment>
    <segment id="24">sese envolver na COP30.</segment>
    <segment id="25">"</segment>
    <segment id="26">Foi uma conversa estratégica para ser desdobrada na prática provavelmente nessa visita"</segment>
    <segment id="27">, disse.</segment>
    <segment id="28">Marina participa de quatro painéis no Fórum nesta terça (16)</segment>
    <segment id="29">, além de reuniões bilaterais.</segment>
    <segment id="30">Ela compõe a delegação brasileira com os ministros Alexandre Silveira (Minas e Energia) e Nísia Trindade (Saúde) e com o presidente do Superior Tribunal Federal</segment>
    <segment id="31">, Luís Roberto Barroso.</segment>
    <segment id="32">Como no ano passado</segment>
    <segment id="33">, o presidente Luiz Inácio Lula da Silva (PT) não veio.</segment>
    <segment id="34">O ministro Fernando Haddad (Fazenda)</segment>
    <segment id="35">, presença aguardada e alvo de interesse das plateias alpinas</segment>
    <segment id="36">, também faltou nesta edição.</segment>
  </rst>
