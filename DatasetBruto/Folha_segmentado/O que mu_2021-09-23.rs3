  <rst>
    <segment id="1">A China anunciou que n&amp;atilde</segment>
    <segment id="2">;o financiar&amp;aacute</segment>
    <segment id="3">; mais usinas termel&amp;eacute</segment>
    <segment id="4">;tricas a carv&amp;atilde</segment>
    <segment id="5">;o no exterior.</segment>
    <segment id="6">Mas esse avan&amp;ccedil</segment>
    <segment id="7">;o, considerado bem-vindo pelos ambientalistas</segment>
    <segment id="8">, n&amp;atilde</segment>
    <segment id="9">;o resolve todos os problemas.</segment>
    <segment id="10">Principal emissor mundial de gases de efeito estufa</segment>
    <segment id="11">, a China n&amp;atilde</segment>
    <segment id="12">;o definiu datas para implementar esta medida</segment>
    <segment id="13">, nem especificou o que vai acontecer com os projetos em desenvolvimento.</segment>
    <segment id="14">Isso &amp;eacute</segment>
    <segment id="15">;</segment>
    <segment id="16">o que se</segment>
    <segment id="17">se sabe por enquanto</segment>
    <segment id="18">:  Vista de usina termelétrica em Uruguaiana (RS)   - Paulo Whitaker - 18.mai.2001/ReutersO que a China prometeu?</segment>
    <segment id="19">Em uma mensagem de v&amp;iacute</segment>
    <segment id="20">;deo divulgada na Assembleia Geral da ONU</segment>
    <segment id="21">, o presidente chin&amp;ecirc</segment>
    <segment id="22">;s, Xi Jinping</segment>
    <segment id="23">, fez esta promessa.</segment>
    <segment id="24">&amp;quot;A China refor&amp;ccedil</segment>
    <segment id="25">;ar&amp;aacute</segment>
    <segment id="26">;</segment>
    <segment id="27">seu apoio aos pa&amp;iacute</segment>
    <segment id="28">;ses em desenvolvimento para fomentar as energias verdes e baixas em carbono</segment>
    <segment id="29">, e n&amp;atilde</segment>
    <segment id="30">;o construir&amp;aacute</segment>
    <segment id="31">; mais usinas el&amp;eacute</segment>
    <segment id="32">;tricas movidas a carv&amp;atilde</segment>
    <segment id="33">;o no exterior&amp;quot</segment>
    <segment id="34">;</segment>
    <segment id="35">.</segment>
    <segment id="36">Isso muda a situa&amp;ccedil</segment>
    <segment id="37">;&amp;atilde</segment>
    <segment id="38">;o?</segment>
    <segment id="39">Sim e n&amp;atilde</segment>
    <segment id="40">;o.</segment>
    <segment id="41">A China &amp;eacute</segment>
    <segment id="42">; o maior financiador p&amp;uacute</segment>
    <segment id="43">;blico de usinas termel&amp;eacute</segment>
    <segment id="44">;tricas a carv&amp;atilde</segment>
    <segment id="45">;o fora das fronteiras</segment>
    <segment id="46">, como</segment>
    <segment id="47">como no</segment>
    <segment id="48">casocaso de Zimb&amp;aacute</segment>
    <segment id="49">;bue, Paquist&amp;atilde</segment>
    <segment id="50">;o, Indon&amp;eacute</segment>
    <segment id="51">;sia e Vietn&amp;atilde</segment>
    <segment id="52">;, entre outros.</segment>
    <segment id="53">Jap&amp;atilde</segment>
    <segment id="54">;o e Coreia do Sul</segment>
    <segment id="55">, os outros maiores financiadores destes projetos</segment>
    <segment id="56">, j&amp;aacute</segment>
    <segment id="57">; anunciaram que v&amp;atilde</segment>
    <segment id="58">;o parar de fazer isso at&amp;eacute</segment>
    <segment id="59">;</segment>
    <segment id="60">o fim do ano.  &amp;quot</segment>
    <segment id="61">;A China foi a &amp;uacute</segment>
    <segment id="62">;ltima a</segment>
    <segment id="63">sese manter firme&amp;quot</segment>
    <segment id="64">;, disse Li Shuo</segment>
    <segment id="65">, do Greenpeace China</segment>
    <segment id="66">, &amp;agrave</segment>
    <segment id="67">; AFP.</segment>
    <segment id="68">O afastamento dos bancos p&amp;uacute</segment>
    <segment id="69">;blicos chineses pode ter um efeito domin&amp;oacute</segment>
    <segment id="70">; nos privados e tornar os investimentos em carv&amp;atilde</segment>
    <segment id="71">;o mais arriscados</segment>
    <segment id="72">, alerta.  &amp;quot</segment>
    <segment id="73">;Quando o dinheiro p&amp;uacute</segment>
    <segment id="74">;blico vai para um setor</segment>
    <segment id="75">, o privado tende a segui-lo&amp;quot</segment>
    <segment id="76">;, explica Li Shuo.</segment>
    <segment id="77">A participa&amp;ccedil</segment>
    <segment id="78">;&amp;atilde</segment>
    <segment id="79">;o chinesa nessas usinas a carv&amp;atilde</segment>
    <segment id="80">;o no exterior &amp;eacute</segment>
    <segment id="81">; baixa</segment>
    <segment id="82">, por&amp;eacute</segment>
    <segment id="83">;m, em fun&amp;ccedil</segment>
    <segment id="84">;&amp;atilde</segment>
    <segment id="85">;o dos fundos (p&amp;uacute</segment>
    <segment id="86">;blicos e privados).</segment>
    <segment id="87">De 2013 a 2019</segment>
    <segment id="88">, os credores chineses (estatais</segment>
    <segment id="89">, ou n&amp;atilde</segment>
    <segment id="90">;o) forneceram apenas 13% do financiamento para f&amp;aacute</segment>
    <segment id="91">;bricas em constru&amp;ccedil</segment>
    <segment id="92">;&amp;atilde</segment>
    <segment id="93">;o, ou planejadas</segment>
    <segment id="94">, fora de suas fronteiras</segment>
    <segment id="95">, de acordo com o Centro de Pol&amp;iacute</segment>
    <segment id="96">;ticas de Desenvolvimento Global da Universidade de Boston.</segment>
    <segment id="97">Aqui, 87% dos recursos foram procedentes de fora da China.</segment>
    <segment id="98">Quem s&amp;atilde</segment>
    <segment id="99">;o seus financiadores?</segment>
    <segment id="100">Principalmente bancos privados e investidores japoneses</segment>
    <segment id="101">, americanos e brit&amp;acirc</segment>
    <segment id="102">;nicos.</segment>
    <segment id="103">De 2018 a 2020</segment>
    <segment id="104">, os bancos privados japoneses foram os principais financiadores destas centrais nos pa&amp;iacute</segment>
    <segment id="105">;ses em desenvolvimento</segment>
    <segment id="106">, emprestando em torno de US$ 76 bilh&amp;otilde</segment>
    <segment id="107">;es (R$ 401 bilh&amp;otilde</segment>
    <segment id="108">;es).</segment>
    <segment id="109">Com US$ 68 bilh&amp;otilde</segment>
    <segment id="110">;es (R$ 359 bilh&amp;otilde</segment>
    <segment id="111">;es), principalmente de bancos privados</segment>
    <segment id="112">, os Estados Unidos responderam por 21%</segment>
    <segment id="113">, e Reino Unido</segment>
    <segment id="114">, por 7%.</segment>
    <segment id="115">Em contraste</segment>
    <segment id="116">, as entidades estatais chinesas investiram apenas US$ 50 bilh&amp;otilde</segment>
    <segment id="117">;es (R$ 264 bilh&amp;otilde</segment>
    <segment id="118">;es) em cinco anos (2015-2019).</segment>
    <segment id="119">A China manter&amp;aacute</segment>
    <segment id="120">; sua palavra?</segment>
    <segment id="121">O governo chin&amp;ecirc</segment>
    <segment id="122">;s sese comprometeu a &amp;quot</segment>
    <segment id="123">;tornar mais verdes&amp;quot</segment>
    <segment id="124">; seus investimentos estrangeiros</segment>
    <segment id="125">, ap&amp;oacute</segment>
    <segment id="126">;s as muitas cr&amp;iacute</segment>
    <segment id="127">;ticas &amp;agrave</segment>
    <segment id="128">;s novas usinas movidas a carv&amp;atilde</segment>
    <segment id="129">;o, que poriam em risco as metas clim&amp;aacute</segment>
    <segment id="130">;ticas globais.  &amp;quot</segment>
    <segment id="131">;A China passa lentamente de uma era (...)</segment>
    <segment id="132">, em que privilegiava arrecadar dinheiro&amp;quot</segment>
    <segment id="133">; e, &amp;quot</segment>
    <segment id="134">;agora</segment>
    <segment id="135">, sese move para melhorar a qualidade de seus projetos&amp;quot</segment>
    <segment id="136">;, disse Li Shuo.</segment>
    <segment id="137">O Minist&amp;eacute</segment>
    <segment id="138">;rio chin&amp;ecirc</segment>
    <segment id="139">;s do Com&amp;eacute</segment>
    <segment id="140">;rcio afirma que</segment>
    <segment id="141">, no primeiro semestre de 2021</segment>
    <segment id="142">, o pa&amp;iacute</segment>
    <segment id="143">;s n&amp;atilde</segment>
    <segment id="144">;o financiou novos projetos de centrais a carv&amp;atilde</segment>
    <segment id="145">;o, no &amp;acirc</segment>
    <segment id="146">;mbito das &amp;quot</segment>
    <segment id="147">;Novas Rotas da Seda&amp;quot</segment>
    <segment id="148">;, seu macroprojeto de infraestruturas no exterior.</segment>
    <segment id="149">Duas quest&amp;otilde</segment>
    <segment id="150">;es permanecem em aberto</segment>
    <segment id="151">, por&amp;eacute</segment>
    <segment id="152">;m, ap&amp;oacute</segment>
    <segment id="153">;s a promessa de Xi Jinping.</segment>
    <segment id="154">A partir de quando a medida ser&amp;aacute</segment>
    <segment id="155">; aplicada?</segment>
    <segment id="156">E ser&amp;atilde</segment>
    <segment id="157">;o bloqueados apenas investimentos de bancos p&amp;uacute</segment>
    <segment id="158">;blicos</segment>
    <segment id="159">, ou tamb&amp;eacute</segment>
    <segment id="160">;m privados?</segment>
    <segment id="161">Celebração dos 100 anos do Partido Comunista Chinês</segment>
    <segment id="162">; veja imagensMais    novamente         de   de  de  representando um  Menos carv&amp;atilde</segment>
    <segment id="163">;o na China?</segment>
    <segment id="164">A China havia prometido que alcan&amp;ccedil</segment>
    <segment id="165">;aria um teto de emiss&amp;otilde</segment>
    <segment id="166">;es de gases de efeito estufa at&amp;eacute</segment>
    <segment id="167">; 2030 e &amp;quot</segment>
    <segment id="168">;reduziria gradualmente&amp;quot</segment>
    <segment id="169">;</segment>
    <segment id="170">o uso de carv&amp;atilde</segment>
    <segment id="171">;o a partir de 2026.</segment>
    <segment id="172">O pa&amp;iacute</segment>
    <segment id="173">;s ainda depende muito dessa matriz energ&amp;eacute</segment>
    <segment id="174">;tica.</segment>
    <segment id="175">Em 2020</segment>
    <segment id="176">, acrescentou 38</segment>
    <segment id="177">,4 GigaWatts (GW) de energia baseada em carv&amp;atilde</segment>
    <segment id="178">;o, tr&amp;ecirc</segment>
    <segment id="179">;s vezes a capacidade instalada</segment>
    <segment id="180">, no referido ano</segment>
    <segment id="181">, em outros pa&amp;iacute</segment>
    <segment id="182">;ses, afirma a organiza&amp;ccedil</segment>
    <segment id="183">;&amp;atilde</segment>
    <segment id="184">;o americana Global Energy Monitor (GEM).</segment>
    <segment id="185">Segundo a ONG Greenpeace</segment>
    <segment id="186">, por&amp;eacute</segment>
    <segment id="187">;m, as prov&amp;iacute</segment>
    <segment id="188">;ncias chinesas aprovaram a constru&amp;ccedil</segment>
    <segment id="189">;&amp;atilde</segment>
    <segment id="190">;o de apenas 24 usinas a carv&amp;atilde</segment>
    <segment id="191">;o no primeiro semestre de 2021 (-79%</segment>
    <segment id="192">, em um ano).</segment>
    <segment id="193">&amp;quot;</segment>
    <segment id="194">Mas n&amp;atilde</segment>
    <segment id="195">;o</segment>
    <segment id="196">h&amp;aacute</segment>
    <segment id="197">; limite em rela&amp;ccedil</segment>
    <segment id="198">;&amp;atilde</segment>
    <segment id="199">;o &amp;agrave</segment>
    <segment id="200">;s emiss&amp;otilde</segment>
    <segment id="201">;es chinesas antes de reduzi-las&amp;quot</segment>
    <segment id="202">;, observou Yuan Jiahai</segment>
    <segment id="203">, da Universidade de Eletricidade do norte da China</segment>
    <segment id="204">, em Pequim.</segment>
    <segment id="205">&amp;</segment>
    <segment id="206">quot;Ou seja</segment>
    <segment id="207">, pode poluir tudo o que quiser antes do prazo-limite&amp;quot</segment>
    <segment id="208">;, completou.</segment>
  </rst>
</analysis>