  <rst>
    <segment id="1">Hunther S. Thompson</segment>
    <segment id="2">, aka Dr. Gonzo</segment>
    <segment id="3">, bateu todos os recordes possíveis de consumação etílica e junkie no universo dos escritores famosos.</segment>
    <segment id="4">Perto dele</segment>
    <segment id="5">, Hemingway é um garotinho na mamadeira e Burroughs um senhor distinto</segment>
    <segment id="6">, com alguns caprichos ilegais.</segment>
    <segment id="7">O sorriso insano</segment>
    <segment id="8">, a ironia selvagem e o senso de humor ácido eram suas ferramentas.</segment>
    <segment id="9">Alguns de seus alvos foram o ex-presidente Nixon ("ele podia apertar sua mão e te esfaquear nas costas ao mesmo tempo") e os Hell's</segment>
    <segment id="10">Angels</segment>
    <segment id="11">, pioneiros de gangues milicianas em duas rodas.</segment>
    <segment id="12">Seu livro mais famoso</segment>
    <segment id="13">, "Medo e Delírio em Las Vegas"</segment>
    <segment id="14">, surgiu quando tentava escrever sobre um jornalista morto pela polícia de Los Angeles.</segment>
    <segment id="15">Lançado em 1971</segment>
    <segment id="16">, começa num hotel em Beverly Hills</segment>
    <segment id="17">, onde seu alter ego está hospedado com "meu advogado".</segment>
    <segment id="18">Por que um advogado?</segment>
    <segment id="19">O drinque singapore sling</segment>
    <segment id="20">, clássico da coquetelaria</segment>
    <segment id="21">, provavelmente foi criado em Singapura pelo bartender chinês Ngiam Tong Boon no início do século 20 - Pixabay</segment>
    <segment id="22">A resposta está nos fundilhos do conversível em que viajam</segment>
    <segment id="23">, onde há um parque de diversões para adultos com saúde de cavalo.</segment>
    <segment id="24">O menu: maconha</segment>
    <segment id="25">, mescalina</segment>
    <segment id="26">, ácido</segment>
    <segment id="27">, cocaína</segment>
    <segment id="28">, "uma galáxia multicolorida de bolinhas</segment>
    <segment id="29">, anfetaminas e calmantes"</segment>
    <segment id="30">, tequila</segment>
    <segment id="31">, rum, éter e poppers.</segment>
    <segment id="32">Não satisfeitos</segment>
    <segment id="33">, vão ao lounge do hotel</segment>
    <segment id="34">, onde enfileiram singapore slings</segment>
    <segment id="35">, shots de mezcal e cerveja.</segment>
    <segment id="36">Até que aparece um telefone cor de rosa e Duke recebe a missão de cobrir um rali no deserto de Las Vegas.</segment>
    <segment id="37">O que chama a atenção no meio desse consumo desenfreado de substâncias é o singapore sling</segment>
    <segment id="38">, um coquetel antigo</segment>
    <segment id="39">, cheio de histórias desencontradas e mil receitas.</segment>
    <segment id="40">Curiosamente</segment>
    <segment id="41">, uma tradução antiga do livro coloca a piña colada na cena.</segment>
    <segment id="42">Está muito longe de ser a mesma coisa</segment>
    <segment id="43">, ainda que ambos tenham tintas equatoriais.</segment>
    <segment id="44">Tudo indica que o coquetel favorito de Dr. Gonzo foi criado pelo bartender chinês Ngiam Tong Boon</segment>
    <segment id="45">, no Raffles Hotel de Cingapura</segment>
    <segment id="46">, entre 1899 e 1915</segment>
    <segment id="47">, quando a Cidade dos Leões estava sob domínio britânico.</segment>
    <segment id="48">Entre as muitas estrelas que passaram pelo hotel estão Oscar Wilde</segment>
    <segment id="49">, Dorothy Parker e Aldous Huxley —imagine o que seria uma mesa reunindo os três e Hunter Thompson (</segment>
    <segment id="50">casocaso as datas nas lápides permitissem).</segment>
    <segment id="51">Não ia prestar.</segment>
    <segment id="52">Talvez falassem de Gina Lollobrigida</segment>
    <segment id="53">, que estampava capas de revistas cingapurianas nos anos 1950 e 60.</segment>
    <segment id="54">Hoje, o Long Bar do Raffles perdeu a doce penumbra da nostalgia</segment>
    <segment id="55">, tendo</segment>
    <segment id="56">sese rendido ao azáfama do serviço turístico.</segment>
    <segment id="57">Perdeu também a receita original do singapore sling de Boon</segment>
    <segment id="58">, possivelmente nos escombros da Segunda Guerra.</segment>
    <segment id="59">Continua</segment>
    <segment id="60">, contudo</segment>
    <segment id="61">contudo</segment>
    <segment id="62">, a preparar o drinque</segment>
    <segment id="63">, marca tão forte quanto o daiquiri do El Floridita (que a saudosa Lollobrigida conheceu quando fez um documentário sobre Fidel Castro.</segment>
    <segment id="64">Thompson também tentou entrevistar o líder revolucionário</segment>
    <segment id="65">, sem sucesso).</segment>
    <segment id="66">A receita teria sido anotada num guardanapo por um cliente e assim preservada das intempéries da história.</segment>
    <segment id="67">Soa como</segment>
    <segment id="68">como jogada de marketing e há quem sustente que o Raffles</segment>
    <segment id="69">sese aproveitou da onda Tiki para incluir o suco de abacaxi.</segment>
    <segment id="70">Mas quais seriam os melhores ingredientes na mistura?</segment>
    <segment id="71">Dr. Gonzo diria —e suspeito que Lollobrigida concordaria— que o importante é " curtir a vida loucamente</segment>
    <segment id="72">, sese apaixonar e não ser preso.</segment>
    <segment id="73">"  Anotado.</segment>
    <segment id="74">SINGAPORE SLING  45 ml de gim  7</segment>
    <segment id="75">,5 ml de licor de cereja  7</segment>
    <segment id="76">,5 ml de licor de laranja  7</segment>
    <segment id="77">,5 ml de Bénédictine DOM  7</segment>
    <segment id="78">,5 ml de grenadine  30 ml de suco fresco de abacaxi  20 ml de suco fresco de limão  1 lance de Angostura  60 ml de água com gás</segment>
    <segment id="79">Bata os oito primeiros ingredientes numa coqueteleira com gelo e coe para um copo highball com gelo.</segment>
    <segment id="80">Complete com água com gás e decore com cereja e abacaxi.</segment>
  </rst>
</analysis>