  <rst>
    <segment id="1">O temporal que arrasou o Rio de Janeiro neste fim de semana deixou um rastro de destruição e morte em Belford Roxo</segment>
    <segment id="2">, na Baixada Fluminense.</segment>
    <segment id="3">Uma pessoa morreu afogada e outra desapareceu após cair no rio Botas</segment>
    <segment id="4">, que transbordou.</segment>
    <segment id="5">No bairro Santa Maria</segment>
    <segment id="6">, próximo ao rio</segment>
    <segment id="7">, moradores contaram que perderam móveis e eletrodomésticos.</segment>
    <segment id="8">José de Souza</segment>
    <segment id="9">, 67, tinha água no portão de sua casa</segment>
    <segment id="10">, na tarde deste domingo (14).</segment>
    <segment id="11">"</segment>
    <segment id="12">Perdi tudo</segment>
    <segment id="13">, tudo"</segment>
    <segment id="14">, disse à reportagem.</segment>
    <segment id="15">Moradores usam barco para resgatar famílias ilhadas pela água em em Belford Roxo - Bruna Fantti/FolhapressEle afirmou que a água subiu tanto que chegou a cobrir seu carro.</segment>
    <segment id="16">Pelas ruas</segment>
    <segment id="17">, moradores levavam o que conseguiram salvar.</segment>
    <segment id="18">"É a segunda vez em um ano que perdi tudo</segment>
    <segment id="19">, geladeira</segment>
    <segment id="20">, cama</segment>
    <segment id="21">, armário.</segment>
    <segment id="22">Tinha comprado tudo após a chuva do ano passado"</segment>
    <segment id="23">, afirmou Ângelo de Sousa Marques</segment>
    <segment id="24">, que trabalha</segment>
    <segment id="25">comocomo bombeiro hidráulico em um hospital.</segment>
    <segment id="26">O mesmo drama viveu Sandra Virgínia dos Santos</segment>
    <segment id="27">, 66.</segment>
    <segment id="28">"</segment>
    <segment id="29">Perdi os armários e cama.</segment>
    <segment id="30">A geladeira ainda não liguei para saber</segment>
    <segment id="31">sese estragou.</segment>
    <segment id="32">Moro desde os dois anos aqui e todo ano</segment>
    <segment id="33">, basta chover</segment>
    <segment id="34">, acontece isso"</segment>
    <segment id="35">, afirmou.</segment>
    <segment id="36">Caminhado pela rua tomada por lama ao lado dos filhos</segment>
    <segment id="37">, ele levava um ventilador.</segment>
    <segment id="38">"</segment>
    <segment id="39">Só consegui tirar o ventilador.</segment>
    <segment id="40">Até o material escolar dos meninos eles perderam: mochila</segment>
    <segment id="41">, cadernos.</segment>
    <segment id="42">Vou para a casa da minha madrinha"</segment>
    <segment id="43">, disse.  Elizabeth Campello</segment>
    <segment id="44">, 44, vendedora de doces</segment>
    <segment id="45">, é outra vítima das chuvas.</segment>
    <segment id="46">Na sua casa</segment>
    <segment id="47">, a cama quebrou com a água.</segment>
    <segment id="48">"É a segunda vez em um ano que isso acontece</segment>
    <segment id="49">, de a água entrar.</segment>
    <segment id="50">Só os doces consegui salvar.</segment>
    <segment id="51">Toda minha comida</segment>
    <segment id="52">, eu perdi também</segment>
    <segment id="53">, estou sem nada"</segment>
    <segment id="54">, contou.</segment>
    <segment id="55">A cada esquina</segment>
    <segment id="56">, não era difícil encontrar pilhas de móveis quebrados e sujos empilhados.</segment>
    <segment id="57">Alguns moradores que tinham botes tentavam ajudar pessoas que estavam ilhadas em suas casas.</segment>
    <segment id="58">Um morador que ajudava a carregar um bote contou que estava desde a noite de sábado resgatando famílias.</segment>
    <segment id="59">O pastor Gilvan Rodrigues</segment>
    <segment id="60">, da igreja Vivendo em Triunfo</segment>
    <segment id="61">, distribuía doações.</segment>
    <segment id="62">"</segment>
    <segment id="63">Estamos desde a manhã distribuindo comida e material de limpeza que doaram na igreja.</segment>
    <segment id="64">Resgatamos também três famílias com um bote"</segment>
    <segment id="65">, disse.</segment>
    <segment id="66">Entre os resgatados estava um cachorro que foi deixado pelo dono após a água invadir a residência.</segment>
    <segment id="67">Até o fim da tarde</segment>
    <segment id="68">, algumas ruas ainda estavam cheias de água.</segment>
    <segment id="69">Na rua Vitorino Palhares</segment>
    <segment id="70">, moradores evitavam sair de casa</segment>
    <segment id="71">poispois</segment>
    <segment id="72">, com o nível de água alto</segment>
    <segment id="73">, apareceu um jacaré.</segment>
    <segment id="74">O animal estava dentro de uma residência.</segment>
    <segment id="75">A reportagem viu o momento em que ele mergulhou na enchente e saiu nadando pela rua.</segment>
    <segment id="76">Chuva deixa mortos</segment>
    <segment id="77">, alaga ruas</segment>
    <segment id="78">, inunda hospital e fecha estações de metrô no RioMais    novamente         de   de  de  representando um</segment>
  </rst>
</analysis>