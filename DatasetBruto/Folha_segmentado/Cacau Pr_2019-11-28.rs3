  <rst>
    <segment id="1">Mensagens vazadas entre um grupo de soldados do quartel central do Corpo de Bombeiros do Rio</segment>
    <segment id="2">sese referiram à atriz Cacau Protásio de forma grosseira.</segment>
    <segment id="3">Com farda da corporação e ao lado de quatro bailarinos</segment>
    <segment id="4">, ela gravou no local cenas para o filme “Juntos e Enrolados”.</segment>
    <segment id="5">“Olha a vergonha no pátio do quartel central.</segment>
    <segment id="6">Essa mulher do ‘Vai que Cola’</segment>
    <segment id="7">, aquela gorda</segment>
    <segment id="8">, colocou a farda e botou os dançarinos viados com roupa de bombeiro.</segment>
    <segment id="9">Isso é um esculacho</segment>
    <segment id="10">, rapaz.</segment>
    <segment id="11">Qual é a desse comandante?</segment>
    <segment id="12">”, dizia uma das mensagens.</segment>
    <segment id="13">Chateada</segment>
    <segment id="14">, Cacau lamentou o episódio e sua repercussão nas redes sociais</segment>
    <segment id="15">, o que gerou até ataques racistas.</segment>
    <segment id="16">O Corpo de Bombeiros emitiu nota para avisar que “</segment>
    <segment id="17">sese solidariza com a atriz e abriu procedimento interno para identificar o(s) militar(es) e apurar a conduta”.  DEIXA</segment>
    <segment id="18">A VIDA TE LEVAR</segment>
    <segment id="19">Sim, há quem viva</segment>
    <segment id="20">, e viva bem</segment>
    <segment id="21">, como</segment>
    <segment id="22">como Vivi Guedes</segment>
    <segment id="23">, a influenciadora digital interpretada por Paolla Oliveira na novela “</segment>
    <segment id="24">A Dona do Pedaço”.</segment>
    <segment id="25">Ao abrir o Instagram da musa fitness Gabriela Pugliesi</segment>
    <segment id="26">, com mais de 4 milhões de seguidores</segment>
    <segment id="27">, encontraremos vários posts patrocinados por dicas de suplementos vitamínicos e roteiros de viagens.</segment>
    <segment id="28">E ela ainda sai bonita na foto.</segment>
    <segment id="29">As gatas de novembroMais    novamente         de   de  de  representando um  FRASE    "</segment>
    <segment id="30">Controlo tudo pelo celular</segment>
    <segment id="31">, sou uma chata</segment>
    <segment id="32">, fico de olho em tudo.</segment>
    <segment id="33">A tecnologia faz com que a gente trabalhe o dia inteiro</segment>
    <segment id="34">, a demanda aumentou e passamos mais tempo no trabalho"  Taís Araújo à revista</segment>
    <segment id="35">Quem    AÇÃO</segment>
    <segment id="36">O DJ Alok criou uma vaquinha no valor de R$ 500 mil para financiar a construção de uma escola e um centro de saúde na aldeia de Muzumia</segment>
    <segment id="37">, em Moçambique.</segment>
    <segment id="38">Os apelos para doações feitos aos seus seguidores nas redes sociais já lhe renderam R$ 250 mil</segment>
    <segment id="39">, valor que ele foi levar pessoalmente até lá.    DESCANSO</segment>
    <segment id="40">Após mais de oito meses de gravações em “</segment>
    <segment id="41">A Dona do Pedaço</segment>
    <segment id="42">”</segment>
    <segment id="43">, Ary Fontoura fez a sua malinha e já chegou a Nova York</segment>
    <segment id="44">, onde curte merecidas férias.    'RIDÍCULO'  Viola Davis não</segment>
    <segment id="45">sese fez de rogada ao ser consultada sobre a possibilidade de Julia Roberts viver a abolicionista negra Harriet Tubman em uma cinebiografia.</segment>
    <segment id="46">À revista MadameNoire</segment>
    <segment id="47">, a atriz afirmou:</segment>
    <segment id="48">“É simples: Julia Roberts</segment>
    <segment id="49">comocomo Harriet Tubman é ridículo.</segment>
    <segment id="50">Isso quase não merece uma resposta.</segment>
    <segment id="51">”</segment>
  </rst>
