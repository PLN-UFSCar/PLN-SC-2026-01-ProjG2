  <rst>
    <segment id="1">Já sou velho o bastante para exigir que governos façam tudo o que quero</segment>
    <segment id="2">, ou, então</segment>
    <segment id="3">, porrada!</segment>
    <segment id="4">—</segment>
    <segment id="5">eventualmente engatando a máxima de Millôr Fernandes</segment>
    <segment id="6">, segundo a qual "imprensa é oposição</segment>
    <segment id="7">; o resto é armazém de secos &amp;amp</segment>
    <segment id="8">; molhados".</segment>
    <segment id="9">Sem contexto</segment>
    <segment id="10">, a divisa é uma tolice.</segment>
    <segment id="11">Quem, por "dever de oposição"</segment>
    <segment id="12">, atacou a recriação de programas sociais na gestão Lula comportou-</segment>
    <segment id="13">sese como</segment>
    <segment id="14">como cliente da...</segment>
    <segment id="15">vendinha bolsonarista.</segment>
    <segment id="16">Pode?</segment>
    <segment id="17">Mesmo no terreno das coisas lícitas (na hipótese de que sejam)</segment>
    <segment id="18">, "nem tudo me convém"</segment>
    <segment id="19">, como</segment>
    <segment id="20">como escreveu um certo Paulo.</segment>
    <segment id="21">Não sei em que ano Millôr fez tal afirmação</segment>
    <segment id="22">, masmas é provável que falte um regime militar</segment>
    <segment id="23">, ou sua herança</segment>
    <segment id="24">, para lhe conferir o sentido original.</segment>
    <segment id="25">Se jornalismo for só oposição</segment>
    <segment id="26">, então é partido.</segment>
    <segment id="27">Imprensa há de ser apego aos fatos</segment>
    <segment id="28">, sempre considerando que o viés ideológico é imanente à atividade já na definição da pauta.</segment>
    <segment id="29">E o jornalismo fotográfico?</segment>
    <segment id="30">Lembro as reflexões de Roland Barthes em "</segment>
    <segment id="31">A Câmara Clara</segment>
    <segment id="32">"</segment>
    <segment id="33">, seu último livro.</segment>
    <segment id="34">Ele chama a atenção para o "punctum" — o ponto</segment>
    <segment id="35">, o pedaço de um todo —</segment>
    <segment id="36">, que o fotógrafo não viu e que só ganha sentido pelos olhos do "spectator"</segment>
    <segment id="37">, do "contemplador".</segment>
    <segment id="38">Também no</segment>
    <segment id="39">casocaso de um texto</segment>
    <segment id="40">, é impossível saber exatamente o que lê um leitor.</segment>
    <segment id="41">O presidente Lula durante cerimônia na base aérea de Brasília - Gabriela Biló - 20.jul.23/FolhapressQuando</segment>
    <segment id="42">sese entra na seara da opinião</segment>
    <segment id="43">, as coisas</segment>
    <segment id="44">sese complicam.</segment>
    <segment id="45">Afinal</segment>
    <segment id="46">, o analista parte de um recorte</segment>
    <segment id="47">, ditado por seu conjunto de valores</segment>
    <segment id="48">;</segment>
    <segment id="49">é dotado de quereres e faz prefigurações.</segment>
    <segment id="50">No capítulo das previsões</segment>
    <segment id="51">, pode-</segment>
    <segment id="52">sese estabelecer alguma medida objetiva: ou aconteceu ou não aconteceu aquilo que ele anteviu</segment>
    <segment id="53">comocomo fatal.</segment>
    <segment id="54">Parece-me que parte dos analistas econômicos anda a operar com uma margem de erro bastante superior à dos astrólogos.</segment>
    <segment id="55">Como estes atuam na esfera da linguagem simbólica e profetizam no território das metáforas e dos conceitos consolidados (sabemos</segment>
    <segment id="56">comocomo é um leonino...)</segment>
    <segment id="57">, é, definitivamente</segment>
    <segment id="58">, o "spectator" quem determina o conteúdo de uma predição astrológica</segment>
    <segment id="59">, sempre uma "obra aberta".</segment>
    <segment id="60">Pergunto-me</segment>
    <segment id="61">sese, na ânsia de fugir do "armazém de secos &amp;amp</segment>
    <segment id="62">; molhados" —e Millôr não tem nada com isso—</segment>
    <segment id="63">, a objetividade possível não está sendo muitas vezes ignorada em nome de convicções e vocações missionárias</segment>
    <segment id="64">, como</segment>
    <segment id="65">como se</segment>
    <segment id="66">se a política brasileira devesse ser submetida a uma espécie de expedição civilizatória</segment>
    <segment id="67">, ditada pela Razão</segment>
    <segment id="68">, a maiúscula</segment>
    <segment id="69">, oriunda do Empíreo.</segment>
    <segment id="70">Ou do "Manual do Perfeito Idiota Liberal Latino-Americano".</segment>
    <segment id="71">Quem perde é a precisão.</segment>
    <segment id="72">Márcia Sensitiva antecipou sobre Lula e seu governo</segment>
    <segment id="73">, no canal "Diva Depressão"</segment>
    <segment id="74">, no dia 30 de dezembro de 2022:</segment>
    <segment id="75">"Ele estava no ano sete e vai entrar no oito no ano que vem.</segment>
    <segment id="76">São os dois melhores anos da vida dele pra grana</segment>
    <segment id="77">, pra sorte</segment>
    <segment id="78">, pra tudo.</segment>
    <segment id="79">(...) Eu só sei que ele vai ter de</segment>
    <segment id="80">sese tratar muito a partir do meio do ano</segment>
    <segment id="81">, tá?</segment>
    <segment id="82">(...)</segment>
    <segment id="83">Depois de abril</segment>
    <segment id="84">, as coisas melhoram para o Brasil.</segment>
    <segment id="85">Você imagina o sistema nervoso de um homem desse</segment>
    <segment id="86">, ainda mais que ele é do signo de escorpião (...).</segment>
    <segment id="87">No começo</segment>
    <segment id="88">, a gente vai dançar um pouco</segment>
    <segment id="89">, masmas as coisas entram no eixo".</segment>
    <segment id="90">Até aqui</segment>
    <segment id="91">, acertou mais do que algumas Cassandras às avessas</segment>
    <segment id="92">, especialistas no próprio método.</segment>
    <segment id="93">Uma análise é sempre parcial</segment>
    <segment id="94">, como</segment>
    <segment id="95">como deixo claro.</segment>
    <segment id="96">Mas não pode ser arbitrária.</segment>
    <segment id="97">No meu "</segment>
    <segment id="98">De Senectute" particular</segment>
    <segment id="99">, relevo os limites da realidade e justifico sem sofismas</segment>
    <segment id="100">, por exemplo</segment>
    <segment id="101">, a eventual entrada do PP e do Republicanos no governo.</segment>
    <segment id="102">Para quê?</segment>
    <segment id="103">Fosse para um biltre</segment>
    <segment id="104">sese livrar do impeachment</segment>
    <segment id="105">, este levaria porrada</segment>
    <segment id="106">, como</segment>
    <segment id="107">como já levou.</segment>
    <segment id="108">Se for para aprovar reformas que ficariam pelo meio do caminho sem o centrão</segment>
    <segment id="109">, que se</segment>
    <segment id="110">se faça.</segment>
    <segment id="111">Na lojinha de que sou freguês</segment>
    <segment id="112">, inexiste sonho sem feijão.</segment>
    <segment id="113">Para registro: já critiquei duramente</segment>
    <segment id="114">, no passado</segment>
    <segment id="115">, o economista Marcio Pochmann e não vejo ainda motivos para elogiá-lo.</segment>
    <segment id="116">Se e quando vir</segment>
    <segment id="117">, eu o farei.</segment>
    <segment id="118">Mas evocar até risco de "argentinização"</segment>
    <segment id="119">porque</segment>
    <segment id="120">porque ele vai assumir a presidência do IBGE e poderia</segment>
    <segment id="121">, especula-</segment>
    <segment id="122">sese, manipular números da economia é um despropósito.</segment>
    <segment id="123">Querem o quê?</segment>
    <segment id="124">A impossível prova da inocência antes mesmo do eventual crime?</segment>
    <segment id="125">Ademais</segment>
    <segment id="126">, o Brasil dispõe de instrumentos vários para detectar eventuais distorções.</segment>
    <segment id="127">Quem tratou o instituto aos chutes —o Censo só foi realizado por ordem do STF— foi Paulo Guedes</segment>
    <segment id="128">, a serviço do balcão bolsonarista de quinquilharias.</segment>
    <segment id="129">Não se</segment>
    <segment id="130">se ouviu metade da gritaria de agora.</segment>
    <segment id="131">Pode?</segment>
    <segment id="132">Pode.</segment>
    <segment id="133">Mas, mesmo no terreno das coisas lícitas</segment>
    <segment id="134">, "nem tudo me convém".</segment>
    <segment id="135">Censo - IBGE realiza mutirão por recenseamento em bairros de alta rendaMais    novamente         de   de  de  representando</segment>
    <segment id="136">um</segment>
  </rst>
</analysis>