  <rst>
    <segment id="1">Vice-presidente da Câmara Municipal de São Paulo</segment>
    <segment id="2">,</segment>
    <segment id="3">o vereador João Jorge (PSDB) afirma que o Legislativo paulistano e a Arquidiocese de São Paulo não têm "nada a ganhar</segment>
    <segment id="4">sese baterem de frente".</segment>
    <segment id="5">Ele afirma ao Painel que</segment>
    <segment id="6">, caso</segment>
    <segment id="7">caso o vereador Rubinho Nunes (União Brasil) insista em vincular a CPI das ONGs que protocolou em dezembro ao padre Júlio Lancellotti</segment>
    <segment id="8">, recorrerá ao presidente da Câmara</segment>
    <segment id="9">, Milton Leite (União Brasil)</segment>
    <segment id="10">, para que</segment>
    <segment id="11">para que ela não seja instalada.</segment>
    <segment id="12">O órgão da Igreja Católica afirmou acompanhar "com perplexidade" a possível abertura da investigação.</segment>
    <segment id="13">João Jorge (PSDB)</segment>
    <segment id="14">, vice-presidente da Câmara Municipal de SP</segment>
    <segment id="15">, durante evento na capital - Ronny Santos-13.jun.2022/FolhapressNunes protocolou o pedido de abertura de CPI em dezembro</segment>
    <segment id="16">, com assinaturas de 24 vereadores</segment>
    <segment id="17">, e recebeu sinalização positiva de parte da cúpula da Câmara sobre sua instalação em fevereiro.</segment>
    <segment id="18">No entanto</segment>
    <segment id="19">, diante da forte repercussão contra a CPI</segment>
    <segment id="20">, vereadores têm retirado apoio.</segment>
    <segment id="21">Ela ainda precisa ser apreciada no colégio de líderes e em plenário</segment>
    <segment id="22">para que</segment>
    <segment id="23">para que seja instalada.</segment>
    <segment id="24">Jorge afirma que é contra qualquer afronta a instituições religiosas e que assinou o pedido de CPI das ONGs que atuam na região central de São Paulo sem ter sido informado de qualquer vinculação ao padre Júlio Lancellotti.</segment>
    <segment id="25">Nas redes sociais e em entrevistas</segment>
    <segment id="26">, Rubinho Nunes coloca o padre</segment>
    <segment id="27">comocomo principal alvo.</segment>
    <segment id="28">O tucano afirma que</segment>
    <segment id="29">, caso</segment>
    <segment id="30">caso o colega mantenha a ideia de voltar a CPI contra o pároco</segment>
    <segment id="31">, ele pode pedir a retirada de sua assinatura em apoio à criação da comissão.</segment>
    <segment id="32">O padre afirmou à coluna que não faz parte de nenhuma ONG e não tem qualquer envolvimento com projetos que envolvam dinheiro público</segment>
    <segment id="33">, e que</segment>
    <segment id="34">, por isso</segment>
    <segment id="35">, não vê sentido em ser investigado.</segment>
    <segment id="36">"</segment>
    <segment id="37">Se eu for chamado a falar</segment>
    <segment id="38">, de que ONG vão falar que eu sou?</segment>
    <segment id="39">Ou, se</segment>
    <segment id="40">se me convocarem</segment>
    <segment id="41">, estarão convocando a Arquidiocese de São Paulo.</segment>
    <segment id="42">A minha ação é da arquidiocese</segment>
    <segment id="43">, que não é ONG e não é conveniada com a prefeitura.</segment>
    <segment id="44">Não vão encontrar dinheiro público em nenhuma das ações"</segment>
    <segment id="45">, afirma.  "</segment>
    <segment id="46">O que a Câmara pode fazer é fiscalizar dinheiro público.</segment>
    <segment id="47">Não existe CPI para fiscalizar a igreja"</segment>
    <segment id="48">, acrescenta.</segment>
  </rst>
</analysis>