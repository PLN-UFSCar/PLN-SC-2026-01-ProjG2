  <rst>
    <segment id="1">Kafta é uma variação da palavra persa kūfta</segment>
    <segment id="2">, que significa bater e moer.</segment>
    <segment id="3">Os kaftas podem ser preparados com carne bovina</segment>
    <segment id="4">, de cordeiro ou de frango</segment>
    <segment id="5">, e até em receitas vegetarianas.</segment>
    <segment id="6">O grande diferencial de um kafta para os espetinhos de carne moída está no tempero —sua origem é no Oriente Médio</segment>
    <segment id="7">, berço das especiarias</segment>
    <segment id="8">, onde</segment>
    <segment id="9">sese utiliza muito cominho</segment>
    <segment id="10">, coentro</segment>
    <segment id="11">, pimentas</segment>
    <segment id="12">, cravo</segment>
    <segment id="13">, canela</segment>
    <segment id="14">, entre outros.</segment>
    <segment id="15">O kafta pode ser servido cru</segment>
    <segment id="16">, grelhado na frigideira</segment>
    <segment id="17">, na brasa</segment>
    <segment id="18">, ou assado no forno.</segment>
    <segment id="19">Vai bem</segment>
    <segment id="20">comocomo aperitivo</segment>
    <segment id="21">, prato principal acompanhado de batatas</segment>
    <segment id="22">, tomates</segment>
    <segment id="23">, cebolas e arroz com macarrão cabelo de anjo frito</segment>
    <segment id="24">, ou como</segment>
    <segment id="25">como lanche no pão sírio com alface</segment>
    <segment id="26">, tomate</segment>
    <segment id="27">, cebola</segment>
    <segment id="28">, homus e pasta de alho.</segment>
    <segment id="29">Hoje, trago minha versão deste clássico: kafta com um chimichurri de hortelã.</segment>
    <segment id="30">Bom apetite!</segment>
    <segment id="31">Kafta com chimichurri de hortelã</segment>
    <segment id="32">, com receita de Larissa Morales - Larissa Morales Kafta com chimichurri de hortelã  INGREDIENTES</segment>
    <segment id="33">1 kg de carne moída.</segment>
    <segment id="34">1 colher de sopa de pimenta síria.</segment>
    <segment id="35">1 colher de sopa de salsinha picada.  ½ cebola ralada.  1/2 xícara de cebolinha picada.  1 xícara de hortelã picado.  1 cebola roxa picada.</segment>
    <segment id="36">3 dentes de alho picados.</segment>
    <segment id="37">1 colher de sopa de pimenta calabresa.</segment>
    <segment id="38">Suco de 1 limão.</segment>
    <segment id="39">200 ml de azeite.</segment>
    <segment id="40">Sal a gosto.</segment>
    <segment id="41">Espetos de bambu.</segment>
    <segment id="42">Aprenda a preparar espetinho de peixeMais    novamente         de   de  de  representando um  PREPARO</segment>
    <segment id="43">Coloque os espetos de madeira de molho em água por 10 minutos</segment>
    <segment id="44">, para não queimar na hora de levar à brasa.</segment>
    <segment id="45">Junte a carne moída com a pimenta síria</segment>
    <segment id="46">, cebola ralada</segment>
    <segment id="47">, 1 colher de sopa de salsinha picada</segment>
    <segment id="48">, 1 colher de sopa de cebolinha picada</segment>
    <segment id="49">, 1 colher de sopa de cebola picada</segment>
    <segment id="50">, 1 dente de alho picado e sal.</segment>
    <segment id="51">Misture bem os ingredientes e molde a carne nos espetos de bambu.</segment>
    <segment id="52">Leve para a brasa alta por 2 minutos cada lado.</segment>
    <segment id="53">Para o chimichurri</segment>
    <segment id="54">, junte o restante da cebolinha e do alho</segment>
    <segment id="55">, o hortelã</segment>
    <segment id="56">, a cebola e macere bem com a ajuda de uma faca</segment>
    <segment id="57">, ou no pilão</segment>
    <segment id="58">, para que</segment>
    <segment id="59">para que o tempero fique</segment>
    <segment id="60">comocomo uma pasta.</segment>
    <segment id="61">Acrescente a pimenta calabresa</segment>
    <segment id="62">, o suco de limão</segment>
    <segment id="63">, o sal e junte o azeite.</segment>
    <segment id="64">Misture até ficar homogêneo e sirva com o kafta.</segment>
  </rst>
</analysis>