  <rst>
    <segment id="1">A mais completa vacina contra a meningite</segment>
    <segment id="2">, que protege contra os tipos</segment>
    <segment id="3">A, C, W e Y</segment>
    <segment id="4">, enfrenta problemas de abastecimento e distribuição há pelo menos três anos.</segment>
    <segment id="5">A dose da imunização pode custar R$ 500 e só é encontrada em clínicas particulares.</segment>
    <segment id="6">“</segment>
    <segment id="7">A vacina é produzida de acordo com a demanda.</segment>
    <segment id="8">Você faz um planejamento do que vai vender de meningite do tipo B em 2020 e pede em 2019.</segment>
    <segment id="9">Se em 2020 houver um surto ou uma demanda inesperada</segment>
    <segment id="10">, não teremos reposição de estoque"</segment>
    <segment id="11">, diz Geraldo Barbosa</segment>
    <segment id="12">, presidente da ABCVAC (Associação Brasileira das Clínicas de Vacinas).</segment>
    <segment id="13">“</segment>
    <segment id="14">A gente sempre é pego de surpresa.</segment>
    <segment id="15">"</segment>
    <segment id="16">Bebê toma vacina na UBS Dona Mariquinha Sciáscia</segment>
    <segment id="17">, na zona norte de São Paulo - Eduardo Anizelli/Folhapress  Um dos exemplos de corrida às clínicas de vacinação ocorreu na semana passada</segment>
    <segment id="18">, com a morte por meningite meningocócica de Arthur Araújo Lula da Silva</segment>
    <segment id="19">, 7, neto do ex-presidente do Lula.</segment>
    <segment id="20">As buscas no Google por meningite meningocócica cresceram 4.000% na última semana</segment>
    <segment id="21">, e pesquisas sobre vacinas contra a infecção tiveram crescimento de 2.600%.</segment>
    <segment id="22">Outro problema</segment>
    <segment id="23">, de acordo com Barbosa</segment>
    <segment id="24">, é a concentração de oferta da imunização em grandes centros</segment>
    <segment id="25">, com a consequente falta de acesso em áreas mais isoladas.</segment>
    <segment id="26">Por fim</segment>
    <segment id="27">, o presidente da ABCVAC também afirma que os prazos de validade das doses têm sido reduzidos</segment>
    <segment id="28">, o que impossibilitaria a construção de um estoque para momentos de escassez.</segment>
    <segment id="29">“</segment>
    <segment id="30">Com um produto de valor agregado alto</segment>
    <segment id="31">, fica difícil fazer estoque.</segment>
    <segment id="32">”</segment>
    <segment id="33">O custo alta da vacina meningocócica ACWY pode ser explicado pela sua complexidade.</segment>
    <segment id="34">“É como</segment>
    <segment id="35">como quatro vacinas em uma só”</segment>
    <segment id="36">, diz Isabella Ballalai</segment>
    <segment id="37">, vice-presidente da Sbim (Sociedade Brasileira de Imunizações).</segment>
    <segment id="38">Além disso</segment>
    <segment id="39">, entra em jogo a disputa internacional pela imunização</segment>
    <segment id="40">, que é produzida por indústrias fora do Brasil.</segment>
    <segment id="41">Nesses casos</segment>
    <segment id="42">, os laboratórios enviam seus lotes para quem pagar mais</segment>
    <segment id="43">, diz Ballalai.</segment>
    <segment id="44">Todos esses fatores ajudam explicar a dificuldade de encontrar a vacina nas clínicas.</segment>
    <segment id="45">Entre as farmacêuticas que produzem a vacina conjugada</segment>
    <segment id="46">, somente a GSK (GlaxoSmithKline) afirma ter tido problemas de distribuição.</segment>
    <segment id="47">“</segment>
    <segment id="48">O fornecimento da vacina ACWY</segment>
    <segment id="49">, Menveo</segment>
    <segment id="50">, durante o ano de 2018</segment>
    <segment id="51">, foi menor do que a demanda e esperamos que a situação da oferta da vacina em questão melhore no segundo semestre de 2019”</segment>
    <segment id="52">, disse a GSK em nota.</segment>
    <segment id="53">Segundo a GSK</segment>
    <segment id="54">, atrasos e interrupções temporárias de algumas linhas de produção da vacina foram causados pela “complexidade de produção e da necessidade de harmonização de processos fabris</segment>
    <segment id="55">, após a aquisição do negócio vacinas da Novartis</segment>
    <segment id="56">, pela GSK”.</segment>
    <segment id="57">A Sanofi Pasteur</segment>
    <segment id="58">, que produz a vacina Menactra</segment>
    <segment id="59">, afirma que a vacina teve abastecimento constante nas clínicas em 2018 e em 2019.</segment>
    <segment id="60">A Pfizer</segment>
    <segment id="61">, que adquiriu a vacina Nimenrix do laboratório GSK</segment>
    <segment id="62">, diz que está em processo de transferência de produção e que o fornecimento da vacina responde à demanda.</segment>
    <segment id="63">No entanto</segment>
    <segment id="64">, não é só a vacina conjugada ACWY que</segment>
    <segment id="65">, segundo especialistas</segment>
    <segment id="66">, tem problemas de distribuição.</segment>
    <segment id="67">A imunização contra meningite tipo C</segment>
    <segment id="68">, que está disponível no SUS e combate o sorogrupo majoritário (75% dos casos) no país</segment>
    <segment id="69">, também teve seu fornecimento comprometido no ano passado.</segment>
    <segment id="70">Como a Folha noticiou</segment>
    <segment id="71">, em 2018</segment>
    <segment id="72">, o país apresentava situação “crítica” no abastecimento.</segment>
    <segment id="73">O Ministério da Saúde afirma que a falha na distribuição das doses da vacina ocorreu devido a atrasos na entrega por parte da Fundação Ezequiel Dias (Funed).</segment>
    <segment id="74">A pasta afirma que recorreu à Opas (Organização Pan-americana da Saúde) para buscar a vacina em produtores internacionais</segment>
    <segment id="75">, masmas não teve sucesso.</segment>
    <segment id="76">Em nota</segment>
    <segment id="77">, o ministério afirma que em 2019 já encaminhou 1</segment>
    <segment id="78">,7 milhão de doses da vacina aos postos de saúde e que a remessa de março corresponderá a 100% do solicitado pelos estados.</segment>
    <segment id="79">Em todo o ano de 2018 foram 9</segment>
    <segment id="80">,8 milhões de doses.</segment>
    <segment id="81">A incorporação ao calendário nacional do SUS da vacina conjugada ACWY</segment>
    <segment id="82">, recomendada pela Sbim e pela Sociedade Brasileira de Pediatria</segment>
    <segment id="83">, está nos planos do ministério</segment>
    <segment id="84">, que no momento diz estar estudando formas de aquisição e o cronograma de distribuição.</segment>
    <segment id="85">A inclusão</segment>
    <segment id="86">, contudo</segment>
    <segment id="87">contudo</segment>
    <segment id="88">, é complexa</segment>
    <segment id="89">, principalmente por conta das grandes quantidades de doses necessárias para o país e</segment>
    <segment id="90">, por isso</segment>
    <segment id="91">, deve ser conduzida de modo planejado para evitar problemas</segment>
    <segment id="92">, principalmente pensando nas reclamações em relação ao abastecimento</segment>
    <segment id="93">, diz Ballalai.</segment>
    <segment id="94">“Seria uma irresponsabilidade oferecer a vacina sem tê-la.</segment>
    <segment id="95">”  Além disso</segment>
    <segment id="96">, a especialista afirma que só a oferta de uma nova vacina não garante proteção à população.</segment>
    <segment id="97">Ainda que a vacina contra o tipo C esteja disponível gratuitamente no SUS</segment>
    <segment id="98">, as taxas de coberturas são de 86</segment>
    <segment id="99">,58% (2017) e de 79</segment>
    <segment id="100">,04% (dados preliminares de 2018).</segment>
    <segment id="101">O ideal é que</segment>
    <segment id="102">sese chegue a 95%.</segment>
    <segment id="103">A vacinação contra meningite em adolescentes</segment>
    <segment id="104">, que também está disponível na rede pública</segment>
    <segment id="105">, é importante para evitar a circulação da doença.</segment>
    <segment id="106">Nesse segmento da população</segment>
    <segment id="107">, porém</segment>
    <segment id="108">porém, as taxas de cobertura são ainda menores.</segment>
    <segment id="109">“Ainda não está na cabeça da população a vacinação de adolescentes”</segment>
    <segment id="110">, diz Ballalai.</segment>
    <segment id="111">“Só vamos ver adolescente vacinado adequadamente quando tivermos a vacinação escolar de rotina.</segment>
    <segment id="112">Países que vacinam rotineiramente esse grupo nas escolas têm boas coberturas.</segment>
    <segment id="113">”     VACINAS CONTRA MENINGITE</segment>
    <segment id="114">Ao nascer</segment>
    <segment id="115">Na rede pública   BCG (Bacilo Calmette-Guerin).</segment>
    <segment id="116">Previne as formas graves de tuberculose</segment>
    <segment id="117">, principalmente miliar e meníngea   Aos 2 meses</segment>
    <segment id="118">Na rede pública</segment>
