  <rst>
    <segment id="1">Pabllo Vittar é uma entidade noturna em seu novo disco</segment>
    <segment id="2">, "Noitada".</segment>
    <segment id="3">"</segment>
    <segment id="4">Eu pertenço à noite assim</segment>
    <segment id="5">comocomo pertenço a você"</segment>
    <segment id="6">, diz a cantora</segment>
    <segment id="7">, com sensualidade</segment>
    <segment id="8">, na faixa de abertura</segment>
    <segment id="9">, como</segment>
    <segment id="10">como se</segment>
    <segment id="11">se desse uma piscadela ao ouvinte.</segment>
    <segment id="12">O álbum</segment>
    <segment id="13">, que mistura funk</segment>
    <segment id="14">, pop e eletrônico</segment>
    <segment id="15">, percorre os prazeres da escuridão com músicas sensuais cheias de trocadilhos eróticos.</segment>
    <segment id="16">Pabllo está cheia de tesão acumulado.</segment>
    <segment id="17">O disco</segment>
    <segment id="18">, que será lançado no próximo dia 8</segment>
    <segment id="19">, serve também</segment>
    <segment id="20">comocomo uma saudação às boates LGBTQIA+</segment>
    <segment id="21">, onde a arte drag queen desabrocha antes de ganhar os palcos do mundo.</segment>
    <segment id="22">Pabllo quer incendiar as pistas e</segment>
    <segment id="23">sese lembrar da época em que cantava para poucas pessoas em palquinhos num desses inferninhos em que foi descoberta em Uberlândia</segment>
    <segment id="24">, em Minas Gerais</segment>
    <segment id="25">, antes de ser alçada ao estrelato.</segment>
    <segment id="26">Pabllo Vittar em cartaz de divulgação de seu novo disco</segment>
    <segment id="27">, &amp;#039</segment>
    <segment id="28">;Noitada&amp;#039</segment>
    <segment id="29">; - DivulgaçãoÉ com a ajuda de Gloria Groove que ela abre as portas da festa em "Ameianoite"</segment>
    <segment id="30">, a segunda faixa do disco.</segment>
    <segment id="31">As drags viram bruxas e evocam o misticismo das sombras —de um jeito bem brasileiro</segment>
    <segment id="32">, é claro.</segment>
    <segment id="33">"</segment>
    <segment id="34">Abracadabra</segment>
    <segment id="35">, tu toma</segment>
    <segment id="36">sentada/ surra bem dada que você não esquece/ não sou Wandinha nem sou a Sabrina/ esse é o mundo sombrio de Lady Leste"</segment>
    <segment id="37">, canta Gloria.</segment>
    <segment id="38">Mas é só na faixa seguinte</segment>
    <segment id="39">, "Descontrolada"</segment>
    <segment id="40">, que a noitada começa de verdade.</segment>
    <segment id="41">A funkeira MC Carol empresta seus berros contagiantes para um pop funk do tipo que Pabllo estava afastada nos seus últimos lançamentos.</segment>
    <segment id="42">No clipe</segment>
    <segment id="43">, as duas</segment>
    <segment id="44">sese encontram numa balada com muito álcool e bateção de bunda.</segment>
    <segment id="45">"Descontrolada"</segment>
    <segment id="46">, aliás</segment>
    <segment id="47">, foi lançada</segment>
    <segment id="48">comocomo single no final do ano passado numa tentativa de aplacar os desejos de uma parcela de fãs que pediam pelo amor de Deus</segment>
    <segment id="49">para que</segment>
    <segment id="50">para que a drag queen voltasse para a farofada.</segment>
    <segment id="51">Veja imagens da cantora Pabllo Vittar Mais    novamente         de   de  de  representando um</segment>
    <segment id="52">Em "Noitada"</segment>
    <segment id="53">, ela cede a esses pedidos.</segment>
    <segment id="54">Mas isso não faz com que este seja um disco genérico.</segment>
    <segment id="55">Longe disso.</segment>
    <segment id="56">Não tem o forrozão original dos seus hits "K.O."</segment>
    <segment id="57">, e "Amor de Que"</segment>
    <segment id="58">, é verdade</segment>
    <segment id="59">, masmas traz uma mistureba dançante que soa</segment>
    <segment id="60">comocomo novidade.</segment>
    <segment id="61">Bons exemplos são faixas que Pabllo canta com Anitta.</segment>
    <segment id="62">A parceria entre as duas</segment>
    <segment id="63">, que deu tão certo em "Sua Cara" e "Modo Turbo" ganha dose dupla em "Noitada".</segment>
    <segment id="64">"Calma Amiga" tem só um minuto de duração</segment>
    <segment id="65">, masmas soa deliciosamente despretensiosa.</segment>
    <segment id="66">"</segment>
    <segment id="67">Quero sair</segment>
    <segment id="68">, dançar</segment>
    <segment id="69">, beijar</segment>
    <segment id="70">, me esfregar</segment>
    <segment id="71">, ‘fulerar’"</segment>
    <segment id="72">, diz a drag queen</segment>
    <segment id="73">, ao que Anitta responde com palavrões.</segment>
    <segment id="74">"</segment>
    <segment id="75">Ai, caralho</segment>
    <segment id="76">, eu estou chapada"</segment>
    <segment id="77">, canta Pabllo no fim</segment>
    <segment id="78">, num tom psicodélico.</segment>
    <segment id="79">Veja fotos do show de Pabllo Vittar no Lollapalooza 2022Mais    novamente         de   de  de  representando um  Ela está mais ousada do que nunca.</segment>
    <segment id="80">"</segment>
    <segment id="81">Há dois anos</segment>
    <segment id="82">, jamais falaria um ‘caralho’ em alguma música.</segment>
    <segment id="83">Os meus outros álbuns são feitos para a família ouvir em todos os lugares"</segment>
    <segment id="84">, diz Pabllo em entrevista a este jornal.</segment>
    <segment id="85">"</segment>
    <segment id="86">Neste álbum</segment>
    <segment id="87">, já estou bem mais explícita e falando</segment>
    <segment id="88">comocomo tenho me sentindo de verdade.</segment>
    <segment id="89">"</segment>
    <segment id="90">Anitta volta a a aparecer na erótica "Balinha de Coração"</segment>
    <segment id="91">, em que menciona dedos melados e corpos arrepiados.</segment>
    <segment id="92">"</segment>
    <segment id="93">Prova minha balinha que é de coração/ derrete na boca e te dá tesão/ hoje eu vou te dar</segment>
    <segment id="94">, não acostuma não"</segment>
    <segment id="95">, cantam elas no refrão.</segment>
    <segment id="96">São músicas diferentes do hit "</segment>
    <segment id="97">Sua Cara</segment>
    <segment id="98">"</segment>
    <segment id="99">, lançado pela dupla com o Major Lazer em 2017 e que até hoje faz o público rebolar sem parar.</segment>
    <segment id="100">Os fãs mais saudosistas devem calibrar as expectativas para não</segment>
    <segment id="101">sese decepcionarem com o resultado da faixa.</segment>
    <segment id="102">"</segment>
    <segment id="103">A gente queria o oposto de ‘Sua Cara’"</segment>
    <segment id="104">, diz Pabllo.</segment>
    <segment id="105">"</segment>
    <segment id="106">As referências de ‘Balinha’ são outras coisas —vêm do funk</segment>
    <segment id="107">, da PC music</segment>
    <segment id="108">, do eletrônico.</segment>
    <segment id="109">"</segment>
    <segment id="110">As cantoras Pabllo Vittar e Anitta no lançamento do clipe &amp;#039</segment>
    <segment id="111">;Sua Cara&amp;#039</segment>
    <segment id="112">;, no Rio de Janeiro - Criz Veronez/FolhapressO tom libidinoso volta a aparecer na letra da faixa seguinte.</segment>
    <segment id="113">Em "Penetra"</segment>
    <segment id="114">, Pabllo brinca de novo com o sexo gay ao invadir uma festa para a qual não foi convidada.</segment>
    <segment id="115">"</segment>
    <segment id="116">Eu entro de penetra"</segment>
    <segment id="117">, canta</segment>
    <segment id="118">, entre gemidos.</segment>
    <segment id="119">"</segment>
    <segment id="120">Eu já tô entrando</segment>
    <segment id="121">, vou penetrando"</segment>
    <segment id="122">, repete Dan Kanalha</segment>
    <segment id="123">, o vocalista da banda de pagode baiano</segment>
    <segment id="124">O Kannalha.</segment>
    <segment id="125">Pabllo</segment>
    <segment id="126">, então</segment>
    <segment id="127">, geme ainda mais alto.</segment>
    <segment id="128">A drag queen continua sua ode ao sexo em "Apetitosa"</segment>
    <segment id="129">, música que traz MC Tchelinho e DJ Tonias.</segment>
    <segment id="130">Aqui é</segment>
    <segment id="131">comocomo</segment>
    <segment id="132">sese Pabllo tivesse saído da pista</segment>
    <segment id="133">, já muito bêbada</segment>
    <segment id="134">, para</segment>
    <segment id="135">sese encarar no espelho.</segment>
    <segment id="136">A manhã está</segment>
    <segment id="137">sese aproximando</segment>
    <segment id="138">, masmas a drag queen está no auge do tesão.</segment>
    <segment id="139">Avista</segment>
    <segment id="140">uma camisinha</segment>
    <segment id="141">e sese descontrola quando o boy sussurra em seu ouvido.</segment>
    <segment id="142">"</segment>
    <segment id="143">Deixa eu fazer bem gostoso/ sabe que eu te arrepio/ tu pede</segment>
    <segment id="144">, tu toma de novo"</segment>
    <segment id="145">, canta.</segment>
    <segment id="146">Pabllo só quer mesmo</segment>
    <segment id="147">sese divertir e está livre</segment>
    <segment id="148">, leve e solta.</segment>
    <segment id="149">"</segment>
    <segment id="150">Se você provou e gostou</segment>
    <segment id="151">, o que tenho a ver com isso?/ foi culpa do cu</segment>
    <segment id="152">,</segment>
    <segment id="153">foi culpa do cupido"</segment>
    <segment id="154">, diz, em mais um dos seus trocadilhos safados.</segment>
    <segment id="155">Veja fotos do clipe &amp;#</segment>
    <segment id="156">039;Triste com T&amp;#039</segment>
    <segment id="157">;, de Pabllo VittarMais    novamente         de   de  de  representando um  "Culpa do Cupido" é a faixa mais explícita do disco</segment>
    <segment id="158">, dessas que jamais funcionaria nas emissoras de rádio</segment>
    <segment id="159">, masmas que tem potencial para viralizar.</segment>
    <segment id="160">Parece que Pabllo</segment>
    <segment id="161">sese rendeu ao funk putaria que tem feito jovens</segment>
    <segment id="162">sese esfregarem nos shows da MC Pipokinha.</segment>
    <segment id="163">A drag queen continua a soar libidinosa em "Derretida</segment>
    <segment id="164">" quando entoa que está ficando assanhadinha com um "pirulito na boquinha".</segment>
    <segment id="165">É como</segment>
    <segment id="166">como se</segment>
    <segment id="167">se a maranhense estivesse</segment>
    <segment id="168">, de fato</segment>
    <segment id="169">, transando num banheiro sórdido de alguma boate.</segment>
    <segment id="170">A noitada chega ao fim</segment>
    <segment id="171">, masmas a contragosto da cantora.</segment>
    <segment id="172">Pabllo clama por mais diversão em "After"</segment>
    <segment id="173">, que encerra um dos seus melhores discos.</segment>
    <segment id="174">"</segment>
    <segment id="175">Qual é o after da vez?</segment>
    <segment id="176">", ela pergunta</segment>
    <segment id="177">, com a melancolia de fim de festa.</segment>
    <segment id="178">Pabllo</segment>
    <segment id="179">sese voltou ao próprio passado para investigar os sabores da noite num álbum que é incendiário</segment>
    <segment id="180">, feito para ferver na pista ou na cama.</segment>
    <segment id="181">Vai ser tocado à exaustão nas boates gays</segment>
    <segment id="182">, dos inferninhos às mais sofisticadas.</segment>
    <segment id="183">Termina rápido demais</segment>
    <segment id="184">, masmas é potente o suficiente</segment>
    <segment id="185">, como</segment>
    <segment id="186">como devem ser as boas noitadas.  NoitadaQuando Disponível nas plataformas</segment>
    <segment id="187">digitaisPreçoAutor Pabllo VittarProdução Brabo Music TeamGravadora Sony</segment>
  </rst>
</analysis>