  <rst>
    <segment id="1">Protesto.</segment>
    <segment id="2">Revolta.</segment>
    <segment id="3">Golpismo.</segment>
    <segment id="4">Por todo o país</segment>
    <segment id="5">, bolsonaristas rejeitam o resultado das urnas.</segment>
    <segment id="6">Elpídio era um velho militante de esquerda.  —</segment>
    <segment id="7">Palhaçada.</segment>
    <segment id="8">Fazerem isso com a bandeira do Brasil.</segment>
    <segment id="9">O velho televisor Colorado RQ mostrava manifestações na frente de instalações militares.  —</segment>
    <segment id="10">Lembro desse quartel.</segment>
    <segment id="11">Elpídio tomou mais um gole de conhaque.  —</segment>
    <segment id="12">Hora de tomar uma atitude.</segment>
    <segment id="13">Escondido atrás de malas e livros</segment>
    <segment id="14">, estava uma recordação dos anos de chumbo.  —Será que esse fuzil ainda funciona?</segment>
    <segment id="15">Camadas de ferrugem e mofo mostravam uma realidade.  —</segment>
    <segment id="16">Há cinquenta anos desisti da luta armada.</segment>
    <segment id="17">Na parede</segment>
    <segment id="18">, o retrato de Che Guevara não dizia sim nem não.  —Mas não esqueci o treinamento básico.</segment>
    <segment id="19">Nos tempos duros de 1969</segment>
    <segment id="20">, Elpídio pensara em aderir ao capitão Lamarca.  —</segment>
    <segment id="21">A história</segment>
    <segment id="22">sese repete.</segment>
    <segment id="23">A garrafa de conhaque já estava vazia.  —Às ruas.</segment>
    <segment id="24">Elpídio topou com um grupo embandeirado na entrada do metrô Santa Cecília.  —Golpistas.</segment>
    <segment id="25">Fascistas.</segment>
    <segment id="26">Vão aprender democracia na marra.  —Comunista.</segment>
    <segment id="27">Não sabe perder.  —</segment>
    <segment id="28">A vitória está aqui.</segment>
    <segment id="29">Na ponta do fuzil.</segment>
    <segment id="30">Elpídio estava pronto para disparar o primeiro tiro quando apareceu o PM Cláudio.  —</segment>
    <segment id="31">O que é que está fazendo aí</segment>
    <segment id="32">, vovô?  —</segment>
    <segment id="33">Sai que você está na minha linha de tiro.</segment>
    <segment id="34">O PM Cláudio sorriu com superioridade.  —</segment>
    <segment id="35">O que é que o senhor tem aí na mão</segment>
    <segment id="36">?</segment>
    <segment id="37">—Minha AR-15 de estimação.</segment>
    <segment id="38">Não era bem isso.</segment>
    <segment id="39">Elpídio segurava apenas o gargalo da garrafa.  --Parece mais uma Dreher Três Estrelas.  —</segment>
    <segment id="40">Hein?  —Considere-</segment>
    <segment id="41">sese preso.</segment>
    <segment id="42">Perturbação da ordem.</segment>
    <segment id="43">Elpídio olhou em volta.  —Ué.</segment>
    <segment id="44">E esses golpistas aí?</segment>
    <segment id="45">O PM Cláudio fez cara séria.  —</segment>
    <segment id="46">São democratas.</segment>
    <segment id="47">Lutando pela verdade em favor do nosso presidente.</segment>
    <segment id="48">Elpídio curte a ressaca no DP.</segment>
    <segment id="49">Garrafas não são armas.</segment>
    <segment id="50">Focinho de porco não é tomada.</segment>
    <segment id="51">Mas há quem veja uma urna eletrônica e só enxergue um tanque de guerra.</segment>
    <segment id="52">Golpistas fazem atos em frente a quartéis pelo país após derrota de BolsonaroMais    novamente         de   de  de  representando um</segment>
  </rst>
