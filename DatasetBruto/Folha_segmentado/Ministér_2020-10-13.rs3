  <rst>
    <segment id="1">O uso de produto químico retardante de fogo para combater queimadas</segment>
    <segment id="2">, como</segment>
    <segment id="3">como na Chapada dos Veadeiros</segment>
    <segment id="4">, já foi adotado antes.</segment>
    <segment id="5">Em agosto</segment>
    <segment id="6">, o Ministério do Meio Ambiente anunciou a utilização da substância contra queimadas em área da Amazônia Legal.</segment>
    <segment id="7">A comunidade da Chapada</segment>
    <segment id="8">sese revoltou contra o uso do material químico.</segment>
    <segment id="9">Bombeiros relatam que o incêndio na Serra do Cipó</segment>
    <segment id="10">, em Minas Gerais</segment>
    <segment id="11">, também usou retardante contra as chamas.</segment>
    <segment id="12">Meio Ambiente com Ricardo SallesMais    novamente         de   de  de  representando um  Procurado</segment>
    <segment id="13">, o ministério não</segment>
    <segment id="14">sese manifestou.</segment>
    <segment id="15">O Ibama afirmou que o combate químico é muito usado em outros países</segment>
    <segment id="16">, como</segment>
    <segment id="17">como EUA e Canadá</segment>
    <segment id="18">, e que frente a potenciais perdas “prescindir do uso de produtos pouco tóxicos seria ignorar a preponderância dos ganhos versus os riscos”.</segment>
    <segment id="19">Reportagem do Estado de S. Paulo mostrou que o Ibama pretende comprar</segment>
    <segment id="20">, em regime de urgência</segment>
    <segment id="21">, retardante de chamas para usar em áreas do Pantanal.</segment>
    <segment id="22">Segundo o jornal</segment>
    <segment id="23">, a aquisição foi orientada pelo ministro Ricardo Salles (Meio Ambiente).</segment>
    <segment id="24">VEJA TEMAS ABORDADOS PELA COLUNAPGR soube pela imprensa que André do Rap era chefe do PCCHerdeiro do banco Safra doa R$ 75 mil à campanha para a reeleição de Bruno Covas em SPMinistério de Salles anunciou uso de retardante químico contra fogo na Amazônia Legal Amoêdo doa para campanha de desafeto de Sabará e esquenta rixa com candidatoRussomanno quer moradores de rua na zeladoria com apoio psicológico das igrejas</segment>
