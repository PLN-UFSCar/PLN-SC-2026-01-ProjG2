  <rst>
    <segment id="1">&amp;#</segment>
    <segment id="2">039;Game of Thrones&amp;#039</segment>
    <segment id="3">; (último episódio)Aos roteiristas</segment>
    <segment id="4">D.B. Weiss e David Benioff</segment>
    <segment id="5">, ajoelhemo-nos.</segment>
    <segment id="6">We bend the knee.</segment>
    <segment id="7">Quanta sutileza e beleza pode haver em encerrar “Game of Thrones” com cada Stark em seu próprio habitat</segment>
    <segment id="8">, após ter feito da execução do patriarca</segment>
    <segment id="9">, Ned (Sean Bean)</segment>
    <segment id="10">, a primeira grande surpresa e sinal de que não</segment>
    <segment id="11">sese tratava</segment>
    <segment id="12">, já ali</segment>
    <segment id="13">, de um folhetim clássico?</segment>
    <segment id="14">Game of Thrones - oitava temporada   novamente         de   de  de  representando um  Descontentes</segment>
    <segment id="15">, claro</segment>
    <segment id="16">, sempre haverá</segment>
    <segment id="17">, masmas o último episódio da série que mais ansiedade provocou nesta década entregou</segment>
    <segment id="18">, após oito temporadas</segment>
    <segment id="19">, um final impecável</segment>
    <segment id="20">, no qual drama</segment>
    <segment id="21">, sangue</segment>
    <segment id="22">, política e humor</segment>
    <segment id="23">sese equilibraram de uma forma raramente vista e impensável após o choque e pavor do penúltimo episódio e suas baixas colaterais.</segment>
    <segment id="24">Cada linha da história foi fechada a contento —até a da profecia de Azor Ahai</segment>
    <segment id="25">, o príncipe libertador</segment>
    <segment id="26">, que no final era mesmo Jon Snow (Kit Haringnton) e teve que sacrificar seu amor</segment>
    <segment id="27">, Daenerys</segment>
    <segment id="28">, não ficou de lado</segment>
    <segment id="29">comocomo</segment>
    <segment id="30">sese enunciava.</segment>
    <segment id="31">Nem o lobo Fantasma sumiu.</segment>
    <segment id="32">Nenhum personagem</segment>
    <segment id="33">, afinal</segment>
    <segment id="34">, sese traiu.</segment>
    <segment id="35">A começar de Daenerys</segment>
    <segment id="36">, a messiânica.</segment>
    <segment id="37">A personagem de Emilia Clarke não enlouqueceu</segment>
    <segment id="38">, como</segment>
    <segment id="39">como alguns entenderam</segment>
    <segment id="40">, nem traiu sua natureza.</segment>
    <segment id="41">Do início ao fim</segment>
    <segment id="42">, ela se</segment>
    <segment id="43">se acreditava imbuída de uma missão divina/sobrenatural de fazer o bem</segment>
    <segment id="44">, mesmo que alguns milhares morressem por isso.</segment>
    <segment id="45">Quem começa descartando vidas supostamente maculadas com facilidade não tem tantos pudores de olhar para inocentes</segment>
    <segment id="46">comocomo perdas lamentáveis</segment>
    <segment id="47">, masmas necessárias.</segment>
    <segment id="48">Já no penúltimo episódio sua morte parecia inevitável</segment>
    <segment id="49">;</segment>
    <segment id="50">ainda assim a cena que a consuma foi executada com uma poesia triste de fazer jus à sua trajetória.</segment>
    <segment id="51">Drogon cospe fogo no último episódio de &amp;#</segment>
    <segment id="52">039;Game of Thrones&amp;#039</segment>
    <segment id="53">; - DivulgaçãoO diálogo de Tyrion com Jon Snow</segment>
    <segment id="54">, já quando o primeiro era prisioneiro da rainha</segment>
    <segment id="55">, serviu</segment>
    <segment id="56">, também</segment>
    <segment id="57">, como</segment>
    <segment id="58">como recado dos roteiristas para os fãs que haviam acolhido com bons olhos as ambições de Dany e depois</segment>
    <segment id="59">sese espantaram com sua trajetória.  E Jon Snow?</segment>
    <segment id="60">Jon nunca foi forjado para ser rei.</segment>
    <segment id="61">Sempre foi mais Stark que Targaryen</segment>
    <segment id="62">, e sempre foi mais bastardo do que nobre.</segment>
    <segment id="63">Nunca esteve confortável com o potencial que os demais viam nele</segment>
    <segment id="64">;</segment>
    <segment id="65">sese sempre foi justo</segment>
    <segment id="66">, faltou-lhe a ousadia nas escolhas</segment>
    <segment id="67">, frequentemente guiadas por outros.</segment>
    <segment id="68">E, no fim</segment>
    <segment id="69">, nem Jon era puro</segment>
    <segment id="70">, fazendo jus ao antimaniqueísmo da série.</segment>
    <segment id="71">Na lei crua</segment>
    <segment id="72">, ele talvez seja um dos maiores criminosos</segment>
    <segment id="73">, duplamente regicida e assassino da amante.</segment>
    <segment id="74">Para ele</segment>
    <segment id="75">, contudo</segment>
    <segment id="76">contudo</segment>
    <segment id="77">, o exílio não é penitência</segment>
    <segment id="78">, masmas o lugar ao qual</segment>
    <segment id="79">sese sente pertencente.</segment>
    <segment id="80">Desertar junto aos Selvagens é poder</segment>
    <segment id="81">sese libertar de um fardo que sempre o confundiu.</segment>
    <segment id="82">Falharam também aqueles que apostavam em um duplo reinado de Sansa e Tyrion</segment>
    <segment id="83">, porque</segment>
    <segment id="84">porque George R.R. Martin</segment>
    <segment id="85">, o autor dos livros que inspiraram a série</segment>
    <segment id="86">, por sua vez</segment>
    <segment id="87">sese inspirou na Guerra das Rosas (1455-85)</segment>
    <segment id="88">, quando Yorks e Lancasters só sanaram sua batalha ao poderem reinar juntos.</segment>
    <segment id="89">Não que os personagens de Sofie Turner e Peter Dinklage —os melhores da trama</segment>
    <segment id="90">, aliás— tenham</segment>
    <segment id="91">sese saído mal.</segment>
    <segment id="92">Ela se</segment>
    <segment id="93">se tornou rainha do norte</segment>
    <segment id="94">, independente</segment>
    <segment id="95">, e ele</segment>
    <segment id="96">, o chefe de gabinete do novo rei</segment>
    <segment id="97">;</segment>
    <segment id="98">um rei eleito</segment>
    <segment id="99">, escolhido em colégio eleitoral de nobres</segment>
    <segment id="100">, vejam só.</segment>
    <segment id="101">Mas nenhum dos dois ocupou o trono dos Sete Reinos</segment>
    <segment id="102">, que no fim</segment>
    <segment id="103">sese tornaram seis</segment>
    <segment id="104">, porque</segment>
    <segment id="105">porque o Norte</segment>
    <segment id="106">sese emancipou sob a gestão de Sansa.</segment>
    <segment id="107">Arya, a assassina adolescente</segment>
    <segment id="108">, a caçula das duas irmãs Stark</segment>
    <segment id="109">, resolveu tirar seu ano sabático após matar o Rei da Noite</segment>
    <segment id="110">, que ameaçava o mundo dos vivos</segment>
    <segment id="111">, e chegar tarde demais para matar a tirana Cersei (Lena Headey) e a totalitária Daenerys.</segment>
    <segment id="112">Arya sempre foi uma “outsider”</segment>
    <segment id="113">, uma estranha no ninho</segment>
    <segment id="114">, e nada mais natural que seja feliz apenas</segment>
    <segment id="115">sese desbravar novos mundos.</segment>
    <segment id="116">E Bran (Isaac Hempstead Wright)</segment>
    <segment id="117">, o garoto que ficou paraplégico por ver o que não devia e acabou</segment>
    <segment id="118">sese tornando aquele que tudo vê e sabe?</segment>
    <segment id="119">Após um dragão aniquilar o trono da discórdia e</segment>
    <segment id="120">sese ensejar uma pequena campanha eleitoral</segment>
    <segment id="121">, sua escolha para governar os seis reinos em Westeros — uma espécie de protorrepública</segment>
    <segment id="122">, já que ele continua sendo rei</segment>
    <segment id="123">, masmas foi votado e não tem herdeiros — não é aquela que comove multidões</segment>
    <segment id="124">, masmas reflete com alguma precisão o que fazem democracias mais amadurecidas.</segment>
    <segment id="125">No fim</segment>
    <segment id="126">, “Game of Thrones” nunca</segment>
    <segment id="127">sese tratou de uma história de herói ou heroína clássicos</segment>
    <segment id="128">, da qual</segment>
    <segment id="129">sese espera um final feliz.</segment>
    <segment id="130">Mas é incrível</segment>
    <segment id="131">comocomo uma série cheia de dragões e zumbis e gigantes e outras alegorias deu conta de retratar</segment>
    <segment id="132">, com realismo</segment>
    <segment id="133">, o quão difícil é forjar uma democracia</segment>
    <segment id="134">, o quão cruenta e comezinha é a política</segment>
    <segment id="135">, e quão falhos são aqueles que sobem ao poder.</segment>
    <segment id="136">E, ainda assim</segment>
    <segment id="137">, terminar em uma nota de otimismo</segment>
    <segment id="138">, quase um acalento.</segment>
    <segment id="139">Em uma de suas muitas frases memoráveis</segment>
    <segment id="140">, Tyrion</segment>
    <segment id="141">, o gigantesco personagem de Dinklage</segment>
    <segment id="142">, diz que o que une a humanidade são as histórias</segment>
    <segment id="143">, é a memória</segment>
    <segment id="144">, as vivências comuns e</segment>
    <segment id="145">comocomo elas são passadas adiante.</segment>
    <segment id="146">Em um mundo que caminha cada vez mais rápido para o obscurantismo e a emergência de “verdades alternativas”</segment>
    <segment id="147">, não poderia haver mensagem mais pungente.</segment>
  </rst>
</analysis>