  <rst>
    <segment id="1">Calor e chuva.</segment>
    <segment id="2">A previsão dos meteorologistas para a cidade de São Paulo para esta quinta-feira (18) foi confirmada.</segment>
    <segment id="3">Pela segunda vez no dia</segment>
    <segment id="4">, a capital entrou em estado de atenção para alagamentos —o alerta mais recente do CGE (Centro de Gerenciamento de Emergências)</segment>
    <segment id="5">, da prefeitura</segment>
    <segment id="6">, foi dado às 22h para a zona sul e a marginal Pinheiros.</segment>
    <segment id="7">Pouco depois</segment>
    <segment id="8">, sese espalhou por toda a cidade.</segment>
    <segment id="9">Segundo o órgão</segment>
    <segment id="10">, o tempo deve continuar instável pelas próximas horas</segment>
    <segment id="11">, com chuva variando de intensidade na capital e região metropolitana.</segment>
    <segment id="12">Mais cedo</segment>
    <segment id="13">, pouco antes 16h</segment>
    <segment id="14">, alerta foi feito para zona norte</segment>
    <segment id="15">, zona leste e centro</segment>
    <segment id="16">, e durou até as 17h45.</segment>
    <segment id="17">Tempo fechado no centro de São Paulo</segment>
    <segment id="18">; previsão é de chuva ao menos até o próximo domingo (22) - Felipe Bächtold - 12.jan.24/FolhapressNo horário</segment>
    <segment id="19">, marginais Pinheiros e Tietê também tiveram riscos de ficarem alagadas.</segment>
    <segment id="20">Nas redes sociais houve relatos de queda granizo —a informação foi confirmada pelo CGE em São Miguel Paulista e no Itaim Paulista</segment>
    <segment id="21">, na zona leste.</segment>
    <segment id="22">"Imagens do radar meteorológico do CGE mostram chuva forte com potencial para queda de granizo na zona leste</segment>
    <segment id="23">, principalmente no Itaim paulista</segment>
    <segment id="24">, Penha</segment>
    <segment id="25">, Mooca e Aricanduva e Vila Formosa"</segment>
    <segment id="26">, afirmou o Centro de Gerenciamento de Emergência.</segment>
    <segment id="27">"</segment>
    <segment id="28">O mesmo quadro é observado na zona oeste</segment>
    <segment id="29">, nas subprefeituras da Lapa e Pinheiros</segment>
    <segment id="30">, e no centro.</segment>
    <segment id="31">"</segment>
    <segment id="32">Segundo o Corpo de Bombeiros</segment>
    <segment id="33">, entre 14h30 e 18h47 foram atendidos 49 chamados para queda de árvores</segment>
    <segment id="34">, principalmente na zona leste</segment>
    <segment id="35">, nas regiões da Vila Curuçá</segment>
    <segment id="36">, Itaim Paulista e Jardim Helena.</segment>
    <segment id="37">O paulistano também enfrentou o calor nesta quinta-feira.</segment>
    <segment id="38">Medição parcial do Inmet (Instituto Nacional de Meteorologia) aponta que às 14h a temperatura chegou a 34</segment>
    <segment id="39">,3ºC no mirante de Santana</segment>
    <segment id="40">, zona norte.</segment>
    <segment id="41">Na região metropolitana</segment>
    <segment id="42">, uma mulher teve fratura em uma das pernas</segment>
    <segment id="43">, após a queda de uma árvore em Osasco.</segment>
    <segment id="44">É o segundo dia seguido na semana que a capital paulista fica em estado de atenção por causa da chuva.</segment>
    <segment id="45">Na quarta-feira (17)</segment>
    <segment id="46">, a principal região atingida pela chuva foi a zona leste —em Itaquera</segment>
    <segment id="47">, ruas e avenidas ficaram intransitáveis.</segment>
    <segment id="48">Na semana passada</segment>
    <segment id="49">, quatro pessoas morreram por causa das chuvas em São Paulo.</segment>
    <segment id="50">A cidade entrou em estado de atenção por cinco dias seguidos.</segment>
    <segment id="51">A chegada de uma frente fria deverá manter a chuva forte nos próximos dias</segment>
    <segment id="52">, masmas com declínio de temperatura</segment>
    <segment id="53">, entre sexta (19) e domingo (21).</segment>
    <segment id="54">De acordo com a Climatempo Meteorologia</segment>
    <segment id="55">, uma área de baixa pressão próxima ao Sudeste irá originar a frente fria que vai</segment>
    <segment id="56">sese deslocar em direção ao Rio de Janeiro nos próximos dias</segment>
    <segment id="57">, passando por São Paulo.</segment>
    <segment id="58">Na capital paulista a temperatura deverá ficar mais amena no fim de semana</segment>
    <segment id="59">, com máximas previstas de 28ºC no sábado</segment>
    <segment id="60">, e de 25ºC</segment>
    <segment id="61">, no domingo.</segment>
  </rst>
</analysis>