  <rst>
    <segment id="1">Mãetrícia: movimento une arte e ciência para desmistificar a mortePor Luciana Dadalto -advogada especializada em testamento vital</segment>
    <segment id="2">, parceira do blog Morte sem TabuNo dia 03.07.2022</segment>
    <segment id="3">, Patrícia Perissinoto Kisser morreu de câncer.</segment>
    <segment id="4">Seu viúvo</segment>
    <segment id="5">, Andreas Kisser</segment>
    <segment id="6">, juntamente com toda a família Perissinoto Kisser</segment>
    <segment id="7">, decidiu transformar a dor do luto em legado.</segment>
    <segment id="8">Decidiu dividir o amor por sua esposa Patrícia em amor ao próximo.</segment>
    <segment id="9">Decidiu transmutar a perda individual em um ganho coletivo.</segment>
    <segment id="10">Decidiu compartilhar com todo o Brasil a "mãetrícia"</segment>
    <segment id="11">, apelido que o João Gordo deu para Patrícia Perissionoto Kisser</segment>
    <segment id="12">, uma mulher que espalhava amor</segment>
    <segment id="13">, alegria e cuidado por onde passava.  Quarta-feira</segment>
    <segment id="14">, dia 28.09.2022</segment>
    <segment id="15">, aconteceu na Audio em São Paulo</segment>
    <segment id="16">, o PatFest</segment>
    <segment id="17">, um festival que reuniu artistas de todas as tribos para celebrar a vida e o legado de Pat.</segment>
    <segment id="18">Da Pat mãe</segment>
    <segment id="19">, da Pat filha</segment>
    <segment id="20">, da Pat esposa</segment>
    <segment id="21">, da Pat irmã</segment>
    <segment id="22">, da Pat cunhada</segment>
    <segment id="23">, da Pat cumadre</segment>
    <segment id="24">, da Pat amiga</segment>
    <segment id="25">, da Pat inspiração.</segment>
    <segment id="26">Mais de 2.000 pessoas participaram desta festa</segment>
    <segment id="27">, que arrecadou dinheiro para a Comunidade Compassiva</segment>
    <segment id="28">, um projeto que leva Cuidados Paliativos a comunidades carentes do Rio de Janeiro e de Minas Gerais.</segment>
    <segment id="29">O PatFest é a primeira semente de um movimento que nasceu oficialmente antes de ontem: o Movimento Mãetrícia</segment>
    <segment id="30">, que pretende conversar de forma aberta sobre a morte e trazer discussões públicas sobre temas</segment>
    <segment id="31">comocomo acesso aos Cuidados Paliativos</segment>
    <segment id="32">, Testamento Vital</segment>
    <segment id="33">, Autonomia no fim da Vida e Morte Digna.</segment>
    <segment id="34">Com o Movimento Mãetrícia</segment>
    <segment id="35">, Andreas e sua família</segment>
    <segment id="36">, desejam ajudar a sociedade brasileira a falar sobre morte com a seriedade e a leveza que o tema merece.</segment>
    <segment id="37">A morte é um fato natural</segment>
    <segment id="38">, masmas hoje</segment>
    <segment id="39">, no Brasil</segment>
    <segment id="40">, morrer de forma digna é um privilégio.</segment>
    <segment id="41">Enquanto muitos encaram a doença</segment>
    <segment id="42">comocomo um castigo</segment>
    <segment id="43">, a morte</segment>
    <segment id="44">comocomo um fracasso e a imortalidade</segment>
    <segment id="45">comocomo um desejo</segment>
    <segment id="46">, Patrícia e toda a família Perissinoto Kisser estão nos ensinando que a morte faz parte da vida e que a única forma de sermos imortais é espalhando sementes de amor e cuidado no mundo.</segment>
    <segment id="47">O movimento Mãetrícia é uma das sementes espalhadas por Patrícia.</segment>
    <segment id="48">Uma mulher que continuará cuidando daqueles que sofrem mesmo após a morte.</segment>
    <segment id="49">Em breve</segment>
    <segment id="50">, você poderá acompanhar o conteúdo do mãetricia no portal http://movimentomaetricia.org.</segment>
  </rst>
</analysis>