  <rst>
    <segment id="1">A secretária de Relações Internacionais de São Paulo</segment>
    <segment id="2">, Marta Suplicy</segment>
    <segment id="3">, trocou a cúpula da pasta que comanda</segment>
    <segment id="4">, na gestão Ricardo Nunes (MDB).</segment>
    <segment id="5">Marta Suplicy durante sua festa de aniversário - DivulgaçãoA mudança incluiu a saída nos últimos dias da secretária-adjunta</segment>
    <segment id="6">, Ana Cristina Wanzeler</segment>
    <segment id="7">, do chefe de gabinete</segment>
    <segment id="8">, Rodrigo Massi</segment>
    <segment id="9">, e do coordenador de relações internacionais</segment>
    <segment id="10">, Hugo Salomão.</segment>
    <segment id="11">A assessoria da secretária diz que as decisões foram motivadas por uma necessidade de "mudança de perfil" nos cargos</segment>
    <segment id="12">, sem dar detalhes.</segment>
    <segment id="13">Salomão</segment>
    <segment id="14">, no entanto</segment>
    <segment id="15">, é alvo de uma investigação preliminar da CGM (Controladoria Geral do Município) há cerca de um mês</segment>
    <segment id="16">, após uma denúncia anônima que apontou "conduta inadequada" de funcionário público.</segment>
    <segment id="17">O conteúdo do</segment>
    <segment id="18">casocaso é sigiloso.</segment>
    <segment id="19">A pasta diz que a acusação "não foi determinante" para a decisão de dispensar o funcionário.</segment>
    <segment id="20">A substituição de dois dos afastados terá uma solução caseira</segment>
    <segment id="21">, com nomes que já atuavam na pasta:</segment>
    <segment id="22">Jonatas Nunes será chefe de gabinete e Luiza Debrassi</segment>
    <segment id="23">, coordenadora de relações internacionais.</segment>
    <segment id="24">Já o cargo de adjunto de Marta está em processo de seleção.</segment>
    <segment id="25">Segundo a assessoria de secretária</segment>
    <segment id="26">, os três prestaram um bom serviço.</segment>
    <segment id="27">"</segment>
    <segment id="28">A troca simultânea visa acelerar o processo de adequação interna antes de importantes eventos já programados para o fim deste ano</segment>
    <segment id="29">, como</segment>
    <segment id="30">como a Expo Internacional Dia da Consciência Negra</segment>
    <segment id="31">, o São Paulo International Summit 2023</segment>
    <segment id="32">, o Fórum Global Contra o Racismo e Discriminação da Unesco</segment>
    <segment id="33">, que a capital paulista vai sediar</segment>
    <segment id="34">, e a participação paulistana na COP28 em Dubai"</segment>
    <segment id="35">, diz a gestão</segment>
    <segment id="36">, em nota.</segment>
    <segment id="37">Marta Suplicy celebra o seu aniversário ao lado de convidadosMais    novamente         de   de  de  representando um</segment>
  </rst>
