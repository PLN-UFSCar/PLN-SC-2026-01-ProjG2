  <rst>
    <segment id="1">Um controverso referendo na Romênia terminou no domingo (7) com mais de 90% de apoio à proibição do casamento gay no país</segment>
    <segment id="2">, masmas foi invalidado nesta segunda-feira (8) devido ao índice de abstenção recorde.</segment>
    <segment id="3">Somente cerca de 20% de eleitores votaram na consulta.</segment>
    <segment id="4">Para que o referendo fosse válido</segment>
    <segment id="5">, era necessário chegar a 30% de participação.</segment>
    <segment id="6">Romeno vota em Bucareste em referendo sobre proibição de casamento gay - Andreea Alexandru/APPouco mais de 3</segment>
    <segment id="7">,4 milhões de pessoas —cerca de 91</segment>
    <segment id="8">,6% dos 3</segment>
    <segment id="9">,7 milhões de pessoas que compareceram às urnas— votaram a favor de uma emenda à Constituição dizendo que somente "um homem e uma mulher</segment>
    <segment id="10">"</segment>
    <segment id="11">podem se</segment>
    <segment id="12">se casar</segment>
    <segment id="13">, e não os "esposos"</segment>
    <segment id="14">, como</segment>
    <segment id="15">como aparece atualmente.</segment>
    <segment id="16">Quase 242 mil pessoas (6</segment>
    <segment id="17">,4%) votaram contra esta modificação</segment>
    <segment id="18">, e o restante dos votos foram anulados</segment>
    <segment id="19">, segundo os primeiros resultados</segment>
    <segment id="20">, com 98% dos colégios eleitorais apurados.</segment>
    <segment id="21">A proposta foi apoiada pelo governo de esquerda</segment>
    <segment id="22">, que sofreu um forte revés após o baixo comparecimento.</segment>
    <segment id="23">O conservador país da União Europeia já proíbe o casamento civil entre pessoas do mesmo sexo.</segment>
    <segment id="24">O referendo foi proposto por uma organização da sociedade civil chamada Coalizão para a Família</segment>
    <segment id="25">, que conseguiu 3 milhões de assinaturas para realizar a votação que garanta que casais gays nunca obtenham o direito a</segment>
    <segment id="26">sese casarem no futuro.</segment>
    <segment id="27">A Coalizão foi apoiada pela Igreja Ortodoxa e por outras religiões.</segment>
    <segment id="28">Todos os partidos do parlamento</segment>
    <segment id="29">, com exceção de um</segment>
    <segment id="30">, endossaram o referendo.</segment>
    <segment id="31">Dezenas de membros do Parlamento Europeu enviaram uma carta aberta à primeira-ministra romena dizendo que o referendo era um erro que poderia promover discurso de ódio contra a comunidade LGBT.</segment>
    <segment id="32">Grupos de direitos humanos também alertaram que uma aprovação da medida colocaria a Romênia em um caminho autoritário e populista.</segment>
    <segment id="33">Artistas e empresas</segment>
    <segment id="34">sese manifestaram contrários ao referendo.</segment>
    <segment id="35">Eles encorajaram a população a boicotar a votação.</segment>
  </rst>
