  <rst>
    <segment id="1">A Secretaria da Segurança Pública do estado de São Paulo anunciou nesta segunda-feira (5) ter ampliado sua estrutura de atendimento para vítimas de violência contra a mulher durante o Carnaval.</segment>
    <segment id="2">Paulistanos no bloco Acadêmicos do Baixo Augusta</segment>
    <segment id="3">, no domingo (4) - Eduardo Knapp/FolhapressSegundo a gestão Tarcísio de Freitas (Republicanos)</segment>
    <segment id="4">, todas as delegacias paulistas receberam reforço de policiais para o período.</segment>
    <segment id="5">No total</segment>
    <segment id="6">, 6.000 agentes foram escalados para atuar no Carnaval.</segment>
    <segment id="7">Além disso</segment>
    <segment id="8">, a PM montou tendas para atender casos de importunação sexual durante as festas</segment>
    <segment id="9">, especialmente em regiões que concentram os maiores blocos.</segment>
    <segment id="10">Haverá presença de policiais mulheres.</segment>
    <segment id="11">"</segment>
    <segment id="12">Esse é um compromisso que temos para ampliar a proteção das mulheres e</segment>
    <segment id="13">, ao mesmo tempo</segment>
    <segment id="14">, incentivar as denúncias</segment>
    <segment id="15">para que</segment>
    <segment id="16">para que a Polícia Civil possa investigar cada</segment>
    <segment id="17">casocaso"</segment>
    <segment id="18">, disse o secretário da Segurança</segment>
    <segment id="19">, Guilherme Derrite.</segment>
  </rst>
