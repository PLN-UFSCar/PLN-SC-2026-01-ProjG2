  <rst>
    <segment id="1">Mircea Lucescu</segment>
    <segment id="2">, 74, se</segment>
    <segment id="3">se atrapalha nas palavras.</segment>
    <segment id="4">Algumas saem em espanhol</segment>
    <segment id="5">, outras em italiano.</segment>
    <segment id="6">Ele fica quase ofendido com a sugestão de que a entrevista pode ser feita em outra língua que não o português.</segment>
    <segment id="7">"</segment>
    <segment id="8">Não, de jeito nenhum.</segment>
    <segment id="9">Vamos falar em português.</segment>
    <segment id="10">Eu preciso praticar.</segment>
    <segment id="11">"</segment>
    <segment id="12">Entre todos os jogadores que enfrentaram a seleção brasileira na Copa de 1970</segment>
    <segment id="13">, provavelmente nenhum</segment>
    <segment id="14">sese identifica tanto com o Brasil quanto o então atacante romeno</segment>
    <segment id="15">, hoje treinador e que teve convite para dirigir o Santos no fim de 2019.</segment>
    <segment id="16">Brasil venceu a Romênia no terceiro jogo da fase de grupos da Copa do Mundo de 1970 - Reprodução/O CraiovanoNos 12 anos em que dirigiu o ucraniano Shakhtar Donetsk</segment>
    <segment id="17">, ele chegou a ter 12 jogadores do país no elenco.</segment>
    <segment id="18">Lucescu ainda mantém contato com alguns deles</segment>
    <segment id="19">, como</segment>
    <segment id="20">como o meia Jadson.</segment>
    <segment id="21">"</segment>
    <segment id="22">Eu me apaixonei pelo Brasil</segment>
    <segment id="23">porque</segment>
    <segment id="24">porque estive lá antes da Copa do Mundo.</segment>
    <segment id="25">Fizemos uma excursão em 1967 e participamos de torneio de verão no início de 1970"</segment>
    <segment id="26">, lembra o ex-atacante.</segment>
    <segment id="27">Há 50 anos</segment>
    <segment id="28">, em 10 de junho de 1970</segment>
    <segment id="29">, ele vestiu a camisa 9 no calor de Guadalajara.</segment>
    <segment id="30">Lucescu lamenta ter perdido uma boa chance para marcar.</segment>
    <segment id="31">Poderia ter mudado a história de um jogo</segment>
    <segment id="32">, afirma</segment>
    <segment id="33">, que todos no Brasil pensaram que seria fácil.</segment>
    <segment id="34">O placar final foi um apertado 3 a 2 para o time que seria tricampeão mundial.</segment>
    <segment id="35">"</segment>
    <segment id="36">Nunca houve uma equipe tão boa em Copas do Mundo</segment>
    <segment id="37">comocomo aquele Brasil de 1970.</segment>
    <segment id="38">Todo o torneio</segment>
    <segment id="39">, tecnicamente</segment>
    <segment id="40">, foi fantástico.</segment>
    <segment id="41">Foi uma partida muito importante para o futebol romeno.</segment>
    <segment id="42">Um enorme espetáculo"</segment>
    <segment id="43">, diz Lucescu.</segment>
    <segment id="44">A chance perdida pelo então centroavante aconteceu quando o Brasil vencia por 2 a 1.</segment>
    <segment id="45">Pelé depois faria o terceiro</segment>
    <segment id="46">, e Dembrowski diminuiria aos 39 do segundo tempo.</segment>
    <segment id="47">"</segment>
    <segment id="48">Nós dominamos os seis minutos finais e poderíamos ter empatado.</segment>
    <segment id="49">Me lembro de tudo desse jogo</segment>
    <segment id="50">, foi uma coisa fantástica.</segment>
    <segment id="51">Aquele Brasil era imbatível.</segment>
    <segment id="52">Clodoaldo</segment>
    <segment id="53">, Gerson</segment>
    <segment id="54">, Rivellino</segment>
    <segment id="55">, Pelé...</segment>
    <segment id="56">O meio de campo era grandíssimo.</segment>
    <segment id="57">"  História da Copa do Mundo 1958-1974   novamente         de   de  de  representando um</segment>
    <segment id="58">As lembranças de Lucescu</segment>
    <segment id="59">, na época jogador do Dínamo Bucareste</segment>
    <segment id="60">, um dos times mais populares da Romênia</segment>
    <segment id="61">, não estão apenas na cabeça.</segment>
    <segment id="62">Paulo Cézar Caju</segment>
    <segment id="63">, integrante daquela seleção brasileira</segment>
    <segment id="64">, mandou para ele por meio de um amigo uma fita VHS com a narração em português.</segment>
    <segment id="65">"</segment>
    <segment id="66">A transmissão brasileira não tem igual</segment>
    <segment id="67">, por causa do espetáculo que cria e o entusiasmo [do narrador]"</segment>
    <segment id="68">, afirma.</segment>
    <segment id="69">A outra recordação está pendurada na parede de sua casa.</segment>
    <segment id="70">A camisa usada por Pelé naquela tarde no México foi enquadrada da mesma forma</segment>
    <segment id="71">comocomo lhe havia sido entregue pelo brasileiro.</segment>
    <segment id="72">Lucescu nem sequer a mandou lavar.</segment>
    <segment id="73">"Todos queriam trocar camisa com Pelé.</segment>
    <segment id="74">Eu fui mais rápido e consegui.</segment>
    <segment id="75">"</segment>
    <segment id="76">O primeiro contato do romeno com o futebol brasileiro</segment>
    <segment id="77">, já com o pensamento na Copa do Mundo</segment>
    <segment id="78">, que seria a primeira da sua seleção</segment>
    <segment id="79">, aconteceu em 1967.</segment>
    <segment id="80">Foram realizados amistosos em Belém</segment>
    <segment id="81">, Natal</segment>
    <segment id="82">, Salvador</segment>
    <segment id="83">, São Paulo</segment>
    <segment id="84">, Ribeirão Preto</segment>
    <segment id="85">, Campinas</segment>
    <segment id="86">, Curitiba e Londrina.</segment>
    <segment id="87">As cidades são citadas uma a uma</segment>
    <segment id="88">, de memória</segment>
    <segment id="89">, pelo hoje treinador.</segment>
    <segment id="90">"</segment>
    <segment id="91">Em Belém jogamos contra o Garrincha.</segment>
    <segment id="92">Em Curitiba</segment>
    <segment id="93">, atuaram Djalma Santos e Bellini"</segment>
    <segment id="94">, relembra</segment>
    <segment id="95">, sobre os amistosos diante de adversários locais.</segment>
    <segment id="96">Em janeiro de 1970</segment>
    <segment id="97">, os romenos</segment>
    <segment id="98">sese hospedaram no Copacabana Palace</segment>
    <segment id="99">, no Rio de Janeiro</segment>
    <segment id="100">, e enfrentaram Flamengo</segment>
    <segment id="101">, Vasco e Independiente-ARG.</segment>
    <segment id="102">Encontraram-</segment>
    <segment id="103">sese pela primeira vez com os jogadores que seriam rivais no México.</segment>
    <segment id="104">Os convocados por Zagallo também estavam no local para exames médicos.</segment>
    <segment id="105">"</segment>
    <segment id="106">Fizemos fotos com todos eles e eu tive a chance de dar um abraço no Pelé.</segment>
    <segment id="107">Foi muito divertido.</segment>
    <segment id="108">"  Mircea Lucescu</segment>
    <segment id="109">, à esquerda</segment>
    <segment id="110">, em ação pelo Dinamo Bucareste- Adevarul Ro/Wikimedia CommonsLucescu constata que os jogadores romenos viviam na época o melhor momento de suas vidas.</segment>
    <segment id="111">Seria o primeiro torneio internacional da seleção após a Segunda Guerra Mundial.</segment>
    <segment id="112">O sorteio os colocou no que foi considerado o grupo da morte</segment>
    <segment id="113">, contra duas seleções que haviam ganhado as três Copas anteriores (Brasil</segment>
    <segment id="114">, em 1958 e 1962</segment>
    <segment id="115">, e Inglaterra</segment>
    <segment id="116">, em 1966) e a Tchecoslováquia</segment>
    <segment id="117">, finalista em 1962 e que seria campeã europeia em 1976.</segment>
    <segment id="118">Isso, de certa forma</segment>
    <segment id="119">, libertou a delegação romena.</segment>
    <segment id="120">Não havia a preocupação em ficar o tempo inteiro concentrado</segment>
    <segment id="121">, trancado no hotel</segment>
    <segment id="122">, como</segment>
    <segment id="123">como acontecia com os favoritos.</segment>
    <segment id="124">"</segment>
    <segment id="125">A seleção brasileira estava concentrada acompanhada por militares</segment>
    <segment id="126">, havia muitos seguranças e eles não podiam ir a lugar algum.</segment>
    <segment id="127">Nós éramos muito mais livres.</segment>
    <segment id="128">O Mundial era uma festa para a gente.</segment>
    <segment id="129">Para o Brasil</segment>
    <segment id="130">, era obrigação"</segment>
    <segment id="131">, define.</segment>
    <segment id="132">Lucescu com Fernandinho na despedida do brasileiro do Shakhtar Donetsk</segment>
    <segment id="133">, que foi treinado no clube pelo romeno - Alexandre Khudoteply - 6.jul.2013/AFPA Romênia perdeu para Brasil e Inglaterra (1 a 0)</segment>
    <segment id="134">, masmas venceu a Tchecoslováquia por 2 a 1 e ficou em terceiro lugar na chave.</segment>
    <segment id="135">A falta de responsabilidade fez com que a equipe atuasse sem medo</segment>
    <segment id="136">, na visão de Lucescu.</segment>
    <segment id="137">E isso aconteceu também contra a equipe que seria campeã do torneio.</segment>
    <segment id="138">"</segment>
    <segment id="139">Houve um momento em campo em que eu pensei que nós não perderíamos</segment>
    <segment id="140">, que iríamos empatar"</segment>
    <segment id="141">, conta.</segment>
    <segment id="142">Não aconteceu</segment>
    <segment id="143">, masmas</segment>
    <segment id="144">, por causa da Copa de 1970</segment>
    <segment id="145">, Lucescu iniciou uma ligação com o futebol brasileiro que continua até os dias de hoje.</segment>
    <segment id="146">Ele cita a amizade que mantém com os jogadores que comandou e</segment>
    <segment id="147">comocomo torce de longe por Luiz Adriano (no Palmeiras) e Fernandinho (no Manchester City).</segment>
    <segment id="148">Ele mostra satisfação também por ter enfrentado a melhor seleção no que chama de a Copa do Mundo mais técnica de todas.</segment>
    <segment id="149">"</segment>
    <segment id="150">Depois de 1970</segment>
    <segment id="151">, o torneio</segment>
    <segment id="152">sese tornou mais atlético"</segment>
    <segment id="153">, completa.</segment>
  </rst>
</analysis>