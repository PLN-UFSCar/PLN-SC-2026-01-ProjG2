  <rst>
    <segment id="1">Gorbachev.</segment>
    <segment id="2">CéuQuando Domingo (11)</segment>
    <segment id="3">, às 19hOnde No LookeProdução Letônia e República Tcheca</segment>
    <segment id="4">, 2020Direção Vitali ManskiMikhail Sergueiévitch Gorbatchov</segment>
    <segment id="5">, o derradeiro líder da União Soviética</segment>
    <segment id="6">, está morrendo.</segment>
    <segment id="7">Ele sabe disso</segment>
    <segment id="8">, e os espectadores do mais recente documentário sobre o político</segment>
    <segment id="9">, "Gorbatchov.</segment>
    <segment id="10">Céu", de 2020</segment>
    <segment id="11">, são relembrados o tempo todo.</segment>
    <segment id="12">Assim, o nonagenário tenta modular suas palavras finais</segment>
    <segment id="13">, em especial quando encarna o fracasso de sete décadas de experimento comunista ao olhos de seus conterrâneos.</segment>
    <segment id="14">Em 1986</segment>
    <segment id="15">, os líderes da União Soviética</segment>
    <segment id="16">, Mikhail Gorbachev (esq.)</segment>
    <segment id="17">, e da Alemanha Oriental</segment>
    <segment id="18">, Erich Honecker</segment>
    <segment id="19">, sese cumprimentam com um beijo fraterno  - Gaby Sommer/ReutersFora da Rússia</segment>
    <segment id="20">, ele é um herói</segment>
    <segment id="21">, lembra o diretor e entrevistador Vitali Manski</segment>
    <segment id="22">, ele mesmo um filho do sistema: ucraniano soviético que cresceu</segment>
    <segment id="23">comocomo russo</segment>
    <segment id="24">, ele hoje trabalha com uma produtora letã por ter caído em desgraça junto ao Kremlin graças a seu brilhante trabalho anterior</segment>
    <segment id="25">, "Testemunhas de Putin" (2018).</segment>
    <segment id="26">Neste ponto</segment>
    <segment id="27">, Gorbatchov lacrimeja.</segment>
    <segment id="28">Afinal</segment>
    <segment id="29">, lembra Manski</segment>
    <segment id="30">, dentro da Rússia ele é odiado ou ignorado.</segment>
    <segment id="31">Ele tenta escapar retoricamente</segment>
    <segment id="32">, masmas é isso.</segment>
    <segment id="33">Não há estátuas dele pelo país que comandou de 1985 a 1991.</segment>
    <segment id="34">Diferentemente do que acontece com o fundador do império comunista</segment>
    <segment id="35">, Vladimir Lênin (1870-1924)</segment>
    <segment id="36">, a quem Gorbatchov chama de "</segment>
    <segment id="37">nosso Deus"</segment>
    <segment id="38">.</segment>
    <segment id="39">"</segment>
    <segment id="40">Eu ainda me vejo</segment>
    <segment id="41">comocomo um socialista"</segment>
    <segment id="42">, diz.</segment>
    <segment id="43">Essa é uma asserção extrema</segment>
    <segment id="44">, dado que há socialismos variados vivos</segment>
    <segment id="45">, goste-</segment>
    <segment id="46">sese ou não deles.</segment>
    <segment id="47">Mas ela vai ao fundo do documentário de Manski: para os russos</segment>
    <segment id="48">, Gorbatchov é associado à decadência dos anos 1990</segment>
    <segment id="49">, não ao sopro da liberdade política (glasnost</segment>
    <segment id="50">, transparência) e econômica (perestroika</segment>
    <segment id="51">, reestruturação) dos 1980.</segment>
    <segment id="52">O diretor consegue uma proeza.</segment>
    <segment id="53">Em seu ocaso</segment>
    <segment id="54">, Gorbatchov vem sendo disputado para o "depoimento final".</segment>
    <segment id="55">O último tiro nesse sentido veio do mais afamado documentarista atual</segment>
    <segment id="56">, o alemão Werner Herzog.</segment>
    <segment id="57">Só que seu "Encontro com Gorbatchov" parece uma atividade recreativa para idosos solitários perto do filme de Manski —que pula a contextualização e desfile de imagens de arquivo</segment>
    <segment id="58">, até porque</segment>
    <segment id="59">porque isso ele fez em um pequeno documentário de 2001 sobre Gorbatchov</segment>
    <segment id="60">, cujas tomadas o alemão usou</segment>
    <segment id="61">, aliás.</segment>
    <segment id="62">Isso serve ao filme</segment>
    <segment id="63">, apesar de Manski ser um fã.</segment>
    <segment id="64">Chega a dizer que "tínhamos democracia sob Gorbatchov" e hoje</segment>
    <segment id="65">, após 21 anos com Vladimir Putin no Kremlin</segment>
    <segment id="66">, "há uma ditadura".</segment>
    <segment id="67">Ambas as frases são exageros</segment>
    <segment id="68">, masmas ajudam a espremer a grande e plúmbea imagem do entrevistado no filme que estreia agora no festival</segment>
    <segment id="69">É Tudo Verdade.</segment>
    <segment id="70">É Tudo Verdade 2021 traz de documentários filmados no auge da pandemia a clássicos do gêneroMais    novamente         de   de  de  representando um</segment>
    <segment id="71">Em nenhum momento Gorbatchov consegue explicar a contradição aparente de ser um socialista que amava seu país e a incapacidade de mantê-lo unido.</segment>
    <segment id="72">"</segment>
    <segment id="73">Não poderia fazer</segment>
    <segment id="74">comocomo meus antecessores</segment>
    <segment id="75">, mesmo Lênin"</segment>
    <segment id="76">, diz, referindo-</segment>
    <segment id="77">sese a fuzilar a oposição.</segment>
    <segment id="78">Ao mesmo tempo</segment>
    <segment id="79">, sese põe na defensiva ante o massacre de manifestantes em Vilnius</segment>
    <segment id="80">, na Lituânia</segment>
    <segment id="81">, no começo de 1991.</segment>
    <segment id="82">"</segment>
    <segment id="83">Você quer me levar para um tribunal?</segment>
    <segment id="84">", questiona.</segment>
    <segment id="85">Em relação a Putin</segment>
    <segment id="86">, o seu silêncio é muito eloquente.</segment>
    <segment id="87">Apenas descreve</segment>
    <segment id="88">comocomo foi ignorado pelo czar do século 21 e murmura</segment>
    <segment id="89">, questionado acerca da ditadura que Manski aponta</segment>
    <segment id="90">, que "não é fácil"</segment>
    <segment id="91">, sobre o ato de governar.</segment>
    <segment id="92">Ao mesmo tempo</segment>
    <segment id="93">, Putin perpassa todo o filme</segment>
    <segment id="94">, como</segment>
    <segment id="95">como um espectro.</segment>
    <segment id="96">Enquanto Gorbatchov rumina</segment>
    <segment id="97">, como</segment>
    <segment id="98">como um rei Lear russo</segment>
    <segment id="99">, sobre sua realidade pós-poder —"quem</segment>
    <segment id="100">sese importa?</segment>
    <segment id="101">", questiona</segment>
    <segment id="102">, sobre sua opinião—</segment>
    <segment id="103">, o presidente russo está lá</segment>
    <segment id="104">, falando sobre qualquer coisa numa tela difusa sintonizada no canal estatal Rússia 1 atrás dele.</segment>
    <segment id="105">A Perestroika e Glasnost Mais    novamente         de   de  de  representando um</segment>
    <segment id="106">Já sobre o seu sucessor</segment>
    <segment id="107">, e antecessor de Putin</segment>
    <segment id="108">, Boris Ieltsin (1931-2007)</segment>
    <segment id="109">, sobra fel.</segment>
    <segment id="110">"</segment>
    <segment id="111">Um idiota"</segment>
    <segment id="112">, diz, bruscamente</segment>
    <segment id="113">, lembrando que "o bêbado" tomou uma garrafa de uísque em seu gabinete após expulsá-lo do Kremlin no dia depois de sua renúncia</segment>
    <segment id="114">, em 25 de dezembro de 1991.</segment>
    <segment id="115">Sobre aquele período</segment>
    <segment id="116">, mais confusão.</segment>
    <segment id="117">Ele se</segment>
    <segment id="118">se nega a dizer quem de fato tirou os aparelhos do moribundo soviético</segment>
    <segment id="119">, sese ele ou Ieltsin</segment>
    <segment id="120">, o presidente da Rússia que lhe salvou de um golpe de Estado em agosto de 1991 só para</segment>
    <segment id="121">sese livrar dele meses depois.  Manski</segment>
    <segment id="122">, fã, se</segment>
    <segment id="123">se desespera pela falta de clareza.</segment>
    <segment id="124">Gorbatchov</segment>
    <segment id="125">sese retrai em sua maciça figura</segment>
    <segment id="126">, elemento central do documentário —que não é enciclopédico</segment>
    <segment id="127">, sem explorar o desastre de Tchernóbil (1986)</segment>
    <segment id="128">, por exemplo.</segment>
    <segment id="129">Como Lênin está no mausoléu da praça Vermelha</segment>
    <segment id="130">, seu último sucessor</segment>
    <segment id="131">sese arrasta com um andador por uma mansão enorme e vazia</segment>
    <segment id="132">, exceto pelo gato ocasional na tela e por prestativos funcionários.</segment>
    <segment id="133">Todos pagos pelo Estado</segment>
    <segment id="134">, que transformou a casa arrendada por líderes de países ex-soviéticos em uma espécie de mausoléu.</segment>
    <segment id="135">O resto das faturas é coberta pelo dinheiro de palestras</segment>
    <segment id="136">, que chegou a US$ 400 mil —cerca de R$ 2</segment>
    <segment id="137">,2 milhões— certa vez</segment>
    <segment id="138">, diz Gorbatchov</segment>
    <segment id="139">, relatando problemas com a Receita.</segment>
    <segment id="140">Cercas altas com câmeras e alarmes dão também um aspecto de bunker ao local.</segment>
    <segment id="141">Lentamente</segment>
    <segment id="142">, Gorbatchov</segment>
    <segment id="143">sese desloca e lembra seu fiel empregado</segment>
    <segment id="144">Volodia</segment>
    <segment id="145">, diminutivo de Vladimir</segment>
    <segment id="146">, que seu tempo está</segment>
    <segment id="147">sese esgotando.</segment>
    <segment id="148">Se isso parece depressivo</segment>
    <segment id="149">, e é, há compensações no humor solar que o político encerra.</segment>
    <segment id="150">Sua paixão pela poesia pastoral do suicida Serguei Iesenin (1895-1925) emerge com declamações fortes</segment>
    <segment id="151">, assim</segment>
    <segment id="152">comocomo quando entoa canções folclóricas.</segment>
    <segment id="153">Há vida no homem</segment>
    <segment id="154">, com sinais da vivacidade dos velhos tempos ao ver que falou um palavrão</segment>
    <segment id="155">, pediu uma vodca ou brincou com um cachorrinho.</segment>
    <segment id="156">Ele não perde uma piada sobre a decadência física.</segment>
    <segment id="157">Visitando o túmulo de sua mulher Raíssa</segment>
    <segment id="158">, morta por câncer em 1999</segment>
    <segment id="159">, ele aponta para "o lugar reservado ao lado" para ele.</segment>
    <segment id="160">Porões da guerra friaMais    novamente         de   de  de  representando um</segment>
    <segment id="161">A amada</segment>
    <segment id="162">, aliás</segment>
    <segment id="163">, é um fantasma que adorna canto do mausoléu em que Gorbatchov vive antes de ser transferido a um hospital.</segment>
    <segment id="164">A vida</segment>
    <segment id="165">, sem ela</segment>
    <segment id="166">, "perdeu o sentido".</segment>
    <segment id="167">Aos 90 anos</segment>
    <segment id="168">, neste documentário ele encarna parte da vertigem do século 20</segment>
    <segment id="169">, com a fundamental incompreensão de seus processos finais e a indignação por isso.</segment>
    <segment id="170">Tudo é condensado numa cena do Ano Novo de 2020</segment>
    <segment id="171">, antes da distopia pandêmica</segment>
    <segment id="172">sese abater sobre o planeta.</segment>
    <segment id="173">Gorbatchov está com Volodia</segment>
    <segment id="174">, sua mulher Tania e a equipe de filmagem na casa do auxiliar.</segment>
    <segment id="175">Ao fundo</segment>
    <segment id="176">, sempre ele</segment>
    <segment id="177">, Putin fala algo edulcorado sobre valores familiares na TV.</segment>
    <segment id="178">Gorbatchov deixa cair seu aparelho auditivo.</segment>
    <segment id="179">Quando tudo acaba</segment>
    <segment id="180">, bate a meia-noite e sobe o hino russo.</segment>
    <segment id="181">Putin resgatou a melodia soviética e alterou parte da letra</segment>
    <segment id="182">, masmas alguns trechos ficaram iguais</segment>
    <segment id="183">, como</segment>
    <segment id="184">como o "salve</segment>
    <segment id="185">, nossa pátria livre!</segment>
    <segment id="186">".</segment>
    <segment id="187">"E quem trouxe a liberdade?</segment>
    <segment id="188">", diz</segment>
    <segment id="189">, à meia voz</segment>
    <segment id="190">, como</segment>
    <segment id="191">como que clamando reparação</segment>
    <segment id="192">, num dos raros momentos em que sua fala revela mais que o silêncio.</segment>
  </rst>
</analysis>