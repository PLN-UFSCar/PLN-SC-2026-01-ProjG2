  <rst>
    <segment id="1">Heartstopper Onde</segment>
    <segment id="2">Na NetflixClassificação 12 anosAutoriaAlice OsemanElenco Kit Connor</segment>
    <segment id="3">, Joe Locke</segment>
    <segment id="4">, Olivia ColmanProdução Inglaterra</segment>
    <segment id="5">, 2022Direção Euros Lyn"Heartstopper"</segment>
    <segment id="6">, da Netflix</segment>
    <segment id="7">, é clichê do primeiro ao último episódio.</segment>
    <segment id="8">É um romance que</segment>
    <segment id="9">, sese fosse protagonizado por um garoto e uma garota</segment>
    <segment id="10">, pouco teria a acrescentar</segment>
    <segment id="11">, masmas</segment>
    <segment id="12">, por tratar da paixão de dois rapazes</segment>
    <segment id="13">, encontra originalidade.</segment>
    <segment id="14">Cena de Heartstopper</segment>
    <segment id="15">, seriado da Netflix protagonizado por casal gay - DivulgaçãoQuantas vezes as telas já foram tomadas pela garota que</segment>
    <segment id="16">sese esconde na biblioteca para ter paz e de repente</segment>
    <segment id="17">sese apaixona pelo garoto que é a estrela do time de futebol da escola?</segment>
    <segment id="18">"Heartstopper" não é diferente.</segment>
    <segment id="19">Charlie sofre bullying por ter sido tirado à força do armário.</segment>
    <segment id="20">Às escondidas</segment>
    <segment id="21">, ele beija um colega</segment>
    <segment id="22">, Ben, que faz parte do grupo dos jogadores de rúgbi homofóbicos e que finge ter uma namorada.</segment>
    <segment id="23">Eis que</segment>
    <segment id="24">, depois de uma briga com Ben</segment>
    <segment id="25">, Charlie conhece Nick</segment>
    <segment id="26">, que também faz parte do time de rúgbi</segment>
    <segment id="27">, masmas curiosamente não é homofóbico.</segment>
    <segment id="28">Entre um trabalho em grupo e uma mensagem escrita e reescrita dez vezes antes de ser enviada</segment>
    <segment id="29">, eles</segment>
    <segment id="30">sese apaixonam.</segment>
    <segment id="31">Veja imagens da série &amp;#039</segment>
    <segment id="32">;Heartstopper&amp;#039</segment>
    <segment id="33">;Mais    novamente         de   de  de  representando um  Nick ainda não sabe</segment>
    <segment id="34">sese gosta de garotos.</segment>
    <segment id="35">Depois de descobrir a resposta</segment>
    <segment id="36">, passa a</segment>
    <segment id="37">sese perguntar</segment>
    <segment id="38">sese é gay ou bissexual.</segment>
    <segment id="39">Ciente de que nada disso importa</segment>
    <segment id="40">, no entanto</segment>
    <segment id="41">, logo</segment>
    <segment id="42">sese deixa levar pela paixão e começa a namorar Charlie.</segment>
    <segment id="43">É a partir daí que os clichês dão espaço para a originalidade.</segment>
    <segment id="44">Se já é difícil apresentar à família um namorado que não corresponde aos padrões esperados</segment>
    <segment id="45">, apresentar um companheiro do mesmo sexo é mais difícil ainda</segment>
    <segment id="46">, o que em "Heartstopper" representa a oportunidade de ver na tela conflitos diferentes dos que estamos cansados de ver.</segment>
    <segment id="47">Enquanto em "Grease" e em "</segment>
    <segment id="48">High School Musical</segment>
    <segment id="49">" os galãs</segment>
    <segment id="50">sese questionavam</segment>
    <segment id="51">sese podiam cantar</segment>
    <segment id="52">, com medo de manchar a reputação</segment>
    <segment id="53">, em "Heartstopper"</segment>
    <segment id="54">o conflito é mais profundo.</segment>
    <segment id="55">É uma avaliação que pode parecer exagerada</segment>
    <segment id="56">, já que a comunidade LGBTQIA+ tem sido vista em quase toda produção recente de Hollywood.</segment>
    <segment id="57">Se avaliarmos tais obras a fundo</segment>
    <segment id="58">, no entanto</segment>
    <segment id="59">, veremos que não é bem por aí</segment>
    <segment id="60">, já que em geral seus dilemas são relegados a pano de fundo.</segment>
    <segment id="61">Kit Connor e Joe Locke em cena da série &amp;#</segment>
    <segment id="62">039;Heartstopper&amp;#039</segment>
    <segment id="63">;, da Netflix - Divulgação"Heartstopper" não é só uma história com um personagem gay</segment>
    <segment id="64">, caso</segment>
    <segment id="65">caso de "Elite" e "Euphoria"</segment>
    <segment id="66">, para lembrar só dois exemplos de seriados de sucesso recentes.</segment>
    <segment id="67">Também não é uma história em que o arco-íris é tratado</segment>
    <segment id="68">comocomo cota</segment>
    <segment id="69">, com personagens da comunidade LGBTQIOA+ que não podem ter vida própria</segment>
    <segment id="70">, como</segment>
    <segment id="71">como como</segment>
    <segment id="72">como é visto em "</segment>
    <segment id="73">And Just Like That"</segment>
    <segment id="74">, o revival de "</segment>
    <segment id="75">Sex and the City".</segment>
    <segment id="76">Embalada por uma paleta ultracolorida</segment>
    <segment id="77">, "Heartstopper" é uma comédia romântica —isto é</segment>
    <segment id="78">, de final feliz</segment>
    <segment id="79">, sem nenhuma grande tragédia</segment>
    <segment id="80">, outro destino comum para gays na ficção—</segment>
    <segment id="81">, só que centrada no romance homossexual.</segment>
    <segment id="82">É ainda</segment>
    <segment id="83">, e talvez isso seja mais importante</segment>
    <segment id="84">, distribuída no circuito mainstream</segment>
    <segment id="85">, dentro de uma plataforma de streaming que chega a qualquer casa</segment>
    <segment id="86">, até mesmo de uma cidade interiorana onde filmes</segment>
    <segment id="87">comocomo "</segment>
    <segment id="88">Me Chame pelo Seu Nome" não chegaram ou onde nem sequer há salas de cinema.</segment>
    <segment id="89">Por mais que não seja a primeira história com esse propósito</segment>
    <segment id="90">, a série</segment>
    <segment id="91">, baseada nos quadrinhos de sua roteirista</segment>
    <segment id="92">, Alice Oseman</segment>
    <segment id="93">, encontra poucos paralelos na indústria audiovisual.</segment>
    <segment id="94">Nos cinemas</segment>
    <segment id="95">, "</segment>
    <segment id="96">Com Amor</segment>
    <segment id="97">, Simon"</segment>
    <segment id="98">, que estreou em 2018</segment>
    <segment id="99">, é até hoje o único filme de um grande estúdio com a mesma proposta.</segment>
    <segment id="100">O sucesso de "Heartstopper" nas redes sociais</segment>
    <segment id="101">, sobretudo no Twitter</segment>
    <segment id="102">, onde</segment>
    <segment id="103">sese tornou o seriado mais comentado da semana</segment>
    <segment id="104">, reflete a carência do público por histórias com representatividade de verdade.</segment>
    <segment id="105">Reflete ainda um atraso.</segment>
    <segment id="106">Não é preciso voltar muitas páginas do calendário.</segment>
    <segment id="107">Qualquer jovem gay de 20 e poucos anos nunca</segment>
    <segment id="108">sese viu representado nas telas durante a adolescência</segment>
    <segment id="109">, assim</segment>
    <segment id="110">comocomo qualquer jovem lésbica ou bissexual ainda não</segment>
    <segment id="111">sese vê</segment>
    <segment id="112">, já que</segment>
    <segment id="113">, para elas</segment>
    <segment id="114">, não existe nenhum Simon ou um Charlie.</segment>
  </rst>
</analysis>