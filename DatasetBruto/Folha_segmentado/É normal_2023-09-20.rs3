  </header>
  <rst>
    <segment id="1">Não são poucos os hábitos alimentares britânicos que o resto do mundo considera</segment>
    <segment id="2">, para dizer o mínimo</segment>
    <segment id="3">, questionáveis.</segment>
    <segment id="4">Tentarei enumerá-los nesta minha temporada londrina</segment>
    <segment id="5">, masmas hoje vou me ater a um que fala às tripas dos brasileiros: o feijão em molho de tomate adocicado no café da manhã.</segment>
    <segment id="6">Eles se</segment>
    <segment id="7">se chamam baked beans</segment>
    <segment id="8">, apesar de não parecerem ser assados.</segment>
    <segment id="9">Até onde</segment>
    <segment id="10">sese sabe</segment>
    <segment id="11">, ninguém prepara os próprios baked beans: a tradição manda comprá-los enlatados</segment>
    <segment id="12">, da marca Heinz</segment>
    <segment id="13">, que detém 60% do mercado do feijão na Inglaterra.</segment>
    <segment id="14">Os baked beans são tão relevantes para a cultura doméstica britânica que a revista The Economist publicou um artigo em que especula suas origens.</segment>
    <segment id="15">Café da manhã inglês</segment>
    <segment id="16">, com baked beans (feijões em molho de tomate)</segment>
    <segment id="17">, hash browns (batata ralada e frita)</segment>
    <segment id="18">, ovo, bacon</segment>
    <segment id="19">, linguiça e tomate assado - Marcos NogueiraAparentemente</segment>
    <segment id="20">, os indígenas da América do Norte já preparavam o feijão com gordura de animais</segment>
    <segment id="21">, em especial de urso e de veado.</segment>
    <segment id="22">Os colonos europeus trocaram a caça por porco e tacaram melaço de cana no negócio.</segment>
    <segment id="23">Os Boston baked beans –a cidade de Massachusetts é famosa pela receita– são doces no limite do intolerável.</segment>
    <segment id="24">Eu os provei nos EUA e</segment>
    <segment id="25">, talvez por isso</segment>
    <segment id="26">, pensava que os feijões ingleses fossem igualmente intragáveis.</segment>
    <segment id="27">Não são.</segment>
    <segment id="28">Aqui, os baked beans chegaram por meio da própria Heinz</segment>
    <segment id="29">, companhia americana com operação em muitos países (inclusive o Brasil).</segment>
    <segment id="30">"</segment>
    <segment id="31">A fábrica da Heinz em Wigan</segment>
    <segment id="32">, norte da Inglaterra</segment>
    <segment id="33">, é a maior planta de processamento de alimentos da Europa e produz cerca de 3 milhões de latas de feijões por dia"</segment>
    <segment id="34">, diz o texto da Economist.</segment>
    <segment id="35">Os baked beans são feijões brancos pequenos</segment>
    <segment id="36">, de uma variedade conhecida aqui por haricot ("feijão"</segment>
    <segment id="37">, em francês).</segment>
    <segment id="38">Nos Estados Unidos</segment>
    <segment id="39">, os mesmos feijões</segment>
    <segment id="40">sese chamam navy beans.</segment>
    <segment id="41">Eles vêm num molho de tomate não muito doce –menos doce do que ketchup</segment>
    <segment id="42">, por exemplo– e são tipicamente comidos sobre torradas</segment>
    <segment id="43">, no café da manhã.</segment>
    <segment id="44">Costumam figurar no full</segment>
    <segment id="45">English breakfast</segment>
    <segment id="46">, um festim matinal que inclui também bacon</segment>
    <segment id="47">, ovos</segment>
    <segment id="48">, linguiça</segment>
    <segment id="49">, chouriço de sangue (black pudding)</segment>
    <segment id="50">, tomates assados e cogumelos.</segment>
    <segment id="51">Em uma semana de Londres</segment>
    <segment id="52">, tomei duas vezes esse desjejum titânico.</segment>
    <segment id="53">E, vou dizer</segment>
    <segment id="54">, é bom demais.</segment>
    <segment id="55">Se você pensar além da rotina bitolada</segment>
    <segment id="56">, dos mesmos hábitos que</segment>
    <segment id="57">sese repetem em modo automático</segment>
    <segment id="58">, verá que não há nada de bizarro ou extraordinário em comer feijões pela manhã.</segment>
    <segment id="59">O desjejum completo dos ingleses é uma tradição que vem de trabalhadores braçais que acordam muito cedo e precisam de muita energia para as tarefas do dia.</segment>
    <segment id="60">Aqui eles comem feijão com chouriço</segment>
    <segment id="61">, no Nordeste do Brasil comem-</segment>
    <segment id="62">sese inhame</segment>
    <segment id="63">, abóbora e tripas fritas.</segment>
    <segment id="64">Cada cultura define o que é comida adequada para o café da manhã com critérios que</segment>
    <segment id="65">, para quem vê de fora</segment>
    <segment id="66">, parecem aleatórios.</segment>
    <segment id="67">Japoneses comem peixe em conserva.</segment>
    <segment id="68">Para os americanos</segment>
    <segment id="69">, ovo é comida matinal</segment>
    <segment id="70">, sempre.</segment>
    <segment id="71">Eles estranham ovos no jantar</segment>
    <segment id="72">, por exemplo.</segment>
    <segment id="73">No Rio Grande do Sul</segment>
    <segment id="74">, o café da manhã rural admite o feijão campeiro.</segment>
    <segment id="75">São feijões pretos com nacos de porco</segment>
    <segment id="76">, quase uma feijoada expressa</segment>
    <segment id="77">, que eu provei e aprovei no Parador Hampel</segment>
    <segment id="78">, em São Francisco de Paula.</segment>
    <segment id="79">Caso sejam os gases causados pelo feijão o motivo da estranheza</segment>
    <segment id="80">, pense: a manhã é a melhor hora para gerá-los e dispensá-los na atmosfera.</segment>
    <segment id="81">O problema é comer feijão no jantar.</segment>
  </rst>
</analysis>