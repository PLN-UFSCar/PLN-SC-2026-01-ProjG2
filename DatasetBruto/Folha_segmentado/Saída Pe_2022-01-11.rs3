  <rst>
    <segment id="1">Amigos</segment>
    <segment id="2">,  Este é o último post de Saída</segment>
    <segment id="3">Pela Direita.</segment>
    <segment id="4">Minhas novas funções na Folha</segment>
    <segment id="5">, como</segment>
    <segment id="6">como editor da coluna Painel</segment>
    <segment id="7">, que assumi nesta segunda-feira (10)</segment>
    <segment id="8">, me levaram a decidir encerrar o blog.</segment>
    <segment id="9">Foram três anos intensos dedicados a falar de conservadores</segment>
    <segment id="10">, liberais</segment>
    <segment id="11">, bolsonaristas</segment>
    <segment id="12">, monarquistas</segment>
    <segment id="13">, evangélicos</segment>
    <segment id="14">, ruralistas</segment>
    <segment id="15">, armamentistas</segment>
    <segment id="16">, militares e tantos outros segmentos do mundo destro.</segment>
    <segment id="17">A ex-primeira-ministra do Reino Unido Margaret Thatcher acena aos leitores de Saída</segment>
    <segment id="18">Pela Direita- Getty Images/BBC News BrasilMuita</segment>
    <segment id="19">gente estranhava no começo e me perguntava por que um blog sobre a direita?</segment>
    <segment id="20">A resposta era sempre a mesma:</segment>
    <segment id="21">porque</segment>
    <segment id="22">porque a direita era a novidade do momento</segment>
    <segment id="23">, um mundo ainda desconhecido pela bolha progressista</segment>
    <segment id="24">, e que de repente</segment>
    <segment id="25">sese impôs politicamente com a eleição de Jair Bolsonaro</segment>
    <segment id="26">, em 2018.</segment>
    <segment id="27">Era preciso contar essa história.</segment>
    <segment id="28">Colunas e BlogsReceba no seu email uma seleção de colunas e blogs da Folha</segment>
    <segment id="29">; exclusiva para assinantes.</segment>
    <segment id="30">Carregando...</segment>
    <segment id="31">Hoje, às portas de um novo pleito</segment>
    <segment id="32">, parte desse desconhecimento foi sanado</segment>
    <segment id="33">, e espero que o Saída tenha contribuído um pouquinho para isso.</segment>
    <segment id="34">Em outras palavras</segment>
    <segment id="35">, sinto que a missão desse blog já foi cumprida.</segment>
    <segment id="36">Outra confusão frequente era achar que eu era bolsonarista</segment>
    <segment id="37">, extremista</segment>
    <segment id="38">, fascista</segment>
    <segment id="39">, direitoso</segment>
    <segment id="40">, ou o que quer que seja.</segment>
    <segment id="41">Ganhei até haters</segment>
    <segment id="42">, algo que hoje é quase sinal de prestígio.</segment>
    <segment id="43">Mas creio que a maioria tenha entendido que não era um blog "de" direita</segment>
    <segment id="44">, e sim "sobre" a direita.</segment>
    <segment id="45">Aprendi demais nesse período</segment>
    <segment id="46">, de entender conceitos teóricos que eu nem suspeitava existirem</segment>
    <segment id="47">, até descobrir a melhor maneira de caminhar pelo verdadeiro campo minado que é retratar este tema polarizador e fascinante.</segment>
    <segment id="48">A todos que me leram</segment>
    <segment id="49">, criticaram e ajudaram</segment>
    <segment id="50">, muitíssimo obrigado.</segment>
    <segment id="51">O material publicado ficará disponível aqui.</segment>
    <segment id="52">E não pretendo abandonar a cobertura desse universo</segment>
    <segment id="53">, que seguirá contemplada no Painel.</segment>
    <segment id="54">Nos vemos lá!</segment>
  </rst>
</analysis>