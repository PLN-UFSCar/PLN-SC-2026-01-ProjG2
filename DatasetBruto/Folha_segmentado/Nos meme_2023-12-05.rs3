  <rst>
    <segment id="1">O Brasileirão 2023 será marcado</segment>
    <segment id="2">comocomo aquele que o Botafogo perdeu depois de abrir 13 pontos de vantagem sobre o segundo colocado.</segment>
    <segment id="3">Agora na quinta posição</segment>
    <segment id="4">, o clube carioca corre o risco de ficar fora da fase de grupos da Libertadores</segment>
    <segment id="5">, e ter que disputar as fases classificatórias.</segment>
    <segment id="6">Nesta quarta</segment>
    <segment id="7">, o Palmeiras deve sagrar-</segment>
    <segment id="8">sese campeão brasileiro mais uma vez --só uma façanha à la Botafogo tira o título dos palestrinos</segment>
    <segment id="9">, o 12º torneio nacional.</segment>
    <segment id="10">O #Hashtag separou os melhores memes que retratam a vida do Botafogo e o virtual título do Palmeiras.</segment>
    <segment id="11">O botafoguense Pedro Certezas foi um dos grandes personagens deste Brasileirão.</segment>
    <segment id="12">Empolgado com a campanha do time no primeiro turno</segment>
    <segment id="13">, o influenciador fez posts bastante enfáticos.</segment>
    <segment id="14">No fim</segment>
    <segment id="15">, depois da derrapada histórica</segment>
    <segment id="16">, acabou virando personagem de reportagens sobre saúde mental.</segment>
    <segment id="17">O influenciador Felipe Neto é outro botafoguense que será lembrado nos memes do futuro.</segment>
    <segment id="18">Fiasco homérico para muitos</segment>
    <segment id="19">, não para Mãe Michele.</segment>
    <segment id="20">Nem Tchê Tchê fez milagre.</segment>
    <segment id="21">O maior vexame da história dos pontos corridos.</segment>
    <segment id="22">Feito inédito.</segment>
    <segment id="23">A história foi escrita neste exato momento.</segment>
    <segment id="24">Time que surpreendeu: Botafogo.</segment>
    <segment id="25">Time que decepcionou: Botafogo.</segment>
    <segment id="26">Queima de arquivo.</segment>
    <segment id="27">Literalmente Botafogo (o vídeo é antigo</segment>
    <segment id="28">, masmas retrata com precisão o momento).</segment>
    <segment id="29">Meteram até a política no meio dos memes.</segment>
    <segment id="30">Cavalo botafoguense.</segment>
    <segment id="31">Distância histórica.</segment>
    <segment id="32">Saudades do que a gente não viveu.</segment>
    <segment id="33">Os memes sobre o Botafogo são tão bons que a gente até esquece do virtual campeão Palmeiras.</segment>
    <segment id="34">Endrick</segment>
    <segment id="35">, de 17 anos</segment>
    <segment id="36">, foi decisivo na reta final do Brasileirão.</segment>
    <segment id="37">Ele tem tudo para ser um dos maiores jogadores da nova geração --irá atuar pelo Real Madrid a partir de julho de 2024.</segment>
    <segment id="38">O gol contra o Botafogo na épica virada de 4 a 3 foi uma obra-prima.</segment>
    <segment id="39">O Palmeiras de Abel Ferreira ganhou de tudo.</segment>
    <segment id="40">E o palmeirense provoca o botafoguense.</segment>
    <segment id="41">O torcedor do Corinthians</segment>
    <segment id="42">, por outro lado</segment>
    <segment id="43">, não teve um ano para comemorar.</segment>
    <segment id="44">Ou melhor:</segment>
    <segment id="45">respirou aliviado por não ter sido rebaixado.</segment>
    <segment id="46">Mas ele tem esperanças de dias melhores.</segment>
    <segment id="47">Quem também está animado é o flamenguista</segment>
    <segment id="48">, apesar de não ter conquistado nenhum título este ano.</segment>
    <segment id="49">O apoio no Maracanã não faltou.</segment>
    <segment id="50">Campeão simbólico do returno</segment>
    <segment id="51">, o Galo não repetiu o título de 2021</segment>
    <segment id="52">, masmas tem tudo para ser vice em 2023.</segment>
    <segment id="53">Renato Gaúcho</segment>
    <segment id="54">, treinador do Grêmio</segment>
    <segment id="55">, entregou um presente para Luis Suárez na despedida do uruguaio.</segment>
  </rst>
</analysis>