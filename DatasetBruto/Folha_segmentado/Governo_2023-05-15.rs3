  <rst>
    <segment id="1">O governo Lula (PT) prepara uma série de medidas voltadas para a chamada classe média baixa.</segment>
    <segment id="2">A ideia</segment>
    <segment id="3">, de acordo com um integrante do governo</segment>
    <segment id="4">, é 'abrir diálogo' com essa parte da população</segment>
    <segment id="5">, que ganha entre três e cinco salários mínimos e que foi mais refratária ao PT na eleição presidencial.</segment>
    <segment id="6">O presidente Lula em pronunciamento ao lado do primeiro-ministro holandês</segment>
    <segment id="7">, Mark Rutte</segment>
    <segment id="8">, no Palácio do Planalto - Evaristo Sá/AFPPERTO  Segundo um integrante do governo que participa da discussão do que seria um pacote de boas notícias para esse segmento</segment>
    <segment id="9">, todos os programas do governo lançados até agora e que têm efeito imediato beneficiaram o eleitorado mais pobre</segment>
    <segment id="10">, já fiel a Lula.</segment>
    <segment id="11">LINHA  Entre eles estão o Minha Casa</segment>
    <segment id="12">, Minha Vida</segment>
    <segment id="13">, com foco nas famílias de baixa renda</segment>
    <segment id="14">, e o novo Bolsa Família.</segment>
    <segment id="15">Seria chegada a hora</segment>
    <segment id="16">, portanto</segment>
    <segment id="17">, de focar na classe média.</segment>
    <segment id="18">LINHA 2</segment>
    <segment id="19">Um dos exemplos citados é um programa que facilite a aquisição de painéis de energia solar.</segment>
    <segment id="20">Lula já zerou os impostos federais sobre eles.</segment>
    <segment id="21">E deve somar à medida uma linha de financiamento para a aquisição do equipamento</segment>
    <segment id="22">, num programa batizado de "</segment>
    <segment id="23">Sol para Todos".</segment>
    <segment id="24">Conheça o novo Bolsa FamíliaMais    novamente         de   de  de  representando um    LINHA 3</segment>
    <segment id="25">Outra iniciativa seria reforçar</segment>
    <segment id="26">, no Mais Médicos</segment>
    <segment id="27">, o que vem sendo chamado de "Mais Especialistas"</segment>
    <segment id="28">, em que profissionais de saúde sejam preparados para fazer atendimentos mais complexos e específicos.</segment>
    <segment id="29">TABELA  De acordo com pesquisas do Datafolha divulgadas no segundo turno de 2022</segment>
    <segment id="30">, Lula ganhou entre os mais pobres</segment>
    <segment id="31">, por 61% a 39% dos votos válidos.</segment>
    <segment id="32">Entre os que ganham de dois a cinco salários mínimos</segment>
    <segment id="33">, Jair Bolsonaro (PL) ganhou</segment>
    <segment id="34">, por 55% a 45%.</segment>
    <segment id="35">Este é Lula em 2023Mais    novamente         de   de  de  representando um  LEIA</segment>
    <segment id="36">TODOS OS TEMAS ABORDADOS PELA COLUNA NA EDIÇÃO IMPRESSA DESTA TERÇA (16)Governo Lula prepara pacote de boas notícias para classe média baixa</segment>
    <segment id="37">Entidades LGBTQIA+ acionam Justiça</segment>
    <segment id="38">para que</segment>
    <segment id="39">para que Nikolas pague R$ 5 mi por transfobia Mais de cem entidades pedem a Lula que Bolsa Família fique de fora do arcabouço fiscal CCBB expande atuação em SP com inauguração de novo prédioTata Amaral vai a Cannes em busca de coprodutores para novo projeto Zé Ibarra lançará projeto inspirado em prédio onde viveu e em lives do confinamento  REGÊNCIA  Concerto &amp;#</segment>
    <segment id="40">039;Israel 75 anos - Yom Haatzmaut&amp;#039</segment>
    <segment id="41">;Mais    novamente         de   de  de  representando um</segment>
    <segment id="42">A apresentadora Didi Wagner prestigiou o "Concerto</segment>
    <segment id="43">Israel 75 anos</segment>
    <segment id="44">– Yom Haatzmaut"</segment>
    <segment id="45">, ocorrido no Clube Hebraica de São Paulo</segment>
    <segment id="46">, na semana passada.</segment>
    <segment id="47">O presidente do grupo Bandeirantes</segment>
    <segment id="48">, Johnny Saad</segment>
    <segment id="49">, também compareceu ao evento</segment>
    <segment id="50">, realizado em celebração aos 75 anos da criação do Estado de Israel.</segment>
    <segment id="51">A secretária municipal de Segurança Urbana de São Paulo</segment>
    <segment id="52">, Elza Paulina de Souza</segment>
