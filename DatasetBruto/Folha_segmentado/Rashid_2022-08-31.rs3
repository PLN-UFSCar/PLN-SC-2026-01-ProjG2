  <rst>
    <segment id="1">As pessoas no final do dia não sabem nada de ninguém</segment>
    <segment id="2">, masmas na internet</segment>
    <segment id="3">a galera tem mania de bater o martelo e julgar</segment>
    <segment id="4">, achando que conhece toda nossa história</segment>
    <segment id="5">, é assim que o rapper Rashid explica a música "</segment>
    <segment id="6">Não Sabem de Nada"</segment>
    <segment id="7">, faixa responsável por abrir caminho para o seu quarto disco de estúdio -previsto ainda para este semestre.</segment>
    <segment id="8">"</segment>
    <segment id="9">Especialmente num país que o presidente não quer enxergar a fome</segment>
    <segment id="10">, isso mostra que as pessoas não sabem de nada mesmo"</segment>
    <segment id="11">, em referência a fala de Bolsonaro (PL)</segment>
    <segment id="12">, em que ele diz que não existe fome "para valer" no Brasil.</segment>
    <segment id="13">Rashid durante divulgação de disco - Instagram/mcrashidOs últimos dois anos foram um período de paciência e experimentação para Rashid.</segment>
    <segment id="14">Após ter lançado seu último álbum</segment>
    <segment id="15">, "</segment>
    <segment id="16">Tão Real</segment>
    <segment id="17">"</segment>
    <segment id="18">, de 2020</segment>
    <segment id="19">, o rapper apostou em um podcast "Cama</segment>
    <segment id="20">, Mesa e Trampo"</segment>
    <segment id="21">, com sua mulher Dani Rodrigues -que acompanha o cantor desde o início da carreira.</segment>
    <segment id="22">Apresentou o campeonato de rimas</segment>
    <segment id="23">Red Bull Francamente</segment>
    <segment id="24">, além de compor e produzir canções para outros artistas.</segment>
    <segment id="25">"</segment>
    <segment id="26">Paciência foi meu maior aprendizado durante a pandemia.</segment>
    <segment id="27">Eu sou um cara que escreve o que vê nas ruas</segment>
    <segment id="28">, nos shows</segment>
    <segment id="29">, no dia a dia da quebrada</segment>
    <segment id="30">, não poder sair de casa me fez uma pessoa paciente durante esse período além de me ajudar a criar em outros campos"</segment>
    <segment id="31">, comenta o rapper que lembra que fez chamadas de vídeo com fãs a lives jogando e ouvindo música.</segment>
    <segment id="32">Sobre os rappers que estouraram na internet durante o período mais crítico da pandemia</segment>
    <segment id="33">, Rashid comenta que os artistas que conseguem transformar views em público são brilhantes.</segment>
    <segment id="34">"É admirável essa nova geração</segment>
    <segment id="35">comocomo Kyan e a dupla Tasha e Tracie</segment>
    <segment id="36">, que conseguem fazer essa volta de estourar em aplicativos de internet e formar públicos reais</segment>
    <segment id="37">, comprando ingresso só mostra que o trabalho deles tem substância e que eles realmente são bons"</segment>
    <segment id="38">, Rashid ainda comenta que</segment>
    <segment id="39">, comparado a esses nomes no rap que viralizaram na internet</segment>
    <segment id="40">, sese considera da velha geração do rap.</segment>
    <segment id="41">Imagens do rapper RashidMais    novamente         de   de  de  representando um</segment>
    <segment id="42">Sobre a nova música lançada nesta quarta-feira (31)</segment>
    <segment id="43">, o rapper comenta que a composição é tão honesta que chega a ser crua.</segment>
    <segment id="44">"</segment>
    <segment id="45">Ela diz também para o ouvinte que ele não está só</segment>
    <segment id="46">, porque</segment>
    <segment id="47">porque todos passam por momentos difíceis no trampo e na rua.</segment>
    <segment id="48">É o tipo de som motivador e o audiovisual foi muito baseado nisso</segment>
    <segment id="49">, com uma estética bem direta e urbana</segment>
    <segment id="50">, trazida com técnicas de direção diferentes".</segment>
    <segment id="51">Ainda sobre o tempo sem lançar novos trabalhos na música</segment>
    <segment id="52">, Rashid lembra.</segment>
    <segment id="53">"</segment>
    <segment id="54">Quando a gente passa um tempo sem lançar nada</segment>
    <segment id="55">, quando retomamos</segment>
    <segment id="56">, a gente</segment>
    <segment id="57">sese sente voltando.</segment>
    <segment id="58">Então se</segment>
    <segment id="59">se é para voltar</segment>
    <segment id="60">, que seja com os dois pés na porta".</segment>
  </rst>
