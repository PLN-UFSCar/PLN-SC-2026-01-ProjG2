    <segment id="45">;</segment>
    <segment id="46">Explodir criança no Natal &amp;amp</segment>
    <segment id="47">; Roubar".</segment>
    <segment id="48">Os bolsonaristas "raiz" não terão problema de vesti-la.</segment>
    <segment id="49">Eles votaram em Jair</segment>
    <segment id="50">para que</segment>
    <segment id="51">para que ele desse um golpe e ficarão felizes pela tentativa</segment>
    <segment id="52">, ainda que frustrados com a incompetência.</segment>
    <segment id="53">Mas como</segment>
    <segment id="54">como fica</segment>
    <segment id="55">, por exemplo</segment>
    <segment id="56">, a situação de Tarcísio de Freitas?</segment>
    <segment id="57">O governador de São Paulo vai continuar</segment>
    <segment id="58">sese declarando "bolsonarista" com Jair preso por golpe de Estado?</segment>
    <segment id="59">Apoiar</segment>
    <segment id="60">Tarcísio será comprar esse pacote golpista?</segment>
    <segment id="61">Já a condenação pelo roubo das joias deve bater mais fundo no eleitorado bolsonarista</segment>
    <segment id="62">comocomo um todo.</segment>
    <segment id="63">É um crime fácil de entender.</segment>
