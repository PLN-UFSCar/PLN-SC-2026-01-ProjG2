  <rst>
    <segment id="1">A Abras (associação brasileira de supermercados) vai criar uma nova data anual no calendário do varejo para oferecer descontos</segment>
    <segment id="2">, uma espécie de Black Friday dos supermercados.</segment>
    <segment id="3">Chamado de Dia do Supermercado</segment>
    <segment id="4">, o evento vai acontecer pela primeira vez no dia 12 de novembro.</segment>
    <segment id="5">Vista interna de um supermercado em São Paulo - Rubens Cavallari - 27.abr.2022/FolhapressA ideia</segment>
    <segment id="6">, segundo a Abras</segment>
    <segment id="7">, é estimular a demanda e aquecer o consumo nos lares.</segment>
    <segment id="8">A associação afirma que indústria e varejo já começaram a negociar promoções para a data.</segment>
    <segment id="9">Joana Cunha com Paulo Ricardo Martins e Diego</segment>
    <segment id="10">Felix</segment>
