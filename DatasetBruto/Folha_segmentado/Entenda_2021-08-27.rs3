  <rst>
    <segment id="1">Em meio &amp;agrave</segment>
    <segment id="2">; radicaliza&amp;ccedil</segment>
    <segment id="3">;&amp;atilde</segment>
    <segment id="4">;o e escalada do discurso golpista do presidente Jair Bolsonaro</segment>
    <segment id="5">, est&amp;atilde</segment>
    <segment id="6">;o sendo organizadas manifesta&amp;ccedil</segment>
    <segment id="7">;&amp;otilde</segment>
    <segment id="8">;es para o pr&amp;oacute</segment>
    <segment id="9">;ximo dia 7 de setembro que t&amp;ecirc</segment>
    <segment id="10">;m entre suas bandeiras a destitui&amp;ccedil</segment>
    <segment id="11">;&amp;atilde</segment>
    <segment id="12">;o de ministros do STF (Supremo Tribunal Federal)</segment>
    <segment id="13">, invas&amp;atilde</segment>
    <segment id="14">;o do Senado</segment>
    <segment id="15">, viol&amp;ecirc</segment>
    <segment id="16">;ncia contra autoridades p&amp;uacute</segment>
    <segment id="17">;blicas e interven&amp;ccedil</segment>
    <segment id="18">;&amp;atilde</segment>
    <segment id="19">;o militar.</segment>
    <segment id="20">Parte da tentativa de frear uma amea&amp;ccedil</segment>
    <segment id="21">;a golpista e uma fragiliza&amp;ccedil</segment>
    <segment id="22">;&amp;atilde</segment>
    <segment id="23">;o irrevers&amp;iacute</segment>
    <segment id="24">;vel da democracia tem partido majoritariamente do Judici&amp;aacute</segment>
    <segment id="25">;rio.</segment>
    <segment id="26">Recentemente</segment>
    <segment id="27">, por determina&amp;ccedil</segment>
    <segment id="28">;&amp;atilde</segment>
    <segment id="29">;o do STF</segment>
    <segment id="30">, o presidente do PTB Roberto Jefferson foi preso preventivamente e o cantor S&amp;eacute</segment>
    <segment id="31">;rgio Reis</segment>
    <segment id="32">, alvo de medidas cautelares.</segment>
    <segment id="33">Advogados e professores de direito consultados pela Folha apontam que</segment>
    <segment id="34">, sese de um lado h&amp;aacute</segment>
    <segment id="35">;</segment>
    <segment id="36">de fato discursos que ultrapassam os limites da liberdade de express&amp;atilde</segment>
    <segment id="37">;o, na maioria das situa&amp;ccedil</segment>
    <segment id="38">;&amp;otilde</segment>
    <segment id="39">;es, outros fatores</segment>
    <segment id="40">, al&amp;eacute</segment>
    <segment id="41">;m da fala por si s&amp;oacute</segment>
    <segment id="42">;</segment>
    <segment id="43">, precisam ser considerados</segment>
    <segment id="44">para que</segment>
    <segment id="45">para que as condutas sejam criminalizadas e n&amp;atilde</segment>
    <segment id="46">;o sese abram precedentes perigosos.</segment>
    <segment id="47">Bolsonaristas fazem atos pelo país em defesa do voto impressoMais    novamente         de   de  de  representando um  </segment>
    <segment id="48">A liberdade de express&amp;atilde</segment>
    <segment id="49">;o &amp;eacute</segment>
    <segment id="50">; absoluta?</segment>
    <segment id="51">Ela pode ser usada para defender o fim da democracia?</segment>
    <segment id="52">Entre os direitos fundamentais garantidos pela Constitui&amp;ccedil</segment>
    <segment id="53">;&amp;atilde</segment>
    <segment id="54">;o est&amp;atilde</segment>
    <segment id="55">;o a liberdade de express&amp;atilde</segment>
    <segment id="56">;o e de manifesta&amp;ccedil</segment>
    <segment id="57">;&amp;atilde</segment>
    <segment id="58">;o.</segment>
    <segment id="59">Nenhum dos dois direitos</segment>
    <segment id="60">, entretanto</segment>
    <segment id="61">, &amp;eacute</segment>
    <segment id="62">; absoluto</segment>
    <segment id="63">, sendo preciso balance&amp;aacute</segment>
    <segment id="64">;-los e delimit&amp;aacute</segment>
    <segment id="65">;-los, em</segment>
    <segment id="66">casocaso de conflito com outros direitos.</segment>
    <segment id="67">E &amp;eacute</segment>
    <segment id="68">; na relativiza&amp;ccedil</segment>
    <segment id="69">;&amp;atilde</segment>
    <segment id="70">;o que mora um complicado debate jur&amp;iacute</segment>
    <segment id="71">;dico,</segment>
    <segment id="72">poispois h&amp;aacute</segment>
    <segment id="73">; entendimentos muito distintos do que est&amp;aacute</segment>
    <segment id="74">; ou n&amp;atilde</segment>
    <segment id="75">;o protegido.</segment>
    <segment id="76">No contexto atual</segment>
    <segment id="77">, questiona-</segment>
    <segment id="78">sese por exemplo</segment>
    <segment id="79">sese defender o fechamento do STF ou mesmo uma interven&amp;ccedil</segment>
    <segment id="80">;&amp;atilde</segment>
    <segment id="81">;o militar extrapolaria este direito.</segment>
    <segment id="82">&amp;ldquo</segment>
    <segment id="83">;A</segment>
    <segment id="84">democracia n&amp;atilde</segment>
    <segment id="85">;o pode aceitar aquilo que meus colegas chamam de discursos suicidas</segment>
    <segment id="86">, ou seja</segment>
    <segment id="87">, aqueles discursos que n&amp;atilde</segment>
    <segment id="88">;o sejam meras defesas de teses</segment>
    <segment id="89">, masmas a&amp;ccedil</segment>
    <segment id="90">;&amp;otilde</segment>
    <segment id="91">;es que pregam a sua pr&amp;oacute</segment>
    <segment id="92">;pria extin&amp;ccedil</segment>
    <segment id="93">;&amp;atilde</segment>
    <segment id="94">;o.</segment>
    <segment id="95">Seria um paradoxo do qual n&amp;atilde</segment>
    <segment id="96">;o sese teria sa&amp;iacute</segment>
    <segment id="97">;da&amp;rdquo</segment>
    <segment id="98">;, diz o professor de hist&amp;oacute</segment>
    <segment id="99">;ria do direito penal Diego Nunes</segment>
    <segment id="100">, da UFSC (Universidade Federal de Santa Catarina).</segment>
    <segment id="101">O professor de direito Leonardo Penteado Rosa</segment>
    <segment id="102">, da UFLA (Universidade Federal de Lavras)</segment>
    <segment id="103">, diz que outros elementos precisam ser analisados.</segment>
    <segment id="104">Na decis&amp;atilde</segment>
    <segment id="105">;o de Moraes que determinou a pris&amp;atilde</segment>
    <segment id="106">;o de Roberto Jefferson</segment>
    <segment id="107">, ele considera</segment>
    <segment id="108">, por exemplo</segment>
    <segment id="109">, que por ser uma opini&amp;atilde</segment>
    <segment id="110">;o do campo pol&amp;iacute</segment>
    <segment id="111">;tico, n&amp;atilde</segment>
    <segment id="112">;o haveria abuso em falas defendendo que Bolsonaro deveria usar o artigo 142 da Constitui&amp;ccedil</segment>
    <segment id="113">;&amp;atilde</segment>
    <segment id="114">;o para uma interven&amp;ccedil</segment>
    <segment id="115">;&amp;atilde</segment>
    <segment id="116">;o militar</segment>
    <segment id="117">, masmas pondera que a situa&amp;ccedil</segment>
    <segment id="118">;&amp;atilde</segment>
    <segment id="119">;o muda quando Jefferson usa express&amp;otilde</segment>
    <segment id="120">;es como</segment>
    <segment id="121">como &amp;</segment>
    <segment id="122">quot;temos que agir agora&amp;rdquo</segment>
    <segment id="123">;, &amp;quot</segment>
    <segment id="124">;concentrar as press&amp;otilde</segment>
    <segment id="125">;es populares&amp;rdquo</segment>
    <segment id="126">;, &amp;quot</segment>
    <segment id="127">;invadir o Senado&amp;rdquo</segment>
    <segment id="128">; e &amp;quot</segment>
    <segment id="129">;colocar pra fora a CPI a pesco&amp;ccedil</segment>
    <segment id="130">;&amp;atilde</segment>
    <segment id="131">;o&amp;rdquo</segment>
    <segment id="132">;.</segment>
    <segment id="133">&amp;ldquo</segment>
    <segment id="134">;Caso haja evid&amp;ecirc</segment>
    <segment id="135">;ncia de que o Roberto Jefferson est&amp;aacute</segment>
    <segment id="136">; sese unindo a outras pessoas para empreender essas a&amp;ccedil</segment>
    <segment id="137">;&amp;otilde</segment>
    <segment id="138">;es, ele de fato est&amp;aacute</segment>
    <segment id="139">; abusando da liberdade de express&amp;atilde</segment>
    <segment id="140">;o&amp;quot</segment>
    <segment id="141">;, afirma.</segment>
    <segment id="142">O que alegam apoiadores de Bolsonaro?</segment>
    <segment id="143">Parlamentares</segment>
    <segment id="144">, pessoas p&amp;uacute</segment>
    <segment id="145">;blicas</segment>
    <segment id="146">, blogueiros e donos de canais de grande audi&amp;ecirc</segment>
    <segment id="147">;ncia nas redes sociais que apoiam o presidente est&amp;atilde</segment>
    <segment id="148">;o entre os alvos de diferentes inqu&amp;eacute</segment>
    <segment id="149">;ritos em curso no STF.</segment>
    <segment id="150">Eles alegam com frequ&amp;ecirc</segment>
    <segment id="151">;ncia que h&amp;aacute</segment>
    <segment id="152">; uma ditadura do Judici&amp;aacute</segment>
    <segment id="153">;rio e que est&amp;atilde</segment>
    <segment id="154">;o sob censura.</segment>
    <segment id="155">Nesses inqu&amp;eacute</segment>
    <segment id="156">;ritos j&amp;aacute</segment>
    <segment id="157">;</segment>
    <segment id="158">ocorreram pris&amp;otilde</segment>
    <segment id="159">;es preventivas</segment>
    <segment id="160">, como</segment>
    <segment id="161">como do blogueiro</segment>
    <segment id="162">Oswaldo Eust&amp;aacute</segment>
    <segment id="163">;quio, do deputado federal Daniel Silveira (PSL-RJ) e</segment>
    <segment id="164">, mais recentemente</segment>
    <segment id="165">, de Roberto Jefferson</segment>
    <segment id="166">, presidente nacional do PTB.</segment>
    <segment id="167">Entre poss&amp;iacute</segment>
    <segment id="168">;veis delitos apontados h&amp;aacute</segment>
    <segment id="169">; desde crimes contra a honra</segment>
    <segment id="170">, de incita&amp;ccedil</segment>
    <segment id="171">;&amp;atilde</segment>
    <segment id="172">;o e de amea&amp;ccedil</segment>
    <segment id="173">;a at&amp;eacute</segment>
    <segment id="174">;</segment>
    <segment id="175">tipos penais previstos na Lei de Seguran&amp;ccedil</segment>
    <segment id="176">;a Nacional &amp;mdash</segment>
    <segment id="177">;texto da ditadura que foi revogado neste m&amp;ecirc</segment>
    <segment id="178">;s pelo Congresso.</segment>
    <segment id="179">Roberto Jefferson e os ataques às instituiçõesMais    novamente         de   de  de  representando um  H&amp;aacute</segment>
    <segment id="180">; cr&amp;iacute</segment>
    <segment id="181">;ticas &amp;agrave</segment>
    <segment id="182">;s decis&amp;otilde</segment>
    <segment id="183">;es do STF?</segment>
    <segment id="184">Uma das investiga&amp;ccedil</segment>
    <segment id="185">;&amp;otilde</segment>
    <segment id="186">;es mais not&amp;oacute</segment>
    <segment id="187">;rias, o inqu&amp;eacute</segment>
    <segment id="188">;rito das fake news</segment>
    <segment id="189">, &amp;eacute</segment>
    <segment id="190">; criticado</segment>
    <segment id="191">, em primeiro lugar</segment>
    <segment id="192">, por ter sido aberto por iniciativa do pr&amp;oacute</segment>
    <segment id="193">;prio tribunal.</segment>
    <segment id="194">&amp;Eacute</segment>
    <segment id="195">; importante fazer a ressalva</segment>
    <segment id="196">, contudo</segment>
    <segment id="197">contudo</segment>
    <segment id="198">, de que parte das decis&amp;otilde</segment>
    <segment id="199">;es recentes decorreram de solicita&amp;ccedil</segment>
    <segment id="200">;&amp;otilde</segment>
    <segment id="201">;es da PGR (Procuradoria-Geral da Rep&amp;uacute</segment>
    <segment id="202">;blica)</segment>
    <segment id="203">, como</segment>
    <segment id="204">como no</segment>
    <segment id="205">casocaso da busca e apreens&amp;atilde</segment>
    <segment id="206">;o contra S&amp;eacute</segment>
    <segment id="207">;rgio Reis</segment>
    <segment id="208">, ou por pedido da Pol&amp;iacute</segment>
    <segment id="209">;cia Federal</segment>
    <segment id="210">, como</segment>
    <segment id="211">como no</segment>
    <segment id="212">casocaso da pris&amp;atilde</segment>
    <segment id="213">;o de Jefferson.</segment>
    <segment id="214">Nestes casos</segment>
    <segment id="215">, o STF apenas deu autoriza&amp;ccedil</segment>
    <segment id="216">;&amp;atilde</segment>
    <segment id="217">;o.</segment>
    <segment id="218">Outra cr&amp;iacute</segment>
    <segment id="219">;tica &amp;eacute</segment>
    <segment id="220">; a de que</segment>
    <segment id="221">, muitas vezes</segment>
    <segment id="222">, n&amp;atilde</segment>
    <segment id="223">;o houve fundamenta&amp;ccedil</segment>
    <segment id="224">;&amp;atilde</segment>
    <segment id="225">;o adequada para medidas mais graves</segment>
    <segment id="226">comocomo a pris&amp;atilde</segment>
    <segment id="227">;o preventiva ou mesmo de busca e apreens&amp;atilde</segment>
    <segment id="228">;o.</segment>
    <segment id="229">E uma terceira dimens&amp;atilde</segment>
    <segment id="230">;o trata de avaliar</segment>
    <segment id="231">sese haveria ou n&amp;atilde</segment>
    <segment id="232">;o crime nas falas e discursos que t&amp;ecirc</segment>
    <segment id="233">;m sido alvo dessas investiga&amp;ccedil</segment>
    <segment id="234">;&amp;otilde</segment>
    <segment id="235">;es.</segment>
    <segment id="236">A professora de direito constitucional Joana Machado</segment>
    <segment id="237">, da UFJF (Universidade Federal de Juiz de Fora)</segment>
    <segment id="238">, diz que no STF</segment>
    <segment id="239">, historicamente</segment>
    <segment id="240">, havia uma linha de decis&amp;otilde</segment>
    <segment id="241">;es no sentido de afirmar o direito &amp;agrave</segment>
    <segment id="242">; liberdade de express&amp;atilde</segment>
    <segment id="243">;o, mas</segment>
    <segment id="244">mas que houve um recuo diante dos ataques &amp;agrave</segment>
    <segment id="245">;s institui&amp;ccedil</segment>
    <segment id="246">;&amp;otilde</segment>
    <segment id="247">;es.  &amp;ldquo</segment>
    <segment id="248">;O</segment>
    <segment id="249">Supremo tem</segment>
    <segment id="250">sese valido de leis que restringem a liberdade de express&amp;atilde</segment>
    <segment id="251">;o como</segment>
    <segment id="252">como resposta &amp;agrave</segment>
    <segment id="253">;</segment>
    <segment id="254">corre&amp;ccedil</segment>
    <segment id="255">;&amp;atilde</segment>
    <segment id="256">;o de discursos que s&amp;atilde</segment>
    <segment id="257">;o anti-institucionais.</segment>
    <segment id="258">Acaba sendo perigoso pelo risco de voc&amp;ecirc</segment>
    <segment id="259">;</segment>
    <segment id="260">ter uma contradi&amp;ccedil</segment>
    <segment id="261">;&amp;atilde</segment>
    <segment id="262">;o perform&amp;aacute</segment>
    <segment id="263">;tica&amp;rdquo</segment>
    <segment id="264">;, diz ela.</segment>
    <segment id="265">Qual a import&amp;acirc</segment>
    <segment id="266">;ncia de limitar discursos de &amp;oacute</segment>
    <segment id="267">;dio, amea&amp;ccedil</segment>
    <segment id="268">;as e incita&amp;ccedil</segment>
    <segment id="269">;&amp;otilde</segment>
    <segment id="270">;es?Para a advogada</segment>
    <segment id="271">Denise Dora</segment>
    <segment id="272">, diretora executiva da ONG</segment>
    <segment id="273">Artigo 19</segment>
    <segment id="274">, &amp;eacute</segment>
    <segment id="275">;</segment>
    <segment id="276">preciso considerar que as recentes decis&amp;otilde</segment>
    <segment id="277">;es do ministro Alexandre de Moraes t&amp;ecirc</segment>
    <segment id="278">;m ocorrido diante da necessidade de regular o aumento da viol&amp;ecirc</segment>
    <segment id="279">;ncia pol&amp;iacute</segment>
    <segment id="280">;tica para que</segment>
    <segment id="281">para que n&amp;atilde</segment>
    <segment id="282">;o haja uma escalada a n&amp;iacute</segment>
    <segment id="283">;veis incontrol&amp;aacute</segment>
    <segment id="284">;veis.</segment>
    <segment id="285">&amp;ldquo</segment>
    <segment id="286">;O que a gente viu dos grandes massacres genocidas dos &amp;uacute</segment>
    <segment id="287">;ltimos 50 anos n&amp;atilde</segment>
    <segment id="288">;o</segment>
    <segment id="289">aconteceram do dia para a noite&amp;rdquo</segment>
    <segment id="290">;, diz.</segment>
    <segment id="291">&amp;ldquo</segment>
    <segment id="292">;[Na guerra da B&amp;oacute</segment>
    <segment id="293">;snia] pessoas que eram vizinhas</segment>
    <segment id="294">, que trabalhavam juntas</segment>
    <segment id="295">, sese tornaram arqui-inimigas e algozes</segment>
    <segment id="296">, numa escalada de discrimina&amp;ccedil</segment>
    <segment id="297">;&amp;atilde</segment>
    <segment id="298">;o &amp;eacute</segment>
    <segment id="299">;tnica e religiosa que n&amp;atilde</segment>
    <segment id="300">;o foi regulada</segment>
    <segment id="301">, que n&amp;atilde</segment>
    <segment id="302">;o foi controlada no in&amp;iacute</segment>
    <segment id="303">;cio.&amp;rdquo</segment>
    <segment id="304">;</segment>
    <segment id="305">Quando uma fala pode ser considerada amea&amp;ccedil</segment>
    <segment id="306">;a ou incita&amp;ccedil</segment>
    <segment id="307">;&amp;atilde</segment>
    <segment id="308">;o?</segment>
    <segment id="309">Anamaria</segment>
    <segment id="310">Prates Barroso</segment>
    <segment id="311">, advogada criminal e doutoranda em direito constitucional</segment>
    <segment id="312">, destaca que a liberdade de express&amp;atilde</segment>
    <segment id="313">;o tem limites</segment>
    <segment id="314">, masmas pondera que muitas das falas que t&amp;ecirc</segment>
    <segment id="315">;m sido inclu&amp;iacute</segment>
    <segment id="316">;das nos inqu&amp;eacute</segment>
    <segment id="317">;ritos n&amp;atilde</segment>
    <segment id="318">;o configuram amea&amp;ccedil</segment>
    <segment id="319">;a e incita&amp;ccedil</segment>
    <segment id="320">;&amp;atilde</segment>
    <segment id="321">;o ou mesmo crime.</segment>
    <segment id="322">&amp;ldquo</segment>
    <segment id="323">;Para que voc&amp;ecirc</segment>
    <segment id="324">; pratique o crime tanto de amea&amp;ccedil</segment>
    <segment id="325">;a ou de incita&amp;ccedil</segment>
    <segment id="326">;&amp;atilde</segment>
    <segment id="327">;o, isso tem que ser algo s&amp;eacute</segment>
    <segment id="328">;rio, consistente.</segment>
    <segment id="329">As bravatas</segment>
    <segment id="330">, por si s&amp;oacute</segment>
    <segment id="331">;</segment>
    <segment id="332">, n&amp;atilde</segment>
    <segment id="333">;o podem caracterizar o crime de incita&amp;ccedil</segment>
    <segment id="334">;&amp;atilde</segment>
    <segment id="335">;o ou amea&amp;ccedil</segment>
    <segment id="336">;a.&amp;rdquo</segment>
    <segment id="337">;</segment>
    <segment id="338">Leonardo Rosa argumenta que &amp;eacute</segment>
    <segment id="339">; preciso tra&amp;ccedil</segment>
    <segment id="340">;ar distin&amp;ccedil</segment>
    <segment id="341">;&amp;otilde</segment>
    <segment id="342">;es a depender do emissor da mensagem e defende que &amp;eacute</segment>
    <segment id="343">; preciso analisar o papel desempenhado por autoridades.</segment>
    <segment id="344">&amp;ldquo</segment>
    <segment id="345">;A gente n&amp;atilde</segment>
    <segment id="346">;o tem que tolerar que um membro das For&amp;ccedil</segment>
    <segment id="347">;as Armadas ou das PMs [tamb&amp;eacute</segment>
    <segment id="348">;m] possa falar uma determinada coisa s&amp;oacute</segment>
    <segment id="349">; porque</segment>
    <segment id="350">porque um cidad&amp;atilde</segment>
    <segment id="351">;o comum fala.&amp;rdquo</segment>
    <segment id="352">;  Diego Nunes (UFSC) adiciona que for&amp;ccedil</segment>
    <segment id="353">;as de seguran&amp;ccedil</segment>
    <segment id="354">;a e militares da ativa t&amp;ecirc</segment>
    <segment id="355">;m o dever de hierarquia</segment>
    <segment id="356">, disciplina e de</segment>
    <segment id="357">sese abster de declara&amp;ccedil</segment>
    <segment id="358">;&amp;otilde</segment>
    <segment id="359">;es de cunho pol&amp;iacute</segment>
    <segment id="360">;tico.</segment>
    <segment id="361">&amp;ldquo</segment>
    <segment id="362">;A</segment>
    <segment id="363">desobedi&amp;ecirc</segment>
    <segment id="364">;ncia a isso pode acarretar no crime de motim</segment>
    <segment id="365">, previsto no C&amp;oacute</segment>
    <segment id="366">;digo Penal Militar e no ainda vigente artigo 17 da Lei de Seguran&amp;ccedil</segment>
    <segment id="367">;a Nacional.&amp;quot</segment>
    <segment id="368">;  NEWSLETTER JURÍDICAReceba no seu email boletins com notícias exclusivas</segment>
    <segment id="369">, análise e opinião sobre assuntos jurídicos</segment>
