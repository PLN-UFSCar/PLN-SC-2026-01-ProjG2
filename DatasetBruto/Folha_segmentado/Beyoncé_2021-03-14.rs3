    <segment id="301">, de Fiona Apple 'Punisher'</segment>
    <segment id="302">, de Phoebe Bridgers 'Hyperspace'</segment>
    <segment id="303">, de Beck 'Jaime'</segment>
    <segment id="304">, de Brittany Howard 'The Slow Rush'</segment>
    <segment id="305">, de Tame Impala</segment>
    <segment id="306">Melhor álbum latino ou urbano 'YHLQMDLG'</segment>
    <segment id="307">, de Bad Bunny 'Pausa'</segment>
    <segment id="308">, de Ricky Martin '3:33'</segment>
    <segment id="309">, de Debi Nova 'Mesa para Dos'</segment>
    <segment id="310">, de Kany García 'Por Primera Vez'</segment>
    <segment id="311">, de Camilo  Melhor álbum de R&amp;amp</segment>
    <segment id="312">;B progressivo 'Ungodly Hour'</segment>
    <segment id="313">, de Chloe X Halle 'Chilombo'</segment>
    <segment id="314">, de Jhene Aiko 'Free Nationals'</segment>
    <segment id="315">, de Free Nationals 'F*** Yo Feelings'</segment>
    <segment id="316">, de Robert Glasper 'It Is What It Is'</segment>
    <segment id="317">, de Thundercat  Melhor álbum de R&amp;amp</segment>
    <segment id="318">;B 'Take Time'</segment>
    <segment id="319">, de Giveon 'Happy 2 Be Here'</segment>
