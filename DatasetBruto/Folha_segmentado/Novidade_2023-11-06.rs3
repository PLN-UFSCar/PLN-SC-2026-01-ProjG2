  <rst>
    <segment id="1">Desde a última quarta-feira (1)</segment>
    <segment id="2">, os passageiros dos voos internacionais da Latam têm uma nova opção de almoço (ou jantar) a bordo: o pintado pantaneiro em crosta de baru</segment>
    <segment id="3">, da chef cuiabana Ariani Malouf.</segment>
    <segment id="4">Servido com banana da terra e arroz de côco</segment>
    <segment id="5">, o prato faz parte dos menus das classes executiva e econômica dos voos de longa duração (mais de sete horas) da companhia.</segment>
    <segment id="6">Quem não tiver uma viagem internacional planejada também pode preparar a receita em casa.</segment>
    <segment id="7">Pintado Pantaneiro em Crosta de Baru</segment>
    <segment id="8">, da chef Ariani Malouf</segment>
    <segment id="9">, servido na classe executiva dos voos internacionais de longa distância da Latam - Bruno Vatanabe/DivulgaçãoO prato de Malouf é o quarto da série Sabor à Brasileira</segment>
    <segment id="10">, que desde fevereiro serve</segment>
    <segment id="11">, nos ares</segment>
    <segment id="12">, pratos de chefs mulheres de todas as regiões do país.</segment>
    <segment id="13">Já passaram pelo menu o Baião de Dois ao Mar</segment>
    <segment id="14">, da chef baiana Nara Amaral</segment>
    <segment id="15">, que inaugurou a série</segment>
    <segment id="16">; a Galinhada das Deusas</segment>
    <segment id="17">, da chef Manuelle Ferraz</segment>
    <segment id="18">, e o Amazônia Encantada</segment>
    <segment id="19">, da chef Débora Shornik.</segment>
    <segment id="20">O projeto reforça a onda de companhias aéreas recrutando chefs para melhorar a imagem de comida de avião.</segment>
    <segment id="21">Dentro da série</segment>
    <segment id="22">, Malouf representa a região centro-oeste do Brasil.</segment>
    <segment id="23">Nascida em Cuiabá (MT) e formada na Le Cordon Bleu</segment>
    <segment id="24">, em Paris</segment>
    <segment id="25">, ela comanda o Mahalo Cozinha Criativa</segment>
    <segment id="26">, um dos melhores restaurantes da região</segment>
    <segment id="27">, famoso por entregar uma cozinha contemporânea que valoriza ingredientes regionais e a fusão inventiva de sabores.</segment>
    <segment id="28">Segundo a companhia aérea</segment>
    <segment id="29">, todos os pratos são harmonizados com uma carta de vinhos assinada por Héctor Vergara</segment>
    <segment id="30">, único Master Sommelier da América Latina</segment>
    <segment id="31">, que analisou mais de 500 opções até chegar a uma lista que realçasse os sabores da América do Sul.  "</segment>
    <segment id="32">O serviço de bordo é um dos pontos de contato em que conseguimos ter uma troca mais próxima ao cliente e demonstrar sua importância ao servir uma boa refeição"</segment>
    <segment id="33">, diz Paulo Miranda</segment>
    <segment id="34">, vice-presidente de Clientes do LATAM Airlines Group.</segment>
    <segment id="35">"</segment>
    <segment id="36">Aproveitamos esse momento para levar o nome de mulheres brasileiras para o mundo por meio de pratos elaborados e que representam em alto nível a riqueza da culinária brasileira.</segment>
    <segment id="37">"</segment>
    <segment id="38">Conheça o pintado pantaneiro</segment>
    <segment id="39">, prato da chef Ariani Malouf para os voos internacionais da LatamMais    novamente         de   de  de  representando</segment>
    <segment id="40">um</segment>
  </rst>
</analysis>