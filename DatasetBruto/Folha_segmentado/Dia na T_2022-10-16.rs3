  </header>
  <rst>
    <segment id="1">Se hoje já nos faltam horas no dia</segment>
    <segment id="2">, imagine</segment>
    <segment id="3">comocomo era há 2</segment>
    <segment id="4">,5 bilhões de anos: naquela época</segment>
    <segment id="5">, o dia na Terra durava apenas 17 horas.</segment>
    <segment id="6">Este é um dos achados de uma equipe internacional de geólogos</segment>
    <segment id="7">, que conseguiu também determinar de maneira inteligente a que distância a Lua estava do nosso planeta naquela época.</segment>
    <segment id="8">Essas coisas estão todas ligadas: a Lua nasceu de um impacto gigante ocorrido contra a Terra há 4</segment>
    <segment id="9">,5 bilhões de anos</segment>
    <segment id="10">, pouco depois da formação do nosso planeta</segment>
    <segment id="11">, e desde então as interações gravitacionais entre os dois corpos vêm fazendo seu trabalho de estica-e-puxa.</segment>
    <segment id="12">O efeito mais notável desse processo é a trava gravitacional que mantém a mesma face da Lua sempre voltada para a Terra.</segment>
    <segment id="13">Mas o jogo corre para os dois lados: a Lua também quer forçar a Terra a manter a mesma face voltada para si.</segment>
    <segment id="14">Como o satélite natural tem massa muito menor que o planeta</segment>
    <segment id="15">, o efeito sobre a Terra é bem mais paulatino.</segment>
    <segment id="16">Ainda assim</segment>
    <segment id="17">, a rotação do nosso mundo vem gradualmente sendo freada pela ação gravitacional lunar.</segment>
    <segment id="18">Logo, era mais veloz no passado.</segment>
    <segment id="19">E, pelo mesmo processo</segment>
    <segment id="20">, ao transferir parte da força para mexer na rotação terrestre</segment>
    <segment id="21">, a Lua vai lentamente</segment>
    <segment id="22">sese afastando em sua órbita.</segment>
    <segment id="23">Hoje a uma distância média de 384</segment>
    <segment id="24">,3 mil km</segment>
    <segment id="25">, nossa companheira fica aproximadamente 3</segment>
    <segment id="26">,8 cm mais distante a cada ano.</segment>
    <segment id="27">É um tiquinho</segment>
    <segment id="28">, masmas que</segment>
    <segment id="29">sese transforma em algo significativo após bilhões de anos.</segment>
    <segment id="30">Rochas sedimentares de Joffre Gorge</segment>
    <segment id="31">, no parque nacional Karijini</segment>
    <segment id="32">, no oeste australiano</segment>
    <segment id="33">, que viabilizaram o estudo dos ciclos de Milankovitch 2</segment>
    <segment id="34">,46 bilhões de anos atrás - Universidade de Utretch/Greg JackEntra o trabalho de Margriet L. Lantink</segment>
    <segment id="35">, da Universidade de Utrecht</segment>
    <segment id="36">, na Holanda</segment>
    <segment id="37">, e colegas</segment>
    <segment id="38">, publicado na PNAS</segment>
    <segment id="39">, revista da Academia Nacional de Ciências dos EUA.</segment>
    <segment id="40">O grupo estudou um grupo de rochas sedimentares antigas no oeste australiano</segment>
    <segment id="41">, que contêm padrões de deposição de ferro e argila que permitem distinguir os chamados ciclos de Milankovitch –fenômeno ligado a oscilações orbitais e axiais periódicas da Terra que dão origem às glaciações.</segment>
    <segment id="42">A periodicidade desses ciclos</segment>
    <segment id="43">, por sua vez</segment>
    <segment id="44">, também guarda relação com a organização do sistema Terra-Lua.</segment>
    <segment id="45">Daí a possibilidade de extrapolar</segment>
    <segment id="46">, a partir de seus registros nas rochas sedimentares</segment>
    <segment id="47">, coisas</segment>
    <segment id="48">comocomo a rotação da Terra e a distância lunar.</segment>
    <segment id="49">Foi o que fizeram os pesquisadores</segment>
    <segment id="50">, constatando que a Lua</segment>
    <segment id="51">, há 2</segment>
    <segment id="52">,46 bilhões de anos</segment>
    <segment id="53">, orbitava a aproximadamente 321</segment>
    <segment id="54">,8 mil km (com margem de erro de 6.500 km).</segment>
    <segment id="55">A Terra</segment>
    <segment id="56">, por sua vez</segment>
    <segment id="57">, concluía uma rotação em 16</segment>
    <segment id="58">,9 horas (com margem de erro de 12 minutos) na mesma época.</segment>
    <segment id="59">O resultado ajuda a compreender melhor a evolução do sistema Terra-Lua e bate o recorde de registro mais antigo de seus parâmetros por uma larga margem</segment>
    <segment id="60">, avançando mais de 1 bilhão de anos no passado com relação a estudos anteriores.</segment>
    <segment id="61">É surpreendente?</segment>
    <segment id="62">Não, pelo contrário.</segment>
    <segment id="63">É algo mais do que esperado</segment>
    <segment id="64">, baseado em tudo que já</segment>
    <segment id="65">sese podia imaginar do passado.</segment>
    <segment id="66">Mas faz diferença não meramente achar</segment>
    <segment id="67">, masmas saber.</segment>
    <segment id="68">As rochas</segment>
    <segment id="69">, testemunhas dos mais remotos eventos do planeta</segment>
    <segment id="70">, contam sua história</segment>
    <segment id="71">, e é isso que nos permite dar conta do que</segment>
    <segment id="72">sese passava por aqui muito antes que o primeiro humano pisasse sobre a Terra.</segment>
    <segment id="73">Esta coluna é publicada às segundas-feiras</segment>
    <segment id="74">, na Folha Corrida.</segment>
    <segment id="75">Siga o Mensageiro Sideral no Facebook</segment>
    <segment id="76">, Twitter</segment>
    <segment id="77">, Instagram e YouTube</segment>
  </rst>
</analysis>