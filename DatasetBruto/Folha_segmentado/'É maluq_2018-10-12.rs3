  <rst>
    <segment id="1">O ex-presidente Lula recebeu visitantes que perguntaram a ele</segment>
    <segment id="2">sese tinha visto os apelos</segment>
    <segment id="3">para que</segment>
    <segment id="4">para que Fernando Haddad renunciasse</segment>
    <segment id="5">, deixando o terceiro colocado</segment>
    <segment id="6">, Ciro Gomes (PDT-CE)</segment>
    <segment id="7">, disputar o segundo turno com Jair Bolsonaro (PSL-RJ).</segment>
    <segment id="8">“Isso é uma maluquice”</segment>
    <segment id="9">, respondeu.</segment>
    <segment id="10">O ex-presidente Lula - ReutersAPELO</segment>
    <segment id="11">Na quarta (10)</segment>
    <segment id="12">, a ideia foi explicitada pela senadora Kátia Abreu (PDT-TO)</segment>
    <segment id="13">, que postou no Twitter uma mensagem pedindo:</segment>
    <segment id="14">“Haddad renuncie e mostre que o Brasil é mais importante que o poder”.</segment>
    <segment id="15">SAI DESSA</segment>
    <segment id="16">O tom da mensagem</segment>
    <segment id="17">, segundo interlocutores do PT</segment>
    <segment id="18">, enterraria a chance de uma conversa séria sobre a hipótese</segment>
    <segment id="19">, que, dizem</segment>
    <segment id="20">, nunca existiu.</segment>
    <segment id="21">QUALIDADE</segment>
    <segment id="22">Lula estaria tranquilo.</segment>
    <segment id="23">Aos interlocutores</segment>
    <segment id="24">, teria dito que a vitória é difícil</segment>
    <segment id="25">, masmas não impossível.</segment>
    <segment id="26">Caso frustrada</segment>
    <segment id="27">, o importante seria o PT “qualificar a derrota”</segment>
    <segment id="28">, apontando “a tragédia que virá”.  ONDA</segment>
    <segment id="29">“</segment>
    <segment id="30">O tsunami vai e volta”</segment>
    <segment id="31">, e a disputa política não</segment>
    <segment id="32">sese encerra em uma eleição</segment>
    <segment id="33">, teria dito ele aos visitantes.</segment>
    <segment id="34">VENTO</segment>
    <segment id="35">O presidente da Câmara dos Deputados</segment>
    <segment id="36">, Rodrigo Maia</segment>
    <segment id="37">, diz que só vai tratar de sua eventual recondução ao cargo depois do segundo turno.</segment>
    <segment id="38">“E nunca seria presidente [da Casa] contra ninguém.</segment>
    <segment id="39">Muito menos contra o futuro presidente eleito</segment>
    <segment id="40">, independente de quem seja”</segment>
    <segment id="41">, afirma.</segment>
    <segment id="42">VENTO 2</segment>
    <segment id="43">Um grupo de parlamentares já</segment>
    <segment id="44">sese articula para formar uma frente de apoio à recondução de Maia.</segment>
    <segment id="45">Eles querem evitar que a Casa caia nas mãos do grupo de Bolsonaro</segment>
    <segment id="46">casocaso ele</segment>
    <segment id="47">sese eleja presidente.</segment>
    <segment id="48">POR FAVOR</segment>
    <segment id="49">Ivo Herzog</segment>
    <segment id="50">, filho do jornalista Vladimir Herzog</segment>
    <segment id="51">, morto pela ditadura</segment>
    <segment id="52">, escreveu uma carta a Fernando Henrique Cardoso pedindo que ele “seja o líder que me moldou” e</segment>
    <segment id="53">sese posicione contra Bolsonaro.</segment>
    <segment id="54">SÓ</segment>
    <segment id="55">VOCÊ</segment>
    <segment id="56">Ele afirma que a hora “não é de apoiar o menos pior.</segment>
    <segment id="57">É de execrar o fascismo</segment>
    <segment id="58">, a cultura da violência</segment>
    <segment id="59">, de desrespeito às minorias”.</segment>
    <segment id="60">Ivo pede que o ex-presidente “seja o líder de um grito de que não aceitamos a volta ao passado”.</segment>
    <segment id="61">E finaliza:</segment>
    <segment id="62">“Precisamos de Fernando Henrique Cardoso”.</segment>
    <segment id="63">Jantar solidário AACDÍcone seta para esquerdaÍcone seta para direita   novamenteÍcone seta para esquerda</segment>
    <segment id="64">VoltarÍcone seta para cimaÍcone seta para baixoÍcone seta para esquerda Voltar       de  PinterestPinterestÍcone  de  de  representando um  MESA POSTA</segment>
    <segment id="65">A apresentadora Eliana e o cantor Daniel foram ao jantar solidário da AACD (Associação de Assistência à Criança Deficiente)</segment>
    <segment id="66">, realizado no Grand  Hyatt São Paulo</segment>
    <segment id="67">, na quarta (10).</segment>
    <segment id="68">A apresentadora Luciana Gimenez</segment>
    <segment id="69">, a atriz Maisa Silva</segment>
    <segment id="70">, a modelo Paola  Antonini e o ator Tiago Abravanel também compareceram.</segment>
    <segment id="71">NOS BRAÇOS</segment>
    <segment id="72">O publicitário Elsinho Mouco</segment>
    <segment id="73">, marqueteiro e um dos assessores mais próximos de Michel Temer (MDB-SP)</segment>
    <segment id="74">, começou a pedir votos nas redes sociais:</segment>
    <segment id="75">“Depois de chamar o meu candidato</segment>
    <segment id="76">, Henrique Meirelles</segment>
    <segment id="77">, no primeiro turno</segment>
    <segment id="78">, agora é reta de chegada.</segment>
    <segment id="79">Agora, é hora de chamar o Jair Bolsonaro”.  PERDÃO</segment>
    <segment id="80">E a equipe de Temer está</segment>
    <segment id="81">sese divertindo com os memes do tal movimento “ficatemer”</segment>
    <segment id="82">, solução que seria melhor do que o resultado eleitoral que</segment>
    <segment id="83">sese avizinha</segment>
    <segment id="84">, e que pode levar Bolsonaro ou o PT ao poder.</segment>
    <segment id="85">“Toda vez que eu te critiquei</segment>
    <segment id="86">, eu estava bêbada.</segment>
    <segment id="87">Tudo bem que te critiquei por dois anos inteiros.</segment>
    <segment id="88">Mas é que eu bebia demais”</segment>
    <segment id="89">, disse uma seguidora dele no Facebook.</segment>
    <segment id="90">PERDÃO 2</segment>
    <segment id="91">Uma outra mensagem dizia:</segment>
    <segment id="92">“Temer</segment>
    <segment id="93">, lembra do que você sempre diz?</segment>
    <segment id="94">‘Não renunciarei?</segment>
    <segment id="95">’.</segment>
    <segment id="96">Agora é a hora”.</segment>
    <segment id="97">Um seguidor dele escreveu ainda:</segment>
    <segment id="98">“A gente</segment>
    <segment id="99">sese intercala para pegar o Michelzinho [filho do presidente] pra você na creche”.</segment>
    <segment id="100">NÃO FUI EU</segment>
    <segment id="101">A importadora de vinhos</segment>
    <segment id="102">Decanter pretende abrir uma ocorrência contra um perfil falso no Instagram com o nome “decanter_sp” que atacou a chef Helena Rizzo</segment>
    <segment id="103">, do restaurante Maní</segment>
    <segment id="104">, na rede:</segment>
    <segment id="105">“Você representa o que há a de mais PODRE na nossa sociedade e você é uma infeliz que insultou milhões de brasileiros.</segment>
    <segment id="106">Sua desqualificada!!!</segment>
    <segment id="107">Nunca nos procure”.  POSIÇÃO</segment>
    <segment id="108">Rizzo sofreu uma avalanche de críticas no perfil por postar uma foto com funcionários do Maní mostrando o dedo do meio e com escritos “#elenão” nos braços.  CARTÃO POSTAL</segment>
    <segment id="109">Em sua primeira passagem pelo país</segment>
    <segment id="110">, o artista francês Olivier Grossetête irá construir uma réplica da Catedral da Sé</segment>
    <segment id="111">, de 24 metros de altura</segment>
    <segment id="112">, com papelão.</segment>
    <segment id="113">A performance conta com a ajuda do público e será realizada no Sesc Parque Dom Pedro 2º</segment>
    <segment id="114">, a partir do dia 23 de outubro.   Quarta-Feira</segment>
    <segment id="115">, Sem Falta</segment>
    <segment id="116">, Lá em CasaÍcone seta para esquerdaÍcone seta para direita   novamenteÍcone seta para esquerda</segment>
    <segment id="117">VoltarÍcone seta para cimaÍcone seta para baixoÍcone seta para esquerda Voltar       de  PinterestPinterestÍcone  de  de  representando um  TUDO COMBINADO</segment>
    <segment id="118">As atrizes Eva Wilma e Suely Franco estrelam a peça “Quarta-Feira</segment>
    <segment id="119">, sem Falta</segment>
    <segment id="120">, Lá em Casa”</segment>
    <segment id="121">, que estreou no Teatro Porto Seguro na semana passada.</segment>
    <segment id="122">O espetáculo é dirigido por Alexandre Reinecke .</segment>
    <segment id="123">Fotos Greg Salibian/Folhapress   CURTO-CIRCUITO</segment>
    <segment id="124">A peça “Tio Ivan” estreia nesta sexta (12)</segment>
    <segment id="125">, às 19h</segment>
    <segment id="126">, na Casa das Rosas.</segment>
    <segment id="127">O movimento Ação pela Democracia faz leilão virtual de obras de artistas</segment>
    <segment id="128">comocomo Tomie Ohtake e Augusto de Campos em prol do Instituto Lula.</segment>
    <segment id="129">Até o dia 19 deste mês.</segment>
    <segment id="130">Os atores Vivianne Pasmanter e Marcello Airoldi estreiam a peça “Amor Profano”</segment>
    <segment id="131">, nesta sexta (12)</segment>
    <segment id="132">, às 20h</segment>
    <segment id="133">, no Teatro Vivo.   com BRUNA NARCIZO</segment>
    <segment id="134">, BRUNO B. SORAGGI e VICTORIA AZEVEDO</segment>
  </rst>
</analysis>