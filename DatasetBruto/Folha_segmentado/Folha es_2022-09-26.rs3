  <rst>
    <segment id="1">A Folha estreia nesta segunda (26) o blog</segment>
    <segment id="2">Na Pinta do Surfe</segment>
    <segment id="3">, que reunirá análises e informações sobre o esporte</segment>
    <segment id="4">, além de entrevista com grandes e jovens promessas da modalidade no Brasil.</segment>
    <segment id="5">O espaço ficará sob o comando do empresário Marcus Romero</segment>
    <segment id="6">, 52.</segment>
    <segment id="7">Nascido em São Caetano</segment>
    <segment id="8">, no ABC</segment>
    <segment id="9">, Marcus reside em Camburi</segment>
    <segment id="10">, no município de São Sebastião</segment>
    <segment id="11">, litoral norte de São Paulo</segment>
    <segment id="12">, berço de alguns dos maiores surfistas da atualidade</segment>
    <segment id="13">, como</segment>
    <segment id="14">como Gabriel Medina</segment>
    <segment id="15">, Felipe Toledo</segment>
    <segment id="16">, Miguel e Samuel Pupo.</segment>
    <segment id="17">O surfista Marcus Romero</segment>
    <segment id="18">, autor do blog sobre surfe- Acervo pessoal"A ideia é usar o espaço para falar sobre as principais competições de surfe da WSL (World Surf League</segment>
    <segment id="19">, a Liga Mundial de Surfe)</segment>
    <segment id="20">, tanto da 1ª quanto da 2ª Divisão.</segment>
    <segment id="21">E abordar</segment>
    <segment id="22">, também</segment>
    <segment id="23">, mudanças de equipamentos</segment>
    <segment id="24">, além de histórias de viagens relacionadas ao surfe"</segment>
    <segment id="25">, afirma o empresário.</segment>
    <segment id="26">Dono de uma cafeteria com temática caiçara na praia de Camburi</segment>
    <segment id="27">, ele é conhecido na região</segment>
    <segment id="28">comocomo "Pinta"</segment>
    <segment id="29">, um apelido que ganhou por causa de uma pinta que possui no rosto.</segment>
    <segment id="30">"</segment>
    <segment id="31">Por isso minha mulher sugeriu esse nome para o blog [Na Pinta do Surfe] e eu gostei.</segment>
    <segment id="32">"</segment>
  </rst>
