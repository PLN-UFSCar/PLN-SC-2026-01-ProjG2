  <rst>
    <segment id="1">O comentarista Leonardo Grandini</segment>
    <segment id="2">, ex-Jovem Pan</segment>
    <segment id="3">, lançará na segunda-feira (19) sua pré-candidatura a vereador de São Paulo pelo PSB.</segment>
    <segment id="4">A lista de convidados para o jantar</segment>
    <segment id="5">, que será realizado na região dos Jardins</segment>
    <segment id="6">, na capital paulista</segment>
    <segment id="7">, inclui nomes</segment>
    <segment id="8">comocomo a deuptada federal Tabata Amaral (PSB-SP)</segment>
    <segment id="9">, pré-candidata à prefeitura paulistana</segment>
    <segment id="10">, o ex-ministro José Dirceu</segment>
    <segment id="11">, e o empresário Antonio Augusto Amaral de Carvalho Filho</segment>
    <segment id="12">, o Tutinha</segment>
    <segment id="13">, além de lideranças do movimento estudantil.</segment>
    <segment id="14">O comentarista Leonardo Grandini ao lado do vice-presidente Geraldo Alckmin</segment>
    <segment id="15">, seu correligionário no PSB - @leonardo_grandini no Instagram</segment>
    <segment id="16">Em sua campanha</segment>
    <segment id="17">, Grandini pretende</segment>
    <segment id="18">sese apresentar</segment>
    <segment id="19">comocomo um nome de oposição ao MBL (Movimento Brasil Livre) e à pré-candidata Zoe Martinez</segment>
    <segment id="20">, ex-comentarista da Jovem Pan que pretende</segment>
    <segment id="21">sese lançar pelo PL de Jair Bolsonaro.</segment>
    <segment id="22">NA AVENIDA</segment>
    <segment id="23">Camarote Bar Brahma no Desfile das Campeãs</segment>
    <segment id="24">, no Anhembi</segment>
    <segment id="25">, em São PauloMais    novamente         de   de  de  representando um</segment>
    <segment id="26">A cantora Karol Conká compareceu ao Camarote Bar Brahma</segment>
    <segment id="27">, no Sambódromo do Anhembi</segment>
    <segment id="28">, em São Paulo</segment>
    <segment id="29">, na noite de sábado (17)</segment>
    <segment id="30">, para prestigiar o Desfile das Campeãs do Carnaval paulistano.</segment>
    <segment id="31">O vice-governador paulista</segment>
    <segment id="32">, Felicio Ramuth (PSD)</segment>
    <segment id="33">, e sua esposa</segment>
    <segment id="34">, a empresária Vanessa Ramuth</segment>
    <segment id="35">, estiveram lá.</segment>
    <segment id="36">A apresentadora Helen Ganzarolli também participou.  com BIANKA VIEIRA</segment>
    <segment id="37">, KARINA MATIAS e MANOELLA SMITH</segment>
  </rst>
