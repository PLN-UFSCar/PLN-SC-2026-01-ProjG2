  <rst>
    <segment id="1">Elas chegaram há alguns anos um pouco tímidas</segment>
    <segment id="2">, masmas querendo fazer muitos amigos.</segment>
    <segment id="3">Agora, com o preço mais acessível</segment>
    <segment id="4">, as boias divertidas e gigantes prometem um verão colorido</segment>
    <segment id="5">, animado e muito confortável.</segment>
    <segment id="6">Tem boia para todos os gostos e bolsos e em diversos formatos.</segment>
    <segment id="7">Tem de pizza</segment>
    <segment id="8">, de melancia</segment>
    <segment id="9">, de unicórnio e de flamingo</segment>
    <segment id="10">, além das gigantes que cabem até oito pessoas.</segment>
    <segment id="11">Todas podem ser compradas pela internet.</segment>
    <segment id="12">A comerciante Daniela Holochi</segment>
    <segment id="13">, 40 anos</segment>
    <segment id="14">, da Fluthua Store</segment>
    <segment id="15">, conheceu as boias divertidas há pouco mais de dois anos.</segment>
    <segment id="16">A brincadeira foi tanta que ela decidiu comercializar o produto.</segment>
    <segment id="17">“Essas boias são uma tendência não somente para diversão</segment>
    <segment id="18">masmas também para decoração de festas e eventos.</segment>
    <segment id="19">Começamos com dez modelos e hoje temos mais de cem</segment>
    <segment id="20">, inclusive as gigantes.</segment>
    <segment id="21">”  Boias coloridas são a diversão de quem cai na água neste verãoMais    novamente         de   de  de  representando um</segment>
    <segment id="22">O comerciante Eduardo Teles</segment>
    <segment id="23">, 63, da Marol Piscinas</segment>
    <segment id="24">, disse que as boias chegaram ao Brasil em meados de 2015</segment>
    <segment id="25">, importadas da China.</segment>
    <segment id="26">“</segment>
    <segment id="27">As primeiras foram as de unicórnio e de flamingo.</segment>
    <segment id="28">Mas ainda eram muito caras</segment>
    <segment id="29">, em torno de R$ 400.</segment>
    <segment id="30">Agora, o preço está mais acessível</segment>
    <segment id="31">, a partir de R$ 150”</segment>
    <segment id="32">, disse.</segment>
    <segment id="33">O importador Ricardo Sessa</segment>
    <segment id="34">, 54, da Imports Náutica</segment>
    <segment id="35">, também decidiu investir no comércio eletrônico de boias.</segment>
    <segment id="36">“Começamos com alguns clientes que fizeram propaganda boca a boca.</segment>
    <segment id="37">Agora são vários.</segment>
    <segment id="38">”  Modelo gigante é usado durante passeios no mar</segment>
    <segment id="39">As boias gigantes</segment>
    <segment id="40">, apesar de mais caras</segment>
    <segment id="41">, também caíram no gosto do brasileiro.</segment>
    <segment id="42">Chamadas de ilhas ou cabanas</segment>
    <segment id="43">, elas são usadas geralmente em represas ou em alto-mar</segment>
    <segment id="44">, na maioria das vezes durante os passeios de barco.</segment>
    <segment id="45">Elas custam a partir de R$ 3.500 e vêm com cooler para bebidas</segment>
    <segment id="46">, completando a diversão.</segment>
    <segment id="47">A advogada Ana Cristina Martins</segment>
    <segment id="48">, 48 anos</segment>
    <segment id="49">, começou a procurar algo que toda a família pudesse</segment>
    <segment id="50">sese divertir junta nos passeios de barco que fazem no Guarujá (86 km de SP)</segment>
    <segment id="51">, onde mora.</segment>
    <segment id="52">“Pesquisei na internet e encontrei as boias gigantes em formatos de ilha.</segment>
    <segment id="53">A nossa cabe até oito pessoas.</segment>
    <segment id="54">Agora todos</segment>
    <segment id="55">sese divertem juntos.</segment>
    <segment id="56">Foi um investimento</segment>
    <segment id="57">, pois</segment>
    <segment id="58">pois é resistente”</segment>
    <segment id="59">, disse.</segment>
    <segment id="60">Quatro amigos</segment>
    <segment id="61">sese unem para brincar com unicórnio</segment>
    <segment id="62">As boias divertidas são um convite à brincadeira com os amigos</segment>
    <segment id="63">, seja na piscina ou na represa.</segment>
    <segment id="64">E é assim com a administradora Raffaela Pagnan</segment>
    <segment id="65">, 24 anos</segment>
    <segment id="66">, quando vai para a lagoa Jaguaruna</segment>
    <segment id="67">, em Santa Catarina</segment>
    <segment id="68">, perto de onde mora</segment>
    <segment id="69">, brincar com a boia gigante de unicórnio em que cabem até quatro pessoas.</segment>
    <segment id="70">“Usei com meus amigos</segment>
    <segment id="71">, nas férias</segment>
    <segment id="72">, e foi bem divertido.</segment>
    <segment id="73">Todos adoraram.</segment>
    <segment id="74">Ela é enorme”.</segment>
    <segment id="75">A estudante Laís Lima Santos</segment>
    <segment id="76">, 20 anos</segment>
    <segment id="77">, também ganhou uma boia de kiwi em que cabem duas pessoas.</segment>
    <segment id="78">Apesar de não ter piscina na casa onde mora</segment>
    <segment id="79">, em Rio Real (BA)</segment>
    <segment id="80">, ela brinca com a boia no clube da cidade.</segment>
    <segment id="81">“Quando chego</segment>
    <segment id="82">, todos querem brincar.</segment>
    <segment id="83">É muito divertido.</segment>
    <segment id="84">Gostamos muito.</segment>
    <segment id="85">”    Modelos e preços das boias mais procuradas Mais    novamente         de   de  de  representando um  Cuidados</segment>
    <segment id="86">Ao encher</segment>
    <segment id="87">Vá para um local que tenha espaço Se for usar a boca</segment>
    <segment id="88">, evite morder a válvula Encha até que ela</segment>
    <segment id="89">sese molde e você consiga apertar sem que ela esteja dura ou rígida Se encheu demais</segment>
    <segment id="90">, aperte as extremidades da válvula para murchar um pouco</segment>
    <segment id="91">Para limpar</segment>
    <segment id="92">Após o uso</segment>
    <segment id="93">, lave com sabão neutro e água e enxágue bem Não use produtos químicos quando estiver no sol Seque completamente antes de guardar Cuidados   Atenção    Tire da piscina/mar quando não estiver usando Guarde em local seco</segment>
    <segment id="94">, longe da luz solar e dos produtos químicos da piscina Evite arrastar a boia em pisos ásperos</segment>
    <segment id="95">Não pule na boia</segment>
    <segment id="96">No mar e no rio  É necessário cautela com a falsa sensação de segurança da boia</segment>
    <segment id="97">, pois</segment>
    <segment id="98">pois locais abertos com água têm vento e correnteza</segment>
    <segment id="99">, que movimentam a boia e pode causar acidentes</segment>
    <segment id="100">Os bombeiros recomendam apenas o uso em piscinas</segment>
    <segment id="101">, caso</segment>
    <segment id="102">caso usar no mar ou no rio é importante:</segment>
    <segment id="103">Cuidado durante o uso Saber nadar Usar colete salva-vidas</segment>
    <segment id="104">Ancorar ou amarrar a boia durante o uso   Fontes:</segment>
    <segment id="105">Capitão Marcos Palumbo</segment>
    <segment id="106">, bombeiro</segment>
  </rst>
</analysis>