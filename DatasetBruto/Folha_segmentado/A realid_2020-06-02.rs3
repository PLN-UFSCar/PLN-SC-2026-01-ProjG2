    </relations>
  </header>
  <rst>
    <segment id="1">O que existe lá fora no mundo em que vivemos?</segment>
    <segment id="2">O que é real nesses tempos loucos?</segment>
    <segment id="3">Perguntas</segment>
    <segment id="4">comocomo essas mantêm filósofos</segment>
    <segment id="5">ocupados</segment>
    <segment id="6">aposto que antes mesmo da palavra "filosofia" existir.</segment>
    <segment id="7">O cérebro pode</segment>
    <segment id="8">sese preocupar com isso —ou não.</segment>
    <segment id="9">O Real</segment>
    <segment id="10">, assim mesmo</segment>
    <segment id="11">, com letra maiúscula</segment>
    <segment id="12">, é por definição impérvio à nossa filosofia (por isso vã).</segment>
    <segment id="13">Vejamos:</segment>
    <segment id="14">O surreal da pandemia   novamente         de   de  de  representando um</segment>
    <segment id="15">O estado de saúde ou doença dos outros não depende do seu conhecimento.</segment>
    <segment id="16">Se os eventos do governo são regidos</segment>
    <segment id="17">, planejados</segment>
    <segment id="18">, calculados ou desastrados</segment>
    <segment id="19">, não é</segment>
    <segment id="20">porque</segment>
    <segment id="21">porque você os considera assim.</segment>
    <segment id="22">A insegurança</segment>
    <segment id="23">, a incerteza e a instabilidade alheias não</segment>
    <segment id="24">sese materializam apenas quando você olha.</segment>
    <segment id="25">Se tanta irrelevância humana frente ao Real já é problemática em tempos comuns</segment>
    <segment id="26">, então em tempos de encapsulamento</segment>
    <segment id="27">, quando</segment>
    <segment id="28">sese espera de cada um de nós justamente não sentir na pele o que os outros sofrem</segment>
    <segment id="29">, em nome do bem comum</segment>
    <segment id="30">, ela é especialmente perigosa.</segment>
    <segment id="31">Porque assim fica especialmente fácil vivermos cada um em sua realidade construída</segment>
    <segment id="32">, placidamente ignorantes do Real.</segment>
    <segment id="33">Afinal de contas</segment>
    <segment id="34">, é isso que o cérebro faz melhor: montar a cada momento uma hipótese de trabalho interna sobre o que acontece lá fora</segment>
    <segment id="35">, conforme as respostas às nossas ações.</segment>
    <segment id="36">Se nós não olhamos</segment>
    <segment id="37">, não vemos nada.</segment>
    <segment id="38">Se não agimos</segment>
    <segment id="39">, não há resposta.</segment>
    <segment id="40">Se não nos importamos</segment>
    <segment id="41">, não há com o que</segment>
    <segment id="42">sese importar.</segment>
    <segment id="43">Quantos humanos nos últimos dois meses você</segment>
    <segment id="44">, leitor</segment>
    <segment id="45">, já viu arfar</segment>
    <segment id="46">, de lábios arroxeados</segment>
    <segment id="47">, lutando em angústia a cada inspiração contra o afogamento iminente em terra firme?</segment>
    <segment id="48">Provavelmente</segment>
    <segment id="49">, nem um só.</segment>
    <segment id="50">O vírus é invisível</segment>
    <segment id="51">; a doença é etérea</segment>
    <segment id="52">, um medo no ar.</segment>
    <segment id="53">Para a maioria de nós</segment>
    <segment id="54">, os casos ainda só chegam aos sentidos</segment>
    <segment id="55">comocomo estatísticas nos jornais.</segment>
    <segment id="56">Da abstração do governo</segment>
    <segment id="57">, então</segment>
    <segment id="58">, nem se</segment>
    <segment id="59">se fala.</segment>
    <segment id="60">O governo</segment>
    <segment id="61">, ou falta dele</segment>
    <segment id="62">, não se</segment>
    <segment id="63">se vê.</segment>
    <segment id="64">Há atores nos jornais</segment>
    <segment id="65">, decerto</segment>
    <segment id="66">, enchendo páginas de fotos</segment>
    <segment id="67">, vídeos e relatos —não importa</segment>
    <segment id="68">sese você</segment>
    <segment id="69">sese sinta vingado e vitorioso</segment>
    <segment id="70">, arrependido</segment>
    <segment id="71">, frustrado</segment>
    <segment id="72">, impotente ou raivoso.</segment>
    <segment id="73">Mas "governo" é uma ideia na cabeça de cada um.</segment>
    <segment id="74">E como</segment>
    <segment id="75">como cada um pensa o que quer</segment>
    <segment id="76">, ninguém</segment>
    <segment id="77">sese entende.</segment>
    <segment id="78">Esta é a diferença entre ilusão e percepção.</segment>
    <segment id="79">A ilusão é o que a gente quiser.</segment>
    <segment id="80">Ou pior:</segment>
    <segment id="81">é a realidade que o cérebro conjura de olhos fechados</segment>
    <segment id="82">, sem ter trabalho de pensar</segment>
    <segment id="83">, problemática</segment>
    <segment id="84">porque</segment>
    <segment id="85">porque é um guia tão útil quanto cego em tiroteio</segment>
    <segment id="86">, completamente alheio ao Real.</segment>
    <segment id="87">A percepção é uma versão do Real razoavelmente útil</segment>
    <segment id="88">, porque</segment>
    <segment id="89">porque razoavelmente fiel.</segment>
    <segment id="90">Como transformar ilusão em percepção?</segment>
    <segment id="91">Basta agir.</segment>
  </rst>
</analysis>