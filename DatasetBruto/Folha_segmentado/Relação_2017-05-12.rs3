  <rst>
    <segment id="1">A mulher do marqueteiro João Santana</segment>
    <segment id="2">, Mônica Moura</segment>
    <segment id="3">, que fez a campanha eleitoral de Dilma em 2010 e 2014</segment>
    <segment id="4">, afirmou em vídeo gravado no acordo de delação premiada o ex-presidente Luiz Inácio Lula da Silva queria ser o candidato à Presidência em 2014</segment>
    <segment id="5">, masmas Dilma insistiu na reeleição.</segment>
    <segment id="6">Mônica disse que recebeu a informação de seu marido</segment>
    <segment id="7">, Santana</segment>
    <segment id="8">, que conversava com frequência com Dilma.</segment>
    <segment id="9">Segundo Mônica</segment>
    <segment id="10">, naquele ano a relação entre Lula e Dilma teve &amp;quot</segment>
    <segment id="11">;um estremecimento&amp;quot</segment>
    <segment id="12">;.Mônica falou sobre a relação entre Lula e Dilma ao responder a uma pergunta dos procuradores da República que queriam saber</segment>
    <segment id="13">sese Lula</segment>
    <segment id="14">sese envolveu nas questões financeiras da campanha de 2014.No mesmo depoimento</segment>
    <segment id="15">, a mulher de João Santana contou que o casal usava apelidos para</segment>
    <segment id="16">sese referir a autoridades do governo.</segment>
    <segment id="17">O ex-presidente Lula era o &amp;quot</segment>
    <segment id="18">;Pavarotti&amp;quot</segment>
    <segment id="19">; ou &amp;quot</segment>
    <segment id="20">;Pava&amp;quot</segment>
    <segment id="21">;, em referência ao cantor de ópera Luciano Pavarotti (1935-2007).</segment>
    <segment id="22">&amp;quot;A gente achava</segment>
    <segment id="23">, uma época que ele ficou muito gordo</segment>
    <segment id="24">, e com barba</segment>
    <segment id="25">, ele parecia com o Pavarotti.</segment>
    <segment id="26">Era Pava ou Pavarotti</segment>
    <segment id="27">, tenho vários telefones anotados</segment>
    <segment id="28">comocomo Pava&amp;quot</segment>
    <segment id="29">;, disse Monica.</segment>
    <segment id="30">Dilma Rousseff era identificada</segment>
    <segment id="31">comocomo &amp;quot</segment>
    <segment id="32">;Tia&amp;quot</segment>
    <segment id="33">; e o então ministro da Fazenda</segment>
    <segment id="34">, Guido Mantega</segment>
    <segment id="35">, era o &amp;quot</segment>
    <segment id="36">;Laticínio&amp;quot</segment>
    <segment id="37">;.&amp;quot</segment>
    <segment id="38">;A gente inventava apelidos para algumas pessoas para não anotar</segment>
    <segment id="39">, como</segment>
    <segment id="40">como eu disse</segment>
    <segment id="41">, não ficar anotando nomes deles em agenda</segment>
    <segment id="42">, como</segment>
    <segment id="43">como 'Guido Mantega: reunião'.</segment>
    <segment id="44">Por que que eu ia ter reunião com Guido Mantega?</segment>
    <segment id="45">Não tinha nenhum sentido&amp;quot</segment>
    <segment id="46">;, disse Mônica.</segment>
  </rst>
</analysis>