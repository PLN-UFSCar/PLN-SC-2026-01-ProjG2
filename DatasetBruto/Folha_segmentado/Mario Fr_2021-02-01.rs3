  <rst>
    <segment id="1">O secretário especial da Cultura</segment>
    <segment id="2">, Mario Frias</segment>
    <segment id="3">, atacou o Governo de São Paulo e disse que as obras do Museu do Ipiranga</segment>
    <segment id="4">, na capital paulista</segment>
    <segment id="5">, são custeadas pelo governo federal</segment>
    <segment id="6">, e não pelo governador João Doria (PSDB).  "</segment>
    <segment id="7">O Museu do Ipiranga é uma obra financiada pela Secult @CulturaGovBr</segment>
    <segment id="8">, não pelo governador de São Paulo"</segment>
    <segment id="9">, escreveu Frias nas redes sociais na sexta (29).</segment>
    <segment id="10">Em texto</segment>
    <segment id="11">, o secretário afirma que visitou as obras do museu</segment>
    <segment id="12">, na quinta (28)</segment>
    <segment id="13">, e diz que lhe causou estranheza "que uma obra tão importante</segment>
    <segment id="14">, que não recebeu recursos do governo do estado de São Paulo</segment>
    <segment id="15">, tenha sido anunciada pelo governador</segment>
    <segment id="16">, João Doria</segment>
    <segment id="17">, como</segment>
    <segment id="18">como a principal obra do seu governo".</segment>
    <segment id="19">Museu do IpirangaMais    novamente         de   de  de  representando um  "​Assim</segment>
    <segment id="20">, tendo o compromisso com a verdade</segment>
    <segment id="21">, e ciente da necessidade de combater o uso político-partidário</segment>
    <segment id="22">, para palanque eleitoral</segment>
    <segment id="23">, dos recursos federais</segment>
    <segment id="24">, já solicitei a minha equipe de fiscalização</segment>
    <segment id="25">para que</segment>
    <segment id="26">para que notificasse o proponente</segment>
    <segment id="27">, no intuito que o mesmo retire do material de divulgação a logomarca estadual</segment>
    <segment id="28">comocomo um dos realizadores da obra</segment>
    <segment id="29">, tendo em vista que não arcou com nenhuma parte do custo da reforma"</segment>
    <segment id="30">, segue Frias.</segment>
    <segment id="31">Em nota</segment>
    <segment id="32">, a Secretaria de Cultura e Economia Criativa de SP rebateu as declarações de Frias e diz que a publicação do secretário "parece ter sido feito por outra pessoa".</segment>
    <segment id="33">Na visita</segment>
    <segment id="34">, segundo a pasta</segment>
    <segment id="35">, Frias foi recebido pelo secretário Sérgio Sá Leitão</segment>
    <segment id="36">, pelo reitor da USP</segment>
    <segment id="37">, Vahan Agopyan</segment>
    <segment id="38">, e pela equipe responsável pelo projeto.</segment>
    <segment id="39">Ainda de acordo com a secretaria</segment>
    <segment id="40">, ela "foi filmada e o vídeo está disponível".    "</segment>
    <segment id="41">Em nenhum momento fez qualquer crítica ao projeto</segment>
    <segment id="42">, à USP</segment>
    <segment id="43">, ao Governo de São Paulo ou ao governador João Doria.</segment>
    <segment id="44">Ao contrário</segment>
    <segment id="45">, aliás</segment>
    <segment id="46">, externou diversos elogios ao longo de toda a visita.</segment>
    <segment id="47">Disse que o projeto era um 'ótimo exemplo'"</segment>
    <segment id="48">, diz a nota.</segment>
    <segment id="49">Saiba quem é quem na Cultura sob Mario FriasMais    novamente         de   de  de  representando um  "</segment>
    <segment id="50">Infelizmente</segment>
    <segment id="51">, o secretário não teve coragem de dizer o mesmo na frente dos anfitriões.</segment>
    <segment id="52">Se tivesse feito</segment>
    <segment id="53">, receberia as informações corretas sobre a participação do Governo de SP e do governador João Doria no projeto.</segment>
    <segment id="54">O Museu do Ipiranga pertence à Universidade de São Paulo</segment>
    <segment id="55">, instituição vinculada ao governo de SP.</segment>
    <segment id="56">O governador João Doria liderou a vitoriosa campanha de captação de recursos para o projeto de restauro e ampliação.</segment>
    <segment id="57">Há recursos estaduais em diversas etapas do projeto.</segment>
    <segment id="58">Cerca de 50% dos recursos captados junto à iniciativa privada não são incentivados"</segment>
    <segment id="59">, segue o texto.</segment>
  </rst>
</analysis>