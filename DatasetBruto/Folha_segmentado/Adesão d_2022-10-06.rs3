  <rst>
    <segment id="1">Os economistas Edmar Bacha e Pedro Malan divulgaram uma nota conjunta em apoio a Lula.</segment>
    <segment id="2">Juntam-</segment>
    <segment id="3">sese, assim</segment>
    <segment id="4">, a André Lara Resende</segment>
    <segment id="5">, Pérsio Arida e Armínio Fraga</segment>
    <segment id="6">, que já o haviam feito.</segment>
    <segment id="7">Esses nomes estão na origem e na sustentação do Real</segment>
    <segment id="8">, o mais ousado</segment>
    <segment id="9">, criativo e bem-sucedido plano de estabilização da economia</segment>
    <segment id="10">, em tempos democráticos</segment>
    <segment id="11">, de que o mundo tem notícia.</segment>
    <segment id="12">Arrumar as contas é até fácil</segment>
    <segment id="13">casocaso</segment>
    <segment id="14">sese ignore o sangue derramado.</segment>
    <segment id="15">Paulo Guedes</segment>
    <segment id="16">, admirador do "ajuste" pinochetiano</segment>
    <segment id="17">, sabe disso.</segment>
    <segment id="18">Não fez parte da geração que conseguiu vencer a desordem econômica em tempos de paz.</segment>
    <segment id="19">Os "economistas do Real" evidenciam estar atentos à era do horror e à fome dos canibais diletantes e profissionais.</segment>
    <segment id="20">Dão, ainda</segment>
    <segment id="21">, uma aula importante a alguns noviços da responsabilidade fiscal</segment>
    <segment id="22">comocomo um fundamentalismo</segment>
    <segment id="23">, que cobram que Lula apresente um plano detalhado de governo.</segment>
    <segment id="24">Fundamentos são importantes</segment>
    <segment id="25">, masmas sua derivação viciosa</segment>
    <segment id="26">, traduzida naquele "ismo"</segment>
    <segment id="27">, perverte a substância.</segment>
    <segment id="28">Edmar Bacha</segment>
    <segment id="29">, Pedro Malan</segment>
    <segment id="30">, Arminio Fraga e Persio Arida</segment>
    <segment id="31">, economistas que declararam apoio a Lula - Zo Guimaraes</segment>
    <segment id="32">, Zanone Fraissat e Missioneiro/Folhapress eGuito Moreto/Agência O Globo</segment>
    <segment id="33">O petista</segment>
    <segment id="34">, insiste o noviciado</segment>
    <segment id="35">, não apresentou um "plano detalhado de governo"</segment>
    <segment id="36">, como</segment>
    <segment id="37">como se</segment>
    <segment id="38">se a desordem econômica e política que Bolsonaro promove apontasse para algum norte que não a reeleição.</segment>
    <segment id="39">Os doutores dão relevo</segment>
    <segment id="40">, e com acerto</segment>
    <segment id="41">, ao compromisso do petista</segment>
    <segment id="42">, demonstrado mais por atos do que por palavras</segment>
    <segment id="43">, com a responsabilidade fiscal.</segment>
    <segment id="44">Mas há mais.</segment>
    <segment id="45">Economia não é conversa de nefelibatas</segment>
    <segment id="46">, alheia ao que</segment>
    <segment id="47">sese passa na terra.</segment>
    <segment id="48">O ajuste que essa turma promoveu no país</segment>
    <segment id="49">, volta-</segment>
    <segment id="50">sese ao ponto</segment>
    <segment id="51">, tinha um pressuposto: a democracia.</segment>
    <segment id="52">É essa ampla escolha civilizatória que os leva à mais restrita</segment>
    <segment id="53">, de natureza política.</segment>
    <segment id="54">E olhem que poderia haver aí razão para uma "metralhadora cheia de mágoas"</segment>
    <segment id="55">, como</segment>
    <segment id="56">como cantou Cazuza.</segment>
    <segment id="57">O PT fustigou o Real impiedosamente e pagou um preço político por isso</segment>
    <segment id="58">, que é a única forma de ajuste de contas aceitável no regime democrático: foi derrotado em 1994 e em 1998 no primeiro turno.</segment>
    <segment id="59">Exalto</segment>
    <segment id="60">, em particular</segment>
    <segment id="61">, a temperança de Pedro Malan</segment>
    <segment id="62">, que, à frente do Ministério da Fazenda</segment>
    <segment id="63">, foi um dos principais alvos do petismo.</segment>
    <segment id="64">Ademais</segment>
    <segment id="65">, aquele que os reuniu para a grande obra</segment>
    <segment id="66">, FHC, também já declarou seu voto no petista.</segment>
    <segment id="67">Antes do "plano detalhado"</segment>
    <segment id="68">, o pressuposto</segment>
    <segment id="69">, como</segment>
    <segment id="70">como quer a etimologia: a democracia.</segment>
    <segment id="71">A turma do Real lembra um tempo —quiçá voltemos a ter divergências que não forcem alianças à beira do abismo— em que</segment>
    <segment id="72">, por mais acerbos que fossem</segment>
    <segment id="73">, os confrontos ainda tinham eira e beira e</segment>
    <segment id="74">sese travavam embates em ambientes que eram deste mundo</segment>
    <segment id="75">, entre os vivos</segment>
    <segment id="76">, deixando em paz a terra dos mortos.</segment>
    <segment id="77">Corre-</segment>
    <segment id="78">sese agora um risco de esgarçamento do tecido democrático que pode nos levar a um ciclo de longa degeneração das instituições.</segment>
    <segment id="79">Colunas e BlogsReceba no seu email uma seleção de colunas e blogs da Folha</segment>
    <segment id="80">; exclusiva para assinantes.</segment>
    <segment id="81">Carregando...</segment>
    <segment id="82">Em sua primeira reação depois da realização do primeiro turno</segment>
    <segment id="83">, Bolsonaro fez mira</segment>
    <segment id="84">, mais uma vez</segment>
    <segment id="85">, no Supremo.</segment>
    <segment id="86">Não é uma obsessão pessoal.</segment>
    <segment id="87">É um plano.</segment>
    <segment id="88">Data de 26 de maio de 2019 o primeiro ato golpista que promoveu.</segment>
    <segment id="89">O governo não havia sofrido ainda derrota nenhuma no tribunal.</segment>
    <segment id="90">Precisamos recuperar dos escombros a civilidade</segment>
    <segment id="91">para que</segment>
    <segment id="92">para que um menino preto não seja preso por um PM que lhe diz: "</segment>
    <segment id="93">Vai gritar Lula lá na África"</segment>
    <segment id="94">, depois de lhe dar um golpe nas costas.</segment>
    <segment id="95">Precisamos recuperar dos escombros a civilidade</segment>
    <segment id="96">para que</segment>
    <segment id="97">para que um governante não</segment>
    <segment id="98">sese alie ao vírus</segment>
    <segment id="99">, contra a vacina</segment>
    <segment id="100">, empurrando o povo</segment>
    <segment id="101">, como</segment>
    <segment id="102">como gado</segment>
    <segment id="103">, à "imunidade do rebanho".</segment>
    <segment id="104">Precisamos recuperar dos escombros a civilidade</segment>
    <segment id="105">para que</segment>
    <segment id="106">para que pobres não morram em camburões transformados em câmaras de gás.</segment>
    <segment id="107">Precisamos recuperar dos escombros a civilidade</segment>
    <segment id="108">para que</segment>
    <segment id="109">para que um presidente da República não atribua a alta votação do adversário ao analfabetismo</segment>
    <segment id="110">, tratado</segment>
    <segment id="111">comocomo mácula e desonra.</segment>
    <segment id="112">O plano econômico da hora é a democracia.</segment>
    <segment id="113">É isso o que está em jogo.</segment>
    <segment id="114">Enquanto escrevo</segment>
    <segment id="115">, vem-me a lembrança a fala de Bolsonaro</segment>
    <segment id="116">, então pré-candidato</segment>
    <segment id="117">, jactando-</segment>
    <segment id="118">sese em entrevista ao New York Times</segment>
    <segment id="119">, de não ter comido carne humana em suposto ritual indígena</segment>
    <segment id="120">porque</segment>
    <segment id="121">porque gente de sua equipe não quis acompanhá-lo.</segment>
    <segment id="122">O canibal diletante tratava a coisa</segment>
    <segment id="123">comocomo um de seus atos de coragem e desassombro:</segment>
    <segment id="124">"É a cultura deles".</segment>
    <segment id="125">Ele só lhes impõe "a nossa" quando</segment>
    <segment id="126">sese trata de</segment>
    <segment id="127">, na prática</segment>
    <segment id="128">, promover a invasão de terras indígenas pelo garimpo pistoleiro.</segment>
    <segment id="129">Chegamos</segment>
    <segment id="130">, pois</segment>
    <segment id="131">pois, ao extremo de a eleição ser também um confronto entre vegetarianos e carnívoros quando a matéria é a carne humana.</segment>
    <segment id="132">Veja economistas que apoiam LulaMais    novamente         de   de  de  representando</segment>
    <segment id="133">um</segment>
  </rst>
</analysis>