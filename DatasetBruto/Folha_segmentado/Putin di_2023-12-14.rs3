  <rst>
    <segment id="1">Se a Guerra da Ucrânia trouxe notícias mais favoráveis a Vladimir Putin</segment>
    <segment id="2">, sua entrevista coletiva e sessão de perguntas com cidadãos selecionados anual provou que o presidente russo está sendo assombrado por outro problema: a inflação do ovo.</segment>
    <segment id="3">"</segment>
    <segment id="4">A demanda cresceu</segment>
    <segment id="5">, era uma proteína relativamente barata popular entre os cidadãos.</segment>
    <segment id="6">Eu mesmo</segment>
    <segment id="7">comocomo ovos mexidos com prazer.</segment>
    <segment id="8">Eu podia comer até dez ovos na manhã"</segment>
    <segment id="9">, afirmou</segment>
    <segment id="10">, respondendo a uma questão transmitida por vídeo.</segment>
    <segment id="11">Morador de Moscou mostra um pacote com dez ovos em uma loja da capital - Alexander Nemenov/AFPNela</segment>
    <segment id="12">, a aposentada Irina Akopova dizia: "</segment>
    <segment id="13">Dez ovos custam entre 120 e 180 rublos (R$ 6</segment>
    <segment id="14">,50 a R$ 9</segment>
    <segment id="15">,80) onde eu moro.</segment>
    <segment id="16">Quando tivemos preços tão altos?</segment>
    <segment id="17">Valdimir Vladimirovitch</segment>
    <segment id="18">, coloque as coisas em ordem</segment>
    <segment id="19">, tenha pena dos aposentados"</segment>
    <segment id="20">, afirmou ela</segment>
    <segment id="21">, usando o prenome e o patronímico ("filho de Vladimir") de Putin</segment>
    <segment id="22">, a forma usual de</segment>
    <segment id="23">sese dirigir a outra pessoa na Rússia.</segment>
    <segment id="24">Não é questão trivial</segment>
    <segment id="25">, tanto que o russo fez uma rara admissão de culpa.</segment>
    <segment id="26">"</segment>
    <segment id="27">Em me desculpo por isso</segment>
    <segment id="28">, masmas é uma falha do trabalho do nosso governo.</segment>
    <segment id="29">Eu prometo que a situação será corrigida</segment>
    <segment id="30">"</segment>
    <segment id="31">, afirmou.</segment>
    <segment id="32">Segundo dados do Serviço Federal de Estatísticas da Rússia</segment>
    <segment id="33">, o preço do produto subiu 40</segment>
    <segment id="34">,29% em novembro</segment>
    <segment id="35">, em comparação com o mesmo mês do ano passado.</segment>
    <segment id="36">A inflação geral</segment>
    <segment id="37">, que está alta</segment>
    <segment id="38">, chegou a 7</segment>
    <segment id="39">,45% e Putin disse temer que ela fique "acima de 8%".</segment>
    <segment id="40">O russo deverá</segment>
    <segment id="41">sese reeleger em março</segment>
    <segment id="42">, numa eleição em que não terá concorrentes viáveis</segment>
    <segment id="43">, masmas o Kremlin foca na manutenção de seus índices de popularidade acima de 80%</segment>
    <segment id="44">, mesmo segundo institutos independentes.</segment>
    <segment id="45">No Brasil</segment>
    <segment id="46">, dez ovos saem por entre R$ 10 (normais) e R$ 15 (caipiras)</segment>
    <segment id="47">, em redes de supermercado.</segment>
    <segment id="48">Na Rússia</segment>
    <segment id="49">, a aumento do consumo levou à situação atual</segment>
    <segment id="50">, com o governo autorizando importação do produto da Turquia e estudando um veto à exportação de ovos.</segment>
    <segment id="51">A situação</segment>
    <segment id="52">sese agrava também</segment>
    <segment id="53">porque</segment>
    <segment id="54">porque o ovo é ingrediente central em diversos pratos sazonais do fim do ano no país</segment>
    <segment id="55">, como</segment>
    <segment id="56">como maionese.</segment>
    <segment id="57">Putin, 20 anos no poderMais    novamente         de   de  de  representando um  "</segment>
    <segment id="58">Eu falei com o ministro da Agricultura sobre</segment>
    <segment id="59">comocomo estavam as coisas com os ovos.</segment>
    <segment id="60">Ele disse que estava tudo ótimo"</segment>
    <segment id="61">, brincou de forma machista Putin</segment>
    <segment id="62">, aludindo ao fato de que ovos são sinônimo de testículos no país</segment>
    <segment id="63">, e a plateia de 600 jornalistas caiu na risada.</segment>
    <segment id="64">A dieta de Putin</segment>
    <segment id="65">, um dos líderes mais opacos do mundo</segment>
    <segment id="66">, é um segredo de Estado.</segment>
    <segment id="67">Aqui e ali ele revelou</segment>
    <segment id="68">, ao longo dos anos</segment>
    <segment id="69">, gostar de omeletes e ovos crus</segment>
    <segment id="70">, de galinha e de cordorna</segment>
    <segment id="71">, pela manhã.</segment>
    <segment id="72">Isso combina com sua imagem atlética</segment>
    <segment id="73">, dada a alto consumo protéico</segment>
    <segment id="74">comocomo ocorre entre frequentadores de academia</segment>
    <segment id="75">, ainda que ele aos 71 anos não</segment>
    <segment id="76">sese veja mais tanto o presidente</segment>
    <segment id="77">sese exercitando sem camisa</segment>
    <segment id="78">comocomo antes.</segment>
    <segment id="79">Cotidiano em Moscou na guerraMais    novamente         de   de  de  representando um</segment>
    <segment id="80">Apesar de a guerra ser o centro da entrevista</segment>
    <segment id="81">, houve outros temas colocados.</segment>
    <segment id="82">Putin elogiou a Turquia por seu papel crítico a Israel no conflito em curso em Gaza e falou muito de economia.</segment>
    <segment id="83">Afirmou que a Rússia resistiu às sanções</segment>
    <segment id="84">, lembrando que o país vai crescer 3</segment>
    <segment id="85">,5% neste ano</segment>
    <segment id="86">, masmas reclamou da inflação e apontou problemas cambiais.</segment>
    <segment id="87">A um repórter do The New York Times</segment>
    <segment id="88">, a quem deu a palavra depois de cortá-la em favor de um jornalista da agência chinesa Xinhua</segment>
    <segment id="89">, disse que espera que haja um acordo de troca de prisioneiros para libertar um jornalista e um militar americanos presos na Rússia.</segment>
    <segment id="90">Ao fim</segment>
    <segment id="91">, houve um momento insólito</segment>
    <segment id="92">, quando um jovem de São Petersburgo questionou o presidente sobre inteligência artificial.</segment>
    <segment id="93">Só que a pergunta foi feita por um Putin em modo "deepfake"</segment>
    <segment id="94">, uma montagem elaborada por computador.</segment>
    <segment id="95">O russo respondeu que é impossível controlar o desenvolvimento do setor e que quer ver seu país líder.</segment>
  </rst>
</analysis>