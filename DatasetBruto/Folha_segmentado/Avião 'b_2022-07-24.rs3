  <rst>
    <segment id="1">O avião "baleia"</segment>
    <segment id="2">, o Airbus A300-600ST</segment>
    <segment id="3">, pousou no Brasil neste domingo (24)</segment>
    <segment id="4">, pela primeira vez na história.</segment>
    <segment id="5">O Beluga ST veio da França com uma parada técnica no Senegal</segment>
    <segment id="6">, a chegada no Aeroporto Internacional Pinto Martins</segment>
    <segment id="7">, em Fortaleza (CE)</segment>
    <segment id="8">, ocorreu às 15h24 deste domingo.</segment>
    <segment id="9">O avião especial</segment>
    <segment id="10">, de matrícula F-GSTB</segment>
    <segment id="11">, passou a noite em Fortaleza.</segment>
    <segment id="12">Nesta segunda (25)</segment>
    <segment id="13">, ele pousou por volta de 13h50 no aeroporto Internacional de Viracopos</segment>
    <segment id="14">, em Campinas (SP)</segment>
    <segment id="15">, seu destino final durante a primeira viagem no Brasil.</segment>
    <segment id="16">Cargueiro baleia</segment>
    <segment id="17">, da Airbus</segment>
    <segment id="18">, pousou em Viracopos por volta de 13h50 de segunda-feira (25) - Thiago Bethônico/FolhapressA aeronave cargueira trouxe a bordo um helicóptero ACH160 que a fabricante Airbus entegará a um cliente brasileiro.</segment>
    <segment id="19">O pouso do Beluga em Fortaleza</segment>
    <segment id="20">, no domingo</segment>
    <segment id="21">, e em Campinas</segment>
    <segment id="22">, na segunda</segment>
    <segment id="23">, chegou a ser transmitido por canais de Youtube que acompanham o mercado de aviação.</segment>
    <segment id="24">Segundo divulgado pela companhia</segment>
    <segment id="25">, a partida de Campinas para retornar à Europa</segment>
    <segment id="26">, com mais uma parada técnica em Fortaleza</segment>
    <segment id="27">, está prevista para ocorrer apenas no final da tarde de terça (26).</segment>
    <segment id="28">O Beluga é um modelo desenvolvido a partir do Airbus A300-600</segment>
    <segment id="29">, modificado com a instalação de uma estrutura de fuselagem muito maior.</segment>
    <segment id="30">Apenas cinco deles foram produzidos durante os anos 1990.</segment>
    <segment id="31">A adaptação teve por objetivo transportar cargas super volumosas</segment>
    <segment id="32">, masmas restritas especificamente às partes de aviões da própria Airbus</segment>
    <segment id="33">, como</segment>
    <segment id="34">como fuselagens do A320 ou asas do gigante A380</segment>
    <segment id="35">, entre suas unidades produtivas espalhadas pela Europa.</segment>
    <segment id="36">Avião cargueiro da Airbus BelugaST pousa em Fortaleza (CE) - Helibras no InstagramPorém</segment>
    <segment id="37">, nos últimos anos a fabricante europeia lançou o novo e maior BelugaXL</segment>
    <segment id="38">, baseado no A330-200.</segment>
    <segment id="39">Com isso</segment>
    <segment id="40">, os antigos Beluga estão sendo usados em uma nova subsidiária da Airbus</segment>
    <segment id="41">, com seu próprio certificado de transportador aéreo para operar serviços comerciais</segment>
    <segment id="42">, tornando-</segment>
    <segment id="43">sese uma companhia aérea efetivamente.</segment>
    <segment id="44">A Airbus destaca que o Beluga pode levar qualquer carga que tenha até sete metros de largura e 6</segment>
    <segment id="45">,7 metros de altura</segment>
    <segment id="46">, sem precisar de nenhuma adaptação no transporte.</segment>
    <segment id="47">A fabricante também anunciou que o novo BelugaXL em breve estará disponível para esse mesmo tipo de transporte.</segment>
  </rst>
</analysis>