  <rst>
    <segment id="1">Em 2001</segment>
    <segment id="2">, a executiva americana Kathleen Peterson foi encontrada morta aos pés da escada de sua casa</segment>
    <segment id="3">, com diversos ferimentos pelo corpo.</segment>
    <segment id="4">Seu marido</segment>
    <segment id="5">, o escritor Michael Peterson</segment>
    <segment id="6">, logo</segment>
    <segment id="7">sese tornou o principal suspeito pelo crime.  Colin Firth e Toni Colette em cena da série &amp;#</segment>
    <segment id="8">039;A Escada&amp;#039</segment>
    <segment id="9">; - DivulgaçãoEste</segment>
    <segment id="10">casocaso rumoroso já rendeu uma série documental disponível na Netflix</segment>
    <segment id="11">, e agora é dramatizado nesta minissérie.</segment>
    <segment id="12">Nomes consagrados</segment>
    <segment id="13">comocomo Colin Firth</segment>
    <segment id="14">, Toni Colette e Juliette Binoche encabeçam o elenco.</segment>
    <segment id="15">Um novo episódio toda quinta-feira</segment>
    <segment id="16">; três já estão disponíveis.  HBO Max</segment>
    <segment id="17">, 16 anos   Irmandade</segment>
    <segment id="18">Na segunda temporada da série nacional</segment>
    <segment id="19">, o líder de uma facção criminosa</segment>
    <segment id="20">, vivido por Seu Jorge</segment>
    <segment id="21">, sobrevive a uma rebelião na cadeia.</segment>
    <segment id="22">Enquanto isto</segment>
    <segment id="23">, do lado de fora</segment>
    <segment id="24">, sua irmã advogada</segment>
    <segment id="25">, papel de Naruna Costa</segment>
    <segment id="26">, precisa armar um plano para o proteger.</segment>
    <segment id="27">Netflix</segment>
    <segment id="28">, 18 anos</segment>
    <segment id="29">Dê Lembranças a Todos</segment>
    <segment id="30">O documentário dos irmãos Fábio</segment>
    <segment id="31">Di Fiori e Thiago Di Fiori recria a trajetória do compositor baiano Dorival Caymmi</segment>
    <segment id="32">, um dos maiores nomes da música brasileira de todos os tempos.  sesctv.org.br</segment>
    <segment id="33">, 12 anos</segment>
    <segment id="34">, grátis   Amigo Arrigo</segment>
    <segment id="35">A faixa "</segment>
    <segment id="36">É Tudo Verdade" traz o documentário de Alain Fresnot e Junior Carone sobre o artista paulistano Arrigo Barnabé</segment>
    <segment id="37">, que passou por diversos estilos até</segment>
    <segment id="38">sese dedicar à música de vanguarda.</segment>
    <segment id="39">Canal Brasil</segment>
    <segment id="40">, 20h, 10 anos</segment>
    <segment id="41">Veja imagens do documentário &amp;#039</segment>
    <segment id="42">;Amigo Arrigo&amp;#039</segment>
    <segment id="43">;, sobre o autor de &amp;#039</segment>
    <segment id="44">;Clara Crocodilo&amp;#039</segment>
    <segment id="45">;Mais    novamente         de   de  de  representando um   Palestra de Selva Almada</segment>
    <segment id="46">A escritora argentina</segment>
    <segment id="47">Selva Almada conversa sobre seu livro "Garotas</segment>
    <segment id="48">Mortas</segment>
    <segment id="49">"</segment>
    <segment id="50">, que retrata três casos de feminicídio ocorridos em seu país na década de 1980</segment>
    <segment id="51">, com as artistas e pesquisadoras Fernanda Machado</segment>
    <segment id="52">, Luiza Romão e Sofia Boito.</segment>
    <segment id="53">YouTube do coletivo Palabreria</segment>
    <segment id="54">, 20h</segment>
    <segment id="55">Tabu</segment>
    <segment id="56">O cineasta alemão F. W. Murnau</segment>
    <segment id="57">, de "Aurora" e "Nosferatu"</segment>
    <segment id="58">, dirige neste longa-metragem de 1931 uma das últimas obras-primas do cinema mudo.</segment>
    <segment id="59">Rodado na ilha de Bora Bora</segment>
    <segment id="60">, na Polinésia Francesa</segment>
    <segment id="61">, o filme conta a história do amor proibido entre um jovem pescador e uma moça consagrada aos deuses.</segment>
