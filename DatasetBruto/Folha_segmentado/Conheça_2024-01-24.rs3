    <segment id="169">, o Nomaa</segment>
    <segment id="170">sese firmou</segment>
    <segment id="171">comocomo uma boa opção na capital paranaense para turistas que apreciam arquitetura e design.</segment>
    <segment id="172">Situado no bairro do Batel</segment>
    <segment id="173">, o hotel abriga 42 quartos com mobiliário assinado por grandes nomes brasileiros</segment>
    <segment id="174">comocomo Sérgio Rodrigues e Jader Almeida</segment>
    <segment id="175">, além inúmeras obras de artistas locais.</segment>
    <segment id="176">Abertos a não hóspedes</segment>
    <segment id="177">, o café da manhã e o brunch são generosos</segment>
    <segment id="178">, com boa variedade de opções à la carte.</segment>
    <segment id="179">Rua Gutemberg</segment>
    <segment id="180">, 168, Batel</segment>
    <segment id="181">, Curitiba (PR).</segment>
