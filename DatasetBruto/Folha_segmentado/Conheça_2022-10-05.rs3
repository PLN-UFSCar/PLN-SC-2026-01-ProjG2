  <rst>
    <segment id="1">O Porco Mundi</segment>
    <segment id="2">, evento dos chefs Janaina Torres Rueda e Jefferson Rueda</segment>
    <segment id="3">, volta com força total depois de uma pausa de três anos.</segment>
    <segment id="4">Serão 19 chefs de sete países latino-americanos preparando um único jantar no dia 11 de outubro</segment>
    <segment id="5">, às 19h.</segment>
    <segment id="6">O evento será realizado n'A Casa do Porco</segment>
    <segment id="7">, 7º melhor restaurante do mundo</segment>
    <segment id="8">, segundo o The World’s 50 Best Restaurants</segment>
    <segment id="9">, e terá ingressos limitados para o público a R$ 1.000 (com bebidas).</segment>
    <segment id="10">Participantes do Porco Mundi realizado em 2019</segment>
    <segment id="11">, que homenageou a Colômbia - DivulgaçãoCriado em 2016 com o intuito de proporcionar o intercâmbio e a confraternização entre chefs do mundo todo</segment>
    <segment id="12">, o Porco Mundi tem a carne suína</segment>
    <segment id="13">comocomo protagonista.</segment>
    <segment id="14">Segundo Jefferson</segment>
    <segment id="15">, "a proposta do evento é investigar a importância cultural</segment>
    <segment id="16">, econômica e social da carne de porco para os diversos povos do mundo e</segment>
    <segment id="17">comocomo eles trabalham esta proteína para</segment>
    <segment id="18">sese alimentar".</segment>
    <segment id="19">E depois de homenagear a Espanha</segment>
    <segment id="20">, o Equador</segment>
    <segment id="21">, a Argentina</segment>
    <segment id="22">, o Brasil</segment>
    <segment id="23">, o Peru e a Colômbia</segment>
    <segment id="24">, chegou a vez de reverenciar a América Latina</segment>
    <segment id="25">, tema dessa edição.</segment>
    <segment id="26">Participam chefs vindos da Argentina</segment>
    <segment id="27">, do Chile</segment>
    <segment id="28">, da Colômbia</segment>
    <segment id="29">, da Costa Rica</segment>
    <segment id="30">, do Equador</segment>
    <segment id="31">, do México e do Peru.</segment>
    <segment id="32">Cada um vai preparar uma receita do menu</segment>
    <segment id="33">, que será composto por 10 entradas</segment>
    <segment id="34">, seis pratos principais e três sobremesas</segment>
    <segment id="35">, revelando um pouco da cultura da carne suína de cada país.</segment>
    <segment id="36">Saiba quem são os chefs convidados e seus respectivos restaurantes.</segment>
    <segment id="37">Colunas e BlogsReceba no seu email uma seleção de colunas e blogs da Folha</segment>
    <segment id="38">; exclusiva para assinantes.</segment>
    <segment id="39">Carregando...</segment>
    <segment id="40">Argentina • Cesar Sagario: Corte Comedor</segment>
    <segment id="41">, Corte Charcutería</segment>
