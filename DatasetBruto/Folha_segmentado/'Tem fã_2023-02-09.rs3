  <rst>
    <segment id="1">A atriz Ana Hikari afirma estar muito empolgada para o Carnaval</segment>
    <segment id="2">, especialmente os blocos de rua.</segment>
    <segment id="3">"Sou a pessoa mais carnavalesca que tem.</segment>
    <segment id="4">Vou para tudo quanto é canto"</segment>
    <segment id="5">, diz ela</segment>
    <segment id="6">, que vai</segment>
    <segment id="7">sese dividir entre São Paulo e Rio de Janeiro nos dias de folia.</segment>
    <segment id="8">A atriz Ana Hikari no lançamento da série &amp;quot</segment>
    <segment id="9">;As Five&amp;quot</segment>
    <segment id="10">;, no Blue Note</segment>
    <segment id="11">, em São Paulo - Mathilde Missioneiro/FolhapressDepois de dois anos de restrições por causa da pandemia</segment>
    <segment id="12">, Ana destaca que será o momento de abraçar "todo mundo sem medo".</segment>
    <segment id="13">"</segment>
    <segment id="14">Eu estou maluca para estar lá</segment>
    <segment id="15">, com os meus amigos</segment>
    <segment id="16">, rebolando até o chão</segment>
    <segment id="17">, no asfalto.</segment>
    <segment id="18">Esse é o meu mood [humor].</segment>
    <segment id="19">"</segment>
    <segment id="20">O figurino ainda não está definido</segment>
    <segment id="21">, conta a atriz à coluna</segment>
    <segment id="22">, masmas há uma certeza: "</segment>
    <segment id="23">Seminua na rua [risos].</segment>
    <segment id="24">Essa é a minha fantasia.</segment>
    <segment id="25">Com o quê</segment>
    <segment id="26">, eu ainda não sei</segment>
    <segment id="27">, vou com o que tiver e com muito glitter"</segment>
    <segment id="28">, diverte-</segment>
    <segment id="29">sese.</segment>
    <segment id="30">Questionada</segment>
    <segment id="31">sese é abordada por fãs quando está pulando no bloco</segment>
    <segment id="32">, Ana Hikari diz que sim.</segment>
    <segment id="33">"E o pior é quando a gente está beijando na boca"</segment>
    <segment id="34">, afirma</segment>
    <segment id="35">, rindo.</segment>
    <segment id="36">"</segment>
    <segment id="37">Aí a gente fala 'oi'</segment>
    <segment id="38">, tira foto e segue a vida.</segment>
    <segment id="39">Mas acontece</segment>
    <segment id="40">, é vida real.</segment>
    <segment id="41">"</segment>
    <segment id="42">Lançamento da segunda temporada da série &amp;#039</segment>
    <segment id="43">;As Five&amp;#039</segment>
    <segment id="44">;, da GloboplayMais    novamente         de   de  de  representando um  A atriz revela também que há os admiradores que querem um pouco mais.</segment>
    <segment id="45">"</segment>
    <segment id="46">Tem fã que ainda pede para beijar na boca"</segment>
    <segment id="47">, diz.</segment>
    <segment id="48">Ana conta que dá um jeitinho para sair da situação.</segment>
    <segment id="49">"</segment>
    <segment id="50">Poso para foto e falo:</segment>
    <segment id="51">'</segment>
    <segment id="52">Ai, meus amigos estão indo ali'.</segment>
    <segment id="53">"</segment>
    <segment id="54">A atriz conversou com a coluna no lançamento da segunda temporada da série "</segment>
    <segment id="55">As Five"</segment>
    <segment id="56">, do Globoplay</segment>
    <segment id="57">, nesta semana</segment>
    <segment id="58">, em São Paulo.</segment>
    <segment id="59">Na trama</segment>
    <segment id="60">, ela interpreta Tina</segment>
    <segment id="61">, uma das cinco protagonistas.</segment>
    <segment id="62">Mônica BergamoReceba no seu email as informações exclusivas da coluna</segment>
    <segment id="63">Mônica BergamoCarregando...</segment>
    <segment id="64">A produção</segment>
    <segment id="65">, que acaba de estrear na plataforma de streaming</segment>
    <segment id="66">, foi gravada em um estúdio em Osasco</segment>
    <segment id="67">, na região metropolitana de São Paulo</segment>
    <segment id="68">, e em pontos da capital paulista</segment>
    <segment id="69">, como</segment>
    <segment id="70">como a Liberdade</segment>
    <segment id="71">, bairro conhecido por ser o reduto da cultura japonesa.</segment>
    <segment id="72">"</segment>
    <segment id="73">Durante as filmagens na Liberdade</segment>
    <segment id="74">, muita gente</segment>
    <segment id="75">sese identificava e vinha falar comigo: 'Nossa</segment>
    <segment id="76">, sua personagem foi muito importante para mim</segment>
    <segment id="77">, me fez entender as minhas questões sobre ser brasileira de origem asiática no Brasil"</segment>
    <segment id="78">, relata ela</segment>
    <segment id="79">, que tem ascendência japonesa.  com BIANKA VIEIRA</segment>
    <segment id="80">, KARINA MATIAS e MANOELLA SMITH</segment>
  </rst>
</analysis>