  <rst>
    <segment id="1">O Flamengo chegou aos 52 pontos em 23 rodadas</segment>
    <segment id="2">, índice inédito em 17 anos de Brasileiro em turno e returno.</segment>
    <segment id="3">O líder não tem o recorde do ataque</segment>
    <segment id="4">, que pertence ao Cruzeiro de 2007</segment>
    <segment id="5">, com 54 gols.</segment>
    <segment id="6">Pergunta-</segment>
    <segment id="7">sese se</segment>
    <segment id="8">se o Corinthians pode ser campeão brasileiro</segment>
    <segment id="9">, porque</segment>
    <segment id="10">porque só perdeu 1 de 14 jogos depois da Copa América.</segment>
    <segment id="11">Não pode.</segment>
    <segment id="12">Dois anos atrás</segment>
    <segment id="13">, podia.</segment>
    <segment id="14">O Corinthians de Fábio Carille tinha 50 pontos nesta altura do Brasileiro.</segment>
    <segment id="15">Carregava 20 gols de saldo positivo e tinha vencido 14 partidas.</segment>
    <segment id="16">Mas sua força era a defesa.</segment>
    <segment id="17">Foi campeão com 9 empates e 72 pontos.</segment>
    <segment id="18">Ano passado</segment>
    <segment id="19">, o Flamengo foi vice com a mesma pontuação.</segment>
    <segment id="20">Nestes 17 anos de pontos corridos</segment>
    <segment id="21">, houve períodos de domínio do ataque e outros da defesa.</segment>
    <segment id="22">Atacar fez o Cruzeiro de Luxemburgo dar a impressão de que a receita era essa.</segment>
    <segment id="23">Neste momento</segment>
    <segment id="24">, é o que acontece com o Flamengo de Jorge Jesus.</segment>
    <segment id="25">Flamengo com três mudanças e mandando no jogo -O</segment>
    <segment id="26">Flamengo virar referência não é uma questão de estatística.</segment>
    <segment id="27">É de tática e estratégia.</segment>
    <segment id="28">Pela Libertadores</segment>
    <segment id="29">, o Grêmio sofreu com seu sistema de marcação por encaixe.</segment>
    <segment id="30">Aprendemos no Brasil que Zezé Moreira inventou a marcação por zona.</segment>
    <segment id="31">Só que os relatos do passado indicam que seu sistema era de encaixar marcadores e perseguir até o fim da jogada.</segment>
    <segment id="32">Os times mais modernos jogam por zona pura.</segment>
    <segment id="33">Seja o Manchester City</segment>
    <segment id="34">, de Guardiola</segment>
    <segment id="35">, seja o Palmeiras</segment>
    <segment id="36">, de Mano Menezes.</segment>
    <segment id="37">Persegue-</segment>
    <segment id="38">sese dentro do quadrante.</segment>
    <segment id="39">Isso diminui a chance de perseguições individuais abrirem buracos na defesa</segment>
    <segment id="40">, como</segment>
    <segment id="41">como Kannemann fez ao tentar desarmar Éverton Ribeiro e Willian Arão.</segment>
    <segment id="42">Ainda há técnicos importantes que marcam assim</segment>
    <segment id="43">, como</segment>
    <segment id="44">como Sampaoli e Bielsa.</segment>
    <segment id="45">Não significa estar ultrapassado.</segment>
    <segment id="46">O Palmeiras guarda a memória da marcação por encaixe de Felipão.</segment>
    <segment id="47">Contra o Inter</segment>
    <segment id="48">, houve uma jogada em que Diogo Barbosa saiu para dar o bote</segment>
    <segment id="49">, ficou no meio do caminho e Dudu salvou a chance colorada.</segment>
    <segment id="50">É um dos riscos de mudar de técnico.</segment>
    <segment id="51">Mudanças invisíveis para os torcedores são muitas vezes decisivas.</segment>
    <segment id="52">Atlético-MG no 5-4-1:</segment>
    <segment id="53">virava 3-4-3 no ataque -No empate com o Atlético-MG</segment>
    <segment id="54">, a dificuldade foi outra.</segment>
    <segment id="55">Rodrigo Santana imitou o que Antonio Conte fazia na Juventus e no Chelsea</segment>
    <segment id="56">, com um 3-4-3</segment>
    <segment id="57">, que se</segment>
    <segment id="58">se transforma em 5-4-1</segment>
    <segment id="59">, na defesa.</segment>
    <segment id="60">O sistema consiste em uma sanfona em que os laterais</segment>
    <segment id="61">sese juntam aos zagueiros para defender e aos volantes para atacar.</segment>
    <segment id="62">A linha de cinco tirou espaço do Palmeiras.</segment>
    <segment id="63">Para tentar superá-la</segment>
    <segment id="64">, Mano Menezes deixou Borja e Deyversonjuntos por dez minutos.</segment>
    <segment id="65">Era a tentativa de criar situação desconfortável para a marcação atleticana.</segment>
    <segment id="66">Não deu certo.</segment>
    <segment id="67">Porque o que funciona sempre é o treino.</segment>
    <segment id="68">Nele, Jorge Jesus construiu o time de movimentação mais constante do Brasil</segment>
    <segment id="69">, desde o Santos campeão da Copa do Brasil de 2010</segment>
    <segment id="70">, com Robinho</segment>
    <segment id="71">, Neymar</segment>
    <segment id="72">, Ganso e André.</segment>
    <segment id="73">Gabriel comemora após marcar contra o Santos</segment>
    <segment id="74">, seu ex-time - Sergio Moraes - 14.set.2019/REUTERSNo Flamengo</segment>
    <segment id="75">, como</segment>
    <segment id="76">como naquele Santos</segment>
    <segment id="77">, a troca de posições não é óbvia.</segment>
    <segment id="78">Não é mudar o ponta de lado</segment>
    <segment id="79">, masmas deslocar para receber</segment>
    <segment id="80">, pedir para ter preferência.</segment>
    <segment id="81">Dizia Tim.</segment>
    <segment id="82">É mais difícil marcar</segment>
    <segment id="83">, quando os mesmos jogadores ocupam lugares diferentes na mesma jogada.</segment>
    <segment id="84">É o que faz o Flamengo.  França</segment>
    <segment id="85">, Alemanha</segment>
    <segment id="86">, Espanha e Inglaterra têm a maioria de seus campeões com treinadores estrangeiros.</segment>
    <segment id="87">Portugal não tem desde 2006</segment>
    <segment id="88">, quando o holandês Co Adriaanse ganhou pelo Porto.</segment>
    <segment id="89">Pode ser a vez de Jorge Jesus no Brasil  Ações e expressões de Jorge Jesus à beira do gramado   novamente         de   de  de  representando um  Quem vai perseguir  Quarta-feira (9) tem Santos x Palmeiras</segment>
    <segment id="90">, na Vila Belmiro.</segment>
    <segment id="91">Jogo que vai definir o perseguidor do Flamengo.</segment>
    <segment id="92">O campeonato não está decidido</segment>
    <segment id="93">, mesmo com cinco pontos à frente.</segment>
    <segment id="94">Mas a próxima rodada pode permitir ao time rubro-negro abrir oito de vantagem sobre o vice-líder.</segment>
    <segment id="95">Tempo ao Tempo  Não</segment>
    <segment id="96">sese diga que Fernando Diniz não mudou o São Paulo.</segment>
    <segment id="97">Por óbvia que seja esta afirmação.</segment>
    <segment id="98">Não se</segment>
    <segment id="99">se muda um time em dez dias e nem Jorge Jesus fez isto</segment>
