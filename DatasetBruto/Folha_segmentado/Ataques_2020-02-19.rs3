  <rst>
    <segment id="1">Ao menos oito pessoas morreram na noite desta quarta-feira (19) em dois ataques a tiros na cidade de Hanau</segment>
    <segment id="2">, próxima a Frankfurt</segment>
    <segment id="3">, na Alemanha</segment>
    <segment id="4">, afirmou a polícia local.</segment>
    <segment id="5">A emissora regional de Hessenschau relatou que os suspeitos abriram fogo num bar de "shisha" (narguilê) na região central</segment>
    <segment id="6">, matando três pessoas.</segment>
    <segment id="7">Depois</segment>
    <segment id="8">, eles teriam ido a um segundo bar</segment>
    <segment id="9">, em outro bairro</segment>
    <segment id="10">, onde mataram outras cinco.</segment>
    <segment id="11">Várias pessoas ficaram feridas —ao menos cinco</segment>
    <segment id="12">, segundo promotores.</segment>
    <segment id="13">A motivação dos ataques é desconhecida.</segment>
    <segment id="14">Carros e helicópteros de unidades especiais da polícia estão sendo usados para localizar os suspeitos</segment>
    <segment id="15">, que fugiram do local do primeiro ataque num carro de cor escura</segment>
    <segment id="16">, afirmou a corporação.​  Agentes armados isolaram duas ruas da cidade</segment>
    <segment id="17">, onde ambulâncias prestam atendimento às vítimas.</segment>
    <segment id="18">A polícia criou uma linha telefônica direta para receber informações que poderiam levar aos autores.</segment>
    <segment id="19">Policial isola a área onde um dos ataques ocorreu</segment>
    <segment id="20">, em Hanau</segment>
    <segment id="21">, na Alemanha - Kai Pfaffenbach/Reuters</segment>
  </rst>
</analysis>