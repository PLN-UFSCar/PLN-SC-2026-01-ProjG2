  <rst>
    <segment id="1">Emicida encontrou ambiente mais que adequado ao show de lançamento de “AmarElo”</segment>
    <segment id="2">, seu mais recente álbum</segment>
    <segment id="3">, na apresentação que fez no Theatro Municipal de São Paulo na tarde desta quarta (27).</segment>
    <segment id="4">Os ingressos para as duas sessões —houve ainda um show às 21h—</segment>
    <segment id="5">, vendidos no dia 8</segment>
    <segment id="6">, esgotaram em dez minutos.</segment>
    <segment id="7">A movimentação era intensa em torno do Municipal</segment>
    <segment id="8">, com telões e caixas de som instalados perto da escadaria</segment>
    <segment id="9">, virados para a calçada.​  Veja fotos do show de Emicida no Theatro MuinicipalMais    novamente         de   de  de  representando um</segment>
    <segment id="10">O rapper foi recebido por uma plateia orgulhosa de seu ídolo</segment>
    <segment id="11">, que gritava “você merece”</segment>
    <segment id="12">, enquanto câmeras passavam por cima do público.</segment>
    <segment id="13">“Vamos fazer um filme contando essa história”</segment>
    <segment id="14">, avisou.</segment>
    <segment id="15">Cantor</segment>
    <segment id="16">, banda e o tradicional espaço estavam em sinergia.  “AmarElo”</segment>
    <segment id="17">, disco em que o rapper economiza nas rimas agressivas e no discurso social ácido que marcou o começo de sua carreira</segment>
    <segment id="18">, é calcado mais nas melodias —de samba</segment>
    <segment id="19">, MPB, R&amp;amp</segment>
    <segment id="20">;B e até de gospel— do que nas letras e batidas.</segment>
    <segment id="21">Logo na primeira performance</segment>
    <segment id="22">, da nova “</segment>
    <segment id="23">A Ordem Natural das Coisas”</segment>
    <segment id="24">, ele se</segment>
    <segment id="25">se emocionou e levou a mão aos olhos com a cabeça baixa abraçado à cantora MC Tha.</segment>
    <segment id="26">Os momentos de emoção foram muitos</segment>
    <segment id="27">, sobretudo nas entradas dos convidados</segment>
    <segment id="28">, entre eles Drik Barbosa</segment>
    <segment id="29">, Jé Santiago</segment>
    <segment id="30">, Majur e Pabllo Vittar.</segment>
    <segment id="31">“Muito importante trazer um concerto de rap para cá”</segment>
    <segment id="32">, Emicida anunciou.</segment>
    <segment id="33">“</segment>
    <segment id="34">Isso aqui é o resultado do sonho coletivo de muita gente.</segment>
    <segment id="35">Essa conquista é o que anistia o espírito de quem veio antes de nós e sofreu.</segment>
    <segment id="36">” O Municipal já havia recebido shows de rap em edições da Virada Cultural.</segment>
    <segment id="37">Emicida equilibrou calmaria e barulho conforme o show foi avançando.</segment>
    <segment id="38">Na primeira metade</segment>
    <segment id="39">, emendou baladas —</segment>
    <segment id="40">comocomo “Madagascar”</segment>
    <segment id="41">, “Baiana”</segment>
    <segment id="42">, “9nha”— e as faixas mais reflexivas de “AmarElo” —“Pequenas Alegrias da Vida Adulta”</segment>
    <segment id="43">, “Cananeia</segment>
    <segment id="44">, Iguape e Ilha Comprida”—</segment>
    <segment id="45">, incrementadas por um naipe de metais.  “AmarElo”</segment>
    <segment id="46">, com sample de Belchior e participações de Pabllo Vittar e Majur</segment>
    <segment id="47">, foi um dos momentos mais eufóricos.</segment>
    <segment id="48">Além de gritar junto com as cantoras o refrão</segment>
    <segment id="49">, a plateia aplaudiu de pé e efusivamente.</segment>
    <segment id="50">A partir dali</segment>
    <segment id="51">, Emicida puxou a fatia mais hip-hop do show</segment>
    <segment id="52">, emendando rimas velozes.</segment>
    <segment id="53">Ele cantou “Eminência Parda”</segment>
    <segment id="54">, “Boa Esperança”</segment>
    <segment id="55">, “Ismália”</segment>
    <segment id="56">, “Levanta e Anda” e “Principia”.</segment>
    <segment id="57">Já na parte final</segment>
    <segment id="58">, alguém na plateia gritou que Emicida “merece” desfrutar o momento.</segment>
    <segment id="59">“</segment>
    <segment id="60">Nós merecemos”</segment>
    <segment id="61">, ele respondeu</segment>
    <segment id="62">, dizendo que ninguém faz nada sozinho.</segment>
    <segment id="63">Imagens do rapper EmicidaMais    novamente         de   de  de  representando um</segment>
    <segment id="64">Logo depois</segment>
    <segment id="65">, falou sobre representatividade —não só pelo show</segment>
    <segment id="66">, masmas por artistas e público negros ocuparem um espaço historicamente relegado às elites brancas.</segment>
    <segment id="67">“Há cinco séculos</segment>
    <segment id="68">, a religião foi usada</segment>
    <segment id="69">comocomo argumento para justificar o sequestro de 12 milhões de pessoas”</segment>
    <segment id="70">, disse.</segment>
    <segment id="71">“</segment>
    <segment id="72">Aquelas pessoas foram obrigadas a caminhar cinco séculos ouvindo que elas não tinham alma.</segment>
    <segment id="73">Que a noite de hoje sirva para nos dizer que pegamos a nossa alma de volta.</segment>
    <segment id="74">”  Não era difícil ver pessoas chorando.</segment>
    <segment id="75">Nos minutos finais das quase duas horas de show o público praticamente não voltou a sentar.</segment>
    <segment id="76">“</segment>
    <segment id="77">Tá bom que nós ia vir no Municipal e não cantar essa”</segment>
    <segment id="78">, Emicida anunciou</segment>
    <segment id="79">, puxando “Gueto”</segment>
    <segment id="80">, faixa que exalta o orgulho negro e faz referência ao funk ostentação.</segment>
    <segment id="81">“</segment>
    <segment id="82">Onde estiver</segment>
    <segment id="83">, onde pisar</segment>
    <segment id="84">, nós sempre vai ser gueto”</segment>
    <segment id="85">, ele cantou.</segment>
    <segment id="86">Ainda houve tempo para “Libre”</segment>
    <segment id="87">, “</segment>
    <segment id="88">A Chapa</segment>
    <segment id="89">É Quente”</segment>
    <segment id="90">, “Passarinhos” e “Ubuntu”</segment>
    <segment id="91">, encerrando uma apresentação histórica não só para Emicida</segment>
    <segment id="92">, masmas para seus fãs.</segment>
    <segment id="93">“Tento ser um cara elegante</segment>
    <segment id="94">, olha onde eu trago vocês”</segment>
    <segment id="95">, brincou o rapper</segment>
    <segment id="96">, em êxtase no fim.</segment>
    <segment id="97">“Já pensou nossos filhos vendo as fotos desse dia aqui?</segment>
    <segment id="98">”</segment>
  </rst>
</analysis>