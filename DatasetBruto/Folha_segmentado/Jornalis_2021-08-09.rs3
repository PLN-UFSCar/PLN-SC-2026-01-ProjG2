  <rst>
    <segment id="1">O jornalista e escritor Leandro Narloch</segment>
    <segment id="2">, 43, voltará a ser colunista da Folha.</segment>
    <segment id="3">Ele passa a assinar um texto semanal</segment>
    <segment id="4">, todas as quartas-feiras</segment>
    <segment id="5">, que serão publicados no site</segment>
    <segment id="6">, na editoria de Poder.</segment>
    <segment id="7">Sua estreia será nesta quarta-feira (11).</segment>
    <segment id="8">Narloch é mestre em filosofia pela Universidade de Londres e autor do livro "Guia Politicamente Incorreto da História do Brasil".</segment>
    <segment id="9">Em suas colunas</segment>
    <segment id="10">, o jornalista diz que irá abordar temas contemporâneos</segment>
    <segment id="11">comocomo o "desafio intelectual de mexer em tabus do século 21".</segment>
    <segment id="12">Narloch afirma também que pretende falar sobre as "verdades que ativistas</segment>
    <segment id="13">sese recusam a enxergar e mostrar</segment>
    <segment id="14">comocomo a sinalização de virtude muitas vezes resulta em tiros no pé".</segment>
    <segment id="15">Com atuação em diversos veículos da imprensa brasileira</segment>
    <segment id="16">, ele já foi colunista da Folha anteriormente —deixou de escrever para o jornal em dezembro de 2018.</segment>
    <segment id="17">"</segment>
    <segment id="18">O que eu mais gosto de fazer na vida é discutir ideias</segment>
    <segment id="19">, principalmente aquelas com algum toque de heresia"</segment>
    <segment id="20">, afirma o jornalista.</segment>
    <segment id="21">Segundo Narloch</segment>
    <segment id="22">, "nunca foi tão interessante fazer isso.</segment>
    <segment id="23">Vivemos um puritanismo identitário</segment>
    <segment id="24">, um tempo de exibicionismo moral</segment>
    <segment id="25">, com muita gente tentando parecer melhor do que realmente é".</segment>
    <segment id="26">O jornalista e colunista Leandro Narloch  - Arquivo Pessoal</segment>
  </rst>
</analysis>