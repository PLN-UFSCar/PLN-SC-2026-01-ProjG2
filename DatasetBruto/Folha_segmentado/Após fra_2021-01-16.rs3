  <rst>
    <segment id="1">O Minist&amp;eacute</segment>
    <segment id="2">;rio da Sa&amp;uacute</segment>
    <segment id="3">;de informou que uma aeronave da Azul levar&amp;aacute</segment>
    <segment id="4">; cilindros de oxig&amp;ecirc</segment>
    <segment id="5">;nio para Manaus (AM) neste s&amp;aacute</segment>
    <segment id="6">;bado (16).</segment>
    <segment id="7">O avi&amp;atilde</segment>
    <segment id="8">;o &amp;eacute</segment>
    <segment id="9">;</segment>
    <segment id="10">o mesmo que viajaria &amp;agrave</segment>
    <segment id="11">; &amp;Iacute</segment>
    <segment id="12">;ndia nesta semana para buscar vacinas contra o coronav&amp;iacute</segment>
    <segment id="13">;rus, mas</segment>
    <segment id="14">mas teve a partida adiada ap&amp;oacute</segment>
    <segment id="15">;s fracasso nas negocia&amp;ccedil</segment>
    <segment id="16">;&amp;otilde</segment>
    <segment id="17">;es entre os governos brasileiro e indiano.</segment>
    <segment id="18">De acordo com a pasta</segment>
    <segment id="19">, a aeronave partir&amp;aacute</segment>
    <segment id="20">; de Campinas (SP) para Manaus neste s&amp;aacute</segment>
    <segment id="21">;bado.</segment>
    <segment id="22">A companhia a&amp;eacute</segment>
    <segment id="23">;rea informou que o voo tem previs&amp;atilde</segment>
    <segment id="24">;o de pouso na capital do Amazonas &amp;agrave</segment>
    <segment id="25">;s 17h50.</segment>
    <segment id="26">Segundo o governo</segment>
    <segment id="27">, o pedido foi feito pelo Minist&amp;eacute</segment>
    <segment id="28">;rio da Sa&amp;uacute</segment>
    <segment id="29">;de com objetivo de abastecer as unidades de sa&amp;uacute</segment>
    <segment id="30">;de da regi&amp;atilde</segment>
    <segment id="31">;o.</segment>
    <segment id="32">A capital do Amazonas sofreu um colapso no sistema hospitalar nesta semana por falta de oxig&amp;ecirc</segment>
    <segment id="33">;nio.  &amp;ldquo</segment>
    <segment id="34">;O voo ser&amp;aacute</segment>
    <segment id="35">; realizado pela mesma aeronave que partiria hoje para Mumbai</segment>
    <segment id="36">, na &amp;Iacute</segment>
    <segment id="37">;ndia, uma vez que a miss&amp;atilde</segment>
    <segment id="38">;o foi reprogramada devido quest&amp;otilde</segment>
    <segment id="39">;es diplom&amp;aacute</segment>
    <segment id="40">;ticas entre Brasil e &amp;Iacute</segment>
    <segment id="41">;ndia e dever&amp;aacute</segment>
    <segment id="42">; ocorrer nos pr&amp;oacute</segment>
    <segment id="43">;ximos dias&amp;rdquo</segment>
    <segment id="44">;, informou a pasta.  Aeronave da Azul irá de Campinas a Manaus neste sábado (16) com carregamento dos cilindros - Tony Winston/MSInicialmente</segment>
    <segment id="45">, o voo da Azul partiria para a &amp;Iacute</segment>
    <segment id="46">;ndia na quinta-feira (14) e a partida chegou a ser adiada para esta sexta.</segment>
    <segment id="47">No entanto</segment>
    <segment id="48">, dificuldades na libera&amp;ccedil</segment>
    <segment id="49">;&amp;atilde</segment>
    <segment id="50">;o das vacinas provocaram novo adiamento e ainda n&amp;atilde</segment>
    <segment id="51">;o h&amp;aacute</segment>
    <segment id="52">; previs&amp;atilde</segment>
    <segment id="53">;o de nova data para a opera&amp;ccedil</segment>
    <segment id="54">;&amp;atilde</segment>
    <segment id="55">;o.</segment>
    <segment id="56">Nesta sexta</segment>
    <segment id="57">, o governo da &amp;Iacute</segment>
    <segment id="58">;ndia negou a entrega imediata de um lote de imunizantes contra a Covid-19 da Oxford/AstraZeneca ao Brasil</segment>
    <segment id="59">, o que frustrou uma opera&amp;ccedil</segment>
    <segment id="60">;&amp;atilde</segment>
    <segment id="61">;o montada para buscar o material no pa&amp;iacute</segment>
    <segment id="62">;s asi&amp;aacute</segment>
    <segment id="63">;tico ainda neste fim de semana e deve resultar numa derrota pol&amp;iacute</segment>
    <segment id="64">;tica para o Pal&amp;aacute</segment>
    <segment id="65">;cio do Planalto.</segment>
    <segment id="66">Com o veto da &amp;Iacute</segment>
    <segment id="67">;ndia, o presidente Jair Bolsonaro (sem partido) corre o risco de assistir o in&amp;iacute</segment>
    <segment id="68">;cio da vacina&amp;ccedil</segment>
    <segment id="69">;&amp;atilde</segment>
    <segment id="70">;o no Brasil com a Coronavac</segment>
    <segment id="71">, que tem sido utilizada</segment>
    <segment id="72">comocomo trunfo do governador de S&amp;atilde</segment>
    <segment id="73">;o Paulo</segment>
    <segment id="74">, Jo&amp;atilde</segment>
    <segment id="75">;o Doria (PSDB).</segment>
    <segment id="76">Na noite de quinta</segment>
    <segment id="77">, o ministro das Rela&amp;ccedil</segment>
    <segment id="78">;&amp;otilde</segment>
    <segment id="79">;es Exteriores</segment>
    <segment id="80">, Ernesto Ara&amp;uacute</segment>
    <segment id="81">;jo, ligou para o chanceler da &amp;Iacute</segment>
    <segment id="82">;ndia, Subrahmanyam Jaishankar</segment>
    <segment id="83">, e fez um &amp;uacute</segment>
    <segment id="84">;ltimo apelo pela libera&amp;ccedil</segment>
    <segment id="85">;&amp;atilde</segment>
    <segment id="86">;o de 2 milh&amp;otilde</segment>
    <segment id="87">;es de vacinas produzidas pelo Serum Institute.</segment>
    <segment id="88">O lote seria um adiantamento do imunizante que posteriormente ser&amp;aacute</segment>
    <segment id="89">; produzido pela Fiocruz (Funda&amp;ccedil</segment>
    <segment id="90">;&amp;atilde</segment>
    <segment id="91">;o Oswaldo Cruz) e que &amp;eacute</segment>
    <segment id="92">;</segment>
    <segment id="93">a grande aposta do governo Bolsonaro na &amp;quot</segment>
    <segment id="94">;guerra da vacina&amp;quot</segment>
    <segment id="95">; travada com Doria.</segment>
    <segment id="96">No entanto</segment>
    <segment id="97">, Ara&amp;uacute</segment>
    <segment id="98">;jo ouviu que a situa&amp;ccedil</segment>
    <segment id="99">;&amp;atilde</segment>
    <segment id="100">;o s&amp;oacute</segment>
    <segment id="101">; seria resolvida &amp;quot</segment>
    <segment id="102">;nos pr&amp;oacute</segment>
    <segment id="103">;ximos dias&amp;quot</segment>
    <segment id="104">;, o que foi entendido no Itamaraty</segment>
    <segment id="105">comocomo uma sinaliza&amp;ccedil</segment>
    <segment id="106">;&amp;atilde</segment>
    <segment id="107">;o de que n&amp;atilde</segment>
    <segment id="108">;o haver&amp;aacute</segment>
    <segment id="109">; libera&amp;ccedil</segment>
    <segment id="110">;&amp;atilde</segment>
    <segment id="111">;o no prazo desejado pelo Brasil.</segment>
    <segment id="112">N&amp;atilde</segment>
    <segment id="113">;o houve compromisso com uma data espec&amp;iacute</segment>
    <segment id="114">;fica.  Drama em ManausMais    novamente         de   de  de  representando um  Tamb&amp;eacute</segment>
    <segment id="115">;m na manh&amp;atilde</segment>
    <segment id="116">; deste s&amp;aacute</segment>
    <segment id="117">;bado (16)</segment>
    <segment id="118">, o governo federal informou que 23 pessoas que estavam internadas em Manaus foram levadas para S&amp;atilde</segment>
    <segment id="119">;o Lu&amp;iacute</segment>
    <segment id="120">;s (MA) em dois voos.</segment>
    <segment id="121">Os primeiros 12 pacientes foram transportados em um avi&amp;atilde</segment>
    <segment id="122">;o da FAB (For&amp;ccedil</segment>
    <segment id="123">;a A&amp;eacute</segment>
    <segment id="124">;rea Brasileira) que deixou a capital do Amazonas na noite de sexta-feira</segment>
    <segment id="125">, chegando a S&amp;atilde</segment>
    <segment id="126">;o Lu&amp;iacute</segment>
    <segment id="127">;s durante a madrugada.</segment>
    <segment id="128">O Minist&amp;eacute</segment>
    <segment id="129">;rio da sa&amp;uacute</segment>
    <segment id="130">;de informou que um segundo avi&amp;atilde</segment>
    <segment id="131">;o decolou &amp;agrave</segment>
    <segment id="132">; tarde com destino &amp;agrave</segment>
    <segment id="133">; capital maranhense</segment>
    <segment id="134">, com 11 pessoas.</segment>
    <segment id="135">A previs&amp;atilde</segment>
    <segment id="136">;o &amp;eacute</segment>
    <segment id="137">; que cheguem at&amp;eacute</segment>
    <segment id="138">;</segment>
    <segment id="139">o fim da tarde.</segment>
    <segment id="140">A pasta tamb&amp;eacute</segment>
    <segment id="141">;m acrescenta que foram disponibilizados 149 leitos para desafogar os hospitais de Manaus.</segment>
    <segment id="142">Al&amp;eacute</segment>
    <segment id="143">;m dos pacientes</segment>
    <segment id="144">, o Minist&amp;eacute</segment>
    <segment id="145">;rio da Defesa informou que foram levados</segment>
    <segment id="146">, durante a madrugada</segment>
    <segment id="147">, mais cinco reservat&amp;oacute</segment>
    <segment id="148">;rios de oxig&amp;ecirc</segment>
    <segment id="149">;nio l&amp;iacute</segment>
    <segment id="150">;quido</segment>
    <segment id="151">, que sa&amp;iacute</segment>
    <segment id="152">;ram de Guarulhos (SP) para Manaus.</segment>
    <segment id="153">O sistema de sa&amp;uacute</segment>
    <segment id="154">;de do Amazonas entrou em colapso pela segunda vez &amp;mdash</segment>
    <segment id="155">;a primeira havia sido em maio.</segment>
    <segment id="156">O aumento do n&amp;uacute</segment>
    <segment id="157">;mero de pacientes com Covid-19 na capital resultou em um cen&amp;aacute</segment>
    <segment id="158">;rio de superlota&amp;ccedil</segment>
    <segment id="159">;&amp;atilde</segment>
    <segment id="160">;o, falta de leitos e macas nos corredores para atender os pacientes.</segment>
    <segment id="161">Nos &amp;uacute</segment>
    <segment id="162">;ltimos dias</segment>
    <segment id="163">, pacientes morreram por asfixia por falta de cilindros de oxig&amp;ecirc</segment>
    <segment id="164">;nio.</segment>
    <segment id="165">Avião que iria buscar vacinas de Oxford na Índia voltou neste sábado (16) para Campinas</segment>
    <segment id="166">, interior de São Paulo - Denny Cesare/Código 19/Agência O Globo</segment>
  </rst>
</analysis>