  <rst>
    <segment id="1">O cantor Thiaguinho lançará na próxima sexta (6) uma nova música: "</segment>
    <segment id="2">Delirante".</segment>
    <segment id="3">A faixa celebra o retorno do "Tardezinha"</segment>
    <segment id="4">, projeto musical que ele voltará a realizar pelo Brasil a partir de abril</segment>
    <segment id="5">, mais de três anos após o seu encerramento no Maracanã.</segment>
    <segment id="6">O cantor Thiaguinho lança o single &amp;#</segment>
    <segment id="7">039;Delirante&amp;#039</segment>
    <segment id="8">; - BS Fotografias/Divulgação"'Delirante' é uma música para cima</segment>
    <segment id="9">, para dançar com os amigos e cantar bem alto.</segment>
    <segment id="10">É tudo que espero também do retorno do 'Tardezinha'"</segment>
    <segment id="11">, diz o músico.</segment>
    <segment id="12">Também na sexta será lançado um videoclipe da canção.</segment>
    <segment id="13">Mônica BergamoReceba no seu email as informações exclusivas da coluna</segment>
    <segment id="14">Mônica BergamoCarregando...</segment>
    <segment id="15">Thiaguinho no Maracanã com o &amp;#039</segment>
    <segment id="16">;Tardezinha&amp;#039</segment>
    <segment id="17">;Mais    novamente         de   de  de  representando um  com BIANKA VIEIRA</segment>
    <segment id="18">, KARINA MATIAS e MANOELLA SMITH</segment>
  </rst>
