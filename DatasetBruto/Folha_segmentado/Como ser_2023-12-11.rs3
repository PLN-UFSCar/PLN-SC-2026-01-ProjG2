  <rst>
    <segment id="1">O novo prédio do Masp</segment>
    <segment id="2">, o Museu de Arte de São Paulo Assis Chateaubriand</segment>
    <segment id="3">, deve ser aberto ao público no segundo semestre do ano que vem.</segment>
    <segment id="4">Batizado de Pietro Maria Bardi</segment>
    <segment id="5">, o edifício ficará ao lado direito da construção atual do museu</segment>
    <segment id="6">, que terá uma interligação por um túnel subterrâneo na avenida Paulista.</segment>
    <segment id="7">Presidente do Masp</segment>
    <segment id="8">, Heitor Martins diz que o edifício criado por Lina Bo Bardi ficou pequeno.</segment>
    <segment id="9">"</segment>
    <segment id="10">Hoje, São Paulo é uma cidade de 20 milhões de habitantes</segment>
    <segment id="11">, e o Masp tem um acervo de mais de 11 mil obras.</segment>
    <segment id="12">É o principal ponto turístico da cidade.</segment>
    <segment id="13">"  "</segment>
    <segment id="14">O edifício atual</segment>
    <segment id="15">, inaugurado em 1968</segment>
    <segment id="16">, é uma obra-prima arquitetônica</segment>
    <segment id="17">, masmas é um prédio que já tem 55 anos</segment>
    <segment id="18">, construído numa São Paulo diferente</segment>
    <segment id="19">, quando você tinha outros critérios museológicos"</segment>
    <segment id="20">, acrescenta Martins.</segment>
    <segment id="21">Projeção da expansão do Masp</segment>
    <segment id="22">, com o novo edifício Pietro Maria Bardi à direita - Metro Arquitetos/DivulgaçãoCom a inauguração do edifício Pietro Maria Bardi</segment>
    <segment id="23">, é calculado que a área expositiva aumente em 66%.</segment>
    <segment id="24">Serão 14 andares</segment>
    <segment id="25">, ocupados por cinco galerias expositivas e dois espaços multiúso.</segment>
    <segment id="26">Dessa forma</segment>
    <segment id="27">, o Masp passará a ter uma área de 17</segment>
    <segment id="28">,6 mil metros quadrados</segment>
    <segment id="29">, comparada aos 10</segment>
    <segment id="30">,4 mil atuais.</segment>
    <segment id="31">Hoje, pouco mais de 1% do acervo fixo do museu é exposto</segment>
    <segment id="32">, devido às limitações físicas do espaço.</segment>
    <segment id="33">O Masp também realiza exposições com intercâmbio internacional de obras</segment>
    <segment id="34">, como</segment>
    <segment id="35">como a mostra recente dedicada a Paul Gauguin e a que está em cartaz no momento</segment>
    <segment id="36">, "Histórias Indígenas".</segment>
    <segment id="37">Veja a projeção da expansão do Masp</segment>
    <segment id="38">, que incluirá o edifício Pietro Maria Bardi em sua estruturaMais    novamente         de   de  de  representando um  O que muda no Masp</segment>
    <segment id="39">A projeção</segment>
    <segment id="40">, segundo Adriano Pedrosa</segment>
    <segment id="41">, diretor artístico do Masp</segment>
    <segment id="42">, é que a entrada principal do museu seja feita por meio do novo prédio.</segment>
    <segment id="43">Desta forma</segment>
    <segment id="44">, o subsolo e o segundo andar do edifício atual devem</segment>
    <segment id="45">sese tornar exclusivos para exposições de longa duração</segment>
    <segment id="46">, com obras que pertencem à coleção do museu.</segment>
    <segment id="47">Já as galerias do novo prédio</segment>
    <segment id="48">, com pé-direito mais alto e um sistema de climatização e iluminação mais avançado</segment>
    <segment id="49">, serão dedicadas às exposições temporárias.</segment>
    <segment id="50">Outra novidade é que a escola do Masp</segment>
    <segment id="51">, hoje sem espaço fixo</segment>
    <segment id="52">, terá um andar inteiro.</segment>
    <segment id="53">O ateliê de restauro e conservação do museu também ganhará um andar do novo prédio</segment>
    <segment id="54">, já que hoje</segment>
    <segment id="55">, apesar de bem equipado</segment>
    <segment id="56">, opera com espaço limitado.</segment>
    <segment id="57">O edifício Pietro Maria Bardi é o antigo prédio Dumont-Adams</segment>
    <segment id="58">, construído na década de 1950 para uso residencial e que vem passando por reformas desde 2019 para</segment>
    <segment id="59">sese tornar parte do Masp.</segment>
    <segment id="60">O projeto arquitetônico</segment>
    <segment id="61">, desenvolvido por Júlio Neves e pelo escritório Metro Arquitetos Associados</segment>
    <segment id="62">, precisou de mudanças em sua estrutura original para adequação ao uso museológico.</segment>
    <segment id="63">A estrutura de concreto da parte superior do edifício foi demolida</segment>
    <segment id="64">, assim</segment>
    <segment id="65">comocomo as lajes intermediárias</segment>
    <segment id="66">, mirando a construção de pavimentos de dimensões regulares e pé-direito de seis metros.</segment>
    <segment id="67">Os pilares estruturais também foram removidos</segment>
    <segment id="68">, para criar pisos amplos e livres de interferências.</segment>
    <segment id="69">O novo prédio terá docas para o estacionamento dos caminhões de transporte de obras</segment>
    <segment id="70">, facilitando a montagem de exposições.</segment>
    <segment id="71">Em diálogo com o vão projetado por Lina Bo Bardi</segment>
    <segment id="72">, o edifício terá o piso térreo transparente</segment>
    <segment id="73">, e seus andares superiores serão revestidos por painéis metálicos perfurados —o que</segment>
    <segment id="74">, visto de fora</segment>
    <segment id="75">, fará parecer que o prédio é um bloco só</segment>
    <segment id="76">, sem emendas.</segment>
    <segment id="77">História do MaspMais    novamente         de   de  de  representando um</segment>
    <segment id="78">A reforma é integralmente financiada por doações privadas</segment>
    <segment id="79">, sem o uso de leis de incentivo à cultura</segment>
    <segment id="80">comocomo a Rouanet.</segment>
    <segment id="81">"</segment>
    <segment id="82">Isso remonta ao museu criado por Assis Chateaubriand</segment>
    <segment id="83">, um empreendedor</segment>
    <segment id="84">, com a participação ativa da sociedade civil"</segment>
    <segment id="85">, diz Martins.</segment>
    <segment id="86">Se hoje o Masp recebe de 500 mil a 700 mil visitantes por ano</segment>
    <segment id="87">, a direção espera que o público chegue a 2 milhões de pessoas com o anexo</segment>
    <segment id="88">, equiparando o museu paulistano aos de cidades</segment>
    <segment id="89">comocomo Paris</segment>
    <segment id="90">, Londres e Nova York</segment>
    <segment id="91">, segundo Heitor Martins.</segment>
    <segment id="92">O vaivém do anexo  2005 Masp compra</segment>
    <segment id="93">, com R$ 12 milhões da Vivo</segment>
    <segment id="94">, o prédio Dumont-Adams.</segment>
    <segment id="95">Intenção do presidente do museu era instalar serviços que trouxessem receita</segment>
    <segment id="96">, como</segment>
    <segment id="97">como um mirante em uma torre de 110 metros de altura.  out.2005 O Conpresp</segment>
    <segment id="98">, órgão municipal de preservação do patrimônio histórico</segment>
    <segment id="99">, veta a torre</segment>
    <segment id="100">, dizendo que interferiria no Masp</segment>
    <segment id="101">, que é tombado.</segment>
    <segment id="102">O museu tentou anular a decisão na Justiça</segment>
    <segment id="103">, masmas perdeu.</segment>
    <segment id="104">2007 Masp desiste da torre e decide instalar uma escola no prédio.</segment>
    <segment id="105">Novas dimensões do projeto</segment>
    <segment id="106">, com 70 metros de altura</segment>
    <segment id="107">, foram aceitas pelo Conpresp</segment>
    <segment id="108">, masmas o projeto não anda.  2010</segment>
    <segment id="109">Nova gestão faz acordo com a Vivo</segment>
    <segment id="110">, que requeria parte do prédio em troca do que havia pago</segment>
    <segment id="111">, dando à operadora galeria no anexo</segment>
    <segment id="112">, masmas projeto não avança.</segment>
    <segment id="113">2014 Atual gestão assume.</segment>
    <segment id="114">Após sanar contas do museu e resolver pendências judiciais quanto ao prédio vizinho</segment>
    <segment id="115">, decide retomar sua ocupação</segment>
    <segment id="116">, mantendo a altura já aceita pelo Conpresp.</segment>
  </rst>
</analysis>