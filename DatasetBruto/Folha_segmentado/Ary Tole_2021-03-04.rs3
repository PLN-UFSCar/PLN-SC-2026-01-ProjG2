  <rst>
    <segment id="1">Aos 83 anos</segment>
    <segment id="2">, Ary Toledo saiu de casa para receber a primeira dose da vacina contra a Covid-19.</segment>
    <segment id="3">“Vacinado</segment>
    <segment id="4">, graças a Deus!</segment>
    <segment id="5">Primeira dose da esperança”</segment>
    <segment id="6">, escreveu em sua página no Instagram.</segment>
    <segment id="7">Antes da pandemia</segment>
    <segment id="8">, o comediante foi internado algumas vezes por causa de problemas nos pulmões.</segment>
    <segment id="9">E também enfrentou quadro depressivo após a morte de sua mulher</segment>
    <segment id="10">, Marly Marley</segment>
    <segment id="11">, em 2014.</segment>
    <segment id="12">QUEM NUNCA?</segment>
    <segment id="13">Ao tomar conhecimento de que havia uma dívida de IPTU a pagar por impostos do seu hotel</segment>
    <segment id="14">, o Jequitimar</segment>
    <segment id="15">, no Guarujá (SP)</segment>
    <segment id="16">, Silvio Santos mandou pagar na hora.</segment>
    <segment id="17">Coisa de R$ 2 milhões.</segment>
    <segment id="18">Os débitos foram quitados na terça-feira (2).</segment>
    <segment id="19">Programa Silvio Santos 2020   novamente         de   de  de  representando um  COROA</segment>
    <segment id="20">A organização do Miss Universo anunciou nesta quarta-feira (3) que o concurso será finalmente realizado em maio</segment>
    <segment id="21">, no dia 16</segment>
    <segment id="22">, na Flórida (EUA).</segment>
    <segment id="23">“Estou muito feliz com a notícia e posso dizer que estou preparada para este momento”</segment>
    <segment id="24">, disse a gaúcha Júlia Gama</segment>
    <segment id="25">, Miss Brasil Universo 2020</segment>
    <segment id="26">, ao site F5.</segment>
    <segment id="27">O anúncio chega quase um ano e três meses depois da última coroação</segment>
    <segment id="28">, em 8 de dezembro de 2019</segment>
    <segment id="29">, quando sul-africana Zozibini Tunzi foi eleita a mulher mais linda do mundo.</segment>
    <segment id="30">Luciana Gimenez recebe Julia Gama</segment>
    <segment id="31">, eleita Miss Brasil - Divulgação/RedeTV!EU NEGO  Acusado por Jonas Alves da Silva de plagiar a música “Vaqueirinha Maltratada”</segment>
    <segment id="32">, Wesley Safadão nega.</segment>
    <segment id="33">O acusador acionou o cantor na Justiça e quer indenização de R$ 4</segment>
    <segment id="34">,7 milhões por danos morais e materiais.</segment>
    <segment id="35">QUE HISTÓRIA</segment>
    <segment id="36">É ESSA?</segment>
    <segment id="37">A pose da vez de Juliana Paes</segment>
    <segment id="38">, assídua frequentadora desta página</segment>
    <segment id="39">, ilustra mais uma marca da qual ela é garota-propaganda.</segment>
    <segment id="40">Expert em faturar mesmo em férias</segment>
    <segment id="41">, a bonitona saiu de casa</segment>
    <segment id="42">, esta semana</segment>
    <segment id="43">, com outro figurino</segment>
    <segment id="44">, claro</segment>
    <segment id="45">, para finalmente gravar o programa</segment>
    <segment id="46">“</segment>
    <segment id="47">Que História é Essa</segment>
    <segment id="48">, Porchat?</segment>
    <segment id="49">”, do canal GNT.</segment>
    <segment id="50">Agora que a atração retomou gravações presenciais</segment>
    <segment id="51">, ela pagou a dívida que tinha com ele: durante o período em que o programa foi feito remotamente</segment>
    <segment id="52">, a atriz havia recusado o convite</segment>
    <segment id="53">porque</segment>
    <segment id="54">porque fazia questão de contar suas histórias pessoalmente.</segment>
    <segment id="55">A nova temporada estreia no dia 16</segment>
    <segment id="56">, às 22h30.</segment>
    <segment id="57">As águas de março no Olá   novamente         de   de  de  representando um  FRASE  "</segment>
    <segment id="58">A comédia é um prazer do cérebro</segment>
    <segment id="59">, da inteligência</segment>
    <segment id="60">, porque</segment>
    <segment id="61">porque a gente morre</segment>
    <segment id="62">, a gente fica doente</segment>
    <segment id="63">, a gente fica velho e não há o que</segment>
    <segment id="64">sese fazer contra isso.</segment>
    <segment id="65">Então, é melhor rir.</segment>
    <segment id="66">A risada é Deus presente"</segment>
    <segment id="67">Marisa Orth a Marcelo Tas no programa #</segment>
    <segment id="68">Provoca</segment>
    <segment id="69">, da TV Cultura</segment>
    <segment id="70">A TV Cultura exibiu nesta terça-feira (2/3) a estreia da temporada 2021 do #Provoca</segment>
    <segment id="71">, apresentado por Marcelo Tas.</segment>
    <segment id="72">Com nova abertura</segment>
    <segment id="73">, vinhetas e visual repaginado</segment>
    <segment id="74">, o programa abre seu terceiro ano com chave de ouro</segment>
    <segment id="75">, entrevistando a atriz Marisa Orth - que aborda assuntos</segment>
    <segment id="76">comocomo assédio</segment>
    <segment id="77">, inseguranças com o corpo</segment>
    <segment id="78">, BBB, poder da psicanálise em sua vida</segment>
    <segment id="79">, entre outros - Nathalie Bohm/Divulgação PÊNALTI  Também modelo</segment>
    <segment id="80">, a árbitra russa</segment>
    <segment id="81">Ekaterina Kostyunina atua nos gramados do futebol local</segment>
    <segment id="82">, masmas chama atenção com fotos sensuais no Instagram.</segment>
    <segment id="83">Recentemente</segment>
    <segment id="84">, ela encantou as torcidas com um ensaio de nudez registrado por Aida Islamova</segment>
    <segment id="85">, em São Petersburgo.</segment>
    <segment id="86">Nas imagens</segment>
    <segment id="87">, ela cobre só as partes íntimas.</segment>
    <segment id="88">Ekaterina Kostyunina</segment>
    <segment id="89">, árbitra de futebol - Ekaterina Kostyunina no InstagramTIETAGEM  Jimmy Fallon na TV americana</segment>
    <segment id="90">, a cantora Rita Ora</segment>
    <segment id="91">, 30 anos</segment>
    <segment id="92">, contou que quando conheceu Madonna</segment>
    <segment id="93">, no início de sua carreira</segment>
    <segment id="94">, a diva pediu que ela</segment>
    <segment id="95">sese ajoelhasse diante dela.</segment>
    <segment id="96">“Foi muito estranho</segment>
    <segment id="97">, masmas também foi muito inacreditável”</segment>
    <segment id="98">, lembra a fã de Madonna.</segment>
  </rst>
</analysis>