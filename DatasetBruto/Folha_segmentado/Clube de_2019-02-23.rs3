  <rst>
    <segment id="1">Enquanto os grupos de WhatsApp ganham mais espaço na política</segment>
    <segment id="2">, no consumo de notícias e no marketing</segment>
    <segment id="3">, o clube de livros por assinatura</segment>
    <segment id="4">Tag Livros é o primeiro a criar uma iniciativa de peso na rede social para a literatura.</segment>
    <segment id="5">Por meio de uma campanha de incentivo à leitura</segment>
    <segment id="6">, a empresa tem agora uma base de números de celular de quem aderiu</segment>
    <segment id="7">, além de e-mails.</segment>
    <segment id="8">Uma das plataformas da campanha</segment>
    <segment id="9">, chamada #Desafio1livropormês</segment>
    <segment id="10">, é o aplicativo de mensagens</segment>
    <segment id="11">, onde já existem 644 grupos ativos administrados pela Tag e quase 100 mil participantes.</segment>
    <segment id="12">O clube de assinaturas</segment>
    <segment id="13">, o principal do país</segment>
    <segment id="14">, compartilha dicas nos grupos</segment>
    <segment id="15">, como</segment>
    <segment id="16">como sugestões de cronogramas de leitura e dicas para ter concentração.</segment>
    <segment id="17">Arthur Dambros</segment>
    <segment id="18">, um dos sócios da empresa</segment>
    <segment id="19">, diz que a Tag poderá usá-los</segment>
    <segment id="20">comocomo canais de divulgação --e não descarta no futuro fazer abordagens individuais a usuários.</segment>
    <segment id="21">"</segment>
    <segment id="22">Há um interesse comercial</segment>
    <segment id="23">, masmas espero que seja um pouco natural</segment>
    <segment id="24">, e [através dos grupos] as pessoas queiram conhecer a Tag"</segment>
    <segment id="25">, diz, acrescentando que</segment>
    <segment id="26">, sese o "mailing" vier a ser usado</segment>
    <segment id="27">, isso será feito sem desvirtuar a intenção original dos grupos.</segment>
    <segment id="28">Ilustração de &amp;#039</segment>
    <segment id="29">;Demência 21&amp;#039</segment>
    <segment id="30">;, mangá de Shintaro Kago</segment>
    <segment id="31">, que a editora Todavia lança em 2020</segment>
    <segment id="32">; a HQ conta a história de uma cuidadora de idosos que</segment>
    <segment id="33">sese mete em situações surreais - DivulgaçãoDIA DO INDIE</segment>
    <segment id="34">Ninguém solta a mão de ninguém.</segment>
    <segment id="35">Diante da crise do setor</segment>
    <segment id="36">, um conjunto de 50 editores independentes resolveu</segment>
    <segment id="37">sese unir em um grupo informal chamado Coesão Independente.</segment>
    <segment id="38">A ideia é trocar experiências e colaborar na produção e divulgação dos livros</segment>
    <segment id="39">, além de organizar feiras.</segment>
    <segment id="40">A primeira delas</segment>
    <segment id="41">, a Choque Literário</segment>
    <segment id="42">, acontece em 6/4.</segment>
    <segment id="43">FLORES E CAPIM</segment>
    <segment id="44">A editora 34 prepara</segment>
    <segment id="45">, para o aniversário de 200 anos de nascimento de Walt Whitman</segment>
    <segment id="46">, uma nova tradução de "Leaves of Grass"</segment>
    <segment id="47">, livro mais famoso do poeta americano.</segment>
    <segment id="48">A tradução será de Guilherme Gontijo Flores</segment>
    <segment id="49">, com o título "Folhas de Capim".</segment>
    <segment id="50">RACISMO</segment>
    <segment id="51">A HarperCollins publicará o novo livro de Colson Whitehead</segment>
    <segment id="52">, "The Nickel Boys".</segment>
    <segment id="53">O autor conta a história de dois rapazes negros em um reformatório</segment>
    <segment id="54">, que existiu na vida real e era conhecido pela violência cometida contra os jovens negros que ali entravam.</segment>
    <segment id="55">Em 2014</segment>
    <segment id="56">, diversos corpos de garotos foram encontrados em uma cova no local.</segment>
    <segment id="57">POESIA</segment>
    <segment id="58">A Moinhos lança "</segment>
    <segment id="59">Orides Fontela - Toda Palavra é Crueldade"</segment>
    <segment id="60">, com depoimentos</segment>
    <segment id="61">, resenhas e entrevistas da poeta.</segment>
    <segment id="62">A Relicário</segment>
    <segment id="63">, ao mesmo tempo</segment>
    <segment id="64">, lança "</segment>
    <segment id="65">O Nervo do Poema"</segment>
    <segment id="66">, antologia de versos em homenagem a Orides</segment>
    <segment id="67">, organizada por Paulo Henriques Britto e Patrícia Lavelle.</segment>
  </rst>
</analysis>