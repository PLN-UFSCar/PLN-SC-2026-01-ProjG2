  <rst>
    <segment id="1">O passado de youtuber rende dividendos a Arthur do Val (Patriota)</segment>
    <segment id="2">, que adotou para si o nome de seu canal</segment>
    <segment id="3">, Mamãe Falei.</segment>
    <segment id="4">O deputado estadual Arthur do Val (Patriota)</segment>
    <segment id="5">, conhecido</segment>
    <segment id="6">comocomo Mamãe Falei</segment>
    <segment id="7">, que é candidato a prefeito de São Paulo -Eduardo Knapp/FolhapressDe acordo com o Datafolha</segment>
    <segment id="8">, ele é conhecido por 27% dos eleitores na faixa entre 16 e 34 anos</segment>
    <segment id="9">, contra 19% do total da população.</segment>
    <segment id="10">Membro do MBL (Movimento Brasil Livre)</segment>
    <segment id="11">, o deputado ganhou projeção com vídeos em que denunciava problemas da cidade e cobrava autoridades em eventos públicos.</segment>
