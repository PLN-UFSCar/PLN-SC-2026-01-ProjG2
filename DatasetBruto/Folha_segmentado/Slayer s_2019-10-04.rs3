  <rst>
    <segment id="1">Um misto ansiedade pairava pelo palco Sunset do Rock in Rio</segment>
    <segment id="2">, à espera do show do Slayer.</segment>
    <segment id="3">A banda de heavy metal</segment>
    <segment id="4">, que está fazendo sua última turnê antes da aposentadoria</segment>
    <segment id="5">, tocou esta semana com casa lotada em São Paulo e nesta sexta (4)</segment>
    <segment id="6">sese despediu do Brasil.</segment>
    <segment id="7">Não demorou duas músicas</segment>
    <segment id="8">para que</segment>
    <segment id="9">para que sinalizadores de luz e fumaça aparecessem no meio do público</segment>
    <segment id="10">, que estava completamente em festa.</segment>
    <segment id="11">Foi um dos shows mais lotados do palco secundário do Rock in Rio nesta edição.</segment>
    <segment id="12">"E aí, porra?</segment>
    <segment id="13">", perguntou o vocalista e baixista Tom Araya</segment>
    <segment id="14">, antes de puxar "</segment>
    <segment id="15">War Ensemble"</segment>
    <segment id="16">, música de 1990.</segment>
    <segment id="17">A plateia</segment>
    <segment id="18">, já em êxtase</segment>
    <segment id="19">, respondeu cantando o nome da banda</segment>
    <segment id="20">, numa prática que</segment>
    <segment id="21">sese repetiu ao fim de cada performance.</segment>
    <segment id="22">Show do Slayer no palco</segment>
    <segment id="23">Sunset do Rock in Rio - Adriano Vizoni/FolhapressO refrão de "Seasons in the Abyss"</segment>
    <segment id="24">, que o público cantou junto</segment>
    <segment id="25">, foi uma evocação à loucura.</segment>
    <segment id="26">Os gritos de "abre a roda!</segment>
    <segment id="27">" só aumentavam</segment>
    <segment id="28">, conforme</segment>
    <segment id="29">sese abriam os espaço para o bate-cabeça.</segment>
    <segment id="30">Com as mãos sempre levantadas e as palmas constantes</segment>
    <segment id="31">, a atmosfera</segment>
    <segment id="32">sese assemelhou a de um jogo de futebol raro</segment>
    <segment id="33">, como</segment>
    <segment id="34">como uma final de campeonato.</segment>
    <segment id="35">Mesmo em um espaço amplo</segment>
    <segment id="36">comocomo o do palco Sunset</segment>
    <segment id="37">, foi difícil ficar perto do palco sem ser empurrado por alguém.</segment>
    <segment id="38">O Slayer teve</segment>
    <segment id="39">, até agora</segment>
    <segment id="40">, o show mais pesado do "dia do metal".</segment>
    <segment id="41">Assim como</segment>
    <segment id="42">como o Sepultura –e também Anthrax</segment>
    <segment id="43">, Megadeth e Metallica</segment>
    <segment id="44">, as duas últimas ausentes deste Rock in Rio–</segment>
    <segment id="45">, a banda americana é uma das grandes da história do thrash metal</segment>
    <segment id="46">, o estilo mais veloz e agressivo do metal.</segment>
    <segment id="47">As músicas rápidas e gritadas parecem ainda mais aceleradas no palco.</segment>
    <segment id="48">A sensação foi das mais recentes</segment>
    <segment id="49">, como</segment>
    <segment id="50">como "Repentless"</segment>
    <segment id="51">, faixa-título do último disco do grupo</segment>
    <segment id="52">, de 2015</segment>
    <segment id="53">, masmas também canções seminais do thrash dos anos 1980</segment>
    <segment id="54">, como</segment>
    <segment id="55">como "</segment>
    <segment id="56">Hell Awaits"</segment>
    <segment id="57">, "South of Heaven" e a clássica "Raining Blood".</segment>
    <segment id="58">A cenografia só amplificou o clima demoníaco</segment>
    <segment id="59">, com caveiras gigantes</segment>
    <segment id="60">, sangue e luzes sempre vermelhas.</segment>
    <segment id="61">O guitarrista Gary Holt tocou com a frase</segment>
    <segment id="62">"kill the Kardashians"</segment>
    <segment id="63">–em referência à famosa família americana de socialites– estampada na camiseta.</segment>
    <segment id="64">Holt é o substituto de Jeff Hanneman</segment>
    <segment id="65">, guitarrista histórico e um dos fundadores do Slayer</segment>
    <segment id="66">, que morreu em 2013.Pode não ter sido o maior e nem o mais épico</segment>
    <segment id="67">, masmas o show do Slayer foi provavelmente o mais eufórico deste Rock in Rio.</segment>
    <segment id="68">Depois de muito suor e cerveja atirada para o alto</segment>
    <segment id="69">, a banda saiu do palco lentamente</segment>
    <segment id="70">, como</segment>
    <segment id="71">como é próprio das despedidas definitivas.</segment>
    <segment id="72">Tom</segment>
    <segment id="73">Araya e seus companheiros</segment>
    <segment id="74">ficaram um tempo no palco</segment>
    <segment id="75">, basicamente olhando calados o público.</segment>
    <segment id="76">Em português</segment>
    <segment id="77">, o vocalista disse: "</segment>
    <segment id="78">Vou sentir saudades.</segment>
    <segment id="79">"</segment>
    <segment id="80">Foi como</segment>
    <segment id="81">como comentou um fã</segment>
    <segment id="82">, já a caminho do Iron Maiden.</segment>
    <segment id="83">"</segment>
    <segment id="84">Depois dessa pancadaria</segment>
    <segment id="85">, ele vem e te quebra o coração.</segment>
    <segment id="86">"  Rock in Rio - 2º fim de semanaMais    novamente         de   de  de  representando</segment>
    <segment id="87">um</segment>
  </rst>
</analysis>