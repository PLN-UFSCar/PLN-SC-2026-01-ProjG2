  <rst>
    <segment id="1">Bastaram três dias de silêncio de Juliette Freire nas redes sociais</segment>
    <segment id="2">para que</segment>
    <segment id="3">para que os fãs já começassem a cobrar notícias da vencedora do “BBB”.</segment>
    <segment id="4">Ela rompeu o silêncio na noite de sexta (27)</segment>
    <segment id="5">, mostrando que está em estúdio</segment>
    <segment id="6">, iniciando as gravações das seis músicas de seu primeiro EP.</segment>
    <segment id="7">VALENDO  Juliette tem boas razões para intensificar nos próximos dois meses os exercícios e a prática para cantar profissionalmente.</segment>
    <segment id="8">Consta que ela encabeça a lista de convidados que Roberto Carlos pretende reunir este ano para a volta de seu especial de Natal na Globo.</segment>
    <segment id="9">No ano passado</segment>
    <segment id="10">, a pandemia nos obrigou a ficar com uma reprise.</segment>
    <segment id="11">Imagens da maquiadora Juliette FreireMais    novamente         de   de  de  representando um  FRASE</segment>
    <segment id="12">É fazendo rir que a gente resiste a tudo nesse país.</segment>
    <segment id="13">Como dizia Millôr [Fernandes]</segment>
    <segment id="14">, o humor só é dado a quem pensa</segment>
    <segment id="15">, a quem raciocina</segment>
    <segment id="16">, porque</segment>
    <segment id="17">porque os chatos não têm nenhum humor    Aracy Balabanian no É de Casa     EXIBIDO</segment>
    <segment id="18">Neymar Jr. levou seguidoras e seguidores do Instagram</segment>
    <segment id="19">, e olhe que eles já são 159 milhões</segment>
    <segment id="20">, à loucura</segment>
    <segment id="21">, ao publicar três fotos em que brinca com a bola</segment>
    <segment id="22">, vestindo apenas cueca.</segment>
    <segment id="23">É claro que as imagens fazem parte de uma nova campanha publicitária protagonizada pelo craque do PSG</segment>
    <segment id="24">, e o suspense em torno da marca faz parte do show.</segment>
    <segment id="25">Neymar Jr. em gravação de campanha - @Neymar no InstagramFIM?</segment>
    <segment id="26">Caio Castro apareceu em foto em seu Instagram ao lado de Rubinho Barrichello</segment>
    <segment id="27">, um orgulho para o ator</segment>
    <segment id="28">, que tem</segment>
    <segment id="29">sese esmerado nas pistas de corrida.</segment>
    <segment id="30">Os dois viram juntos a cenas de Fórmula 1 deste sábado (28).</segment>
    <segment id="31">O problema é que ele aparece na foto sem aliança</segment>
    <segment id="32">, peça que vinha usando desde o início do romance com Grazi Massafera.</segment>
    <segment id="33">BOATOS</segment>
    <segment id="34">Os rumores sobre um fim de namoro entre Grazi e Caio Castro foram reforçados pelo colunista Léo Dias</segment>
    <segment id="35">, que apontou um possível novo romance para o ator.</segment>
    <segment id="36">A última aparição do casal foi no fim de julho</segment>
    <segment id="37">, quando Caio competiu na Copa Porsche.</segment>
    <segment id="38">Imagens do casal</segment>
    <segment id="39">Caio Castro e Grazi MassaferaMais    novamente         de   de  de  representando um  MAQUIAGEM</segment>
    <segment id="40">, SIM,</segment>
    <segment id="41">MAS</segment>
    <segment id="42">SEM FILTRO</segment>
    <segment id="43">Ícone das passarelas dos anos 1980 e 90</segment>
    <segment id="44">, a modelo Paulina Porizkova posou nua</segment>
    <segment id="45">, aos 56 anos</segment>
    <segment id="46">, para a revista Los Angeles Magazine e reproduziu em seu Instagram a história do ensaio.</segment>
    <segment id="47">As fotos foram feitas por Jill Greenberg</segment>
    <segment id="48">, uma mulher</segment>
    <segment id="49">, o que Paulina trata</segment>
    <segment id="50">comocomo vantagem para ficar mais à vontade.</segment>
    <segment id="51">“</segment>
    <segment id="52">Não, eu não ando por aí maravilhosa assim em um dia normal”</segment>
    <segment id="53">, brincou.</segment>
    <segment id="54">“Isso é resultado de duas horas de maquiagem profissional e cabeleireiro.</segment>
    <segment id="55">E maquiagem no corpo.</segment>
    <segment id="56">E excelente luz e fotógrafos talentosos.</segment>
    <segment id="57">Mas o resultado sou eu no meu melhor.</segment>
    <segment id="58">Sem retoque</segment>
    <segment id="59">, filtros e nada mais”</segment>
    <segment id="60">As belas de agosto passam por aquiMais    novamente         de   de  de  representando um  MÁGICA</segment>
    <segment id="61">Barbara Eden</segment>
    <segment id="62">, eterna Jeannie é um Gênio</segment>
    <segment id="63">, acaba de completar 90 anos e revelou sua receita de saúde.</segment>
    <segment id="64">“Sou muito cuidadosa com minha dieta”</segment>
    <segment id="65">, disse a atriz ao site Closer Weekly.</segment>
    <segment id="66">“Sou uma carnívora.</segment>
    <segment id="67">Eu gosto de bife.</segment>
    <segment id="68">Nós comemos muito porco</segment>
    <segment id="69">, frango e legumes”</segment>
    <segment id="70">, admite</segment>
    <segment id="71">, dizendo que aprecia também sobremesas</segment>
    <segment id="72">comocomo marshmallow e balas de goma.  HIT</segment>
    <segment id="73">O seriado “Jeanne é um Gênio” foi produzido entre 1965 e 1970</segment>
    <segment id="74">, masmas ficou no ar por muito mais tempo</segment>
    <segment id="75">, em reprises intermináveis.</segment>
    <segment id="76">Barbara Eden</segment>
    <segment id="77">, de Jeanne é um Gêniio</segment>
    <segment id="78">, louca por doces - M.J.Sheshire/@BarbaraEden no Instagram</segment>
  </rst>
