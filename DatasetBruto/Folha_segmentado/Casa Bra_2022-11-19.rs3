  <rst>
    <segment id="1">A Casa Branca foi</segment>
    <segment id="2">, neste sábado (19)</segment>
    <segment id="3">, o cenário do casamento de uma das netas do presidente dos Estados Unidos</segment>
    <segment id="4">, Joe Biden.</segment>
    <segment id="5">A advogada Naomi Biden</segment>
    <segment id="6">, 28, se</segment>
    <segment id="7">se casou com Peter Neal</segment>
    <segment id="8">, 25, recém-formado em direito e funcionário do Centro de Direito da Universidade de Georgetown.</segment>
    <segment id="9">Segundo a agência de notícias Reuters</segment>
    <segment id="10">, 250 pessoas foram convidadas para a cerimônia</segment>
    <segment id="11">, que aconteceu no gramado da residência oficial da Presidência americana.</segment>
    <segment id="12">A imprensa não teve acesso ao evento.</segment>
    <segment id="13">Presidente dos EUA</segment>
    <segment id="14">, Joe Biden</segment>
    <segment id="15">, e a primeira-dama americana</segment>
    <segment id="16">, Jill Biden</segment>
    <segment id="17">, comparecem ao casamento de Peter Neal e Naomi Biden na Casa Branca</segment>
    <segment id="18">, em Washington - Adam Schultz /Casa</segment>
    <segment id="19">Branca"Foi</segment>
    <segment id="20">uma alegria ver Naomi crescer</segment>
    <segment id="21">, descobrir quem ela é e construir uma vida tão incrível para si mesma"</segment>
    <segment id="22">, disseram o presidente e a primeira-dama</segment>
    <segment id="23">, Jill Biden</segment>
    <segment id="24">, em um comunicado conjunto divulgado após a cerimônia.</segment>
    <segment id="25">"</segment>
    <segment id="26">Agora, estamos muito orgulhosos de vê-la escolher Peter</segment>
    <segment id="27">comocomo marido e estamos honrados em recebê-lo em nossa família.</segment>
    <segment id="28">Desejamos a eles dias cheios de risadas e um amor que</segment>
    <segment id="29">sese aprofunda a cada ano que passa"</segment>
    <segment id="30">, acrescentaram.</segment>
    <segment id="31">O atual presidente americano está casado com a primeira-dama há 45 anos.</segment>
    <segment id="32">Naomi Biden é filha de Hunter Biden</segment>
    <segment id="33">, filho do líder americano.</segment>
    <segment id="34">Um almoço para os familiares e a festa de casamento aconteceram no salão de jantar da Casa Branca.</segment>
    <segment id="35">Uma recepção noturna com sobremesa e dança está programada para a noite de sábado.</segment>
    <segment id="36">No domingo</segment>
    <segment id="37">, curiosamente</segment>
    <segment id="38">, Biden completará 80 anos.</segment>
    <segment id="39">Família Biden adota gata</segment>
    <segment id="40">Mais    novamente         de   de  de  representando um</segment>
    <segment id="41">A diretora de comunicações de Jill Biden</segment>
    <segment id="42">, Elizabeth Alexander</segment>
    <segment id="43">, disse que a família pagará pelo casamento</segment>
    <segment id="44">, "assim</segment>
    <segment id="45">comocomo acontece em outros eventos privados organizados pela família e seguindo as tradições das festividades de casamento anteriores na Casa Branca".</segment>
    <segment id="46">O casamento de Naomi e Peter é o 19º a acontecer na residência oficial do presidente dos EUA.</segment>
    <segment id="47">De acordo com a Associação Histórica da Casa Branca</segment>
    <segment id="48">, a tradição começou em 1812</segment>
    <segment id="49">, quando Lucy Payne Washington</segment>
    <segment id="50">, irmã da primeira-dama Dolley Madison</segment>
    <segment id="51">, casou-</segment>
    <segment id="52">sese com o juiz da Suprema Corte Thomas Todd.</segment>
    <segment id="53">Grover Cleveland foi o único presidente americano a</segment>
    <segment id="54">sese casar na Casa Branca</segment>
    <segment id="55">; ele trocou alianças com Frances Folsom em 1886.</segment>
  </rst>
</analysis>