  <rst>
    <segment id="1">O Halloween</segment>
    <segment id="2">, ou Dia das Bruxas</segment>
    <segment id="3">, é uma tradição marcante nos EUA</segment>
    <segment id="4">, masmas tem conquistado um lugar especial no coração de alguns brasileiros.</segment>
    <segment id="5">Neste ano</segment>
    <segment id="6">, uma nova tendência está</segment>
    <segment id="7">sese destacando: a viralização de fantasias engraçadas e a adoção da tradição de "pedir doces" em condomínios.</segment>
    <segment id="8">Uma das razões para a crescente popularidade do Halloween no Brasil é a criatividade que as pessoas têm demonstrado ao escolher suas fantasias.</segment>
    <segment id="9">Em vez de optar pelas tradicionais bruxas e vampiros</segment>
    <segment id="10">, muitos brasileiros estão escolhendo fantasias derivadas de memes na internet e que</segment>
    <segment id="11">, de certa forma</segment>
    <segment id="12">, possam ser compartilhadas.</segment>
    <segment id="13">Apesar disso</segment>
    <segment id="14">, a discussão também</segment>
    <segment id="15">sese estende para aqueles que não acreditam que o Halloween tenha espaço em território nacional e questionam</segment>
    <segment id="16">sese os adeptos ao Dia das Bruxas estão confundindo a festa com o Carnaval.</segment>
    <segment id="17">Posts em defesa ao Dia do Saci</segment>
    <segment id="18">, que também é comemorado em 31 de outubro</segment>
    <segment id="19">, repercutem e geram discussões.</segment>
    <segment id="20">Gostosuras ou travessuras</segment>
    <segment id="21">Outra tendência que tem chamado a atenção é a adaptação da tradição norte-americana de "trick or treat"</segment>
    <segment id="22">(doces ou travessuras).</segment>
    <segment id="23">Em condomínios residenciais</segment>
    <segment id="24">, as crianças têm</segment>
    <segment id="25">sese reunido para pedir doces de porta em porta</segment>
    <segment id="26">, e os moradores têm</segment>
    <segment id="27">sese mostrado entusiasmados.</segment>
    <segment id="28">Alguns</segment>
    <segment id="29">sese esqueceram de programar a distribuição e outros aproveitaram para</segment>
    <segment id="30">sese juntar à brincadeira.</segment>
    <segment id="31">E você</segment>
    <segment id="32">, vai entrar na brincadeira?</segment>
    <segment id="33">Deixe nos comentários!</segment>
  </rst>
</analysis>