  <rst>
    <segment id="1">Se Alceu Valença canta que "a solidão é fera</segment>
    <segment id="2">, a solidão devora"</segment>
    <segment id="3">, como</segment>
    <segment id="4">como descrever esse sentimento quando o solitário é uma criança?</segment>
    <segment id="5">Embora muitos insistam em idealizar a infância</segment>
    <segment id="6">comocomo um período solar e recheado de positividade</segment>
    <segment id="7">, todos sabemos que nem sempre é assim.</segment>
    <segment id="8">E, para tomar emprestado outro clássico da música brasileira</segment>
    <segment id="9">, desta vez de Caetano Veloso</segment>
    <segment id="10">, muitas vezes "a tristeza é senhora" —e</segment>
    <segment id="11">, vez ou outra</segment>
    <segment id="12">, ela surge justamente da solidão.</segment>
    <segment id="13">Ilustração Gabriel Pessoto para o livro &amp;quot</segment>
    <segment id="14">;O Aquário de Pedro&amp;quot</segment>
    <segment id="15">;, de Diego Mauro- DivulgaçãoNessas horas</segment>
    <segment id="16">, uma companhia pode ser a literatura.</segment>
    <segment id="17">Não apenas</segment>
    <segment id="18">comocomo uma relação afetiva de mergulho em diferentes histórias</segment>
    <segment id="19">, masmas também</segment>
    <segment id="20">porque</segment>
    <segment id="21">porque alguns livros infantis e ilustrados falam sobre o tema e jogam luz sobre personagens que não têm companhia.</segment>
    <segment id="22">É claro que a arte não tem essa função didática</segment>
    <segment id="23">, masmas ela pode ajudar a despertar reflexões e a criar provocações no leitor criança.</segment>
    <segment id="24">De maneiras diferentes</segment>
    <segment id="25">, isso é o que fazem os cinco títulos abaixo.</segment>
    <segment id="26">Há os que concordam com Caetano e dialogam com a tristeza.</segment>
    <segment id="27">Outros preferem a saída da imaginação e dos sonhos.</segment>
    <segment id="28">Tem ainda os que usam brincadeiras para falar da solidão</segment>
    <segment id="29">, que nem sempre é uma coisa ruim.</segment>
    <segment id="30">Conheça as obras abaixo.  5 livros infantis para falar de solidão Mais    novamente         de   de  de  representando um     Domingo</segment>
    <segment id="31">Recém-lançado</segment>
    <segment id="32">,</segment>
    <segment id="33">este livro é uma das boas surpresas recentes.</segment>
    <segment id="34">O autor</segment>
    <segment id="35">, Marcelo Tolentino</segment>
    <segment id="36">, parte de suas memórias de infância para narrar uma história com texto curto</segment>
    <segment id="37">, masmas com imagens que levam tempo no olhar.</segment>
    <segment id="38">Nela, o menino-personagem visita a casa dos avós num domingo ao lado dos pais.</segment>
    <segment id="39">A solidão não surge escancarada</segment>
    <segment id="40">, masmas mora nos detalhes.</segment>
    <segment id="41">Única criança da casa</segment>
    <segment id="42">, ele decide brincar de dar a volta ao mundo</segment>
    <segment id="43">, masmas não encontra companheiros.</segment>
    <segment id="44">O avô está assistindo à televisão</segment>
    <segment id="45">, os pais estão cozinhando e a avó cuida das roupas.</segment>
    <segment id="46">Então, parte sozinho —ou quase</segment>
    <segment id="47">, já que leva o cachorro Fubá.</segment>
    <segment id="48">É aí que aparecem o fantástico e a imaginação.</segment>
    <segment id="49">Filtros de barro</segment>
    <segment id="50">sese tornam castelos</segment>
    <segment id="51">, bolos viram imensos vulcões</segment>
    <segment id="52">, rostos ganham a sinuosidade de dunas e camisetas tremulam</segment>
    <segment id="53">comocomo velas de um barco pirata.</segment>
    <segment id="54">DomingoPreço R$ 59</segment>
    <segment id="55">,90 (56 págs.)Autoria Marcelo TolentinoEditora Companhia das LetrinhasIlustração do livro &amp;quot</segment>
    <segment id="56">;Domingo&amp;quot</segment>
    <segment id="57">;, de Marcelo Tolentino - Divulgação</segment>
    <segment id="58">O Aquário de Pedro Pedro passa horas sozinho em seu quarto.</segment>
    <segment id="59">Deita sobre o tapete</segment>
    <segment id="60">, desenha em folhas de papel</segment>
    <segment id="61">, mexe no tablet</segment>
    <segment id="62">, brinca no computador</segment>
    <segment id="63">, joga-</segment>
    <segment id="64">sese na cama de ponta-cabeça e</segment>
    <segment id="65">, principalmente</segment>
    <segment id="66">, interage com Dourado</segment>
    <segment id="67">, seu peixe de estimação</segment>
    <segment id="68">, que vive num aquário ali mesmo.</segment>
    <segment id="69">Tudo aparece ilustrado com traços de lápis de cor</segment>
    <segment id="70">, feitos pelo ilustrador Gabriel Pessoto.</segment>
    <segment id="71">A solidão e o tédio fazem com que Pedro transfira seus sentimentos para o peixe</segment>
    <segment id="72">, o que o faz colocar alguns de seus brinquedos dentro do aquário</segment>
    <segment id="73">, para que</segment>
    <segment id="74">para que o bicho não</segment>
    <segment id="75">sese sinta tão sozinho.</segment>
    <segment id="76">Quando percebe que isso não resolve a situação</segment>
    <segment id="77">, decide adquirir outro animal para ser amigo de Dourado.</segment>
    <segment id="78">É assim que o rapaz ganha as ferramentas para sair do próprio aquário onde vive.</segment>
    <segment id="79">O Aquário de PedroPreço R$ 45 (60 págs.)Autoria Diego</segment>
    <segment id="80">Mauro e Gabriel</segment>
    <segment id="81">PessotoEditora</segment>
    <segment id="82">PatuáLeia tambémConheça 5 livros infantis para</segment>
    <segment id="83">sese impressionar com as ilustraçõesTatiana</segment>
    <segment id="84">Belinky achou que fosse trote</segment>
    <segment id="85">, masmas era Monteiro LobatoPrincesa que beija sapo é desconstruída em livro que brinca com o multiverso Balas Mágicas "</segment>
    <segment id="86">Eu brinco sozinho.</segment>
    <segment id="87">Brincar sozinho não é tão ruim".</segment>
    <segment id="88">É desse jeito que começa "</segment>
    <segment id="89">Balas Mágicas"</segment>
    <segment id="90">, primeiro livro da sul-coreana Heena Baek publicado no Brasil.</segment>
    <segment id="91">Nele, um menino</segment>
    <segment id="92">sese isola</segment>
    <segment id="93">porque</segment>
    <segment id="94">porque gosta de bolinhas de gude</segment>
    <segment id="95">, masmas as outras crianças só pensam em jogar bola.</segment>
    <segment id="96">Um dia</segment>
    <segment id="97">, quando vai comprar bolinhas novas</segment>
    <segment id="98">, descobre que elas também são balas.</segment>
    <segment id="99">Ao colocá-las na boca</segment>
    <segment id="100">, um estranho poder surge: o garoto passa a ouvir vozes antes inaudíveis.</segment>
    <segment id="101">O sofá tagarela</segment>
    <segment id="102">, o cachorro desabafa</segment>
    <segment id="103">, o coração rígido do pai</segment>
    <segment id="104">sese confessa e até a avó morta sussurra.</segment>
    <segment id="105">Ao sair do seu isolamento e</segment>
    <segment id="106">sese abrir para outras falas</segment>
    <segment id="107">, ele não apenas abre os ouvidos</segment>
    <segment id="108">, masmas também amplia o seu olhar.</segment>
    <segment id="109">E, de alguma forma</segment>
    <segment id="110">, percebe que "é impossível ser feliz sozinho"</segment>
    <segment id="111">, como</segment>
    <segment id="112">como diria Tom Jobim.</segment>
    <segment id="113">Balas MágicasPreço R$ 64</segment>
    <segment id="114">,90 (48 págs.)Autoria Heena BaekEditora Companhia das LetrinhasTradução Ara CulturalIlustração do livro &amp;quot</segment>
    <segment id="115">;Balas Mágicas&amp;quot</segment>
    <segment id="116">;, da sul-coreana Heena Baek - Divulgação Boa Noite</segment>
    <segment id="117">, Yolanda Depois de uma volta de carro com o pai</segment>
    <segment id="118">, a menina Yolanda do título fica sozinha em seu quarto</segment>
    <segment id="119">, observa a Lua da janela e dá início a uma jornada pelo mundo dos sonhos e do fantástico.</segment>
    <segment id="120">Nós, leitores</segment>
    <segment id="121">, não sabemos muito bem os motivos dessa ausência</segment>
    <segment id="122">, masmas desvendamos aos poucos que a mãe da personagem não vive mais com ela.</segment>
    <segment id="123">É justamente essa mãe que surge inesperadamente na janela e leva Yolanda para um passeio.</segment>
    <segment id="124">Juntas</segment>
    <segment id="125">, de mãos dadas</segment>
    <segment id="126">, as duas desbravam as matas</segment>
    <segment id="127">, ouvem os sons da floresta e dançam perto da Lua.</segment>
    <segment id="128">De forma delicada</segment>
    <segment id="129">, a narrativa é costurada pela saudade e pela certeza de que</segment>
    <segment id="130">, mesmo que certas pessoas não estejam mais aqui</segment>
    <segment id="131">, de alguma forma elas sempre estarão.</segment>
    <segment id="132">Boa Noite</segment>
    <segment id="133">, YolandaPreço R$ 49</segment>
    <segment id="134">,80 (40 págs.)Autoria Stella Elia e Weberson SantiagoEditora Yellowfante Ilustração de Weberson Santiago para &amp;quot</segment>
    <segment id="135">;Boa Noite</segment>
    <segment id="136">, Yolanda&amp;quot</segment>
    <segment id="137">;, de Stella Elia - Divulgação Tanta Chuva no Céu Lançada em 2020</segment>
    <segment id="138">, esta é a obra mais antiga da lista e uma das mais interessantes dos últimos anos para falar de tristeza e solidão.</segment>
    <segment id="139">Na história</segment>
    <segment id="140">, uma menina acorda sozinha</segment>
    <segment id="141">, numa casa vazia</segment>
    <segment id="142">, sem qualquer som —a não ser o dos sentimentos que aos poucos percebemos retumbar dentro dela.</segment>
    <segment id="143">A mãe não está mais lá e já não lê seus livros com os pés apoiados na mesinha.</segment>
    <segment id="144">O pai também está ausente e não pede que ela vista as meias.</segment>
    <segment id="145">Quando um barulho surge lá fora</segment>
    <segment id="146">, não é o do carro dos pais</segment>
    <segment id="147">, pois</segment>
    <segment id="148">pois "esse ela sabia que não ouviria mais".</segment>
    <segment id="149">Numa trama densa</segment>
    <segment id="150">, repleta de chuvas</segment>
    <segment id="151">, choros</segment>
    <segment id="152">, cicatrizes e costuras</segment>
    <segment id="153">, o autor</segment>
    <segment id="154">, Volnei Canônica</segment>
    <segment id="155">, usa um tom poético para falar da dor da perda e dos primeiros passos rumo à reconstrução.</segment>
    <segment id="156">Tanta</segment>
    <segment id="157">Chuva</segment>
    <segment id="158">no CéuPreço R$ 59</segment>
    <segment id="159">,80 (40 págs.)Autoria Volnei Canônica e Roger YcazaEditora Editora do Brasil  EM TEMPO...</segment>
    <segment id="160">As músicas citadas neste texto:  "Solidão"</segment>
    <segment id="161">, de Alceu Valença   "</segment>
    <segment id="162">Desde que o Samba É Samba"</segment>
    <segment id="163">, de Caetano Veloso   "</segment>
    <segment id="164">Wave", de Tom Jobim</segment>
  </rst>
</analysis>