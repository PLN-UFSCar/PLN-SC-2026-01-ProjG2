  <rst>
    <segment id="1">As agências bancárias não irão abrir na próxima segunda-feira (12) por causa do feriado de Nossa Senhora de Aparecida.</segment>
    <segment id="2">Boletos que tiverem o vencimento programado para o dia 12 poderão ser pagos no dia seguinte sem multa.</segment>
    <segment id="3">O Poupatempo vai abrir no sábado (10)</segment>
    <segment id="4">, masmas depois só volta a funcionar na terça-feira.</segment>
    <segment id="5">Na saúde</segment>
    <segment id="6">, os serviços municipais que fazem atendimento de emergência</segment>
    <segment id="7">, como</segment>
    <segment id="8">como hospitais</segment>
    <segment id="9">, prontos-socorros e UPAs (Unidades de Pronto Atendimento) funcionarão normalmente.</segment>
    <segment id="10">Nas rodovias Anchieta e Imigrantes</segment>
    <segment id="11">, é esperado fluxo de até 370 mil veículos rumo à Baixada Santista.</segment>
    <segment id="12">Na Tamoios</segment>
    <segment id="13">, que dá acesso ao litoral norte</segment>
    <segment id="14">, são esperados 162 mil carros.</segment>
    <segment id="15">Mesmo com a quarentena por causa da pandemia do novo coronavírus</segment>
    <segment id="16">, cerca de 275 mil pessoas deverão embarcar e desembarcar pelos terminais rodoviários da capital paulista.</segment>
    <segment id="17">Após feriado</segment>
    <segment id="18">, Santos e Guarujá vivem aumento de casos de Covid   novamente         de   de  de  representando um  Veja</segment>
    <segment id="19">comocomo será o funcionamento dos serviços     Serviço Sábado (10)</segment>
