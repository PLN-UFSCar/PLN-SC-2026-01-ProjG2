  <rst>
    <segment id="1">Dona Hermínia</segment>
    <segment id="2">, personagem do humorista Paulo Gustavo na franquia de sucesso 'Minha Mãe é Uma Peça'</segment>
    <segment id="3">, é uma das mães mais famosas do cinema brasileiro</segment>
    <segment id="4">, masmas não é a única.</segment>
    <segment id="5">A seguir</segment>
    <segment id="6">, conheça ou relembre seis personagens marcantes que</segment>
    <segment id="7">, nos filmes</segment>
    <segment id="8">, lutaram por seus filhos</segment>
    <segment id="9">, enfrentando a fome</segment>
    <segment id="10">, a seca</segment>
    <segment id="11">, as dificuldades da vida</segment>
    <segment id="12">, a ditadura militar e a distância.</segment>
    <segment id="13">Os preços e a disponibilidade nos serviços de streaming foram pesquisados neste sábado (7 de maio).</segment>
    <segment id="14">A atriz Maria Ribeiro</segment>
    <segment id="15">comocomo Sinhá Vitória em cena do filme &amp;#039</segment>
    <segment id="16">;Vidas Secas&amp;#039</segment>
    <segment id="17">; (1963)</segment>
    <segment id="18">, de Nelson Pereira dos Santos - DivulgaçãoSINHÁ VITÓRIA</segment>
    <segment id="19">, EM ‘VIDAS SECAS’ (1963)</segment>
    <segment id="20">Neste clássico de Nelson Pereira dos Santos baseado no livro homônimo de Graciliano Ramos</segment>
    <segment id="21">, a personagem da atriz Maria Ribeiro leva com a família uma vida errante pelo sertão nordestino</segment>
    <segment id="22">, em busca de água.</segment>
    <segment id="23">Nas estradas secas e cheias de poeira</segment>
    <segment id="24">, carrega trouxas e um de seus dois filhos nos braços.</segment>
    <segment id="25">Quando o marido</segment>
    <segment id="26">, Fabiano (Átila Iório)</segment>
    <segment id="27">, encontra trabalho</segment>
    <segment id="28">comocomo vaqueiro em uma roça</segment>
    <segment id="29">, e a vida</segment>
    <segment id="30">sese estabiliza um pouco</segment>
    <segment id="31">, ela se</segment>
    <segment id="32">se dá ao luxo de sonhar com uma cama forrada por couro</segment>
    <segment id="33">, de gente decente</segment>
    <segment id="34">, como</segment>
    <segment id="35">como diz.</segment>
    <segment id="36">Enquanto ele cuida dos bois</segment>
    <segment id="37">, ela se</segment>
    <segment id="38">se ocupa da casa e dos filhos.</segment>
    <segment id="39">Mas a seca logo volta e a família tem de retornar para a estrada.</segment>
    <segment id="40">Sem antes fazer um sacrifício</segment>
    <segment id="41">, que ela sabe ser dolorido para os filhos.</segment>
    <segment id="42">ONDE VER</segment>
    <segment id="43">Telecine</segment>
    <segment id="44">, Globoplay e NOW:</segment>
    <segment id="45">para assinantes</segment>
    <segment id="46">Os atores Fernanda Montenegro e Gianfrancesco Guarnieri em cena do filme &amp;#039</segment>
    <segment id="47">;Eles não Usam Black-Tie&amp;#039</segment>
    <segment id="48">;</segment>
    <segment id="49">(1981) - DivulgaçãoROMANA (FERNANDA MONTENEGRO)</segment>
    <segment id="50">, EM ‘ELES NÃO USAM BLACK TIE’ (1981)</segment>
    <segment id="51">Romana é um dos pilares de uma família de operários no início dos anos 1980 retratada no longa de Leon Hirszman</segment>
    <segment id="52">, vencedor de vários prêmios internacionais.</segment>
    <segment id="53">A personagem de Fernanda Montenegro já suportou anos com o marido</segment>
    <segment id="54">, Otávio (Gianfrancesco Guarnieri)</segment>
    <segment id="55">, na prisão por causa de suas atividades sindicais durante a ditadura.</segment>
    <segment id="56">Agora vê o filho mais velho</segment>
    <segment id="57">, Tião (Carlos Alberto Riccelli)</segment>
    <segment id="58">, entrar em conflito com o pai.</segment>
    <segment id="59">Tião não quer participar de uma greve na fábrica em que ambos trabalham.</segment>
    <segment id="60">Romana tenta aparar as diferenças entre os dois</segment>
    <segment id="61">, masmas a situação recrudesce quando o filho fura a greve e</segment>
    <segment id="62">, sem fazer nada</segment>
    <segment id="63">, vê Otávio ser preso.</segment>
    <segment id="64">Só resta a Romana</segment>
    <segment id="65">, então</segment>
    <segment id="66">, esperar que o filho encontre um novo caminho</segment>
    <segment id="67">, distante da família.</segment>
    <segment id="68">ONDE VER Looke</segment>
    <segment id="69">, Telecine</segment>
    <segment id="70">, Globoplay</segment>
    <segment id="71">, Oi Play e NOW: para assinantes</segment>
    <segment id="72">Itaú Cultural Play: grátis</segment>
    <segment id="73">Os atores Dira Paes e Lima Duarte em cena de &amp;#039</segment>
    <segment id="74">;2 Filhos de Francisco&amp;#039</segment>
    <segment id="75">; (2005) - Divulgação​HELENA (DIRA PAES)</segment>
    <segment id="76">, EM ‘2 FILHOS DE FRANCISCO’ (2005) "</segment>
    <segment id="77">Não sei de nada</segment>
    <segment id="78">, não, Francisco.</segment>
    <segment id="79">Não conheço sonho.</segment>
    <segment id="80">Foi acordada que criei essas crianças.</segment>
    <segment id="81">"</segment>
    <segment id="82">É assim que Helena</segment>
    <segment id="83">, mãe dos cantores Zezé Di Camargo e Luciano</segment>
    <segment id="84">, vivida por Dira Paes no longa</segment>
    <segment id="85">, resume seu papel na vida da família</segment>
    <segment id="86">enquanto Francisco</segment>
    <segment id="87">, pai da dupla</segment>
    <segment id="88">, sonhava com o sucesso dos filhos.</segment>
    <segment id="89">No filme</segment>
    <segment id="90">, o mundo real está estampado no rosto de Dira/Helena: o dia a dia de cuidados com os filhos</segment>
    <segment id="91">, a partida da roça</segment>
    <segment id="92">, a chegada na cidade</segment>
    <segment id="93">, a vida em uma casa precária</segment>
    <segment id="94">, a fome</segment>
    <segment id="95">, a perda de um filho…</segment>
    <segment id="96">Neste filme em que o pai é o personagem central</segment>
    <segment id="97">, a Helena de Dira é a cara de muitas mães do Brasil.</segment>
    <segment id="98">ONDE VER</segment>
    <segment id="99">Globoplay e Oi Play:</segment>
    <segment id="100">para assinantes</segment>
    <segment id="101">Apple TV: R$ 9</segment>
    <segment id="102">,90 (aluguel) e R$ 24</segment>
    <segment id="103">,90 (compra)</segment>
    <segment id="104">Google</segment>
    <segment id="105">Play: R$ 19</segment>
    <segment id="106">,90 (compra)</segment>
    <segment id="107">Os atores Patricia Pillar e Alexandre Borges em cena de &amp;#</segment>
    <segment id="108">039;Zuzu Angel&amp;#039</segment>
    <segment id="109">; (2006) - Divulgação​​ZUZU ANGEL (PATRiCIA PILLAR)</segment>
    <segment id="110">, EM ‘ZUZU ANGEL’ (2006)</segment>
    <segment id="111">A luta da estilista Zuzu Angel pelo reconhecimento da morte e do desaparecimento de seu filho</segment>
    <segment id="112">, Stuart (Daniel de Oliveira)</segment>
    <segment id="113">, em 1971</segment>
    <segment id="114">, nos porões da ditadura</segment>
    <segment id="115">, é o centro desta cinebiografia dirigida por Sérgio Rezende.</segment>
    <segment id="116">Patricia Pillar interpreta a personagem</segment>
    <segment id="117">, que vai de uma certa inocência sobre a situação do país até a consciência dos horrores cometidos no regime militar.</segment>
    <segment id="118">Reconhecida no Brasil e no exterior</segment>
    <segment id="119">, Zuzu buscou a verdade</segment>
    <segment id="120">, recorreu ao governo dos EUA e à Anistia Internacional</segment>
    <segment id="121">, e também</segment>
    <segment id="122">sese tornou vítima da ditadura.</segment>
    <segment id="123">A estilista morreu no Rio</segment>
    <segment id="124">, em 1976.</segment>
    <segment id="125">Anos mais tarde</segment>
    <segment id="126">, a Comissão da Verdade concluiu que acidente que causou sua morte foi provocado por agentes da repressão.</segment>
    <segment id="127">ONDE VER Globoplay: para assinantes</segment>
    <segment id="128">Apple TV: R$ 7</segment>
    <segment id="129">,90 (aluguel) e R$ 19</segment>
    <segment id="130">,90 (compra)</segment>
    <segment id="131">A atriz Sandra Corveloni</segment>
    <segment id="132">comocomo Cleuza</segment>
    <segment id="133">, em &amp;#039</segment>
    <segment id="134">;Linha de Passe&amp;#039</segment>
    <segment id="135">; (2008) - Divulgação​CLEUSA (SANDRA CORVELONI)</segment>
    <segment id="136">, EM ‘LINHA DE PASSE’ (2008)</segment>
    <segment id="137">Neste filme de Walter Salles e Daniela Thomas</segment>
    <segment id="138">, Cleusa é uma mãe da periferia de São Paulo.</segment>
    <segment id="139">Cuida sozinha dos quatro filhos</segment>
    <segment id="140">, cada um de um pai desconhecido</segment>
    <segment id="141">, e sustenta a casa com o trabalho</segment>
    <segment id="142">comocomo empregada doméstica.</segment>
    <segment id="143">Cada filho tenta seguir um rumo na vida.</segment>
    <segment id="144">O mais velho</segment>
    <segment id="145">, Dênis (João Baldasserini)</segment>
    <segment id="146">, trabalha</segment>
    <segment id="147">comocomo motoboy e tem um filho bebê.</segment>
    <segment id="148">Dinho (Geraldo Rodrigues) é frentista de um posto de gasolina e Dario (Vinícius de Oliveira) sonha em ser jogador de futebol</segment>
    <segment id="149">, masmas vê seu tempo</segment>
    <segment id="150">sese esgotar a cada ano que passa.</segment>
    <segment id="151">E o caçula Reginaldo (Kaique Jesus Santos) passa o dia andando de ônibus</segment>
    <segment id="152">, pois</segment>
    <segment id="153">pois crê ser o pai motorista de coletivo.</segment>
    <segment id="154">Grávida novamente</segment>
    <segment id="155">, Cleusa tenta equilibrar todos os sonhos dos filhos e os seus também.</segment>
    <segment id="156">Por sua interpretação</segment>
    <segment id="157">, Sandra Corveloni ganhou o prêmio de melhor atriz no Festival de Cannes de 2008.</segment>
    <segment id="158">ONDE VER Apple TV: R$ 9</segment>
    <segment id="159">,90 (aluguel) e R$ 29</segment>
    <segment id="160">,90 (compra)</segment>
    <segment id="161">Google Play: R$ 6</segment>
    <segment id="162">,90 (aluguel) e R$ 24</segment>
    <segment id="163">,90 (compra)</segment>
    <segment id="164">Claro Video: R$ 6</segment>
    <segment id="165">,90 (aluguel)</segment>
    <segment id="166">Regina Casé interpreta Val em &amp;#</segment>
    <segment id="167">039;Que Horas Ela Volta?&amp;#039</segment>
    <segment id="168">; (2015) - Divulgação​​VAL (REGINA CASÉ)</segment>
    <segment id="169">, EM ‘</segment>
    <segment id="170">QUE HORAS ELA VOLTA?</segment>
    <segment id="171">’ (2015)</segment>
    <segment id="172">A personagem de Regina Casé no longa de Anna Muylaert é a empregada doméstica Val</segment>
    <segment id="173">, uma mãe</segment>
    <segment id="174">comocomo milhões no país _as que deixam seus filhos aos cuidados de outra pessoa para</segment>
    <segment id="175">sese dedicar às crianças dos patrões.</segment>
    <segment id="176">Criada a distância</segment>
    <segment id="177">, a filha de Val</segment>
    <segment id="178">, Jéssica</segment>
    <segment id="179">, vem a São Paulo para prestar vestibular.</segment>
    <segment id="180">Ela fica na casa dos patrões da mãe</segment>
    <segment id="181">, o que torna mais aparente as diferenças sociais entre Val e seus empregadores</segment>
    <segment id="182">, que dizem considerá-la 'da família'.</segment>
    <segment id="183">O longa</segment>
    <segment id="184">, já um clássico do cinema nacional</segment>
    <segment id="185">, arrebatou prêmios em festivais pelo mundo</segment>
    <segment id="186">, entre eles Sundance e Berlim.</segment>
    <segment id="187">ONDE VER Netflix</segment>
    <segment id="188">, Telecine</segment>
    <segment id="189">, Globoplay e NOW: para assinantes</segment>
    <segment id="190">Apple TV: R$ 14</segment>
    <segment id="191">,90 (aluguel) e R$ 19</segment>
    <segment id="192">,90 (compra)</segment>
    <segment id="193">Google</segment>
    <segment id="194">Play: R$ 6</segment>
    <segment id="195">,90 (aluguel) e R$ 19</segment>
    <segment id="196">,90 (compra)</segment>
  </rst>
