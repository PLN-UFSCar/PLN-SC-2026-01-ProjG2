  <rst>
    <segment id="1">Pela primeira vez</segment>
    <segment id="2">, é um documentário o título escolhido pelo Brasil para disputar uma vaga entre os finalistas na categoria de filme estrangeiro no Oscar 2021.</segment>
    <segment id="3">Dirigido por Bárbara Paz</segment>
    <segment id="4">, “Babenco:</segment>
    <segment id="5">Alguém Tem que Ouvir o Coração e Dizer: Parou” tem</segment>
    <segment id="6">comocomo foco o ex-marido da atriz</segment>
    <segment id="7">, o cineasta Hector Babenco</segment>
    <segment id="8">, morto em 2016</segment>
    <segment id="9">, aos 70 anos de idade.</segment>
    <segment id="10">O anúncio foi feito pela Academia Brasileira de Cinema</segment>
    <segment id="11">, nesta quarta-feira (18)</segment>
    <segment id="12">, após reunião do Comitê de Seleção.</segment>
    <segment id="13">O filme derrotou títulos</segment>
    <segment id="14">comocomo “Três irmãs”</segment>
    <segment id="15">, de Sandra Kogut</segment>
    <segment id="16">, também muito elogiado</segment>
    <segment id="17">, e “Marighella”</segment>
    <segment id="18">, de Wagner Moura</segment>
    <segment id="19">, que ainda vai estrear em maio de 2021.</segment>
    <segment id="20">A lista dos finalistas será anunciada em março e a festa do prêmio será em 25 de abril.</segment>
    <segment id="21">O cineasta Hector Babenco fecha os olhos em cena do documentário &amp;#039</segment>
    <segment id="22">;Babenco </segment>
    <segment id="23">Alguém Tem que Ouvir o Coração e Dizer: Parou&amp;#039</segment>
    <segment id="24">;, dirigido por Bárbara Paz - Acervo Pessoal   SAQUE VITORIOSO</segment>
    <segment id="25">Absolvida pelo STJD (Superior Tribunal de Justiça Desportiva)</segment>
    <segment id="26">por ter gritado</segment>
    <segment id="27">“</segment>
    <segment id="28">Fora Bolsonaro” no SporTV</segment>
    <segment id="29">, ao fim da partida que valia o bronze na 1ª etapa da temporada do Circuito Brasileiro de Vôlei de Praia</segment>
    <segment id="30">, Carol Solberg vem agradecendo</segment>
    <segment id="31">, desde segunda-feira (16)</segment>
    <segment id="32">, aos vários amigos que a ajudaram durante o processo que questionava</segment>
    <segment id="33">sese a manifestação havia ou não ocorrido em local inadequado.</segment>
    <segment id="34">A atleta pode enfim entreter seus fãs e seguidores no Instagram com imagens</segment>
    <segment id="35">comocomo esta.</segment>
    <segment id="36">“Temos muita força e precisamos usá-la de forma consciente</segment>
    <segment id="37">, sem deixar de olhar para as injustiças que nosso país sofre"  Salve Novembro no OláMais    novamente         de   de  de  representando um  FRASE  "</segment>
    <segment id="38">Nunca imaginei estar tão feliz aos 93 anos.</segment>
    <segment id="39">Cheguei a temer</segment>
    <segment id="40">comocomo passaria a minha velhice.</segment>
    <segment id="41">Será que terei alguém cuidando por amor?</segment>
    <segment id="42">Será que estarei com saúde?</segment>
    <segment id="43">"</segment>
    <segment id="44">Cid Moreira no Instagram</segment>
    <segment id="45">, comemorando 20 anos de casado com sua Fátima   LUTA</segment>
    <segment id="46">Com três tumores no peritônio</segment>
    <segment id="47">, região do estômago</segment>
    <segment id="48">, Dudu Braga</segment>
    <segment id="49">, 51 anos</segment>
    <segment id="50">, tranquilizou os fãs pelo Instagram</segment>
    <segment id="51">, garantindo que sua recuperação está em bom caminho.</segment>
    <segment id="52">“Pessoal</segment>
    <segment id="53">, está tudo bem.</segment>
    <segment id="54">Fiz a químio ontem</segment>
    <segment id="55">, não sei</segment>
    <segment id="56">sese vocês viram meus stories.</segment>
    <segment id="57">Graças a Deus</segment>
    <segment id="58">, fiz os exames e está tudo maravilha e vamos seguir em frente”</segment>
    <segment id="59">, disse o filho de Roberto Carlos.  Dudu Braga</segment>
    <segment id="60">, filho de Roberto Carlos - @dudubraga no Instagram   ACUSAÇÕES</segment>
    <segment id="61">Terceira mulher de Phil Collins</segment>
    <segment id="62">, que trava com o músico um tumultuado processo de separação (aliás</segment>
    <segment id="63">, o segundo rompimento do casal)</segment>
    <segment id="64">, Orianne Cevey</segment>
    <segment id="65">, levou intimidades do astro ao processo judicial que trata do episódio de partilha de bens e outras pendências.</segment>
    <segment id="66">Disse ela que ele é um “eremita” que passa meses sem escovar os dentes e tomar banho.</segment>
    <segment id="67">Eca.</segment>
    <segment id="68">TRILHA SONORA  Barack Obama fez uma lista de músicas que marcaram sua administração à frente da presidência dos Estados Unidos</segment>
    <segment id="69">, no propósito de celebrar o lançamento de seu livro</segment>
    <segment id="70">, “Uma Terra Prometida”</segment>
    <segment id="71">, sobre seu governo.</segment>
    <segment id="72">“</segment>
    <segment id="73">A música sempre teve um papel importante na minha vida”</segment>
    <segment id="74">, escreveu.</segment>
    <segment id="75">A relação inclui Aretha Frnaklin</segment>
    <segment id="76">, Bruce Springsteen</segment>
    <segment id="77">, Frank Sinatra</segment>
    <segment id="78">, Beyoncé</segment>
    <segment id="79">, Beatles e U2</segment>
    <segment id="80">, entre outros.</segment>
  </rst>
