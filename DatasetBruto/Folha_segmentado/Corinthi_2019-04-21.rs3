  <rst>
    <segment id="1">Maior vencedor do Campeonato Paulista</segment>
    <segment id="2">, o Corinthians ampliou o seu domínio com a conquista deste domingo (21) sobre o São Paulo</segment>
    <segment id="3">, por 2 a 1</segment>
    <segment id="4">, em Itaquera.</segment>
    <segment id="5">O clube chegou a 30 troféus</segment>
    <segment id="6">, três deles nos últimos três anos.</segment>
    <segment id="7">Atrás do time alvinegro estão Palmeiras e Santos</segment>
    <segment id="8">, com 22 títulos cada um.</segment>
    <segment id="9">Final do Campeonato Paulista 2019 - Corinthians x</segment>
    <segment id="10">São PauloMais    novamente         de   de  de  representando um  Derrotada em Itaquera</segment>
    <segment id="11">, a equipe tricolor perdeu a chance de</segment>
    <segment id="12">sese igualar a Palmeiras e Santos na segunda posição.</segment>
