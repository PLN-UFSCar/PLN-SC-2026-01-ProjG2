  <rst>
    <segment id="1">Houve alguns avanços na 28ª</segment>
    <segment id="2">Conferência das Partes da Convenção-Quadro das Nações Unidas sobre Mudança do Clima</segment>
    <segment id="3">, a tão aguardada COP28 em Dubai.</segment>
    <segment id="4">Poucos e significativos</segment>
    <segment id="5">, masmas insuficientes diante das agruras que o aquecimento global já inflige às populações pobres —e muito mais virá pela frente.</segment>
    <segment id="6">O primeiro progresso</segment>
    <segment id="7">sese deu logo no primeiro dia: concretizou-</segment>
    <segment id="8">sese o fundo de perdas e danos</segment>
    <segment id="9">, destinado a auxiliar na recuperação de regiões vulneráveis quando devastadas por elevação do nível do mar</segment>
    <segment id="10">, incêndios florestais</segment>
    <segment id="11">, secas</segment>
    <segment id="12">, enchentes e ondas de calor mortíferas.</segment>
    <segment id="13">Planeta em TranseUma newsletter com o que você precisa saber sobre mudanças climáticasCarregando...</segment>
    <segment id="14">Mas o que são US$ 800 milhões</segment>
    <segment id="15">, soma total de valores prometidos</segment>
    <segment id="16">, quando nações insulares inteiras</segment>
    <segment id="17">comocomo Tuvalu</segment>
    <segment id="18">, Tonga e Kiribati correm o risco de submergir nas águas do Pacífico?</segment>
    <segment id="19">Isso mal dá para socorrer as vítimas de desastres climáticos em apenas um ano</segment>
    <segment id="20">comocomo 2023</segment>
    <segment id="21">, o mais quente em 125 milênios.</segment>
    <segment id="22">Cabe recordar que os países desenvolvidos jamais cumpriram a promessa de destinar US$ 100 bilhões anuais para mitigação do aquecimento e adaptação das nações mais pobres à mudança do clima.</segment>
    <segment id="23">Combustíveis fósseis estiveram no ponto nevrálgico do documento final acordado nos Emirados Árabes Unidos —um petroestado</segment>
    <segment id="24">, cabe assinalar.</segment>
    <segment id="25">Nunca tantos lobistas do petróleo</segment>
    <segment id="26">, 2.456</segment>
    <segment id="27">, compareceram a uma COP</segment>
    <segment id="28">, sinal de que temiam pelo pior</segment>
    <segment id="29">, de sua perspectiva: uma convocação para os 197 países signatários do Acordo de Paris (2015) eliminarem produção e queima dos fósseis.</segment>
    <segment id="30">De certo modo</segment>
    <segment id="31">, venceram.</segment>
    <segment id="32">Não há compromisso real que possa ser legalmente exigido de quem polui a atmosfera com gases do efeito estufa.</segment>
    <segment id="33">O presidente da COP28</segment>
    <segment id="34">, Sultan Ahmed al-Jaber</segment>
    <segment id="35">, na sessão plenária de encerramento do evento nesta quarta (13) em Dubai - Giuseppe Cacace/AFPNuma das versões do documento ainda</segment>
    <segment id="36">sese mencionava eliminação gradual de petróleo</segment>
    <segment id="37">, gás natural e carvão</segment>
    <segment id="38">, masmas só da queima que não fosse compensada por retirada de carbono da atmosfera</segment>
    <segment id="39">, algo muito duvidoso.</segment>
    <segment id="40">Agora, o texto final fala meramente em "transicionar".</segment>
    <segment id="41">Literalmente: "</segment>
    <segment id="42">Transicionar dos combustíveis fósseis nos sistemas de energia</segment>
    <segment id="43">, de maneira justa</segment>
    <segment id="44">, ordenada e equitativa".</segment>
    <segment id="45">O objetivo adotado seria "alcançar o zero líquido até 2050</segment>
    <segment id="46">, de acordo com a ciência".</segment>
    <segment id="47">Leia tambémCOP28 termina com aprovação de transição dos combustíveis fósseisMapa da Folha mede desmatamento da Amazônia a partir do endereço do leitorComo anotou</segment>
    <segment id="48">Leo Hickman</segment>
    <segment id="49">, editor do boletim Carbon Brief</segment>
    <segment id="50">, a carta de Dubai apenas "convida" ("calls on"</segment>
    <segment id="51">, em inglês) os governos a fazer a transição.</segment>
    <segment id="52">É o termo mais fraco em "climatês"</segment>
    <segment id="53">, idioma diluidor formatado em três décadas de negociações sobre mudança climática.</segment>
    <segment id="54">Outro calcanhar de Aquiles está na fantasiosa neutralidade de carbono</segment>
    <segment id="55">, o tal "net zero".</segment>
    <segment id="56">Como o planeta está atrasado no corte das emissões de carbono</segment>
    <segment id="57">, será imprescindível recorrer a emissões negativas</segment>
    <segment id="58">, ou seja</segment>
    <segment id="59">, retirar da atmosfera algum dióxido de carbono.</segment>
    <segment id="60">Ativistas jovens cobram transição energética justa na COP28Mais    novamente         de   de  de  representando um</segment>
    <segment id="61">Com essa pedalada</segment>
    <segment id="62">, quem tem jazidas de fósseis fará de tudo para acelerar a exploração.</segment>
    <segment id="63">Sai barato apostar na perspectiva duvidosa de compensá-las.</segment>
    <segment id="64">Falar em "acelerar a ação nesta década crítica</segment>
    <segment id="65">"</segment>
    <segment id="66">é simples</segment>
    <segment id="67">, complicado é obter consenso em torno de metas escalonadas no tempo para alcançar o objetivo.</segment>
    <segment id="68">No compasso atual</segment>
    <segment id="69">, em que emissões seguem em alta</segment>
    <segment id="70">, o mundo "transiciona"</segment>
    <segment id="71">, mesmo</segment>
    <segment id="72">, a um acréscimo de 2</segment>
    <segment id="73">,5°C a 3°C na temperatura média da atmosfera</segment>
    <segment id="74">, "para longe" do compactuado em Paris há oito anos: 1</segment>
    <segment id="75">,5°C de aquecimento.</segment>
    <segment id="76">Sim, houve avanço em reconhecer</segment>
    <segment id="77">, pela primeira vez no modorrento processo da ONU</segment>
    <segment id="78">, que os combustíveis fósseis são o problema central e que será preciso livrar-</segment>
    <segment id="79">sese deles.</segment>
    <segment id="80">Sim, houve avanço em adotar um fundo para perdas e danos.</segment>
    <segment id="81">Assim, de pouco em pouco</segment>
    <segment id="82">, de onda de calor em onda de calor</segment>
    <segment id="83">, de incêndio em incêndio</segment>
    <segment id="84">, de seca em seca</segment>
    <segment id="85">, até o fim do século estaremos todos fritos.</segment>
  </rst>
</analysis>