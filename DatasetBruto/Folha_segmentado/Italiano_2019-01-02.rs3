  <rst>
    <segment id="1">Luca Tombolini</segment>
    <segment id="2">, 39, precisa de uma câmera analógica</segment>
    <segment id="3">, de um veículo utilitário e de até seis meses no deserto para produzir sua série de paisagens.</segment>
    <segment id="4">Seu projeto começou em 2012</segment>
    <segment id="5">, quando o então fotógrafo comercial</segment>
    <segment id="6">, vivendo em Milão</segment>
    <segment id="7">, sese viu insatisfeito e</segment>
    <segment id="8">sese questionou sobre o que gostaria de fotografar</segment>
    <segment id="9">sese não precisasse de dinheiro e aprovação.</segment>
    <segment id="10">A resposta veio: desertos.</segment>
    <segment id="11">Desde então</segment>
    <segment id="12">, viajou para vários países em busca de cenários sem humanos.</segment>
    <segment id="13">Nos desertos</segment>
    <segment id="14">, ele trabalha sem pressa e usa o veículo</segment>
    <segment id="15">comocomo casa.</segment>
    <segment id="16">"</segment>
    <segment id="17">As melhores imagens que fiz foram aquelas em que tive tempo de me conectar com o lugar"</segment>
    <segment id="18">, diz o italiano</segment>
    <segment id="19">, que só faz até duas fotos por dia.</segment>
    <segment id="20">Ele diz não</segment>
    <segment id="21">sese sentir só.</segment>
    <segment id="22">"É o último grau de liberdade que</segment>
    <segment id="23">sese pode experimentar.</segment>
    <segment id="24">"</segment>
    <segment id="25">Fotógrafo de desertos   novamente         de   de  de  representando um</segment>
  </rst>
