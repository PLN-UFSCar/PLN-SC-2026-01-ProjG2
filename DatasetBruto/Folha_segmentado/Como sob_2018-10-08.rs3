  <rst>
    <segment id="1">Notícias falsas no WhatsApp dão conta de que um meteoro</segment>
    <segment id="2">sese aproxima da Terra.</segment>
    <segment id="3">As pessoas entram em pânico</segment>
    <segment id="4">, abandonam seus empregos e saqueiam os supermercados.</segment>
    <segment id="5">Em pouco tempo falta água</segment>
    <segment id="6">, energia elétrica e a violência explode nas ruas.</segment>
    <segment id="7">Ninguém quer viver um cenário assim</segment>
    <segment id="8">, masmas é bom estar preparado.</segment>
    <segment id="9">“</segment>
    <segment id="10">Em um cenário desses</segment>
    <segment id="11">, nós voltamos ao século 19</segment>
    <segment id="12">, masmas infelizmente sem as técnicas da época”</segment>
    <segment id="13">, diz Giuliano Toniolo</segment>
    <segment id="14">, especialista em sobrevivencialismo da escola Mestre do Mato</segment>
    <segment id="15">, de Belo Horizonte (MG).</segment>
    <segment id="16">Em um cenário pensado para uma semana sem poder sair de casa antes de a ordem ser restaurada</segment>
    <segment id="17">, ele dá dicas de</segment>
    <segment id="18">comocomo</segment>
    <segment id="19">sese manter vivo.</segment>
    <segment id="20">A chave para essa missão é estar preparado.</segment>
    <segment id="21">“</segment>
    <segment id="22">A mentalidade do preparo prévio é fundamental.</segment>
    <segment id="23">Ninguém aprende a nadar quando o barco está afundando</segment>
    <segment id="24">, é preciso investir um pouco de tempo para aprender algumas técnicas básicas de sobrevivência</segment>
    <segment id="25">, antes de precisar delas.</segment>
    <segment id="26">”Como se</segment>
    <segment id="27">se preparar para o fim do mundo - Carolina Daffara  Água</segment>
    <segment id="28">O item mais fundamental para sobreviver.</segment>
    <segment id="29">Estoque água em todos os recipientes disponíveis</segment>
    <segment id="30">, encha a máquina de lavar</segment>
    <segment id="31">, garrafas e baldes.</segment>
    <segment id="32">Ela só deve ser usada para beber e preparar alimentos.</segment>
    <segment id="33">Banhos e higiene íntima devem ser resolvidos com lenços umedecidos.</segment>
    <segment id="34">E a louça</segment>
    <segment id="35">, de preferência</segment>
    <segment id="36">, deve ser descartável.</segment>
    <segment id="37">Dejetos</segment>
    <segment id="38">A descarga vira um luxo nesses casos.</segment>
    <segment id="39">O ideal é utilizar uma sacola plástica acoplada ao assento sanitário para o número dois</segment>
    <segment id="40">, e amarre bem ao terminar.</segment>
    <segment id="41">Se houver um quintal</segment>
    <segment id="42">, enterre.</segment>
    <segment id="43">Em apartamentos</segment>
    <segment id="44">, utilize um outro saco maior para armazenar os sacos de dejetos em um cômodo pouco utilizado.</segment>
    <segment id="45">Segurança</segment>
    <segment id="46">Sua casa é seu abrigo.</segment>
    <segment id="47">Evite sair a qualquer custo.</segment>
    <segment id="48">Só sese desloque</segment>
    <segment id="49">casocaso sua vida esteja sob risco iminente.</segment>
    <segment id="50">Conheça os pontos vulneráveis para invasores e procure bloqueá-los.</segment>
    <segment id="51">Também é importante conhecer a vizinhança</segment>
    <segment id="52">, onde estão postos de polícia</segment>
    <segment id="53">, hospitais e fontes de água.</segment>
    <segment id="54">Comida É importante ter pelo menos uma semana de comida estocada em casa.</segment>
    <segment id="55">Prefira enlatados e secos.</segment>
    <segment id="56">No momento de crise</segment>
    <segment id="57">, comece pela geladeira e perecíveis.</segment>
    <segment id="58">Tenha em mente que a variedade e quantidade de refeições serão reduzidos no período.</segment>
    <segment id="59">Procure ter um fogareiro de acampamento para preparar as refeições</segment>
    <segment id="60">, caso</segment>
    <segment id="61">caso fique sem gás.</segment>
    <segment id="62">Comunicação e energia</segment>
    <segment id="63">Mantenha pacotes de velas e pilhas reservas sempre à mão.</segment>
    <segment id="64">Carregadores solares podem ser um bom investimento.</segment>
    <segment id="65">Tenha uma lanterna para cada membro da família.</segment>
  </rst>
</analysis>