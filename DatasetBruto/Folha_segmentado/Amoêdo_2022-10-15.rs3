  <rst>
    <segment id="1">O fundador do partido Novo</segment>
    <segment id="2">, JoãoAmoêdo</segment>
    <segment id="3">, surpreendeu internautas apoiadores de Lula (PT) e</segment>
    <segment id="4">, ao mesmo tempo</segment>
    <segment id="5">, nem um pouco a bolsonaristas</segment>
    <segment id="6">, após declarar voto no petista no segundo turno destas eleições.</segment>
    <segment id="7">Nas redes sociais</segment>
    <segment id="8">, sese por um lado a declaração</segment>
    <segment id="9">, em entrevista à Folha</segment>
    <segment id="10">, reforça a percepção de que está</segment>
    <segment id="11">sese construindo uma frente ampla pela democracia ("ampla até demais"</segment>
    <segment id="12">, dizem alguns)</segment>
    <segment id="13">, por outro há quem afirme que o Partido Novo "sempre foi laranja por fora e vermelho por dentro".</segment>
    <segment id="14">Amoêdo concorreu à Presidência em 2018 e</segment>
    <segment id="15">, na ocasião</segment>
    <segment id="16">, declarou voto em Jair Bolsonaro (PL</segment>
    <segment id="17">, à época PSL) quando este foi para o segundo turno contra Fernando Haddad (PT).</segment>
    <segment id="18">Ao justificar seu posicionamento</segment>
    <segment id="19">, o então presidente do partido Novo afirmou que votava "contra o PT</segment>
    <segment id="20">, masmas não em algo em que acredito.</segment>
    <segment id="21">"</segment>
    <segment id="22">Em 2022</segment>
    <segment id="23">, no entanto</segment>
    <segment id="24">, Amoêdo avalia que "os fatos</segment>
    <segment id="25">, a história recente e o resultado do 1º turno</segment>
    <segment id="26">, que fortaleceram a base de apoio de Bolsonaro</segment>
    <segment id="27">, me levam à conclusão de que o atual presidente apresenta um risco substancialmente maior"</segment>
    <segment id="28">, disse à Folha por escrito.</segment>
    <segment id="29">Seu nome chegou ao topo dos assuntos do momento no Twitter no início da tarde deste sábado (15)</segment>
    <segment id="30">, somando quase 30 mil postagens de repercussão até a publicação deste texto.</segment>
    <segment id="31">O atual presidente do Novo</segment>
    <segment id="32">, Eduardo Ribeiro</segment>
    <segment id="33">, chamou de "vergonhosa</segment>
    <segment id="34">, constrangedora e incoerente" a posição de Amôedo nestas eleições.</segment>
    <segment id="35">Outros membros do partido também foram às redes lamentar a decisão.</segment>
    <segment id="36">Nas redes de apoiadores do presidente</segment>
    <segment id="37">, além do posicionamento de Amoêdo ter sido recebido</segment>
    <segment id="38">comocomo óbvio</segment>
    <segment id="39">, o nome de Olavo de Carvalho (1974-2022)</segment>
    <segment id="40">, guru do bolsonarismo</segment>
    <segment id="41">, está sendo evocado por supostamente ter previsto a inclinação eleitoral do ex-presidenciável.</segment>
    <segment id="42">A terra plana está</segment>
    <segment id="43">, mais uma vez</segment>
    <segment id="44">, capotando.</segment>
    <segment id="45">Os memes</segment>
    <segment id="46">, por sua vez</segment>
    <segment id="47">, estão chegando.</segment>
  </rst>
</analysis>