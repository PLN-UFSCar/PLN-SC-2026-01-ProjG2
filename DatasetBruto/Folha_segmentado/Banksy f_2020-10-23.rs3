  <rst>
    <segment id="1">Uma pintura de Banksy parodiando uma obra de Claude Monet foi vendida em Londres nesta quarta-feira (21) por cerca de US$ 9</segment>
    <segment id="2">,8 milhões (equivalente a R$ 54</segment>
    <segment id="3">,5 milhões)</segment>
    <segment id="4">, tornando-</segment>
    <segment id="5">sese a segunda obra mais cara do misterioso artista britânico</segment>
    <segment id="6">, anunciou a casa de leilões Sotheby's.</segment>
    <segment id="7">A tela</segment>
    <segment id="8">, feita com tinta a óleo</segment>
    <segment id="9">, é intitulada "Mostre-me o Monet" e é uma imitação ímpar de "</segment>
    <segment id="10">O Lago das Ninfeias"</segment>
    <segment id="11">, uma das pinturas mais famosas do artista francês Claude Monet.</segment>
    <segment id="12">A casa de leilões Sotheby's vendeu a obra de Banksy pelo valor total de £ 7</segment>
    <segment id="13">,5 milhões</segment>
    <segment id="14">, ou quase US$ 9</segment>
    <segment id="15">,8 milhões.</segment>
    <segment id="16">"</segment>
    <segment id="17">O martelo bateu depois que cinco colecionadores disputaram a obra por quase nove minutos</segment>
    <segment id="18">, o que levou à elevação do preço</segment>
    <segment id="19">, que se</segment>
    <segment id="20">se tornou o segundo leilão mais caro do artista"</segment>
    <segment id="21">, relatou a Sotheby's.</segment>
    <segment id="22">Esta venda ocorre um ano após uma pintura de Banksy que retrata o Parlamento britânico repleto de chimpanzés ser leiloada por £ 9</segment>
    <segment id="23">,9 milhões (R$ 72</segment>
    <segment id="24">,3 milhões)</segment>
    <segment id="25">, um preço recorde para o misterioso artista britânico.</segment>
    <segment id="26">&amp;quot;Mostre-me o Monet&amp;quot</segment>
    <segment id="27">;, de Banksy</segment>
    <segment id="28">, releitura de &amp;quot</segment>
    <segment id="29">;O Lago das Ninfeias&amp;quot</segment>
    <segment id="30">;</segment>
    <segment id="31">, uma das pinturas mais famosas do artista francês Claude Monet - Daniel Leal-Olivas/AFP</segment>
    <segment id="32">A obra leiloada nesta quarta ilustra a paisagem de uma ponte japonesa sobre um lago florido</segment>
    <segment id="33">, como</segment>
    <segment id="34">como na pintura original de Monet</segment>
    <segment id="35">, masmas</segment>
    <segment id="36">, na versão de Banksy</segment>
    <segment id="37">, também há um cone de trânsito e carrinhos de supermercado no meio do lago.</segment>
    <segment id="38">"</segment>
    <segment id="39">Banksy destaca o desprezo da sociedade pelo meio ambiente em face dos excessos perdulários do consumismo"</segment>
    <segment id="40">, disse Alex Branczik</segment>
    <segment id="41">, chefe europeu de arte contemporânea da Sotheby's</segment>
    <segment id="42">, em um comunicado</segment>
    <segment id="43">, que considera o artista de Bristol "um visionário".  "</segment>
    <segment id="44">Show</segment>
    <segment id="45">Me the Monet" foi criada em 2005</segment>
    <segment id="46">comocomo parte da coleção intitulada ""</segment>
    <segment id="47">Pinturas a Óleo Vulgares"</segment>
    <segment id="48">, na qual Banksy</segment>
    <segment id="49">sese dedicou a parodiar obras-primas da arte pictórica</segment>
    <segment id="50">comocomo "Girassóis"</segment>
    <segment id="51">, de Van Gogh</segment>
    <segment id="52">, ou os retratos de Marilyn Monroe feitos por Andy Warhol.</segment>
    <segment id="53">Veja fotos da obra de Banksy é leiloada em Londres em 2019   novamente         de   de  de  representando um</segment>
  </rst>
</analysis>