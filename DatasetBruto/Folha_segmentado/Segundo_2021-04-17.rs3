  <rst>
    <segment id="1">A saga criada por George Lucas já terminou nos cinemas e prossegue em derivados</segment>
    <segment id="2">comocomo a série “The Mandalorian”</segment>
    <segment id="3">, do Disney+.</segment>
    <segment id="4">Só agora o penúltimo longa</segment>
    <segment id="5">, "Star Wars:</segment>
    <segment id="6">Os Últimos Jedi"</segment>
    <segment id="7">, estreia na TV aberta.</segment>
    <segment id="8">No chamado “Episódio 8”</segment>
    <segment id="9">, a jovem Rey (Daisy Ridley) começa a apresentar sinais da Força.</segment>
    <segment id="10">Foi o primeiro filme da franquia lançado depois da morte de Carrie Fisher (1956-2016)</segment>
    <segment id="11">, a princesa Leia.</segment>
    <segment id="12">&amp;#</segment>
    <segment id="13">039;Star Wars:</segment>
    <segment id="14">Os Últimos Jedi&amp;#039</segment>
    <segment id="15">;Mais    novamente         de   de  de  representando um    Globo</segment>
    <segment id="16">, 15h50</segment>
    <segment id="17">, 12 anos</segment>
    <segment id="18">Neorrealismo Italiano</segment>
    <segment id="19">O Festival 125 Anos de Cinema dedica o domingo ao movimento cinematográfico que floresceu na Itália após a Segunda Guerra Mundial.</segment>
    <segment id="20">Entre os destaques</segment>
    <segment id="21">, “Ladrões de Bicicleta” (18h25</segment>
    <segment id="22">, 10 anos)</segment>
    <segment id="23">, de Vittorio De Sica</segment>
    <segment id="24">, e “Roma</segment>
    <segment id="25">, Cidade Aberta” (20h05</segment>
    <segment id="26">, 14 anos)</segment>
    <segment id="27">, de Roberto Rossellini.    Telecine Cult</segment>
    <segment id="28">, a partir de 10h35   MIS Ex-Libris</segment>
    <segment id="29">O escritor Lira Neto conversa ao vivo com José Luiz Goldfarb sobre seu novo livro</segment>
    <segment id="30">, “Arrancados da Terra”</segment>
    <segment id="31">, que conta</segment>
    <segment id="32">comocomo judeus perseguidos pela Inquisição formaram as primeiras comunidades judaicas das Américas.</segment>
    <segment id="33">Canal do MIS no YouTube</segment>
    <segment id="34">, 17h</segment>
    <segment id="35">Repórter Eco</segment>
    <segment id="36">O programa apresentado por Márcia Bongiovanni tem edição sobre o Dia do Índio.</segment>
    <segment id="37">Cultura</segment>
    <segment id="38">, 23h, livre   Silk Road:</segment>
    <segment id="39">Mercado Clandestino Baseado na incrível história real de Ross Ulbricht</segment>
    <segment id="40">, o americano que montou um esquema online de narcotráfico —a “Amazon das drogas”.</segment>
    <segment id="41">É irônico que o filme</segment>
    <segment id="42">, inédito nos cinemas brasileiros</segment>
    <segment id="43">, chegue aqui pela Amazon.</segment>
    <segment id="44">Amazon Prime Video</segment>
    <segment id="45">, 16 anos   Noite no Paraíso Exibido no Festival de Veneza de 2020</segment>
    <segment id="46">, o thriller do sul-coreano Park Hoon-Jung fala de um gângster perseguido e uma mulher atormentada.</segment>
    <segment id="47">Noite no Paraíso - Noh Juhan/Netflix</segment>
    <segment id="48">Netflix</segment>
    <segment id="49">, 16 anos   Dentro da Minha Pele</segment>
    <segment id="50">O documentário de Toni Venturi e Val Gomes mostra</segment>
    <segment id="51">comocomo o racismo estrutural afeta a vida de nove paulistanos negros —entre eles</segment>
    <segment id="52">, a psicóloga e colunista deste jornal Cida Bento.</segment>
