  <rst>
    <segment id="1">A HarperCollins acaba de comprar os direitos sobre a obra completa do americano Charles Bukowski</segment>
    <segment id="2">, que ganhará nova identidade visual num projeto de estofo inaugurado em julho pelo romance "Factótum"</segment>
    <segment id="3">, logo seguido de "Pulp</segment>
    <segment id="4">" em agosto.</segment>
    <segment id="5">O escritor americano de raízes alemãs Charles Bukowski - DivulgaçãoNascido na Alemanha</segment>
    <segment id="6">, de onde saiu aos três anos</segment>
    <segment id="7">, o escritor foi marcado por uma infância abusiva e por uma vida de rejeições</segment>
    <segment id="8">, alcoolismo e trabalhos braçais antes de conseguir ser publicado.</segment>
    <segment id="9">Sua literatura ficou conhecida pelo estilo bruto</segment>
    <segment id="10">, pessimista e completamente despudorado.</segment>
    <segment id="11">O projeto é ambicioso</segment>
    <segment id="12">porque</segment>
    <segment id="13">porque a obra de Bukowski é prolífica</segment>
    <segment id="14">, tendo mais de 40 títulos entre romances</segment>
    <segment id="15">, poemas</segment>
    <segment id="16">, contos e ensaios.</segment>
    <segment id="17">O autor vinha sendo publicado pela L&amp;amp</segment>
    <segment id="18">;PM nas últimas décadas</segment>
    <segment id="19">, masmas livros pontuais já tinham saído em outras editoras —</segment>
    <segment id="20">comocomo o próprio "Factótum" nos tempos áureos da Brasiliense.</segment>
    <segment id="21">Também é uma obra arriscada em tempos em que editoras contratam "leitores sensíveis" —</segment>
    <segment id="22">Bukowski já foi muito acusado de misoginia</segment>
    <segment id="23">, só para começar.</segment>
    <segment id="24">A editora pretende incluir prefácios contextualizando cada livro em seu tempo.</segment>
    <segment id="25">Ilustração de Luci Sacoleira para o livro infantil &amp;#039</segment>
    <segment id="26">;Menina Mandioca&amp;#039</segment>
    <segment id="27">;, de Rita Carelli</segment>
    <segment id="28">, que sai pela Pallas - DivulgaçãoCOMO LUZ DEL FUEGO Lembra o movimento</segment>
    <segment id="29">Um Grande Dia</segment>
    <segment id="30">para as Escritoras</segment>
    <segment id="31">, que reuniu centenas de autoras para uma fotografia no estádio do Pacaembu durante a primeira edição da Feira do Livro?</segment>
    <segment id="32">Está virando um livro homônimo</segment>
    <segment id="33">, que registra não só os nomes das mulheres que participaram deste retrato</segment>
    <segment id="34">, masmas dos feitos em quase 50 cidades brasileiras e no exterior</segment>
    <segment id="35">, depois que o movimento</segment>
    <segment id="36">sese alastrou.</segment>
    <segment id="37">São, ao todo</segment>
    <segment id="38">, 2.302 escritoras reconhecidas no livro.</segment>
    <segment id="39">NÃO TINHA MEDO</segment>
    <segment id="40">O volume será lançado pela Bazar do Tempo na próxima edição da Feira</segment>
    <segment id="41">, em junho</segment>
    <segment id="42">, com textos de cinco organizadoras da iniciativa: Deborah Goldemberg</segment>
    <segment id="43">, Esmeralda Ribeiro</segment>
    <segment id="44">, Paula Carvalho</segment>
    <segment id="45">, Sony Ferseck e Giovana Madalosso</segment>
    <segment id="46">, colunista da Folha.</segment>
    <segment id="47">Conheça as escritoras responsáveis pela imagem &amp;#039</segment>
    <segment id="48">;Um Grande dia em São Paulo&amp;#039</segment>
    <segment id="49">;Mais    novamente         de   de  de  representando um  ELA TAMBÉM FOI PRO CÉU E a editora 34 está trazendo de volta à praça o precioso volume de contos completos de Virginia Woolf</segment>
    <segment id="50">, na mesma tradução de Leonardo Fróes feita para a edição da extinta Cosac Naify em 2005</segment>
    <segment id="51">, agora com um novo prefácio do tradutor.</segment>
    <segment id="52">Tudo a lerReceba no seu email uma seleção com lançamentos</segment>
    <segment id="53">, clássicos e curiosidades literárias</segment>
    <segment id="54">; aberta para não assinantes.</segment>
    <segment id="55">Carregando...</segment>
    <segment id="56">UM MONTE DE GENTE FELIZ</segment>
    <segment id="57">A Sextante aposta no lançamento daquele que é considerado o estudo mais longevo sobre a felicidade nas relações humanas</segment>
    <segment id="58">, de dois professores de psicologia de Harvard</segment>
    <segment id="59">, Robert Waldinger e Marc Schulz.</segment>
    <segment id="60">"</segment>
    <segment id="61">A Boa Vida" sai em agosto.</segment>
  </rst>
</analysis>