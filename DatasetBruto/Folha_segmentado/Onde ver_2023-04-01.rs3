    <segment id="1">Em 1988</segment>
    <segment id="2">, o empresário Henk Rogers conhece o "Tetris"</segment>
    <segment id="3">, um videogame criado pelo russo Alexey Pajitnov.</segment>
    <segment id="4">Disposto a comprar os direitos</segment>
    <segment id="5">, ele parte para a União Soviética</segment>
    <segment id="6">, dando início a uma disputa que marcou os últimos anos da Guerra Fria.</segment>
    <segment id="7">Taron Egerton e Nikita Efremov em cena do filme &amp;quot</segment>
    <segment id="8">;Tetris&amp;quot</segment>
    <segment id="9">;, de Jon S. Baird - Divulgação"Tetris"</segment>
    <segment id="10">, thriller com toques cômicos é estrelado por Taron Egerton</segment>
    <segment id="11">, que encarnou Elton John em "Rocketman".</segment>
    <segment id="12">Apple TV+</segment>
    <segment id="13">, 14 anos</segment>
    <segment id="14">De Quem Estamos Fugindo?</segment>
    <segment id="15">Uma mulher e sua filha adolescente não têm endereço fixo.</segment>
    <segment id="16">Estão sempre viajando</segment>
    <segment id="17">, pulando de hotel em hotel.</segment>
    <segment id="18">A garota não sabe o que aconteceu no passado da mãe</segment>
    <segment id="19">, que encara tudo</segment>
    <segment id="20">comocomo uma possível ameaça.</segment>
    <segment id="21">Série turca exclusiva da plataforma.</segment>
    <segment id="22">Netflix</segment>
    <segment id="23">, 16 anos   Disque Jane</segment>
    <segment id="24">Uma dona de casa com filhos engravida de novo</segment>
    <segment id="25">, masmas dessa vez sua vida corre risco.</segment>
    <segment id="26">A única solução seria um aborto</segment>
    <segment id="27">, ainda ilegal nos EUA de 1968.</segment>
    <segment id="28">Ela então conhece um grupo de mulheres que podem ajudá-la</segment>
    <segment id="29">, as Janes.</segment>
    <segment id="30">Com Elizabeth Banks e Sigourney Weaver.</segment>
    <segment id="31">Amazon Prime Video</segment>
    <segment id="32">, 16 anos   Auts e Stella  Auts convida sua amiga Stella para fazerem um filme juntos.</segment>
    <segment id="33">Ambos são autistas</segment>
    <segment id="34">, masmas de expressões diferentes.</segment>
    <segment id="35">Para marcar o Dia Mundial de Conscientização do Autismo</segment>
    <segment id="36">, a emissora exibe o curta-metragem de animação derivado do seriado "Auts".</segment>
    <segment id="37">Cultura</segment>
    <segment id="38">, 12h30</segment>
