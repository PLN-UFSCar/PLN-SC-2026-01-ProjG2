  <rst>
    <segment id="1">Uma gata que abre a boca enquanto espera a tutora dar o petisco</segment>
    <segment id="2">, como</segment>
    <segment id="3">como se</segment>
    <segment id="4">se fosse um bebê recebendo a papinha de "aviãozinho</segment>
    <segment id="5">" com a colher</segment>
    <segment id="6">, viralizou nas redes sociais nas últimas semanas.</segment>
    <segment id="7">A felina é Poong</segment>
    <segment id="8">, uma gata de 9 anos que vive na Coreia do Sul.</segment>
    <segment id="9">Ao contrário do que parece num primeiro momento</segment>
    <segment id="10">, ela não foi adestrada para comer assim.</segment>
    <segment id="11">Na verdade</segment>
    <segment id="12">, a bichana tem um problema neurológico que compromete seus movimentos</segment>
    <segment id="13">, por isso precisa receber a ração na boca.</segment>
    <segment id="14">Gatinha com problema neurológico faz sucesso nas redes sociais pedindo comida Mais    novamente         de   de  de  representando um</segment>
    <segment id="15">A tutora de Poong conta no seu perfil do Instagram que os sintomas começaram um pouco antes de a gatinha completar dois anos</segment>
    <segment id="16">, masmas os veterinários não souberam especificar qual é a doença que ela tem.</segment>
    <segment id="17">Para um diagnóstico mais detalhado</segment>
    <segment id="18">, a felina precisaria fazer um exame de ressonância magnética</segment>
    <segment id="19">, masmas</segment>
    <segment id="20">, no caso</segment>
    <segment id="21">caso dela</segment>
    <segment id="22">, o procedimento poderia provocar convulsões ou mesmo a morte.</segment>
    <segment id="23">Então ela decidiu cuidar da gata da melhor forma possível</segment>
    <segment id="24">, dentro das limitações motoras que ela tem.</segment>
    <segment id="25">Poong é castrada e vive com mais dois gatos</segment>
    <segment id="26">, Junie e Dukie.  +</segment>
    <segment id="27">GaticesLeia</segment>
    <segment id="28">mais sobre gatosPerfil reúne fotos de gatos espiando a vida alheia em janelasRinotraqueíte em gatos causa coriza</segment>
    <segment id="29">, espirros e conjuntiviteGatos adultos</segment>
    <segment id="30">, frajolas e escaminhas são rejeitados na adoçãoGato vira atração turística com avaliação 5 estrelas na PolôniaSiga o blog Gatices no Twitter</segment>
    <segment id="31">, Instagram e Facebook.</segment>
