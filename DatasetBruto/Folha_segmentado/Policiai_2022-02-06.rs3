  <rst>
    <segment id="1">O Sindpesp (Sindicato dos Delegados de Polícia do Estado de São Paulo) e outras 12 entidades de policiais civis vão protocolar no governo estadual de João Doria (PSDB)</segment>
    <segment id="2">, nesta terça-feira (8)</segment>
    <segment id="3">, um documento pedindo diálogo sobre as condições da corporação.</segment>
    <segment id="4">O grupo reivindica mais investimento e plano de carreira.</segment>
    <segment id="5">O governador João Doria (PSDB) durante cerimônia no Palácio dos Bandeirantes</segment>
    <segment id="6">, em São Paulo - Mathilde Missioneiro - 26.jan.2022/Folhapress EM FAMÍLIA</segment>
    <segment id="7">O cantor Fábio Jr com os filhos atores</segment>
    <segment id="8">, Cleo Pires e Fiuk</segment>
    <segment id="9">, no set do filme &amp;#039</segment>
    <segment id="10">;Me Tira da Mira&amp;#039</segment>
    <segment id="11">; - Larissa MarquesFábio Jr.</segment>
    <segment id="12">, Cleo Pires e Fiuk estarão juntos pela primeira vez no cinema.</segment>
    <segment id="13">Pai e filhos contracenam na comédia policial "</segment>
    <segment id="14">Me Tira da Mira"</segment>
    <segment id="15">, do diretor Hsu Chien</segment>
    <segment id="16">, que estreia em 17 de março.</segment>
    <segment id="17">"</segment>
    <segment id="18">Imagina só o orgulho do papai aqui!</segment>
    <segment id="19">Produção da minha filhota [Cleo]</segment>
    <segment id="20">, elenco incrível</segment>
    <segment id="21">, roteiro</segment>
    <segment id="22">, direção.</segment>
    <segment id="23">E ainda poder contracenar pela primeira vez nós três foi muito lindo!</segment>
    <segment id="24">A gente</segment>
    <segment id="25">sese divertiu</segment>
    <segment id="26">, sese emocionou"</segment>
    <segment id="27">, diz o cantor.  JOELMIR TAVARES (interino)</segment>
    <segment id="28">, com LÍGIA MESQUITA</segment>
    <segment id="29">, BIANKA VIEIRA e MANOELLA SMITH</segment>
    <segment id="30">​</segment>
