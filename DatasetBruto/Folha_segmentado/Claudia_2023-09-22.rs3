  <rst>
    <segment id="1">Claudia Sheinbaum (Cidade do México</segment>
    <segment id="2">, 1962)</segment>
    <segment id="3">, cientista</segment>
    <segment id="4">, acadêmica da Universidade Nacional Autônoma do México (Unam)</segment>
    <segment id="5">, ativista política e ex-chefe de governo da Cidade do México</segment>
    <segment id="6">, é a candidata do Movimento de Regeneração Nacional (Morena) à Presidência do México.</segment>
    <segment id="7">Será ela quem vai concorrer nas eleições gerais a serem celebradas em 2024.</segment>
    <segment id="8">Colunas e BlogsReceba no seu email uma seleção de colunas e blogs da Folha</segment>
    <segment id="9">; exclusiva para assinantes.</segment>
    <segment id="10">Carregando...</segment>
    <segment id="11">A ex-chefe de governo da capital ganhou a pesquisa que seu partido propôs</segment>
    <segment id="12">comocomo forma de escolher seu candidato ou candidata para as próximas eleições gerais e para suceder o atual presidente</segment>
    <segment id="13">, Andrés Manuel López Obrador</segment>
    <segment id="14">, na Presidência da República nos próximos seis anos</segment>
    <segment id="15">sese, como</segment>
    <segment id="16">como preveem as pesquisas</segment>
    <segment id="17">, ela triunfar.</segment>
    <segment id="18">Claudia Sheinbaum com Mario Delgado e Alfonso Durazo</segment>
    <segment id="19">, dirigentes do Morena - Henry Romero - 10.set.23/Reuters  Claudia Sheinbaum enfrenta um grande desafio.</segment>
    <segment id="20">Sobre isso não há dúvidas.</segment>
    <segment id="21">E, para enfrentá-lo</segment>
    <segment id="22">, conta com a formação acadêmica e a trajetória política adequadas.</segment>
    <segment id="23">Pela sua formação acadêmica</segment>
    <segment id="24">, é importante mencionar que Sheinbaum estudou licenciatura em física</segment>
    <segment id="25">, fez mestrado e doutorado em engenharia de energia na Unam e passou um tempo na Universidade da Califórnia</segment>
    <segment id="26">, nos Estados Unidos.</segment>
    <segment id="27">Atua como</segment>
    <segment id="28">como pesquisadora no Instituto de Engenharia da Unam desde 1995.</segment>
    <segment id="29">Seus primeiros contatos com a prática política</segment>
    <segment id="30">sese deram na luta estudantil na Unam</segment>
    <segment id="31">, quando</segment>
    <segment id="32">, como</segment>
    <segment id="33">como aluna da Faculdade de Ciências</segment>
    <segment id="34">, participou do movimento de 1986-1987 em defesa da educação pública e contra o aumento das taxas para os estudantes.</segment>
    <segment id="35">Foi somente no ano 2000 que ela aceitou um cargo de secretária do Meio Ambiente no governo da cidade</segment>
    <segment id="36">, então governado pelo atual presidente do México.</segment>
    <segment id="37">Foi nessa etapa que ela estabeleceu uma relação de trabalho e um compromisso político com López Obrador</segment>
    <segment id="38">, que contou com ela em sua primeira campanha presidencial em 2006.</segment>
    <segment id="39">Depois que as eleições foram consideradas fraudulentas</segment>
    <segment id="40">, López Obrador estabeleceu um movimento de resistência civil e solicitou a Sheinbaum que</segment>
    <segment id="41">sese encarregasse da organização da estrutura popular em defesa do patrimônio nacional (conhecidos</segment>
    <segment id="42">comocomo as Adelitas).</segment>
    <segment id="43">Em 2012</segment>
    <segment id="44">, na segunda campanha para a Presidência</segment>
    <segment id="45">, ela foi proposta para a pasta do Meio Ambiente</segment>
    <segment id="46">, caso</segment>
    <segment id="47">caso vencesse as eleições.</segment>
    <segment id="48">Mas a eleição foi vencida pelo candidato do PRI e a acadêmica voltou ao seu trabalho de pesquisa na Unam.</segment>
    <segment id="49">Em 2014</segment>
    <segment id="50">, ela retornou à arena política após a fundação do Morena</segment>
    <segment id="51">; em 2015</segment>
    <segment id="52">, concorreu e ganhou a Prefeitura de Tlalpan</segment>
    <segment id="53">, que ocuparia até 2018</segment>
    <segment id="54">, quando passou a gerenciar</segment>
    <segment id="55">, depois de ser eleita</segment>
    <segment id="56">, a chefia da Cidade do México</segment>
    <segment id="57">, da qual ficou encarregada até 2023.  Claudia Sheinbaum no dia em que foi escolhida</segment>
    <segment id="58">comocomo candidata do Morena - Henry Romero/Reuters</segment>
    <segment id="59">De sua administração</segment>
    <segment id="60">, podemos extrair algumas ideias sobre o perfil da ex-chefe de governo.</segment>
    <segment id="61">A acadêmica</segment>
    <segment id="62">, formada em física e ecologia</segment>
    <segment id="63">, deu atenção especial ao meio ambiente e procurou ampliar a rede de transporte público limpo e sustentável (Metrobus</segment>
    <segment id="64">, trólebus</segment>
    <segment id="65">, ciclovias)</segment>
    <segment id="66">;</segment>
    <segment id="67">em consonância com as demandas estudantis de sua juventude</segment>
    <segment id="68">, durante sua gestão foram concedidas bolsas de estudo a estudantes de baixa renda e foi implementado um programa para levar formação extracurricular a áreas marginalizadas: espaços de formação comunitária conhecidos</segment>
    <segment id="69">comocomo Pilares.</segment>
    <segment id="70">Às luzes dessa gestão deve ser acrescentada uma sombra: em 2021</segment>
    <segment id="71">, houve um acidente na linha 12 do metrô no qual 27 pessoas perderam a vida.</segment>
    <segment id="72">Embora essa linha tenha sido projetada e construída durante a gestão anterior</segment>
    <segment id="73">, a administração de Sheinbaum foi acusada de não fornecer suficiente manutenção devido às políticas de austeridade.</segment>
    <segment id="74">Acidente com metrô na Cidade do México em maio de 2021 - Pedro Pardo/AFPEm suma</segment>
    <segment id="75">, a trajetória da candidata à presidência da República dos Estados Unidos Mexicanos nos dá uma ideia de quem é a mulher que pode assumir a maior responsabilidade política do país.</segment>
    <segment id="76">Mulher que</segment>
    <segment id="77">, não omito em mencionar</segment>
    <segment id="78">, é também mãe de dois filhos:</segment>
    <segment id="79">Mariana</segment>
    <segment id="80">, atualmente pós-doutoranda no Instituto de Pesquisas Filosóficas da UNAM</segment>
    <segment id="81">, e Rodrigo</segment>
    <segment id="82">, que estudou Artes Visuais na UNAM e</segment>
    <segment id="83">sese dedica ao cinema documental.  Muitos meios de comunicação nacionais e estrangeiros noticiaram sua condição de mulher.</segment>
    <segment id="84">De fato</segment>
    <segment id="85">, devemos nos parabenizar pelo fato de que</segment>
    <segment id="86">, após séculos de luta (não nos esqueçamos de que em 1791</segment>
    <segment id="87">Olympia de Gouges escreveu a Declaração dos Direitos da Mulher e da Cidadã)</segment>
    <segment id="88">, as mulheres vêm ocupando espaços de representação e de tomada de decisões políticas</segment>
    <segment id="89">, e também devemos nos parabenizar pelo fato de a paridade ter sido incorporada à Constituição mexicana.</segment>
    <segment id="90">É de se</segment>
    <segment id="91">se esperar que sua gestão</segment>
    <segment id="92">, no caso</segment>
    <segment id="93">caso de ganhar as eleições</segment>
    <segment id="94">, seja sensível às demandas sinceras das mulheres e corpos feminizados</segment>
    <segment id="95">, em continuidade ao seu trabalho na Chefia de Governo da Cidade do México.</segment>
    <segment id="96">Embora</segment>
    <segment id="97">, do meu ponto de vista</segment>
    <segment id="98">, não é a sua condição de mulher o relevante.</segment>
    <segment id="99">Houve (e há) outras mulheres ocupando cargos de representação política insensíveis às questões de gênero.</segment>
    <segment id="100">Pensemos em Margaret Thatcher</segment>
    <segment id="101">, por exemplo.</segment>
    <segment id="102">O que é realmente significativo no fato de ela ser uma mulher ocupando o cargo mais alto da República é</segment>
    <segment id="103">, em primeiro lugar</segment>
    <segment id="104">, que sua trajetória pode ser um exemplo para as mulheres</segment>
    <segment id="105">, para as jovens deste país:</segment>
    <segment id="106">sim, as mulheres podem</segment>
    <segment id="107">;</segment>
    <segment id="108">sim, as mulheres têm o direito efetivo (não apenas no papel) de exercer a representação política.</segment>
    <segment id="109">Para todas</segment>
    <segment id="110">, e especialmente para aquelas que sofrem violência e condições de desigualdade laboral</segment>
    <segment id="111">, social e econômica</segment>
    <segment id="112">, a jovem que integrou o movimento estudantil da década de 1980 teria</segment>
    <segment id="113">, sese fosse presidente</segment>
    <segment id="114">, a possibilidade de implementar políticas e planos de igualdade</segment>
    <segment id="115">, programas de inclusão e</segment>
    <segment id="116">, fundamentalmente</segment>
    <segment id="117">, programas contra a violência de gênero.</segment>
    <segment id="118">Essas políticas podem ser executadas por um presidente ou uma presidenta indistintamente</segment>
    <segment id="119">;</segment>
    <segment id="120">no entanto</segment>
    <segment id="121">, no caso</segment>
    <segment id="122">caso de Sheinbaum</segment>
    <segment id="123">, é de</segment>
    <segment id="124">sese esperar que isso ocorra</segment>
    <segment id="125">, pois</segment>
    <segment id="126">pois ela mesma sofreu agressões machistas.</segment>
    <segment id="127">De fato</segment>
    <segment id="128">, é surpreendente que os críticos da aspirante à Presidência semeiem dúvidas sobre sua capacidade de agência livre</segment>
    <segment id="129">, responsável e comprometida</segment>
    <segment id="130">, apontando</segment>
    <segment id="131">, em um gesto caracteristicamente misógino</segment>
    <segment id="132">, que ela não passa de uma marionete nas mãos do atual presidente da República.</segment>
    <segment id="133">Não há dúvida de que Andrés Manuel López Obrador é um líder carismático.</segment>
    <segment id="134">Com sua retirada da vida política</segment>
    <segment id="135">, ele deixará um vazio significativo no movimento de esquerdas que fundou e comandou de 2014 até hoje.</segment>
    <segment id="136">Hoje, depois de receber o "bastão de comando"</segment>
    <segment id="137">, Claudia Sheinbaum tem</segment>
    <segment id="138">comocomo primeiro desafio a construção</segment>
    <segment id="139">, no interior do movimento</segment>
    <segment id="140">, de uma nova liderança</segment>
    <segment id="141">, uma liderança com sua própria marca.</segment>
    <segment id="142">Seu desafio maior</segment>
    <segment id="143">, no médio prazo</segment>
    <segment id="144">, será dirigir a República com base nos princípios dessa nova liderança.</segment>
  </rst>
</analysis>