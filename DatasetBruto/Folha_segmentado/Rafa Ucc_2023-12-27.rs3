  <rst>
    <segment id="1">A influenciadora e apresentadora Rafa Uccman diz que não tinha superstições de Ano Novo</segment>
    <segment id="2">, masmas resolveu adotar para a virada de 2023 para 2024 uma dica que recebeu da astróloga e vidente Márcia Fernandes</segment>
    <segment id="3">, mais conhecida</segment>
    <segment id="4">comocomo Márcia Sensitiva.</segment>
    <segment id="5">"</segment>
    <segment id="6">A gente sobe em cima de um banco alto e</segment>
    <segment id="7">, assim que der meia-noite</segment>
    <segment id="8">, é preciso pular com o pé direito para o chão"</segment>
    <segment id="9">, relata Rafa à coluna.</segment>
    <segment id="10">"</segment>
    <segment id="11">Dizem que é maravilhoso!</segment>
    <segment id="12">O primeiro banco que eu vir na minha frente</segment>
    <segment id="13">, já vou subir"</segment>
    <segment id="14">, acrescenta.</segment>
    <segment id="15">A influencer Rafa Uccman-</segment>
    <segment id="16">Divulgação Uccman diz que passará o Réveillon em uma fazenda</segment>
    <segment id="17">, fazendo um detox.</segment>
    <segment id="18">"</segment>
    <segment id="19">Sem festa</segment>
    <segment id="20">, sem álcool e loucura.</segment>
    <segment id="21">Quero começar 2024 tranquila</segment>
    <segment id="22">, só mentalizando os meus pedidos e agradecendo.</segment>
    <segment id="23">"</segment>
    <segment id="24">Ela também afirma que gosta de usar na virada peças nas cores branco</segment>
    <segment id="25">, amarelo ou dourado "para atrair um dinheirinho".</segment>
    <segment id="26">Já a cantora Karinah tem algumas tradições</segment>
    <segment id="27">, como</segment>
    <segment id="28">como tomar ponche com champanhe e frutas e comer romã e guardar as sementes na carteira.</segment>
    <segment id="29">"</segment>
    <segment id="30">É tradição de família"</segment>
    <segment id="31">, diz.</segment>
    <segment id="32">Ela também afirma preferir passar o Ano Novo na praia —e que nesta virada de 2023 para 2024 não será diferente.</segment>
    <segment id="33">A artista e a família estarão em Balneário Camboriú</segment>
    <segment id="34">, em Santa Catarina.</segment>
    <segment id="35">"</segment>
    <segment id="36">Não gosto de passar a virada longe do mar.</segment>
    <segment id="37">O mar é casa de mãe</segment>
    <segment id="38">, sempre peço por mim e pelos meus</segment>
    <segment id="39">, de preferência proteção e calmaria.</segment>
    <segment id="40">"</segment>
    <segment id="41">Claudia Leitte apresenta o projeto &amp;#</segment>
    <segment id="42">039;O Carnaval da Minha Vida&amp;#039</segment>
    <segment id="43">; Mais    novamente         de   de  de  representando um</segment>
    <segment id="44">A apresentadora Catia Fonseca</segment>
    <segment id="45">, por sua vez</segment>
    <segment id="46">, estará bem longe do calor brasileiro.</segment>
    <segment id="47">Ela e o marido</segment>
    <segment id="48">, o diretor Rodrigo Riccó</segment>
    <segment id="49">, escolheram Toronto</segment>
    <segment id="50">, no Canadá</segment>
    <segment id="51">, para o Ano Novo.</segment>
    <segment id="52">"</segment>
    <segment id="53">O que gostamos de fazer</segment>
    <segment id="54">, independentemente do lugar em que estamos</segment>
    <segment id="55">, é realizarmos nossas orações.</segment>
    <segment id="56">Eu acho que esse é um momento da gente refletir um pouco sobre tudo que fizemos durante o ano</segment>
    <segment id="57">, agradecer pelos objetivos que alcançamos</segment>
    <segment id="58">, onde dá pra melhorar…"</segment>
    <segment id="59">, analisa.</segment>
    <segment id="60">A artista brasileira Ella</segment>
    <segment id="61">A fará um caminho oposto ao de Catia.</segment>
    <segment id="62">Radicada na Noruega</segment>
    <segment id="63">, após seis anos passando a virada no frio europeu</segment>
    <segment id="64">, ela estará no Brasil neste Réveillon.</segment>
    <segment id="65">"</segment>
    <segment id="66">As expectativas estão muito altas"</segment>
    <segment id="67">, diz.</segment>
    <segment id="68">"</segment>
    <segment id="69">Eu mantenho a tradição brasileira de sempre passar de branco</segment>
    <segment id="70">, mesmo lá Noruega que o pessoal me acha estranha por causa disso"</segment>
    <segment id="71">, conta ela</segment>
    <segment id="72">, entre risos.</segment>
    <segment id="73">RETROVISOR</segment>
    <segment id="74">A apresentadora Sandra Annenberg na Pinacoteca de São Paulo</segment>
    <segment id="75">, onde gravou a Retrospectiva 2023- Lucas Seixas/DivulgaçãoA apresentadora Sandra Annenberg</segment>
    <segment id="76">foi fotografada na Pinacoteca de São Paulo</segment>
    <segment id="77">, onde gravou o programa Retrospectiva 2023</segment>
    <segment id="78">, que vai ao ar na TV Globo na sexta (29)</segment>
    <segment id="79">, após a novela "Terra e Paixão".</segment>
    <segment id="80">"</segment>
    <segment id="81">Vimos a democracia ser testada aqui e em muitos países</segment>
    <segment id="82">, e também descuidamos tanto da nossa natureza que passamos do limite.</segment>
    <segment id="83">Esses e tantos outros assuntos que foram marcantes estarão na Retrospectiva 2023"</segment>
    <segment id="84">, diz Sandra.  com BIANKA VIEIRA</segment>
    <segment id="85">, KARINA MATIAS e MANOELLA SMITH</segment>
  </rst>
</analysis>