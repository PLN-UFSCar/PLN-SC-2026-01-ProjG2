  <rst>
    <segment id="1">A Nike cancelou nesta terça-feira (21) o lançamento de um novo modelo de tênis</segment>
    <segment id="2">, após protestos de indígenas panamenhos pelo suposto uso de um símbolo artístico ancestral da etnia.  "</segment>
    <segment id="3">Nos desculpamos pela representação incorreta da origem do desenho do Nike Air Force 1 Porto Rico.</segment>
    <segment id="4">Como resultado</segment>
    <segment id="5">, este produto já não estará disponível"</segment>
    <segment id="6">, informou um porta-voz da Nike à AFP.</segment>
    <segment id="7">Os indígenas guna do Panamá ficaram furiosos com a multinacional americana  pelo suposto uso do símbolo ancestral no tênis que seria lançado no mercado no mês que vem</segment>
    <segment id="8">, e exigiram uma indenização.</segment>
    <segment id="9">Modelo clássico da Nike</segment>
    <segment id="10">, o Air Force 1</segment>
    <segment id="11">; versão com símbolo panamenho foi cancelada - DivulgaçãoA polêmica surgiu</segment>
    <segment id="12">porque</segment>
    <segment id="13">porque Nike fez uma edição especial de tênis para Porto Rico com um desenho muito parecido com uma mola</segment>
    <segment id="14">, uma arte ancestral dos indígenas guna do Panamá e da Colômbia.</segment>
    <segment id="15">"</segment>
    <segment id="16">Já houve um dano</segment>
    <segment id="17">porque</segment>
    <segment id="18">porque foi utilizado nosso desenho</segment>
    <segment id="19">, que faz parte da espiritualidade do povo guna.</segment>
    <segment id="20">Portanto</segment>
    <segment id="21">, a empresa (Nike) tem que indenizar</segment>
    <segment id="22">, porque</segment>
    <segment id="23">porque foi uma cópia ilegal de nossos desenhos"</segment>
    <segment id="24">, disse à AFP o advogado dos guna</segment>
    <segment id="25">, Aresio Valiente.</segment>
    <segment id="26">Os gunas são uma etnia indígena que vive principalmente nas ilhas do Caribe panamenho e no território colombiano.</segment>
    <segment id="27">No Panamá</segment>
    <segment id="28">, vivem principalmente na reserva indígena de Guna Yala</segment>
    <segment id="29">, onde</segment>
    <segment id="30">sese dedicam à pesca</segment>
    <segment id="31">, à agricultura</segment>
    <segment id="32">, ao artesanato e ao turismo.  "</segment>
    <segment id="33">A mola é</segment>
    <segment id="34">comocomo uma bandeira para os gunas</segment>
    <segment id="35">, realmente há toda uma identidade cultural que</segment>
    <segment id="36">sese articula ao redor da mola.</segment>
    <segment id="37">É um elemento identitário muito forte"</segment>
    <segment id="38">, disse à AFP a professora de antropologia social na Universidade de Barcelona</segment>
    <segment id="39">, Mónica Martínez.</segment>
    <segment id="40">Os gunas afirmam que a lei panamenha reconhece a mola</segment>
    <segment id="41">comocomo propriedade intelectual deles</segment>
    <segment id="42">, portanto exigem que a Nike os compense por utilizar o desenho sem sua permissão.</segment>
    <segment id="43">"</segment>
    <segment id="44">Já mandamos uma nota de protesto à empresa Nike"</segment>
    <segment id="45">, afirmou</segment>
    <segment id="46">Valiente à imprensa</segment>
  </rst>
</analysis>