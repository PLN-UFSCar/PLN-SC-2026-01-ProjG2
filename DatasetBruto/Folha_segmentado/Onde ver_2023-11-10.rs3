  <rst>
    <segment id="1">Lançado em 1970</segment>
    <segment id="2">, o livro "Ei</segment>
    <segment id="3">, Deus</segment>
    <segment id="4">, Está Aí?</segment>
    <segment id="5">Sou Eu</segment>
    <segment id="6">, a Margaret"</segment>
    <segment id="7">, sese tornou um best-seller para muitas gerações.</segment>
    <segment id="8">Na trama</segment>
    <segment id="9">, uma garota de 11 anos</segment>
    <segment id="10">sese muda para uma nova cidade e conta com o apoio da mãe</segment>
    <segment id="11">, da avó e das amigas para enfrentar a chegada da adolescência.</segment>
    <segment id="12">Cena do filme &amp;#039</segment>
    <segment id="13">;Crescendo Juntas&amp;#039</segment>
    <segment id="14">;, de Kelly Fremon Craig - Divulgação</segment>
    <segment id="15">Agora finalmente a história é adaptada para o cinema em 'Crescendo Juntas'</segment>
    <segment id="16">, com Rachel McAdams</segment>
    <segment id="17">, Benny Safdie e Kathy Bates no elenco e direção de Kelly Fremon Craig.</segment>
    <segment id="18">HBO, 22h</segment>
    <segment id="19">Romanceiro  Duas crianças indefesas são perseguidas por pessoas que as acusam de assassinato</segment>
    <segment id="20">, e também por criaturas sobrenaturais.</segment>
    <segment id="21">Minissérie espanhola em seis episódios.  Amazon Prime Video</segment>
    <segment id="22">, 16 anos   Penso em Ti  Nesta novela mexicana</segment>
    <segment id="23">, Dulce María vive uma jovem que sonha em ser cantora e compositora.</segment>
    <segment id="24">Para isso</segment>
    <segment id="25">, ela conta com a ajuda de um astro da música</segment>
    <segment id="26">, que se</segment>
    <segment id="27">se apaixona por ela.</segment>
    <segment id="28">Globoplay</segment>
    <segment id="29">, 12 anos</segment>
    <segment id="30">SP2  Estreia da segunda temporada da série "Memórias Negras"</segment>
    <segment id="31">, em que a repórter Mariana Aldano percorre regiões da Grande São Paulo que contribuíram para a história da cidade por meio de sua população negra.</segment>
    <segment id="32">Quatro reportagens ao todo</segment>
    <segment id="33">, exibidas em sábados consecutivos.</segment>
    <segment id="34">Globo, 19h20</segment>
    <segment id="35">, livre</segment>
    <segment id="36">Carlos</segment>
    <segment id="37">, O Chacal  Por décadas</segment>
    <segment id="38">, o venezuelano Ilich Ramírez Sánchez</segment>
    <segment id="39">, apelidado de Chacal pela imprensa</segment>
    <segment id="40">, sese envolveu em atentados políticos na Europa.</segment>
    <segment id="41">A minissérie de Olivier Assayas é condensada neste longa</segment>
    <segment id="42">, estrelado por Edgar Ramírez.</segment>
    <segment id="43">A&amp;amp;E</segment>
    <segment id="44">, 21h, 16 anos</segment>
    <segment id="45">Eneida</segment>
    <segment id="46">A cineasta Heloísa Passos registra</segment>
    <segment id="47">, neste documentário</segment>
    <segment id="48">, a tentativa de sua mãe para</segment>
    <segment id="49">sese reconciliar com a filha mais velha</segment>
    <segment id="50">, que não vê há mais de 20 anos.</segment>
    <segment id="51">O longa foi rodado em Portugal e no Brasil.</segment>
    <segment id="52">Veja cenas do documentário &amp;#039</segment>
    <segment id="53">;Eneida&amp;#039</segment>
    <segment id="54">;Mais    novamente         de   de  de  representando um  CineBrasilTV</segment>
