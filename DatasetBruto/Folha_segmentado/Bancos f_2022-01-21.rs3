  <rst>
    <segment id="1">O aniversário da cidade de São Paulo</segment>
    <segment id="2">, que acontece nesta terça (25)</segment>
    <segment id="3">, praticamente não afetará os serviços públicos no município</segment>
    <segment id="4">, oferecidos pelo governo estadual e pela prefeitura.</segment>
    <segment id="5">O funcionamento de shoppings e agências bancárias também não será alterado.</segment>
    <segment id="6">A gestão Ricardo Nunes (MDB) informa que não funcionarão na data UBSs (Unidades Básicas de Saúde)</segment>
    <segment id="7">, Caps 2 (Centros de Atenção Psicossocial)</segment>
    <segment id="8">, Ceccos (Centros de Convivência e Cooperativa)</segment>
    <segment id="9">, CERs (Centros Especializados em Reabilitação) e unidades especializadas em infecções sexualmente transmissíveis</segment>
    <segment id="10">, da mesma forma que hospitais públicos veterinários.</segment>
    <segment id="11">Os demais serviços de saúde</segment>
    <segment id="12">, incluindo AMAs/UBSs integradas</segment>
    <segment id="13">, realizarão atendimento normalmente</segment>
    <segment id="14">, acrescentou a prefeitura.</segment>
    <segment id="15">Ponte Estaiada Jornalista Octávio Frias de Oliveira</segment>
    <segment id="16">, na zona sul</segment>
    <segment id="17">, um dos cartões postais da capital paulista   - Rivaldo Gomes/11 mai.2020/FolhapressO rodízio de veículos deixa de valer na véspera do aniversário da cidade</segment>
    <segment id="18">, da mesma forma que na data comemorativa</segment>
    <segment id="19">, para veículos de passeio.</segment>
    <segment id="20">Ele continua valendo para caminhões e demais veículos de grande porte.</segment>
    <segment id="21">Na quarta-feira (26) motoristas com placas finais 5 e 6 devem ficar alertas</segment>
    <segment id="22">, pois</segment>
    <segment id="23">pois a regra volta a valer das 7h às 10h e das 17h às 20h.</segment>
    <segment id="24">O governador Joao Doria (PSDB) assinou um decreto</segment>
    <segment id="25">, publicado nesta sexta-feira (21) no Diário Oficial</segment>
    <segment id="26">, em que determina que a data será ponto facultativo.</segment>
    <segment id="27">Isso ocorre pelo fato de o então prefeito Bruno Covas (PSDB) ter antecipado o recesso</segment>
    <segment id="28">, em março do ano passado</segment>
    <segment id="29">, com mais outros quatro feriados</segment>
    <segment id="30">, como</segment>
    <segment id="31">como medida preventiva à pandemia do coronavírus.</segment>
    <segment id="32">De acordo com a Secretaria Estadual da Saúde</segment>
    <segment id="33">, não farão atendimento no dia 25 o CRI (Centro de Referência ao Idoso) Norte</segment>
    <segment id="34">, o IPGG (Instituto Paulista de Geriatria e Gerontologia)</segment>
    <segment id="35">, as AMEs (Ambulatórios Médicos de Especialidades)</segment>
    <segment id="36">, assim</segment>
    <segment id="37">comocomo parte das farmácias de medicamentos especializados e Dose Certa.</segment>
    <segment id="38">Irão entregar medicamentos</segment>
    <segment id="39">, no feriado da capital</segment>
    <segment id="40">, as Farmácias do AME Maria Zélia</segment>
    <segment id="41">, Hospital das Clínicas</segment>
    <segment id="42">, Geraldo Bourroul e Vila Mariana.</segment>
    <segment id="43">As demais unidades</segment>
    <segment id="44">, Várzea do Carmo</segment>
    <segment id="45">, Heliópolis</segment>
    <segment id="46">, Instituto Dante Pazzanese e Instituto de Infectologia Emílio Ribas</segment>
    <segment id="47">, estarão fechadas no feriado.</segment>
    <segment id="48">O Poupatempo irá funcionar normalmente.</segment>
    <segment id="49">Para atendimento presencial</segment>
    <segment id="50">, é necessário marcar antecipadamente horário por meio do site ou pelo aplicativo.</segment>
    <segment id="51">As agências do INSS em São Paulo funcionam também normalmente na terça-feira.</segment>
    <segment id="52">Para ser atendido</segment>
    <segment id="53">, é necessário agendar pela internet</segment>
    <segment id="54">, pelo aplicativo</segment>
    <segment id="55">Meu INSS ou pelo telefone 135.</segment>
    <segment id="56">Já serviços ligados ao Detran podem ser feitos de forma online</segment>
    <segment id="57">, como</segment>
    <segment id="58">como renovação de CNH (carteira de habilitação)</segment>
    <segment id="59">, licenciamento de veículos e consulta de IPVA.</segment>
    <segment id="60">O Procon também irá manter o atendimento presencial.</segment>
    <segment id="61">Aniversário triste da capitalMais    novamente         de   de  de  representando um</segment>
    <segment id="62">O transporte público terá algumas mudanças.</segment>
    <segment id="63">A CPTM (Companhia Paulista de Trens Metropolitanos) trabalhará com maior intervalo entre os trens</segment>
    <segment id="64">, como</segment>
    <segment id="65">como ocorre aos finais de semana.</segment>
    <segment id="66">Já o Metrô funcionará entre as 4h40 e a meia-noite</segment>
    <segment id="67">, como</segment>
    <segment id="68">como ocorre aos domingos.</segment>
    <segment id="69">Os postos de atendimento da SPTrans funcionam normalmente no feriado</segment>
    <segment id="70">, das 6h às 22h</segment>
    <segment id="71">, com exceção das lojas Augusta (centro)</segment>
    <segment id="72">, Jabaquara (zona sul)</segment>
    <segment id="73">, Santana (zona norte) e Posto Central.</segment>
    <segment id="74">Também funcionarão no feriado agências dos Correios</segment>
    <segment id="75">, agências bancárias e shopping centers.            Serviço Segunda-feira (24) Terça-feira (25)</segment>
    <segment id="76">Bancos Abre Abre     Sabesp Abre Abre     Correios Abre Abre     Procon Abre Abre     Poupatempo Abre Abre     Enel</segment>
    <segment id="77">Abre Abre</segment>
    <segment id="78">Agências INSS</segment>
    <segment id="79">Abre Abre</segment>
    <segment id="80">Hospitais municipais</segment>
    <segment id="81">Abre Abre     Prontos-socorros Abre Abre</segment>
    <segment id="82">AMAs 24h</segment>
    <segment id="83">Abre Abre     AMAs/UBSs integradas</segment>
    <segment id="84">Abre Abre     Ambulatórios de especialidades</segment>
    <segment id="85">Abre Abre     AMA especialidades e Hospitais Dia Abre Abre     UPAs</segment>
    <segment id="86">Abre Abre</segment>
