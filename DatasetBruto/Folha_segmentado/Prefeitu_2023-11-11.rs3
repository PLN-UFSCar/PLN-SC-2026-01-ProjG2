  <rst>
    <segment id="1">A Prefeitura de São Paulo e a Federação Paulista de Futebol (FPF) irão promover a primeira edição da Copa São Paulo de Futebol Júnior Feminina</segment>
    <segment id="2">, que acontecerá de 4 a 17 de dezembro de 2023.</segment>
    <segment id="3">Para a realização do evento</segment>
    <segment id="4">, a administração municipal investiu cerca de R$ 3</segment>
    <segment id="5">,5 milhões.</segment>
    <segment id="6">Ao apoiar a realização do torneio na versão feminina</segment>
    <segment id="7">, a Prefeitura consolida seu objetivo de dar oportunidades para todos e de trazer cada vez mais as mulheres para a prática esportiva.</segment>
    <segment id="8">O torneio terá participação de 16 equipes de várias cidades e estados</segment>
    <segment id="9">, que serão divididas em quatro grupos.</segment>
    <segment id="10">Equipes do mesmo estado não podem</segment>
    <segment id="11">sese enfrentar na fase de grupos.</segment>
    <segment id="12">De acordo com o site da FPF</segment>
    <segment id="13">, os grupos da competição estão assim estabelecidos:</segment>
    <segment id="14">Grupo A: Botafogo-PB</segment>
    <segment id="15">, Grêmio-RS</segment>
    <segment id="16">, Flamengo-RJ e Santos Grupo B: Vitória-BA</segment>
    <segment id="17">, Minas Brasília-DF</segment>
    <segment id="18">, Internacional-RS e Ferroviária Grupo C: América-MG</segment>
    <segment id="19">, Real Brasília-DF</segment>
    <segment id="20">, Fluminense-RJ e São Paulo Grupo D: Fortaleza-CE</segment>
    <segment id="21">, Atlético-MG</segment>
    <segment id="22">, Botafogo-RJ e Corinthians</segment>
    <segment id="23">Ainda de acordo com a federação</segment>
    <segment id="24">, as partidas do Grupo</segment>
    <segment id="25">A</segment>
    <segment id="26">serão no estádio</segment>
    <segment id="27">Oswaldo Teixeira Duarte</segment>
    <segment id="28">, o Canindé.</segment>
    <segment id="29">As do Grupo B</segment>
    <segment id="30">, no estádio Nicolau Alayon</segment>
    <segment id="31">, na rua Comendador Sousa</segment>
    <segment id="32">, na Água Branca.</segment>
    <segment id="33">Do C, no estádio Conde Rodolfo Crespi</segment>
    <segment id="34">, na rua Javari.</segment>
    <segment id="35">As do D</segment>
    <segment id="36">, na Ibrachina Arena</segment>
    <segment id="37">, na rua Borges de Figueiredo</segment>
    <segment id="38">, Mooca.</segment>
    <segment id="39">Treino de equipe de torneio feminino de junho deste ano</segment>
    <segment id="40">; em dezembro</segment>
    <segment id="41">, Copa São Paulo de Futebol Júnior Feminina terá participação de 16 equipes - Felipe Evers/SECOMREPARAÇÃO</segment>
    <segment id="42">Proibidas de jogar futebol por 40 anos</segment>
    <segment id="43">, as mulheres vêm ganhando cada vez mais protagonismo.</segment>
    <segment id="44">A atual edição do Campeonato Paulista</segment>
    <segment id="45">, por exemplo</segment>
    <segment id="46">, distribuirá R$ 3</segment>
    <segment id="47">,1 milhões em premiações.</segment>
    <segment id="48">A primeira edição do Campeonato Paulista Feminino só foi realizada em 1987</segment>
    <segment id="49">, 85 anos depois do masculino.</segment>
    <segment id="50">Hoje, há mais de 500 meninas</segment>
    <segment id="51">, adolescentes e mulheres jogando futebol nos campeonatos realizados em São Paulo.</segment>
    <segment id="52">As competições femininas também estão atraindo mais público.</segment>
    <segment id="53">Mais de 4</segment>
    <segment id="54">,8 milhões de pessoas acompanharam a final da edição de 2022 do Paulistão Feminino pela televisão e outras 20.071 assistiram à partida entre Palmeiras e Santos do estádio.</segment>
    <segment id="55">A cidade de São Paulo já realiza</segment>
    <segment id="56">, desde 1969</segment>
    <segment id="57">, a Copa São Paulo de Futebol Júnior Masculino</segment>
    <segment id="58">, também conhecida</segment>
    <segment id="59">comocomo Copinha</segment>
    <segment id="60">, que é considerada a maior competição de base do mundo.</segment>
    <segment id="61">*</segment>
    <segment id="62">Conteúdo patrocinado produzido pelo Estúdio Folha.</segment>
  </rst>
</analysis>