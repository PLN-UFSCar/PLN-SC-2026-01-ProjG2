  <rst>
    <segment id="1">O brexit segue sua trajetória de jornada sem fim.</segment>
    <segment id="2">Pela terceira vez</segment>
    <segment id="3">, o prazo de saída do Reino Unido da União Europeia foi adiado.</segment>
    <segment id="4">De 31 de outubro</segment>
    <segment id="5">, passou para 31 de janeiro de 2020.</segment>
    <segment id="6">"</segment>
    <segment id="7">Os 27 [países-membros] concordaram em aceitar a solicitação do Reino Unido de um adiamento flexível do brexit até 31 de janeiro"</segment>
    <segment id="8">, escreveu o presidente do Conselho Europeu</segment>
    <segment id="9">, Donald Tusk</segment>
    <segment id="10">, no Twitter.</segment>
    <segment id="11">Ele explicou que a decisão</segment>
    <segment id="12">, adotada pelos embaixadores dos países em Bruxelas</segment>
    <segment id="13">, deve ser formalizada por escrito.</segment>
    <segment id="14">Uma proposta do premiê Boris Johnson de realizar eleições até o fim de 2019</segment>
    <segment id="15">, porém</segment>
    <segment id="16">porém, acabou rejeitada pelos deputados</segment>
    <segment id="17">, mantendo assim a atual situação de impasse na Casa.</segment>
    <segment id="18">O primeiro-ministro britânico</segment>
    <segment id="19">, Boris Johnson - Tolga Akmen - 23.out.19/AFP</segment>
    <segment id="20">A extensão flexível</segment>
    <segment id="21">, apelidada de "flextension"</segment>
    <segment id="22">, permite ao Reino Unido deixar o bloco antes do prazo marcado</segment>
    <segment id="23">, masmas para isso é preciso que o Parlamento britânico aprove um acordo de saída.</segment>
    <segment id="24">Os parlamentares já recusaram diversas versões desse documento.</segment>
    <segment id="25">Um acordo feito pelo primeiro-ministro do Reino Unido</segment>
    <segment id="26">, Boris Johnson</segment>
    <segment id="27">, com a UE está em análise pelos parlamentares.</segment>
    <segment id="28">Eles, no entanto</segment>
    <segment id="29">, recusaram-</segment>
    <segment id="30">sese a votar o tema de forma expressa</segment>
    <segment id="31">, como</segment>
    <segment id="32">como queria o premiê.</segment>
    <segment id="33">Com isso</segment>
    <segment id="34">, afasta-</segment>
    <segment id="35">sese por ora o temor de uma saída sem acordo</segment>
    <segment id="36">, algo que foi considerado por Boris e que poderia trazer graves problemas para a economia e a vida no país.</segment>
    <segment id="37">O adiamento é mais uma derrota para o primeiro-ministro.</segment>
    <segment id="38">Ele disse repetidas vezes que não pediria uma nova extensão do prazo</segment>
    <segment id="39">, masmas foi forçado a fazer isso por uma lei aprovada no Parlamento britânico.</segment>
    <segment id="40">Pouco após o anúncio da UE</segment>
    <segment id="41">, os deputados votaram a proposta do governo para antecipar as eleições para 12 de dezembro.</segment>
    <segment id="42">Para aprovar o novo pleito eram necessários 434 votos (o equivalente a dois terços do Parlamento)</segment>
    <segment id="43">, masmas o projeto recebeu só 299 votos a favor e 70 contrários —a maior parte da oposição trabalhista</segment>
    <segment id="44">sese absteve.</segment>
    <segment id="45">Isso porque</segment>
    <segment id="46">porque o pedido de novas eleições foi feito por meio de uma legislação específica sobre esse assunto</segment>
    <segment id="47">, que exige um quórum qualificado para ser aprovado.</segment>
    <segment id="48">Mas com a derrota</segment>
    <segment id="49">, Boris anunciou que vai propor um projeto de lei simples para modificar essa legislação e convocar uma eleição em 12 de dezembro.</segment>
    <segment id="50">Nesse caso</segment>
    <segment id="51">caso, a proposta poderá ser aprovada por maioria simples</segment>
    <segment id="52">, sem a necessidade do apoio de dois terços dos deputados.</segment>
    <segment id="53">Mas o caminho legislativo para isso é um pouco mais longo</segment>
    <segment id="54">, já que o projeto precisará passar pelas comissões do Parlamento e pela Câmara dos Lordes.</segment>
    <segment id="55">A trajetória de Boris Johnson   novamente         de   de  de  representando um</segment>
    <segment id="56">O objetivo do governo é votar a proposta já nesta terça (29)</segment>
    <segment id="57">, masmas ainda há dúvidas sobre a viabilidade da medida.</segment>
    <segment id="58">​​Boris espera que uma votação expressiva nas urnas dê poderes a ele para aprovar o acordo de saída no Parlamento</segment>
    <segment id="59">, missão na qual teve seguidas derrotas nos últimos meses.</segment>
    <segment id="60">Sua antecessora</segment>
    <segment id="61">, Theresa May</segment>
    <segment id="62">, também fracassou.</segment>
    <segment id="63">Ele já tentou obter os votos para uma eleição geral</segment>
    <segment id="64">outras duas vezes</segment>
    <segment id="65">, masmas falhou em ambas</segment>
    <segment id="66">, ao não atingir o apoio dos parlamentares.</segment>
    <segment id="67">O brexit foi aprovado em votação popular em junho de 2016 e</segment>
    <segment id="68">, desde então</segment>
    <segment id="69">, Reino Unido e União Europeia debatem</segment>
    <segment id="70">comocomo e</segment>
    <segment id="71">sese devem colocá-lo em prática.</segment>
    <segment id="72">Em 40 meses</segment>
    <segment id="73">, as respostas ainda não foram encontradas.</segment>
    <segment id="74">Os atrasos do brexit  29.mar.19  No dia 23 de março de 2017 o Reino Unido formalizou o pedido para a União Europeia de que iria sair do bloco e o divórcio foi marcado para dois anos depois.</segment>
    <segment id="75">Durante esse tempo</segment>
    <segment id="76">, a então primeira-ministra Theresa May negociou com Bruxelas um acordo de saída</segment>
    <segment id="77">, masmas ele acabou derrubado pelo Parlamento britânico no início de 2019.</segment>
    <segment id="78">Sem alternativa</segment>
    <segment id="79">, ela pediu o primeiro adiamento.   12.abr.19 (ou 22.mai.19)</segment>
    <segment id="80">No melhor estilo brexit</segment>
    <segment id="81">, a UE estendeu o prazo para duas datas diferentes.</segment>
    <segment id="82">Se o Parlamento britânico aprovasse o acordo do brexit até o início de abril</segment>
    <segment id="83">, os dois lados teriam até 22 de maio para acertar os detalhes.</segment>
    <segment id="84">Caso isso não acontecesse</segment>
    <segment id="85">, a saída seria em 12 de abril.</segment>
    <segment id="86">Mas no fim nada deu certo e o prazo foi adiado de novo  31.out.19</segment>
    <segment id="87">May pediu um adiamento apenas até 30 de junho</segment>
    <segment id="88">, masmas a UE deu um prazo ainda maior</segment>
    <segment id="89">, já temendo novos problemas.</segment>
    <segment id="90">Neste meio tempo</segment>
    <segment id="91">, ela foi substituída por Boris Johnson</segment>
    <segment id="92">, que assumiu prometendo que não pediria um novo adiamento e renegociou o acordo com o bloco.</segment>
    <segment id="93">O Parlamento britânico</segment>
    <segment id="94">, porém</segment>
    <segment id="95">porém, novamente vetou o projeto e ainda proibiu uma saída sem acordo</segment>
    <segment id="96">, obrigando o premiê a descumprir sua promessa.</segment>
    <segment id="97">31.jan.20  ​O novo prazo dado pela UE</segment>
    <segment id="98">, após pedido de Boris</segment>
    <segment id="99">, ganhou o apelido de "flextension".</segment>
    <segment id="100">Isso porque</segment>
    <segment id="101">porque</segment>
    <segment id="102">casocaso os deputados aprovem o acordo com o bloco antes da data final</segment>
    <segment id="103">, a saída pode ser antecipada.</segment>
  </rst>
</analysis>