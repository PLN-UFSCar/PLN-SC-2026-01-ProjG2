  <rst>
    <segment id="1">Foi o longa "</segment>
    <segment id="2">Nosso Sonho"</segment>
    <segment id="3">, sobre a dupla de funkeiros Claudinho e Buchecha</segment>
    <segment id="4">, encarnada pelos atores Juan Paiva e Lucas Penteado</segment>
    <segment id="5">, que levou mais brasileiros ao cinema em 2023.</segment>
    <segment id="6">Cena do filme &amp;#039</segment>
    <segment id="7">;Minha Irmã e Eu&amp;#039</segment>
    <segment id="8">;, de Susana Garcia - Ellen Soares/DivulgaçãoCerca de 521 mil pessoas foram às salas</segment>
    <segment id="9">, levando a um faturamento de R$ 8</segment>
    <segment id="10">,8 milhões para o filme</segment>
    <segment id="11">, segundo dados do Filme B</segment>
    <segment id="12">, site especializado no mercado audiovisual.</segment>
    <segment id="13">Mas a comédia "</segment>
    <segment id="14">Minha Irmã e Eu"</segment>
    <segment id="15">, com Tatá Werneck e Ingrid Guimarães</segment>
    <segment id="16">, que no final do ano passado levou apenas uma semana em cartaz para ocupar a terceira posição do ranking de filmes brasileiros mais vistos</segment>
    <segment id="17">, atraindo 277 mil pessoas às salas de cinema</segment>
    <segment id="18">, já ultrapassou "</segment>
    <segment id="19">Nosso Sonho"</segment>
    <segment id="20">na primeira semana de 2024</segment>
    <segment id="21">.</segment>
    <segment id="22">Veja cenas do filme &amp;#039</segment>
    <segment id="23">;Minha Irmã e Eu&amp;#039</segment>
    <segment id="24">;Mais    novamente         de   de  de  representando um</segment>
    <segment id="25">A comédia já foi vista por mais de 540 mil espectadores e arrecadou mais de R$ 10 milhões em bilheteria.</segment>
    <segment id="26">O longa estreou no dia 28 de dezembro em 1.017 salas de cinema em todo o país.</segment>
    <segment id="27">Veja imagens do filme &amp;#039</segment>
    <segment id="28">;Nosso Sonho&amp;#039</segment>
    <segment id="29">;Mais    novamente         de   de  de  representando um  Até dezembro</segment>
    <segment id="30">, o segundo filme mais visto de 2023</segment>
    <segment id="31">foi "</segment>
    <segment id="32">Os Aventureiros - A Origem"</segment>
    <segment id="33">, do influenciador Luccas Neto</segment>
    <segment id="34">, com um público total de 429 mil pessoas e faturamento de R$ 7</segment>
    <segment id="35">,5 milhões.</segment>
    <segment id="36">O ano teve muitas cinebiografias</segment>
    <segment id="37">, que representam quatro dos dez filmes mais vistos em 2023.</segment>
    <segment id="38">Além de "</segment>
    <segment id="39">Nosso Sonho"</segment>
    <segment id="40">, é o caso</segment>
    <segment id="41">caso de "Mussum</segment>
    <segment id="42">, O Filmis"</segment>
    <segment id="43">, sobre o comediante dos trapalhões</segment>
    <segment id="44">, "Mamonas Assassinas:</segment>
    <segment id="45">O Filme" e "</segment>
    <segment id="46">Meu Nome</segment>
    <segment id="47">É Gal"</segment>
    <segment id="48">, que levou Sophie Charlotte às telonas para interpretar o ícone da tropicália</segment>
    <segment id="49">, morta em 2022.</segment>
    <segment id="50">Imagens do filme</segment>
    <segment id="51">Meu Nome</segment>
    <segment id="52">é GalMais    novamente         de   de  de  representando um</segment>
    <segment id="53">Apesar dos bons números de "</segment>
    <segment id="54">Nosso Sonho"</segment>
    <segment id="55">, o diretor</segment>
    <segment id="56">, Eduardo Albergaria</segment>
    <segment id="57">, lamentou a queda do número de salas destinadas à produção depois da segunda semana em cartaz.</segment>
    <segment id="58">A cota de tela para produções nacionais foi aprovada apenas em dezembro</segment>
    <segment id="59">, quando o filme já havia saído de circulação e ainda precisa ser sancionada pelo Executivo para entrar em vigor.</segment>
    <segment id="60">Os números aumentam a esperança de que um filme brasileiro poderá superar</segment>
    <segment id="61">, em breve</segment>
    <segment id="62">, a marca de 1 milhão de espectadores</segment>
    <segment id="63">, recorde alcançado por "Minha Mãe É uma Peça 3"</segment>
    <segment id="64">, em 2019.</segment>
    <segment id="65">Confira a lista completa dos dez filmes nacionais mais vistos em 2023</segment>
    <segment id="66">, com os respectivos números de espectadores até o final do ano:   "</segment>
