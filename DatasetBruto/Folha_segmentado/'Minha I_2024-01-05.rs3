    <segment id="77">, O Filmis"</segment>
    <segment id="78">, de Sílvio Guindane</segment>
    <segment id="79">, 215 mil "</segment>
    <segment id="80">O Sequestro do Voo 375"</segment>
    <segment id="81">, de Marcus Baldini</segment>
    <segment id="82">, 198 mil "</segment>
    <segment id="83">Ó</segment>
