  <rst>
    <segment id="1">Os últimos meses foram agitados para Bobi</segment>
    <segment id="2">, um rafeiro do Alentejo que em fevereiro recebeu o título de cão mais velho do mundo pelo Guinness World Records.</segment>
    <segment id="3">No dia 11 passado</segment>
    <segment id="4">, o peludo completou 31 anos e ganhou festa com comida preferida</segment>
    <segment id="5">, música e bolo para os convidados.</segment>
    <segment id="6">Bobi mora em uma área rural de Leiria</segment>
    <segment id="7">, Portugal</segment>
    <segment id="8">, e não é apenas o cão mais idoso vivo</segment>
    <segment id="9">;</segment>
    <segment id="10">é o mais velho entre todos os registros do livro dos recordes.</segment>
    <segment id="11">Desde a comprovação do Guinness</segment>
    <segment id="12">, recebeu inúmeras visitas e posou para fotos.</segment>
    <segment id="13">Bobi comemora 31 anos - Bobiportugal no InstagramO tutor</segment>
    <segment id="14">, Leonel Costa</segment>
    <segment id="15">, 38, descreve Bobi</segment>
    <segment id="16">comocomo muito sociável.</segment>
    <segment id="17">No entanto</segment>
    <segment id="18">, devido à rotina movimentada nos últimos tempos</segment>
    <segment id="19">, levou o cachorro para um check-up recentemente.</segment>
    <segment id="20">Ao livro dos recordes</segment>
    <segment id="21">, antes da festa</segment>
    <segment id="22">, afirmou que esperava cerca de cem pessoas</segment>
    <segment id="23">, algumas até do exterior.</segment>
    <segment id="24">Os pratos para o evento</segment>
    <segment id="25">, que incluíram peixes e carnes</segment>
    <segment id="26">, também foram pensados em Bobi</segment>
    <segment id="27">, que não come ração.</segment>
    <segment id="28">Imagens compartilhadas em um perfil criado em rede social em homenagem ao cachorro mostram que a festança</segment>
    <segment id="29">, ocorrida dia 13</segment>
    <segment id="30">, contou com música e dança típica</segment>
    <segment id="31">, um bolo com estampa de Bobi e o tradicional "</segment>
    <segment id="32">Parabéns a Você".</segment>
    <segment id="33">Fotos também mostram que o idosinho parecia não</segment>
    <segment id="34">sese incomodar com a movimentação e até dormiu em certo momento.</segment>
    <segment id="35">Ao Guinness o tutor atribui a longevidade ao ambiente tranquilo em que Bobi vive.</segment>
    <segment id="36">Contou que</segment>
    <segment id="37">, por causa da idade</segment>
    <segment id="38">, o cachorro agora prefere ficar mais em casa</segment>
    <segment id="39">, em vez de explorar a região.</segment>
    <segment id="40">A audição já não é tão boa</segment>
    <segment id="41">, assim</segment>
    <segment id="42">comocomo a visão —por isso às vezes ele esbarra em objetos enquanto caminha.</segment>
    <segment id="43">Segundo a publicação</segment>
    <segment id="44">, a data de nascimento de Bobi foi confirmada pelo serviço médico veterinário do município e também verificada pelo banco de dados do Siac (Sistema de Informação de Animais de Companhia) de Portugal.</segment>
    <segment id="45">A expectativa de vida da raça</segment>
    <segment id="46">, de guarda de rebanho</segment>
    <segment id="47">, fica entre 12 e 14 anos.</segment>
    <segment id="48">Antes, o título de cachorro mais velho de todos os tempos era do pastor australiano Bluey</segment>
    <segment id="49">, que morreu em 14 de novembro de 1939</segment>
    <segment id="50">, aos 29 anos e 5 meses.</segment>
    <segment id="51">Veja imagens do cãozinho BobiMais    novamente         de   de  de  representando um  +</segment>
    <segment id="52">Bom</segment>
    <segment id="53">Pra CachorroMãe de pet também é mãe?</segment>
    <segment id="54">Leia relatosMunicípio pode proibir fogos de artifício barulhentos</segment>
    <segment id="55">, decide STFSnoopy na vida real?</segment>
    <segment id="56">Pet chama atenção por semelhança com personagemSiga o Bom</segment>
    <segment id="57">Pra</segment>
    <segment id="58">Cachorro</segment>
    <segment id="59">no Twitter</segment>
    <segment id="60">, Instagram e Facebook</segment>
  </rst>
