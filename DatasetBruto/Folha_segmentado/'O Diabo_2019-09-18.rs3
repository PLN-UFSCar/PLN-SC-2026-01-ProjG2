  <rst>
    <segment id="1">Uma versão musical do livro “</segment>
    <segment id="2">O Diabo</segment>
    <segment id="3">Veste Prada”</segment>
    <segment id="4">, de Lauren Weisberger</segment>
    <segment id="5">, está programada para estrear em Chicago em julho de 2020</segment>
    <segment id="6">, antes de chegar à Broadway.</segment>
    <segment id="7">Com músicas originais de Elton John</segment>
    <segment id="8">, o espetáculo também será inspirado no filme homônimo de 2006</segment>
    <segment id="9">, sobre uma jornalista que começa a trabalhar em uma revista de moda.</segment>
