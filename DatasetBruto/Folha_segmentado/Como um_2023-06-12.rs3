  <rst>
    <segment id="1">Era a hora do rush da manhã em Tóquio.</segment>
    <segment id="2">O trem estava lotado e balançando.</segment>
    <segment id="3">A jovem Takako (nome fictício) estava a caminho da escola.</segment>
    <segment id="4">A garota de 15 anos tentava</segment>
    <segment id="5">sese segurar no trem.</segment>
    <segment id="6">De repente</segment>
    <segment id="7">, ela sentiu uma mão apertando seu corpo por trás.</segment>
    <segment id="8">Ela pensou que alguém havia esbarrado por acidente.</segment>
    <segment id="9">Mas a mão começou a apalpá-la.</segment>
    <segment id="10">"</segment>
    <segment id="11">Foi quando finalmente percebi —era abuso sexual"</segment>
    <segment id="12">, lembra Takako.</segment>
    <segment id="13">A mão desapareceu rapidamente na multidão.</segment>
    <segment id="14">"</segment>
    <segment id="15">Eu não podia fazer mais nada a respeito.</segment>
    <segment id="16">"</segment>
    <segment id="17">Ela chegou à escola aos prantos naquele dia.</segment>
    <segment id="18">Takako.</segment>
    <segment id="19">que foi agredida sexualmente muitas vezes quando adolescente</segment>
    <segment id="20">, usa um adesivo que adverte sobre possíveis agressores - Noriko HayashiEssa foi a primeira vez que ela foi abusada sexualmente no transporte público.</segment>
    <segment id="21">Mas depois disso Takako foi molestada quase que diariamente por mais de um ano em seu trajeto.</segment>
    <segment id="22">Em inúmeras noites</segment>
    <segment id="23">, ela foi dormir chorando.</segment>
    <segment id="24">"</segment>
    <segment id="25">Senti que não havia esperança na minha vida"</segment>
    <segment id="26">, diz ela.</segment>
    <segment id="27">Muitas mulheres e meninas</segment>
    <segment id="28">comocomo Takako são visadas em público por predadores sexuais.</segment>
    <segment id="29">Em alguns casos</segment>
    <segment id="30">, elas enfrentam outro assédio —o ataque é filmado e os vídeos são vendidos online.</segment>
    <segment id="31">A maioria dos vídeos segue o mesmo padrão: um homem filma secretamente uma mulher por trás e segue ela até um trem.</segment>
    <segment id="32">Segundos depois</segment>
    <segment id="33">, ele abusa sexualmente dela.</segment>
    <segment id="34">Os homens agem discretamente e suas vítimas nem percebem que estão sendo seguidas.</segment>
    <segment id="35">Esses vídeos são colocados à venda em sites.</segment>
    <segment id="36">Em uma investigação que durou um ano</segment>
    <segment id="37">, a BBC rastreou os homens por trás de três sites que vendem e produzem milhares desses vídeos de agressão sexual.</segment>
    <segment id="38">Uma epidemia no Japão  Sofrendo com abuso sexual quase diariamente</segment>
    <segment id="39">, Takako não conseguiu reagir durante o assédio devido ao medo e à vergonha.</segment>
    <segment id="40">Mas todas as noites ela cobria a boca com uma toalha e falava na frente do espelho</segment>
    <segment id="41">comocomo</segment>
    <segment id="42">sese tivesse gritando contra um assediador: "</segment>
    <segment id="43">Essa pessoa é um chikan!</segment>
    <segment id="44">"  "</segment>
    <segment id="45">Chikan" é um termo japonês que descreve agressão sexual em público</segment>
    <segment id="46">, especialmente no transporte público.</segment>
    <segment id="47">Também descreve os próprios infratores.</segment>
    <segment id="48">Os perpetradores "chikan" geralmente</segment>
    <segment id="49">sese aproveitam das multidões e do medo das vítimas de provocar um escândalo.</segment>
    <segment id="50">No Japão</segment>
    <segment id="51">, falar muito direta e abertamente pode ser visto</segment>
    <segment id="52">comocomo grosseria.</segment>
    <segment id="53">Milhares de detenções são feitas todos os anos por crimes "chikan"</segment>
    <segment id="54">, masmas muitos assédios passam despercebidos e impunes.</segment>
    <segment id="55">Saito Akiyoshi</segment>
    <segment id="56">, profissional de saúde mental e autor de um livro sobre o tema</segment>
    <segment id="57">, diz que apenas cerca de 10% das vítimas denunciam o crime.</segment>
    <segment id="58">Sites de 'chikan'</segment>
    <segment id="59">Um site em chinês chamado DingBuZhu (que significa "não consigo segurar" em chinês) imediatamente chamou nossa atenção.</segment>
    <segment id="60">É um mercado para vídeos</segment>
    <segment id="61">"chikan" filmados secretamente em telefones celulares em locais públicos lotados</segment>
    <segment id="62">, como</segment>
    <segment id="63">como trens e ônibus.</segment>
    <segment id="64">Eles são filmados em todo o leste da Ásia</segment>
    <segment id="65">, incluindo Japão</segment>
    <segment id="66">, Coreia do Sul</segment>
    <segment id="67">, Taiwan</segment>
    <segment id="68">, Hong Kong e China.</segment>
    <segment id="69">Alguns vídeos custam menos de um dólar.</segment>
    <segment id="70">Antigamente</segment>
    <segment id="71">, o site permitia que os usuários encomendassem vídeos de abuso feitos "sob medida".</segment>
    <segment id="72">Também encontramos links no DingBuZhu para dois outros sites —Chihan e Jieshe— com o mesmo tipo de conteúdo.</segment>
    <segment id="73">Há um grupo no Telegram com 4.000 membros que compartilham dicas sobre</segment>
    <segment id="74">comocomo abusar sexualmente de mulheres.</segment>
    <segment id="75">Um nome continuou aparecendo nesses sites: "</segment>
    <segment id="76">Uncle Qi" ("</segment>
    <segment id="77">Tio</segment>
    <segment id="78">Qi</segment>
    <segment id="79">")</segment>
    <segment id="80">.</segment>
    <segment id="81">Ele foi aclamado</segment>
    <segment id="82">comocomo o guru nesta comunidade.</segment>
    <segment id="83">Dezenas de vídeos de abuso foram rotulados</segment>
    <segment id="84">comocomo seu trabalho.</segment>
    <segment id="85">No Twitter</segment>
    <segment id="86">, ele colocou teasers dos vídeos dos sites para seus 80 mil seguidores.</segment>
    <segment id="87">Mas quem é ele?</segment>
    <segment id="88">O grupo do Telegram que estávamos monitorando revelou uma pista.</segment>
    <segment id="89">Um dia</segment>
    <segment id="90">, um administrador alegou em uma série de mensagens que havia abusado de uma mulher junto com o Tio Qi.</segment>
    <segment id="91">As mensagens eram acompanhadas por fotos de uma mulher parada no que parecia ser uma plataforma de metrô.</segment>
    <segment id="92">Em poucas horas</segment>
    <segment id="93">, encontramos uma correspondência para o local —a estação Ikebukuro em Tóquio.</segment>
    <segment id="94">Tang Zhuoran (conhecido</segment>
    <segment id="95">comocomo Maomi) é o responsável por sites de vídeos de homens assediando mulheres - BBCE havia mais pistas apontando para o Japão.</segment>
    <segment id="96">Os sites listavam uma conta Paypal em ienes japoneses que estava vinculada a um endereço de Gmail.</segment>
    <segment id="97">Quando colocamos o endereço no Google Contacts</segment>
    <segment id="98">, a foto do perfil que apareceu era a de um jovem com penteado elaborado e maquiagem teatral.</segment>
    <segment id="99">Uma pesquisa de imagem reversa revelou um nom: Noctis Zang</segment>
    <segment id="100">, um cantor chinês de 30 anos que mora em Tóquio.</segment>
    <segment id="101">Ele era vocalista de uma banda de metal chamada The Versus.</segment>
    <segment id="102">Noctis tinha uma imagem pública de glamour</segment>
    <segment id="103">, masmas logo descobrimos algo estranho por trás disso.</segment>
    <segment id="104">No início de 2022</segment>
    <segment id="105">, o fotógrafo do grupo The Versus alegou na plataforma de mídia social chinesa Weibo que Noctis havia criado "sites pornográficos</segment>
    <segment id="106">" ao lado de outro membro da banda</segment>
    <segment id="107">, Lupus Fu.</segment>
    <segment id="108">Ele havia postado fotos de um notebook</segment>
    <segment id="109">, que mostravam algumas imagens semelhantes às dos sites.</segment>
    <segment id="110">O fotógrafo também postou um vídeo que parecia mostrar o histórico de navegação de Noctis</segment>
    <segment id="111">, com links para Chihan</segment>
    <segment id="112">, Jieshe e as páginas de administração do DingBuZhu.</segment>
    <segment id="113">Seria este cantor de rock o verdadeiro Tio Qi?</segment>
    <segment id="114">Desmascarando os administradores dos sites  Fazendo-</segment>
    <segment id="115">sese passar por um caçador de talentos musicais chamado Ian</segment>
    <segment id="116">, nosso jornalista disfarçado</segment>
    <segment id="117">sese encontrou com Noctis em um sofisticado bar em uma cobertura em Tóquio.</segment>
    <segment id="118">Eles conversaram primeiro sobre música</segment>
    <segment id="119">, masmas o papo mudou para o assunto sexo.</segment>
    <segment id="120">Quando Ian disse que sua empresa fazia filmes pornôs</segment>
    <segment id="121">, os olhos de Noctis brilharam.</segment>
    <segment id="122">Os dois</segment>
    <segment id="123">sese encontraram várias vezes e até comemoraram o aniversário de Noctis juntos.</segment>
    <segment id="124">Noctis apresentou Ian a seu companheiro de banda Lupus Fu</segment>
    <segment id="125">, cujo nome havia sido mencionado pelo fotógrafo.</segment>
    <segment id="126">Lupus, também da China</segment>
    <segment id="127">, estudava sociologia no Japão.</segment>
    <segment id="128">Ian disse que sua empresa planejava investir em sites pornográficos e perguntou</segment>
    <segment id="129">sese eles tinham algum conhecimento sobre esse negócio.</segment>
    <segment id="130">Noctis confessou que teve "alguma exposição" a esse tipo de site por meio de um amigo</segment>
    <segment id="131">, "Maomi"</segment>
    <segment id="132">, que havia criado seus próprios sites pornográficos com conteúdo de "metrô".</segment>
    <segment id="133">Ian então mencionou o site DingBuZhu casualmente.</segment>
    <segment id="134">Lupus e Noctis riram:</segment>
    <segment id="135">"</segment>
    <segment id="136">Esse é o site do Maomi!</segment>
    <segment id="137">"</segment>
    <segment id="138">Eles revelaram que a pessoa por trás dos sites era um chinês em Tóquio apelidado de Maomi.</segment>
    <segment id="139">Disseram que Maomi era recluso e paranoico.</segment>
    <segment id="140">Noctis e Lupus também admitiram que desempenhavam funções administrativas nos sites.</segment>
    <segment id="141">Eles explicaram o modelo de negócios.  "</segment>
    <segment id="142">Na China</segment>
    <segment id="143">, o sexo é mais reprimido"</segment>
    <segment id="144">, disse Noctis</segment>
    <segment id="145">, "</segment>
    <segment id="146">Alguns homens são muito pervertidos</segment>
    <segment id="147">, eles só querem ver as mulheres sendo...</segment>
    <segment id="148">"</segment>
    <segment id="149">Lupus terminou a frase: "</segment>
    <segment id="150">Sacaneadas".</segment>
    <segment id="151">Lupus disse que era encarregado de promover vídeos de abuso no Twitter.</segment>
    <segment id="152">Noctis revelou que carregou mais de 5.000 vídeos nos sites</segment>
    <segment id="153">, recebeu pagamentos pelo negócio e ficou com 30% da receita.</segment>
    <segment id="154">O resto ele transferiu para Maomi.</segment>
    <segment id="155">Lupus também disse que poderia ajudar a conectar Ian a Maomi.</segment>
    <segment id="156">O clube 'chikan'</segment>
    <segment id="157">Em uma rua tranquila na zona de prostituição do bairro de Yokohama</segment>
    <segment id="158">, uma loja decorada</segment>
    <segment id="159">comocomo</segment>
    <segment id="160">sese fosse uma estação de metrô chama a atenção.</segment>
    <segment id="161">Uma placa explica seu conceito:</segment>
    <segment id="162">"trens legais de chikan".</segment>
    <segment id="163">Neste clube de sexo</segment>
    <segment id="164">, chamado Rush Hour</segment>
    <segment id="165">, os clientes podem pagar para desfrutar da experiência chikan legalmente.</segment>
    <segment id="166">Seu gerente</segment>
    <segment id="167">, Hasuda Shuhei</segment>
    <segment id="168">, nos dá as boas-vindas a bordo.</segment>
    <segment id="169">"</segment>
    <segment id="170">Deixamos as pessoas fazerem coisas que não podem ser feitas lá fora.</segment>
    <segment id="171">É por isso que as pessoas vêm aqui.</segment>
    <segment id="172">"  No interior</segment>
    <segment id="173">, um cheiro adocicado de produtos de limpeza permeia o ar.</segment>
    <segment id="174">Os quartos privados são decorados</segment>
    <segment id="175">comocomo vagões e equipados com um sistema de som que reproduz anúncios de trem.</segment>
    <segment id="176">Até os cartões de sócio do clube</segment>
    <segment id="177">sese parecem exatamente com os cartões de transporte do Japão.</segment>
    <segment id="178">"Acho importante que os homens possam pagar para desopilar em lugares</segment>
    <segment id="179">comocomo este</segment>
    <segment id="180">, para que</segment>
    <segment id="181">para que não cometam estupro e outras formas de agressão sexual"</segment>
    <segment id="182">, diz Hasuda.</segment>
    <segment id="183">O profissional de saúde mental Saito diz que o assunto não é tão simples quanto afirma Hasuda.</segment>
    <segment id="184">Ele diz que a maioria dos perpetradores de "chikan" ficam excitados com a ideia de dominação e humilhação de suas vítimas.</segment>
    <segment id="185">"</segment>
    <segment id="186">Eles não tratam suas vítimas</segment>
    <segment id="187">comocomo iguais</segment>
    <segment id="188">, masmas</segment>
    <segment id="189">comocomo objetos.</segment>
    <segment id="190">"  É uma opinião que Takako entende bem.</segment>
    <segment id="191">Depois de meses sendo assediada</segment>
    <segment id="192">, um dia ela finalmente confrontou um assediador.</segment>
    <segment id="193">Ao sentir uma mão alcançar sua saia em um vagão de trem lotado</segment>
    <segment id="194">, Takako gritou a plenos pulmões e agarrou o agressor pelo pulso.</segment>
    <segment id="195">Takako processou o homem</segment>
    <segment id="196">, que recebeu apenas uma pena leve</segment>
    <segment id="197">, embora</segment>
    <segment id="198">embora ele já tivesse sido pego outras vezes praticando crimes de "chikan".</segment>
    <segment id="199">Decepcionada com o resultado de seu</segment>
    <segment id="200">casocaso</segment>
    <segment id="201">, Takako iniciou uma campanha anti-chikan</segment>
    <segment id="202">, produzindo distintivos coloridos que diziam "</segment>
    <segment id="203">Chikan é um crime!"</segment>
    <segment id="204">As pessoas podem usá-los para mostrar que não vão ficar caladas.</segment>
    <segment id="205">"É um aviso aos criminosos"</segment>
    <segment id="206">, diz Takako</segment>
    <segment id="207">, que hoje tem 24 anos.</segment>
    <segment id="208">Há agora um concurso anual de design de distintivos anti-chikan entre estudantes japoneses do ensino médio.</segment>
    <segment id="209">O hamster  Maomi significa "gatinho</segment>
    <segment id="210">" em chinês.</segment>
    <segment id="211">No entanto</segment>
    <segment id="212">, Lupus disse que sua personalidade era mais parecida com a de um hamster.</segment>
    <segment id="213">"</segment>
    <segment id="214">Ele é inofensivo</segment>
    <segment id="215">, masmas cauteloso com tudo e às vezes exagera.</segment>
    <segment id="216">"  Lupus estava certo.</segment>
    <segment id="217">Maomi recusou-</segment>
    <segment id="218">sese repetidamente a encontrar Ian.</segment>
    <segment id="219">Mas na véspera do Ano Novo Chinês</segment>
    <segment id="220">, a sorte de Ian mudou.</segment>
    <segment id="221">Maomi concordou com um encontro em um bar de karaokê.</segment>
    <segment id="222">O ar estava carregado de fumaça de cigarro</segment>
    <segment id="223">, ao som de copos tilintando e canções pop chinesas.</segment>
    <segment id="224">A pessoa que apareceu não era quem esperávamos.</segment>
    <segment id="225">Jovem, magro e usando óculos de meio aro e um sobretudo escuro</segment>
    <segment id="226">, Maomi parecia um estudante universitário.</segment>
    <segment id="227">Ele disse que tinha 27 anos.</segment>
    <segment id="228">Demonstrando interesse em investir em seu negócio</segment>
    <segment id="229">, Ian perguntou quanto ele ganhava.</segment>
    <segment id="230">"</segment>
    <segment id="231">Nosso faturamento diário gira em torno de 5.000 a 10.000 yuans chineses (R$ 3.500 a R$ 7.000)"</segment>
    <segment id="232">, disse Maomi com orgulho</segment>
    <segment id="233">, mostrando as transações em seu telefone.</segment>
    <segment id="234">"</segment>
    <segment id="235">Renda muito estável</segment>
    <segment id="236">, certo?</segment>
    <segment id="237">"</segment>
    <segment id="238">Ian ficou impressionado e mencionou o nome de Tio Qi.</segment>
    <segment id="239">Maomi admitiu:</segment>
    <segment id="240">"</segment>
    <segment id="241">Eu sou o Tio Qi.</segment>
    <segment id="242">"  Mas</segment>
    <segment id="243">, para nossa surpresa</segment>
    <segment id="244">, ele revelou que Tio Qi não era apenas uma pessoa.</segment>
    <segment id="245">Ele gerenciava uma equipe de 15 pessoas</segment>
    <segment id="246">, incluindo dez na China</segment>
    <segment id="247">, que faziam vídeos sob o mesmo nome.</segment>
    <segment id="248">Maomi recebia de 30 a 100 vídeos todos os meses.</segment>
    <segment id="249">Os vídeos eram são vendidos nos três sites que Maomi confirmou ser de sua propriedade.</segment>
    <segment id="250">Os sites tinham mais de 10 mil assinantes pagantes — a maioria chineses.  "</segment>
    <segment id="251">A chave é ser autêntico.</segment>
    <segment id="252">Tem que ser real"</segment>
    <segment id="253">, disse Maomi.</segment>
    <segment id="254">Mais tarde</segment>
    <segment id="255">, ele nos disse que seus sites até vendiam vídeos de estupro facilitado por drogas.</segment>
    <segment id="256">Maomi falava sobre seu negócio</segment>
    <segment id="257">comocomo</segment>
    <segment id="258">sese fosse uma startup normal.</segment>
    <segment id="259">Ele descreveu sua equipe</segment>
    <segment id="260">comocomo "apaixonada" e "corajosa".</segment>
    <segment id="261">Ele até mencionou casualmente que estava treinando outras pessoas para realizar e filmar agressões sexuais.</segment>
    <segment id="262">Mas havia uma coisa que ele nunca mencionou: as mulheres em seus vídeos.</segment>
    <segment id="263">Era como</segment>
    <segment id="264">como se</segment>
    <segment id="265">se elas não tivessem a menor importância para ele.</segment>
    <segment id="266">Maomi exposto  Queríamos saber a verdadeira identidade de Maomi.</segment>
    <segment id="267">Em outra reunião com Ian</segment>
    <segment id="268">, ele falou abertamente sobre</segment>
    <segment id="269">comocomo entrou neste negócio.</segment>
    <segment id="270">Como muitos meninos</segment>
    <segment id="271">, Maomi gostava de Superman</segment>
    <segment id="272">, anime e videogames.</segment>
    <segment id="273">Mas quando tinha 14 anos</segment>
    <segment id="274">, começou a assistir a vídeos de agressão sexual</segment>
    <segment id="275">comocomo os que vende agora.</segment>
    <segment id="276">Ele sabia que seu negócio não era isento de riscos.</segment>
    <segment id="277">"</segment>
    <segment id="278">Eu sou muito cuidadoso"</segment>
    <segment id="279">, disse Maomi.</segment>
    <segment id="280">"</segment>
    <segment id="281">Segurança primeiro."</segment>
    <segment id="282">Para evitar o escrutínio das autoridades chinesas</segment>
    <segment id="283">, ele planejava</segment>
    <segment id="284">sese naturalizar</segment>
    <segment id="285">comocomo cidadão japonês.</segment>
    <segment id="286">No entanto</segment>
    <segment id="287">, por mais cuidadoso que Maomi fosse</segment>
    <segment id="288">, ele cometeu um erro.</segment>
    <segment id="289">Quando Ian perguntou para onde enviar os fundos de investimento</segment>
    <segment id="290">, Maomi pegou seu cartão do banco e o entregou a Ian.</segment>
    <segment id="291">O cartão revelou seu nome verdadeiro —Tang Zhuoran.</segment>
    <segment id="292">Mais tarde</segment>
    <segment id="293">, confrontamos Maomi com nossas alegações.</segment>
    <segment id="294">Quando nos aproximamos</segment>
    <segment id="295">, ele tentou cobrir o rosto e</segment>
    <segment id="296">sese afastou.</segment>
    <segment id="297">E, de repente</segment>
    <segment id="298">, ele explodiu</segment>
    <segment id="299">, atacando nossa câmera e nossa equipe.</segment>
    <segment id="300">No dia seguinte</segment>
    <segment id="301">, por coincidência</segment>
    <segment id="302">, avistamos Maomi no aeroporto.</segment>
    <segment id="303">Ele estava saindo do Japão.</segment>
    <segment id="304">A conta do Twitter do Tio Qi</segment>
    <segment id="305">, onde ele promove abertamente os vídeos de abuso</segment>
    <segment id="306">, ainda está ativa.</segment>
    <segment id="307">O Twitter não respondeu ao nosso pedido de entrevista.</segment>
    <segment id="308">Em vez disso</segment>
    <segment id="309">, eles nos enviaram um emoji de cocô</segment>
    <segment id="310">, que tem sido uma resposta automática a qualquer pergunta direcionada ao e-mail de imprensa desde março.</segment>
    <segment id="311">Também apresentamos nossas alegações para Noctis e Lupus.</segment>
    <segment id="312">Eles não responderam.</segment>
    <segment id="313">Desde então</segment>
    <segment id="314">, descobrimos que eles não trabalham mais com Maomi.</segment>
    <segment id="315">Em um dia de primavera</segment>
    <segment id="316">, nos encontramos com Takako para contar a ela sobre nossa investigação.</segment>
    <segment id="317">Chocada</segment>
    <segment id="318">, ela diz:</segment>
    <segment id="319">"</segment>
    <segment id="320">Nós, mulheres</segment>
    <segment id="321">, somos apenas conteúdo dos vídeos deles.</segment>
    <segment id="322">Eles nos veem</segment>
    <segment id="323">comocomo objetos.</segment>
    <segment id="324">Eles não acham que temos um coração.</segment>
    <segment id="325">"  Takako defende leis mais rígidas contra esses crimes.</segment>
    <segment id="326">O Japão está prestes a aprovar suas primeiras leis proibindo o "upskirting" (prática de fazer filmagens não consensuais sob a saia de uma mulher).</segment>
    <segment id="327">No entanto</segment>
    <segment id="328">, ainda não há uma lei nacional contra a prática de chikan.</segment>
    <segment id="329">Mas Takako disse que não vai desistir.</segment>
  </rst>
</analysis>