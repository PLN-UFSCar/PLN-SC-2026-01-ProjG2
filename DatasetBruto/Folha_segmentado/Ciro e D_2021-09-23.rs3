  <rst>
    <segment id="1">Ao assumirem uma estrat&amp;eacute</segment>
    <segment id="2">;gia eleitoral com foco no antipetismo</segment>
    <segment id="3">, presidenci&amp;aacute</segment>
    <segment id="4">;veis da chamada terceira via contradizem a tend&amp;ecirc</segment>
    <segment id="5">;ncia de parte do seu eleitorado de convergir para o antibolsonarismo em um eventual segundo turno entre Luiz In&amp;aacute</segment>
    <segment id="6">;cio Lula da Silva (PT) e Jair Bolsonaro (sem partido).</segment>
    <segment id="7">A t&amp;aacute</segment>
    <segment id="8">;tica anti-PT &amp;eacute</segment>
    <segment id="9">; baseada no c&amp;aacute</segment>
    <segment id="10">;lculo dos presidenci&amp;aacute</segment>
    <segment id="11">;veis de que uma participa&amp;ccedil</segment>
    <segment id="12">;&amp;atilde</segment>
    <segment id="13">;o deles no segundo turno s&amp;oacute</segment>
    <segment id="14">;</segment>
    <segment id="15">vir&amp;aacute</segment>
    <segment id="16">; &amp;agrave</segment>
    <segment id="17">; custa do derretimento de Bolsonaro</segment>
    <segment id="18">, o que os levaria a um enfrentamento com Lula.</segment>
    <segment id="19">Entre estrategistas do PDT de Ciro Gomes e do PSDB de Jo&amp;atilde</segment>
    <segment id="20">;o Doria e Eduardo Leite</segment>
    <segment id="21">, a ideia &amp;eacute</segment>
    <segment id="22">; cavar a ida &amp;agrave</segment>
    <segment id="23">; segunda fase do pleito com o argumento de que a terceira via tem chances de vencer Lula</segment>
    <segment id="24">, enquanto Bolsonaro perdeu essa capacidade em raz&amp;atilde</segment>
    <segment id="25">;o dos recordes de desaprova&amp;ccedil</segment>
    <segment id="26">;&amp;atilde</segment>
    <segment id="27">;o e rejei&amp;ccedil</segment>
    <segment id="28">;&amp;atilde</segment>
    <segment id="29">;o.</segment>
    <segment id="30">Caso o segundo turno entre Lula e Bolsonaro</segment>
    <segment id="31">sese confirme</segment>
    <segment id="32">, pesquisa Datafolha mostra que</segment>
    <segment id="33">, hoje</segment>
    <segment id="34">, o antibolsonarismo seria uma for&amp;ccedil</segment>
    <segment id="35">;a maior do que o antipetismo na segunda etapa da elei&amp;ccedil</segment>
    <segment id="36">;&amp;atilde</segment>
    <segment id="37">;o, o que torna a t&amp;aacute</segment>
    <segment id="38">;tica de mirar Lula mais arriscada</segment>
    <segment id="39">, j&amp;aacute</segment>
    <segment id="40">; que afugentaria uma parcela de ocasionais apoiadores.</segment>
    <segment id="41">Eleitores de Ciro e dos dois tucanos</segment>
    <segment id="42">, que disputam as pr&amp;eacute</segment>
    <segment id="43">;vias do PSDB para a escolha do candidato presidencial</segment>
    <segment id="44">, tendem a preferir o petista</segment>
    <segment id="45">, embora</segment>
    <segment id="46">embora a parcela que votaria em Bolsonaro ou em nenhum tamb&amp;eacute</segment>
    <segment id="47">;m seja expressiva a ponto de causar empates dentro da margem de erro com a parte pr&amp;oacute</segment>
    <segment id="48">;-Lula.</segment>
    <segment id="49">A pesquisa Datafolha</segment>
    <segment id="50">, realizada nos dias 13 a 15 de setembro</segment>
    <segment id="51">, ouviu 3.667 eleitores de forma presencial em 190 cidades.</segment>
    <segment id="52">O resultado mostrou Lula mantendo larga vantagem sobre Bolsonaro na dianteira da disputa.</segment>
    <segment id="53">Ciro, que desde 2018 ampliou o descolamento do PT e adotou as cr&amp;iacute</segment>
    <segment id="54">;ticas m&amp;uacute</segment>
    <segment id="55">;tuas a Bolsonaro e Lula</segment>
    <segment id="56">comocomo foco de sua pr&amp;eacute</segment>
    <segment id="57">;-campanha para 2022</segment>
    <segment id="58">, dever&amp;aacute</segment>
    <segment id="59">; manter essa linha</segment>
    <segment id="60">, de acordo com aliados</segment>
    <segment id="61">, na inten&amp;ccedil</segment>
    <segment id="62">;&amp;atilde</segment>
    <segment id="63">;o de se</segment>
    <segment id="64">se apresentar</segment>
    <segment id="65">comocomo uma op&amp;ccedil</segment>
    <segment id="66">;&amp;atilde</segment>
    <segment id="67">;o diferente</segment>
    <segment id="68">, ou seja</segment>
    <segment id="69">, um tipo de governo que ainda n&amp;atilde</segment>
    <segment id="70">;o foi experimentado.</segment>
    <segment id="71">Os ataques a Lula</segment>
    <segment id="72">, contudo</segment>
    <segment id="73">contudo</segment>
    <segment id="74">, causam ru&amp;iacute</segment>
    <segment id="75">;do n&amp;atilde</segment>
    <segment id="76">;o s&amp;oacute</segment>
    <segment id="77">;</segment>
    <segment id="78">em uma parcela dos apoiadores</segment>
    <segment id="79">, masmas tamb&amp;eacute</segment>
    <segment id="80">;m entre colegas de partido</segment>
    <segment id="81">, conforme mostrou a Folha em junho.</segment>
    <segment id="82">Entre quem vota em Ciro no primeiro turno</segment>
    <segment id="83">, 58% votam em Lula e 17% escolhem Bolsonaro em um segundo turno sem a presen&amp;ccedil</segment>
    <segment id="84">;a do pedetista &amp;mdash</segment>
    <segment id="85">;26% n&amp;atilde</segment>
    <segment id="86">;o querem nenhum dos dois.</segment>
    <segment id="87">A margem de erro &amp;eacute</segment>
    <segment id="88">; de cinco pontos para mais ou para menos.</segment>
    <segment id="89">O presidente do PDT em S&amp;atilde</segment>
    <segment id="90">;o Paulo</segment>
    <segment id="91">, Antonio Neto</segment>
    <segment id="92">, afirma que o partido est&amp;aacute</segment>
    <segment id="93">; &amp;ldquo</segment>
    <segment id="94">;convicto em apresentar uma alternativa&amp;rdquo</segment>
    <segment id="95">; que n&amp;atilde</segment>
    <segment id="96">;o seja &amp;ldquo</segment>
    <segment id="97">;nem o passado nem o presente&amp;rdquo</segment>
    <segment id="98">;.</segment>
    <segment id="99">&amp;ldquo</segment>
    <segment id="100">;Vamos bater no sistema</segment>
    <segment id="101">, n&amp;atilde</segment>
    <segment id="102">;o no partido ou nas pessoas.</segment>
    <segment id="103">Queremos mudar essa pol&amp;iacute</segment>
    <segment id="104">;tica e vamos ter que escancarar isso&amp;rdquo</segment>
    <segment id="105">;, diz.</segment>
    <segment id="106">Questionado sobre Ciro errar ao atacar Lula e Bolsonaro pessoalmente</segment>
    <segment id="107">, Neto afirma que n&amp;atilde</segment>
    <segment id="108">;o v&amp;ecirc</segment>
    <segment id="109">;</segment>
    <segment id="110">equ&amp;iacute</segment>
    <segment id="111">;voco.</segment>
    <segment id="112">&amp;ldquo</segment>
    <segment id="113">;Ele tem dados e informa&amp;ccedil</segment>
    <segment id="114">;&amp;otilde</segment>
    <segment id="115">;es para falar isso</segment>
    <segment id="116">, conhece bem os atores.</segment>
    <segment id="117">Ciro fala da vis&amp;atilde</segment>
    <segment id="118">;o que ele teve de dentro&amp;rdquo</segment>
    <segment id="119">;, segue.</segment>
    <segment id="120">O presidenci&amp;aacute</segment>
    <segment id="121">;vel foi ministro do governo Lula.</segment>
    <segment id="122">Para o ex-deputado federal Miro Teixeira (PDT-RJ)</segment>
    <segment id="123">, a sobreposi&amp;ccedil</segment>
    <segment id="124">;&amp;atilde</segment>
    <segment id="125">;o de parte dos eleitorados de Ciro e Lula &amp;eacute</segment>
    <segment id="126">; algo natural e as cr&amp;iacute</segment>
    <segment id="127">;ticas &amp;agrave</segment>
    <segment id="128">; era petista s&amp;atilde</segment>
    <segment id="129">;o embasadas.</segment>
    <segment id="130">&amp;quot;Independentemente das palavras do Ciro sobre o Lula e do Lula sobre o Ciro</segment>
    <segment id="131">, &amp;eacute</segment>
    <segment id="132">; o eleitorado que faz a alian&amp;ccedil</segment>
    <segment id="133">;a, &amp;eacute</segment>
    <segment id="134">;</segment>
    <segment id="135">ele que escolhe&amp;quot</segment>
    <segment id="136">;, diz.</segment>
    <segment id="137">Miro afirma ainda que seu trabalho e o da milit&amp;acirc</segment>
    <segment id="138">;ncia &amp;quot</segment>
    <segment id="139">;&amp;eacute</segment>
    <segment id="140">; para que</segment>
    <segment id="141">para que o Ciro esteja no segundo turno&amp;quot</segment>
    <segment id="142">; e que a estrat&amp;eacute</segment>
    <segment id="143">;gia do pr&amp;eacute</segment>
    <segment id="144">;-candidato para</segment>
    <segment id="145">sese diferenciar dos atuais l&amp;iacute</segment>
    <segment id="146">;deres das pesquisas &amp;eacute</segment>
    <segment id="147">; a &amp;uacute</segment>
    <segment id="148">;nica poss&amp;iacute</segment>
    <segment id="149">;vel.</segment>
    <segment id="150">&amp;quot;</segment>
    <segment id="151">Se o Ciro apoiasse um dos dois [Lula ou Bolsonaro]</segment>
    <segment id="152">, ele n&amp;atilde</segment>
    <segment id="153">;o seria candidato&amp;quot</segment>
    <segment id="154">;, sintetiza.</segment>
    <segment id="155">Veja quais são os possíveis candidatos à Presidência em 2022Mais    novamente         de   de  de  representando</segment>
    <segment id="156">um  Principais for&amp;ccedil</segment>
    <segment id="157">;as hoje dentro do PSDB</segment>
    <segment id="158">, Doria e Leite adotar&amp;atilde</segment>
    <segment id="159">;o estrat&amp;eacute</segment>
    <segment id="160">;gias distintas</segment>
    <segment id="161">, em caso</segment>
    <segment id="162">caso de vit&amp;oacute</segment>
    <segment id="163">;ria nas pr&amp;eacute</segment>
    <segment id="164">;vias.</segment>
    <segment id="165">Ambos seguir&amp;atilde</segment>
    <segment id="166">;o suas linhas atuais &amp;mdash</segment>
    <segment id="167">;o ga&amp;uacute</segment>
    <segment id="168">;cho com uma oposi&amp;ccedil</segment>
    <segment id="169">;&amp;atilde</segment>
    <segment id="170">;o mais comedida</segment>
    <segment id="171">, enquanto o paulista n&amp;atilde</segment>
    <segment id="172">;o poupa a ret&amp;oacute</segment>
    <segment id="173">;rica incisiva contra Lula e Bolsonaro.</segment>
    <segment id="174">Doria, que trava um embate com Bolsonaro a respeito da gest&amp;atilde</segment>
    <segment id="175">;o da pandemia e</segment>
    <segment id="176">sese tornou um dos principais nomes de oposi&amp;ccedil</segment>
    <segment id="177">;&amp;atilde</segment>
    <segment id="178">;o ao presidente</segment>
    <segment id="179">,</segment>
    <segment id="180">afirmou na segunda-feira (20) que o tom anti-PT ser&amp;aacute</segment>
    <segment id="181">; forte</segment>
    <segment id="182">casocaso</segment>
    <segment id="183">sese confirme sua tentativa de chegar ao Planalto.</segment>
    <segment id="184">&amp;quot;Esse antipetismo ser&amp;aacute</segment>
    <segment id="185">;</segment>
    <segment id="186">predominante dentro da nossa campanha</segment>
    <segment id="187">, com muita clareza&amp;quot</segment>
    <segment id="188">;, disse.</segment>
    <segment id="189">Ao fazer sua inscri&amp;ccedil</segment>
    <segment id="190">;&amp;atilde</segment>
    <segment id="191">;o nas pr&amp;eacute</segment>
    <segment id="192">;vias, o tucano criticou diretamente os ex-presidentes Lula e Dilma Rousseff (ambos do PT)</segment>
    <segment id="193">, citando &amp;quot</segment>
    <segment id="194">;o maior esquema de corrup&amp;ccedil</segment>
    <segment id="195">;&amp;atilde</segment>
    <segment id="196">;o do qual</segment>
    <segment id="197">sese tem not&amp;iacute</segment>
    <segment id="198">;cia&amp;quot</segment>
    <segment id="199">;, mas</segment>
    <segment id="200">mas deixou impl&amp;iacute</segment>
    <segment id="201">;citas as cr&amp;iacute</segment>
    <segment id="202">;ticas ao governo de Bolsonaro</segment>
    <segment id="203">, mencionando retrocesso democr&amp;aacute</segment>
    <segment id="204">;tico e defesa da urna eletr&amp;ocirc</segment>
    <segment id="205">;nica.</segment>
    <segment id="206">Embora o paulista esteja voltando sua mira para o PT</segment>
    <segment id="207">, o Datafolha mostra que seus eleitores tendem a preferir Lula a Bolsonaro em um segundo turno entre os dois.</segment>
    <segment id="208">No total</segment>
    <segment id="209">, 42% dizem que escolheriam Lula</segment>
    <segment id="210">, contra 23% que votariam em Bolsonaro.</segment>
    <segment id="211">Uma parcela expressiva de 35% afirma que votaria nulo ou em branco.</segment>
    <segment id="212">A margem de erro</segment>
    <segment id="213">, nesse</segment>
    <segment id="214">casocaso</segment>
    <segment id="215">, &amp;eacute</segment>
    <segment id="216">; de sete pontos para mais ou para menos.</segment>
    <segment id="217">Apesar disso</segment>
    <segment id="218">, aliados do governador e mesmo membros da dire&amp;ccedil</segment>
    <segment id="219">;&amp;atilde</segment>
    <segment id="220">;o do PSDB n&amp;atilde</segment>
    <segment id="221">;o consideram um erro adotar a estrat&amp;eacute</segment>
    <segment id="222">;gia do antipetismo.</segment>
    <segment id="223">Isso porque</segment>
    <segment id="224">porque</segment>
    <segment id="225">, segundo eles</segment>
    <segment id="226">, sese Doria chegar ao segundo turno</segment>
    <segment id="227">, provavelmente ser&amp;aacute</segment>
    <segment id="228">; contra Lula &amp;mdash</segment>
    <segment id="229">;que vence em todos os cen&amp;aacute</segment>
    <segment id="230">;rios de segundo turno hoje.</segment>
    <segment id="231">O presidente estadual do PSDB de S&amp;atilde</segment>
    <segment id="232">;o Paulo</segment>
    <segment id="233">, Marco Vinholi</segment>
    <segment id="234">, ​avalia a t&amp;aacute</segment>
    <segment id="235">;tica de Doria</segment>
    <segment id="236">comocomo acertada.</segment>
    <segment id="237">&amp;</segment>
    <segment id="238">quot;Os n&amp;uacute</segment>
    <segment id="239">;meros demonstram que quem tem condi&amp;ccedil</segment>
    <segment id="240">;&amp;otilde</segment>
    <segment id="241">;es derrotar Lula no segundo turno &amp;eacute</segment>
    <segment id="242">; a terceira via.</segment>
    <segment id="243">O projeto bolsonarista perdeu a consist&amp;ecirc</segment>
    <segment id="244">;ncia e a viabilidade eleitoral&amp;quot</segment>
    <segment id="245">;, diz.</segment>
    <segment id="246">Para os tucanos</segment>
    <segment id="247">, enquanto Bolsonaro derrete naturalmente</segment>
    <segment id="248">, os ataques a Lula fariam o eleitorado recordar esc&amp;acirc</segment>
    <segment id="249">;ndalos de corrup&amp;ccedil</segment>
    <segment id="250">;&amp;atilde</segment>
    <segment id="251">;o da era petista.</segment>
    <segment id="252">A leitura &amp;eacute</segment>
    <segment id="253">; a de que o brasileiro tende ao conservadorismo e &amp;agrave</segment>
    <segment id="254">; direita e criou repulsa ao PT</segment>
    <segment id="255">, tanto que elegeu Bolsonaro.</segment>
    <segment id="256">Da&amp;iacute</segment>
    <segment id="257">; a inten&amp;ccedil</segment>
    <segment id="258">;&amp;atilde</segment>
    <segment id="259">;o de acenar a esse grupo.</segment>
    <segment id="260">H&amp;aacute</segment>
    <segment id="261">; ainda a quest&amp;atilde</segment>
    <segment id="262">;o de que uma parcela significativa do eleitorado das pr&amp;eacute</segment>
    <segment id="263">;vias tucanas</segment>
    <segment id="264">, inclusive boa parte dos deputados federais do PSDB</segment>
    <segment id="265">, &amp;eacute</segment>
    <segment id="266">; alinhada a Bolsonaro</segment>
    <segment id="267">, o que explicaria a fala de Doria sobre a predomin&amp;acirc</segment>
    <segment id="268">;ncia do antipetismo em sua campanha.</segment>
    <segment id="269">Membros do partido afirmam</segment>
    <segment id="270">, no entanto</segment>
    <segment id="271">, que o adesismo da bancada ao governo &amp;eacute</segment>
    <segment id="272">; um aspecto lateral no momento de pensar t&amp;aacute</segment>
    <segment id="273">;ticas eleitorais.</segment>
    <segment id="274">&amp;Eacute</segment>
    <segment id="275">; crescente a press&amp;atilde</segment>
    <segment id="276">;o no PSDB</segment>
    <segment id="277">para que</segment>
    <segment id="278">para que os deputados fi&amp;eacute</segment>
    <segment id="279">;is a Bolsonaro</segment>
    <segment id="280">sese enquadrem no papel de oposi&amp;ccedil</segment>
    <segment id="281">;&amp;atilde</segment>
    <segment id="282">;o ou deixem a sigla.</segment>
    <segment id="283">Aliados de Doria ouvidos pela Folha ressaltam</segment>
    <segment id="284">, por&amp;eacute</segment>
    <segment id="285">;m, que o governador paulista n&amp;atilde</segment>
    <segment id="286">;o ser&amp;aacute</segment>
    <segment id="287">; apenas anti-Lula</segment>
    <segment id="288">, masmas tamb&amp;eacute</segment>
    <segment id="289">;m anti-Bolsonaro</segment>
    <segment id="290">, e pregaram o caminho do meio.</segment>
    <segment id="291">Vinholi diz que a aposta &amp;eacute</segment>
    <segment id="292">; em um &amp;quot</segment>
    <segment id="293">;eleitor de centro</segment>
    <segment id="294">, contra os dois extremos&amp;quot</segment>
    <segment id="295">;.</segment>
    <segment id="296">&amp;quot;A gente</segment>
    <segment id="297">sese posiciona</segment>
    <segment id="298">comocomo via alternativa aos dois na mesma intensidade.</segment>
    <segment id="299">Somos &amp;#</segment>
    <segment id="300">39;antibolsopetista&amp;#39</segment>
    <segment id="301">;&amp;quot</segment>
    <segment id="302">;, resume.</segment>
    <segment id="303">Para o dirigente</segment>
    <segment id="304">, os n&amp;uacute</segment>
    <segment id="305">;meros das pesquisas s&amp;oacute</segment>
    <segment id="306">; sese consolidar&amp;atilde</segment>
    <segment id="307">;o mais adiante.</segment>
    <segment id="308">Manifestações na avenida Paulista desde 2014Mais    novamente         de   de  de  representando um  ​​Leite</segment>
    <segment id="309">, diferentemente de Doria</segment>
    <segment id="310">, afirmou</segment>
    <segment id="311">, na ter&amp;ccedil</segment>
    <segment id="312">;a-feira (21)</segment>
    <segment id="313">, que n&amp;atilde</segment>
    <segment id="314">;o basear&amp;aacute</segment>
    <segment id="315">; sua campanha no antipetismo ou no antibolsonarismo e pregou a concilia&amp;ccedil</segment>
    <segment id="316">;&amp;atilde</segment>
    <segment id="317">;o do pa&amp;iacute</segment>
    <segment id="318">;s.</segment>
    <segment id="319">Sua carta de inscri&amp;ccedil</segment>
    <segment id="320">;&amp;atilde</segment>
    <segment id="321">;o nas pr&amp;eacute</segment>
    <segment id="322">;vias tem cr&amp;iacute</segment>
    <segment id="323">;ticas veladas aos dois lados.</segment>
    <segment id="324">De acordo com o Datafolha</segment>
    <segment id="325">, seus eleitores</segment>
    <segment id="326">sese dividiriam</segment>
    <segment id="327">, em um segundo turno</segment>
    <segment id="328">, em 43% para Lula</segment>
    <segment id="329">, 27% para Bolsonaro e 27% em nulo ou branco.</segment>
    <segment id="330">A margem de erro &amp;eacute</segment>
    <segment id="331">; de oito pontos para mais ou menos.</segment>
    <segment id="332">Leite afirmou ser cedo para tirar conclus&amp;otilde</segment>
    <segment id="333">;es das pesquisas</segment>
    <segment id="334">, masmas ressaltou a alta rejei&amp;ccedil</segment>
    <segment id="335">;&amp;atilde</segment>
    <segment id="336">;o dos atuais l&amp;iacute</segment>
    <segment id="337">;deres.</segment>
    <segment id="338">​A estrat&amp;eacute</segment>
    <segment id="339">;gia do governador ga&amp;uacute</segment>
    <segment id="340">;cho, contudo</segment>
    <segment id="341">contudo</segment>
    <segment id="342">, &amp;eacute</segment>
    <segment id="343">; falar com o eleitor que recha&amp;ccedil</segment>
    <segment id="344">;a n&amp;atilde</segment>
    <segment id="345">;o apenas as figuras de Lula e Bolsonaro</segment>
    <segment id="346">, masmas a polariza&amp;ccedil</segment>
    <segment id="347">;&amp;atilde</segment>
    <segment id="348">;o em si.</segment>
    <segment id="349">&amp;Agrave</segment>
    <segment id="350">;</segment>
    <segment id="351">Folha ele diz que o antipetismo n&amp;atilde</segment>
    <segment id="352">;o &amp;eacute</segment>
    <segment id="353">; uma estrat&amp;eacute</segment>
    <segment id="354">;gia eleitoral adequada e que &amp;quot</segment>
    <segment id="355">;falta ao pa&amp;iacute</segment>
    <segment id="356">;s um projeto de constru&amp;ccedil</segment>
    <segment id="357">;&amp;atilde</segment>
    <segment id="358">;o&amp;quot</segment>
    <segment id="359">;</segment>
    <segment id="360">.  &amp;quot</segment>
    <segment id="361">;A gente n&amp;atilde</segment>
    <segment id="362">;o precisa de um terceiro polo de radicaliza&amp;ccedil</segment>
    <segment id="363">;&amp;atilde</segment>
    <segment id="364">;o.</segment>
    <segment id="365">A gente precisa de uma terceira via.</segment>
    <segment id="366">N&amp;atilde</segment>
    <segment id="367">;o adianta entrar na polariza&amp;ccedil</segment>
    <segment id="368">;&amp;atilde</segment>
    <segment id="369">;o polarizando mais ainda&amp;quot</segment>
    <segment id="370">;, afirma.  &amp;quot</segment>
    <segment id="371">;Olho para a elei&amp;ccedil</segment>
    <segment id="372">;&amp;atilde</segment>
    <segment id="373">;o e o p&amp;oacute</segment>
    <segment id="374">;s-elei&amp;ccedil</segment>
    <segment id="375">;&amp;atilde</segment>
    <segment id="376">;o 2022.</segment>
    <segment id="377">O Brasil precisa superar essa crise pol&amp;iacute</segment>
    <segment id="378">;tica.</segment>
    <segment id="379">Temos que ganhar do jeito certo.</segment>
    <segment id="380">Pelas nossas qualidades e virtudes do nosso projeto</segment>
    <segment id="381">, e n&amp;atilde</segment>
    <segment id="382">;o pelos defeitos dos outros.&amp;quot</segment>
    <segment id="383">;</segment>
    <segment id="384">Na ter&amp;ccedil</segment>
    <segment id="385">;a, Leite respondeu &amp;agrave</segment>
    <segment id="386">;</segment>
    <segment id="387">declara&amp;ccedil</segment>
    <segment id="388">;&amp;atilde</segment>
    <segment id="389">;o de Doria sobre o antipetismo e afirmou ter um estilo diferente</segment>
    <segment id="390">, de &amp;quot</segment>
    <segment id="391">;n&amp;atilde</segment>
    <segment id="392">;o promover ataques &amp;agrave</segment>
    <segment id="393">;s pessoas&amp;quot</segment>
    <segment id="394">;.</segment>
    <segment id="395">Segundo ele</segment>
    <segment id="396">, as pessoas n&amp;atilde</segment>
    <segment id="397">;o aguentam mais o que chamou de guerra.</segment>
    <segment id="398">&amp;quot;N&amp;atilde</segment>
    <segment id="399">;o desejo ser presidente para brigar com Lula ou Bolsonaro&amp;quot</segment>
    <segment id="400">;, diz a carta.</segment>
    <segment id="401">O ga&amp;uacute</segment>
    <segment id="402">;cho, por&amp;eacute</segment>
    <segment id="403">;m, n&amp;atilde</segment>
    <segment id="404">;o deixou de fazer cr&amp;iacute</segment>
    <segment id="405">;ticas a ambos ao afirmar que o atual presidente n&amp;atilde</segment>
    <segment id="406">;o respeita espa&amp;ccedil</segment>
    <segment id="407">;os de contesta&amp;ccedil</segment>
    <segment id="408">;&amp;atilde</segment>
    <segment id="409">;o e que sua elei&amp;ccedil</segment>
    <segment id="410">;&amp;atilde</segment>
    <segment id="411">;o foi &amp;quot</segment>
    <segment id="412">;resultado de uma pol&amp;iacute</segment>
    <segment id="413">;tica feita com divis&amp;atilde</segment>
    <segment id="414">;o pelo pr&amp;oacute</segment>
    <segment id="415">;prio Partido dos Trabalhadores&amp;quot</segment>
    <segment id="416">;.</segment>
    <segment id="417">A aposta da terceira via no antipetismo faz sentido</segment>
    <segment id="418">, por&amp;eacute</segment>
    <segment id="419">;m, segundo as tend&amp;ecirc</segment>
    <segment id="420">;ncias apontadas pelo Datafolha de migra&amp;ccedil</segment>
    <segment id="421">;&amp;atilde</segment>
    <segment id="422">;o do voto bolsonarista &amp;mdash</segment>
    <segment id="423">;casocaso Bolsonaro n&amp;atilde</segment>
    <segment id="424">;o chegue ao segundo turno</segment>
    <segment id="425">, como</segment>
    <segment id="426">como esperam tucanos e pedetistas.</segment>
    <segment id="427">A pesquisa mostra que quase metade dos bolsonaristas rejeita escolher Lula e</segment>
    <segment id="428">sese mostra resistente a uma terceira via.</segment>
    <segment id="429">Tal parcela poderia ser seduzida pelo antipetismo demonstrado por candidatos de PDT e PSDB.</segment>
    <segment id="430">A atra&amp;ccedil</segment>
    <segment id="431">;&amp;atilde</segment>
    <segment id="432">;o de eleitores de Bolsonaro &amp;eacute</segment>
    <segment id="433">; maior com Ciro.</segment>
    <segment id="434">Entre o pedetista e Lula</segment>
    <segment id="435">, 11% dos bolsonaristas votariam no petista e h&amp;aacute</segment>
    <segment id="436">; um empate na margem de erro</segment>
    <segment id="437">, de tr&amp;ecirc</segment>
    <segment id="438">;s pontos nesse</segment>
    <segment id="439">casocaso</segment>
    <segment id="440">, entre os que votariam em Ciro (46%) ou em nenhum</segment>
    <segment id="441">, branco ou nulo (42%).</segment>
    <segment id="442">Na escolha entre Lula e Doria (opositores contundentes do presidente)</segment>
    <segment id="443">, a maior parcela dos eleitores de Bolsonaro n&amp;atilde</segment>
    <segment id="444">;o quer ningu&amp;eacute</segment>
    <segment id="445">;m: 48%.</segment>
    <segment id="446">Uma fatia de 12% escolhe Lula</segment>
    <segment id="447">, e 39% preferem Doria.</segment>
    <segment id="448">A margem de erro &amp;eacute</segment>
    <segment id="449">; de tr&amp;ecirc</segment>
    <segment id="450">;s pontos.</segment>
    <segment id="451">Na situa&amp;ccedil</segment>
    <segment id="452">;&amp;atilde</segment>
    <segment id="453">;o contr&amp;aacute</segment>
    <segment id="454">;ria e considerada menos poss&amp;iacute</segment>
    <segment id="455">;vel &amp;mdash</segment>
    <segment id="456">;de Lula n&amp;atilde</segment>
    <segment id="457">;o chegar ao segundo turno e a terceira via enfrentar Bolsonaro&amp;mdash</segment>
    <segment id="458">;, o Datafolha mostra que os petistas migram em parcelas majorit&amp;aacute</segment>
    <segment id="459">;rias para Ciro (75%) e Doria (69%).</segment>
    <segment id="460">A margem de erro &amp;eacute</segment>
    <segment id="461">; de tr&amp;ecirc</segment>
    <segment id="462">;s pontos nesse</segment>
    <segment id="463">casocaso.</segment>
    <segment id="464">Ou seja</segment>
    <segment id="465">, esse movimento &amp;eacute</segment>
    <segment id="466">; tido</segment>
    <segment id="467">comocomo certo</segment>
    <segment id="468">, mesmo que os canh&amp;otilde</segment>
    <segment id="469">;es de tucanos e pedetistas</segment>
    <segment id="470">sese voltem contra Lula</segment>
    <segment id="471">, devido &amp;agrave</segment>
    <segment id="472">; ojeriza da esquerda a Bolsonaro.</segment>
    <segment id="473">Os cen&amp;aacute</segment>
    <segment id="474">;rios de rejei&amp;ccedil</segment>
    <segment id="475">;&amp;atilde</segment>
    <segment id="476">;o medidos pelo Datafolha confirmam a tend&amp;ecirc</segment>
    <segment id="477">;ncia de eleitores de Ciro</segment>
    <segment id="478">, Doria e Leite terem maior avers&amp;atilde</segment>
    <segment id="479">;o a Bolsonaro do que a Lula.</segment>
    <segment id="480">Novamente</segment>
    <segment id="481">, no entanto</segment>
    <segment id="482">, o eleitorado tucano aparece</segment>
    <segment id="483">comocomo levemente mais inclinado a dar um voto ao atual presidente do que ao petista.</segment>
    <segment id="484">Enquanto o &amp;iacute</segment>
    <segment id="485">;ndice dos que n&amp;atilde</segment>
    <segment id="486">;o votariam de jeito nenhum em Bolsonaro chega a 79% entre os simpatizantes de Ciro</segment>
    <segment id="487">, cai para 74% entre os apoiadores de Doria e para 68% entre os de Leite.</segment>
    <segment id="488">Sobre Lula</segment>
    <segment id="489">, os percentuais s&amp;atilde</segment>
    <segment id="490">;o de, respectivamente</segment>
    <segment id="491">, 53%, 60% e 52%.</segment>
    <segment id="492">No quadro geral da pesquisa</segment>
    <segment id="493">, 59% diserram que n&amp;atilde</segment>
    <segment id="494">;o escolheriam Bolsonaro de maneira nenhuma e 38% responderam n&amp;atilde</segment>
    <segment id="495">;o apertariam o n&amp;uacute</segment>
    <segment id="496">;mero de Lula.</segment>
    <segment id="497">Ciro tem rejei&amp;ccedil</segment>
    <segment id="498">;&amp;atilde</segment>
    <segment id="499">;o de 30%</segment>
    <segment id="500">, Doria de 37% e Leite de 18%.</segment>
  </rst>
</analysis>