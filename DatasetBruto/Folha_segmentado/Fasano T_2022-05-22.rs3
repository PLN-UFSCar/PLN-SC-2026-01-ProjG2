  <rst>
    <segment id="1">Inaugurado em dezembro de 2021</segment>
    <segment id="2">, o Hotel Fasano Trancoso entrou nesse mês para a concorrida Hot List da Condé Nast Traveler</segment>
    <segment id="3">, revista britânica que elege os melhores hotéis recém-abertos em todo o mundo.</segment>
    <segment id="4">Instalado na Praia de Itapororoca</segment>
    <segment id="5">, no Sul da Bahia</segment>
    <segment id="6">, o hotel conta com 40 bangalôs e um surpreendente deque de madeira certificada com 500 metros de comprimento.</segment>
    <segment id="7">Construído a 1</segment>
    <segment id="8">,5 m acima do solo</segment>
    <segment id="9">, ele interliga todo o empreendimento e preserva a natureza.</segment>
    <segment id="10">Hotel Fasano TrancosoMais    novamente         de   de  de  representando um</segment>
    <segment id="11">O restaurante</segment>
    <segment id="12">, localizado no final do deque e junto à piscina principal</segment>
    <segment id="13">, tem projeto minimalista de Isay Weinfeld</segment>
    <segment id="14">, que assina todos os ambientes do hotel.</segment>
    <segment id="15">Salão e lounges interligados e sem paredes garantem o clima descontraído</segment>
    <segment id="16">, pontuado pelo elegante traço contemporâneo do arquiteto</segment>
    <segment id="17">, sempre em harmonia com a natureza do entorno.</segment>
    <segment id="18">Para garantir a tradição da gastronomia italiana presente no DNA da marca</segment>
    <segment id="19">, foi convocado o chef José Antonio Rodrigues</segment>
    <segment id="20">, ou "Zé Branco"</segment>
    <segment id="21">, com mais de 20 anos de experiência no Grupo.</segment>
    <segment id="22">"</segment>
    <segment id="23">O grande desafio foi montar e treinar uma equipe local em apenas dois meses"</segment>
    <segment id="24">, conta o chef</segment>
    <segment id="25">, que se</segment>
    <segment id="26">se diz bastante satisfeito com o resultado.</segment>
    <segment id="27">"</segment>
    <segment id="28">Tenho dois ótimos subchefs</segment>
    <segment id="29">, o Ivan e o Magno</segment>
    <segment id="30">, que ajudam na operação diária"</segment>
    <segment id="31">, destacou.</segment>
    <segment id="32">O restaurante tem cardápio focado nos frutos do mar e passeia pelas cozinhas italiana e baiana com a mesma desenvoltura.</segment>
    <segment id="33">Para garantir a autenticidade dos pratos regionais</segment>
    <segment id="34">, Zé Branco conta com a ajuda de cozinheiras locais</segment>
    <segment id="35">, como</segment>
    <segment id="36">como a Benedita</segment>
    <segment id="37">, responsável pelo preparo de delícias</segment>
    <segment id="38">comocomo os acarajés e os croquetes de siri com molho picante</segment>
    <segment id="39">, imperdíveis.</segment>
    <segment id="40">O cardápio é dividido em entradas</segment>
    <segment id="41">, massas</segment>
    <segment id="42">, risotos</segment>
    <segment id="43">, principais</segment>
    <segment id="44">, seleção baiana</segment>
    <segment id="45">, menu kids e sobremesas.</segment>
    <segment id="46">As moquecas são guarnecidas com arroz</segment>
    <segment id="47">, farofa e pirão e aparecem em porções individuais ou para compartilhar.</segment>
    <segment id="48">São aromáticas</segment>
    <segment id="49">, delicadas</segment>
    <segment id="50">masmas ricas em sabor e muito bem servidas.</segment>
    <segment id="51">O bobó de camarão também faz bonito e traz o azeite de dendê no ponto.</segment>
    <segment id="52">Um dos destaques do menu é o ravioli de peixe ao molho de vinho branco</segment>
    <segment id="53">, que revela leveza e um molho apurado que deleita o paladar.</segment>
    <segment id="54">Uma sobremesa certeira é a cocada ao forno com sorvete de rapadura</segment>
    <segment id="55">, cachaça e especiarias.</segment>
    <segment id="56">Ou o tradicional tiramisù</segment>
    <segment id="57">, um clássico do Fasano.</segment>
    <segment id="58">O restaurante conta também com um ponto de atendimento na praia</segment>
    <segment id="59">, em meio à vegetação e sob uma imensa amendoeira.</segment>
    <segment id="60">Não bastasse o cenário privilegiado --um autêntico pé na areia com mesas e confortáveis poltronas--</segment>
    <segment id="61">a refeição é animada pelos sets da DJ Monica Soldan</segment>
    <segment id="62">, que mesclam de MPB ao deep house.</segment>
    <segment id="63">No cardápio</segment>
    <segment id="64">, brilham os frutos do mar</segment>
    <segment id="65">, como</segment>
    <segment id="66">como o ceviche de peixe branco e o carpaccio de salmão</segment>
    <segment id="67">, ou em preparos na brasa</segment>
    <segment id="68">, como</segment>
    <segment id="69">como os espetinhos de camarão e o peixe inteiro grelhado</segment>
    <segment id="70">, servido com legumes e farofa.</segment>
    <segment id="71">O Hotel Fasano Trancoso fica na Praia de Itapororoca</segment>
    <segment id="72">, em um dos trechos mais privilegiados da região</segment>
    <segment id="73">, e o restaurante é aberto também a não hóspedes mediante reserva.</segment>
    <segment id="74">Prazer garantido.</segment>
    <segment id="75">Hotel Fasano Trancoso: Estrada de Itaquena</segment>
    <segment id="76">, 3.925</segment>
    <segment id="77">, Trancoso</segment>
    <segment id="78">, Bahia WhatsApp: (73)</segment>
    <segment id="79">99818-1091</segment>
  </rst>
</analysis>