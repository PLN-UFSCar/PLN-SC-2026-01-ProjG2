  <rst>
    <segment id="1">O deputado federal Alexandre Frota (PSDB-SP) diz que está apostando tudo na candidatura do governador paulista</segment>
    <segment id="2">, Rodrigo Garcia (PSDB)</segment>
    <segment id="3">, e na sua para deputado estadual por São Paulo.</segment>
    <segment id="4">Ele e a esposa</segment>
    <segment id="5">, Fabi Frota</segment>
    <segment id="6">, estiveram na noite deste sábado (23) no Camarote Bar Brahma</segment>
    <segment id="7">, no Sambódromo do Anhembi</segment>
    <segment id="8">, em São Paulo.</segment>
    <segment id="9">"</segment>
    <segment id="10">Eu trabalho muito bem com o governo desde a época do [João] Doria.</segment>
    <segment id="11">Assumi o compromisso junto com o PSDB de trabalhar para a eleição do Rodrigo.</segment>
    <segment id="12">Também vou aproveitar para ficar mais perto da família</segment>
    <segment id="13">, eu tenho uma filhinha de três anos"</segment>
    <segment id="14">, afirmou.</segment>
    <segment id="15">O deputado Alexandre Frota e sua esposa</segment>
    <segment id="16">, Fabi Frota</segment>
    <segment id="17">, no Camarote Bar Bhrama</segment>
    <segment id="18">, no Sambódromo do Anhembi</segment>
    <segment id="19">, em São Paulo - Lucas Ramos/AgNewsFrota destacou que nos últimos três anos trabalhou bastante para o social</segment>
    <segment id="20">, o estado e a cidade de São Paulo.</segment>
    <segment id="21">"</segment>
    <segment id="22">Eu conversei muito</segment>
    <segment id="23">porque</segment>
    <segment id="24">porque o partido não queria [que ele deixasse de disputar uma cadeira na Câmara Federal]</segment>
    <segment id="25">, masmas agora a gente acertou e</segment>
    <segment id="26">, sese Deus quiser</segment>
    <segment id="27">, vai dar tudo certo.</segment>
    <segment id="28">"</segment>
    <segment id="29">Sobre a disputa interna no PSDB em torno da candidatura de Doria à Presidência</segment>
    <segment id="30">, Frota lembrou que ninguém queria que ele fosse candidato à prefeitura e ao Governo de São Paulo</segment>
    <segment id="31">, masmas o tucano venceu as prévias e as eleições.</segment>
    <segment id="32">"</segment>
    <segment id="33">Eu converso com ele [Doria] quase todos os dias</segment>
    <segment id="34">, e ele fala para mim que vai ganhar.</segment>
    <segment id="35">"</segment>
    <segment id="36">Famosos no segundo dia do grupo especial em São</segment>
    <segment id="37">PauloMais    novamente         de   de  de  representando um    Segundo Frota</segment>
    <segment id="38">, o PSDB está confuso</segment>
    <segment id="39">, muito rachado e em guerra por causa da terceira via.</segment>
    <segment id="40">Ele afirma que a legenda tem muito cacique querendo brilhar em uma tribo só.</segment>
    <segment id="41">"</segment>
    <segment id="42">Acho que a gente tem que aguardar.</segment>
    <segment id="43">Daqui a dois meses</segment>
    <segment id="44">a gente vai poder entender</segment>
    <segment id="45">para que</segment>
    <segment id="46">para que lado o país vai seguir</segment>
    <segment id="47">, ou se</segment>
    <segment id="48">se vai ficar nessa polarização.</segment>
    <segment id="49">"</segment>
    <segment id="50">Em uma eventual disputa entre Luiz Inácio Lula da Silva (PT) e Jair Bolsonaro (PL)</segment>
    <segment id="51">, Frota não declarou voto em nenhum dos dois.</segment>
    <segment id="52">"</segment>
    <segment id="53">O que eu posso falar é que em Bolsonaro eu não voto nunca mais.</segment>
    <segment id="54">Bolsonaro não tem meu voto</segment>
    <segment id="55">, não tem meu apoio</segment>
    <segment id="56">, seja com quem ele vá para o segundo turno.</segment>
    <segment id="57">"</segment>
  </rst>
</analysis>