  <rst>
    <segment id="1">Nos anos 1970</segment>
    <segment id="2">, conheci na Fran&amp;ccedil</segment>
    <segment id="3">;a &amp;mdash</segment>
    <segment id="4">;e passei a frequentar</segment>
    <segment id="5">, em viagens posteriores&amp;mdash</segment>
    <segment id="6">; uma charmosa loja de vinhos chamada Les Caves de la Madeleine</segment>
    <segment id="7">, aberta em 1971 na margem direita do Sena.</segment>
    <segment id="8">Ali funcionava tamb&amp;eacute</segment>
    <segment id="9">;m a primeira escola de vinhos aberta ao p&amp;uacute</segment>
    <segment id="10">;blico comum</segment>
    <segment id="11">, chamada Acad&amp;eacute</segment>
    <segment id="12">;mie du Vin.</segment>
    <segment id="13">Nada de surpreendente</segment>
    <segment id="14">, estando em Paris.</segment>
    <segment id="15">A n&amp;atilde</segment>
    <segment id="16">;o ser pelo fato de que seu dono n&amp;atilde</segment>
    <segment id="17">;o era franc&amp;ecirc</segment>
    <segment id="18">;s: era um ingl&amp;ecirc</segment>
    <segment id="19">;s, Steven Spurrier</segment>
    <segment id="20">, que morreu de causas n&amp;atilde</segment>
    <segment id="21">;o divulgadas na madrugada de hoje</segment>
    <segment id="22">, rodeado pela fam&amp;iacute</segment>
    <segment id="23">;lia, em sua casa em Dorset</segment>
    <segment id="24">, na Inglaterra</segment>
    <segment id="25">, aos 79 anos.</segment>
    <segment id="26">Seu atrevimento em pontificar sobre vinhos na Fran&amp;ccedil</segment>
    <segment id="27">;a era patente.</segment>
    <segment id="28">Ele adorava</segment>
    <segment id="29">, divulgava e vendia vinhos franceses</segment>
    <segment id="30">, masmas tamb&amp;eacute</segment>
    <segment id="31">;m fazia algo raro naquele pa&amp;iacute</segment>
    <segment id="32">;s: promover e vender vinhos de fora</segment>
    <segment id="33">, como</segment>
    <segment id="34">como por exemplo vinhos do Porto</segment>
    <segment id="35">, de Jerez e da Madeira.</segment>
    <segment id="36">O amante de vinhos Steven Spurrier</segment>
    <segment id="37">, durante degustação em feira de São Paulo</segment>
    <segment id="38">, em 2014 - Ivan Almeida/DivulgaçãoMas o que tornou Spurrier e sua loja famosos foi uma degusta&amp;ccedil</segment>
    <segment id="39">;&amp;atilde</segment>
    <segment id="40">;o que ele organizou ali</segment>
    <segment id="41">, em 1976</segment>
    <segment id="42">, e que ficou conhecida</segment>
    <segment id="43">comocomo o Julgamento de Paris</segment>
    <segment id="44">, no qual &amp;mdash</segment>
    <segment id="45">;desta vez</segment>
    <segment id="46">, inadvertidamente&amp;mdash</segment>
    <segment id="47">;</segment>
    <segment id="48">ele mais uma vez lan&amp;ccedil</segment>
    <segment id="49">;ou a luz sobre vinhos n&amp;atilde</segment>
    <segment id="50">;o franceses.</segment>
    <segment id="51">A degusta&amp;ccedil</segment>
    <segment id="52">;&amp;atilde</segment>
    <segment id="53">;o foi planejada para cotejar grandes vinhos franceses com outros</segment>
    <segment id="54">, sobejamente desconhecidos no mundo</segment>
    <segment id="55">, vindos do ent&amp;atilde</segment>
    <segment id="56">;o obscuro vale californiano do Napa</segment>
    <segment id="57">, num pa&amp;iacute</segment>
    <segment id="58">;s sem tradi&amp;ccedil</segment>
    <segment id="59">;&amp;atilde</segment>
    <segment id="60">;o vin&amp;iacute</segment>
    <segment id="61">;cola, os Estados Unidos.</segment>
    <segment id="62">Um embate aparentemente t&amp;atilde</segment>
    <segment id="63">;o esdr&amp;uacute</segment>
    <segment id="64">;xulo que a imprensa francesa sequer compareceu ao evento &amp;mdash</segment>
    <segment id="65">;o &amp;uacute</segment>
    <segment id="66">;nico</segment>
    <segment id="67">jornalista presente era da revista americana Time (que depois faria uma bomb&amp;aacute</segment>
    <segment id="68">;stica mat&amp;eacute</segment>
    <segment id="69">;ria a respeito).  J&amp;aacute</segment>
    <segment id="70">;</segment>
    <segment id="71">o j&amp;uacute</segment>
    <segment id="72">;ri era composto por degustadores de alto coturno (</segment>
    <segment id="73">comocomo o dono do vinho Roman&amp;eacute</segment>
    <segment id="74">;e-Conti</segment>
    <segment id="75">, Aubert de Villaine</segment>
    <segment id="76">, a editora da revista La Revue du Vin de France e sommeliers de grandes restaurantes) e</segment>
    <segment id="77">, mesmo sendo uma degusta&amp;ccedil</segment>
    <segment id="78">;&amp;atilde</segment>
    <segment id="79">;o &amp;agrave</segment>
    <segment id="80">;s cegas (o j&amp;uacute</segment>
    <segment id="81">;ri n&amp;atilde</segment>
    <segment id="82">;o sabia quais vinhos estava provando)</segment>
    <segment id="83">, o pr&amp;oacute</segment>
    <segment id="84">;prio Spurrier estava certo de que os franceses venceriam de lavada.</segment>
    <segment id="85">Mas entre os tintos</segment>
    <segment id="86">, todos da uva cabernet sauvignon</segment>
    <segment id="87">, ganhou o americano Stag&amp;#39</segment>
    <segment id="88">;s Leap Cabernet Sauvignon 1973</segment>
    <segment id="89">, batendo grandes Bordeaux</segment>
    <segment id="90">comocomo Mouton-Rothschild e Haut Brion.</segment>
    <segment id="91">E entre os brancos</segment>
    <segment id="92">, venceu o tamb&amp;eacute</segment>
    <segment id="93">;m californiano do Napa Chateau Montelena Chardonnay 1973</segment>
    <segment id="94">, batendo os franceses da Bourgogne.</segment>
    <segment id="95">Com isso</segment>
    <segment id="96">, os americanos entraram para a hist&amp;oacute</segment>
    <segment id="97">;ria do vinho &amp;mdash</segment>
    <segment id="98">;assim</segment>
    <segment id="99">comocomo o ingl&amp;ecirc</segment>
    <segment id="100">;s Spurrier</segment>
    <segment id="101">, mesmo com os franceses alegando que seus vinhos</segment>
    <segment id="102">, que evoluiriam mais lentamente</segment>
    <segment id="103">, eram muito jovens (n&amp;atilde</segment>
    <segment id="104">;o estariam ainda em seu esplendor) para comparar com americanos de safras semelhantes.</segment>
    <segment id="105">Anos depois deste evento</segment>
    <segment id="106">, o ingl&amp;ecirc</segment>
    <segment id="107">;s voltou para seu pa&amp;iacute</segment>
    <segment id="108">;s natal</segment>
    <segment id="109">, onde nasceu em 1941 e onde come&amp;ccedil</segment>
    <segment id="110">;ara sua carreira nos anos 1960</segment>
    <segment id="111">, trabalhando na Chistopher&amp;#39</segment>
    <segment id="112">;s, a mais antiga loja de vinhos de Londres.</segment>
    <segment id="113">De volta ao lar</segment>
    <segment id="114">, desenvolveu sua carreira</segment>
    <segment id="115">comocomo consultor de lojas</segment>
    <segment id="116">, vin&amp;iacute</segment>
    <segment id="117">;colas e importadoras</segment>
    <segment id="118">, escreveu livros (</segment>
    <segment id="119">comocomo o mais recente</segment>
    <segment id="120">, sua autobiografia intitulada &amp;quot</segment>
    <segment id="121">;A Life in Wine&amp;quot</segment>
    <segment id="122">;), publicou colunas e participou em v&amp;aacute</segment>
    <segment id="123">;rios postos editoriais na importante revista Decanter.</segment>
    <segment id="124">Para completar</segment>
    <segment id="125">, fundou uma vin&amp;iacute</segment>
    <segment id="126">;cola &amp;mdash</segment>
    <segment id="127">;a Bride Valley Vineyard</segment>
    <segment id="128">, em Dorset</segment>
    <segment id="129">, onde morava.</segment>
    <segment id="130">Mas nunca deixou de ser lembrado pela famosa degusta&amp;ccedil</segment>
    <segment id="131">;&amp;atilde</segment>
    <segment id="132">;o de 1976.</segment>
    <segment id="133">O evento chegou a virar filme recentemente.</segment>
    <segment id="134">&amp;quot;Bottle Shock&amp;quot</segment>
    <segment id="135">; (2008)</segment>
    <segment id="136">, ou em portugu&amp;ecirc</segment>
    <segment id="137">;s, &amp;quot</segment>
    <segment id="138">;O</segment>
    <segment id="139">Julgamento de Paris&amp;quot</segment>
    <segment id="140">;, est&amp;aacute</segment>
    <segment id="141">; dispon&amp;iacute</segment>
    <segment id="142">;vel na Amazon Prime Video</segment>
    <segment id="143">, masmas</segment>
    <segment id="144">, infelizmente</segment>
    <segment id="145">, apenas em vers&amp;atilde</segment>
    <segment id="146">;o dublada.</segment>
    <segment id="147">Alan Rickman</segment>
    <segment id="148">comocomo Steven Spurrier em cena do filme &amp;quot</segment>
    <segment id="149">;O Julgamento de Paris&amp;quot</segment>
    <segment id="150">; - DivulgaçãoNele</segment>
    <segment id="151">, Spurrier &amp;eacute</segment>
    <segment id="152">; representado pelo ator Alan Rickman</segment>
    <segment id="153">comocomo um ingl&amp;ecirc</segment>
    <segment id="154">;s esnobe e pern&amp;oacute</segment>
    <segment id="155">;stico</segment>
    <segment id="156">, o que &amp;eacute</segment>
    <segment id="157">; injusto.</segment>
    <segment id="158">Conheci Spurrier</segment>
    <segment id="159">, ainda que superficialmente</segment>
    <segment id="160">, em eventos (inclusive no Brasil)</segment>
    <segment id="161">, e ele foi sempre uma pessoa elegantemente trajada</segment>
    <segment id="162">, masmas educado e gentil.</segment>
    <segment id="163">Como um sincero amante do vinho deveria sempre ser.</segment>
  </rst>
</analysis>