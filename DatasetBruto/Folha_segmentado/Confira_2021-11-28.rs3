  <rst>
    <segment id="1">O gabarito oficial do Enem 2021 só deve ser divulgado em 1º de dezembro</segment>
    <segment id="2">, masmas a Folha preparou</segment>
    <segment id="3">, em parceria com o colégio Objetivo</segment>
    <segment id="4">, uma correção extraoficial das provas de matemática e ciências da natureza</segment>
    <segment id="5">, que aconteceram neste domingo (28).</segment>
    <segment id="6">As questões tiveram enunciados baseados em temas</segment>
    <segment id="7">comocomo dengue</segment>
    <segment id="8">, extinção no Pantanal e até campeonato de futebol</segment>
    <segment id="9">, masmas a pandemia de coronavírus ficou de fora.</segment>
    <segment id="10">Veja imagens do 1º dia da prova do Enem</segment>
    <segment id="11">, em São Paulo Mais    novamente         de   de  de  representando um</segment>
    <segment id="12">Para os professores do Objetivo</segment>
    <segment id="13">, foi uma prova que exigiu dos candidatos não só boa interpretação de textos e tabelas</segment>
    <segment id="14">, masmas conhecimento específico dos temas tratados.</segment>
