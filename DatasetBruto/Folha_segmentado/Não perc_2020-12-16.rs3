  </header>
  <rst>
    <segment id="1">Tudo começou numa inocente consulta ao mapa —no</segment>
    <segment id="2">casocaso</segment>
    <segment id="3">, o do Google.</segment>
    <segment id="4">Eu não precisava saber um caminho: o motorista sabia</segment>
    <segment id="5">comocomo chegar ao restaurante</segment>
    <segment id="6">O Jardim</segment>
    <segment id="7">, em Belo Horizonte.</segment>
    <segment id="8">Eu queria apenas saciar uma velha mania: tentar localizar-me no espaço.</segment>
    <segment id="9">Mesmo que não esteja guiando</segment>
    <segment id="10">, gosto de checar que</segment>
    <segment id="11">, saindo do aeroporto de Heathrow</segment>
    <segment id="12">, meu deslocamento para Londres</segment>
    <segment id="13">sese dá em direção ao leste —enquanto em Nova York</segment>
    <segment id="14">, do aeroporto JFK a Manhattan</segment>
    <segment id="15">, será para noroeste</segment>
    <segment id="16">, por exemplo.</segment>
    <segment id="17">Melhores restaurantes da América Latina    novamente         de   de  de  representando um  Parece que o mar</segment>
    <segment id="18">, no Brasil</segment>
    <segment id="19">, fica quase sempre a leste das cidades</segment>
    <segment id="20">, masmas minha curiosidade cartográfica alerta que</segment>
    <segment id="21">, da orla</segment>
    <segment id="22">, quase nunca vemos realmente o nascente —é até comum assistirmos</segment>
    <segment id="23">, no horizonte do mar</segment>
    <segment id="24">, a belíssimos pores do sol (que</segment>
    <segment id="25">, como</segment>
    <segment id="26">como sabemos</segment>
    <segment id="27">, acontece no oeste).</segment>
    <segment id="28">Portanto em Belo</segment>
    <segment id="29">Horizonte</segment>
    <segment id="30">eu só queria saber que trajeto faria.</segment>
    <segment id="31">Mas, ao digitar o nome do restaurante</segment>
    <segment id="32">, surgiu na tela o endereço</segment>
    <segment id="33">, a localização...</segment>
    <segment id="34">E a informação: “Combina 84%”.</segment>
    <segment id="35">Combina o quê?</segment>
    <segment id="36">Com quem?</segment>
    <segment id="37">Abismado</segment>
    <segment id="38">, cliquei no ícone para entrar nos intestinos da informação do Google —algo que</segment>
    <segment id="39">, claro</segment>
    <segment id="40">, o gigante jamais permitirá de verdade.</segment>
    <segment id="41">Mas pude entender que ele estava informando a este estúpido usuário que o restaurante “combina” comigo.</segment>
    <segment id="42">Em 84% —seja isso o que for.</segment>
    <segment id="43">Eu ainda não conhecia esta absurda presunção de decidir por mim</segment>
    <segment id="44">sese eu combino ou não com algo.</segment>
    <segment id="45">Como se</segment>
    <segment id="46">se fosse um aplicativo de namoro me explicando quem eu amo ou não —sem que fosse preciso eu conhecer a pobre vítima.</segment>
    <segment id="47">O Google faz isso com a espionagem sistemática da nossa vida</segment>
    <segment id="48">, o muito que sabe sobre nós (afinal</segment>
    <segment id="49">, é nos vendendo aos anunciantes que</segment>
    <segment id="50">sese tornou bilionário).</segment>
    <segment id="51">Ou, nas palavras mais comedidas deles</segment>
    <segment id="52">, apontam a “probabilidade de você gostar de um lugar com base nos seus interesses</segment>
    <segment id="53">, classificações</segment>
    <segment id="54">, atividade na web e de apps e histórico de localização”.</segment>
    <segment id="55">Coisas</segment>
    <segment id="56">, aliás</segment>
    <segment id="57">, que muita gente</segment>
    <segment id="58">, ao bel-prazer</segment>
    <segment id="59">, adora desnudar.</segment>
    <segment id="60">Infelizmente só encontrei o tal “combina” em buscas de restaurantes.</segment>
    <segment id="61">Tentei museus</segment>
    <segment id="62">, lojas —e nada.</segment>
    <segment id="63">E, mesmo um restaurante que tem “bar” no nome</segment>
    <segment id="64">, A Casa do Porco Bar</segment>
    <segment id="65">, ficou sem classificação (mesmo recém-eleito o melhor do Brasil).</segment>
    <segment id="66">Em compensação</segment>
    <segment id="67">, dos mesmos donos</segment>
    <segment id="68">, deram meu match com o Bar da Dona Onça (combina... 49%...</segment>
    <segment id="69">Só?</segment>
    <segment id="70">E aquela dobradinha</segment>
    <segment id="71">, aquele fígado acebolado</segment>
    <segment id="72">, aquela galinhada com quiabo?</segment>
    <segment id="73">Ufa, o Google realmente não me conhece).</segment>
    <segment id="74">A Casa do Porco</segment>
    <segment id="75">, Bar da Dona Onça e Hot Pork   novamente         de   de  de  representando um</segment>
    <segment id="76">O Fasano cravou 79%.</segment>
    <segment id="77">OK, mas</segment>
    <segment id="78">mas não</segment>
    <segment id="79">sese explica que ganhou do Arpège (70%)</segment>
    <segment id="80">, em Paris</segment>
    <segment id="81">, e do Alain Ducasse de Monte Carlo (71%).</segment>
    <segment id="82">O Le Jazz explodiu com 90%</segment>
    <segment id="83">; masmas</segment>
    <segment id="84">comocomo o Maní ficou em humilhantes 56% —os vigilantes não perceberam que é um dos meus preferidos?</segment>
    <segment id="85">Os recém-classificados melhores restaurantes da América Latina cravaram todos meros 47% (</segment>
    <segment id="86">porque</segment>
    <segment id="87">porque a França</segment>
    <segment id="88">, tão mais longe</segment>
    <segment id="89">, pontua tão mais?).</segment>
    <segment id="90">O engraçado é clicar no tal “combina” e ver a explicação para cada lugar —sempre meio igual:</segment>
    <segment id="91">“Você parece</segment>
    <segment id="92">sese interessar por culinária sofisticada</segment>
    <segment id="93">, vinhos excelentes e culinária italiana”</segment>
    <segment id="94">; ou “por coquetéis excelentes</segment>
    <segment id="95">, vinhos excelentes</segment>
    <segment id="96">, culinária sofisticada”.</segment>
    <segment id="97">Conclusão:</segment>
    <segment id="98">para que</segment>
    <segment id="99">para que ir provar um restaurante e tirar conclusões?</segment>
    <segment id="100">Besteira</segment>
    <segment id="101">, o Google nos poupa desse esforço.</segment>
    <segment id="102">Para que conhecer a moça para saber</segment>
    <segment id="103">sese vai gostar?</segment>
    <segment id="104">O carro?</segment>
    <segment id="105">A cidade turística?</segment>
    <segment id="106">Ou a vida?</segment>
    <segment id="107">O Grande Irmão te conta: não perca tempo vivendo.</segment>
    <segment id="108">Mas me pagam.</segment>
    <segment id="109">Passei uma hora com buscas para despistar os vigilantes.</segment>
    <segment id="110">Academias de triatlo</segment>
    <segment id="111">; lojas Salvatore Ferragamo</segment>
    <segment id="112">; Habib’s</segment>
    <segment id="113">; saunas gay.</segment>
    <segment id="114">Vou dar um nó na cabeça deles...</segment>
    <segment id="115">Quero ver</segment>
    <segment id="116">sese atreverem novamente a decidir por mim do que vou gostar ou não.</segment>
  </rst>
</analysis>