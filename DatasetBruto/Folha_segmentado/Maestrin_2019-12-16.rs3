  <rst>
    <segment id="1">A maestrina Marin Alsop receberá a primeira Medalha Tarsila do Amaral</segment>
    <segment id="2">, condecoração recém-criada pelo governo de SP para reconhecer artistas</segment>
    <segment id="3">, gestores e personalidades ligados às artes por suas contribuições ao setor cultural de São Paulo.</segment>
    <segment id="4">Outras 14 medalhas serão entregues no evento Premiações da Cultura</segment>
    <segment id="5">, no dia 29 de janeiro</segment>
    <segment id="6">, em São Paulo.</segment>
    <segment id="7">Leia a coluna completa aqui.</segment>
    <segment id="8">Marin Alsop agradece ao publico após apresentação na Sala São Paulo - Eduardo Knapp — 5.jul.2019/Folhapress</segment>
  </rst>
