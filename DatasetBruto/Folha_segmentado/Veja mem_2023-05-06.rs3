  <rst>
    <segment id="1">Amante não tem lar</segment>
    <segment id="2">, amante nunca vai casar</segment>
    <segment id="3">, dizem os versos de Marília Mendonça que foram parar nos assuntos mais comentados no Twitter na manhã deste sábado (6)</segment>
    <segment id="4">, quando o rei Charles 3º foi coroado na Abadia de Westminster.</segment>
    <segment id="5">A cerimônia</segment>
    <segment id="6">, que durou pouco mais de duas horas</segment>
    <segment id="7">, também coroou rainha Camilla.</segment>
    <segment id="8">Ocupante do trono britânico após a morte de Elizabeth 2ª</segment>
    <segment id="9">, o rei contrariou pedido feito pela soberana três meses antes de morrer:</segment>
    <segment id="10">que a nora fosse chamada apenas de 'rainha consorte'.</segment>
    <segment id="11">Amante de Charles</segment>
    <segment id="12">, Camilla e o então príncipe</segment>
    <segment id="13">sese casaram em 2005</segment>
    <segment id="14">, oito anos após morte de princesa Diana em 1997.</segment>
    <segment id="15">Diana é mãe dos príncipes</segment>
    <segment id="16">William e Harry.</segment>
    <segment id="17">Agora rei e rainha</segment>
    <segment id="18">, Charles e Camilla já formavam um casal em 1972</segment>
    <segment id="19">, antes de</segment>
    <segment id="20">sese tornarem um casal de adúlteros famosos.</segment>
    <segment id="21">Ao longo da formalidade transmitida ao vivo nesta manhã</segment>
    <segment id="22">, os termos "Amante" e "Diana" chegaram aos assuntos do momento no Brasil.</segment>
    <segment id="23">Publicações nas redes dizem que Diana é quem deveria estar</segment>
    <segment id="24">sese tornando rainha.</segment>
    <segment id="25">"</segment>
    <segment id="26">Camila</segment>
    <segment id="27">Parker Bowles é a prova de que amante tem lar</segment>
    <segment id="28">, sim!</segment>
    <segment id="29">Viu Marília Mendonça?</segment>
    <segment id="30">", escreveu um.</segment>
    <segment id="31">"Tem até coroa"</segment>
    <segment id="32">, disseram outros.</segment>
    <segment id="33">Entre memes</segment>
    <segment id="34">, perfis apontam misoginia nos comentários sobre a nova rainha e criticam conservadorismo.</segment>
    <segment id="35">"[O] povo: ‘uma mancha na história da coroa britânica’.</segment>
    <segment id="36">Como se</segment>
    <segment id="37">se a coroa britânica nunca tivesse feito nada</segment>
    <segment id="38">, tipo genocídio de outras nações</segment>
    <segment id="39">, masmas o que é isso perto de coroar a amante</segment>
    <segment id="40">, né?</segment>
    <segment id="41">", escreve um perfil.</segment>
    <segment id="42">Além das publicações envolvendo a polêmica amorosa que marca a história da família real britânica</segment>
    <segment id="43">, internautas brincam com o fato de o rei começar sua vida de trabalho aos 74 anos.</segment>
    <segment id="44">Outros dizem que ele teria atuado em frentes importantes nas últimas décadas</segment>
    <segment id="45">, como</segment>
    <segment id="46">como questões ligadas à urbanização.</segment>
    <segment id="47">"</segment>
    <segment id="48">Charles III"</segment>
    <segment id="49">, "The Crown" e "</segment>
    <segment id="50">William" surgem entre termos envolvendo a família nos assuntos do momento.</segment>
    <segment id="51">Tuiteiros também compartilham trechos da cerimônia contendo caras feitas pelos filhos de príncipe</segment>
    <segment id="52">William e Kate Middleton</segment>
    <segment id="53">, e outros detalhes da cerimônia</segment>
    <segment id="54">, como</segment>
    <segment id="55">como a presença da cantora Katy Perry.</segment>
  </rst>
</analysis>