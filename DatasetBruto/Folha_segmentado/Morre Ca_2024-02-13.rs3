  <rst>
    <segment id="1">Símbolo da comunidade LGBTQIA+</segment>
    <segment id="2">, Camille K morreu</segment>
    <segment id="3">, nesta segunda-feira</segment>
    <segment id="4">, aos 78 anos.</segment>
    <segment id="5">Ela fez parte da primeira geração de artistas travestis do país</segment>
    <segment id="6">, que se</segment>
    <segment id="7">se apresentava no palco do Teatro Rival</segment>
    <segment id="8">, no centro do Rio de Janeiro.</segment>
    <segment id="9">A causa da morte não foi informada.</segment>
    <segment id="10">Camille K.</segment>
    <segment id="11">, personagem do documentário de Leandra Leal sobre as &amp;#039</segment>
    <segment id="12">;Divinas Divas&amp;#039</segment>
    <segment id="13">;, nos bastidores do Teatro Rival - Rony Maltz/FolhapressOs últimos tempos</segment>
    <segment id="14">, porém</segment>
    <segment id="15">porém, foram difíceis para Camille.</segment>
    <segment id="16">No ano passado</segment>
    <segment id="17">, ela sofreu com problemas financeiros e com a saúde</segment>
    <segment id="18">, já debilitada.</segment>
    <segment id="19">Durante a pandemia</segment>
    <segment id="20">, ela teve de parar de</segment>
    <segment id="21">sese apresentar e não conseguiu voltar aos palcos</segment>
    <segment id="22">, porque</segment>
    <segment id="23">porque sofreu uma queda e fraturou o ombro.</segment>
    <segment id="24">Entre seus trabalhos mais conhecidos</segment>
    <segment id="25">, estão as colaborações com Miguel Falabella.</segment>
    <segment id="26">Nos anos 1990</segment>
    <segment id="27">, Camille virou musa do diretor</segment>
    <segment id="28">, ao participar da peça "</segment>
    <segment id="29">No Coração do Brasil"</segment>
    <segment id="30">, com Maria Padilha</segment>
    <segment id="31">, Jacqueline Laurence e Thales Pan Chacon.</segment>
    <segment id="32">Em seguida</segment>
    <segment id="33">, a parceria foi retomada na peça "</segment>
    <segment id="34">A Pequena Mártir de Cristo Rei"</segment>
    <segment id="35">, que não teve o mesmo sucesso de público e crítica.  Leandra Leal dirige documentário sobre travestisMais    novamente         de   de  de  representando um</segment>
    <segment id="36">Na época</segment>
    <segment id="37">, a atriz estava no auge de sua popularidade</segment>
    <segment id="38">, sendo cultuada nas revistas especializadas na comunidade gay.</segment>
    <segment id="39">Há oito anos</segment>
    <segment id="40">, Camille foi uma das personagens do documentário "Divinas Divas"</segment>
    <segment id="41">, dirigido por Leandra Leal.</segment>
    <segment id="42">O filme conta a história de oito travestis</segment>
    <segment id="43">, que foram pioneiras no palco do Teatro Rival.</segment>
    <segment id="44">Nas redes sociais</segment>
    <segment id="45">, Leal lamentou a morte de Camille.</segment>
    <segment id="46">"</segment>
    <segment id="47">Ela era um diva.</segment>
    <segment id="48">Camille foi a pessoa mais elegante e vaidosa que eu ja conheci</segment>
    <segment id="49">, minha artista virginiana</segment>
    <segment id="50">, hilária e muito consciente.</segment>
    <segment id="51">Ela teve a sorte de viver um grande amor.</segment>
    <segment id="52">Camille dizia 'a arte é divina de mais para ser normal</segment>
    <segment id="53">, todo artista tem uma luz diferente'</segment>
    <segment id="54">, e Camille era iluminada"</segment>
    <segment id="55">, escreveu a atriz e diretora.</segment>
  </rst>
</analysis>