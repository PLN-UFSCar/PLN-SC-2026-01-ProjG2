  <rst>
    <segment id="1">Ausente durante a maior parte dos eventos que celebraram seus 70 anos de reinado</segment>
    <segment id="2">, Elizabeth 2ª</segment>
    <segment id="3">, 96, fez uma aparição surpresa na varanda do Palácio de Buckingham neste domingo (5)</segment>
    <segment id="4">, último dia das festividades relacionadas ao Jubileu de Platina.</segment>
    <segment id="5">A monarca usava um vestido verde e estava acompanhada de seu filho Charles</segment>
    <segment id="6">, o primeiro na linha de sucessão do trono britânico</segment>
    <segment id="7">, ao lado da esposa Camila</segment>
    <segment id="8">, além do neto William</segment>
    <segment id="9">, com a esposa Kate e os três filhos do casal.</segment>
    <segment id="10">Ela sorriu e acenou para a multidão ali presente</segment>
    <segment id="11">, que agitava freneticamente bandeirinhas do Reino Unido.</segment>
    <segment id="12">A rainha Elizabeth 2ª na varanda do Palácio de Buckingham ao lado de (da esq.</segment>
    <segment id="13">para a dir.</segment>
    <segment id="14">): a duquesa de Cornualha</segment>
    <segment id="15">, Camilla</segment>
    <segment id="16">, o príncipe Charles</segment>
    <segment id="17">, o príncipe Willian</segment>
    <segment id="18">, a duquesa de Cambridge</segment>
    <segment id="19">, Kate</segment>
    <segment id="20">, e os três filhos do casal - Henry Nicholls - 5.jun.22/ReutersElizabeth assistiu no Castelo de Windsor à maioria dos eventos que a homenagearam.</segment>
    <segment id="21">Alegando desconfortos de mobilidade</segment>
    <segment id="22">, a rainha mais longeva do Reino Unido foi representada por seus parentes</segment>
    <segment id="23">, em especial os herdeiros Charles e William</segment>
    <segment id="24">, além da princesa Anne</segment>
    <segment id="25">, nas festividades que tomaram conta do país desde quinta-feira (2).</segment>
    <segment id="26">A breve aparição —foram cerca de 10 minutos</segment>
    <segment id="27">, segundo a transmissão da britânica BBC— foi uma maneira de apaziguar a ausência da monarca.</segment>
    <segment id="28">Charles</segment>
    <segment id="29">, 73, vem aos poucos assumindo as funções públicas da mãe</segment>
    <segment id="30">, que chegou a ser internada para realizar exames no ano passado.</segment>
    <segment id="31">Lá foraReceba no seu email uma seleção semanal com o que de mais importante aconteceu no mundo</segment>
    <segment id="32">; aberta para não assinantes.</segment>
    <segment id="33">Carregando...</segment>
    <segment id="34">O herdeiro</segment>
    <segment id="35">, assim</segment>
    <segment id="36">comocomo a mãe</segment>
    <segment id="37">, goza de popularidade</segment>
    <segment id="38">, masmas em índices bem menores.</segment>
    <segment id="39">Charles tem cerca de 50% de opiniões favoráveis entre os britânicos</segment>
    <segment id="40">, de acordo com pesquisa recente do instituto YouGov</segment>
    <segment id="41">, enquanto Elizabeth tem 75%.</segment>
    <segment id="42">Apenas 32% acham que ele será um bom rei.</segment>
    <segment id="43">A monarca também divulgou um comunicado após o contato com o público.</segment>
    <segment id="44">Disse estar profundamente tocada com o fato de tantas pessoas terem comparecido aos eventos em sua homenagem: "</segment>
    <segment id="45">Embora eu não tenha participado de todos os eventos pessoalmente</segment>
    <segment id="46">, meu coração está com todos vocês</segment>
    <segment id="47">; e continuo comprometida em servi-los da melhor maneira possível</segment>
    <segment id="48">, com o apoio de minha família.</segment>
    <segment id="49">"  Disse também esperar que o que descreveu</segment>
    <segment id="50">comocomo o "renovado sentimento de união" dos últimos dias</segment>
    <segment id="51">"continue por muitos anos".</segment>
    <segment id="52">A fala foi semelhante à do príncipe Charles</segment>
    <segment id="53">, que pela manhã pediu que o mesmo sentimento de união represente o fim das brigas.</segment>
    <segment id="54">Mãe e filho não detalharam a que</segment>
    <segment id="55">sese referiam.</segment>
    <segment id="56">O Reino Unido</segment>
    <segment id="57">, no entanto</segment>
    <segment id="58">, vive uma crise do custo de vida</segment>
    <segment id="59">, impulsionada pelo aumento da inflação</segment>
    <segment id="60">, que, em abril</segment>
    <segment id="61">, atingiu seu nível mais alto em mais de 40 anos.</segment>
    <segment id="62">E, politicamente</segment>
    <segment id="63">, a situação tampouco é favorável.</segment>
    <segment id="64">O premiê Boris Johnson</segment>
    <segment id="65">, conservador</segment>
    <segment id="66">, entrou numa espiral de crises após participar de festas durante o período de rígidas restrições na Inglaterra para conter a Covid.</segment>
    <segment id="67">Consequentemente</segment>
    <segment id="68">, perdeu força nas eleições regionais e</segment>
    <segment id="69">sese viu abandonado por dezenas de correligionários.</segment>
    <segment id="70">Foi recebido com vaias durante um serviço religioso em homenagem à rainha na sexta-feira (3).</segment>
    <segment id="71">Rainha Elizabeth 2ª nos dois primeiros dias de celebrações do Jubileu de PlatinaMais    novamente         de   de  de  representando um  O último dia das celebrações do jubileu foi um mergulho na história da vida de Elizabeth.</segment>
    <segment id="72">Milhares de pessoas acompanharam</segment>
    <segment id="73">, ornamentadas com as cores da bandeira britânica</segment>
    <segment id="74">, a rota que a rainha fez no dia de sua coroação</segment>
    <segment id="75">, há 69 anos</segment>
    <segment id="76">, em 1953.</segment>
    <segment id="77">Dançarinos vestidos com roupas que marcaram as décadas da rainha no poder caminhavam pela importante avenida Mall</segment>
    <segment id="78">, que se</segment>
    <segment id="79">se estende até o Palácio de Buckingham.</segment>
    <segment id="80">A carruagem Gold State Coach</segment>
    <segment id="81">, que levou a monarca para a Abadia de Westminster</segment>
    <segment id="82">, quando ela foi coroada</segment>
    <segment id="83">, foi vista em público pela primeira vez em cerca de duas décadas</segment>
    <segment id="84">, depois de ter sido usada pela última vez no Jubileu de Ouro —50 anos no trono</segment>
    <segment id="85">, em 2002.</segment>
    <segment id="86">Por todo o país</segment>
    <segment id="87">, foram realizados milhares de almoços e festas de rua para lembrar a monarca.</segment>
    <segment id="88">Somente em Windsor</segment>
    <segment id="89">, 488 mesas foram colocadas na entrada do castelo onde reside a rainha</segment>
    <segment id="90">, e o príncipe Charles e sua esposa foram almoçar em um campo de críquete.</segment>
    <segment id="91">Carruagem Gold State Coach</segment>
    <segment id="92">, que levou Elizabeth 2ª para sua coroação há 69 anos</segment>
    <segment id="93">, desfila pela avenida The Mall</segment>
    <segment id="94">, em Londres</segment>
    <segment id="95">, no último dia de celebrações do Jubileu de Platina - Niklas Halle&amp;#039</segment>
    <segment id="96">;n - 5.jun.22/AFPAs comemorações do Jubileu de Platina tiveram início na quinta</segment>
    <segment id="97">, quando Elizabeth acompanhou</segment>
    <segment id="98">, da varanda do Palácio de Buckingham</segment>
    <segment id="99">, um desfile militar que reuniu cerca de 1.500 soldados e oficiais.</segment>
    <segment id="100">Na sexta</segment>
    <segment id="101">, por sua vez</segment>
    <segment id="102">, a rainha acompanhou as celebrações de forma remota.</segment>
    <segment id="103">Ela foi homenageada em um serviço religioso de ação de graças na Catedral de St Paul</segment>
    <segment id="104">, em Londres.</segment>
    <segment id="105">Já no sábado (4)</segment>
    <segment id="106">, a princesa Anne representou a monarca em uma tradicional corrida de cavalos</segment>
    <segment id="107">, e um show</segment>
    <segment id="108">, com artistas</segment>
    <segment id="109">comocomo a banda Queen &amp;amp</segment>
    <segment id="110">;</segment>
    <segment id="111">Adam Lambert</segment>
    <segment id="112">, foi transmitido e acompanhado virtualmente por mais de 12 milhões de pessoas.​</segment>
    <segment id="113">Elizabeth 2ª reinou por mais tempo do que qualquer um de seus antecessores.</segment>
    <segment id="114">Ela subiu ao trono aos 25 anos</segment>
    <segment id="115">, em 1952</segment>
    <segment id="116">, quando estava em viagem oficial ao Quênia</segment>
    <segment id="117">, após a morte de seu pai</segment>
    <segment id="118">, o rei George 6º.</segment>
    <segment id="119">O país</segment>
    <segment id="120">, àquela altura</segment>
    <segment id="121">, ainda emergia da devastação da Segunda Guerra Mundial</segment>
    <segment id="122">, e Winston Churchill era premiê —a rainha acompanhou 14 primeiros-ministros desde que chegou ao trono.</segment>
  </rst>
</analysis>