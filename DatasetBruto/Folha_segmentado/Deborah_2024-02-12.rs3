  <rst>
    <segment id="1">Minutos antes de entrar na Marquês de Sapucaí pelo Salgueiro</segment>
    <segment id="2">, Deborah Secco diz que está com o "coração acelerado".</segment>
    <segment id="3">Pelo quarto ano consecutivo</segment>
    <segment id="4">, ela desfila</segment>
    <segment id="5">comocomo musa da escola.</segment>
    <segment id="6">"</segment>
    <segment id="7">A gente vem para</segment>
    <segment id="8">sese divertir e fazer o Salgueiro campeão.</segment>
    <segment id="9">Nos empenhamos muito</segment>
    <segment id="10">, acho que neste ano o título vem"</segment>
    <segment id="11">, afirma ela</segment>
    <segment id="12">, que usa uma fantasia com inspiração indígena.</segment>
    <segment id="13">O enredo da escola de samba faz uma homenagem ao povo Yanomami.</segment>
    <segment id="14">A atriz Deborah Secco na Marquês de Sapucaí</segment>
    <segment id="15">, no Rio</segment>
    <segment id="16">, onde desfila pelo Salgueiro neste domingo (11) - Marlene Bergamo/FolhapressQuestionada</segment>
    <segment id="17">sese o marido</segment>
    <segment id="18">, Hugo Moura</segment>
    <segment id="19">, iria vê-la</segment>
    <segment id="20">, Deborah conta que ele foi curtir o Carnaval na Bahia.</segment>
    <segment id="21">"</segment>
    <segment id="22">O maridão está em Salvador.</segment>
    <segment id="23">No momento</segment>
    <segment id="24">, sabe-</segment>
    <segment id="25">sese lá Deus onde.</segment>
    <segment id="26">"</segment>
    <segment id="27">"</segment>
    <segment id="28">Ele é baiano e não larga Salvador.</segment>
    <segment id="29">E eu, carioca</segment>
    <segment id="30">, não largo a Sapucaí.</segment>
    <segment id="31">Então, a gente tem que</segment>
    <segment id="32">sese dividir"</segment>
    <segment id="33">, afirma.</segment>
    <segment id="34">Famosos e personalidades no primeiro dia de desfiles na SapucaíMais    novamente         de   de  de  representando um</segment>
    <segment id="35">A atriz já contou que ela e Hugo têm uma relação em que eles possuem liberdade para</segment>
    <segment id="36">sese relacionarem com outras pessoas.</segment>
    <segment id="37">O casal está junto desde 2015 e são pais de Maria Flor</segment>
    <segment id="38">, de oito anos.</segment>
    <segment id="39">"</segment>
    <segment id="40">Ela vinha [me ver] desfilar</segment>
    <segment id="41">, masmas ficou doentinha e não pôde"</segment>
    <segment id="42">, conta a atriz.</segment>
  </rst>
