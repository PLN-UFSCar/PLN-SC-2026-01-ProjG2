  <rst>
    <segment id="1">Chefs brasileiros estão cada vez mais preocupados em valorizar ingredientes que simbolizam nossa cultura</segment>
    <segment id="2">, ancestralidade e hospitalidade.</segment>
    <segment id="3">É isso que norteia o trabalho da chef Bel Coelho</segment>
    <segment id="4">, à frente do Cuia Café e Restaurante desde 2020.</segment>
    <segment id="5">Por isso</segment>
    <segment id="6">, junto com a bartender</segment>
    <segment id="7">Pri Okino</segment>
    <segment id="8">, Coelho ensina a receita de caipirinha de caju servida no Cuia.</segment>
    <segment id="9">Além das frutas frescas e da cachaça</segment>
    <segment id="10">, ela é feita com um xarope de açúcar e gengibre</segment>
    <segment id="11">, que facilita na hora de dosar e diluir.</segment>
    <segment id="12">Caipirinha de caju da chef</segment>
    <segment id="13">Bel Coelho - Divulgação/Cuia RestauranteEm</segment>
    <segment id="14">casocaso da falta do xarope</segment>
    <segment id="15">, o drinque pode ser adoçado com açúcar</segment>
    <segment id="16">, que deve ser macerado com as frutas.</segment>
    <segment id="17">Outra dica é escolher um limão com casca mais fina e macia</segment>
    <segment id="18">, porque</segment>
    <segment id="19">porque tem mais suco.</segment>
    <segment id="20">Veja o passo a passo.</segment>
    <segment id="21">CAIPIRINHA DE CAJU E LIMÃO</segment>
    <segment id="22">Rendimento: duas porções</segment>
    <segment id="23">Tempo de preparo: 25 minutos</segment>
    <segment id="24">Ingredientes  Para o xarope de gengibre e açúcar   250 g gengibre 500 ml água 500 g açúcar</segment>
    <segment id="25">Para a caipirinha   2 cajus 1 limão 40 ml de xarope de gengibre 100 ml de cachaça Gelo a gosto   Conheça o Cuia Café e RestauranteMais    novamente         de   de  de  representando um  Preparo</segment>
    <segment id="26">Primeiro prepare o xarope.</segment>
    <segment id="27">Descasque e pique o gengibre.</segment>
    <segment id="28">Bata com a água e coe.</segment>
    <segment id="29">Numa panela</segment>
    <segment id="30">, aqueça esse suco e quando ferver</segment>
    <segment id="31">, dissolva o açúcar.</segment>
    <segment id="32">Reserve Agora faça a caipirinha.</segment>
    <segment id="33">Numa tábua</segment>
    <segment id="34">, corte as pontas do limão</segment>
    <segment id="35">, depois longitudinalmente e</segment>
    <segment id="36">, a seguir</segment>
    <segment id="37">, em meia lua.</segment>
    <segment id="38">Coloque nos copos</segment>
    <segment id="39">Corte a tampinha do caju</segment>
    <segment id="40">, reserve.</segment>
    <segment id="41">Com uma faca</segment>
    <segment id="42">, divida o caju ao meio</segment>
    <segment id="43">, depois em meia lua e adicione ao copo.</segment>
    <segment id="44">Macere o limão e o caju</segment>
    <segment id="45">, acrescente o xarope de gengibre Despeje o gelo e</segment>
    <segment id="46">, por último</segment>
    <segment id="47">, a cachaça.</segment>
    <segment id="48">Com uma colher bailarina</segment>
    <segment id="49">, mexa bastante por baixo para misturar bem o xarope e as frutas</segment>
    <segment id="50">Finalize com as tampinhas do caju</segment>
  </rst>
</analysis>