  <rst>
    <segment id="1">Como é o</segment>
    <segment id="2">casocaso com vestidinhos pretinhos básicos</segment>
    <segment id="3">, receitas de frango assado nunca são demais.</segment>
    <segment id="4">Especialmente não as do tipo francês.</segment>
    <segment id="5">Por isso mesmo</segment>
    <segment id="6">, quando Florence Chapgier</segment>
    <segment id="7">, uma leitora nascida em Paris</segment>
    <segment id="8">masmas residente em Los Angeles</segment>
    <segment id="9">, enviou ao New York Times esta receita de sua mãe</segment>
    <segment id="10">, Christiane Baumgartner</segment>
    <segment id="11">, de frango assado com estragão</segment>
    <segment id="12">, manteiga e conhaque</segment>
    <segment id="13">, o jornal experimentou imediatamente.</segment>
    <segment id="14">Receita de frango assado - Adobe StockO nome que Chapgier deu ao prato</segment>
    <segment id="15">, "frango assado francês"</segment>
    <segment id="16">, transmite sua origem</segment>
    <segment id="17">, masmas não seu caráter singular.</segment>
    <segment id="18">O toque especial da receita é a alquimia entre a manteiga abundante quando</segment>
    <segment id="19">sese mistura ao caldo caramelizado que</segment>
    <segment id="20">sese forma quando o frango assa</segment>
    <segment id="21">, mais um ramo inteiro de estragão fresquinho e uma boa dose de conhaque.</segment>
    <segment id="22">O prato tem tão poucos ingredientes que Chapgier recomenda que você procure os de melhor qualidade: frango alimentado com milho ("</segment>
    <segment id="23">comocomo no sudoeste da França")</segment>
    <segment id="24">, conhaque VSOP ("você não vai precisar usar muito") e sal marinho rico em minerais.</segment>
    <segment id="25">O jornal testou a receita com um frango comum</segment>
    <segment id="26">, conhaque da Califórnia e sal kosher de supermercado local</segment>
    <segment id="27">, e mesmo assim ficou maravilhosa.</segment>
    <segment id="28">Portanto</segment>
    <segment id="29">, use os melhores ingredientes que você puder</segment>
    <segment id="30">, masmas não arranque os cabelos por conta disso.</segment>
    <segment id="31">Veja restaurantes que servem frango frito em SPMais    novamente         de   de  de  representando um</segment>
    <segment id="32">A técnica de assar não poderia ser mais simples: salgue o frango</segment>
    <segment id="33">, deixe a pele secar um pouco</segment>
    <segment id="34">, depois a cubra de manteiga amolecida e estragão e asse a 200ºC.</segment>
    <segment id="35">Quando o frango estiver totalmente assado</segment>
    <segment id="36">, desligue o forno e regue com o conhaque e o caldo formado na assadeira.</segment>
    <segment id="37">Deixe repousar por dez minutos no forno desligado para melhor absorver todos os sabores e então corte em pedaços</segment>
    <segment id="38">, regue a carne e a pele assada com bastante caldo amanteigado</segment>
    <segment id="39">, cheio de estragão</segment>
    <segment id="40">, e sirva.</segment>
    <segment id="41">Chapgier fez uma observação sobre o conhaque: desligue o forno antes de devolver o frango regado com conhaque ao forno para repousar.</segment>
    <segment id="42">Na única vez que ela</segment>
    <segment id="43">sese esqueceu disso</segment>
    <segment id="44">, o calor intenso pôs fogo no conhaque e rachou o vidro da porta de seu forno ("me pegou de surpresa"</segment>
    <segment id="45">, ela escreveu).</segment>
    <segment id="46">Diferentemente do "coq au vin"</segment>
    <segment id="47">, este frango francês não fica melhor flambado.</segment>
    <segment id="48">Frango assado com conhaque e estragão   - David Malosh/The New York TimesPara completar a refeição da maneira mais classicamente francesa</segment>
    <segment id="49">, sirva o frango com batatas –assadas</segment>
    <segment id="50">, fritas</segment>
    <segment id="51">, gratinadas ou</segment>
    <segment id="52">, a melhor opção de todas</segment>
    <segment id="53">, em purê—</segment>
    <segment id="54">, para que</segment>
    <segment id="55">para que elas possam absorver cada gota do molho aromático.</segment>
    <segment id="56">Polenta molinha é uma alternativa menos tradicional</segment>
    <segment id="57">, masmas igualmente saborosa.</segment>
    <segment id="58">Acompanhe com uma salada verde e um bom vinho</segment>
    <segment id="59">, "et voilà"</segment>
    <segment id="60">, está pronto.</segment>
    <segment id="61">Como é o</segment>
    <segment id="62">casocaso do pretinho básico</segment>
    <segment id="63">, quando o assunto é frango assado</segment>
    <segment id="64">, simplicidade é sofisticação –e</segment>
    <segment id="65">, neste</segment>
    <segment id="66">casocaso</segment>
    <segment id="67">, garante uma refeição deliciosa.</segment>
    <segment id="68">Frango assado com estragão e conhaque</segment>
    <segment id="69">Rendimento: 4 porções Tempo de preparo: duas horas e meia  Ingredientes   1 frango inteiro (1</segment>
    <segment id="70">,8 quilo) 2 colheres de chá de sal marinho grosso cinzento ou 2 ½ colheres de chá de sal kosher 6 colheres de sopa de manteiga sem sal amolecida 1 maço de estragão fresco</segment>
    <segment id="71">, com as folhas e os ramos tenros picados (cerca de ¾ de uma xícara) 2 colheres de sopa de conhaque 1 colher de chá de pimenta-do-reino moída na hora</segment>
    <segment id="72">Modo de fazer</segment>
    <segment id="73">Seque o frango com um pano de copa (ou papel-toalha) e esfreque sal por dentro e por fora.</segment>
    <segment id="74">Transfira para um prato ou travessa</segment>
    <segment id="75">, de preferência sobre uma grade</segment>
    <segment id="76">, e leve à geladeira sem cobrir por pelo menos uma hora ou até o dia seguinte.</segment>
    <segment id="77">Quando estiver pronto para assar o frango</segment>
    <segment id="78">, aqueça o forno a 200ºC. Numa tigela pequena combine a manteiga</segment>
    <segment id="79">, o estragão</segment>
    <segment id="80">, 1 colher de sopa de conhaque e a pimenta.</segment>
    <segment id="81">Esfregue essa mistura dentro da cavidade do frango e sobre e embaixo da pele.</segment>
    <segment id="82">Coloque o frango numa travessa funda ou numa panela grande que possa ir ao forno.</segment>
    <segment id="83">Asse-o</segment>
    <segment id="84">, com o peito para cima</segment>
    <segment id="85">, até a pele estar dourada e crocante e o escorrer um líquido claro quando você inserir um garfo na parte mais grossa da coxa</segment>
    <segment id="86">, depois de uma hora mais ou menos.</segment>
    <segment id="87">Desligue o forno –não</segment>
    <segment id="88">sese esqueça deste passo</segment>
    <segment id="89">, porque</segment>
    <segment id="90">porque</segment>
    <segment id="91">sese conhaque esquentar demais pode pegar fogo— e transfira a assadeira com o frango para o balcão.</segment>
    <segment id="92">Regue o frango com a colher de sopa restante de conhaque e com um pouco do caldo amanteigado da travessa.</segment>
    <segment id="93">Devolva o frango ao forno desligado e deixe-o repousar ali por dez minutos antes de cortar e servir.</segment>
  </rst>
</analysis>