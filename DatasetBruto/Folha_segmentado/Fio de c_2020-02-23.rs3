  <rst>
    <segment id="1">Rolava um dilema na ladeira Porto Geral:</segment>
    <segment id="2">só Aninha não queria ter um diminutivo na sua fantasia.</segment>
    <segment id="3">A turma da Odonto 2007 já tinha</segment>
    <segment id="4">sese ajeitado:</segment>
    <segment id="5">a Má ia de enfermeirinha</segment>
    <segment id="6">;</segment>
    <segment id="7">Fê ia de fadinha</segment>
    <segment id="8">; e a Lu ia de Chapeuzinho Vermelho</segment>
    <segment id="9">, que já era diminutivo no original.</segment>
    <segment id="10">Mas Aninha sentiu um repique no estômago quando</segment>
    <segment id="11">sese viu cercada por aquelas fantasias de dois palmos de paetês.</segment>
    <segment id="12">Ela já tinha o diminutivo no nome o ano inteiro.</segment>
    <segment id="13">Desde que saíra de Rio Claro era Aninha</segment>
    <segment id="14">, porque</segment>
    <segment id="15">porque na sala da faculdade já tinha uma Ana</segment>
    <segment id="16">, com mais de 1</segment>
    <segment id="17">,50 m.</segment>
    <segment id="18">Fazia dez anos que tinha perdido o direito a um nome de tamanho mediano.</segment>
    <segment id="19">Ela, que diria "credo!</segment>
    <segment id="20">" sese alguém a chamasse de feminista</segment>
    <segment id="21">, não queria ser uma versão diminuída de fantasia só</segment>
    <segment id="22">porque</segment>
    <segment id="23">porque era mulher.</segment>
    <segment id="24">Queria uma fantasia inteira.</segment>
    <segment id="25">Aninha andou até os fundos da loja Só Folia &amp;amp</segment>
    <segment id="26">;</segment>
    <segment id="27">Alegria.</segment>
    <segment id="28">Encontrou no canto</segment>
    <segment id="29">, numa pilha em saldão</segment>
    <segment id="30">, umas fantasias abandonadas há muitos carnavais.</segment>
    <segment id="31">Um macacão de palhaço</segment>
    <segment id="32">, clássico e assustador.</segment>
    <segment id="33">Uma máscara de pinguim de um desenho infantil que não pegou no Brasil.</segment>
    <segment id="34">E algo que brilhava sob as outras.</segment>
    <segment id="35">Um pedaço de peruca preta</segment>
    <segment id="36">comocomo a asa da graúna.</segment>
    <segment id="37">Ela pegou a peruca pelo cabelo.</segment>
    <segment id="38">Puxou.</segment>
    <segment id="39">Olhou a fantasia na altura do seu rosto e riu.</segment>
    <segment id="40">Fio de Cabelo - Bruna BarrosAs amigas já estava pegando as sacolas no guichê de pacote.</segment>
    <segment id="41">Aninha pagou ("Só aceita dinheiro</segment>
    <segment id="42">, moça") e saiu da 25 de Março para o consultório com um segredo dentro de uma sacola de plástico branca.</segment>
    <segment id="43">No dia do bloco do Alok</segment>
    <segment id="44">, a ideia era</segment>
    <segment id="45">sese encontrar para um esquenta no apartamento da Má --"Moema até o Ibira é um pulinho".</segment>
    <segment id="46">A fadinha</segment>
    <segment id="47">, a enfermeirinha e a Chapeuzinho Vermelho que veste a mesma capa desde os 11 anos de idade ficaram impacientes.</segment>
    <segment id="48">"Amiga</segment>
    <segment id="49">,</segment>
    <segment id="50">já são 10h30!</segment>
    <segment id="51">O bloquinho começava às 10h"</segment>
    <segment id="52">, mandaram no grupo de zap</segment>
    <segment id="53">, para a única que não chegara.</segment>
    <segment id="54">"Vão indo</segment>
    <segment id="55">, encontro vocês lá.</segment>
    <segment id="56">"  E quando elas chegaram</segment>
    <segment id="57">, Aninha já estava esperando.</segment>
    <segment id="58">Não que elas tenham reconhecido.</segment>
    <segment id="59">Ela era outra.</segment>
    <segment id="60">O cabelo loiro tinha sido coberto por fios sintéticos pretos</segment>
    <segment id="61">, grossos e lisos</segment>
    <segment id="62">comocomo arame.</segment>
    <segment id="63">O decote da Aninha tinha sido aniquilado por uma camisa de flanela xadrez.</segment>
    <segment id="64">Ela estava de salto?</segment>
    <segment id="65">Não dava pra ver com essa calça jeans.</segment>
    <segment id="66">Aninha ia pular Carnaval fantasiada de Xororó.</segment>
    <segment id="67">Ou era de Chitãozinho?</segment>
    <segment id="68">Aquele menorzinho</segment>
    <segment id="69">, que canta fino e que não é pai da Sandy.</segment>
    <segment id="70">Ou é?</segment>
    <segment id="71">Aquele que tem o cabelo compridinho atrás.</segment>
    <segment id="72">"</segment>
    <segment id="73">É mullets que chama"</segment>
    <segment id="74">, explicou a Aninha às amigas atônitas</segment>
    <segment id="75">, gritando contra a batida eletrônica.</segment>
    <segment id="76">Má quis protestar.</segment>
    <segment id="77">Lu quis abrir os cinco primeiros botões da camisa.</segment>
    <segment id="78">Fê queria mandar a amiga</segment>
    <segment id="79">embora</segment>
    <segment id="80">embora.</segment>
    <segment id="81">Mas não tinha jeito</segment>
    <segment id="82">, o Carnaval havia chegado.</segment>
    <segment id="83">Era a fantasia que tinha para hoje.</segment>
    <segment id="84">Um índio loiro e politicamente incorreto</segment>
    <segment id="85">sese aproximou do grupo</segment>
    <segment id="86">, com o arco na mão.</segment>
    <segment id="87">Crivou a camisa de flanela de Aninha com a flecha do seu olhar.</segment>
    <segment id="88">"</segment>
    <segment id="89">É gringa a sua amiga</segment>
    <segment id="90">, acha que tá no Halloween?</segment>
    <segment id="91">", ele quis saber da Má</segment>
    <segment id="92">, a enfermeirinha.</segment>
    <segment id="93">Antes que houvesse uma resposta</segment>
    <segment id="94">, houve um beijo que impediu a resposta.</segment>
    <segment id="95">E, como</segment>
    <segment id="96">como um batalhão na pior das guerras</segment>
    <segment id="97">, a turma do diminutivo foi perdendo integrantes.</segment>
    <segment id="98">O exército inimigo era feroz:</segment>
    <segment id="99">Fê caiu nas garras de um dos irmãos Petralha</segment>
    <segment id="100">, e Lu abateu um surfista que poderia estar sem fantasia não fosse pelos dois traços de protetor solar do lado do nariz.</segment>
    <segment id="101">Aninha</segment>
    <segment id="102">sese viu sozinha.</segment>
    <segment id="103">Sozinha</segment>
    <segment id="104">, segurando a cerveja com uma mão e tapando o bocal da lata com a outra</segment>
    <segment id="105">, para proteger de espuma e de coisas piores.</segment>
    <segment id="106">E Aninha</segment>
    <segment id="107">sese viu livre.</segment>
    <segment id="108">Ela sentia o petróleo transformado em cabelo ferver na cuca.</segment>
    <segment id="109">Mas ela não sentia o peso dos olhares que a acompanharam a vida toda.</segment>
    <segment id="110">O olhar nunca encomendado dos homens.</segment>
    <segment id="111">Leia toda a série Amores de CarnavalAmor de bróder</segment>
    <segment id="112">O Zé nunca achou que fosse achar amor no Carnaval.</segment>
    <segment id="113">Mas naquele momento ele amouFio de cabelo (sintético)</segment>
    <segment id="114">Enquanto os dois</segment>
    <segment id="115">sese aproximaram</segment>
    <segment id="116">, teve alguém que jura ter ouvido:</segment>
    <segment id="117">&amp;#</segment>
    <segment id="118">039;Eu tenho medo de te dar meu coração&amp;#039</segment>
    <segment id="119">;O menor Carnaval da Terra Dos 38 Carnavais que passou neste mundo</segment>
    <segment id="120">, a dra.</segment>
    <segment id="121">Ana Luísa Sá Makhlouf pulou umTodo Carnaval tem seu final felizLourdes estava com a mangueira na mão</segment>
    <segment id="122">, apontada para a maçaroca de genteAté que</segment>
    <segment id="123">, no meio de fantasias masculinas</segment>
    <segment id="124">, de tamanho real</segment>
    <segment id="125">masmas de imaginação diminuta</segment>
    <segment id="126">, Aninha viu algo reluzir ao sol.</segment>
    <segment id="127">No meio do bloco</segment>
    <segment id="128">, ela viu um mullet.</segment>
    <segment id="129">Um rabicho de cabelo sintético na cor asa da graúna.</segment>
    <segment id="130">E Aninha parou</segment>
    <segment id="131">, enquanto a música continuou.</segment>
    <segment id="132">Numa cena que passaria em câmera lenta no cinema</segment>
    <segment id="133">, masmas aconteceu em velocidade natural para Aninha</segment>
    <segment id="134">, o dono da peruca</segment>
    <segment id="135">sese virou na sua direção.</segment>
    <segment id="136">Era um Chitãozinho.</segment>
    <segment id="137">Ou outro Xororó?</segment>
    <segment id="138">Que difícil saber quem é quem.</segment>
    <segment id="139">Enfim, era a mesma fantasia que a dela.</segment>
    <segment id="140">Sob os mullets estava um homem</segment>
    <segment id="141">, franzino</segment>
    <segment id="142">, com a cara de passarinho.</segment>
    <segment id="143">Como a dela.</segment>
    <segment id="144">Os dois</segment>
    <segment id="145">sese aproximaram.</segment>
    <segment id="146">O trio do Alok tocava uma música eletrônica com letra em inglês que as pessoas repetiam sem entender.</segment>
    <segment id="147">Enquanto os dois</segment>
    <segment id="148">sese aproximaram</segment>
    <segment id="149">, teve alguém que jura ter ouvido:</segment>
    <segment id="150">"</segment>
    <segment id="151">Eu tenho medo de te dar meu coração".</segment>
  </rst>
</analysis>