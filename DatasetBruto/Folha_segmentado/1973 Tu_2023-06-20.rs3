  <rst>
    <segment id="1">Após um exílio de quase 18 anos</segment>
    <segment id="2">, o ex-presidente da Argentina Juan Domingo</segment>
    <segment id="3">Perón retornou ao seu país nesta quarta-feira (20)</segment>
    <segment id="4">, masmas a sua festa foi frustrada devido a um tumulto.</segment>
    <segment id="5">Uma imensa massa popular tinha</segment>
    <segment id="6">sese reunido ao longo da rodovia de acesso ao aeroporto de Ezeiza para recebê-lo.</segment>
    <segment id="7">Enquanto o seu avião</segment>
    <segment id="8">, que vinha de Madri</segment>
    <segment id="9">, voava sobre a Argentina</segment>
    <segment id="10">, Perón foi informado sobre uma grande confusão na multidão que o esperava.</segment>
    <segment id="11">Houve tiroteio</segment>
    <segment id="12">, com feridos e mortos (não há a confirmação dos números)</segment>
    <segment id="13">, em uma situação fora de controle.</segment>
    <segment id="14">Com isso</segment>
    <segment id="15">, o avião mudou a rota e aterrissou na base militar de Morón</segment>
    <segment id="16">, a cerca de 20 quilômetros de Ezeiza.</segment>
    <segment id="17">Primeira Página da Folha de 21 de junho de 1973 - Reprodução</segment>
  </rst>
