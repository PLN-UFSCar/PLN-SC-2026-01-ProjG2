  <rst>
    <segment id="1">A ministra da Cultura</segment>
    <segment id="2">, Margareth Menezes</segment>
    <segment id="3">, promoveu nesta quinta-feira (25) uma reunião entre os presidentes do Sesc-SP</segment>
    <segment id="4">, Danilo Miranda</segment>
    <segment id="5">, e da Embratur</segment>
    <segment id="6">, Marcelo Freixo.</segment>
    <segment id="7">Ambos têm travado uma disputa por verbas após a Câmara ter aprovado que 5% dos recursos do chamado "</segment>
    <segment id="8">Sistema</segment>
    <segment id="9">S</segment>
    <segment id="10">"</segment>
    <segment id="11">devem ser destinados à empresa promotora de turismo.</segment>
    <segment id="12">A ministra da Cultura</segment>
    <segment id="13">, Margareth Menezes</segment>
    <segment id="14">, entre o diretor do Sesc-SP</segment>
    <segment id="15">, Danilo Miranda (à esq.) e o presidente da Embratur</segment>
    <segment id="16">, Marcelo Freixo - Divulgação</segment>
    <segment id="17">Como mostrou o Painel</segment>
    <segment id="18">, Freixo chegou a dizer que entidades</segment>
    <segment id="19">comocomo o Sesc (Serviço Social do Comércio) têm uma caixa preta sobre a qual não querem debater.</segment>
    <segment id="20">Na reunião</segment>
    <segment id="21">, as entidades concordaram em articular ações unindo cultura e turismo.</segment>
    <segment id="22">Um protocolo de intenções será elaborado</segment>
    <segment id="23">, com a previsão de promover manifestações culturais para trazer mais turistas estrangeiros ao Brasil.</segment>
  </rst>
