  <rst>
    <segment id="1">1970.</segment>
    <segment id="2">México.</segment>
    <segment id="3">Uma Copa.</segment>
    <segment id="4">Cinco craques.</segment>
    <segment id="5">Uma história.</segment>
    <segment id="6">Cinco versões.</segment>
    <segment id="7">Carlos Alberto.</segment>
    <segment id="8">Gerson.</segment>
    <segment id="9">Clodoaldo.</segment>
    <segment id="10">Tostão.</segment>
    <segment id="11">Piazza.</segment>
    <segment id="12">Cinco campeões mundiais</segment>
    <segment id="13">, todos grandes ídolos do futebol nacional</segment>
    <segment id="14">, contam essa conquista memorável</segment>
    <segment id="15">, quando o Brasil amealhou definitivamente a emblemática Taça Jules Rimet.</segment>
    <segment id="16">Relatos de um mesmo espaço de tempo</segment>
    <segment id="17">, visões individualizadas do antes</segment>
    <segment id="18">, do durante e do depois da Copa do Mundo.</segment>
    <segment id="19">O fiasco em 1966.</segment>
    <segment id="20">A chegada de João Saldanha.</segment>
    <segment id="21">A saída de João Saldanha.</segment>
    <segment id="22">A chegada de Zagallo.</segment>
    <segment id="23">As incertezas e as certezas de Zagallo.</segment>
    <segment id="24">A preparação</segment>
    <segment id="25">, rígida</segment>
    <segment id="26">, longa e inovadora</segment>
    <segment id="27">, para fazer frente ao então dominante futebol força da Europa.</segment>
    <segment id="28">A análise de cada adversário &amp;mdash</segment>
    <segment id="29">;quatro europeus</segment>
    <segment id="30">, dois sul-americanos&amp;mdash</segment>
    <segment id="31">;, suas potencialidades e suas fragilidades.</segment>
    <segment id="32">Os jogos</segment>
    <segment id="33">, um por um.</segment>
    <segment id="34">As apreensões</segment>
    <segment id="35">, as artimanhas</segment>
    <segment id="36">, as alternâncias.</segment>
    <segment id="37">As emoções</segment>
    <segment id="38">, os detalhes.</segment>
    <segment id="39">Os gols.</segment>
    <segment id="40">Os bastidores da concentração e das partidas.</segment>
    <segment id="41">O título e a glória.</segment>
    <segment id="42">A comemoração</segment>
    <segment id="43">, a torcida e as festas.</segment>
    <segment id="44">O regresso e a continuidade (ou descontinuidade) na seleção.</segment>
    <segment id="45">Memórias que não</segment>
    <segment id="46">sese apagam</segment>
    <segment id="47">, de um dos melhores escretes de todos os tempos</segment>
    <segment id="48">, e que devem ser orgulhosamente revividas e celebradas.</segment>
  </rst>
</analysis>