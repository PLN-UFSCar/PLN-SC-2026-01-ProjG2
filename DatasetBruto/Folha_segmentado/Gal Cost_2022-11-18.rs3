  <rst>
    <segment id="1">A cantora Gal Costa será homenageada com um tributo na Sala São Paulo</segment>
    <segment id="2">, na capital paulista</segment>
    <segment id="3">, no dia 17 de dezembro.</segment>
    <segment id="4">Na mesma a data</segment>
    <segment id="5">, o espaço receberia uma apresentação da artista junto com o cantor Silva —todos os ingressos</segment>
    <segment id="6">sese esgotaram.</segment>
    <segment id="7">Gal morreu no dia 9 deste mês</segment>
    <segment id="8">, aos 77 anos.</segment>
    <segment id="9">Gal Costa em show no FIG</segment>
    <segment id="10">, o Festival de Inverno de Garanhuns</segment>
    <segment id="11">, em Pernambuco</segment>
    <segment id="12">, em julho - Felipe Souto Maior/Fundarpe/Divulgação  CANTA</segment>
    <segment id="13">BRASIL</segment>
    <segment id="14">O tributo integrará o projeto Encontros Históricos na Sala São Paulo</segment>
    <segment id="15">, promovido pela Fundação Osesp</segment>
    <segment id="16">, e reunirá os cantores Tim Bernardes</segment>
    <segment id="17">, Rubel</segment>
    <segment id="18">, Dora Morelenbaum e Lívia Nestrovski</segment>
    <segment id="19">, além da orquestra Brasil Jazz Sinfônica.</segment>
    <segment id="20">CANTA 2</segment>
    <segment id="21">Os ingressos comprados para o concerto original continuam válidos</segment>
    <segment id="22">, e novos ingressos serão disponibilizados em</segment>
    <segment id="23">casocaso de desistências.</segment>
    <segment id="24">Veja fotos de Gal Gosta</segment>
    <segment id="25">, morta aos 77 anosMais    novamente         de   de  de  representando um   INCLUSÃO</segment>
    <segment id="26">Lançamento do livro Mais    novamente         de   de  de  representando um</segment>
    <segment id="27">O jornalista Jairo Marques</segment>
    <segment id="28">, editor e colunista da Folha</segment>
    <segment id="29">, recebeu convidados no lançamento do seu livro "Crônicas para um Mundo Mais Diverso".</segment>
    <segment id="30">A secretária municipal da Pessoa com Deficiência de São Paulo</segment>
    <segment id="31">, Silvia Grecco</segment>
    <segment id="32">, prestigiou o evento</segment>
    <segment id="33">, que ocorreu na noite de quinta (17)</segment>
    <segment id="34">, na Drummond Livraria</segment>
    <segment id="35">, em São Paulo.</segment>
    <segment id="36">O vice-presidente da Câmara Brasileira do Livro Luciano Monteiro também passou por lá.  com BIANKA VIEIRA</segment>
    <segment id="37">, KARINA MATIAS e MANOELLA SMITH</segment>
  </rst>
