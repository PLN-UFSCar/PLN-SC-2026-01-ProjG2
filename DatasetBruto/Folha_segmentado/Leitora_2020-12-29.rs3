  <rst>
    <segment id="1">A merendeira Maria de Lourdes Rodrigues</segment>
    <segment id="2">, 62 anos</segment>
    <segment id="3">, do Jardim Iva (zona leste)</segment>
    <segment id="4">, conta que</segment>
    <segment id="5">, desde o mês passado</segment>
    <segment id="6">, não consegue pegar fralda geriátrica para a sua mãe na UBS (Unidade Básica da Saúde)</segment>
    <segment id="7">Jardim Grimaldi</segment>
    <segment id="8">, localizada na mesma região onde mora.</segment>
    <segment id="9">“</segment>
    <segment id="10">A falta começou no posto de saúde no dia 23 de novembro.</segment>
    <segment id="11">Esse foi o primeiro dia em que estive lá e não recebi nada”</segment>
    <segment id="12">, queixa-</segment>
    <segment id="13">sese a leitora à reportagem.</segment>
    <segment id="14">Maria de Lourdes afirma que liga para a UBS todos os dias</segment>
    <segment id="15">, masmas não obtém sucesso.</segment>
    <segment id="16">“</segment>
    <segment id="17">Também entro em contato uma vez por semana com a supervisão regional da saúde da Vila Prudente.</segment>
    <segment id="18">Porém ambos informam a mesma coisa: que as fraldas estão em falta e que não há previsão de quando chegarão.</segment>
    <segment id="19">A minha mãe precisa das fraldas.</segment>
    <segment id="20">É um verdadeiro descaso com o idoso.</segment>
    <segment id="21">”</segment>
    <segment id="22">UBS São Vicente de Paula no Ipiranga em São Paulo - Lalo de Almeida/ Folhapress</segment>
    <segment id="23">A merendeira conta que a família está tendo que comprar o insumo nas farmácias particulares.</segment>
    <segment id="24">“</segment>
    <segment id="25">O pacote de fraldas está saindo</segment>
    <segment id="26">, em média</segment>
    <segment id="27">, R$ 27.</segment>
    <segment id="28">Fazemos um esforço</segment>
    <segment id="29">, masmas o fato é que ela tem direito a retirar essas fraldas gratuitamente.</segment>
    <segment id="30">É injusto.</segment>
    <segment id="31">Além do que ela utiliza outros medicamentos”</segment>
    <segment id="32">, afirma.</segment>
    <segment id="33">Maria de Lourdes relata que sua mãe precisa de 13 pacotes de fraldas por mês.</segment>
    <segment id="34">“Ela utiliza uma média de nove unidades por dia</segment>
    <segment id="35">, pois</segment>
    <segment id="36">pois toma medicamento diurético”</segment>
    <segment id="37">, explica a merendeira à reportagem ao Agora.</segment>
    <segment id="38">“</segment>
    <segment id="39">Não sei mais a quem recorrer.</segment>
    <segment id="40">Por isso peço a intervenção do Defesa do Cidadão</segment>
    <segment id="41">para que</segment>
    <segment id="42">para que essa situação seja resolvida de forma definitiva”</segment>
    <segment id="43">, diz a leitora.</segment>
    <segment id="44">Secretaria entrega produto</segment>
    <segment id="45">A Prefeitura de São Paulo</segment>
    <segment id="46">, por meio da Secretaria Municipal da Saúde</segment>
    <segment id="47">, informa que já tomou as medidas necessárias para a compra emergencial de fraldas.</segment>
    <segment id="48">Isso foi necessário</segment>
    <segment id="49">, pois</segment>
    <segment id="50">pois o processo licitatório regular para a aquisição do insumo na capital paulista foi suspenso pelo Tribunal de Contas do Município.</segment>
    <segment id="51">A pasta diz ainda que fez os esclarecimentos necessários para retomar o processo.</segment>
    <segment id="52">A Coordenadoria Regional de Saúde Sudeste afirma ter disponibilizado 117 unidades de fraldas para a munícipe.</segment>
  </rst>
</analysis>