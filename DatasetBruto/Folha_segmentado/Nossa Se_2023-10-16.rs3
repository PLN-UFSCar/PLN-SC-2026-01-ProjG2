  <rst>
    <segment id="1">A representação de Maria</segment>
    <segment id="2">, mãe de Jesus</segment>
    <segment id="3">, mantém sua posição</segment>
    <segment id="4">comocomo uma das imagens mais icônicas em um país que continua sendo o lar da maior população católica do mundo.</segment>
    <segment id="5">A recente inauguração de uma gigantesca escultura de Nossa Senhora Aparecida na cidade homônima</segment>
    <segment id="6">, exemplifica essa devoção</segment>
    <segment id="7">, são 50 metros de altura</segment>
    <segment id="8">, superando em 12 metros a altura do Cristo Redentor.</segment>
    <segment id="9">Um pastor evangélico residente no interior de São Paulo</segment>
    <segment id="10">, no entanto</segment>
    <segment id="11">, incomodado com uma estátua instalada pela prefeitura na entrada da cidade</segment>
    <segment id="12">, descreveu a santa</segment>
    <segment id="13">comocomo "</segment>
    <segment id="14">Satanás fantasiado de azul".</segment>
    <segment id="15">Para conversar sobre os ataques à santa e sua unanimidade no país</segment>
    <segment id="16">, Isabella Faria recebeu a repórter especial Anna Virginia Balloussier no Como é que é?</segment>
    <segment id="17">desta segunda-feira (16).</segment>
    <segment id="18">Especiais da TV FolhaCanal no Youtube publica análises</segment>
    <segment id="19">, entrevistas e documentáriosEntenda</segment>
    <segment id="20">comocomo está a Guerra da Ucrânia um ano depois da invasão russa |</segment>
    <segment id="21">FOLHA EXPLICA&amp;#039</segment>
    <segment id="22">;Esquecem que país foi construído por imigrantes&amp;#039</segment>
    <segment id="23">;, diz ativista sobre crise nos EUA | 1ª PESSOARenato</segment>
    <segment id="24">Terra: &amp;#039</segment>
    <segment id="25">;Vamos tentar achar graça dessa desgraça que foi 2022&amp;#039</segment>
    <segment id="26">; | OPINIÃODesconectados: os impactos da pandemia na educação brasileira | DOCUMENTÁRIOJustiça persegue líderes</segment>
    <segment id="27">comocomo Lula e eu</segment>
    <segment id="28">, diz Cristina Kirchner |</segment>
    <segment id="29">ENTREVISTATransmitido ao vivo direto da Redação da Folha</segment>
    <segment id="30">, no centro de São Paulo</segment>
    <segment id="31">, o programa da TV Folha vai ao ar de segunda a sexta-feira</segment>
    <segment id="32">, pelos canais do jornal no YouTube</segment>
    <segment id="33">, no Instagram</segment>
    <segment id="34">, no Facebook e na Twitch.</segment>
    <segment id="35">Depois da transmissão</segment>
    <segment id="36">, a íntegra das conversas segue disponível no canal da TV Folha no YouTube e também em versão áudio nos principais agregadores de podcasts.</segment>
    <segment id="37">Além do novo programa diário</segment>
    <segment id="38">, a TV Folha publica no YouTube entrevistas</segment>
    <segment id="39">, reportagens e minidocs sobre diferentes temas do noticiário.</segment>
  </rst>
