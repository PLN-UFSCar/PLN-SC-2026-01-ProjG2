  <rst>
    <segment id="1">Zorro, um dos heróis mascarados mais famosos de todos os tempos</segment>
    <segment id="2">, atuou na região da Califórnia do começo do século 19</segment>
    <segment id="3">, que então pertencia ao México.</segment>
    <segment id="4">Não deixa de ser surpreendente que só agora tenhamos uma série mexicana dedicada ao personagem.</segment>
    <segment id="5">Cena da série &amp;#039</segment>
    <segment id="6">;Zorro&amp;#039</segment>
    <segment id="7">;, do Prime Video - Divulgação</segment>
    <segment id="8">Ao longo de dez episódios</segment>
    <segment id="9">, o aristocrata Diego de la Vega assume a identidade do justiceiro</segment>
    <segment id="10">, para prender os assassinos de seu pai.</segment>
    <segment id="11">Com Miguel Bernardeau e Cecilia Suárez.</segment>
