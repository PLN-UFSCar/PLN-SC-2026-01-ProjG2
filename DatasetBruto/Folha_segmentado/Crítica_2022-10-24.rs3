  <rst>
    <segment id="1">A Casa do DragãoOnde Disponível na HBO MaxClassificação 16</segment>
    <segment id="2">anosElenco</segment>
    <segment id="3">Matt Smith</segment>
    <segment id="4">, Olivia Cooke e Emma D&amp;#039</segment>
    <segment id="5">;ArcyProdução EUA</segment>
    <segment id="6">, 2022Criação</segment>
    <segment id="7">George R.R. Martin e Ryan J. CondalNo fim</segment>
    <segment id="8">, havia os dragões.</segment>
    <segment id="9">Sim, parece óbvio em uma série chamada "</segment>
    <segment id="10">A Casa do Dragão"</segment>
    <segment id="11">, masmas há de</segment>
    <segment id="12">sese levar em conta que esta primeira temporada dedicou a esmagadora parte das cenas a intrigas palacianas</segment>
    <segment id="13">, traições</segment>
    <segment id="14">, alianças —enfim</segment>
    <segment id="15">, à política— enquanto os bichões ficavam em segundo plano</segment>
    <segment id="16">comocomo arma de dissuasão</segment>
    <segment id="17">, um botão vermelho.</segment>
    <segment id="18">Assim teria prosseguido</segment>
    <segment id="19">sese não houvesse uma modificação crucial sobre o livro original —"</segment>
    <segment id="20">Fogo e Sangue"</segment>
    <segment id="21">, de George R.R. Martin—</segment>
    <segment id="22">, promovendo os répteis de objeto de cena a agentes da história.</segment>
    <segment id="23">E daqui por diante este texto trará spoilers da temporada.</segment>
    <segment id="24">A Casa do Dragão</segment>
    <segment id="25">, derivado de &amp;#039</segment>
    <segment id="26">;Game of Thrones&amp;#039</segment>
    <segment id="27">; - HBO Max/DivulgaçãoAs mortes do garoto Lucerys —Eliot Grihault— e de seu dragão</segment>
    <segment id="28">Arrax servem de estopim à guerra fratricida dos Targaryen pelo trono de ferro.</segment>
    <segment id="29">Tanto no livro de Martin quanto na série criada por Ryan J. Condal eles são despedaçados pelo réptil muito maior de Aemond —Ewan Mitchell.</segment>
    <segment id="30">Mas, se</segment>
    <segment id="31">se no original essa era mesmo a intenção do tio vingativo</segment>
    <segment id="32">, nas telas a morte ocorre por vontade de seu dragão</segment>
    <segment id="33">, irritado com a petulância do bicho menor que lhe chamusca o pescoço.</segment>
    <segment id="34">É um homicídio culposo cujas consequências são percebidas por Aemond —aliás</segment>
    <segment id="35">, Mitchell</segment>
    <segment id="36">, desde que surgiu no sétimo episódio</segment>
    <segment id="37">, é um ladrão de cena.</segment>
    <segment id="38">Com isso</segment>
    <segment id="39">, "</segment>
    <segment id="40">A Casa do Dragão" retoma um dos elementos centrais em "Game of Thrones"</segment>
    <segment id="41">, o megasucesso encerrado em 2019 para o qual serve de prólogo: o imponderável.</segment>
    <segment id="42">Na antecessora</segment>
    <segment id="43">, toda tramoia política estava à sombra de uma ameaça natural ou sobrenatural</segment>
    <segment id="44">, algo que havia</segment>
    <segment id="45">sese perdido em "</segment>
    <segment id="46">A Casa do Dragão"</segment>
    <segment id="47">, restrita à tragédia de uma família real específica e com um verniz de lógica e paralelos atuais mais espesso.</segment>
    <segment id="48">Veja cenas da série &amp;#039</segment>
    <segment id="49">;A Casa do Dragão&amp;#039</segment>
    <segment id="50">;Mais    novamente         de   de  de  representando um</segment>
    <segment id="51">A guerra que ganhará corpo na segunda temporada</segment>
    <segment id="52">, porém</segment>
    <segment id="53">porém, deve ter suas reviravoltas determinadas pelos sentimentos mundanos</segment>
    <segment id="54">, como</segment>
    <segment id="55">como deixam claro as cenas de luto de Rhaenyra —Emma D'Arcy— após perder um bebê e ao receber a notícia de que o favorito</segment>
    <segment id="56">, Luc, morreu.</segment>
    <segment id="57">Esse torvelinho —e no meio dele há uma sequência na qual o marido</segment>
    <segment id="58">, Daemon</segment>
    <segment id="59">, vivido por Matt Smith</segment>
    <segment id="60">, sese distancia dela a ponto de</segment>
    <segment id="61">sese tornar agressivo— deve passar a mover a personagem muito mais do que a coroa que ela busca garantir</segment>
    <segment id="62">comocomo herdeira legítima após a morte do pai</segment>
    <segment id="63">, Viserys —</segment>
    <segment id="64">Paddy Considine</segment>
    <segment id="65">, que fará falta.</segment>
    <segment id="66">Com isso</segment>
    <segment id="67">, a personagem de D'Arcy</segment>
    <segment id="68">, apresentada</segment>
    <segment id="69">comocomo a parte "emoção" em contraponto ao calculismo de sua madrasta</segment>
    <segment id="70">, Alicent —Olivia Cooke—</segment>
    <segment id="71">, ganha camadas</segment>
    <segment id="72">, tornando o conflito menos maniqueísta</segment>
    <segment id="73">, ainda que por ora pareça inevitável torcer por ela.</segment>
    <segment id="74">Em suas cores soturnas e sua preferência pela realpolitik</segment>
    <segment id="75">, "</segment>
    <segment id="76">A Casa do Dragão" pode parecer menos atraente do que o multiverso de "Game of Thrones"</segment>
    <segment id="77">, com suas muitas subtramas</segment>
    <segment id="78">, linhagens familiares extensas e conflitos em diversas escalas.</segment>
    <segment id="79">Relembre o que acontece em cada temporada de &amp;#</segment>
    <segment id="80">039;Game of Thrones&amp;#039</segment>
    <segment id="81">;Mais</segment>
    <segment id="82">novamente         de   de  de  representando um  Ela fala mais alto</segment>
    <segment id="83">, porém</segment>
    <segment id="84">porém, àqueles que apreciam as tramas políticas e a ironia com a realpolitik.</segment>
    <segment id="85">É como</segment>
    <segment id="86">como se</segment>
    <segment id="87">se a primeira partisse do Tolkien e chegasse a Shakespeare</segment>
    <segment id="88">, e esta já partisse de Shakespeare e chegasse aos romances históricos de Hillary Mantell ou mesmo a dramas contemporâneos sobre o poder</segment>
    <segment id="89">, como</segment>
    <segment id="90">como "House of Cards" e "Borgen".</segment>
    <segment id="91">É notável ainda o efeito do terremoto cultural dos dez anos que separam as duas estreias.</segment>
    <segment id="92">O uso frequente de estupros</segment>
    <segment id="93">comocomo artifício dramático</segment>
    <segment id="94">, o elenco quase integralmente branco</segment>
    <segment id="95">, a violência profusa e repetitiva</segment>
    <segment id="96">comocomo linguagem —nada disso parece mais aceitável aos olhos do público e dos produtores.</segment>
    <segment id="97">Aos poucos</segment>
    <segment id="98">, a "prequência" assume identidade própria</segment>
    <segment id="99">, e isso parece ter agradado a Martin</segment>
    <segment id="100">, que mais de uma vez elogiou os rumos adotados pelos roteiristas</segment>
    <segment id="101">, divergentes do livro em algumas ocasiões.</segment>
    <segment id="102">O que a série ainda parece dever é uma dimensão maior para Alicent</segment>
    <segment id="103">, que acabou engolida pelos demais —a começar do pai</segment>
    <segment id="104">, Otto Hightower</segment>
    <segment id="105">, um soberbo Rhys Ifans.</segment>
    <segment id="106">A produção da HBO tem recebido</segment>
    <segment id="107">, sobretudo nos episódios recentes</segment>
    <segment id="108">, mais elogios do que críticas do público e da imprensa.</segment>
    <segment id="109">Há arestas a ajeitar</segment>
    <segment id="110">, masmas o feito desta primeira temporada não é trivial.</segment>
  </rst>
</analysis>