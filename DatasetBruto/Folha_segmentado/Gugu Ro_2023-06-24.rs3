  <rst>
    <segment id="1">Rose Miriam</segment>
    <segment id="2">, que luta para ser reconhecida</segment>
    <segment id="3">comocomo viúva do apresentador Gugu</segment>
    <segment id="4">, sese envolveu em uma discussão na internet.</segment>
    <segment id="5">Em uma postagem no Instagram</segment>
    <segment id="6">, ela defendeu o filho João Augusto</segment>
    <segment id="7">, 20, que foi criticado por uma seguidora que o chamou de "egoísta" por não</segment>
    <segment id="8">sese posicionar a favor da mãe na disputa pela herança.</segment>
    <segment id="9">As mensagens foram postadas</segment>
    <segment id="10">comocomo comentários a uma foto que Rose publicou ao lado das filhas Marina e Sofia</segment>
    <segment id="11">, 19, e dos advogados Nelson Willians e Jacob Daniel Broder.</segment>
    <segment id="12">"</segment>
    <segment id="13">Eu já ouvi muito isso</segment>
    <segment id="14">, masmas meu coração de mãe sente que o João está preso em uma grande teia de aranha e que mesmo que quisesse</segment>
    <segment id="15">, não conseguiria sair por si só"</segment>
    <segment id="16">, respondeu Rose.</segment>
    <segment id="17">"</segment>
    <segment id="18">Ele sempre foi uma pessoa incrível</segment>
    <segment id="19">, é e sempre será!</segment>
    <segment id="20">Ele sequer pode imaginar o imenso e infinito amor que sinto por ele.</segment>
    <segment id="21">Dou a vida pelos meus três filhos.</segment>
    <segment id="22">Parece mentira</segment>
    <segment id="23">, masmas ele voltou a morar em casa</segment>
    <segment id="24">, e todos os dias eu digo:</segment>
    <segment id="25">'Eu te amo</segment>
    <segment id="26">, filho!'.</segment>
    <segment id="27">E ele sempre responde:</segment>
    <segment id="28">'Eu também te amo'.</segment>
    <segment id="29">Então, isso me dá a maior alegria do mundo.</segment>
    <segment id="30">Sei que um dia ele vai acordar para a realidade.</segment>
    <segment id="31">Deus é o justo juiz.</segment>
    <segment id="32">Obrigada.</segment>
    <segment id="33">Abraço"</segment>
    <segment id="34">, finalizou.</segment>
    <segment id="35">Rose Miriam - @rosemiriamoficial no InstagramNesta semana</segment>
    <segment id="36">, o nome de Rose esteve envolvido em mais uma polêmica.</segment>
    <segment id="37">Uma carta que Rose escreveu à mão e enviou a Gugu anos atrás foi juntada ao processo por conta de seu conteúdo —Rose diz no texto que sabia que o apresentador</segment>
    <segment id="38">sese encontrava com alguns rapazes.</segment>
    <segment id="39">Estas são Sofia e Marina Liberato</segment>
    <segment id="40">Mais    novamente         de   de  de  representando um  "</segment>
    <segment id="41">Anjo, eu sei que sua preferência sexual é diferente"</segment>
    <segment id="42">, diz a mãe dos filhos do apresentador.</segment>
    <segment id="43">"</segment>
    <segment id="44">Mas esse tipo de conduta sexual sua não vem do teu espírito</segment>
    <segment id="45">, isso não é teu.</segment>
    <segment id="46">Você é um homem maravilhoso.</segment>
    <segment id="47">E eu tenho</segment>
    <segment id="48">comocomo transformar esse problema"</segment>
    <segment id="49">, escreveu ela.</segment>
    <segment id="50">Além disso</segment>
    <segment id="51">, o processo de disputa pela herança de Gugu também trouxe outra revelação nos últimos dias</segment>
    <segment id="52">, como</segment>
    <segment id="53">como a existência de um suposto filho que pede reconhecimento de paternidade "post mortem".</segment>
  </rst>
