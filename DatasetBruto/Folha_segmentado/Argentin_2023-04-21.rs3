  <rst>
    <segment id="1">O presidente da Argentina</segment>
    <segment id="2">, Alberto Fernández</segment>
    <segment id="3">, anunciou de surpresa na manhã desta sexta (21)</segment>
    <segment id="4">, em um vídeo no Twitter</segment>
    <segment id="5">, que não concorrerá à reeleição.</segment>
    <segment id="6">O país escolherá o próximo líder em outubro.  "</segment>
    <segment id="7">O contexto econômico me obriga a dedicar todos os meus esforços a atender os difíceis momentos que a Argentina atravessa.</segment>
    <segment id="8">Como disse recentemente</segment>
    <segment id="9">, depois da pátria vem o movimento"</segment>
    <segment id="10">, afirmou ele.</segment>
    <segment id="11">O presidente da Argentina</segment>
    <segment id="12">, Alberto Fernández</segment>
    <segment id="13">, durante encontro com o líder dos EUA</segment>
    <segment id="14">, Joe Biden</segment>
    <segment id="15">, na Casa Branca</segment>
    <segment id="16">, em Washington - Jonathan Ernst - 29.mar.23/ReutersSua recondução à Casa Rosada era considerada improvável devido à grave crise econômica e ao crescimento da pobreza que marcam seu governo.</segment>
    <segment id="17">Fernández</segment>
    <segment id="18">, afinal</segment>
    <segment id="19">, é desaprovado por 71% dos argentinos</segment>
    <segment id="20">, a maior rejeição na série histórica de 17 anos da consultora Poliarquía</segment>
    <segment id="21">, que divulgou o número nesta quinta-feira (20).</segment>
    <segment id="22">A desistência</segment>
    <segment id="23">, incomum para um incumbente</segment>
    <segment id="24">, ocorre quase um mês após o antecessor Mauricio Macri (2015-2018) abandonar a disputa</segment>
    <segment id="25">, na aliança de oposição</segment>
    <segment id="26">Juntos por el Cambio.</segment>
    <segment id="27">Ele tentou a reeleição em 2019</segment>
    <segment id="28">, masmas perdeu para Fernández.</segment>
    <segment id="29">A poucos meses do pleito</segment>
    <segment id="30">, a corrida é considerada muito incerta.</segment>
    <segment id="31">Lá foraReceba no seu email uma seleção semanal com o que de mais importante aconteceu no mundo</segment>
    <segment id="32">; aberta para não assinantes.</segment>
    <segment id="33">Carregando...</segment>
    <segment id="34">No vídeo de quase 8 minutos em que fez o anúncio</segment>
    <segment id="35">, editado com imagens históricas e música emotiva</segment>
    <segment id="36">, Fernández evocou a figura do ex-presidente Néstor Kirchner</segment>
    <segment id="37">, de quem foi ministro há 20 anos</segment>
    <segment id="38">, e afirmou que chegou à Presidência dando fim a um ciclo de "inquietação para o povo argentino"</segment>
    <segment id="39">, em uma alfinetada a Macri.</segment>
    <segment id="40">Ele argumenta ter recebido um país endividado</segment>
    <segment id="41">, em recessão</segment>
    <segment id="42">, com alta pobreza e inflação</segment>
    <segment id="43">, além de ter passado pela pandemia e pela Guerra da Ucrânia.</segment>
    <segment id="44">Mesmo assim</segment>
    <segment id="45">, segue</segment>
    <segment id="46">, construiu casas e fez obras públicas</segment>
    <segment id="47">"comocomo nunca</segment>
    <segment id="48">", ampliou os direitos das mulheres e "construiu pontes" na América Latina.</segment>
    <segment id="49">Fernández culpou a forte seca —que afeta as commodities</segment>
    <segment id="50">, uma das principais fontes de renda do país— pela crise</segment>
    <segment id="51">, além dos "especuladores de sempre</segment>
    <segment id="52">, que geram inquietudes</segment>
    <segment id="53">, jogando com o dólar ilegal".</segment>
    <segment id="54">Terminou pedindo unidade para enfrentar as eleições gerais e convocando a militância peronista a participar das primárias</segment>
    <segment id="55">, em agosto.</segment>
    <segment id="56">"</segment>
    <segment id="57">É preciso gerar um novo ciclo"</segment>
    <segment id="58">, disse.  "Fernández</segment>
    <segment id="59">dá sinais ao resto do seu arco político e a atores internacionais</segment>
    <segment id="60">, como</segment>
    <segment id="61">como Washington e FMI [Fundo Monetário Internacional]</segment>
    <segment id="62">, hoje muito relevantes para a Argentina devido ao elevado endividamento externo"</segment>
    <segment id="63">, afirma Geraldina Dana</segment>
    <segment id="64">, cientista política da Universidade de Buenos Aires (UBA).</segment>
    <segment id="65">Sem dólares</segment>
    <segment id="66">, Argentina empobrece e vive ameaça de hiperinflação em ano eleitoralMais    novamente         de   de  de  representando um</segment>
    <segment id="67">Entre os nomes considerados presidenciáveis dentro da aliança de esquerda está o da atual vice</segment>
    <segment id="68">, Cristina Kirchner</segment>
    <segment id="69">, com quem Fernández tem choques frequentes —apesar de a oposição explorar sua imagem de "marionete" da ex-presidente.</segment>
    <segment id="70">Cristina tem feito mistério sobre sua candidatura</segment>
    <segment id="71">, usando a narrativa de que estaria inelegível após ter sido condenada por corrupção em dezembro.</segment>
    <segment id="72">Isso, porém</segment>
    <segment id="73">porém, só ocorrerá</segment>
    <segment id="74">casocaso a decisão da Justiça argentina em primeira instância seja confirmada pelas esferas superiores.</segment>
    <segment id="75">Ela afirma ser vítima de "lawfare"</segment>
    <segment id="76">, termo usado para</segment>
    <segment id="77">sese referir a casos em que o Judiciário persegue um investigado por razões políticas</segment>
    <segment id="78">, e sustenta que a condenação estava escrita desde o início do processo.</segment>
    <segment id="79">Outro possível candidato pela aliança é o ministro da Economia</segment>
    <segment id="80">, Sergio Massa</segment>
    <segment id="81">, masmas ambos estão em queda de popularidade.</segment>
    <segment id="82">Um terceiro nome cotado é o de Daniel Scioli</segment>
    <segment id="83">, hoje embaixador em Brasília.</segment>
    <segment id="84">Leia mais sobre a crise na ArgentinaSem dólares e com pesos que &amp;#039</segment>
    <segment id="85">;queimam&amp;#039</segment>
    <segment id="86">;, hiperinflação ameaça Argentina Pobreza dá salto na Argentina</segment>
    <segment id="87">;</segment>
    <segment id="88">Folha reencontra morador de favela 16 anos depoisArgentina já foi mais rica do que Alemanha</segment>
    <segment id="89">, Itália e FrançaArgentinos poupam dólares embaixo do colchão</segment>
    <segment id="90">, diz ex-ministroPodcast explica os impactos da crise na Argentina em ano de eleiçõesFormado em direito</segment>
    <segment id="91">, Fernández começou a carreira pública</segment>
    <segment id="92">comocomo subdiretor jurídico do Ministério da Economia no governo de Raúl Alfonsín (1983-1989).</segment>
    <segment id="93">Depois</segment>
    <segment id="94">, virou superintendente de seguros na gestão Carlos Menem (1989-1999).</segment>
    <segment id="95">Também foi deputado da capital federal de 2000 a 2003</segment>
    <segment id="96">, quando passou a chefe de gabinete de Néstor Kirchner.</segment>
    <segment id="97">Hoje é presidente do Partido Justicialista</segment>
    <segment id="98">, continuação do Partido Peronista</segment>
    <segment id="99">, desde 2021.</segment>
    <segment id="100">A insatisfação com seu atual governo é puxada pela piora dos índices econômicos e sociais.</segment>
    <segment id="101">Segundo o Indec</segment>
    <segment id="102">, o IBGE argentino</segment>
    <segment id="103">, cerca de 39% da população é formada por pobres</segment>
    <segment id="104">, e 8,1%</segment>
    <segment id="105">, por indigentes</segment>
    <segment id="106">, o que torna mais difícil retirar os enormes subsídios concedidos às famílias</segment>
    <segment id="107">, incluindo em contas de luz e gás.</segment>
    <segment id="108">O país vive mergulhado em instabilidade econômica.</segment>
    <segment id="109">Em 40 anos de democracia</segment>
    <segment id="110">, completados neste ano</segment>
    <segment id="111">, atravessou nove grandes crises</segment>
    <segment id="112">, conservando até hoje o mesmo PIB per capita daquela época.</segment>
    <segment id="113">Ainda que haja esse contexto</segment>
    <segment id="114">, Fernández é visto</segment>
    <segment id="115">comocomo incompetente para resolver a crise</segment>
    <segment id="116">, e o titular da Economia</segment>
    <segment id="117">, Massa</segment>
    <segment id="118">, como</segment>
    <segment id="119">como alguém colocado para "segurar as pontas" até o pleito</segment>
    <segment id="120">, entregando o abacaxi ao próximo governo.</segment>
    <segment id="121">A desistência do presidente de tentar a reeleição ocorre em uma semana particularmente tensa.</segment>
    <segment id="122">Na última sexta-feira (14)</segment>
    <segment id="123">, os argentinos receberam a notícia de um novo recorde da inflação acumulada em março: 104</segment>
    <segment id="124">,3%, o maior valor dos últimos 31 anos.</segment>
    <segment id="125">Depois</segment>
    <segment id="126">, assustaram-</segment>
    <segment id="127">sese com outra disparada no dólar paralelo "blue"</segment>
    <segment id="128">, que deu um salto de 10% em dez dias</segment>
    <segment id="129">, após meses de alta estável.</segment>
    <segment id="130">Assim,</segment>
    <segment id="131">sese uma pessoa fosse a uma "cueva"</segment>
    <segment id="132">, casa de câmbio ilegal</segment>
    <segment id="133">, no último dia 10</segment>
    <segment id="134">, compraria um dólar por 400 pesos.</segment>
    <segment id="135">Na quinta (20)</segment>
    <segment id="136">, ele já custaria 432 pesos.</segment>
    <segment id="137">É essa a cotação que dita o dia a dia do país</segment>
    <segment id="138">, e não a oficial.</segment>
    <segment id="139">"</segment>
    <segment id="140">O que ocorre é uma rejeição ao peso"</segment>
    <segment id="141">, diz Miguel Boggiano</segment>
    <segment id="142">, diretor da consultoria Carta Financiera.</segment>
    <segment id="143">"</segment>
    <segment id="144">O mercado entendeu que as ações do governo não funcionam</segment>
    <segment id="145">, a seca começa a significar algo gravíssimo e tudo isso vai</segment>
    <segment id="146">sese traduzindo na materialização dessa desconfiança que já existia.</segment>
    <segment id="147">"</segment>
    <segment id="148">Parte dos analistas</segment>
    <segment id="149">, porém</segment>
    <segment id="150">porém, relativiza a disparada e diz que ela não é tão alta em termos reais</segment>
    <segment id="151">porque</segment>
    <segment id="152">porque acompanha a inflação.</segment>
    <segment id="153">A economista Carla Arévalo</segment>
    <segment id="154">, do Instituto de Estudos de Trabalho e Desenvolvimento Econômico (Ielde)</segment>
    <segment id="155">, chama a atenção para indicadores positivos na gestão Fernández que são pouco comentados.</segment>
    <segment id="156">"Estamos muito bem em vários setores: atividade produtiva</segment>
    <segment id="157">, consumo</segment>
    <segment id="158">, turismo</segment>
    <segment id="159">, além de desemprego e informalidade muito baixos.</segment>
    <segment id="160">Os salários em geral acompanham a inflação</segment>
    <segment id="161">, porque</segment>
    <segment id="162">porque temos sindicatos fortes e já há uma normalização da situação.</segment>
    <segment id="163">Além disso</segment>
    <segment id="164">, hoje há uma estrutura de proteção social.</segment>
    <segment id="165">Isso minimamente contém o caos social.</segment>
    <segment id="166">"  China</segment>
    <segment id="167">, terra do meioReceba no seu email os grandes temas da China explicados e contextualizados</segment>
    <segment id="168">; exclusiva para assinantes.</segment>
    <segment id="169">Carregando...</segment>
    <segment id="170">Qualquer perspectiva de solução mais profunda da economia</segment>
    <segment id="171">, porém</segment>
    <segment id="172">porém,</segment>
    <segment id="173">sese arrastará até as eleições</segment>
    <segment id="174">, marcadas por mais incertezas.</segment>
    <segment id="175">A aliança de oposição</segment>
    <segment id="176">Juntos por el Cambio</segment>
    <segment id="177">, que concorre contra os peronistas</segment>
    <segment id="178">, também vive uma crise.</segment>
    <segment id="179">Após a desistência de Macri</segment>
    <segment id="180">, disputam o status de presidenciável Patricia Bullrich</segment>
    <segment id="181">, ex-presidente do Partido Progressista</segment>
    <segment id="182">, e Horacio Larreta</segment>
    <segment id="183">, governador da capital federal.</segment>
    <segment id="184">Quem mais</segment>
    <segment id="185">sese beneficia do caos econômico e das brigas internas nas duas principais forças políticas do país</segment>
    <segment id="186">, no entanto</segment>
    <segment id="187">, é o candidato visto</segment>
    <segment id="188">comocomo "outsider": o deputado ultraliberal Javier Milei</segment>
    <segment id="189">, da legenda</segment>
    <segment id="190">A Liberdade Avança</segment>
    <segment id="191">, nominalmente à frente em algumas pesquisas de intenção de voto.</segment>
    <segment id="192">Sua principal proposta é a dolarização total da Argentina</segment>
    <segment id="193">, considerada por alguns uma sugestão ousada e</segment>
    <segment id="194">, por outros</segment>
    <segment id="195">, surrealista</segment>
    <segment id="196">, já que o país não tem reserva da moeda americana.</segment>
    <segment id="197">Se Milei for bem nas primárias</segment>
    <segment id="198">, pode provocar uma corrida ainda maior por dólares antes das eleições</segment>
    <segment id="199">, afirma o economista Matías Surt</segment>
    <segment id="200">, diretor da consultoria Invecq.</segment>
    <segment id="201">"</segment>
    <segment id="202">Tudo vai depender do que acontecer em agosto.</segment>
    <segment id="203">"</segment>
  </rst>
</analysis>