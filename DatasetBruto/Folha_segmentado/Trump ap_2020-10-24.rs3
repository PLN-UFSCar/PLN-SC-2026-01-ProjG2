  <rst>
    <segment id="1">Em cima do palco da igreja evangélica Nación de Fe</segment>
    <segment id="2">, na Flórida</segment>
    <segment id="3">, Jeff Mojica canta acompanhado de banda</segment>
    <segment id="4">, backing vocal e um grupo de dançarinos.</segment>
    <segment id="5">Nascido em Porto Rico</segment>
    <segment id="6">, o jovem de 21 anos mudou-</segment>
    <segment id="7">sese para os EUA ainda criança e</segment>
    <segment id="8">, há dois meses</segment>
    <segment id="9">, virou um dos líderes da igreja em Kissimmee</segment>
    <segment id="10">, cidade de 70 mil habitantes que</segment>
    <segment id="11">sese tornou símbolo da luta de Joe Biden para conquistar o estado que pode custar a reeleição de Donald Trump.</segment>
    <segment id="12">O vice-presidente dos EUA</segment>
    <segment id="13">, Mike Pence</segment>
    <segment id="14">, discursa em comício para latinos pró-Trump em Orlando</segment>
    <segment id="15">, na Flórida - Zak Bennett - 10.out.20/AFPÉ ali</segment>
    <segment id="16">, perto de Orlando</segment>
    <segment id="17">, que muitos porto-riquenhos</segment>
    <segment id="18">sese estabelecem ao deixar a ilha caribenha</segment>
    <segment id="19">, território americano que tem passado por agudas crises socioeconômicas.</segment>
    <segment id="20">Seus cidadãos</segment>
    <segment id="21">, aptos a votar nos EUA</segment>
    <segment id="22">, são uma das principais apostas do democrata para decolar na Flórida.</segment>
    <segment id="23">Pessoas de origem latina tendem a votar em candidatos democratas —71% delas escolheram</segment>
    <segment id="24">Barack Obama em 2012 e 66% optaram por Hillary Clinton em 2016.</segment>
    <segment id="25">Entre porto-riquenhos</segment>
    <segment id="26">, a fatia é ainda maior: três em cada quatro preferem o partido de Biden quando vão às urnas.</segment>
    <segment id="27">Mas Mojica inverte essa lógica.</segment>
    <segment id="28">Diz que votará em Trump em nome dos valores conservadores e reflete a complexidade de traçar o perfil dos latinos no estado em que a comunidade representa 20% do eleitorado e pode definir a disputa à Casa Branca.</segment>
    <segment id="29">"</segment>
    <segment id="30">Como cristãos</segment>
    <segment id="31">, temos valores que devemos seguir</segment>
    <segment id="32">, ser pró-vida [contrário ao aborto] e tudo o que for em benefício de buscar Deus.</segment>
    <segment id="33">Trump tem apoiado isso e</segment>
    <segment id="34">, portanto</segment>
    <segment id="35">, nós [da igreja] o apoiamos"</segment>
    <segment id="36">, explica Mojica.</segment>
    <segment id="37">"</segment>
    <segment id="38">Biden é contra as famílias</segment>
    <segment id="39">,</segment>
    <segment id="40">não é pró-vida</segment>
    <segment id="41">, é aberto à homossexualidade</segment>
    <segment id="42">, coisas que a igreja não apoia.</segment>
    <segment id="43">"  Mojica releva a retórica agressiva e a política anti-imigração de Trump</segment>
    <segment id="44">, além da condução errática e ineficaz do presidente diante da pandemia que já matou mais de 220 mil pessoas nos EUA.</segment>
    <segment id="45">Tudo em nome das ideias que diz estarem na Bíblia.</segment>
    <segment id="46">"</segment>
    <segment id="47">Não importa o que aconteça</segment>
    <segment id="48">, minha percepção permanece a mesma</segment>
    <segment id="49">, porque</segment>
    <segment id="50">porque devo lutar pelos meus valores.</segment>
    <segment id="51">"</segment>
    <segment id="52">Latinos evangélicos aumentam base de Trump na FlóridaMais    novamente         de   de  de  representando um</segment>
    <segment id="53">A Flórida é chave na eleição.</segment>
    <segment id="54">Considerado estado-pêndulo (que ora vota em democratas</segment>
    <segment id="55">, ora em republicanos)</segment>
    <segment id="56">, tem 29 dos 270 votos que o vencedor precisa atingir no Colégio Eleitoral —sistema indireto que escolhe o presidente americano.</segment>
    <segment id="57">Em 2016</segment>
    <segment id="58">, Trump venceu Hillary Clinton por apenas um ponto percentual no estado e</segment>
    <segment id="59">, agora</segment>
    <segment id="60">, Biden tem quatro de vantagem</segment>
    <segment id="61">, segundo a média das pesquisas compiladas pelo site FiveThirtyEight.</segment>
    <segment id="62">O democrata lidera no cenário nacional com mais de dez pontos</segment>
    <segment id="63">, masmas não consegue abrir boa margem na Flórida</segment>
    <segment id="64">, pois</segment>
    <segment id="65">pois tem tido dificuldade para conquistar latinos que</segment>
    <segment id="66">, pela primeira vez na história dos EUA</segment>
    <segment id="67">, devem superar os negros e</segment>
    <segment id="68">sese tornar a minoria étnica com maior representação nas urnas —13</segment>
    <segment id="69">,3%.</segment>
    <segment id="70">Desanimados com a política</segment>
    <segment id="71">, que associam à ineficiência e à corrupção</segment>
    <segment id="72">, muitos não</segment>
    <segment id="73">sese animam a votar</segment>
    <segment id="74">, masmas o discurso fervoroso de Trump motiva os mais conservadores</segment>
    <segment id="75">, que têm impedido que Biden deslanche entre a comunidade latina na região.</segment>
    <segment id="76">Há mais de 20 anos</segment>
    <segment id="77">, quem ganha na Flórida leva também a Casa Branca</segment>
    <segment id="78">, e Trump sabe que vencer ali é fundamental para sua reeleição —desde 1924</segment>
    <segment id="79">, um republicano não chega à Presidência sem o estado.</segment>
    <segment id="80">Em linhas gerais</segment>
    <segment id="81">, o sul da Flórida está mais progressista</segment>
    <segment id="82">, tendendo a Biden</segment>
    <segment id="83">, enquanto o norte segue conservador</segment>
    <segment id="84">, com Trump.</segment>
    <segment id="85">O presidente lidera entre eleitores de origem cubana e venezuelana</segment>
    <segment id="86">, sensíveis ao discurso antissocialista do republicano</segment>
    <segment id="87">, enquanto Biden tem mais entrada em grupos de ascendência mexicana e porto-riquenha.</segment>
    <segment id="88">O cenário nebuloso da região delega o termômetro à Flórida central</segment>
    <segment id="89">, no chamado corredor I-94</segment>
    <segment id="90">, referência à rodovia que cruza o estado de costa a costa.</segment>
    <segment id="91">A Folha percorreu parte dessa faixa que vai da democrata Tampa à republicana Daytona Beach.</segment>
    <segment id="92">Brasileiros na Flórida sentem impacto econômico da pandemia e</segment>
    <segment id="93">sese dividem sobre TrumpMais    novamente         de   de  de  representando um  Há quatro anos</segment>
    <segment id="94">, os condados de Orange</segment>
    <segment id="95">, que abriga Orlando</segment>
    <segment id="96">, e de Osceola</segment>
    <segment id="97">, onde fica Kissimmee</segment>
    <segment id="98">, deram a vitória a Hillary por 60%</segment>
    <segment id="99">, masmas Biden precisa ampliar essa vantagem</segment>
    <segment id="100">, atraindo maior participação dos eleitores latinos para tentar desequilibrar o bom desempenho de Trump em outras partes do estado.</segment>
    <segment id="101">A métrica</segment>
    <segment id="102">, porém</segment>
    <segment id="103">porém, é pouco favorável: desde 1996</segment>
    <segment id="104">, menos da metade dos latinos elegíveis a votar comparecem no dia do pleito</segment>
    <segment id="105">, visto que nos EUA o voto não é obrigatório.</segment>
    <segment id="106">A poucos quilômetros da igreja de Mojica</segment>
    <segment id="107">, o Miguelo's Bar costuma juntar porto-riquenhos que refletem esse desânimo.</segment>
    <segment id="108">Em busca de comidas e bebidas típicas</segment>
    <segment id="109">, com pedidos feitos somente em espanhol</segment>
    <segment id="110">, os irmãos Alex e Diana contam que estão nos EUA há quase 15 anos</segment>
    <segment id="111">, masmas só ela foi às urnas</segment>
    <segment id="112">, numa estreia que aconteceu em 2016.</segment>
    <segment id="113">"</segment>
    <segment id="114">Votei na Hillary</segment>
    <segment id="115">, claro</segment>
    <segment id="116">, masmas neste ano não estou pensando em votar.</segment>
    <segment id="117">As pessoas estão com raiva do que estamos vivendo</segment>
    <segment id="118">, masmas o adversário de Trump também não é bom</segment>
    <segment id="119">, é como</segment>
    <segment id="120">como um voto perdido.</segment>
    <segment id="121">"  Diana diz que precisava de uma promessa mais clara de Biden pela diminuição da desigualdade e do racismo contra latinos e negros no país para votar.</segment>
    <segment id="122">"</segment>
    <segment id="123">Isso aumentou muito desde que Trump tomou posse.</segment>
    <segment id="124">Sinto na pele vivendo aqui.</segment>
    <segment id="125">"  Infectado</segment>
    <segment id="126">, Trump discursa sem máscara a apoiadoresMais    novamente         de   de  de  representando um  Já</segment>
    <segment id="127">Millie</segment>
    <segment id="128">Santiago deixou Porto Rico há três anos</segment>
    <segment id="129">, um mês depois de o furacão</segment>
    <segment id="130">Maria atingir a ilha.</segment>
    <segment id="131">Moradora de Orlando</segment>
    <segment id="132">, diz entender a falta de motivação de parte de seus conterrâneos</segment>
    <segment id="133">, masmas acredita que</segment>
    <segment id="134">, diante de um governo Trump</segment>
    <segment id="135">, seu voto é fundamental.</segment>
    <segment id="136">"Estamos cansados</segment>
    <segment id="137">, porque</segment>
    <segment id="138">porque a política em Porto Rico é sempre corrupta e não muda nada.</segment>
    <segment id="139">Mas, para os latinos</segment>
    <segment id="140">, Biden é a melhor alternativa.</segment>
    <segment id="141">A pessoa que está no poder tem demonstrado uma antipatia brutal em relação aos latinos.</segment>
    <segment id="142">Para ele</segment>
    <segment id="143">, somos um zero à esquerda.</segment>
    <segment id="144">Ele é racista</segment>
    <segment id="145">, olha o jeito que fala de mulheres</segment>
    <segment id="146">, dos imigrantes</segment>
    <segment id="147">, é horrível.</segment>
    <segment id="148">"  Auxiliares da campanha de Biden dizem que há muita desinformação com impacto na comunidade latina</segment>
    <segment id="149">, como</segment>
    <segment id="150">como no discurso da lei e da ordem —</segment>
    <segment id="151">Trump insiste que protestos vão destruir os subúrbios—</segment>
    <segment id="152">, a ideia de que o voto contra o presidente não tem valor e que Biden vai financiar clínicas de aborto e mergulhar os EUA no socialismo</segment>
    <segment id="153">, embora</segment>
    <segment id="154">embora o democrata seja um moderado.</segment>
    <segment id="155">Essas teses foram repetidas na fala do vice-presidente Mike Pence</segment>
    <segment id="156">, que desembarcou nas imediações de Orlando em 10 de outubro.</segment>
    <segment id="157">Recebido com oração</segment>
    <segment id="158">, Pence fez um pronunciamento de quase uma hora</segment>
    <segment id="159">, diante da audiência que</segment>
    <segment id="160">, em grande parte</segment>
    <segment id="161">, não falava inglês.</segment>
    <segment id="162">Ao lado do marido</segment>
    <segment id="163">, Damian Carpintero</segment>
    <segment id="164">, a venezuelana Soraya Rubio disse temer que os EUA repitam o regime de Nicolás Maduro e que a religião ainda move seu voto.</segment>
    <segment id="165">"Sou evangélica</segment>
    <segment id="166">, e Trump apoia um país com religião e moral</segment>
    <segment id="167">, tudo o que</segment>
    <segment id="168">sese perdeu aqui.</segment>
    <segment id="169">"  Descendentes no Novo MéxicoMais    novamente         de   de  de  representando um</segment>
    <segment id="170">Os dados sobre a preferência política de latinos evangélicos são escassos na Flórida</segment>
    <segment id="171">, masmas análise do Public Religion Research Institute mostra que a percepção favorável sobre Trump entre protestantes hispânicos de todo o país cresceu dois dígitos entre 2019 e 2020 —foi de 37% para 50%.</segment>
    <segment id="172">Mesmo aliados dizem que Biden demorou para reagir às investidas de Trump na Flórida central</segment>
    <segment id="173">, masmas a contraofensiva —com reforço na equipe e propagandas direcionadas— tem surtido efeito em outra minoria</segment>
    <segment id="174">, que pode compensar a dificuldade do democrata entre latinos e ser definitiva nessa eleição: os idosos.</segment>
    <segment id="175">Em 2012</segment>
    <segment id="176">, pessoas com 65 anos ou mais foram 26% do eleitorado.</segment>
    <segment id="177">Em 2016</segment>
    <segment id="178">, 30%.</segment>
    <segment id="179">A vantagem dos republicanos sempre foi confortável nesse grupo</segment>
    <segment id="180">, masmas tem diminuído</segment>
    <segment id="181">, principalmente diante da má condução do presidente na pandemia.</segment>
    <segment id="182">Trump chegou a 46% da preferência entre eleitores com 65 anos ou mais</segment>
    <segment id="183">, segundo pesquisa do Wall Street Journal/NBC News</segment>
    <segment id="184">, queda de seis pontos percentuais em relação ao que teve em 2016.</segment>
    <segment id="185">Na Flórida</segment>
    <segment id="186">, que abriga muitos aposentados por causa de seu clima ameno</segment>
    <segment id="187">, o desempenho do presidente também piorou nessa faixa etária.</segment>
    <segment id="188">Patrulha apreende imigrantes na fronteira dos EUAMais    novamente         de   de  de  representando um  Perto de Tampa</segment>
    <segment id="189">, em uma das pontas do corredor I-94</segment>
    <segment id="190">, fica o condado de Pinellas</segment>
    <segment id="191">, com a cidade de São Petersburgo e uma das populações mais velhas do país.</segment>
    <segment id="192">Em 2012</segment>
    <segment id="193">, a região deu a vitória a Obama e</segment>
    <segment id="194">, em 2016</segment>
    <segment id="195">, foi de Trump</segment>
    <segment id="196">, transformando-</segment>
    <segment id="197">sese em um dos dez mais importantes condados para a corrida deste ano</segment>
    <segment id="198">, segundo o jornal The New York Times.</segment>
    <segment id="199">Morador de São Petersburgo</segment>
    <segment id="200">, o aposentado William Stewert</segment>
    <segment id="201">, 68, resume o sentimento do eleitorado que tem</segment>
    <segment id="202">sese afastado dos republicanos —e preocupado o presidente.</segment>
    <segment id="203">"Só quero me livrar do Trump.</segment>
    <segment id="204">Não é que eu ame o Biden</segment>
    <segment id="205">, é só que ele é a outra opção.</segment>
    <segment id="206">"</segment>
    <segment id="207">Trump sabe que não deve ganhar de Biden entre os latinos —seu esforço serve para tentar diminuir a vantagem do democrata em um estado crucial.</segment>
    <segment id="208">Mas o fracasso diante de um eleitor cativo</segment>
    <segment id="209">, como</segment>
    <segment id="210">como os mais velhos</segment>
    <segment id="211">, pode custar um passo importante rumo à sua reeleição.</segment>
  </rst>
</analysis>