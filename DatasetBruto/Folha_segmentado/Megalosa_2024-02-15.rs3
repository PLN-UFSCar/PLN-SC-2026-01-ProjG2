  <rst>
    <segment id="1">Em 20 de fevereiro de 1824</segment>
    <segment id="2">, o naturalista e teólogo inglês William Buckland dirigiu-</segment>
    <segment id="3">sese à Sociedade Geológica de Londres</segment>
    <segment id="4">, descrevendo uma mandíbula enorme e ossos de membros desenterrados em uma pedreira de ardósia na vila de Stonesfield</segment>
    <segment id="5">, perto de Oxford.</segment>
    <segment id="6">Ele reconheceu que esses fósseis pertenciam a um enorme réptil extinto e deu a ele um nome científico formal: Megalosaurus</segment>
    <segment id="7">, que significa grande lagarto.</segment>
    <segment id="8">Com isso</segment>
    <segment id="9">, o primeiro dinossauro foi oficialmente reconhecido</segment>
    <segment id="10">, embora</segment>
    <segment id="11">embora a palavra dinossauro em si só tenha sido cunhada na década de 1840.</segment>
    <segment id="12">"</segment>
    <segment id="13">Foi o início da nossa fascinação pelos dinossauros"</segment>
    <segment id="14">, disse o paleontólogo Steve Brusatte</segment>
    <segment id="15">, da Universidade de Edimburgo.</segment>
    <segment id="16">O anúncio</segment>
    <segment id="17">, segundo ele</segment>
    <segment id="18">, também deu início a uma corrida por fósseis</segment>
    <segment id="19">, não só na Inglaterra</segment>
    <segment id="20">masmas em outros países.</segment>
    <segment id="21">Parte de mandíbula com dentes do Megalosaurus</segment>
    <segment id="22">, primeiro dinossauro a ganhar um nome científico</segment>
    <segment id="23">, em 1824    - Museu de História Natural da Universidade de OxfordNos 200 anos seguintes</segment>
    <segment id="24">, pesquisas revelaram</segment>
    <segment id="25">comocomo essas criaturas viveram</segment>
    <segment id="26">, evoluíram e o que as condenou.</segment>
    <segment id="27">Os dinossauros percorreram o planeta de 231 milhões de anos a 66 milhões de anos atrás</segment>
    <segment id="28">, durante a Era Mesozoica.  "</segment>
    <segment id="29">Nossa compreensão dos dinossauros mudou significativamente desde o século 19"</segment>
    <segment id="30">, disse a paleontóloga Emma Nicholls do Museu de História Natural da Universidade de Oxford</segment>
    <segment id="31">, lar dos fósseis de Megalosaurus estudados por Buckland.  "Buckland e outros naturalistas do início do século 19 ficariam chocados com o quanto sabemos agora sobre os dinossauros"</segment>
    <segment id="32">, acrescentou ela.</segment>
    <segment id="33">Megalosaurus foi o 1º dinossauro há ganhar nome científicoMais    novamente         de   de  de  representando um</segment>
    <segment id="34">O Megalosaurus é um exemplo disso.</segment>
    <segment id="35">Buckland pensava que era um lagarto com cerca de 20 metros de comprimento</segment>
    <segment id="36">, andava em quatro patas e podia viver em terra ou na água.</segment>
    <segment id="37">Hoje, os cientistas sabem que ele não era quadrúpede e não era um lagarto</segment>
    <segment id="38">, masmas pertencia ao grupo terópode</segment>
    <segment id="39">, formado por dinossauros carnívoros</segment>
    <segment id="40">comocomo o Tyrannosaurus e o Spinosaurus</segment>
    <segment id="41">, e tinha aproximadamente 9 metros de comprimento.</segment>
    <segment id="42">"</segment>
    <segment id="43">Ele corria em suas patas traseiras</segment>
    <segment id="44">, perseguindo sua presa"</segment>
    <segment id="45">, disse Brusatte.</segment>
    <segment id="46">Assim como</segment>
    <segment id="47">como outros na época</segment>
    <segment id="48">, Buckland não compreendia há quanto tempo os dinossauros viveram</segment>
    <segment id="49">, acreditando que a Terra tinha somente alguns milhares de anos.</segment>
    <segment id="50">Sabe-se</segment>
    <segment id="51">se, hoje</segment>
    <segment id="52">, que o nosso planeta tem cerca de 4</segment>
    <segment id="53">,5 bilhões de anos.</segment>
    <segment id="54">O Megalossauro viveu cerca de 165 milhões de anos atrás.</segment>
    <segment id="55">O naturalista inglês Richard Owen reconheceu que fósseis encontrados no sul da Inglaterra de Megalossauro e outros dois grandes répteis terrestres</segment>
    <segment id="56">, Iguanodonte e Hylaeossauro</segment>
    <segment id="57">, formavam um grupo comum</segment>
    <segment id="58">, chamando-os de "Dinosauria" em uma palestra de 1841 e numa publicação no ano seguinte.</segment>
    <segment id="59">A descoberta subsequente de fósseis de Hadrossauro e Dryptosaurus em Nova Jersey</segment>
    <segment id="60">, nos Estados Unidos</segment>
    <segment id="61">, mostrou que pelo menos alguns dinossauros eram bípedes.</segment>
    <segment id="62">A partir dos anos 1870</segment>
    <segment id="63">, os primeiros esqueletos completos de espécies grandes —primeiro no oeste americano</segment>
    <segment id="64">, depois na Bélgica e em outros lugares— demonstraram a diversidade desses animais.</segment>
    <segment id="65">Na década de 1960</segment>
    <segment id="66">, a identificação do carnívoro Deinonico abalou a ciência</segment>
    <segment id="67">, ao mostrar que os dinossauros podiam ser pequenos e ágeis.</segment>
    <segment id="68">Alguns eram anatomicamente semelhantes a aves primitivas</segment>
    <segment id="69">comocomo o Archaeopteryx</segment>
    <segment id="70">, confirmando</segment>
    <segment id="71">comocomo as aves evoluíram a partir de dinossauros pequenos e emplumados.</segment>
    <segment id="72">Também provocou um debate sobre</segment>
    <segment id="73">sese os dinossauros eram de sangue quente</segment>
    <segment id="74">comocomo as aves</segment>
    <segment id="75">, contradizendo a concepção de longa data de que eram lentos</segment>
    <segment id="76">, pesados e de sangue frio.</segment>
    <segment id="77">Ilustração de Megalosaurus</segment>
    <segment id="78">, primeiro dinossauro a ganhar um nome</segment>
    <segment id="79">, em 1824   - Julius T. Csotonyi/Museu de História Natural da Universidade de Oxford"Nas décadas seguintes</segment>
    <segment id="80">, houve um aumento no trabalho sobre o crescimento dos dinossauros</segment>
    <segment id="81">, no uso de tomografias computadorizadas</segment>
    <segment id="82">, em métodos analíticos para a reconstrução de relações evolutivas e de função biomecânica</segment>
    <segment id="83">, tudo isso ajudando a criar uma visão mais dinâmica e biológica dos dinossauros</segment>
    <segment id="84">comocomo seres vivos"</segment>
    <segment id="85">, disse o paleontólogo Thomas Holtz</segment>
    <segment id="86">, da Universidade de Maryland.</segment>
    <segment id="87">Paleontólogos colocam fósseis cranianos em tomógrafos computadorizados para construir modelos digitais de cérebros</segment>
    <segment id="88">, adquirindo um melhor conhecimento de sentidos</segment>
    <segment id="89">, como</segment>
    <segment id="90">como visão</segment>
    <segment id="91">, audição e olfato.</segment>
    <segment id="92">Os pesquisadores também podem determinar a cor dos dinossauros</segment>
    <segment id="93">sese sua pele ou penas estiverem preservadas para reter bolhas microscópicas de melanossomas que contêm pigmento nas células.</segment>
    <segment id="94">Atualmente</segment>
    <segment id="95">, mais de 2.000 espécies de dinossauros são conhecidas e a paleontologia é uma ciência vibrante e internacional.</segment>
    <segment id="96">Descobertas notáveis de fósseis estão sendo feitas em lugares</segment>
    <segment id="97">comocomo China</segment>
    <segment id="98">, Argentina</segment>
    <segment id="99">, Brasil</segment>
    <segment id="100">, África do Sul e Mongólia.</segment>
    <segment id="101">O primeiro ninhal de dinossauros encontrado no BrasilMais    novamente         de   de  de  representando um  "</segment>
    <segment id="102">No que diz respeito às descobertas sobre dinossauros nas últimas décadas</segment>
    <segment id="103">, a mais importante</segment>
    <segment id="104">, na minha opinião</segment>
    <segment id="105">, é a de que pelo menos os dinossauros carnívoros</segment>
    <segment id="106">, terópodes</segment>
    <segment id="107">, tinham penas em vez de escamas e que alguns tinham penas muito bem desenvolvidas em seus braços</segment>
    <segment id="108">, mesmo que fossem incapazes de voar"</segment>
    <segment id="109">, disse o paleontólogo Hans-Dieter Sues</segment>
    <segment id="110">, do Museu Nacional de História Natural do Smithsonian Institution em Washington.  "</segment>
    <segment id="111">Possivelmente</segment>
    <segment id="112">, essas penas</segment>
    <segment id="113">, que frequentemente eram coloridas</segment>
    <segment id="114">, forneciam isolamento para o corpo e</segment>
    <segment id="115">, em pelo menos algumas espécies</segment>
    <segment id="116">, eram usadas para exibição"</segment>
    <segment id="117">, acrescentou Sues.</segment>
    <segment id="118">Fim à Era dos Dinossauros</segment>
    <segment id="119">A extinção dos dinossauros há muito tempo intrigava os cientistas</segment>
    <segment id="120">, com várias hipóteses oferecidas</segment>
    <segment id="121">, algumas plausíveis e outras ridículas</segment>
    <segment id="122">.</segment>
    <segment id="123">Alguns até propuseram que os mamíferos do tamanho de musaranhos da época devoraram os ovos dos dinossauros.</segment>
    <segment id="124">Em 1980</segment>
    <segment id="125">, pesquisadores identificaram uma camada de sedimento datada precisamente do fim da Era dos Dinossauros contendo altas concentrações de irídio</segment>
    <segment id="126">, um elemento comum em meteoritos</segment>
    <segment id="127">, indicando que um enorme asteroide havia atingido a Terra.</segment>
    <segment id="128">A cratera de Chicxulub</segment>
    <segment id="129">, na península de Yucatán</segment>
    <segment id="130">, no México—com 180 km de diâmetro— foi posteriormente identificada</segment>
    <segment id="131">comocomo o local do impacto do asteroide que eliminou três quartos das espécies da Terra</segment>
    <segment id="132">, incluindo os dinossauros.</segment>
    <segment id="133">Se esse asteroide tivesse tomado outra direção</segment>
    <segment id="134">, os dinossauros ainda dominariam a Terra?</segment>
    <segment id="135">"</segment>
    <segment id="136">Quase certamente sim"</segment>
    <segment id="137">, disse Holtz.</segment>
    <segment id="138">"</segment>
    <segment id="139">Os mamíferos surgiram pouco depois dos primeiros dinossauros</segment>
    <segment id="140">, masmas passaram muitos milhões de anos à sombra deles.</segment>
    <segment id="141">Os mamíferos mesozoicos foram altamente bem-sucedidos e diversos</segment>
    <segment id="142">, masmas apenas em tamanhos corporais menores.</segment>
    <segment id="143">"</segment>
    <segment id="144">Leia mais sobre dinossaurosParente mais próximo do T. rex</segment>
    <segment id="145">, T. mcraeensis é achado guardado em museu</segment>
    <segment id="146">Cientistas descreveram a nova espécie</segment>
    <segment id="147">, com base em crânio mantido há mais de 30 anos em museu dos EUAFóssil de Gorgosaurus</segment>
    <segment id="148">, primo do T. rex</segment>
    <segment id="149">, preserva suas últimas refeições</segment>
    <segment id="150">Esse é o primeiro esqueleto de tiranossauro com itens de presa dentro de seu estômagoPoeira de asteroide que levou à extinção de dinossauros gerou catástrofe climáticaMaterial liberado pelo impacto seria mais do que 11 vezes a massa do Monte Everest"Os dinossauros teriam que lidar com o eventual ressecamento e resfriamento do mundo</segment>
    <segment id="151">, e com isso a redução das florestas e sua substituição por pastagens"</segment>
    <segment id="152">, acrescentou Holtz.</segment>
    <segment id="153">"Mas essas mudanças parecem ter sido graduais o suficiente</segment>
    <segment id="154">para que</segment>
    <segment id="155">para que os dinossauros tivessem a chance de evoluir e</segment>
    <segment id="156">sese adaptar às novas condições</segment>
    <segment id="157">, assim</segment>
    <segment id="158">comocomo os grandes mamíferos fizeram.</segment>
    <segment id="159">"</segment>
    <segment id="160">Os cientistas avaliaram o metabolismo dos dinossauros usando uma fórmula baseada na massa corporal</segment>
    <segment id="161">, revelada pelo volume de seus ossos da coxa</segment>
    <segment id="162">, e nas taxas de crescimento</segment>
    <segment id="163">, demonstradas pelos anéis de crescimento nos ossos fósseis semelhantes aos das árvores.</segment>
    <segment id="164">A pesquisa sugeriu que os dinossauros eram intermediários entre os animais de sangue quente e os de sangue frio de hoje.</segment>
    <segment id="165">Os cientistas também refinaram sua avaliação acerca do tamanho de vários dinossauros</segment>
    <segment id="166">, incluindo o grupo dos saurópodes.</segment>
    <segment id="167">Um estudo de 2023</segment>
    <segment id="168">, baseado nas dimensões dos ossos das patas</segment>
    <segment id="169">, coroou o Argentinosaurus</segment>
    <segment id="170">, que tinha cerca de 35 metros de comprimento</segment>
    <segment id="171">, como</segment>
    <segment id="172">como o campeão peso-pesado com cerca de 76 toneladas.</segment>
    <segment id="173">Mesmo depois de dois séculos</segment>
    <segment id="174">, a pesquisa está longe de terminar.  "</segment>
    <segment id="175">Fora do campo da nova tecnologia</segment>
    <segment id="176">, ainda existem muitos terrenos baldios em vários cantos do mundo que são em grande parte inexplorados paleontologicamente"</segment>
    <segment id="177">, disse Holtz.</segment>
    <segment id="178">"</segment>
    <segment id="179">Essas regiões revelarão novas espécies da Era dos Dinossauros.</segment>
    <segment id="180">É praticamente certo que existem grupos inteiros ainda desconhecidos.</segment>
    <segment id="181">"</segment>
  </rst>
</analysis>