      <rel name="volitional-result" type="rst"/>
    </relations>
  </header>
  <rst>
    <segment id="1">Se Jair Bolsonaro &amp;eacute</segment>
    <segment id="2">; uma vers&amp;atilde</segment>
    <segment id="3">;o tropical de Donald Trump</segment>
    <segment id="4">, ent&amp;atilde</segment>
    <segment id="5">;o a derrota do presidente brasileiro na pr&amp;oacute</segment>
    <segment id="6">;xima elei&amp;ccedil</segment>
    <segment id="7">;&amp;atilde</segment>
    <segment id="8">;o passa por encontrar (ou construir) um equivalente de Joe Biden no Brasil.</segment>
    <segment id="9">O racioc&amp;iacute</segment>
    <segment id="10">;nio passou a nortear pol&amp;iacute</segment>
    <segment id="11">;ticos e estrategistas que discutem a formata&amp;ccedil</segment>
    <segment id="12">;&amp;atilde</segment>
    <segment id="13">;o de candidaturas para 2022.</segment>
    <segment id="14">A corrida em busca de uma vers&amp;atilde</segment>
    <segment id="15">;o nacional do pol&amp;iacute</segment>
    <segment id="16">;tico que assumiu em janeiro o governo dos Estados Unidos pregando a reunifica&amp;ccedil</segment>
    <segment id="17">;&amp;atilde</segment>
    <segment id="18">;o nacional e o fim dos extremismos ganhou corpo nas &amp;</segment>
    <segment id="19">uacute</segment>
    <segment id="20">;ltimas semanas em setores da centro-direita e da esquerda que querem brecar a reelei&amp;ccedil</segment>
    <segment id="21">;&amp;atilde</segment>
    <segment id="22">;o de Bolsonaro (sem partido).</segment>
    <segment id="23">Na fila para ser o Biden brasileiro aparecem hoje: Lula (PT)</segment>
    <segment id="24">, que deve ser candidato</segment>
    <segment id="25">sese mantiver seus direitos pol&amp;iacute</segment>
    <segment id="26">;ticos</segment>
    <segment id="27">;</segment>
    <segment id="28">Tasso Jereissati (PSDB)</segment>
    <segment id="29">, que ainda &amp;eacute</segment>
    <segment id="30">; d&amp;uacute</segment>
    <segment id="31">;vida no jogo eleitoral</segment>
    <segment id="32">; Rodrigo Pacheco (DEM)</segment>
    <segment id="33">, que diz recusar a candidatura</segment>
    <segment id="34">; e Michel Temer (MDB)</segment>
    <segment id="35">, que n&amp;atilde</segment>
    <segment id="36">;o chega a ser nem bal&amp;atilde</segment>
    <segment id="37">;o de ensaio.</segment>
    <segment id="38">Em montagem</segment>
    <segment id="39">, o ex-presidente Lula</segment>
    <segment id="40">, o senador Tasso Jereissati</segment>
    <segment id="41">, o ex-presidente Michel Temer e o presidente do Senado</segment>
    <segment id="42">, Rodrigo Pacheco    - Marlene Bergamo/Folhapress</segment>
    <segment id="43">, Jane de Araújo/Agência Senado</segment>
    <segment id="44">, Mathilde Missioneiro/Folhapress e Pedro Gontijo/Senado Federal&amp;Eacute</segment>
    <segment id="45">; claro que a diferen&amp;ccedil</segment>
    <segment id="46">;a entre os sistemas pol&amp;iacute</segment>
    <segment id="47">;ticos americano (bipartid&amp;aacute</segment>
    <segment id="48">;rio) e brasileiro (com 33 legendas) desencoraja uma compara&amp;ccedil</segment>
    <segment id="49">;&amp;atilde</segment>
    <segment id="50">;o r&amp;iacute</segment>
    <segment id="51">;gida,</segment>
    <segment id="52">masmas a ca&amp;ccedil</segment>
    <segment id="53">;ada ao menos vem arrancando risadas e repercutido em memes.</segment>
    <segment id="54">O movimento enseja tamb&amp;eacute</segment>
    <segment id="55">;m um debate sobre pol&amp;iacute</segment>
    <segment id="56">;ticas de governo para a economia.</segment>
    <segment id="57">Talvez o &amp;uacute</segment>
    <segment id="58">;nico</segment>
    <segment id="59">aspecto de Biden capaz de contemplar todo o quarteto local seja a experi&amp;ecirc</segment>
    <segment id="60">;ncia, j&amp;aacute</segment>
    <segment id="61">; que o grupo re&amp;uacute</segment>
    <segment id="62">;ne dois ex-presidentes e dois senadores &amp;mdash</segment>
    <segment id="63">;Pacheco &amp;eacute</segment>
    <segment id="64">; o atual presidente do Senado</segment>
    <segment id="65">, e Tasso</segment>
    <segment id="66">, que tem mandato no Senado at&amp;eacute</segment>
    <segment id="67">; 2023</segment>
    <segment id="68">, j&amp;aacute</segment>
    <segment id="69">;</segment>
    <segment id="70">foi governador do Cear&amp;aacute</segment>
    <segment id="71">;</segment>
    <segment id="72">por tr&amp;ecirc</segment>
    <segment id="73">;s vezes.</segment>
    <segment id="74">No recorte et&amp;aacute</segment>
    <segment id="75">;rio, Pacheco</segment>
    <segment id="76">, com 44 anos</segment>
    <segment id="77">, &amp;eacute</segment>
    <segment id="78">; reprovado na disputa com Tasso (72)</segment>
    <segment id="79">, Lula (75) e Temer (80)</segment>
    <segment id="80">, que se</segment>
    <segment id="81">se aproximam dos 77 anos de Biden na data da elei&amp;ccedil</segment>
    <segment id="82">;&amp;atilde</segment>
    <segment id="83">;o.</segment>
    <segment id="84">No quesito Kamala Harris</segment>
    <segment id="85">, uma figura feminina e politicamente forte</segment>
    <segment id="86">comocomo candidata a vice</segment>
    <segment id="87">, nenhum dos quatro tem cartas na manga.</segment>
    <segment id="88">Para se</segment>
    <segment id="89">se consagrar candidato</segment>
    <segment id="90">, Biden uniu correntes progressistas e moderadas do seu Partido Democrata.</segment>
    <segment id="91">Por aqui</segment>
    <segment id="92">, Tasso</segment>
    <segment id="93">, Temer e Pacheco comp&amp;otilde</segment>
    <segment id="94">;em o campo que quer repetir a fa&amp;ccedil</segment>
    <segment id="95">;anha e convergir for&amp;ccedil</segment>
    <segment id="96">;as pol&amp;iacute</segment>
    <segment id="97">;ticas para o centro &amp;mdash</segment>
    <segment id="98">;tarefa mais complexa</segment>
    <segment id="99">, j&amp;aacute</segment>
    <segment id="100">; que o xadrez envolve partidos diferentes.</segment>
    <segment id="101">A imagem de um pol&amp;iacute</segment>
    <segment id="102">;tico conciliador</segment>
    <segment id="103">, comedido e experiente &amp;eacute</segment>
    <segment id="104">;</segment>
    <segment id="105">um ativo almejado n&amp;atilde</segment>
    <segment id="106">;o s&amp;oacute</segment>
    <segment id="107">;</segment>
    <segment id="108">pelos que est&amp;atilde</segment>
    <segment id="109">;o na corrida eleitoral e</segment>
    <segment id="110">sese espelham na popularidade do presidente dos EUA</segment>
    <segment id="111">, masmas tamb&amp;eacute</segment>
    <segment id="112">;m por atores que dizem querer apoiar um postulante avesso &amp;agrave</segment>
    <segment id="113">;</segment>
    <segment id="114">conflagra&amp;ccedil</segment>
    <segment id="115">;&amp;atilde</segment>
    <segment id="116">;o instaurada pela direita bolsonarista.</segment>
    <segment id="117">Veja quais são os possíveis candidatos à Presidência em 2022   novamente         de   de  de  representando um  No PSDB</segment>
    <segment id="118">, a campanha informal de Tasso foi lan&amp;ccedil</segment>
    <segment id="119">;ada pelo presidente da legenda</segment>
    <segment id="120">, Bruno Ara&amp;uacute</segment>
    <segment id="121">;jo, e &amp;eacute</segment>
    <segment id="122">; inflada por militantes</segment>
    <segment id="123">, sobretudo a ala da juventude</segment>
    <segment id="124">, que &amp;eacute</segment>
    <segment id="125">; comandada por uma sobrinha do senador</segment>
    <segment id="126">, J&amp;uacute</segment>
    <segment id="127">;lia Jereissati.</segment>
    <segment id="128">V&amp;ecirc</segment>
    <segment id="129">;m do grupo v&amp;iacute</segment>
    <segment id="130">;deos e memes que abra&amp;ccedil</segment>
    <segment id="131">;am a compara&amp;ccedil</segment>
    <segment id="132">;&amp;atilde</segment>
    <segment id="133">;o do cearense a Biden.</segment>
    <segment id="134">O perfil do Twitter &amp;quot</segment>
    <segment id="135">;Presidentasso&amp;quot</segment>
    <segment id="136">; descreveu o tucano</segment>
    <segment id="137">comocomo &amp;quot</segment>
    <segment id="138">;Brazilian Biden&amp;quot</segment>
    <segment id="139">;, pegando onda no meme que replicou a imagem de divulga&amp;ccedil</segment>
    <segment id="140">;&amp;atilde</segment>
    <segment id="141">;o da nova m&amp;uacute</segment>
    <segment id="142">;sica da cantora Anitta.</segment>
    <segment id="143">Segundo membros do PSDB</segment>
    <segment id="144">, as a&amp;ccedil</segment>
    <segment id="145">;&amp;otilde</segment>
    <segment id="146">;es s&amp;atilde</segment>
    <segment id="147">;o espont&amp;acirc</segment>
    <segment id="148">;neas, sem participa&amp;ccedil</segment>
    <segment id="149">;&amp;atilde</segment>
    <segment id="150">;o de marqueteiros.</segment>
    <segment id="151">Integrantes da sigla relatam que o mote ganhou f&amp;ocirc</segment>
    <segment id="152">;lego, curiosamente</segment>
    <segment id="153">, pelas m&amp;atilde</segment>
    <segment id="154">;os de um detrator</segment>
    <segment id="155">, o deputado federal Marco Feliciano (Republicanos-SP).</segment>
    <segment id="156">O aliado de Bolsonaro tuitou</segment>
    <segment id="157">, em 15 de abril</segment>
    <segment id="158">, que um dos objetivos da CPI da Covid era dar visibilidade a Tasso &amp;quot</segment>
    <segment id="159">;para tentar fazer dele o &amp;#</segment>
    <segment id="160">39;Biden brasileiro&amp;#39</segment>
    <segment id="161">;&amp;quot</segment>
    <segment id="162">;.  Se tiver mesmo voca&amp;ccedil</segment>
    <segment id="163">;&amp;atilde</segment>
    <segment id="164">;o para Biden</segment>
    <segment id="165">, Tasso poder&amp;aacute</segment>
    <segment id="166">; prov&amp;aacute</segment>
    <segment id="167">;-la</segment>
    <segment id="168">apaziguando o clima em seu partido</segment>
    <segment id="169">, que organiza pr&amp;eacute</segment>
    <segment id="170">;vias para definir o candidato.</segment>
    <segment id="171">Os demais concorrentes s&amp;atilde</segment>
    <segment id="172">;o os governadores de S&amp;atilde</segment>
    <segment id="173">;o Paulo</segment>
    <segment id="174">, Jo&amp;atilde</segment>
    <segment id="175">;o Doria</segment>
    <segment id="176">, e do Rio Grande do Sul</segment>
    <segment id="177">, Eduardo Leite</segment>
    <segment id="178">, e o ex-prefeito de Manaus Arthur Virg&amp;iacute</segment>
    <segment id="179">;lio.  ​No entorno de Temer</segment>
    <segment id="180">, a analogia &amp;eacute</segment>
    <segment id="181">; vista com simpatia</segment>
    <segment id="182">, ao mesmo tempo em que o ex-presidente nega a inten&amp;ccedil</segment>
    <segment id="183">;&amp;atilde</segment>
    <segment id="184">;o de concorrer.</segment>
    <segment id="185">Diante das especula&amp;ccedil</segment>
    <segment id="186">;&amp;otilde</segment>
    <segment id="187">;es sobre campanha</segment>
    <segment id="188">, o emedebista brincou em mar&amp;ccedil</segment>
    <segment id="189">;o que a &amp;uacute</segment>
    <segment id="190">;nica candidatura a que</segment>
    <segment id="191">sese dispunha era &amp;agrave</segment>
    <segment id="192">;</segment>
    <segment id="193">aplica&amp;ccedil</segment>
    <segment id="194">;&amp;atilde</segment>
    <segment id="195">;o da segunda dose da vacina contra a Covid-19.  &amp;quot</segment>
    <segment id="196">;Vejo no presidente Temer a mesma serenidade</segment>
    <segment id="197">, experi&amp;ecirc</segment>
    <segment id="198">;ncia, tempo de vida semelhante&amp;quot</segment>
    <segment id="199">;, diz o ex-deputado federal Carlos Marun (MDB-MS)</segment>
    <segment id="200">, um dos maiores entusiastas da volta de Temer.</segment>
    <segment id="201">&amp;quot;Ele pode ser um Biden brasileiro</segment>
    <segment id="202">, um pacificador</segment>
    <segment id="203">, depois de oito anos de grandes conflitos no pa&amp;iacute</segment>
    <segment id="204">;s.&amp;quot</segment>
    <segment id="205">;</segment>
    <segment id="206">O presidente nacional do PSD</segment>
    <segment id="207">, Gilberto Kassab</segment>
    <segment id="208">, por sua vez</segment>
    <segment id="209">, aposta as fichas em Pacheco</segment>
    <segment id="210">comocomo &amp;quot</segment>
    <segment id="211">;sugest&amp;atilde</segment>
    <segment id="212">;o de Biden&amp;quot</segment>
    <segment id="213">;.</segment>
    <segment id="214">Afirma que o mineiro &amp;quot</segment>
    <segment id="215">;&amp;eacute</segment>
    <segment id="216">; moderado</segment>
    <segment id="217">, preparado</segment>
    <segment id="218">, &amp;eacute</segment>
    <segment id="219">;</segment>
    <segment id="220">presidente do Senado</segment>
    <segment id="221">, tem bom di&amp;aacute</segment>
    <segment id="222">;logo com a esquerda</segment>
    <segment id="223">, tem independ&amp;ecirc</segment>
    <segment id="224">;ncia em rela&amp;ccedil</segment>
    <segment id="225">;&amp;atilde</segment>
    <segment id="226">;o ao governo</segment>
    <segment id="227">, masmas est&amp;aacute</segment>
    <segment id="228">; ajudando</segment>
    <segment id="229">, &amp;eacute</segment>
    <segment id="230">;</segment>
    <segment id="231">solid&amp;aacute</segment>
    <segment id="232">;rio&amp;quot</segment>
    <segment id="233">;.</segment>
    <segment id="234">Kassab ressalta que n&amp;atilde</segment>
    <segment id="235">;o est&amp;aacute</segment>
    <segment id="236">; lan&amp;ccedil</segment>
    <segment id="237">;ando a campanha do senador do DEM</segment>
    <segment id="238">, masmas que ele teria espa&amp;ccedil</segment>
    <segment id="239">;o no PSD para concorrer &amp;agrave</segment>
    <segment id="240">; Presid&amp;ecirc</segment>
    <segment id="241">;ncia.</segment>
    <segment id="242">Questionado sobre a idade de Pacheco ser um empecilho para o perfil</segment>
    <segment id="243">, o dirigente afirma que &amp;quot</segment>
    <segment id="244">;ele tem experi&amp;ecirc</segment>
    <segment id="245">;ncia&amp;quot</segment>
    <segment id="246">;</segment>
    <segment id="247">e, como</segment>
    <segment id="248">como Biden</segment>
    <segment id="249">, &amp;quot</segment>
    <segment id="250">;&amp;eacute</segment>
    <segment id="251">; alto</segment>
    <segment id="252">, magro</segment>
    <segment id="253">, discreto e gosta de ouvir&amp;quot</segment>
    <segment id="254">;.</segment>
    <segment id="255">No PT, a associa&amp;ccedil</segment>
    <segment id="256">;&amp;atilde</segment>
    <segment id="257">;o de Lula a Biden come&amp;ccedil</segment>
    <segment id="258">;a a aparecer em duas chaves: a de campanha eleitoral e a de plano de governo.</segment>
    <segment id="259">As falas giram em torno do estilo agregador que o ex-presidente vem buscando apresentar desde sua reabilita&amp;ccedil</segment>
    <segment id="260">;&amp;atilde</segment>
    <segment id="261">;o eleitoral</segment>
    <segment id="262">, com acenos &amp;agrave</segment>
    <segment id="263">; centro-direita e ao empresariado.</segment>
    <segment id="264">Na opini&amp;atilde</segment>
    <segment id="265">;o do ex-ministro Tarso Genro (PT-RS)</segment>
    <segment id="266">, no entanto</segment>
    <segment id="267">, a proximidade maior entre o brasileiro e o americano</segment>
    <segment id="268">sese d&amp;aacute</segment>
    <segment id="269">; na maneira de governar</segment>
    <segment id="270">, com uma pol&amp;iacute</segment>
    <segment id="271">;tica econ&amp;ocirc</segment>
    <segment id="272">;mica que considera o Estado pe&amp;ccedil</segment>
    <segment id="273">;a fundamental nos investimentos</segment>
    <segment id="274">, v&amp;ecirc</segment>
    <segment id="275">; a iniciativa privada</segment>
    <segment id="276">comocomo parceira e estimula programas de renda.</segment>
    <segment id="277">&amp;quot;Acho que a campanha deve</segment>
    <segment id="278">sese apropriar de algumas mensagens formuladas pelo Biden</segment>
    <segment id="279">, inclusive a de resgatar as fun&amp;ccedil</segment>
    <segment id="280">;&amp;otilde</segment>
    <segment id="281">;es p&amp;uacute</segment>
    <segment id="282">;blicas do Estado.</segment>
    <segment id="283">A ess&amp;ecirc</segment>
    <segment id="284">;ncia do Biden &amp;eacute</segment>
    <segment id="285">; recuperar o Estado</segment>
    <segment id="286">comocomo indutor de um certo tipo de desenvolvimento</segment>
    <segment id="287">, oferecendo marcos seguros para empresas p&amp;uacute</segment>
    <segment id="288">;blicas e privadas&amp;quot</segment>
    <segment id="289">;, diz.  Tarso</segment>
    <segment id="290">, por&amp;eacute</segment>
    <segment id="291">;m, faz ressalvas quanto &amp;agrave</segment>
    <segment id="292">;</segment>
    <segment id="293">compara&amp;ccedil</segment>
    <segment id="294">;&amp;atilde</segment>
    <segment id="295">;o, distinguindo os dois pa&amp;iacute</segment>
    <segment id="296">;ses em diversos aspectos.</segment>
    <segment id="297">Nos primeiros cem dias</segment>
    <segment id="298">, o governo do democrata prop&amp;ocirc</segment>
    <segment id="299">;s tr&amp;ecirc</segment>
    <segment id="300">;s pacotes de trilh&amp;otilde</segment>
    <segment id="301">;es de d&amp;oacute</segment>
    <segment id="302">;lares para investimentos em educa&amp;ccedil</segment>
    <segment id="303">;&amp;atilde</segment>
    <segment id="304">;o, sa&amp;uacute</segment>
    <segment id="305">;de, infraestrutura e recupera&amp;ccedil</segment>
    <segment id="306">;&amp;atilde</segment>
    <segment id="307">;o da economia.</segment>
    <segment id="308">&amp;quot;A &amp;uacute</segment>
    <segment id="309">;nica</segment>
    <segment id="310">pessoa com credibilidade e capacidade de propor um projeto de unidade nacional em defesa da recupera&amp;ccedil</segment>
    <segment id="311">;&amp;atilde</segment>
    <segment id="312">;o econ&amp;ocirc</segment>
    <segment id="313">;mica do pa&amp;iacute</segment>
    <segment id="314">;s &amp;eacute</segment>
    <segment id="315">;</segment>
    <segment id="316">o presidente Lula&amp;quot</segment>
    <segment id="317">;, diz o ex-governador ga&amp;uacute</segment>
    <segment id="318">;cho, acrescentando que outros candidatos podem &amp;quot</segment>
    <segment id="319">;at&amp;eacute</segment>
    <segment id="320">; falar que est&amp;atilde</segment>
    <segment id="321">;o aderindo &amp;agrave</segment>
    <segment id="322">;s ideias do Biden&amp;quot</segment>
    <segment id="323">;, mas</segment>
    <segment id="324">mas deixariam d&amp;uacute</segment>
    <segment id="325">;vidas.</segment>
    <segment id="326">O ex-presidente Lula em 2021   novamente         de   de  de  representando um  Articulador de uma coaliz&amp;atilde</segment>
    <segment id="327">;o de centro e direita contra a polariza&amp;ccedil</segment>
    <segment id="328">;&amp;atilde</segment>
    <segment id="329">;o entre Lula e Bolsonaro</segment>
    <segment id="330">, o ex-ministro da Sa&amp;uacute</segment>
    <segment id="331">;de Luiz Henrique Mandetta (DEM) diz que a agenda econ&amp;ocirc</segment>
    <segment id="332">;mica dos pr&amp;oacute</segment>
    <segment id="333">;ximos anos dever&amp;aacute</segment>
    <segment id="334">; recorrer a todas as ferramentas.</segment>
    <segment id="335">&amp;quot;N&amp;atilde</segment>
    <segment id="336">;o sese consegue recupera&amp;ccedil</segment>
    <segment id="337">;&amp;atilde</segment>
    <segment id="338">;o somente com o Estado nem somente com a iniciativa privada&amp;quot</segment>
    <segment id="339">;, afirma ele</segment>
    <segment id="340">, que orbita em torno de pr&amp;eacute</segment>
    <segment id="341">;-candidatos</segment>
    <segment id="342">comocomo Doria</segment>
    <segment id="343">, Leite</segment>
    <segment id="344">, Ciro Gomes (PDT)</segment>
    <segment id="345">, Jo&amp;atilde</segment>
    <segment id="346">;o Amo&amp;ecirc</segment>
    <segment id="347">;do (Novo)</segment>
    <segment id="348">, Luciano Huck e Sergio Moro (ambos sem partido).</segment>
    <segment id="349">Para Kassab</segment>
    <segment id="350">, medidas de reaquecimento</segment>
    <segment id="351">comocomo as adotadas por Biden nos EUA &amp;mdash</segment>
    <segment id="352">;que marcaram</segment>
    <segment id="353">, segundo analistas</segment>
    <segment id="354">, uma guinada ao nacional-desenvolvimentismo cultuado por setores da esquerda&amp;mdash</segment>
    <segment id="355">; poderiam</segment>
    <segment id="356">, sim, ser adotadas por um eventual candidato do PSD.</segment>
    <segment id="357">&amp;quot;Essa pandemia mostrou que a tese do Estado m&amp;iacute</segment>
    <segment id="358">;nimo est&amp;aacute</segment>
    <segment id="359">; eliminada ou suspensa.</segment>
    <segment id="360">&amp;Eacute</segment>
    <segment id="361">; fundamental um Estado forte na sa&amp;uacute</segment>
    <segment id="362">;de, na educa&amp;ccedil</segment>
    <segment id="363">;&amp;atilde</segment>
    <segment id="364">;o, na defesa.</segment>
