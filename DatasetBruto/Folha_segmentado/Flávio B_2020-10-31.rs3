  <rst>
    <segment id="1">O senador Fl&amp;aacute</segment>
    <segment id="2">;vio Bolsonaro (Republicanos-RJ) viajou para o arquip&amp;eacute</segment>
    <segment id="3">;lago de Fernando de Noronha (PE)</segment>
    <segment id="4">, onde passa o feriado prolongado do Dia de Finados</segment>
    <segment id="5">, com passagens a&amp;eacute</segment>
    <segment id="6">;reas pagas pelo Senado.</segment>
    <segment id="7">O pedido de reembolso das tarifas a&amp;eacute</segment>
    <segment id="8">;reas, que somam mais de R$ 1.500</segment>
    <segment id="9">, consta no Portal da Transpar&amp;ecirc</segment>
    <segment id="10">;ncia do Senado.</segment>
    <segment id="11">Em nota</segment>
    <segment id="12">, a assessoria do parlamentar afirmou que houve um equ&amp;iacute</segment>
    <segment id="13">;voco na solicita&amp;ccedil</segment>
    <segment id="14">;&amp;atilde</segment>
    <segment id="15">;o.</segment>
    <segment id="16">O gabinete tamb&amp;eacute</segment>
    <segment id="17">;m afirma que ir&amp;aacute</segment>
    <segment id="18">;</segment>
    <segment id="19">suspender o pedido de reembolso feito para as di&amp;aacute</segment>
    <segment id="20">;rias.</segment>
    <segment id="21">&amp;ldquo</segment>
    <segment id="22">;O gabinete do Senador Fl&amp;aacute</segment>
    <segment id="23">;vio</segment>
    <segment id="24">Bolsonaro informa que houve um equ&amp;iacute</segment>
    <segment id="25">;voco da equipe que emitiu as passagens para Fernando de Noronha.</segment>
    <segment id="26">As passagens foram pagas pelo pr&amp;oacute</segment>
    <segment id="27">;prio senador</segment>
    <segment id="28">, masmas a equipe</segment>
    <segment id="29">, por engano</segment>
    <segment id="30">, pediu reembolso.</segment>
    <segment id="31">Ele j&amp;aacute</segment>
    <segment id="32">;</segment>
    <segment id="33">fez a solicita&amp;ccedil</segment>
    <segment id="34">;&amp;atilde</segment>
    <segment id="35">;o para cancelar o reembolso e para tamb&amp;eacute</segment>
    <segment id="36">;m cancelar os pedidos de di&amp;aacute</segment>
    <segment id="37">;rias&amp;rsquo</segment>
    <segment id="38">;, afirma a nota.</segment>
    <segment id="39">Este é Flávio Bolsonaro   novamente         de   de  de  representando um</segment>
    <segment id="40">O caso</segment>
    <segment id="41">caso foi revelado neste s&amp;aacute</segment>
    <segment id="42">;bado (31) pelo site Metr&amp;oacute</segment>
    <segment id="43">;poles.</segment>
    <segment id="44">O filho do presidente Jair Bolsonaro (sem partido) saiu de Bras&amp;iacute</segment>
    <segment id="45">;lia na noite de quarta-feira (28) com destino ao Recife</segment>
    <segment id="46">, onde pernoitou antes de seguir para Fernando de Noronha.</segment>
    <segment id="47">A passagem de Bras&amp;iacute</segment>
    <segment id="48">;lia para Recife foi emitida no pr&amp;oacute</segment>
    <segment id="49">;prio dia e custou R$ R$ 256</segment>
    <segment id="50">,47.</segment>
    <segment id="51">J&amp;aacute</segment>
    <segment id="52">; os trechos de ida e volta de Fernando de Noronha para Recife e Bras&amp;iacute</segment>
    <segment id="53">;lia foram emitidos em 13 de outubro</segment>
    <segment id="54">, segundo consta nos registros do Senado.</segment>
    <segment id="55">Pelos dois trechos da viagem</segment>
    <segment id="56">, a Casa desembolsou R$ 1.361</segment>
    <segment id="57">,19.</segment>
    <segment id="58">No m&amp;ecirc</segment>
    <segment id="59">;s de outubro</segment>
    <segment id="60">, Fl&amp;aacute</segment>
    <segment id="61">;vio j&amp;aacute</segment>
    <segment id="62">; gastou R$ 6.527</segment>
    <segment id="63">,28 em passagens a&amp;eacute</segment>
    <segment id="64">;reas.</segment>
    <segment id="65">O parlamentar embarcou para a ilha na manh&amp;atilde</segment>
    <segment id="66">; de quinta-feira (29).</segment>
    <segment id="67">A passagem de volta de Fernando de Noronha para Bras&amp;iacute</segment>
    <segment id="68">;lia, com escala no Recife</segment>
    <segment id="69">, est&amp;aacute</segment>
    <segment id="70">; marcada para a pr&amp;oacute</segment>
    <segment id="71">;xima ter&amp;ccedil</segment>
    <segment id="72">;a-feira (3).</segment>
    <segment id="73">No bilhete a&amp;eacute</segment>
    <segment id="74">;reo, a previs&amp;atilde</segment>
    <segment id="75">;o de chegada a Bras&amp;iacute</segment>
    <segment id="76">;lia &amp;eacute</segment>
    <segment id="77">; 20h40.</segment>
    <segment id="78">Na ter&amp;ccedil</segment>
    <segment id="79">;a, o Senado inicia mais uma semana de esfor&amp;ccedil</segment>
    <segment id="80">;o concentrado</segment>
    <segment id="81">, com vota&amp;ccedil</segment>
    <segment id="82">;&amp;otilde</segment>
    <segment id="83">;es j&amp;aacute</segment>
    <segment id="84">; marcadas h&amp;aacute</segment>
    <segment id="85">; duas semanas.</segment>
    <segment id="86">Na pauta previamente acertada pelos l&amp;iacute</segment>
    <segment id="87">;deres partid&amp;aacute</segment>
    <segment id="88">;rios, consta o projeto de autonomia do BC (Banco Central)</segment>
    <segment id="89">, tido</segment>
    <segment id="90">comocomo uma das novas bandeiras da bancada governista.</segment>
    <segment id="91">A expectativa &amp;eacute</segment>
    <segment id="92">; que a vota&amp;ccedil</segment>
    <segment id="93">;&amp;atilde</segment>
    <segment id="94">;o ocorra &amp;agrave</segment>
    <segment id="95">;</segment>
    <segment id="96">tarde.​</segment>
  </rst>
</analysis>