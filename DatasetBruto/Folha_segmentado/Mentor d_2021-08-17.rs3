  <rst>
    <segment id="1">Luiz D&amp;oacute</segment>
    <segment id="2">;rea vibrou muito com o nocaute espetacular que deu a Hebert Concei&amp;ccedil</segment>
    <segment id="3">;&amp;atilde</segment>
    <segment id="4">;o a medalha de ouro nos Jogos Ol&amp;iacute</segment>
    <segment id="5">;mpicos de T&amp;oacute</segment>
    <segment id="6">;quio.</segment>
    <segment id="7">Era mais uma de suas crias chegando a uma grande conquista no boxe depois de ter crescido no esporte em seu projeto social em Salvador.</segment>
    <segment id="8">Mas o ex-lutador de 56 anos</segment>
    <segment id="9">, desta vez</segment>
    <segment id="10">, tomou o cuidado de celebrar o triunfo pelo triunfo</segment>
    <segment id="11">, n&amp;atilde</segment>
    <segment id="12">;o como</segment>
    <segment id="13">como um ponto de virada para a modalidade no Brasil.</segment>
    <segment id="14">O erro cometido em comemora&amp;ccedil</segment>
    <segment id="15">;&amp;otilde</segment>
    <segment id="16">;es anteriores</segment>
    <segment id="17">, como</segment>
    <segment id="18">como no bronze de Adriana Ara&amp;uacute</segment>
    <segment id="19">;jo em Londres-2012 e no ouro de Robson Concei&amp;ccedil</segment>
    <segment id="20">;&amp;atilde</segment>
    <segment id="21">;o no Rio-2016</segment>
    <segment id="22">, n&amp;atilde</segment>
    <segment id="23">;o sese repetiu.</segment>
    <segment id="24">&amp;ldquo</segment>
    <segment id="25">;N&amp;atilde</segment>
    <segment id="26">;o muda</segment>
    <segment id="27">, meu amigo.</segment>
    <segment id="28">N&amp;atilde</segment>
    <segment id="29">;o muda&amp;rdquo</segment>
    <segment id="30">;, resume</segment>
    <segment id="31">, sem a expectativa de que o &amp;</segment>
    <segment id="32">oacute</segment>
    <segment id="33">;timo desempenho dos pugilistas brasileiros no Jap&amp;atilde</segment>
    <segment id="34">;o possa atrair investimentos.</segment>
    <segment id="35">Hebert venceu entre os m&amp;eacute</segment>
    <segment id="36">;dios, Bia Ferreira foi prata na categoria leve</segment>
    <segment id="37">, e o peso-pesado Abner Teixeira levou o bronze</segment>
    <segment id="38">, masmas as conquistas</segment>
    <segment id="39">, para D&amp;oacute</segment>
    <segment id="40">;rea, n&amp;atilde</segment>
    <segment id="41">;o foram acompanhadas de esperan&amp;ccedil</segment>
    <segment id="42">;a.</segment>
    <segment id="43">Atleta da academia Champions</segment>
    <segment id="44">, de onde saíram três medalhistas olímpicos do boxe brasileiro - Marcio Pimenta/FolhapressMotivos para a descren&amp;ccedil</segment>
    <segment id="45">;a n&amp;atilde</segment>
    <segment id="46">;o lhe faltam.</segment>
    <segment id="47">Ele fundou a academia Champion h&amp;aacute</segment>
    <segment id="48">; 31 anos e s&amp;oacute</segment>
    <segment id="49">;</segment>
    <segment id="50">em um deles teve patroc&amp;iacute</segment>
    <segment id="51">;nio para o projeto Campe&amp;otilde</segment>
    <segment id="52">;es da Vida.</segment>
    <segment id="53">Mesmo com o sucesso de grandes nomes que passaram por sua academia</segment>
    <segment id="54">, como</segment>
    <segment id="55">como Pop&amp;oacute</segment>
    <segment id="56">;, Rodrigo Minotauro</segment>
    <segment id="57">, Rog&amp;eacute</segment>
    <segment id="58">;rio Minotouro</segment>
    <segment id="59">, Anderson Silva</segment>
    <segment id="60">, J&amp;uacute</segment>
    <segment id="61">;nior Cigano &amp;ndash</segment>
    <segment id="62">;al&amp;eacute</segment>
    <segment id="63">;m dos medalhistas Adriana</segment>
    <segment id="64">, Robson e Hebert&amp;ndash</segment>
    <segment id="65">;, o esperado apoio n&amp;atilde</segment>
    <segment id="66">;o sese materializou.</segment>
    <segment id="67">O jeito para ex-boxeador &amp;eacute</segment>
    <segment id="68">; contar com a ajuda da fam&amp;iacute</segment>
    <segment id="69">;lia.</segment>
    <segment id="70">Trabalham na Champion seu filho</segment>
    <segment id="71">, D&amp;oacute</segment>
    <segment id="72">;rea J&amp;uacute</segment>
    <segment id="73">;nior, sua filha</segment>
    <segment id="74">, Laila</segment>
    <segment id="75">, e seu genro</segment>
    <segment id="76">, Andr&amp;eacute</segment>
    <segment id="77">;</segment>
    <segment id="78">Le&amp;atilde</segment>
    <segment id="79">;o.</segment>
    <segment id="80">S&amp;atilde</segment>
    <segment id="81">;o eles que est&amp;atilde</segment>
    <segment id="82">;o cuidando do espa&amp;ccedil</segment>
    <segment id="83">;o enquanto Luiz est&amp;aacute</segment>
    <segment id="84">;</segment>
    <segment id="85">nos Estados Unidos treinando Robson Concei&amp;ccedil</segment>
    <segment id="86">;&amp;atilde</segment>
    <segment id="87">;o e Anderson Silva</segment>
    <segment id="88">, que t&amp;ecirc</segment>
    <segment id="89">;m combates em territ&amp;oacute</segment>
    <segment id="90">;rio norte-americano no m&amp;ecirc</segment>
    <segment id="91">;s que vem.</segment>
    <segment id="92">&amp;ldquo</segment>
    <segment id="93">;Ele teve pouco apoio durante a carreira de lutador</segment>
    <segment id="94">, e a academia n&amp;atilde</segment>
    <segment id="95">;o tem at&amp;eacute</segment>
    <segment id="96">; hoje.</segment>
    <segment id="97">&amp;Eacute</segment>
    <segment id="98">; dif&amp;iacute</segment>
    <segment id="99">;cil, mas</segment>
    <segment id="100">mas perseveramos&amp;rdquo</segment>
    <segment id="101">;, diz a mulher de D&amp;oacute</segment>
    <segment id="102">;rea, Rosangela.</segment>
    <segment id="103">O treinador</segment>
    <segment id="104">, apesar de ver o esfor&amp;ccedil</segment>
    <segment id="105">;o recompensado em p&amp;oacute</segment>
    <segment id="106">;dios ol&amp;iacute</segment>
    <segment id="107">;mpicos e em t&amp;iacute</segment>
    <segment id="108">;tulos importantes</segment>
    <segment id="109">, afirma estar financeiramente &amp;ldquo</segment>
    <segment id="110">;no limite&amp;rdquo</segment>
    <segment id="111">;.</segment>
    <segment id="112">Nesta entrevista &amp;agrave</segment>
    <segment id="113">;</segment>
    <segment id="114">Folha, ele recorda os triunfos</segment>
    <segment id="115">, os subsequentes &amp;quot</segment>
    <segment id="116">;tapinhas no ombro&amp;quot</segment>
    <segment id="117">; e explica por que</segment>
    <segment id="118">, mesmo diante de resultados t&amp;atilde</segment>
    <segment id="119">;o satisfat&amp;oacute</segment>
    <segment id="120">;rios, n&amp;atilde</segment>
    <segment id="121">;o est&amp;aacute</segment>
    <segment id="122">; otimista.</segment>
    <segment id="123">Dórea já não tem maiores ilusões sobre o investimento no boxe - Divulgação  O que faz o seu projeto formar tantos atletas?</segment>
    <segment id="124">Conseguimos uma evolu&amp;ccedil</segment>
    <segment id="125">;&amp;atilde</segment>
    <segment id="126">;o r&amp;aacute</segment>
    <segment id="127">;pida nos atletas</segment>
    <segment id="128">, com uma metodologia de treino diferenciada.</segment>
    <segment id="129">&amp;Eacute</segment>
    <segment id="130">; um trip&amp;eacute</segment>
    <segment id="131">; de alto rendimento: base</segment>
    <segment id="132">, metodologia e aptid&amp;atilde</segment>
    <segment id="133">;o do povo baiano.</segment>
    <segment id="134">Agora, perceba que esse trabalho &amp;eacute</segment>
    <segment id="135">;</segment>
    <segment id="136">corpo a corpo</segment>
    <segment id="137">, sem apoio.</segment>
    <segment id="138">S&amp;oacute</segment>
    <segment id="139">; tivemos um patroc&amp;iacute</segment>
    <segment id="140">;nio em 31 anos de projeto</segment>
    <segment id="141">, em 2012.</segment>
    <segment id="142">Trein&amp;aacute</segment>
    <segment id="143">;vamos 400 crian&amp;ccedil</segment>
    <segment id="144">;as, era aula o dia todo.</segment>
    <segment id="145">Hoje, temos 40.</segment>
    <segment id="146">Sabe quem come&amp;ccedil</segment>
    <segment id="147">;ou a treinar pr&amp;oacute</segment>
    <segment id="148">;ximo dali?</segment>
    <segment id="149">O Hebert</segment>
    <segment id="150">, hoje medalhista de ouro.</segment>
    <segment id="151">A falta de patroc&amp;iacute</segment>
    <segment id="152">;nio o desanima de alguma forma?</segment>
    <segment id="153">&amp;</segment>
    <segment id="154">Agrave</segment>
    <segment id="155">;s</segment>
    <segment id="156">vezes, recebo convites para vir morar aqui nos Estados Unidos e sei que seria melhor financeiramente</segment>
    <segment id="157">, masmas penso: &amp;quot</segment>
    <segment id="158">;Meu Deus</segment>
    <segment id="159">, o que vai ser desses garotos?&amp;quot</segment>
    <segment id="160">;.</segment>
    <segment id="161">Muita gente depende de mim.</segment>
    <segment id="162">As pessoas buscam a Champion pensando em mudar a vida</segment>
    <segment id="163">, e eu sei que posso mudar a vida de muita gente.</segment>
    <segment id="164">Os pais e as m&amp;atilde</segment>
    <segment id="165">;es levam os filhos com orgulho para l&amp;aacute</segment>
    <segment id="166">;.</segment>
    <segment id="167">Eu estou aqui treinando o Robson e o Anderson</segment>
    <segment id="168">, e o Andr&amp;eacute</segment>
    <segment id="169">;, meu genro</segment>
    <segment id="170">, est&amp;aacute</segment>
    <segment id="171">; segurando as coisas no Brasil para a gente n&amp;atilde</segment>
    <segment id="172">;o fechar.</segment>
    <segment id="173">Imagine o que n&amp;oacute</segment>
    <segment id="174">;s poder&amp;iacute</segment>
    <segment id="175">;amos fazer</segment>
    <segment id="176">sese tiv&amp;eacute</segment>
    <segment id="177">;ssemos apoio?</segment>
    <segment id="178">N&amp;atilde</segment>
    <segment id="179">;o tem governo</segment>
    <segment id="180">, prefeitura</segment>
    <segment id="181">, time de futebol</segment>
    <segment id="182">, empresa privada para chegar junto?</segment>
    <segment id="183">Espero que alguns dias as pessoas tenham essa sensibilidade de ajudar o esporte.</segment>
    <segment id="184">Eu sou o cara que mais andou de carro de bombeiro na Bahia</segment>
    <segment id="185">, de tantos t&amp;iacute</segment>
    <segment id="186">;tulos</segment>
    <segment id="187">, e recebi muita promessa</segment>
    <segment id="188">, muito tapinha no ombro</segment>
    <segment id="189">, masmas &amp;eacute</segment>
    <segment id="190">; s&amp;oacute</segment>
    <segment id="191">; isso.</segment>
    <segment id="192">Eu consigo bancar o meu projeto</segment>
    <segment id="193">, com meu s&amp;oacute</segment>
    <segment id="194">;cio, meus filhos</segment>
    <segment id="195">, porque</segment>
    <segment id="196">porque eu treino o pessoal aqui.</segment>
    <segment id="197">Estou no meu limite</segment>
    <segment id="198">, n&amp;atilde</segment>
    <segment id="199">;o tenho condi&amp;ccedil</segment>
    <segment id="200">;&amp;otilde</segment>
    <segment id="201">;es de manter com o funcionamento que gostaria.</segment>
    <segment id="202">Fico sentido</segment>
    <segment id="203">porque</segment>
    <segment id="204">porque queria ter uma estrutura melhor para ofertar melhor para essas pessoas que buscam a academia.</segment>
    <segment id="205">Eu sou o cara que mais andou de carro de bombeiro na Bahia</segment>
    <segment id="206">, de tantos títulos</segment>
    <segment id="207">, e recebi muita promessa</segment>
    <segment id="208">, muito tapinha no ombroLuiz Dóreatécnico de boxePor que o modelo da academia n&amp;atilde</segment>
    <segment id="209">;o &amp;eacute</segment>
    <segment id="210">; reproduzido pelo Brasil?</segment>
    <segment id="211">O boxe</segment>
    <segment id="212">, na maioria das vezes</segment>
    <segment id="213">, &amp;eacute</segment>
    <segment id="214">; procurado por pessoas que t&amp;ecirc</segment>
    <segment id="215">;m poucas condi&amp;ccedil</segment>
    <segment id="216">;&amp;otilde</segment>
    <segment id="217">;es, mas</segment>
    <segment id="218">mas &amp;eacute</segment>
    <segment id="219">; caro manter uma academia.</segment>
    <segment id="220">Eu mesmo s&amp;oacute</segment>
    <segment id="221">;</segment>
    <segment id="222">abro um hor&amp;aacute</segment>
    <segment id="223">;rio hoje em dia</segment>
    <segment id="224">, que &amp;eacute</segment>
    <segment id="225">; a manh&amp;atilde</segment>
    <segment id="226">;.</segment>
    <segment id="227">Veja quanto &amp;eacute</segment>
    <segment id="228">;</segment>
    <segment id="229">um saco de pancada</segment>
    <segment id="230">, as luvas</segment>
    <segment id="231">, a manuten&amp;ccedil</segment>
    <segment id="232">;&amp;atilde</segment>
    <segment id="233">;o.</segment>
    <segment id="234">Muitos treinadores abrem seus projetos e s&amp;oacute</segment>
    <segment id="235">; conseguem segurar por seis meses</segment>
    <segment id="236">, um ano</segment>
    <segment id="237">, dois anos</segment>
    <segment id="238">, masmas t&amp;ecirc</segment>
    <segment id="239">;m que fechar depois.</segment>
    <segment id="240">N&amp;atilde</segment>
    <segment id="241">;o d&amp;aacute</segment>
    <segment id="242">; para bancar tudo.</segment>
    <segment id="243">Eu tenho 42 anos dentro do esporte</segment>
    <segment id="244">, consegui todos os t&amp;iacute</segment>
    <segment id="245">;tulos.</segment>
    <segment id="246">Queria eu que tiv&amp;eacute</segment>
    <segment id="247">;ssemos um modelo</segment>
    <segment id="248">comocomo o projeto Campe&amp;otilde</segment>
    <segment id="249">;es da Vida em cada bairro da Bahia.</segment>
    <segment id="250">Aqui nos Estados Unidos</segment>
    <segment id="251">, ningu&amp;eacute</segment>
    <segment id="252">;m acredita que mantemos o projeto sem patroc&amp;iacute</segment>
    <segment id="253">;nio.</segment>
    <segment id="254">E eu sempre digo: &amp;quot</segment>
    <segment id="255">;Estamos aguardando h&amp;aacute</segment>
    <segment id="256">; 31</segment>
    <segment id="257">anos&amp;quot</segment>
    <segment id="258">;.</segment>
    <segment id="259">A minha luta &amp;eacute</segment>
    <segment id="260">; para que</segment>
    <segment id="261">para que os atletas tenham alimenta&amp;ccedil</segment>
    <segment id="262">;&amp;atilde</segment>
    <segment id="263">;o, uma bolsa para</segment>
    <segment id="264">sese manter</segment>
    <segment id="265">, que tenham condi&amp;ccedil</segment>
    <segment id="266">;&amp;otilde</segment>
    <segment id="267">;es de viajar</segment>
    <segment id="268">, de competir.  Academia Champion</segment>
    <segment id="269">, em Salvador (BA)</segment>
    <segment id="270">, já formou 3 medalhistas   novamente         de   de  de  representando um  Como surgiu o projeto?</segment>
    <segment id="271">Na minha melhor &amp;eacute</segment>
    <segment id="272">;poca enquanto lutador</segment>
    <segment id="273">, eu tive um t&amp;eacute</segment>
    <segment id="274">;cnico e um patrocinador</segment>
    <segment id="275">, fui campe&amp;atilde</segment>
    <segment id="276">;o mundial de boxe profissional j&amp;uacute</segment>
    <segment id="277">;nior em 1988.</segment>
    <segment id="278">Infelizmente</segment>
    <segment id="279">, os dois faleceram em &amp;eacute</segment>
    <segment id="280">;pocas parecidas</segment>
    <segment id="281">, e eu fiquei quase sozinho.</segment>
    <segment id="282">Na parte de tr&amp;aacute</segment>
    <segment id="283">;s da minha casa</segment>
    <segment id="284">, havia um galp&amp;atilde</segment>
    <segment id="285">;o, e chamei o Lu&amp;iacute</segment>
    <segment id="286">;s Carlos Freitas</segment>
    <segment id="287">, irm&amp;atilde</segment>
    <segment id="288">;o de Pop&amp;oacute</segment>
    <segment id="289">;, para treinar l&amp;aacute</segment>
    <segment id="290">;.</segment>
    <segment id="291">Era 1990</segment>
    <segment id="292">, e muita gente veio treinar com a gente.</segment>
    <segment id="293">Eu virei treinador</segment>
    <segment id="294">, porque</segment>
    <segment id="295">porque eu era sparring deles.</segment>
    <segment id="296">N&amp;oacute</segment>
    <segment id="297">;s inauguramos a academia em 7 de mar&amp;ccedil</segment>
    <segment id="298">;o de 1990 e dois anos depois j&amp;aacute</segment>
    <segment id="299">;</segment>
    <segment id="300">t&amp;iacute</segment>
    <segment id="301">;nhamos o Lu&amp;iacute</segment>
    <segment id="302">;s Carlos nos Jogos Ol&amp;iacute</segment>
    <segment id="303">;mpicos.</segment>
    <segment id="304">Da&amp;iacute</segment>
    <segment id="305">; veio o Pop&amp;oacute</segment>
    <segment id="306">;, com todos os t&amp;iacute</segment>
    <segment id="307">;tulos dele</segment>
    <segment id="308">, Minotauro</segment>
    <segment id="309">, Minotouro</segment>
    <segment id="310">, Anderson Silva</segment>
    <segment id="311">, J&amp;uacute</segment>
    <segment id="312">;nior Cigano...</segment>
    <segment id="313">A primeira medalha ol&amp;iacute</segment>
    <segment id="314">;mpica no boxe feminino foi nossa</segment>
    <segment id="315">, com a Adriana</segment>
    <segment id="316">, depois dois ouros</segment>
    <segment id="317">, com o Robson e o Hebert.</segment>
    <segment id="318">Eu sinto</segment>
    <segment id="319">comocomo</segment>
    <segment id="320">sese toda conquista fosse nova</segment>
    <segment id="321">, a alegria &amp;eacute</segment>
    <segment id="322">; a mesma</segment>
    <segment id="323">, masmas a verdade &amp;eacute</segment>
    <segment id="324">; que j&amp;aacute</segment>
    <segment id="325">; ganhamos tudo.</segment>
    <segment id="326">Para lhe falar a verdade</segment>
    <segment id="327">, as cr&amp;iacute</segment>
    <segment id="328">;ticas que eu fa&amp;ccedil</segment>
    <segment id="329">;o nesta nossa conversa eu j&amp;aacute</segment>
    <segment id="330">; fiz em toda entrevista que eu dou depois de um t&amp;iacute</segment>
    <segment id="331">;tulo.</segment>
    <segment id="332">S&amp;atilde</segment>
    <segment id="333">;o 14 atletas ol&amp;iacute</segment>
    <segment id="334">;mpicos</segment>
    <segment id="335">, 8.000 crian&amp;ccedil</segment>
    <segment id="336">;as, e eu fico pensando: &amp;quot</segment>
    <segment id="337">;Agora vai mudar</segment>
    <segment id="338">, agora vai mudar&amp;quot</segment>
    <segment id="339">;.</segment>
    <segment id="340">Em 2007</segment>
    <segment id="341">, com o Pedro Lima</segment>
    <segment id="342">, no Pan do Rio</segment>
    <segment id="343">, a gente teve um ouro depois de 44 anos</segment>
    <segment id="344">, e eu disse a ele: &amp;quot</segment>
    <segment id="345">;Peu, esse ouro seu vem depois de 44 anos</segment>
    <segment id="346">, agora as coisas v&amp;atilde</segment>
    <segment id="347">;o mudar&amp;quot</segment>
    <segment id="348">;.</segment>
    <segment id="349">N&amp;atilde</segment>
    <segment id="350">;o muda</segment>
    <segment id="351">, meu amigo</segment>
    <segment id="352">, n&amp;atilde</segment>
    <segment id="353">;o muda.</segment>
    <segment id="354">Falta sensibilidade.</segment>
    <segment id="355">Hebert Conceição conquista o 2º ouro olímpico do boxe brasileiro   novamente         de   de  de  representando um  ​Faz tempo que voc&amp;ecirc</segment>
    <segment id="356">; sese tornou descrente nessa mudan&amp;ccedil</segment>
    <segment id="357">;a?</segment>
    <segment id="358">Em 2018</segment>
    <segment id="359">, fui chamado para um projeto em Madre de Deus</segment>
    <segment id="360">, uma cidade com cerca de 20 mil habitantes.</segment>
    <segment id="361">Foi uma coisa da prefeitura</segment>
    <segment id="362">, da secretaria de esportes.</segment>
    <segment id="363">A ideia era termos v&amp;aacute</segment>
    <segment id="364">;rios esportes</segment>
    <segment id="365">, com os alunos entrando &amp;agrave</segment>
    <segment id="366">;s 7h e saindo &amp;agrave</segment>
    <segment id="367">;s 17h.</segment>
    <segment id="368">O esporte era mat&amp;eacute</segment>
    <segment id="369">;ria obrigat&amp;oacute</segment>
    <segment id="370">;ria dos alunos.</segment>
    <segment id="371">Em dois anos que trabalhei l&amp;aacute</segment>
    <segment id="372">;, quase zeramos a evas&amp;atilde</segment>
    <segment id="373">;o escolar</segment>
    <segment id="374">, a criminalidade diminuiu</segment>
    <segment id="375">, especialmente em homic&amp;iacute</segment>
    <segment id="376">;dio e tentativas.</segment>
    <segment id="377">Havia toda a estrutura que voc&amp;ecirc</segment>
    <segment id="378">; puder imaginar.</segment>
    <segment id="379">Fui coordenador t&amp;eacute</segment>
    <segment id="380">;cnico do boxe</segment>
    <segment id="381">, formamos atletas e colocamos atletas em campeonatos estaduais</segment>
    <segment id="382">, nacionais.</segment>
    <segment id="383">Estimul&amp;aacute</segment>
    <segment id="384">;vamos os meninos.</segment>
    <segment id="385">Foi um grande exemplo para o Brasil</segment>
    <segment id="386">, sa&amp;iacute</segment>
    <segment id="387">;mos at&amp;eacute</segment>
    <segment id="388">; no Caldeir&amp;atilde</segment>
    <segment id="389">;o do Huck.</segment>
    <segment id="390">E, com todo esse exemplo da cidade</segment>
    <segment id="391">, n&amp;atilde</segment>
    <segment id="392">;o mudou nada.</segment>
    <segment id="393">A pr&amp;oacute</segment>
    <segment id="394">;pria Salvador n&amp;atilde</segment>
    <segment id="395">;o seguiu essa linha</segment>
    <segment id="396">, a cem quil&amp;ocirc</segment>
    <segment id="397">;metros de dist&amp;acirc</segment>
    <segment id="398">;ncia.</segment>
    <segment id="399">Era um sonho meu</segment>
    <segment id="400">, que o esporte e a educa&amp;ccedil</segment>
    <segment id="401">;&amp;atilde</segment>
    <segment id="402">;o caminhassem juntos.</segment>
  </rst>
