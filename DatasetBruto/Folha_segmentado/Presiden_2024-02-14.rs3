  <rst>
    <segment id="1">O presidente nacional do PSB</segment>
    <segment id="2">, Carlos Siqueira</segment>
    <segment id="3">, tem usado uma imagem da estrela de Davi</segment>
    <segment id="4">, símbolo judeu</segment>
    <segment id="5">, em seu perfil no aplicativo de mensagens WhatsApp.</segment>
    <segment id="6">O presidente do PSB Carlos Siqueira</segment>
    <segment id="7">, em sua sala na sede do partido - Gabriela Biló/FolhapressO objetivo é sinalizar apoio a Israel</segment>
    <segment id="8">, após o ataque do grupo terrorista palestino Hamas em outubro do ano passado</segment>
    <segment id="9">, quando cerca de 1.200 pessoas foram assassinadas e 200</segment>
    <segment id="10">, sequestradas.</segment>
    <segment id="11">Segundo Siqueira</segment>
    <segment id="12">, sua posição pró-Israel é pessoal e não partidária.</segment>
    <segment id="13">"</segment>
    <segment id="14">Sou contra o terrorismo de que Israel foi vítima e lamento profundamente as circunstâncias que obrigaram à sua reação"</segment>
    <segment id="15">, diz Siqueira</segment>
    <segment id="16">, em referência ao ataques na faixa de Gaza.</segment>
    <segment id="17">O dirigente afirma que</segment>
    <segment id="18">, apesar disso</segment>
    <segment id="19">, não é contrário aos palestinos.</segment>
    <segment id="20">"</segment>
    <segment id="21">Sempre fui um admirador de líderes israelenses que buscaram a paz com os palestinos</segment>
    <segment id="22">, como</segment>
    <segment id="23">como [os ex-primeiros-ministros] David Ben-Gurion</segment>
    <segment id="24">, Yitzhak Rabin e Shimon Peres".</segment>
    <segment id="25">"</segment>
    <segment id="26">Minha solidariedade com Israel é antiga</segment>
    <segment id="27">, em defesa de existir</segment>
    <segment id="28">comocomo um Estado em paz.</segment>
    <segment id="29">E quero deixar claro que não</segment>
    <segment id="30">sese trata de uma defesa minha do atual governo israelense"</segment>
    <segment id="31">, afirma.</segment>
    <segment id="32">A posição do dirigente socialista destoa de outros líderes de partidos de esquerda</segment>
    <segment id="33">, como</segment>
    <segment id="34">como PT e PSOL</segment>
    <segment id="35">, que tendem a uma atitude pró-palestinos.</segment>
    <segment id="36">Siqueira nega que o uso do símbolo judaico tenha</segment>
    <segment id="37">comocomo objetivo mandar algum tipo de recado às outras legendas sobre o tema.</segment>
  </rst>
