  <rst>
    <segment id="1">Luis Miranda deu um tempo ao Zorra para reviver Madame Sheila</segment>
    <segment id="2">, divertida personagem da peça “Cinco Vezes Comédia”</segment>
    <segment id="3">, em um espetáculo criado especialmente para o contexto da pandemia.</segment>
    <segment id="4">“Ela passa a enxergar o exército de pessoas que eram invisíveis para ela</segment>
    <segment id="5">, como</segment>
    <segment id="6">como os seus empregados ou os porteiros”</segment>
    <segment id="7">, disse o ator em entrevista online</segment>
    <segment id="8">, assim</segment>
    <segment id="9">comocomo a nova produção.</segment>
    <segment id="10">Interessado em focar seu trabalho em um humor que seja socialmente útil</segment>
    <segment id="11">, Miranda está dispensando a piada sem relevância ou ser apenas um sujeito engraçado.</segment>
    <segment id="12">Sob direção de Monique Gardenberg</segment>
    <segment id="13">, com cenário de Daniela Thomas</segment>
    <segment id="14">, Madame Sheila surgirá online todas as quintas-feiras de outubro e novembro</segment>
    <segment id="15">, a partir desta semana</segment>
    <segment id="16">, sempre às 21h.</segment>
    <segment id="17">A cada semana</segment>
    <segment id="18">, irá ao ar um ato de até oito minutos de duração.</segment>
    <segment id="19">O último será apresentado no dia 19 de novembro.</segment>
    <segment id="20">Os oito atos da peça poderão ser vistos no site do Teatro Unimed até 26 de novembro. .</segment>
    <segment id="21">As exibições serão online e gratuitas</segment>
    <segment id="22">, pelo site www.teatrounimed.com.br.</segment>
    <segment id="23">É PIQUE!  Irmão de Guta Stresser por 14 anos na ficção de “</segment>
    <segment id="24">A Grande Família” (Globo)</segment>
    <segment id="25">, Lúcio Mauro Filho parabenizou a atriz pelos 48 anos:</segment>
    <segment id="26">“</segment>
    <segment id="27">Aniversário da minha maninha Guta Stresser</segment>
    <segment id="28">, um pé de coelho na minha vida</segment>
    <segment id="29">, aquele típico encontro que já tava escrito”</segment>
    <segment id="30">, escreveu o ator na rede social Instagram.</segment>
    <segment id="31">REFLEXÕES PROFUNDAS</segment>
    <segment id="32">Em longa entrevista à revista Marie Claire</segment>
    <segment id="33">, Cássia Kis</segment>
    <segment id="34">, 62 anos</segment>
    <segment id="35">, relatou que sofreu abusos sexuais de um dentista</segment>
    <segment id="36">, aos 11 anos.</segment>
    <segment id="37">Mãe de quatro filhos</segment>
    <segment id="38">, a atriz fala ainda sobre o arrependimento que carrega por um aborto a que</segment>
    <segment id="39">sese submeteu em 1985.</segment>
    <segment id="40">“Por mais que eu tenha pedido perdão</segment>
    <segment id="41">, lamentado</segment>
    <segment id="42">, à vezes faço as contas de quantos anos esse filho teria</segment>
    <segment id="43">, sese eu seria avó”</segment>
    <segment id="44">, disse Cássia.</segment>
    <segment id="45">DOSE DUPLA</segment>
    <segment id="46">TODA NOITE  Ela está à vontade em casa</segment>
    <segment id="47">, com toda razão.</segment>
    <segment id="48">Com a volta de “</segment>
    <segment id="49">A Força do Querer</segment>
    <segment id="50">”</segment>
    <segment id="51">à vaga da novela das nove</segment>
    <segment id="52">, Juliana Paes</segment>
    <segment id="53">, 41 anos</segment>
    <segment id="54">, está no ar em dose dupla: na trama das 19h35</segment>
    <segment id="55">, ligeiramente má</segment>
    <segment id="56">, e na das 21h10</segment>
    <segment id="57">, em tom de heroína</segment>
    <segment id="58">, dominando a faixa nobre da Globo.</segment>
    <segment id="59">Só falta ela aparecer no Jornal Nacional.</segment>
    <segment id="60">A situação será esta até 11 de outubro</segment>
    <segment id="61">, quando vai ao ar o último capítulo da bem-sucedida reprise de “Totalmente Demais”</segment>
    <segment id="62">, folhetim de Rosane Svartman e Paul Halm</segment>
    <segment id="63">, que tem rendido mais audiência que o enredo de Glória Perez.</segment>
    <segment id="64">Sobre Bibi Perigosa</segment>
    <segment id="65">, a personagem que acaba de voltar à tela</segment>
    <segment id="66">, a atriz acredita que sua força é atemporal e ela “sempre será atual</segment>
    <segment id="67">, porque</segment>
    <segment id="68">porque o comportamento dela</segment>
    <segment id="69">, sempre explosivo</segment>
    <segment id="70">, sem medir consequência</segment>
    <segment id="71">, sempre será perigoso”</segment>
    <segment id="72">, diz.</segment>
    <segment id="73">“É emocionalmente perigoso”</segment>
    <segment id="74">As gatas de setembroMais    novamente         de   de  de  representando um  NOVO CEP  Acidentado em 2013</segment>
    <segment id="75">, o heptacampeão da Fórmula 1 Michael Schumacher teria sido transferido da Suíça para uma mansão na ilha espanhola de Maiorca</segment>
    <segment id="76">, onde seguiria seu tratamento.</segment>
    <segment id="77">Corinna Schumacher adquiriu a propriedade por R$ 196</segment>
    <segment id="78">,8 milhões de Florentino Perez</segment>
    <segment id="79">, ex-presidente do Real Madrid.  CARTAZ  Filha de Bruce Willis e Demi Moore</segment>
    <segment id="80">, Rumer Willis</segment>
    <segment id="81">, 32 anos</segment>
    <segment id="82">, posou em ousado ensaio no Instagram</segment>
    <segment id="83">, obra realizada em parceria com o famoso fotógrafo Tyler Shields.</segment>
    <segment id="84">Atriz, ela pede o fim do “policiamento dos corpos das mulheres” e o direito de elas fazerem suas escolhas.</segment>
    <segment id="85">Rumer Willis</segment>
    <segment id="86">, atriz</segment>
    <segment id="87">, filha de demi Moore e Bruce Willis em ensaio feito por Tyler Shields - Tyler Shields/@rumerWillis no Instagram</segment>
  </rst>
</analysis>