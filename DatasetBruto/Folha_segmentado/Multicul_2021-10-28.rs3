    <segment id="374">;o e seus valores</segment>
    <segment id="375">, que se</segment>
    <segment id="376">se resumem a liberdade</segment>
    <segment id="377">, igualdade e fraternidade.</segment>
    <segment id="378">Esses valores s&amp;atilde</segment>
    <segment id="379">;o extremistas?</segment>
    <segment id="380">Penso que n&amp;atilde</segment>
    <segment id="381">;o.</segment>
    <segment id="382">Quando a Fran&amp;ccedil</segment>
    <segment id="383">;a era forte</segment>
    <segment id="384">, o mundo inteiro nos invejava por esses valores.</segment>
    <segment id="385">O pr&amp;oacute</segment>
    <segment id="386">;prio Brasil</segment>
    <segment id="387">sese inspirou neles no s&amp;eacute</segment>
    <segment id="388">;culo 19</segment>
    <segment id="389">, por meio do movimento positivista.</segment>
    <segment id="390">Muitos im&amp;oacute</segment>
    <segment id="391">;veis de luxo no Brasil ostentam um nome franc&amp;ecirc</segment>
    <segment id="392">;s, segundo me foi dito.</segment>
    <segment id="393">Desejo para os &amp;aacute</segment>
    <segment id="394">;rabes da Fran&amp;ccedil</segment>
    <segment id="395">;a o mesmo destino que tiveram os s&amp;iacute</segment>
    <segment id="396">;rios e os libaneses que</segment>
    <segment id="397">sese assimilaram admiravelmente &amp;agrave</segment>
    <segment id="398">;</segment>
    <segment id="399">civiliza&amp;ccedil</segment>
    <segment id="400">;&amp;atilde</segment>
    <segment id="401">;o de seu belo pa&amp;iacute</segment>
    <segment id="402">;s [Brasil].</segment>
    <segment id="403">Os &amp;aacute</segment>
    <segment id="404">;rabes do Brasil s&amp;atilde</segment>
    <segment id="405">;o aut&amp;ecirc</segment>
    <segment id="406">;nticos brasileiros.</segment>
    <segment id="407">Gostaria que os &amp;aacute</segment>
    <segment id="408">;rabes da Fran&amp;ccedil</segment>
    <segment id="409">;a sese tornassem aut&amp;ecirc</segment>
    <segment id="410">;nticos franceses.</segment>
    <segment id="411">Como jornalista</segment>
    <segment id="412">, o sr. defende limites &amp;agrave</segment>
    <segment id="413">; liberdade de express&amp;atilde</segment>
    <segment id="414">;o nas redes sociais?</segment>
    <segment id="415">Fico chocado ao ver quantos jornalistas</segment>
    <segment id="416">, na Fran&amp;ccedil</segment>
    <segment id="417">;a e no Brasil</segment>
    <segment id="418">, defendem a censura!</segment>
    <segment id="419">Que invers&amp;atilde</segment>
    <segment id="420">;o de valores!</segment>
    <segment id="421">Acredito na democracia e na liberdade de express&amp;atilde</segment>
    <segment id="422">;o.</segment>
    <segment id="423">&amp;Eacute</segment>
    <segment id="424">;</segment>
    <segment id="425">claro que n&amp;atilde</segment>
    <segment id="426">;o sese pode dizer qualquer coisa &amp;ndash</segment>
    <segment id="427">;as leis referentes a insulto</segment>
    <segment id="428">, cal&amp;uacute</segment>
    <segment id="429">;nia e difama&amp;ccedil</segment>
    <segment id="430">;&amp;atilde</segment>
    <segment id="431">;o existem para isso.</segment>
    <segment id="432">No fundo</segment>
    <segment id="433">, o que est&amp;aacute</segment>
    <segment id="434">; em jogo hoje &amp;eacute</segment>
    <segment id="435">; a interdi&amp;ccedil</segment>
    <segment id="436">;&amp;atilde</segment>
    <segment id="437">;o de toda diversidade de opini&amp;otilde</segment>
    <segment id="438">;es e ideias.</segment>
    <segment id="439">Sou a favor da verdadeira diversidade: a diversidade dos pontos de vista e das sensibilidades.</segment>
    <segment id="440">O sr. ser&amp;aacute</segment>
    <segment id="441">; candidato na elei&amp;ccedil</segment>
    <segment id="442">;&amp;atilde</segment>
    <segment id="443">;o presidencial?</segment>
    <segment id="444">E qual &amp;eacute</segment>
    <segment id="445">; a sua opini&amp;atilde</segment>
    <segment id="446">;o sobre o presidente Macron?</segment>
    <segment id="447">N&amp;atilde</segment>
    <segment id="448">;o sou candidato.</segment>
    <segment id="449">Eu observo e reflito.</segment>
    <segment id="450">Tomarei minha decis&amp;atilde</segment>
    <segment id="451">;o na hora certa.</segment>
    <segment id="452">Macron &amp;eacute</segment>
    <segment id="453">; prisioneiro de seus dogmas: o europe&amp;iacute</segment>
    <segment id="454">;smo e o globalismo.</segment>
    <segment id="455">Ele est&amp;aacute</segment>
    <segment id="456">; alinhado &amp;agrave</segment>
    <segment id="457">; casta pol&amp;iacute</segment>
    <segment id="458">;tica que h&amp;aacute</segment>
    <segment id="459">; 30 anos luta para destruir a Fran&amp;ccedil</segment>
    <segment id="460">;a.</segment>
    <segment id="461">Eleito para reformar o pa&amp;iacute</segment>
    <segment id="462">;s e convert&amp;ecirc</segment>
    <segment id="463">;-lo em uma &amp;quot</segment>
    <segment id="464">;na&amp;ccedil</segment>
    <segment id="465">;&amp;atilde</segment>
    <segment id="466">;o start-up&amp;quot</segment>
    <segment id="467">;, acabou n&amp;atilde</segment>
    <segment id="468">;o fazendo nada e provocou a ira de meus compatriotas</segment>
    <segment id="469">, revelada na crise dos coletes amarelos.</segment>
    <segment id="470">A Fran&amp;ccedil</segment>
    <segment id="471">;a, que no passado era vista</segment>
    <segment id="472">comocomo um reduto de paz</segment>
    <segment id="473">, onde</segment>
    <segment id="474">sese vivia bem</segment>
    <segment id="475">, converteu-</segment>
    <segment id="476">sese num lugar violento onde</segment>
    <segment id="477">sese decapitam professores e onde as mulheres t&amp;ecirc</segment>
    <segment id="478">;m medo de sair &amp;agrave</segment>
    <segment id="479">; noite.</segment>
    <segment id="480">Um ano da revolta dos coletes amarelosMais    novamente         de   de  de  representando um  O que o sr. pensa da tentativa de Marine Le Pen de</segment>
    <segment id="481">sese posicionar</segment>
    <segment id="482">comocomo uma voz mais moderada no campo da direita?</segment>
    <segment id="483">N&amp;atilde</segment>
    <segment id="484">;o tenho nada contra Marine Le Pen.</segment>
    <segment id="485">Eu a acho corajosa</segment>
    <segment id="486">, valente.</segment>
    <segment id="487">O problema &amp;eacute</segment>
    <segment id="488">; que ela n&amp;atilde</segment>
    <segment id="489">;o consegue ganhar.</segment>
    <segment id="490">Todos que a cercam t&amp;ecirc</segment>
    <segment id="491">;m consci&amp;ecirc</segment>
    <segment id="492">;ncia disso</segment>
    <segment id="493">, e estou convencido de que ela pr&amp;oacute</segment>
    <segment id="494">;pria sabe disso.</segment>
    <segment id="495">Sobretudo</segment>
    <segment id="496">, Emmanuel Macron sabe disso</segment>
    <segment id="497">, e &amp;eacute</segment>
    <segment id="498">; exatamente por isso que ele tanto sonha em reproduzir um duelo que n&amp;atilde</segment>
    <segment id="499">;o teria</segment>
    <segment id="500">comocomo perder.</segment>
    <segment id="501">E o que pensa do movimento dos coletes amarelos?</segment>
    <segment id="502">Qual &amp;eacute</segment>
    <segment id="503">; a mensagem deles &amp;agrave</segment>
    <segment id="504">; classe pol&amp;iacute</segment>
    <segment id="505">;tica francesa?</segment>
    <segment id="506">Os coletes amarelos expressaram o sofrimento das classes populares e m&amp;eacute</segment>
    <segment id="507">;dias, confrontadas com o espectro da precariza&amp;ccedil</segment>
    <segment id="508">;&amp;atilde</segment>
    <segment id="509">;o.</segment>
    <segment id="510">&amp;Eacute</segment>
    <segment id="511">; preciso imaginar a vida de um franc&amp;ecirc</segment>
    <segment id="512">;s obrigado a sair da periferia parisiense devido &amp;agrave</segment>
    <segment id="513">; imigra&amp;ccedil</segment>
    <segment id="514">;&amp;atilde</segment>
    <segment id="515">;o, que</segment>
    <segment id="516">sese v&amp;ecirc</segment>
    <segment id="517">;</segment>
    <segment id="518">longe dos centros das cidades e dos servi&amp;ccedil</segment>
    <segment id="519">;os p&amp;uacute</segment>
    <segment id="520">;blicos</segment>
    <segment id="521">, que precisa usar seu carro para</segment>
    <segment id="522">sese locomover e descobre que o governo aumentou o imposto sobre o combust&amp;iacute</segment>
    <segment id="523">;vel.</segment>
    <segment id="524">Some-se</segment>
    <segment id="525">se a isso o fato de ele tamb&amp;eacute</segment>
    <segment id="526">;m ter que pagar pelos aux&amp;iacute</segment>
    <segment id="527">;lios de solidariedade que s&amp;atilde</segment>
    <segment id="528">;o distribu&amp;iacute</segment>
    <segment id="529">;dos sem controle</segment>
    <segment id="530">, inclusive a estrangeiros.</segment>
    <segment id="531">&amp;Eacute</segment>
    <segment id="532">; uma situa&amp;ccedil</segment>
    <segment id="533">;&amp;atilde</segment>
    <segment id="534">;o inaceit&amp;aacute</segment>
    <segment id="535">;vel.</segment>
    <segment id="536">O Brasil assiste a um retorno dos militares &amp;agrave</segment>
    <segment id="537">; pol&amp;iacute</segment>
    <segment id="538">;tica.</segment>
    <segment id="539">Tamb&amp;eacute</segment>
    <segment id="540">;m na Fran&amp;ccedil</segment>
    <segment id="541">;a os militares est&amp;atilde</segment>
    <segment id="542">;o mais presentes no debate.</segment>
    <segment id="543">O sr. cr&amp;ecirc</segment>
    <segment id="544">; que os militares t&amp;ecirc</segment>
    <segment id="545">;m um lugar a ocupar em um governo?</segment>
    <segment id="546">Se a esquerda [do Brasil] n&amp;atilde</segment>
    <segment id="547">;o tivesse saqueado a Petrobras</segment>
    <segment id="548">, sese Dilma [Rousseff] tivesse combatido a inseguran&amp;ccedil</segment>
    <segment id="549">;a terr&amp;iacute</segment>
    <segment id="550">;vel da qual sofrem os brasileiros</segment>
    <segment id="551">, [Jair] Bolsonaro jamais teria sido eleito e jamais poderia ter reinstalado oficiais militares no governo federal.</segment>
    <segment id="552">O retorno dos militares &amp;eacute</segment>
    <segment id="553">; culpa da esquerda.</segment>
    <segment id="554">Na Fran&amp;ccedil</segment>
    <segment id="555">;a, alguns oficiais escreveram uma carta aberta a Macron sobre a degrada&amp;ccedil</segment>
    <segment id="556">;&amp;atilde</segment>
    <segment id="557">;o da situa&amp;ccedil</segment>
    <segment id="558">;&amp;atilde</segment>
    <segment id="559">;o interna do pa&amp;iacute</segment>
    <segment id="560">;s.</segment>
    <segment id="561">Se Macron tivesse feito seu trabalho</segment>
    <segment id="562">, teriam permanecido em sil&amp;ecirc</segment>
    <segment id="563">;ncio.</segment>
    <segment id="564">Tirando isso</segment>
    <segment id="565">, os militares n&amp;atilde</segment>
    <segment id="566">;o est&amp;atilde</segment>
    <segment id="567">;o presentes na vida p&amp;uacute</segment>
    <segment id="568">;blica.</segment>
    <segment id="569">Dizem que o Ex&amp;eacute</segment>
    <segment id="570">;rcito franc&amp;ecirc</segment>
    <segment id="571">;s &amp;eacute</segment>
    <segment id="572">;</segment>
    <segment id="573">&amp;quot;o grande mudo&amp;quot</segment>
    <segment id="574">;, e a meu ver ele deve continuar assim.</segment>
    <segment id="575">O sr. considera Bolsonaro um aliado ideol&amp;oacute</segment>
    <segment id="576">;gico?</segment>
    <segment id="577">N&amp;atilde</segment>
    <segment id="578">;o cabe a mim avaliar um chefe de Estado estrangeiro.</segment>
    <segment id="579">O presidente brasileiro foi eleito por seu povo da maneira mais democr&amp;aacute</segment>
    <segment id="580">;tica poss&amp;iacute</segment>
    <segment id="581">;vel.</segment>
    <segment id="582">O presidente franc&amp;ecirc</segment>
    <segment id="583">;s deve trabalhar com todos seus colegas</segment>
    <segment id="584">, sem exce&amp;ccedil</segment>
    <segment id="585">;&amp;atilde</segment>
    <segment id="586">;o.</segment>
    <segment id="587">Raio-x  Eric Zemmour</segment>
    <segment id="588">, 63 Nascido em Montreuil</segment>
    <segment id="589">, na Fran&amp;ccedil</segment>
    <segment id="590">;a, &amp;eacute</segment>
    <segment id="591">; graduado em ci&amp;ecirc</segment>
    <segment id="592">;ncia pol&amp;iacute</segment>
    <segment id="593">;tica pela Sciences Po.</segment>
    <segment id="594">Trabalhou</segment>
    <segment id="595">comocomo jornalista no Le Quotidien de Paris (1986-96) e desde ent&amp;atilde</segment>
    <segment id="596">;o colabora com o Le Figaro.</segment>
    <segment id="597">&amp;Eacute</segment>
    <segment id="598">;, ainda</segment>
    <segment id="599">, autor de diversos livros</segment>
    <segment id="600">, entre biografias</segment>
    <segment id="601">, ensaios e obras de fic&amp;ccedil</segment>
    <segment id="602">;&amp;atilde</segment>
    <segment id="603">;o; seu &amp;uacute</segment>
    <segment id="604">;ltimo trabalho &amp;eacute</segment>
    <segment id="605">;</segment>
    <segment id="606">&amp;quot;La France N&amp;#39</segment>
    <segment id="607">;A</segment>
    <segment id="608">Pas Dit son Dernier Mot&amp;quot</segment>
    <segment id="609">; (a Fran&amp;ccedil</segment>
    <segment id="610">;a n&amp;atilde</segment>
