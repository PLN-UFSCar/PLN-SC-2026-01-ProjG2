  <rst>
    <segment id="1">A polícia de Liverpool</segment>
    <segment id="2">, no norte da Inglaterra</segment>
    <segment id="3">, declarou que a explosão de uma bomba em um táxi neste domingo (14) está sendo investigada</segment>
    <segment id="4">comocomo um ato terrorista</segment>
    <segment id="5">, embora</segment>
    <segment id="6">embora a motivação do ataque ainda não esteja clara.</segment>
    <segment id="7">Uma bomba carregada por um passageiro envolveu o veículo em chamas do lado de fora de um hospital da cidade inglesa</segment>
    <segment id="8">, pouco antes de uma cerimônia religiosa por ocasião do Dia da Memória</segment>
    <segment id="9">, quando o país homenageia os mortos na guerra.</segment>
    <segment id="10">Único a morrer na explosão</segment>
    <segment id="11">, o passageiro foi identificado pela polícia</segment>
    <segment id="12">comocomo Emad Al Swealmeen</segment>
    <segment id="13">, 32.</segment>
    <segment id="14">Segundo o detetive-chefe da Polícia de Grande Manchester</segment>
    <segment id="15">, Andrew Meeks</segment>
    <segment id="16">, ele está ligado a dois endereços onde buscas estão sendo realizadas.</segment>
    <segment id="17">Agentes inspecionam região que foi alvo de uma explosão agora considerada um ato terrorista em frente a um hospital em Liverpool</segment>
    <segment id="18">, no Reino Unido - Paul Ellis - 15.nov.21/AFP"Nossas investigações indicam que um dispositivo explosivo improvisado foi fabricado</segment>
    <segment id="19">, e nossa suposição até agora é que ele foi construído pelo passageiro do táxi" disse Russ Jackson</segment>
    <segment id="20">, chefe local da polícia antiterrorista.</segment>
    <segment id="21">Segundo Jackson</segment>
    <segment id="22">, ainda não há elementos que comprovem a conexão entre a explosão e o Dia da Memória</segment>
    <segment id="23">, masmas essa é uma hipótese que não foi descartada.</segment>
    <segment id="24">Quatro homens</segment>
    <segment id="25">, com idades entre 20 e 29 anos</segment>
    <segment id="26">, foram presos no domingo e nesta segunda-feira (15).</segment>
    <segment id="27">O motivo das detenções ainda não foi esclarecido</segment>
    <segment id="28">, masmas elas decorreram de uma série de buscas em vários endereços</segment>
    <segment id="29">, entre os quais Jackson afirmou que foram encontrados "itens significativos"</segment>
    <segment id="30">, sem dar detalhes.</segment>
    <segment id="31">Segundo a polícia</segment>
    <segment id="32">, o passageiro havia embarcado no táxi em um ponto de Liverpool que fica a dez minutos do hospital para onde ele pediu que fosse levado.</segment>
    <segment id="33">A explosão ocorreu dentro do carro quando o veículo</segment>
    <segment id="34">sese aproximava do ponto de desembarque em frente à unidade médica.</segment>
    <segment id="35">Lá foraReceba no seu email uma seleção semanal com o que de mais importante aconteceu no mundo</segment>
    <segment id="36">; aberta para não assinantes.</segment>
    <segment id="37">Carregando...</segment>
    <segment id="38">O motorista</segment>
    <segment id="39">, que ficou ferido</segment>
    <segment id="40">masmas conseguiu escapar do táxi em chamas</segment>
    <segment id="41">, recebeu tratamento médico e já teve alta.</segment>
    <segment id="42">Em entrevista à rádio britânica BBC</segment>
    <segment id="43">, a prefeita de Liverpool descreveu as ações do taxista —que não foi identificado—</segment>
    <segment id="44">comocomo heroicas.</segment>
    <segment id="45">Segundo Joanne Anderson</segment>
    <segment id="46">, ele conseguiu trancar o passageiro dentro do veículo antes da explosão.</segment>
    <segment id="47">"</segment>
    <segment id="48">O taxista</segment>
    <segment id="49">, em seus esforços heroicos</segment>
    <segment id="50">, conseguiu impedir o que poderia ter sido um desastre absolutamente terrível no hospital"</segment>
    <segment id="51">, disse a prefeita.</segment>
    <segment id="52">O primeiro-ministro do Reino Unido</segment>
    <segment id="53">, Boris Johnson</segment>
    <segment id="54">, também elogiou a "incrível presença de espírito e a bravura" do taxista.</segment>
    <segment id="55">O premiê anunciou ainda que o país elevou o nível de ameaça para severo</segment>
    <segment id="56">, o que significa que um ataque é tido</segment>
    <segment id="57">comocomo muito provável.</segment>
    <segment id="58">"</segment>
    <segment id="59">Não posso comentar os detalhes do</segment>
    <segment id="60">casocaso ou sua motivação</segment>
    <segment id="61">, masmas é um lembrete gritante da necessidade de todos nós permanecermos totalmente vigilantes"</segment>
    <segment id="62">, afirmou.</segment>
    <segment id="63">O ministro do Interior</segment>
    <segment id="64">, Priti Patel</segment>
    <segment id="65">, ressaltou que este é o segundo incidente fatal em um mês</segment>
    <segment id="66">, após o parlamentar conservador David Amess morrer esfaqueado</segment>
    <segment id="67">, em 15 de outubro.</segment>
    <segment id="68">Amess estava na Igreja Metodista de Belfairs</segment>
    <segment id="69">, sede escolhida para um encontro quinzenal entre os membros do Legislativo e seu eleitorado.</segment>
    <segment id="70">Uma placa na entrada da igreja diz</segment>
    <segment id="71">"todos são bem-vindos aqui: onde velhos amigos</segment>
    <segment id="72">sese encontram e estranhos</segment>
    <segment id="73">sese sentem em casa".</segment>
    <segment id="74">Testemunhas disseram que um homem com uma faca entrou no prédio e atacou o parlamentar</segment>
    <segment id="75">, sem motivação aparente.</segment>
    <segment id="76">O conservador chegou a receber cuidados médicos dentro da igreja</segment>
    <segment id="77">, masmas não resistiu aos ferimentos.</segment>
    <segment id="78">A Polícia Metropolitana informou que considerava o ataque um "incidente terrorista" e que a investigação coube à divisão especializada em terrorismo.</segment>
  </rst>
</analysis>