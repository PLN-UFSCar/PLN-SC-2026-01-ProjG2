  <rst>
    <segment id="1">Barcelona</segment>
    <segment id="2">, manhã do primeiro turno das eleições a princípios de outubro</segment>
    <segment id="3">, e uma pacífica fila dobrava o quarteirão</segment>
    <segment id="4">, serpenteando por amplas calçadas</segment>
    <segment id="5">, contornando pontos de ônibus.</segment>
    <segment id="6">A região da Plaça d'Espanya</segment>
    <segment id="7">, cartão-postal da cidade</segment>
    <segment id="8">, foi tomada por pontinhos vermelhos entremeados de bandeiras do Brasil e camisetas da seleção.</segment>
    <segment id="9">Na fila</segment>
    <segment id="10">, sol a pino de um princípio de outono</segment>
    <segment id="11">, mil papos desencontrados na nossa língua musical.</segment>
    <segment id="12">Os resenhistas:  -- Pô</segment>
    <segment id="13">, tá faltando alguém vendendo uma água ou uma coxinha</segment>
    <segment id="14">, néah! (em Madri</segment>
    <segment id="15">, segundo fontes</segment>
    <segment id="16">, tinha)</segment>
    <segment id="17">Os estereotipistas:  -- Brasileiro adora uma filinha!</segment>
    <segment id="18">Os agoniados</segment>
    <segment id="19">, com razão:  -- Fake news</segment>
    <segment id="20">, fake news</segment>
    <segment id="21">, bulos (que é</segment>
    <segment id="22">comocomo os españoles chamam as feiki níus)..!</segment>
    <segment id="23">Eu, que já moro na cidade há uns bons anos</segment>
    <segment id="24">, me surpreendi com a profusão de votantes nesse pleito de 2022 em comparação a 2018.</segment>
    <segment id="25">Outros amigos também tiveram a mesma impressão.</segment>
    <segment id="26">Mesmo assim</segment>
    <segment id="27">, fato é que somente metade dos 11 mil cidadãos aptos a votar na capital catalã compareceram nesse primeiro turno.</segment>
    <segment id="28">A expectativa é que o segundo turno seja mais concorrido.</segment>
    <segment id="29">Como comentou a advogada do Conselho de Cidadania brasileiro Ivonete Faust à agência EFE</segment>
    <segment id="30">, muitos dos que não vieram no dia 02 possivelmente estariam "</segment>
    <segment id="31">sese organizando para votar no domingo (30)</segment>
    <segment id="32">, porque</segment>
    <segment id="33">porque é uma disputa importante e as pessoas querem participar".</segment>
    <segment id="34">Barcelona é uma das duas cidades espanholas em que brasileiros que moram no país podem votar nesse pleito de 2022.</segment>
    <segment id="35">A outra é a capital Madri</segment>
    <segment id="36">, com 20 mil eleitores.</segment>
    <segment id="37">A população brasileira registrada na Espanha atualmente é de 90.535 pessoas.</segment>
    <segment id="38">É o quinto país do mundo com mais brasileiros.</segment>
    <segment id="39">Desse total</segment>
    <segment id="40">, 31 mil cidadãos estão aptos a votar.</segment>
    <segment id="41">Ao contrário de 2018</segment>
    <segment id="42">, quando Bolsonaro ganhou com 60% dos votos em Madri</segment>
    <segment id="43">, neste primeiro turno de 2022 Lula foi líder.</segment>
    <segment id="44">O atual presidente</segment>
    <segment id="45">, que perdeu em Barcelona nas eleições anteriores</segment>
    <segment id="46">, com 46%</segment>
    <segment id="47">, volta a perder a disputa na cidade para o candidato do PT.</segment>
    <segment id="48">Lula liderou o primeiro turno no estrangeiro</segment>
    <segment id="49">, com pouco mais de 47% dos votos totais.  ***</segment>
    <segment id="50">O número de cidadãos brasileiros aptos a votar no exterior aumentou quase 40% desde as últimas eleições de 2018.</segment>
    <segment id="51">Neste domingo 30</segment>
    <segment id="52">, até 697.078 eleitores poderão ir às urnas em todo o mundo.</segment>
    <segment id="53">Parece insignificante -- 0</segment>
    <segment id="54">,45% do eleitorado total --</segment>
    <segment id="55">, masmas somos muitos</segment>
    <segment id="56">, sim.</segment>
    <segment id="57">E, talvez ainda mais por estar longe de casa</segment>
    <segment id="58">, muitos queremos participar</segment>
    <segment id="59">, custe o que custe.</segment>
    <segment id="60">Como Amanda</segment>
    <segment id="61">, uma capixaba que conheci na tal fila do primeiro turno.</segment>
    <segment id="62">As duas esturricando no sol por mais de meia hora.</segment>
    <segment id="63">Ela, preocupada</segment>
    <segment id="64">, não tirava os olhos do relógio.</segment>
    <segment id="65">"</segment>
    <segment id="66">Minha família</segment>
    <segment id="67">"</segment>
    <segment id="68">,</segment>
    <segment id="69">disse.</segment>
    <segment id="70">"</segment>
    <segment id="71">Viemos em uma viagem de carro de quase duas horas com minha pequena e meu bebê só pra eu poder votar.</segment>
    <segment id="72">Duro, mas</segment>
    <segment id="73">mas, com as coisas</segment>
    <segment id="74">comocomo estão</segment>
    <segment id="75">, eu tinha que vir.</segment>
    <segment id="76">E aqui estamos.</segment>
    <segment id="77">Olha eles lá na esquina!</segment>
    <segment id="78">"  Acena</segment>
    <segment id="79">, e seu marido valenciano acena de volta</segment>
    <segment id="80">, com a bebê hispanobrasileirinha no colo</segment>
    <segment id="81">, sorridente</segment>
    <segment id="82">, dando tchau com a mão gorduchinha sob o sol de Barcelona.</segment>
    <segment id="83">A nova geração.</segment>
    <segment id="84">Boa votação a todxs &amp;lt</segment>
