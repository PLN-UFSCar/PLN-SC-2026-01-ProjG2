    <segment id="160">sese transferir para o CosmosLuto e agradecimento marcam repercussão da morte de Pelé nas redesFilhos e netos de Pelé</segment>
    <segment id="161">sese despedem:</segment>
    <segment id="162">&amp;#</segment>
    <segment id="163">039;Tudo o que somos é graças a você&amp;#039</segment>
    <segment id="164">;Messi e Cristiano Ronaldo prestam homenagem a Pelé: &amp;#039</segment>
    <segment id="165">;adeus ao eterno Rei&amp;#039</segment>
    <segment id="166">;Clubes brasileiros</segment>
    <segment id="167">homenageiam</segment>
    <segment id="168">Pelé pelas redes sociaisRei Pelé é homenageado com coroa em perfil do Santos nas redes sociaisRelembre frases de Pelé</segment>
    <segment id="169">, de seus admiradores e de desafetosMelhor jogador da história</segment>
    <segment id="170">, Pelé morre aos 82 anos</segment>
    <segment id="171">, em São PauloPelé compôs mais de cem músicas e cantou com Elis Regina e Roberto CarlosObama</segment>
    <segment id="172">, Macron</segment>
    <segment id="173">, Fernández e outros líderes mundiais lamentam morte de Pelé</segment>
