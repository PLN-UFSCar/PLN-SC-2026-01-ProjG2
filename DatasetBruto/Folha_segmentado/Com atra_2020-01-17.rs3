  <rst>
    <segment id="1">Prometida para ser entregue em 2013</segment>
    <segment id="2">, a ampliação da linha 2-verde do metrô começará em 2020</segment>
    <segment id="3">, sete anos depois da data na qual deveria ter sido concluída.</segment>
    <segment id="4">O governador João Doria (PSDB) anunciou a medida nesta sexta-feira (17).</segment>
    <segment id="5">A previsão é que sejam construídas oito estações e que a linha chegue até a Penha</segment>
    <segment id="6">, zona leste</segment>
    <segment id="7">, em 2026.</segment>
    <segment id="8">Caso o atual prazo proposto pelo governo estadual de São Paulo seja cumprido</segment>
    <segment id="9">, a obra ficará pronta 13 anos após a promessa anterior.</segment>
    <segment id="10">Todas as novas estações ficam na zona leste:</segment>
    <segment id="11">Orfanato</segment>
    <segment id="12">, Água Rasa</segment>
    <segment id="13">, Anália Franco</segment>
    <segment id="14">, Vila Formosa</segment>
    <segment id="15">, Guilherme Giorgi</segment>
    <segment id="16">, Nova Manchester</segment>
    <segment id="17">, Aricanduva e Penha.</segment>
    <segment id="18">A extensão até Guarulhos</segment>
    <segment id="19">, que também fazia parte da promessa anterior</segment>
    <segment id="20">, ainda não tem data para ser iniciada.</segment>
    <segment id="21">A administração estadual afirma que "o Metrô trabalha nas desapropriações do trecho Penha-Guarulhos para poder iniciar os projetos executivos que antecedem as obras.</segment>
    <segment id="22">Após elaboração do projeto executivo é possível definir o cronograma de início".</segment>
    <segment id="23">Terreno onde deverá ser a estação Água Rasa da linha 2-verde do metrô</segment>
    <segment id="24">; segundo governo</segment>
    <segment id="25">, obras de expansão terão investimentos de R$ 6 bi  - Ronny Santos - 7.mai.19/FolhapressEste novo projeto contempla cerca de 6 km e cinco estações: Penha de França</segment>
    <segment id="26">, Tiquatira</segment>
    <segment id="27">, Paulo Freire</segment>
    <segment id="28">, Ponte Grande e Dutra.</segment>
    <segment id="29">Em maio de 2019</segment>
    <segment id="30">, reportagem do Agora mostrou que o estado de São Paulo tinha 219 obras de grande porte paralisadas.</segment>
    <segment id="31">Entre elas estavam áreas de expansão da linha 2</segment>
    <segment id="32">, com diversas desapropriações e demolições de casas já realizadas.   "</segment>
    <segment id="33">Pelo menos umas 30 casas foram demolidas e os moradores tiveram de ir</segment>
    <segment id="34">embora</segment>
    <segment id="35">embora.</segment>
    <segment id="36">E a área está vazia</segment>
    <segment id="37">, sem nenhuma movimentação"</segment>
    <segment id="38">, disse na época o comerciante Nardélio Rodrigues</segment>
    <segment id="39">, 35 anos</segment>
    <segment id="40">, que mora em frente ao terreno onde deverá ser a estação Água Rasa.</segment>
    <segment id="41">Segundo o governo</segment>
    <segment id="42">, serão investidos R$ 6 bilhões para a ampliação da linha 2-verde do metrô.</segment>
    <segment id="43">Também está incluso neste valor a aquisição de 22 novos trens.</segment>
    <segment id="44">Atualmente</segment>
    <segment id="45">, a linha 2-verde liga as estações Vila Madalena (zona oeste) e Vila Prudente (zona leste).</segment>
    <segment id="46">A previsão é que o novo trecho atenda 300 mil pessoas.</segment>
    <segment id="47">CPTM chega  a Varginha no ano de 2022</segment>
    <segment id="48">O Governo de São Paulo anunciou também a continuidade das obras da estação Varginha</segment>
    <segment id="49">, linha 9-esmeralda da CPTM.</segment>
    <segment id="50">A promessa é que ela fique pronta no primeiro semestre de 2022.</segment>
    <segment id="51">Segundo a administração estadual</segment>
    <segment id="52">, foram liberados mais de R$ 87 milhões do governo federal.</segment>
    <segment id="53">A obra</segment>
    <segment id="54">, quando concluída</segment>
    <segment id="55">, permitirá ligação até a estação Osasco da CPTM.</segment>
    <segment id="56">Segundo Doria</segment>
    <segment id="57">, a linha será concluída em etapas.</segment>
    <segment id="58">E as estações entrarão em funcionamento</segment>
    <segment id="59">, uma a uma</segment>
    <segment id="60">, quando ficarem prontas.</segment>
    <segment id="61">A previsão é que mais 100 mil pessoas sejam atendidas.</segment>
    <segment id="62">Sobre outras da CPTM</segment>
    <segment id="63">, o governo afirma que "a extensão entre Grajaú e Mendes está em estágio avançado" e que "com esta autorização</segment>
    <segment id="64">, o início de obras entre as estações Mendes</segment>
    <segment id="65">, Vila Natal e a estação Varginha</segment>
    <segment id="66">, concretizaremos a extensão da linha 9-esmeralda".</segment>
    <segment id="67">Obras da linha 2-verde do metrô de SP serão retomadas   novamente         de   de  de  representando um</segment>
  </rst>
</analysis>