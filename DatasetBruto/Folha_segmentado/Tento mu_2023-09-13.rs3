  <rst>
    <segment id="1">Antes de</segment>
    <segment id="2">sese tornar escritora</segment>
    <segment id="3">, Paula Fábrio ganhou de presente uma consulta esotérica e visitou uma astróloga para fazer o seu mapa astral.</segment>
    <segment id="4">"</segment>
    <segment id="5">Achei tudo muito picareta na época</segment>
    <segment id="6">, porque</segment>
    <segment id="7">porque ela falou coisas que não tinham nada a ver"</segment>
    <segment id="8">, lembra a autora.</segment>
    <segment id="9">"</segment>
    <segment id="10">Isso faz uns 20 anos.</segment>
    <segment id="11">Mas hoje vejo que ela acertou tudo.</segment>
    <segment id="12">Pena que não tenho mais o contato daquela mulher"</segment>
    <segment id="13">, emenda com uma risada.</segment>
    <segment id="14">Ilustração de Laura Athayde para &amp;quot</segment>
    <segment id="15">;Tão Importante</segment>
    <segment id="16">comocomo um Pedaço da Língua&amp;quot</segment>
    <segment id="17">;, de Paula Fábrio - Divulgação</segment>
    <segment id="18">Entre as previsões feitas</segment>
    <segment id="19">, havia uma especial —a de que Fábrio trabalharia com crianças e escreveria histórias para a infância.</segment>
    <segment id="20">Seja por acerto</segment>
    <segment id="21">, seja mais provavelmente pelas mágicas do viés de confirmação</segment>
    <segment id="22">, a escritora lança nesta semana o seu segundo livro infantojuvenil</segment>
    <segment id="23">, "</segment>
    <segment id="24">Tão Importante</segment>
    <segment id="25">comocomo um Pedaço da Língua"</segment>
    <segment id="26">, publicado pela FTD.</segment>
    <segment id="27">Veja ilustrações do livro &amp;#039</segment>
    <segment id="28">;Tão Importante</segment>
    <segment id="29">comocomo um Pedaço da Língua&amp;#039</segment>
    <segment id="30">;Mais    novamente         de   de  de  representando um</segment>
    <segment id="31">A história</segment>
    <segment id="32">, ilustrada pela artista gráfica Laura Athayde</segment>
    <segment id="33">, investiga</segment>
    <segment id="34">comocomo as amizades chegam ao fim e apresenta três garotas inseparáveis</segment>
    <segment id="35">, unidas por serem pré-adolescentes fora do padrão.</segment>
    <segment id="36">Uma tem cabelos revoltos e ama astronomia.</segment>
    <segment id="37">Outra se</segment>
    <segment id="38">se torna a mais gorda da turma.</segment>
    <segment id="39">A terceira</segment>
    <segment id="40">, que é a protagonista</segment>
    <segment id="41">, sese acha baixinha e é dona do gato Fernando.</segment>
    <segment id="42">O felino</segment>
    <segment id="43">, que não tem um pedaço da língua</segment>
    <segment id="44">, é quem ajuda a batizar a obra.</segment>
    <segment id="45">Leia tambémGilberto</segment>
    <segment id="46">Gil e Jorge Mautner lançam livros ilustrados e para crianças</segment>
    <segment id="47">;</segment>
    <segment id="48">conheçaPanelas</segment>
    <segment id="49">, pregadores</segment>
    <segment id="50">, pimentões e outros objetos viram ilustrações de livrosOdilon</segment>
    <segment id="51">Moraes ilustra solidão e ausência em novos livros para criançasAs três faziam absolutamente tudo juntas</segment>
    <segment id="52">, masmas as coisas mudam.</segment>
    <segment id="53">"</segment>
    <segment id="54">Nenhum tempo</segment>
    <segment id="55">, quando acaba</segment>
    <segment id="56">, avisa que vai acabar"</segment>
    <segment id="57">, afirma o texto.</segment>
    <segment id="58">Nayara</segment>
    <segment id="59">, a personagem principal</segment>
    <segment id="60">, percebe então que as amigas</segment>
    <segment id="61">sese afastam sem motivo.</segment>
    <segment id="62">De uma hora para outra</segment>
    <segment id="63">, sem entender as razões</segment>
    <segment id="64">, ela se</segment>
    <segment id="65">se vê sozinha</segment>
    <segment id="66">, só com a companhia do gato sem língua</segment>
    <segment id="67">, que ajuda a transformar em metáfora a falta de comunicação</segment>
    <segment id="68">, a ausência de respostas</segment>
    <segment id="69">, o silêncio</segment>
    <segment id="70">, a mentira.</segment>
    <segment id="71">"</segment>
    <segment id="72">Passei por algo parecido na minha infância e vivia isso no momento em que escrevia o livro</segment>
    <segment id="73">, já adulta.</segment>
    <segment id="74">A perda das amizades acompanha a nossa vida"</segment>
    <segment id="75">, conta Fábrio.</segment>
    <segment id="76">No livro</segment>
    <segment id="77">, assim</segment>
    <segment id="78">comocomo ocorre muitas vezes no mundo real</segment>
    <segment id="79">, a personagem não descobre com certeza os porquês do afastamento.</segment>
    <segment id="80">Mas há indicações.</segment>
    <segment id="81">Paula Fábrio na entrega do prêmio São Paulo de Literatura</segment>
    <segment id="82">, em 2013 - Davi Ribeiro/FolhapressNão conto mais para não dar spoiler</segment>
    <segment id="83">, masmas as suspeitas de Nayara esbarram na condição social de sua família e em problemas enfrentados por seu pai</segment>
    <segment id="84">, que está longe.</segment>
    <segment id="85">"</segment>
    <segment id="86">Quero que meus livros gerem ruído na classe média alta.</segment>
    <segment id="87">Não só os infantojuvenis</segment>
    <segment id="88">, masmas tenho pensado nisso em relação à minha literatura para adultos também.</segment>
    <segment id="89">Quero fazer essa troca entre a periferia e o centro.</segment>
    <segment id="90">"  Para adultos</segment>
    <segment id="91">, a escritora venceu o prêmio São Paulo de Literatura com "Desnorteio"</segment>
    <segment id="92">, em 2013</segment>
    <segment id="93">, e publicou também títulos</segment>
    <segment id="94">comocomo "</segment>
    <segment id="95">Um Dia Toparei Comigo" e "</segment>
    <segment id="96">Estudo sobre o Fim".</segment>
    <segment id="97">Já na literatura infantojuvenil</segment>
    <segment id="98">, fez sua estreia com "</segment>
    <segment id="99">No Corredor dos Cobogós"</segment>
    <segment id="100">, lançado em 2019 pela editora SM.</segment>
    <segment id="101">Ilustração de Laura Athayde para &amp;quot</segment>
    <segment id="102">;Tão Importante</segment>
    <segment id="103">comocomo um Pedaço da Língua&amp;quot</segment>
    <segment id="104">; - Divulgação</segment>
    <segment id="105">Em comum entre os dois livros para a infância</segment>
    <segment id="106">, está o protagonismo feminino.</segment>
    <segment id="107">É verdade que "</segment>
    <segment id="108">No Corredor dos Cobogós"</segment>
    <segment id="109">sese equilibra entre dois personagens</segment>
    <segment id="110">, um menino e uma menina.</segment>
    <segment id="111">"</segment>
    <segment id="112">Sem o garoto até poderia haver história</segment>
    <segment id="113">, masmas sem ela não existiria o livro"</segment>
    <segment id="114">, afirma Fábrio.</segment>
    <segment id="115">Já no lançamento</segment>
    <segment id="116">, praticamente tudo gira ao redor do universo feminino.</segment>
    <segment id="117">"É uma voz que domino mais</segment>
    <segment id="118">, masmas é também um projeto.</segment>
    <segment id="119">Quero criar histórias com protagonistas femininas</segment>
    <segment id="120">porque</segment>
    <segment id="121">porque</segment>
    <segment id="122">, quando eu era criança</segment>
    <segment id="123">, li centenas de livros com heróis masculinos.</segment>
    <segment id="124">"  "</segment>
    <segment id="125">Nos livros para adultos</segment>
    <segment id="126">, isso não é uma questão para mim"</segment>
    <segment id="127">, diz a escritora.</segment>
    <segment id="128">"</segment>
    <segment id="129">Pode ser romântico ou uma inocência minha</segment>
    <segment id="130">, masmas é no livro infantil que tento mudar o mundo.</segment>
    <segment id="131">Quero que meninas das novas gerações</segment>
    <segment id="132">sese deparem na literatura com um olhar diferente.</segment>
    <segment id="133">O adulto já está perdido</segment>
    <segment id="134">, masmas sinto que a gente ainda pode contribuir com o leitor em formação.</segment>
    <segment id="135">"</segment>
    <segment id="136">Tão Importante</segment>
    <segment id="137">comocomo um Pedaço da LínguaPreço R$ 66 (48 págs.)Autoria Paula Fábrio e Laura AthaydeEditora FTDLançamentoSáb.</segment>
    <segment id="138">(16), às 10h30</segment>
    <segment id="139">, na livraria Miúda (r. Coronel Melo de Oliveira</segment>
    <segment id="140">, 766, Pompeia</segment>
    <segment id="141">, região oeste</segment>
    <segment id="142">, São Paulo/SP)</segment>
    <segment id="143">;</segment>
    <segment id="144">participação de Aline Abreu</segment>
    <segment id="145">, que lança conjuntamente &amp;#039</segment>
    <segment id="146">;Sementes de Mamona&amp;#039</segment>
    <segment id="147">; (FTD)</segment>
  </rst>
</analysis>