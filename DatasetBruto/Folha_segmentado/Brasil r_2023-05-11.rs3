  <rst>
    <segment id="1">O Brasil registrou ao menos 273 mortes violentas de pessoas LGBTQIAP+ em 2022.</segment>
    <segment id="2">Desses casos</segment>
    <segment id="3">, 228 foram assassinatos</segment>
    <segment id="4">, 30 suicídios e 15 outras causas</segment>
    <segment id="5">, como</segment>
    <segment id="6">como morte decorrente de lesões por agressão.</segment>
    <segment id="7">A média é de um morto a cada 32 horas.</segment>
    <segment id="8">O levantamento foi realizado pelo Observatório de Mortes Violentes Contra LGBTI+</segment>
    <segment id="9">, que ainda conta contou com a parceria de Antra (Associação Nacional de Travestis e Transexuais) e ABGLT (Associação Brasileira de Lésbicas</segment>
    <segment id="10">, Gays</segment>
    <segment id="11">, Bissexuais</segment>
    <segment id="12">, Travestis</segment>
    <segment id="13">, Transexuais e Intersexos).</segment>
    <segment id="14">Por ausência de dados oficiais</segment>
    <segment id="15">, segundo as organizações</segment>
    <segment id="16">, as principais fontes consultadas foram notícias publicadas na mídia.</segment>
    <segment id="17">Bandeira entendida durante a 27°</segment>
    <segment id="18">Parada LGBTQIA+ de Copacabana</segment>
    <segment id="19">, no Rio de Janeiro</segment>
    <segment id="20">, em novembro de 2022 - Prefeitura do Rio de Janeiro/ DivulgaçãoTravestis e transexuais representam maior parte dos mortos (58%)</segment>
    <segment id="21">, seguidos por gays (35%)</segment>
    <segment id="22">, lésbicas (3%) e homens trans (3%).</segment>
    <segment id="23">Ainda há pequena porcentagem de pessoas não binárias (0</segment>
    <segment id="24">,4) e outras designações (0</segment>
    <segment id="25">,4).</segment>
    <segment id="26">Em 2021</segment>
    <segment id="27">, ocorreram 316 mortes violentas.</segment>
    <segment id="28">Ou seja</segment>
    <segment id="29">, em um ano</segment>
    <segment id="30">, houve redução de 14% no total de mortos.</segment>
    <segment id="31">A coleta de dados foi iniciada em 2000</segment>
    <segment id="32">, quando foram computados 130 óbitos.</segment>
    <segment id="33">Em 2017</segment>
    <segment id="34">, foi registrado o pico da série histórica</segment>
    <segment id="35">, com 445 mortos.</segment>
    <segment id="36">Em 2022</segment>
    <segment id="37">, segundo os pesquisadores</segment>
    <segment id="38">, a idade das vítimas variou de 13 a 75 anos.</segment>
    <segment id="39">Distribuindo os casos por decênios</segment>
    <segment id="40">, perceberam que grande parte dos mortos são jovens adultos entre 20 e 29 anos (33</segment>
    <segment id="41">,33%).</segment>
    <segment id="42">Dos 273 casos computados</segment>
    <segment id="43">, foi identificada raça de 187 indivíduos</segment>
    <segment id="44">, correspondendo a 68</segment>
    <segment id="45">,5% do total: 94 eram brancas e 91 pretas ou pardas.</segment>
    <segment id="46">Houve dois casos de pessoas indígenas.</segment>
    <segment id="47">Sobre o método empregado</segment>
    <segment id="48">, 74 mortes foram causadas por arma de fogo e 48 foram por esfaqueamento.</segment>
    <segment id="49">Nordeste (118) e Sudeste (71) foram as regiões com mais ocorrências levantadas.</segment>
    <segment id="50">O que significa cada letra da sigla LGBTQIA+?Mais    novamente         de   de  de  representando um</segment>
    <segment id="51">O relatório diz que os dados apresentados apontam que o ambiente político e social do país continua sendo favorável à homofobia.</segment>
    <segment id="52">"</segment>
    <segment id="53">Isso acaba impactando</segment>
    <segment id="54">comocomo as pessoas</segment>
    <segment id="55">LGBT+</segment>
    <segment id="56">são recebidas nos espaços</segment>
    <segment id="57">, aumentando os riscos de violações de direitos humanos e violência contra esses corpos</segment>
    <segment id="58">, suas identidades de gênero</segment>
    <segment id="59">, orientações sexuais e suas expressões de gêneros.</segment>
    <segment id="60">"</segment>
    <segment id="61">Bruna Benevides</segment>
    <segment id="62">, secretária de articulação política da Associação Nacional de Travestis e Transexuais</segment>
    <segment id="63">, diz que</segment>
    <segment id="64">, embora</segment>
    <segment id="65">embora haja queda no número de óbitos derivados de violência entre 2021 e 2022</segment>
    <segment id="66">, a quantidade do último ano ainda é 108% maior do que a registrada no início da série</segment>
    <segment id="67">, em 2000.</segment>
    <segment id="68">"</segment>
    <segment id="69">O dado mostra continuar ausente qualquer política pública que denuncie e ataque o problema da LGBTIfobia no Brasil"</segment>
    <segment id="70">, declara Benevides. "</segment>
    <segment id="71">No momento</segment>
    <segment id="72">, temos que</segment>
    <segment id="73">, com um governo que já demonstrou ser defensor da população LGBTQIA+</segment>
    <segment id="74">, cobrar ainda mais empenho para erradicar todas as formas de agressão a nós e mudar esta triste realidade de violência"</segment>
    <segment id="75">, continua.</segment>
  </rst>
</analysis>