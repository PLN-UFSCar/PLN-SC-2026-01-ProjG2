  <rst>
    <segment id="1">O presidente Lula (PT) passará o fim de semana em Alter do Chão</segment>
    <segment id="2">, distrito turístico de Santarém (PA)</segment>
    <segment id="3">, às margens do rio Tapajós ao lado da primeira-dama Janja.</segment>
    <segment id="4">Lula chegou com a mulher e assessores nesta sexta-feira (4) à Casa do Saulo</segment>
    <segment id="5">, hotel e restaurante na praia do Carapanari.</segment>
    <segment id="6">Ele ficará em um dos dez bangalôs do local.</segment>
    <segment id="7">Alter do Chão</segment>
    <segment id="8">, distrito de Santarém</segment>
    <segment id="9">, famosa pelas sua praias</segment>
    <segment id="10">, o balneário às margens do rio Tapajós atrai turistas do mundo inteiro.</segment>
    <segment id="11">A faixa de areia no centro da imagem é conhecida</segment>
    <segment id="12">comocomo Ilha do Amor. - Pedro Ladeira - 19.set.2022 / FolhapressA hospedagem foi recém-criada anexa ao restaurante do chef Saulo Jennings</segment>
    <segment id="13">, que cunhou a expressão "cozinha tapajônica"</segment>
    <segment id="14">, em referência à culinária com peixes típicos da região.</segment>
    <segment id="15">Além do restaurante em Alter do Chão</segment>
    <segment id="16">, ele mantém filiais em Belém e no Rio de Janeiro.</segment>
    <segment id="17">No jantar foi servido pirarucu</segment>
    <segment id="18">, tambaqui e outros peixes da região assados na folha da bananeira.</segment>
    <segment id="19">Foram oferecidos sucos de cupuaçu</segment>
    <segment id="20">, cacau e graviola</segment>
    <segment id="21">, frutas típicas da Amazônia.</segment>
    <segment id="22">O chef serviu também um vinagrete de feijão Santarém.</segment>
    <segment id="23">Não será a primeira vez que Lula terá à disposição os serviços do chef.</segment>
    <segment id="24">Saulo serviu bolinho de piracuí na recepção oferecida a convidados no dia da posse</segment>
    <segment id="25">, em janeiro.</segment>
    <segment id="26">O presidente também almoçou no restaurante dele em Belém</segment>
    <segment id="27">, em junho</segment>
    <segment id="28">, ao lado do governador Helder Barbalho (MDB) e do agora ministro Celso Sabino (União Brasil).</segment>
    <segment id="29">O custo médio da diária de um bangalô é de R$ 800.</segment>
    <segment id="30">A Presidência da República e o hotel não informaram</segment>
    <segment id="31">comocomo e</segment>
    <segment id="32">sese a hospedagem foi cobrada.</segment>
    <segment id="33">Os dez bangalôs estão reservados para a comitiva presidencial.</segment>
    <segment id="34">Guias de turismo foram informados de que o espaço estará fechado para visitantes até domingo (6)</segment>
    <segment id="35">, quando está prevista a saída de Lula do local.</segment>
    <segment id="36">Nesta sexta-feira</segment>
    <segment id="37">, o presidente teve agenda no interior do Amazonas</segment>
    <segment id="38">, em Parintins.</segment>
    <segment id="39">Na segunda-feira (7)</segment>
    <segment id="40">, há previsão de visita do petista a um navio-escola em Santarém e a uma unidade da Universidade Federal do Oeste do Pará.</segment>
    <segment id="41">Lula em viagens pelo Brasil em 2023Mais    novamente         de   de  de  representando</segment>
    <segment id="42">um</segment>
  </rst>
</analysis>