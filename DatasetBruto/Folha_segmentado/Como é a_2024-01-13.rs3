  <rst>
    <segment id="1">Na imagem abaixo</segment>
    <segment id="2">, uma trabalhadora dalit (anteriormente conhecidos</segment>
    <segment id="3">comocomo intocáveis) caminha com dificuldade passando por uma mina de carvão a céu aberto no estado de Jharkhand</segment>
    <segment id="4">, na Índia</segment>
    <segment id="5">, onde incêndios subterrâneos acontecem há mais de um século.</segment>
    <segment id="6">A fotografia faz parte de uma série em preto e branco intitulada "</segment>
    <segment id="7">Broken"</segment>
    <segment id="8">, de Asha Thadani</segment>
    <segment id="9">, que há sete anos retrata a vida de dalits.</segment>
    <segment id="10">Uma mulher dalit caminha descalça em Jharkhand</segment>
    <segment id="11">, na Índia- Asha ThadaniOs 200 milhões de dalits da Índia encontram-</segment>
    <segment id="12">sese entre os cidadãos mais marginalizados do país</segment>
    <segment id="13">, condenados aos escalões mais baixos da sociedade por uma rígida hierarquia de castas.</segment>
    <segment id="14">Cotas em instituições estatais para dalits reduziram as lacunas na educação</segment>
    <segment id="15">, renda e saúde.</segment>
    <segment id="16">Os dalits agora possuem uma próspera câmara de comércio repleta de milionários.</segment>
    <segment id="17">Muitas organizações defendem ativamente seus direitos.</segment>
    <segment id="18">Dois dalits já foram chefes de Estado.</segment>
    <segment id="19">Um número significativo de dalits</segment>
    <segment id="20">, no entanto</segment>
    <segment id="21">, segue fazendo os trabalhos evitados por outros</segment>
    <segment id="22">, como</segment>
    <segment id="23">como o descarte de animais mortos e a limpeza de esgotos.</segment>
    <segment id="24">Artista dalit theyyam-</segment>
    <segment id="25">Asha ThadaniTheyyam é um ritual religioso original da parte norte do Estado de Kerala.</segment>
    <segment id="26">A imagem mostra um artista dalit theyyam do Estado</segment>
    <segment id="27">, onde</segment>
    <segment id="28">sese acredita que esses dançarinos em transe incorporam as próprias divindades que veneram.</segment>
    <segment id="29">"</segment>
    <segment id="30">Quando eles</segment>
    <segment id="31">sese tornam artistas de theyyam</segment>
    <segment id="32">, eles</segment>
    <segment id="33">sese tornam contadores de histórias e representações vivas médias dos deuses.</segment>
    <segment id="34">Embora o theyyam esteja enraizado no sistema de castas</segment>
    <segment id="35">, durante a performance as castas superiores devem respeitar e obedecer o dançarino divino que é da casta inferior"</segment>
    <segment id="36">, diz Thadani.</segment>
    <segment id="37">Mulher dalit com um rato na cabeça - Asha ThadaniOs Musahars</segment>
    <segment id="38">, que literalmente significa "pessoas rato"</segment>
    <segment id="39">, são tão pobres que sua dieta básica geralmente inclui ratos.</segment>
    <segment id="40">Uma comunidade dalit no Estado de Bihar</segment>
    <segment id="41">, os Musahars trabalham principalmente nas fazendas de proprietários de terra e ficam sem trabalho por até oito meses por ano.</segment>
    <segment id="42">Enfrentando o desafio de sobrevivência e dependentes da generosidade imprevisível dos proprietários de terra</segment>
    <segment id="43">, os Musahars encontraram meios de subsistência alternativos</segment>
    <segment id="44">, como</segment>
    <segment id="45">como o Nachaniya —um grupo de artistas de gênero fluido dentro da comunidade.</segment>
    <segment id="46">Esses artistas do sexo masculino</segment>
    <segment id="47">, de 10 a 23 anos</segment>
    <segment id="48">, vestem-</segment>
    <segment id="49">sese como</segment>
    <segment id="50">como mulheres e apresentam-</segment>
    <segment id="51">sese em casamentos em aldeias</segment>
    <segment id="52">, especialmente durante a temporada de monções.</segment>
    <segment id="53">Mulher dalit ramnami-</segment>
    <segment id="54">Asha ThadaniEm um hino visual à devoção</segment>
    <segment id="55">, uma mulher Ramnami olha pensativa</segment>
    <segment id="56">, próxima a uma porta</segment>
    <segment id="57">, com o rosto e a cabeça raspada tatuadas com a repetição rítmica de "</segment>
    <segment id="58">Ram" na escrita Devanagari</segment>
    <segment id="59">, usada para escrever hindi —uma manifestação eloquente de canto em forma escrita.</segment>
    <segment id="60">A cada golpe da agulha de madeira</segment>
    <segment id="61">, impregnada de tinta derivada da fuligem da lâmpada de querosene</segment>
    <segment id="62">, emergem círculos concêntricos intrincados e padrões lineares</segment>
    <segment id="63">, formando uma tapeçaria sagrada em sua pele.</segment>
    <segment id="64">A tradição</segment>
    <segment id="65">sese estende a um xale</segment>
    <segment id="66">, graciosamente colocado em seus ombros</segment>
    <segment id="67">, com a palavra sagrada.</segment>
    <segment id="68">Nascidos de um ato de desafio do final do século 19</segment>
    <segment id="69">, os Ramnamis do Estado de Chhattisgarh incorporam um protesto distinto</segment>
    <segment id="70">, gravando a devoção tanto na pele quanto na alma —uma fusão atemporal de fé e identidade.</segment>
    <segment id="71">Mergulhador dalit - Asha</segment>
    <segment id="72">ThadaniEmergindo das profundezas sagradas do Ganges na cidade religiosa de Varanasi</segment>
    <segment id="73">, um habilidoso mergulhador dalit surge com moedas apertadas entre os dentes - uma imagem evocativa de uma vida tecida na narrativa do rio.</segment>
    <segment id="74">Conhecido</segment>
    <segment id="75">comocomo um 'Gotakhor' ou um mergulhador especializado</segment>
    <segment id="76">, ele segura as moedas —ofertas de buscadores de absolvição— entre os dentes</segment>
    <segment id="77">, deixando as mãos livres para navegar pela corrente do rio.</segment>
    <segment id="78">Os mergulhadores também são encarregados de recuperar os corpos de pessoas que</segment>
    <segment id="79">sese afogaram no rio e são compensados com álcool barato</segment>
    <segment id="80">, de acordo com Thadani.</segment>
    <segment id="81">"</segment>
    <segment id="82">Cada mergulho é um ritual</segment>
    <segment id="83">, e cada moeda recuperada serve</segment>
    <segment id="84">comocomo uma oferta para facilitar a jornada simbólica através de águas difíceis"</segment>
    <segment id="85">, diz ela.</segment>
    <segment id="86">Mulher dalit tatuada - ASHA THADANIEm um canto de Bihar</segment>
    <segment id="87">, essas mulheres dalit resistiram às restrições de castas superiores às joias</segment>
    <segment id="88">, desenvolvendo uma forma única de adorno —as tatuagens.</segment>
    <segment id="89">Usando esterco de vaca</segment>
    <segment id="90">, bambu</segment>
    <segment id="91">, palha</segment>
    <segment id="92">, galhos e folhas de palmeira para construir suas cabanas</segment>
    <segment id="93">, elas transformaram as paredes em telas.</segment>
    <segment id="94">"Proibidas de retratar divindades hindus</segment>
    <segment id="95">, elas encontraram inspiração na natureza.</segment>
    <segment id="96">Hoje, suas pinturas são renomadas</segment>
    <segment id="97">, servindo</segment>
    <segment id="98">comocomo fonte de subsistência e testemunho da criatividade e coragem dessas mulheres"</segment>
    <segment id="99">, diz Thadani.</segment>
    <segment id="100">Mulher dalit - Asha</segment>
    <segment id="101">ThadaniEssas mulheres são carpideiras profissionais</segment>
    <segment id="102">, que praticam o antigo ritual de luto</segment>
    <segment id="103">Oppari profundamente enraizado em uma comunidade de dalits em Tamil Nadu.</segment>
    <segment id="104">Tradicionalmente realizado</segment>
    <segment id="105">comocomo uma resposta emotiva à perda de familiares próximos</segment>
    <segment id="106">, Opparis são cantados em nome ou diretamente para a família em luto.</segment>
    <segment id="107">Essas mulheres são convocadas para lares onde a morte ocorreu</segment>
    <segment id="108">, habilmente externalizando o luto em um ritual profundo.</segment>
    <segment id="109">A tarefa</segment>
    <segment id="110">, considerada "poluente</segment>
    <segment id="111">" e reservada para dalits</segment>
    <segment id="112">, desafia as normas sociais que associam a exibição externa do luto à fraqueza</segment>
    <segment id="113">, uma percepção tradicionalmente reservada às mulheres.  Shiva</segment>
    <segment id="114">, um jovem dalit queimando cabeças de cabra - Asha ThadaniShiva</segment>
    <segment id="115">, de uma comunidade de dalits em Karnataka</segment>
    <segment id="116">, faz parte de um grupo que queima cabeças de cabra do lado de fora do mercado de carne na cidade de Bangalore.</segment>
    <segment id="117">As cabeças de cabra são processadas a fogo para remover a pele</segment>
    <segment id="118">, facilitando a preparação e a venda do órgão mais caro —o cérebro.</segment>
    <segment id="119">Esse processo é um passo necessário na preparação da carne.</segment>
    <segment id="120">Expostos ao calor escaldante</segment>
    <segment id="121">, fumaça tóxica e poeira de carvão diariamente</segment>
    <segment id="122">, os que fazem esse trabalho têm uma expectativa de vida de 35 a 45 anos.</segment>
    <segment id="123">Os espetos de metal que são usados ficam extremamente quentes durante a queima</segment>
    <segment id="124">, afetando a sensibilidade das mãos ao segurá-los durante todo o dia de trabalho.</segment>
    <segment id="125">O trabalho é realizado exclusivamente por dalits do sexo masculino</segment>
    <segment id="126">, alguns com idade entre 10 e 12 anos</segment>
    <segment id="127">, que recebem um pagamento de 15 rúpias (18 centavos) pelo processamento de uma cabeça de cabra.</segment>
  </rst>
</analysis>