  <rst>
    <segment id="1">Morreu nesta sexta (24) o chef espanhol Daniel Redondo</segment>
    <segment id="2">, que abriu o restaurante paulistano Maní ao lado da chef Helena Rizzo</segment>
    <segment id="3">, com quem foi casado.</segment>
    <segment id="4">Aos 46 anos</segment>
    <segment id="5">, ele sofreu um acidente de moto —ainda não há informação sobre o local em que isso ocorreu.</segment>
    <segment id="6">A notícia foi confirmada por Helena Rizzo neste sábado (25) e comunicada pela família Roca</segment>
    <segment id="7">, que está à frente do premiado restaurante espanhol</segment>
    <segment id="8">El Celler de Can Roca</segment>
    <segment id="9">, em Girona.</segment>
    <segment id="10">Redondo foi chef de cozinha do local aos 27 anos</segment>
    <segment id="11">, onde conheceu Helena Rizzo</segment>
    <segment id="12">, que havia ido estagiar na casa.</segment>
    <segment id="13">O chef Daniel Redondo durante jantar de lancamento do filme &amp;#039</segment>
    <segment id="14">;Joao, o Maestro&amp;#039</segment>
    <segment id="15">;, em São Paulo</segment>
    <segment id="16">, em 2017 - Greg Salibian/Folhapress  Em 2006</segment>
    <segment id="17">, os dois abriram em São Paulo o restaurante Maní</segment>
    <segment id="18">, que combinava</segment>
    <segment id="19">, à época</segment>
    <segment id="20">, as técnicas da cozinha de vanguarda espanhola</segment>
    <segment id="21">, que teve Ferran Adrià</segment>
    <segment id="22">comocomo expoente</segment>
    <segment id="23">, à pesquisa de ingredientes brasileiros.</segment>
    <segment id="24">"</segment>
    <segment id="25">Me lembro que em 2008 recebemos todo aquele time de espanhóis aqui no Brasil</segment>
    <segment id="26">, naquele momento em que a Espanha estava vivendo um momento especial</segment>
    <segment id="27">, transmitindo a mensagem que cada lugar [país] deveria olhar seu entorno"</segment>
    <segment id="28">, diz Helena.</segment>
    <segment id="29">Essa diretriz era vista em ingredientes</segment>
    <segment id="30">comocomo taioba e tucupi</segment>
    <segment id="31">, que ainda eram raridade em menus-degustação em restaurantes paulistanos ou cariocas –uma tendência que</segment>
    <segment id="32">, quase duas décadas depois</segment>
    <segment id="33">, o Maní ajudou popularizar.</segment>
    <segment id="34">Redondo integrou o time até 2016</segment>
    <segment id="35">, quando Helena assumiu a cozinha integralmente.</segment>
    <segment id="36">ManíMais    novamente         de   de  de  representando um    "</segment>
    <segment id="37">Ele amava o Brasil</segment>
    <segment id="38">, amava caipirinhas</segment>
    <segment id="39">, amava uma cozinha genuína.</segment>
    <segment id="40">Gostava de comer e de conhecer os produtores aqui.</segment>
    <segment id="41">Quando viemos para cá [abrir o Maní]</segment>
    <segment id="42">, ele tinha essa vontade de fazer algo</segment>
    <segment id="43">, de ser criativo.</segment>
    <segment id="44">Quem conviveu com ele tem essa memória"</segment>
    <segment id="45">, diz Helena.</segment>
    <segment id="46">"Que talento descomunal.</segment>
    <segment id="47">Nascido para cozinhar.</segment>
    <segment id="48">Uma pessoa perseverante</segment>
    <segment id="49">, talentosa"</segment>
    <segment id="50">, diz uma mensagem na conta de Instagram do restaurante El Celler de Can Roca</segment>
    <segment id="51">, que acompanha uma foto de Redondo.</segment>
    <segment id="52">O El Celler de Can Roca foi eleito duas vezes o melhor restaurante do mundo segundo a lista do 50 Best</segment>
    <segment id="53">, em 2013 e 2015 –desde 2009 estava na lista dos cinco melhores.</segment>
    <segment id="54">A chef Helena Rizzo junto de Daniel Redondo no restaurante Maní</segment>
    <segment id="55">, em São Paulo</segment>
    <segment id="56">, em 2011 - Marisa Cauduro/Folhapress</segment>
    <segment id="57">O espanhol Oscar Bosch</segment>
    <segment id="58">, que comanda o Tanit e o Nit Bar de Tapas</segment>
    <segment id="59">, nos Jardins</segment>
    <segment id="60">, em São Paulo</segment>
    <segment id="61">, trabalhou com Redondo no El Celler de Can Roca e também conviveu com o chef na capital paulista.</segment>
    <segment id="62">"Era um gênio</segment>
    <segment id="63">, fazia combinações inusitadas de cabeça e era muito exigente na cozinha.</segment>
    <segment id="64">Tenho três funcionários que trabalharam com ele e que dizem: ‘me ensinou muita coisa</segment>
    <segment id="65">, mesmo que fosse bravo.</segment>
    <segment id="66">’"</segment>
    <segment id="67">Redondo foi crescendo ao longo dos anos no El Celler</segment>
    <segment id="68">, conta Bosch</segment>
    <segment id="69">, masmas foi no Brasil que teve a oportunidade de expressar sua personalidade na gastronomia de forma mais autoral.</segment>
    <segment id="70">"</segment>
    <segment id="71">Aqui, fez uma cozinha com toda aquela bagagem espanhola somada ao conhecimento das frutas e dos ingredientes brasileiros.</segment>
    <segment id="72">Ele amava o Brasil".</segment>
  </rst>
</analysis>