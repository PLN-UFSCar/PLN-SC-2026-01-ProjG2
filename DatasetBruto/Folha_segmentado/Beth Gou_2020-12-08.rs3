  <rst>
    <segment id="1">Beth Goulart gravou novo vídeo para agradecer mais uma vez o apoio do público à mãe</segment>
    <segment id="2">, Nicette Bruno</segment>
    <segment id="3">, e dar notícias sobre seu estado de saúde.</segment>
    <segment id="4">“</segment>
    <segment id="5">Continuamos com muita esperança e fé.</segment>
    <segment id="6">Aproveito para agradecer a todos em meu nome e de minha família por todas as orações</segment>
    <segment id="7">, as mensagens de carinho e de força.</segment>
    <segment id="8">Estamos juntos.</segment>
    <segment id="9">Muita gratidão”</segment>
    <segment id="10">, escreveu ela.</segment>
    <segment id="11">Beth disse ainda que o quadro de Nicette permanece bastante delicado.</segment>
    <segment id="12">Infectada com a Covid-19</segment>
    <segment id="13">, ela teve de ser intubada e vem precisando de hemodiálise</segment>
    <segment id="14">, recurso qufe</segment>
    <segment id="15">, segundo a atriz</segment>
    <segment id="16">, começa a fazer efeito no quadro geral.</segment>
    <segment id="17">AFAGO</segment>
    <segment id="18">ÀS PLANTINHAS</segment>
    <segment id="19">Com mais de 1 milhão de curtidas por esta foto</segment>
    <segment id="20">, Cleo colecionou elogios em seu Instagram.</segment>
    <segment id="21">A imagem não tem qualquer propósito definido.</segment>
    <segment id="22">A atriz e cantora tem</segment>
    <segment id="23">sese divertido em performar com figurino de todos os tipos ou quase sem figurino.</segment>
    <segment id="24">Um dos comentários para o post causou engajamento especialmente maior.</segment>
    <segment id="25">Era de Dani Calabresa</segment>
    <segment id="26">, que, a partir de uma denúncia de assédio sexual contra Marcius Melhem</segment>
    <segment id="27">, virou o centro das atenções nos últimos dias e vem motivando uma onda de solidariedade.</segment>
    <segment id="28">“Força</segment>
    <segment id="29">, Dani”</segment>
    <segment id="30">, comentaram sobre uma figurinha que ela publicou ali</segment>
    <segment id="31">Então é NatalMais    novamente         de   de  de  representando um  FRASE</segment>
    <segment id="32">"Tive um quadro no Fantástico</segment>
    <segment id="33">, ‘</segment>
    <segment id="34">A Gente Ganha Pouco</segment>
    <segment id="35">, masmas</segment>
    <segment id="36">Se Diverte’.</segment>
    <segment id="37">O chefão cancelou</segment>
    <segment id="38">, alegando</segment>
    <segment id="39">, ‘você é muito nordestina para ter um quadro no Fantástico’.</segment>
    <segment id="40">Chorei copiosamente"</segment>
    <segment id="41">Dadá Coelho no Twitter  Dada´</segment>
    <segment id="42">Coelho</segment>
    <segment id="43">Qual melhor atriz de humor?</segment>
    <segment id="44">Dadá Coelho (A Culpa É da Carlota) - Instagram/dadacoelhoREVERÊNCIA  “Gratidão.</segment>
    <segment id="45">Quantos amigos queridos</segment>
    <segment id="46">, quantas mensagens lindas.</segment>
    <segment id="47">Saudades de todos”</segment>
    <segment id="48">, disse Fátima Bernardes em agradecimento às muitas mensagens que vem recebendo desde domingo</segment>
    <segment id="49">, após</segment>
    <segment id="50">sese submeter a uma cirurgia para tratamento de um câncer no útero.</segment>
    <segment id="51">Poucas horas após a operação</segment>
    <segment id="52">, seu namorado</segment>
    <segment id="53">, o deputado Túlio Gadêlha (PDT-PE)</segment>
    <segment id="54">, falou sobre seu estado de saúde e tranquilizou os fãs.</segment>
    <segment id="55">“Deu certo!</segment>
    <segment id="56">As boas energias e orações deram certo.</segment>
    <segment id="57">Se tudo permanecer bem</segment>
    <segment id="58">, amanhã estaremos em casa.</segment>
    <segment id="59">”</segment>
    <segment id="60">Ainda nesta terça (8)</segment>
    <segment id="61">, Fátima postou uma homenagem a Eduardo Galvão</segment>
    <segment id="62">, que morreu na noite de segunda-feira (7)</segment>
    <segment id="63">, aos 58 anos</segment>
    <segment id="64">, de Covid</segment>
    <segment id="65">, com uma foto dos dois no Encontro.</segment>
    <segment id="66">Encontro com Fátima</segment>
    <segment id="67">Bernardes 2020Mais</segment>
    <segment id="68">novamente         de   de  de  representando um  ​RECADO</segment>
    <segment id="69">Em entrevista à revista Harper’s Bazaar</segment>
    <segment id="70">, Angelina Jolie fez um alerta às mulheres para</segment>
    <segment id="71">sese defenderem da violência doméstica.</segment>
    <segment id="72">“Fale com alguém.</segment>
    <segment id="73">Tente encontrar aliados.</segment>
    <segment id="74">Esteja conectada para emergências.</segment>
    <segment id="75">Você pode combinar uma palavra-código com amigo”</segment>
    <segment id="76">, ensinou.</segment>
    <segment id="77">TRIBUNAL</segment>
    <segment id="78">A atriz Natalie Portman</segment>
    <segment id="79">, 39 anos</segment>
    <segment id="80">, culpou a mídia pela sexualização de sua imagem quando ela era uma estrela infantil.</segment>
    <segment id="81">Mãe de duas crianças e vencedora de um Oscar por seu trabalho em “Cisne Negro” (2010)</segment>
    <segment id="82">, ela falou sobre o assunto ao podcast “Armchair Expert”</segment>
    <segment id="83">, conduzido pelo ator Dex Shepard.</segment>
