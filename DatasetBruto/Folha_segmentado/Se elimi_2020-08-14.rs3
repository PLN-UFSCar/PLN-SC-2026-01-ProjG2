  <rst>
    <segment id="1">Antes da pandemia</segment>
    <segment id="2">, lembro-me de sair com alívio de um cinema.</segment>
    <segment id="3">Tinha ido ver “Era Uma Vez em...</segment>
    <segment id="4">Hollywood”</segment>
    <segment id="5">, de Quentin Tarantino.</segment>
    <segment id="6">Aquele massacre horrível na casa de Sharon Tate</segment>
    <segment id="7">, que, prestes a ter um filho</segment>
    <segment id="8">, estava entre os cadáveres</segment>
    <segment id="9">, não havia acontecido.</segment>
    <segment id="10">Filme de Tarantino tem que mostrar sangue: houve uma carnificina</segment>
    <segment id="11">, masmas só morreram os do mal.</segment>
    <segment id="12">Bem feito para eles.</segment>
    <segment id="13">Sensação semelhante tive com a série “Hollywood”</segment>
    <segment id="14">, da Netflix.</segment>
    <segment id="15">Em 1948</segment>
    <segment id="16">, o combate contra os preconceitos raciais e antigay triunfou.</segment>
    <segment id="17">Que bom</segment>
    <segment id="18">sese o passado tivesse sido assim.</segment>
    <segment id="19">Porque</segment>
    <segment id="20">, nos dois casos</segment>
    <segment id="21">, tudo é ficção</segment>
    <segment id="22">, história corrigida para o lado bom da força.</segment>
    <segment id="23">Fiquei pensando</segment>
    <segment id="24">sese não estamos vivendo uma tendência mais geral</segment>
    <segment id="25">, investida por uma desesperada vontade de corrigir o passado.</segment>
    <segment id="26">Veja cenas de &amp;#</segment>
    <segment id="27">039;Era uma Vez em...</segment>
    <segment id="28">Hollywood&amp;#039</segment>
    <segment id="29">;Mais    novamente         de   de  de  representando um</segment>
    <segment id="30">Tento compreender o mundo de agora</segment>
    <segment id="31">, masmas entre as minhas muitas e grandes limitações está a da idade.</segment>
    <segment id="32">Sou velho numa época que evolui muito rápido.</segment>
    <segment id="33">Portanto</segment>
    <segment id="34">, avanço com cuidado no que tenho a dizer: nossos tempos são suscetíveis.</segment>
    <segment id="35">Parece-me que a destruição dos monumentos públicos que ocorre hoje em dia faz parte desse desejo de alterar o passado.</segment>
    <segment id="36">Eu ficaria muito feliz</segment>
    <segment id="37">sese todos dissessem:</segment>
    <segment id="38">“Vamos combinar que daqui para a frente não haverá mais estátuas celebrando feitos ou heróis”.</segment>
    <segment id="39">Porque celebrar feitos e heróis é a pior maneira de fazer história.</segment>
    <segment id="40">Ela fica assim unívoca</segment>
    <segment id="41">, simplificada</segment>
    <segment id="42">, para não dizer simplória.</segment>
    <segment id="43">E nenhum feito ou herói é sentido</segment>
    <segment id="44">comocomo positivo por todos.</segment>
    <segment id="45">Pela boa razão de que cada um de nós é sempre o canalha de alguém.</segment>
    <segment id="46">Mas estátuas assim existem há milênios e é muito provável que continuem a existir até o fim dos tempos.</segment>
    <segment id="47">Possuem uma presença poderosa</segment>
    <segment id="48">, animada por forças afirmativas que</segment>
    <segment id="49">sese querem eternas.</segment>
    <segment id="50">Encarnam convicções</segment>
    <segment id="51">, de modo material e expressivo.</segment>
    <segment id="52">São simbólicas e impositivas.</segment>
    <segment id="53">Por isso também concentram ódios.</segment>
    <segment id="54">Desde sempre que os vitoriosos destroem estátuas dos vencidos</segment>
    <segment id="55">, internos ou externos.</segment>
    <segment id="56">No antigo Egito</segment>
    <segment id="57">, faraós em desgraça tinham suas imagens desmanteladas ou ocultadas</segment>
    <segment id="58">para que</segment>
    <segment id="59">para que ninguém as visse.</segment>
    <segment id="60">Na União Soviética</segment>
    <segment id="61">, o filme “Outubro” (1928)</segment>
    <segment id="62">, de Eisenstein</segment>
    <segment id="63">, evidenciou a gigantesca força opressora do monumento ao czar Alexandre III</segment>
    <segment id="64">, para mostrá-lo depois despedaçado pelos revolucionários.</segment>
    <segment id="65">Sequência impressionante</segment>
    <segment id="66">, abre o filme apresentando-</segment>
    <segment id="67">sese como</segment>
    <segment id="68">como “a primeira vitória do proletariado no caminho para o socialismo”.</segment>
    <segment id="69">Não faz tanto tempo</segment>
    <segment id="70">, em 2003</segment>
    <segment id="71">, a enorme estátua de Saddam Hussein</segment>
    <segment id="72">, em Bagdá</segment>
    <segment id="73">, conheceu um destino semelhante</segment>
    <segment id="74">, transmitido em imagens que pareciam repetir o filme de Eisenstein.</segment>
    <segment id="75">Movimentos antirracistas</segment>
    <segment id="76">sese voltam contra estátuas de figuras coloniais e escravocratasMais    novamente         de   de  de  representando um    Portanto</segment>
    <segment id="77">, as estátuas são poderosas e podem inspirar afetos e ojerizas.</segment>
    <segment id="78">Eu detestaria ter na esquina da minha casa —ou simplesmente saber que existe— uma estátua de Bolsonaro ou Hitler e faria parte de todas as campanhas para eliminá-las.</segment>
    <segment id="79">É muito compreensível que pessoas</segment>
    <segment id="80">sese sintam feridas pela presença de algumas delas e que desejem sua liquidação.</segment>
    <segment id="81">Mas os impulsos demolidores</segment>
    <segment id="82">, justificáveis em efervescências coletivas</segment>
    <segment id="83">, não deveriam</segment>
    <segment id="84">, penso</segment>
    <segment id="85">, fazer parte de um programa que</segment>
    <segment id="86">sese prolongue.</segment>
    <segment id="87">Se eliminarmos todas as estátuas que julgamos ofensivas</segment>
    <segment id="88">, reformaremos o passado.</segment>
    <segment id="89">Esqueceremos que a história é a história das violências dos homens sobre os homens</segment>
    <segment id="90">, violências que algumas dessas estátuas celebraram.</segment>
    <segment id="91">Que nosso passado coletivo não é uma ficção hollywoodiana.</segment>
    <segment id="92">O que fazer então</segment>
    <segment id="93">, com essas estátuas?</segment>
    <segment id="94">Não creio que possa haver solução única.</segment>
    <segment id="95">Dois escultores</segment>
    <segment id="96">, Antonio Carlos Fortis e Waldo Bravo tiveram uma boa ideia: pôr jaula e correntes à volta do Borba Gato em Santo Amaro (estátua da qual</segment>
    <segment id="97">, contra a maioria absoluta de opinião</segment>
    <segment id="98">, eu gosto: seu excelente escultor</segment>
    <segment id="99">, Julio Guerra</segment>
    <segment id="100">, não era um imbecil e soube transformar o projeto heroico num bonecão ou fantoche</segment>
    <segment id="101">, criando um antimonumento.</segment>
    <segment id="102">Mas eles</segment>
    <segment id="103">, os monumentos</segment>
    <segment id="104">, não são afeitos à complexidade).</segment>
    <segment id="105">Belas ideias poderiam surgir para o Monumento às Bandeiras</segment>
    <segment id="106">, mais amado pelo prestígio modernista de seu autor</segment>
    <segment id="107">, que não destoaria</segment>
    <segment id="108">, porém</segment>
    <segment id="109">porém, na Itália de Mussolini ou no Portugal de Salazar</segment>
    <segment id="110">; como</segment>
    <segment id="111">como para o Duque de Caxias da praça Princesa Isabel</segment>
    <segment id="112">, despropósito de um heroísmo que pousa sobre um pedestal absurdamente alto</segment>
    <segment id="113">; para o Cabral</segment>
    <segment id="114">, de Morrone</segment>
    <segment id="115">, no Ibirapuera</segment>
    <segment id="116">, de um misticismo histérico.</segment>
    <segment id="117">As estátuas de pequeno porte são facilmente levadas para os museus</segment>
    <segment id="118">, que não são cemitérios</segment>
    <segment id="119">, masmas nos quais o passado retoma vida para mostrar seus horrores e tentar fazer com que eles não</segment>
    <segment id="120">sese repitam.</segment>
    <segment id="121">É importante que as gerações futuras saibam e sintam</segment>
    <segment id="122">comocomo a história foi violenta.</segment>
    <segment id="123">Protegê-las disso é expô-las à repetição do mal.</segment>
    <segment id="124">Estátuas paulistas exaltam heróis e escondem racismoMais    novamente         de   de  de  representando um</segment>
  </rst>
</analysis>