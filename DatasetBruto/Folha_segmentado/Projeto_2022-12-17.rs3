  <rst>
    <segment id="1">Panetones</segment>
    <segment id="2">, brinquedos</segment>
    <segment id="3">, cestas básicas e ração.</segment>
    <segment id="4">Assim, e com a ajuda de voluntários</segment>
    <segment id="5">, o projeto Moradores de Rua e Seus Cães realizaram neste fim de semana uma mega-ação de Natal em nove cidades de sete estados.</segment>
    <segment id="6">Foram atendidos moradores de rua e de ocupações</segment>
    <segment id="7">, além de seus animais de estimação.</segment>
    <segment id="8">Cachorro em ação realizada no Recife - MRSCRecife no Instagram</segment>
    <segment id="9">A iniciativa tem apoio da Petz e ocorreu em São Paulo</segment>
    <segment id="10">, Osasco</segment>
    <segment id="11">, Campinas</segment>
    <segment id="12">, Belo Horizonte</segment>
    <segment id="13">, Rio de Janeiro</segment>
    <segment id="14">, Florianópolis</segment>
    <segment id="15">, Porto Alegre</segment>
    <segment id="16">, Recife e Fortaleza —cidades onde o MRSC tem sede.</segment>
    <segment id="17">Em São Paulo</segment>
    <segment id="18">, o sábado (17) foi dia de entrega de cestas básicas</segment>
    <segment id="19">, panetones e brinquedos para crianças em ocupações.</segment>
    <segment id="20">A expectativa era atender 70 famílias</segment>
    <segment id="21">, o que inclui 135 crianças e 180 animais.</segment>
    <segment id="22">Já no domingo (18)</segment>
    <segment id="23">, a ação na capital paulista ocorreu na região do Arouche (centro) —a expectativa era a de atender 150 animais e até 300 pessoas em situação de rua.</segment>
    <segment id="24">O MRSC</segment>
    <segment id="25">, que completou sete anos no último dia 5</segment>
    <segment id="26">, costuma fazer ações mensais nas ruas de São Paulo.</segment>
    <segment id="27">Esta ação</segment>
    <segment id="28">, especial pelo país</segment>
    <segment id="29">, é a de número 92.</segment>
    <segment id="30">Segundo Eduardo Leporo</segment>
    <segment id="31">, idealizador do projeto</segment>
    <segment id="32">, o grupo passou a atender moradores de ocupações após a pandemia.  "</segment>
    <segment id="33">Com o início da pandemia</segment>
    <segment id="34">, a gente percebeu a necessidade de atender também as pessoas que moram em ocupações</segment>
    <segment id="35">, que tinham seu trabalho</segment>
    <segment id="36">, pagavam seu aluguelzinho social</segment>
    <segment id="37">, passaram a não ter mais condições de arcar com essas despesas</segment>
    <segment id="38">, das suas crianças</segment>
    <segment id="39">, do seu aluguel</segment>
    <segment id="40">, da sua alimentação</segment>
    <segment id="41">, dos seus pets.</segment>
    <segment id="42">"</segment>
    <segment id="43">Em outubro</segment>
    <segment id="44">, mês das crianças</segment>
    <segment id="45">, o projeto fez outra mega-ação</segment>
    <segment id="46">, em seis cidades</segment>
    <segment id="47">, em parceria com a editora Mol e a Petz.</segment>
    <segment id="48">Para os animais</segment>
    <segment id="49">, as ações levam</segment>
    <segment id="50">, além de ração</segment>
    <segment id="51">, vacinas</segment>
    <segment id="52">, antipulgas</segment>
    <segment id="53">, guias</segment>
    <segment id="54">, coleiras e banho.  "</segment>
    <segment id="55">A gente dá banho em todo animal de rua que vai na ação.</segment>
    <segment id="56">Tem animais de rua com 10</segment>
    <segment id="57">, 8 anos que nunca tinham tomado um banho com água quentinha</segment>
    <segment id="58">, com toalha.</segment>
    <segment id="59">Depois</segment>
    <segment id="60">, ele ganho guia</segment>
    <segment id="61">, coleira.</segment>
    <segment id="62">No inverno tem roupinha</segment>
    <segment id="63">, caminha</segment>
    <segment id="64">, a ração"</segment>
    <segment id="65">, conta Leporo.</segment>
    <segment id="66">Gatos também são atendidos</segment>
    <segment id="67">, em uma tenda separada dos cães para evitar o estresse.  "</segment>
    <segment id="68">Como nem só de ração vive um cão</segment>
    <segment id="69">, essa é a frase que nós criamos</segment>
    <segment id="70">, além da ração</segment>
    <segment id="71">, [os animais recebem] vacina</segment>
    <segment id="72">, vermífugo</segment>
    <segment id="73">, antipulga</segment>
    <segment id="74">, carrapaticida.</segment>
    <segment id="75">Não basta só dar comida</segment>
    <segment id="76">, tem também que cuidar da saúde deles.</segment>
    <segment id="77">"  Para isso</segment>
    <segment id="78">, o projeto conta com apoio da clínica Seres</segment>
    <segment id="79">, da Petz.</segment>
    <segment id="80">"</segment>
    <segment id="81">Vale ressaltar que vários funcionários da companhia</segment>
    <segment id="82">sese inscrevem</segment>
    <segment id="83">comocomo voluntários e dedicam o fim de semana para ajudar.</segment>
    <segment id="84">É uma ação que nos dá muito orgulho</segment>
    <segment id="85">, a alegria desses tutores ao ver seus pets recebendo tratamento é imensa"</segment>
    <segment id="86">, diz Giulliana Tessari</segment>
    <segment id="87">, gerente do Adote Petz</segment>
    <segment id="88">, programa de colaboração da rede de pet shop com ONGs e protetores parceiros.</segment>
    <segment id="89">Além da rede</segment>
    <segment id="90">, o MRSC conta com outras parcerias para suas ações</segment>
    <segment id="91">, como</segment>
    <segment id="92">como rações da Baw Waw</segment>
    <segment id="93">;</segment>
    <segment id="94">Perigot Cosméticos</segment>
    <segment id="95">, para o banho dos pets</segment>
    <segment id="96">;</segment>
    <segment id="97">ONG Banho de Gato</segment>
    <segment id="98">, que fornece kit higiene</segment>
    <segment id="99">; Banho Solidário e Banho de Amor</segment>
    <segment id="100">, com banho</segment>
    <segment id="101">, corte de cabelo e barba</segment>
    <segment id="102">; Pãozinho Solidário</segment>
    <segment id="103">, com lanches e água</segment>
    <segment id="104">; e motoclube Insanos.</segment>
    <segment id="105">"</segment>
    <segment id="106">Não basta só ter produto</segment>
    <segment id="107">, tem que ter</segment>
    <segment id="108">comocomo</segment>
    <segment id="109">sese locomover</segment>
    <segment id="110">, tem que ter dinheiro pelo menos para pôr a gasolina no carro"</segment>
    <segment id="111">, diz Leporo ao lembrar que</segment>
    <segment id="112">, apesar de toda a doação de produtos e serviços</segment>
    <segment id="113">, o projeto também conta com doações em dinheiro para</segment>
    <segment id="114">sese manter.  +</segment>
    <segment id="115">Bom</segment>
    <segment id="116">Pra CachorroCaramelo invade evento internacional de cães de raça</segment>
    <segment id="117">, mobiliza grupo e acaba adotadoCães para adoção</segment>
    <segment id="118">sese vestem para a Copa em ensaio fotográfico</segment>
    <segment id="119">;</segment>
    <segment id="120">vejaComo cuidar do cachorro em todas as fases da vida</segment>
    <segment id="121">; veja perguntas e respostasComo seu pet</segment>
    <segment id="122">sese comunica com você?</segment>
    <segment id="123">Siga o Bom Pra Cachorro no Twitter</segment>
    <segment id="124">, Instagram e Facebook</segment>
  </rst>
</analysis>