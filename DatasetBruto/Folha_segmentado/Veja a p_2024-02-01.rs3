  <rst>
    <segment id="1">A Netflix divulgou</segment>
    <segment id="2">, nesta quinta-feira (1°)</segment>
    <segment id="3">, a primeira imagem da minissérie que vai narrar a vida e a carreira de Ayrton Senna</segment>
    <segment id="4">, piloto de Fórmula 1 que virou ídolo internacional do esporte e que morreu num trágico acidente em 1994.</segment>
    <segment id="5">Fotos do ator Gabriel Leone e do piloto Ayrton Senna - Divulgação  Encarnado por Gabriel Leone</segment>
    <segment id="6">, o protagonista aparece coberto pelo capacete na primeira foto de cena</segment>
    <segment id="7">, ou seja</segment>
    <segment id="8">, de um trecho real do que será visto pelos espectadores nas telas.</segment>
    <segment id="9">A previsão é que "Senna" chegue à Netflix ainda neste ano.</segment>
    <segment id="10">Confira imagens da minissérie &amp;#039</segment>
    <segment id="11">;Senna&amp;#039</segment>
    <segment id="12">;, da NetflixMais    novamente         de   de  de  representando um</segment>
    <segment id="13">No elenco estão ainda Kaya Scodelario</segment>
    <segment id="14">, Matt Mella</segment>
    <segment id="15">, Susana Ribeiro</segment>
    <segment id="16">, Julia Foti</segment>
    <segment id="17">, Marco Ricca</segment>
    <segment id="18">, Camila Márdila</segment>
    <segment id="19">, Gabriel Louchard</segment>
    <segment id="20">, Christian Malheiros</segment>
    <segment id="21">, Hugo Bonemer</segment>
    <segment id="22">, Alice Wegmann e Pâmela Tomé.</segment>
    <segment id="23">Já a direção é de Julia Rezende e Vicente Amorim</segment>
    <segment id="24">, este também showrunner.</segment>
    <segment id="25">A produção é da Gullane.</segment>
    <segment id="26">Ao todo</segment>
    <segment id="27">, "Senna" terá seis episódios para mostrar</segment>
    <segment id="28">, pela primeira vez numa ficção</segment>
    <segment id="29">, a trajetória profissional e a vida íntima do piloto</segment>
    <segment id="30">, desde a sua mudança para a Inglaterra para competir no Fórmula Ford até o acidente fatal em Ímola</segment>
    <segment id="31">, na Itália.</segment>
    <segment id="32">Relações pessoais</segment>
    <segment id="33">, como</segment>
    <segment id="34">como o namoro com Xuxa</segment>
    <segment id="35">, também serão abordadas.</segment>
    <segment id="36">Isto é Ayrton SennaMais    novamente         de   de  de  representando</segment>
    <segment id="37">um</segment>
  </rst>
