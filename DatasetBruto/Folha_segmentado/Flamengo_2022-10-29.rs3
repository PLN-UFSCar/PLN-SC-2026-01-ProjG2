  <rst>
    <segment id="1">Neste sábado (29)</segment>
    <segment id="2">, às 17h</segment>
    <segment id="3">, Flamengo e Athletico-PR disputam a taça da Copa Libertadores da América.</segment>
    <segment id="4">A final acontece em Guayaquil</segment>
    <segment id="5">, no Equador</segment>
    <segment id="6">, e os torcedores podem assistir à partida em canais de TV aberta</segment>
    <segment id="7">, fechada e streaming.</segment>
    <segment id="8">O vencedor da terceira final consecutiva entre clubes brasileiros garante também uma vaga no Mundial de Clubes da Fifa.</segment>
    <segment id="9">O SBT transmite a partida na TV aberta e em seu site</segment>
    <segment id="10">, com narração de Téo José e comentários de Mauro Beting</segment>
    <segment id="11">, Mauro Cezar Pereira e Nadine Basttos.</segment>
    <segment id="12">A cobertura começará às 14h45</segment>
    <segment id="13">, com um programa pré-jogo.</segment>
    <segment id="14">A partir de 2023</segment>
    <segment id="15">, o torneio voltará a ser transmitido pela Globo.</segment>
    <segment id="16">Athletico tenta 'complicar o jogo' do 'confiante' Flamengo na final da Libertadores Final é exibida em bares de SP</segment>
    <segment id="17">; veja opções</segment>
    <segment id="18">Três anos depois do início</segment>
    <segment id="19">, fórmula da final única da Libertadores</segment>
    <segment id="20">é questionada</segment>
    <segment id="21">O estádio Monumental</segment>
    <segment id="22">, em Guyaquil</segment>
    <segment id="23">, é o palco da final - Dana Moreira - 23.ago.22/AFPA final também pode ser acompanhada pela ESPN</segment>
    <segment id="24">, na TV fechada</segment>
    <segment id="25">, e pelo streaming Star+</segment>
    <segment id="26">, ambos canais da Disney.</segment>
    <segment id="27">Campeão em 2019 e vice em 2021</segment>
    <segment id="28">, o Flamengo mira o tricampeonato.</segment>
    <segment id="29">Já o Athletico-PR</segment>
    <segment id="30">, vice-campeão em 2005</segment>
    <segment id="31">, disputa uma final de Libertadores pela segunda vez —</segment>
    <segment id="32">sese o time sair vitorioso</segment>
    <segment id="33">, Luiz Felipe Scolari será o primeiro técnico brasileiro com três títulos do torneio (antes</segment>
    <segment id="34">, ele venceu o campeonato liderando o Grêmio</segment>
    <segment id="35">, em 1995</segment>
    <segment id="36">, e o Palmeiras</segment>
    <segment id="37">, em 1999)  Final da Libertadores: 5 bares para assistir a partida entre Flamengo e Athletico-PRMais    novamente         de   de  de  representando um</segment>
  </rst>
