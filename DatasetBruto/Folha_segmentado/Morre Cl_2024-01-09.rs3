  <rst>
    <segment id="1">O jornalista Claudio Coletti</segment>
    <segment id="2">, primeiro diretor da Sucursal de Brasília da Folha</segment>
    <segment id="3">, morreu nesta terça-feira (9)</segment>
    <segment id="4">, aos 93 anos</segment>
    <segment id="5">, no município de Alcobaça (BA).</segment>
    <segment id="6">Nascido em Foz do Iguaçu (PR)</segment>
    <segment id="7">, em 1º de novembro de 1930</segment>
    <segment id="8">, Colleti começou no jornal em 1948</segment>
    <segment id="9">, aos 18 anos</segment>
    <segment id="10">, em São Paulo.</segment>
    <segment id="11">Foi para Brasília em 1960</segment>
    <segment id="12">, onde</segment>
    <segment id="13">sese tornou o primeiro diretor da sucursal.</segment>
    <segment id="14">O jornalista ficou na Folha até 1979.</segment>
    <segment id="15">Posteriormente</segment>
    <segment id="16">, fez assessoria para políticos e</segment>
    <segment id="17">sese mudou para o litoral baiano.</segment>
    <segment id="18">O jornalista Claudio Colletti - Pedro Ladeira - 18.out.20/FolhapressSegundo Cláudia</segment>
    <segment id="19">, filha de Colleti</segment>
    <segment id="20">, o jornalista morreu em casa —a família ainda aguarda laudo sobre a causa oficial.</segment>
    <segment id="21">Após iniciar na Redação auxiliando outros colegas de profissão</segment>
    <segment id="22">, como</segment>
    <segment id="23">como contínuo das Folhas da Manhã e da Noite</segment>
    <segment id="24">, Colleti interessou-</segment>
    <segment id="25">sese pelo jornalismo e começou a fazer pequenas reportagens.</segment>
    <segment id="26">O tino para a profissão fez com que recebesse atividades mais complexas</segment>
    <segment id="27">, como</segment>
    <segment id="28">como a cobertura jornalística de Jânio Quadros</segment>
    <segment id="29">, prefeito e governador de São Paulo nos anos 1950 e depois presidente da República.</segment>
    <segment id="30">Posteriormente</segment>
    <segment id="31">, foi convidado a dar continuidade à cobertura em Brasília.</segment>
    <segment id="32">Chegou à região 20 dias antes da inauguração da capital federal.</segment>
    <segment id="33">De lá, preparou a cobertura do evento com reportagens que eram datilografadas e enviadas a São Paulo em voos diários da Vasp.</segment>
    <segment id="34">Na cidade</segment>
    <segment id="35">, montou uma livraria e trabalhou na corregedoria geral da Justiça do Trabalho —a prática de duplo emprego era usual à época.</segment>
    <segment id="36">Registro profissional de Claudio Coletti</segment>
    <segment id="37">, primeiro diretor da Sucursal de Brasília   - ReproduçãoEm entrevista dada à Folha em 2021</segment>
    <segment id="38">, Colleti afirmou que o maior desafio da profissão foi a cobertura da vinda do general Charles de Gaulle</segment>
    <segment id="39">, então presidente da França</segment>
    <segment id="40">, ao Brasil</segment>
    <segment id="41">, em 1964.</segment>
    <segment id="42">Também em entrevista</segment>
    <segment id="43">, lembrou o período ditatorial</segment>
    <segment id="44">, em que D’Alembert Jaccoud</segment>
    <segment id="45">, um dos jornalistas da sucursal de Brasília</segment>
    <segment id="46">, foi torturado</segment>
    <segment id="47">, e os militares faziam pressão sobre o jornal.</segment>
    <segment id="48">Coletti deixou a Folha em 30 de agosto de 1979.</segment>
    <segment id="49">Depois disso</segment>
    <segment id="50">, fez assessoria a políticos</segment>
    <segment id="51">comocomo Franco Montoro (1916-1999) e Átila Lins (PP-AM).</segment>
    <segment id="52">Ele saiu da capital federal e</segment>
    <segment id="53">sese mudou para Alcobaça em 2020</segment>
    <segment id="54">, cidade na qual morreu.</segment>
    <segment id="55">Ele deixa os filhos Cláudia</segment>
    <segment id="56">, Paulo Cesar</segment>
    <segment id="57">, Cláudio</segment>
    <segment id="58">, Tânia e Patrícia.</segment>
    <segment id="59">Humanos da FolhaMais    novamente         de   de  de  representando</segment>
    <segment id="60">um</segment>
  </rst>
</analysis>