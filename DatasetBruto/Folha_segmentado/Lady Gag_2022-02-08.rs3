  <rst>
    <segment id="1">Não será desta vez que Lady Gaga ganhará o Oscar de melhor atriz.</segment>
    <segment id="2">Apesar de sua entrega ao interpretar Patrizia Reggiani em "Casa Gucci"</segment>
    <segment id="3">, longa de Ridley Scott que conta a história real de</segment>
    <segment id="4">comocomo a italiana planejou assassinar o marido</segment>
    <segment id="5">, herdeiro da grife de luxo</segment>
    <segment id="6">, a cantora ficou de fora da lista de indicações do prêmio este ano</segment>
    <segment id="7">, anunciadas na manhã desta terça (8).</segment>
    <segment id="8">Lady Gaga em cena do filme &amp;#039</segment>
    <segment id="9">;Casa Gucci&amp;#039</segment>
    <segment id="10">;, dirigido por Ridley Scott - DivulgaçãoGaga foi indicada ao Oscar de melhor atriz pela primeira vez em 2019</segment>
    <segment id="11">, por seu papel em "</segment>
    <segment id="12">Nasce uma Estrela".</segment>
    <segment id="13">No remake —a quarta encarnação da trama em Hollywood—</segment>
    <segment id="14">, interpretava uma aspirante a cantora que</segment>
    <segment id="15">sese envolve com um roqueiro famoso</segment>
    <segment id="16">, masmas com tendências autodestrutivas</segment>
    <segment id="17">, vivido por Bradley Cooper</segment>
    <segment id="18">, também diretor do filme.</segment>
    <segment id="19">A cantora perdeu para Olivia Colman em "</segment>
    <segment id="20">A Favorita"</segment>
    <segment id="21">, masmas não saiu da cerimônia sem um troféu nas mãos.</segment>
    <segment id="22">A música que ela compôs para a trilha sonora do longa</segment>
    <segment id="23">, "Shallow"</segment>
    <segment id="24">, abocanhou o prêmio de melhor canção original —e grudou na cabeça de muita gente</segment>
    <segment id="25">, com direito a uma versão em português cantada por Paula Fernandes e Luan Santana.</segment>
    <segment id="26">Este ano</segment>
    <segment id="27">, as suspeitas de uma possível indicação ao Oscar tinham ganhado tração na semana passada</segment>
    <segment id="28">, quando ela apareceu entre as concorrentes a melhor atriz no Bafta</segment>
    <segment id="29">, maior prêmio da indústria cinematográfica britânica.</segment>
    <segment id="30">Então, tomou o lugar de algumas das favoritas desta temporada</segment>
    <segment id="31">, caso</segment>
    <segment id="32">caso de Kristen Stewart</segment>
    <segment id="33">, por sua versão da princesa Diana em "Spencer"</segment>
    <segment id="34">, e Olivia Colman</segment>
    <segment id="35">, que protagoniza "</segment>
    <segment id="36">A Filha Perdida".</segment>
    <segment id="37">Mas, no Oscar</segment>
    <segment id="38">, os sinais</segment>
    <segment id="39">sese inverteram —Stewart e Colman seguem na disputa</segment>
    <segment id="40">, Gaga não.</segment>
    <segment id="41">Oscar 2022:</segment>
    <segment id="42">conheça as indicadas ao prêmio de melhor atrizMais    novamente         de   de  de  representando um  Em entrevistas</segment>
    <segment id="43">, Gaga afirmou que</segment>
    <segment id="44">sese dedicou intensamente ao seu papel em "Casa Gucci'</segment>
    <segment id="45">, com direito a adoção de um sotaque italiano e o uso de uma técnica de interpretação conhecida em Hollywood</segment>
    <segment id="46">comocomo "o método"</segment>
    <segment id="47">, em que o ator segue agindo</segment>
    <segment id="48">comocomo seu personagem mesmo com a câmera desligada.</segment>
    <segment id="49">Queria</segment>
    <segment id="50">sese comprometer com a arte "em um nível celular"</segment>
    <segment id="51">, como</segment>
    <segment id="52">como falou no programa "</segment>
    <segment id="53">The Late</segment>
    <segment id="54">Show</segment>
    <segment id="55">with Stephen Colbert".</segment>
    <segment id="56">"</segment>
    <segment id="57">Sinto isso quando canto</segment>
    <segment id="58">, quando componho</segment>
    <segment id="59">, e sinto isso quando atuo.</segment>
    <segment id="60">"</segment>
    <segment id="61">Apesar da recepção morna de "</segment>
    <segment id="62">Casa Gucci" pela imprensa americana</segment>
    <segment id="63">, a atuação de Gaga foi bastante elogiada.</segment>
    <segment id="64">Um crítico da revista Rolling Stone escreveu que</segment>
    <segment id="65">, sese o filme for lembrado por algo</segment>
    <segment id="66">, será por ser "a prova número um da grande atriz que ela [Gaga]</segment>
    <segment id="67">é".</segment>
    <segment id="68">"</segment>
    <segment id="69">Esqueçam Gucci.</segment>
    <segment id="70">Vida longa à casa que Gaga construiu"</segment>
    <segment id="71">, ele finaliza.</segment>
    <segment id="72">Imagens do filme &amp;#039</segment>
    <segment id="73">;House</segment>
    <segment id="74">of Gucci&amp;#039</segment>
    <segment id="75">; (&amp;#039</segment>
    <segment id="76">;Casa Gucci&amp;#039</segment>
    <segment id="77">;)Mais    novamente         de   de  de  representando</segment>
    <segment id="78">um</segment>
  </rst>
