  <rst>
    <segment id="1">Fora do ar desde o final de junho</segment>
    <segment id="2">, quando deixou o "Encontro"</segment>
    <segment id="3">, Fátima Bernardes é a nova apresentadora do concurso entre cantores</segment>
    <segment id="4">, que chega à 11ª temporada.</segment>
    <segment id="5">O júri é formado por Gaby Amarantos</segment>
    <segment id="6">, Iza, Lulu Santos e Michel Teló</segment>
    <segment id="7">, e Thaís Fersoza faz matérias nos bastidores.</segment>
    <segment id="8">O programa de estreia traz uma homenagem a Gal Costa.</segment>
    <segment id="9">Fátima</segment>
    <segment id="10">Bernardes à frente do palco do &amp;#</segment>
    <segment id="11">039;The Voice&amp;#039</segment>
    <segment id="12">;, que assume esta semana na programação da Globo - João CottaGlobo</segment>
    <segment id="13">, 22h25</segment>
    <segment id="14">, livre   7ª MOSTRA DO CINEMA CHINÊS</segment>
    <segment id="15">Sob o tema "China – Luzes e Sombras</segment>
    <segment id="16">, Sons e Sonhos"</segment>
    <segment id="17">, o festival online oferece oito longas inéditos no Brasil.</segment>
    <segment id="18">Entre os destaques</segment>
    <segment id="19">, o premiado "Chaogtu e Sarula"</segment>
    <segment id="20">, de Wang Rui</segment>
    <segment id="21">, e a animação "Reino de Terracota".</segment>
    <segment id="22">Programação completa: https://mostracinema.institutoconfucio.com.br.</segment>
    <segment id="23">Até 30/11.</segment>
    <segment id="24">www.ccsplay.com.br</segment>
    <segment id="25">, grátis   SAVAGE</segment>
    <segment id="26">X FENTY SHOW VOL.</segment>
    <segment id="27">4</segment>
    <segment id="28">O quarto desfile da grife de moda íntima da cantora Rihanna traz um modelo polêmico</segment>
    <segment id="29">, o ator Johnny Depp</segment>
    <segment id="30">, e uma apresentação da cantora brasileira Anitta.</segment>
    <segment id="31">Amazon Prime Video</segment>
    <segment id="32">, 14 anos   ED STAFFORD: VIDA DE CIGANO</segment>
    <segment id="33">O aventureiro britânico passou dois meses com uma comunidade cigana nômade</segment>
    <segment id="34">, percorrendo o Reino Unido.</segment>
    <segment id="35">Os dois episódios serão exibidos em sequência.  Discovery</segment>
    <segment id="36">, 19h40</segment>
    <segment id="37">, e Discovery+</segment>
    <segment id="38">, 12 anos   METRÓPOLES  Silvero Pereira e Gyl Giffony fazem irmãos que buscam</segment>
    <segment id="39">sese reconciliar neste espetáculo da Arte para Alimentar Inquieta Cia</segment>
    <segment id="40">, do Ceará</segment>
    <segment id="41">, que integra a programação do Palco Giratório.</segment>
    <segment id="42">Apresentações até 20/11.</segment>
    <segment id="43">Instagram do Sesc Brasil</segment>
    <segment id="44">, 20h   MASTERCHEF+</segment>
    <segment id="45">Mal terminou o "MasterChef</segment>
    <segment id="46">Profissionais" e a emissora já põe no ar uma nova variante do formato.</segment>
    <segment id="47">Agora os participantes são cozinheiros amadores</segment>
    <segment id="48">, entre 60 e 80 anos de idade.</segment>
    <segment id="49">Veja quem são os participantes do MasterChef+Mais    novamente         de   de  de  representando um  Band</segment>
    <segment id="50">, 22h45</segment>
    <segment id="51">, 10 anos   PROVOCA</segment>
    <segment id="52">O ex-jogador e colunista da Folha Walter Casagrande conversa com Marcelo Tas sobre sua saída da Globo</segment>
    <segment id="53">, sua relação com a mãe e a morte de sua irmã.</segment>
    <segment id="54">Também fala sobre os atuais craques do futebol brasileiro.  Cultura</segment>
    <segment id="55">, 22h, 10 anos</segment>
