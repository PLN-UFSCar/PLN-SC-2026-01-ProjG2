  <rst>
    <segment id="1">A cantora Preta Gil estará de volta ao Carnaval de Salvador e ao camarote Expresso 2222 neste ano.</segment>
    <segment id="2">Após se</segment>
    <segment id="3">se afastar da folia em 2023 para tratar um câncer</segment>
    <segment id="4">, a cantora</segment>
    <segment id="5">sese apresentará no badalado espaço VIP no domingo (11)</segment>
    <segment id="6">, ao lado de Ju Moraes e da Banda Sambaiana.  "</segment>
    <segment id="7">O Expresso 2222 é um símbolo e um marco no Carnaval de Salvador.</segment>
    <segment id="8">É um camarote que reúne diversidade</segment>
    <segment id="9">, música</segment>
    <segment id="10">, família</segment>
    <segment id="11">, artistas e traz para a cidade muita alegria e beleza"</segment>
    <segment id="12">, diz Preta.</segment>
    <segment id="13">A cantora Preta Gil</segment>
    <segment id="14">sese apresenta no show do seu pai</segment>
    <segment id="15">, Gilberto Gil</segment>
    <segment id="16">, com a família</segment>
    <segment id="17">, no Espaço Unimed</segment>
    <segment id="18">, em SP - onny Santos/FolhapressA cantora acaba de lançar o EP "</segment>
    <segment id="19">De Volta ao Sol".</segment>
    <segment id="20">O Expresso 2222 é o único camarote do Carnaval de Salvador que não tem venda de ingressos.</segment>
    <segment id="21">Toda a produção que envolve o espaço é realizada pela equipe liderada pela empresária Flora Gil</segment>
    <segment id="22">, mulher de Gilberto Gil</segment>
    <segment id="23">, pai de Preta.</segment>
    <segment id="24">O tema dos festejos em 2024 é "Brasilidade".</segment>
    <segment id="25">Em 25 anos de existência</segment>
    <segment id="26">, o Expresso já recebeu de Bono</segment>
    <segment id="27">, do U2</segment>
    <segment id="28">, a Quincy Jones e até a rainha Silvia</segment>
    <segment id="29">, da Suécia.</segment>
    <segment id="30">Preta GilMais    novamente         de   de  de  representando um   RELEITURA</segment>
    <segment id="31">Atores</segment>
    <segment id="32">sese reúnem em evento de lançamento de &amp;#039</segment>
    <segment id="33">;Renascer&amp;#039</segment>
    <segment id="34">;Mais    novamente         de   de  de  representando um</segment>
    <segment id="35">O ator Vladimir Brichta</segment>
    <segment id="36">, que dará vida ao vilão Egídio em "Renascer"</segment>
    <segment id="37">, prestigiou o evento de lançamento do remake da trama</segment>
    <segment id="38">, promovido pela Globo no Clube Monte Líbano</segment>
    <segment id="39">, no Rio de Janeiro</segment>
    <segment id="40">, na noite de quarta (17).</segment>
    <segment id="41">A atriz Eli Ferreira</segment>
    <segment id="42">, intérprete da professora Lu</segment>
    <segment id="43">, e o ator Humberto Carrão</segment>
    <segment id="44">, que fará o protagonista José Inocêncio na primeira fase</segment>
    <segment id="45">, também estiveram presentes.  com BIANKA VIEIRA (interina)</segment>
    <segment id="46">, KARINA MATIAS e MANOELLA SMITH</segment>
    <segment id="47">; colaborou GEOVANA</segment>
    <segment id="48">OLIVEIRA</segment>
  </rst>
