  <rst>
    <segment id="1">O sambista Moacyr Luz lança</segment>
    <segment id="2">, nesta sexta-feira (28)</segment>
    <segment id="3">, nas plataformas digitais</segment>
    <segment id="4">, o álbum "</segment>
    <segment id="5">A Música do Músico-Moacyr Luz e convidados</segment>
    <segment id="6">", com músicas inéditas ao lado de grandes instrumentistas</segment>
    <segment id="7">, em homenagem ao Rio de Janeiro.</segment>
    <segment id="8">Um show com o repertório do disco está programado para acontecer na Sala Municipal Baden Powell</segment>
    <segment id="9">, no Rio de Janeiro</segment>
    <segment id="10">, às 20h</segment>
    <segment id="11">, no dia 23 de novembro.</segment>
    <segment id="12">Antes do espetáculo</segment>
    <segment id="13">, às 19h</segment>
    <segment id="14">, haverá um bate-papo com Moacyr Luz contando sobre o processo de criação das músicas e as parcerias.</segment>
    <segment id="15">Ilustração em feltro da artista Jaca Almeida</segment>
    <segment id="16">, com reprodução da capa do álbum &amp;#039</segment>
    <segment id="17">;A Música do Músico-Moacyr Luz e convidados&amp;#039</segment>
    <segment id="18">; - Fotomontagem Carlos Bozzo Junior/FolhapressPara compor o álbum</segment>
    <segment id="19">, Moacyr Luz convidou 11 parceiros instrumentistas e compositores</segment>
    <segment id="20">, moradores ou nascidos na cidade do Rio de Janeiro.</segment>
    <segment id="21">Além de terem algum vínculo com a cidade maravilhosa</segment>
    <segment id="22">, todos os envolvidos são amigos de estrada</segment>
    <segment id="23">, de alguma parceria anterior ou de admiração do artista.</segment>
    <segment id="24">Entre os nomes que figuram no disco estão Carlinhos 7 Cordas</segment>
    <segment id="25">, Ricardo Silveira</segment>
    <segment id="26">, Alaan Monteiro</segment>
    <segment id="27">, Bebê Krammer</segment>
    <segment id="28">, Hamilton de Holanda</segment>
    <segment id="29">, Zé Paulo Becker</segment>
    <segment id="30">, Rogerio Caetano</segment>
    <segment id="31">, Paulo Malaguti Pauleira</segment>
    <segment id="32">, Carlos Malta</segment>
    <segment id="33">, Guinga e o maestro Cristóvão Bastos</segment>
    <segment id="34">, que pela primeira vez mostra a sua voz em uma canção.</segment>
    <segment id="35">"</segment>
    <segment id="36">Acho que este disco é uma demonstração do amor que eu tenho pela música em si.</segment>
    <segment id="37">A devoção e a minha entrega a um trabalho têm uma sintonia</segment>
    <segment id="38">, modestamente falando</segment>
    <segment id="39">, um pouco elevada</segment>
    <segment id="40">, sem preocupação com modismos"</segment>
    <segment id="41">, disse Moa.</segment>
    <segment id="42">LANÇAMENTO CD ‘</segment>
    <segment id="43">A MÚSICA DO MÚSICO-MOACYR LUZ E CONVIDADOS’  QUANDO Sexta-feira (28)  ONDE Plataformas digitais</segment>
    <segment id="44">SHOW</segment>
    <segment id="45">Lançamento do CD "</segment>
    <segment id="46">A Música do Músico-Moacyr Luz e convidados</segment>
    <segment id="47">"</segment>
    <segment id="48">QUANDO</segment>
    <segment id="49">Dia 23 de novembro</segment>
    <segment id="50">, às 20h</segment>
    <segment id="51">;</segment>
    <segment id="52">conversa com o compositor</segment>
    <segment id="53">, às 19h  ONDE Sala Municipal Baden Powell</segment>
    <segment id="54">, Av. Nossa Sra. de Copacabana</segment>
    <segment id="55">, 360, Copacabana</segment>
    <segment id="56">, Rio de Janeiro</segment>
    <segment id="57">, tel. (21)</segment>
    <segment id="58">2547-9147  QUANTO R$ 10</segment>
  </rst>
</analysis>