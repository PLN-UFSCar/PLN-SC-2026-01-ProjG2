  <rst>
    <segment id="1">A Polícia Civil do Rio de Janeiro vai notificar os compradores dos quadros envolvidos em investigação de roubo milionário</segment>
    <segment id="2">para que</segment>
    <segment id="3">para que devolvam as obras.</segment>
    <segment id="4">Entre os 16 quadros alvos da operação</segment>
    <segment id="5">, há pinturas de Tarsila do Amaral</segment>
    <segment id="6">, Cícero Dias e Di Cavalcanti.</segment>
    <segment id="7">​  Os quadros faziam parte do acervo da francesa Geneviève Rose Coll Boghici</segment>
    <segment id="8">, 82, herdados há sete anos após a morte do marido</segment>
    <segment id="9">, o marchand romeno Eugéne Boghici</segment>
    <segment id="10">, conhecido</segment>
    <segment id="11">comocomo Jean Boghici.</segment>
    <segment id="12">A filha do casal</segment>
    <segment id="13">, Sabine Coll Boghici</segment>
    <segment id="14">, e a vidente Rosa Stanesco Nicolau</segment>
    <segment id="15">, conhecida</segment>
    <segment id="16">comocomo mãe Valéria de Oxóssi</segment>
    <segment id="17">, estão entre os presos.</segment>
    <segment id="18">O grupo acusado de aplicar na viúva um golpe estimado em R$ 725 milhões foi alvo de operação na última quarta (10)</segment>
    <segment id="19">, na capital fluminense.</segment>
    <segment id="20">O "Elevador Social" (1966)</segment>
    <segment id="21">, de Rubens Gerchman</segment>
    <segment id="22">, e "Maquete para Meu Espelho" (1964)</segment>
    <segment id="23">, de Antonio Dias</segment>
    <segment id="24">, são os dois quadros que faltam ainda serem recuperados pela polícia.</segment>
    <segment id="25">Policiais retiram de viatura quadros apreendidos em operação no Rio de Janeiro - Mariana Moreira/FolhapressDos 16 quadros que foram roubados</segment>
    <segment id="26">, segundo a polícia</segment>
    <segment id="27">, 11 foram encontrados na casa da vidente</segment>
    <segment id="28">, embaixo de uma cama.</segment>
    <segment id="29">Os outros cinco foram vendidos para uma galeria em São Paulo.</segment>
    <segment id="30">A própria vítima</segment>
    <segment id="31">, conforme os investigadores</segment>
    <segment id="32">, recebeu a informação de que as obras estavam nessa galeria</segment>
    <segment id="33">, e a polícia conseguiu recuperar três telas diretamente com a empresa</segment>
    <segment id="34">, "</segment>
    <segment id="35">O Sono"</segment>
    <segment id="36">, de Tarsila do Amaral</segment>
    <segment id="37">, "</segment>
    <segment id="38">O Menino"</segment>
    <segment id="39">, de Alberto Guingnard</segment>
    <segment id="40">, e "Mascaradas"</segment>
    <segment id="41">, de Di Cavalcanti.</segment>
    <segment id="42">As outras duas</segment>
    <segment id="43">, "Elevador Social"</segment>
    <segment id="44">, de Rubens Gerchman</segment>
    <segment id="45">, e "Maquete para Meu Espelho"​</segment>
    <segment id="46">, de Antonio Dias</segment>
    <segment id="47">, porém</segment>
    <segment id="48">porém, já foram vendidas para a coleção privada do argentino Eduardo Costantini</segment>
    <segment id="49">, fundador do Malba (Museu de Arte Latino-Americana de Buenos Aires).</segment>
    <segment id="50">No entanto</segment>
    <segment id="51">, não será tão simples reaver esses trabalhos.</segment>
    <segment id="52">Trazer essas pinturas de volta pode significar dar início a um longo processo</segment>
    <segment id="53">, seja ele movido pela proprietária ou pelo próprio Estado</segment>
    <segment id="54">, segundo especialistas ouvidos pela Folha.</segment>
    <segment id="55">A proprietária mesmo pode entrar numa disputa judicial para reaver os itens alegando que esses foram vendidos a "non domino" —ou seja</segment>
    <segment id="56">, uma comercialização que não foi feita pelo proprietário e que é</segment>
    <segment id="57">, portanto</segment>
    <segment id="58">, inválida.</segment>
    <segment id="59">Para isso</segment>
    <segment id="60">, ela vai ter que provar que não</segment>
    <segment id="61">sese desfez dos quadros nem tinha intenção de repassá-los para a filha.</segment>
    <segment id="62">Se Sabine utilizou</segment>
    <segment id="63">, por exemplo</segment>
    <segment id="64">, uma procuração no nome da mãe para a venda</segment>
    <segment id="65">, aí já fica mais difícil que Geneviève reverta a venda.</segment>
    <segment id="66">Veja obras de arte que filha roubou da mãe no Rio de Janeiro</segment>
    <segment id="67">, segundo a políciaMais    novamente         de   de  de  representando um</segment>
    <segment id="68">Um advogado especialista na área cultural que pediu para não ser identificado afirma que</segment>
    <segment id="69">, no caso</segment>
    <segment id="70">caso das obras que tiverem sido vendidas mediante a intermediação de uma galeria</segment>
    <segment id="71">, como</segment>
    <segment id="72">como no</segment>
    <segment id="73">casocaso das transações internacionais</segment>
    <segment id="74">, a empresa também pode ser levada à Justiça.</segment>
    <segment id="75">Isso porque</segment>
    <segment id="76">porque</segment>
    <segment id="77">, neste</segment>
    <segment id="78">casocaso</segment>
    <segment id="79">, foi responsabilidade dela a venda.  Todos esses imbróglios podem levar anos para</segment>
    <segment id="80">sese resolver</segment>
    <segment id="81">, principalmente os das pinturas que estão na Argentina.</segment>
    <segment id="82">Duas convenções estabelecem</segment>
    <segment id="83">comocomo esses trâmites podem ser feitos</segment>
    <segment id="84">, explica Marcelo Frullani</segment>
    <segment id="85">, advogado especializado pela USP e sócio do escritório Frullani Lopes Advogados.</segment>
    <segment id="86">"</segment>
    <segment id="87">Os órgãos internacionais preveem que deve haver restituição do bem quanto ele é exportado de forma ilícita.</segment>
    <segment id="88">O objetivo é proteger não só o proprietário do bem</segment>
    <segment id="89">, masmas também o patrimônio cultural do Brasil"</segment>
    <segment id="90">, explica.</segment>
    <segment id="91">Apesar de não serem tombadas</segment>
    <segment id="92">comocomo os trabalhos da Tarsila</segment>
    <segment id="93">, as duas pinturas são importantes para a produção brasileira.</segment>
    <segment id="94">Dias teve protagonismo na vanguarda dos anos 1960</segment>
    <segment id="95">, ao lado de Gerchman.</segment>
    <segment id="96">E, neste</segment>
    <segment id="97">casocaso</segment>
    <segment id="98">, o Estado mesmo pode comprovar que elas têm uma importância para o repertório nacional e demandar seu retorno.</segment>
    <segment id="99">O direito estabelece que a devolução deve respeitar as convenções internacionais.</segment>
    <segment id="100">E isso também não afasta a possibilidade de quem adquiriu a obra comprovar boa-fé na compra com documentos e registros —e até pedir uma indenização ao provar isso.</segment>
    <segment id="101">O que se</segment>
    <segment id="102">se sabe sobre as obras de arte roubadas</segment>
    <segment id="103">Mais    novamente         de   de  de  representando um</segment>
    <segment id="104">De acordo com o delegado responsável pelo</segment>
    <segment id="105">casocaso</segment>
    <segment id="106">, Gilberto Ribeiro</segment>
    <segment id="107">, o comprador argentino será notificado e terá que devolver as obras.</segment>
    <segment id="108">Ainda segundo Ribeiro</segment>
    <segment id="109">, no entanto</segment>
    <segment id="110">, quem adquiriu os quadros envolvidos no</segment>
    <segment id="111">casocaso não será investigado</segment>
    <segment id="112">comocomo criminoso.</segment>
    <segment id="113">O dono da galeria de arte de São Paulo disse à polícia que não desconfiou que as obras haviam sido roubadas da idosa.</segment>
    <segment id="114">Ele afirmou conhecer a família e ter recebido os quadros da própria filha da proprietária.</segment>
    <segment id="115">"</segment>
    <segment id="116">Elas foram adquiridas de forma irregular.</segment>
    <segment id="117">A pessoa pode até ter tido boa-fé</segment>
    <segment id="118">, masmas não observou corretamente o cuidado de adquirir uma obra da pessoa que é proprietária dessa obra.</segment>
    <segment id="119">'</segment>
    <segment id="120">Ah, eu adquiri da Sabine [filha da viúva]'.</segment>
    <segment id="121">Bom, tudo bem</segment>
    <segment id="122">, masmas Sabine não era a dona.</segment>
    <segment id="123">Então, eles erraram</segment>
    <segment id="124">, no mínimo"</segment>
    <segment id="125">, afirmou o delegado.</segment>
    <segment id="126">"</segment>
    <segment id="127">Nós optamos por não ouvir as pessoas e optamos por não provocar nenhuma situação antes</segment>
    <segment id="128">porque</segment>
    <segment id="129">porque não tínhamos interesse estratégico de irmos atrás antes.</segment>
    <segment id="130">Agora, podemos ouvir todo mundo"</segment>
    <segment id="131">, disse também Ribeiro.</segment>
    <segment id="132">Leia mais sobre o casoFilha é presa acusada de roubar da mãe R$ 725 mi</segment>
    <segment id="133">, incluindo quadro de TarsilaQuem é Sabine Boghici</segment>
    <segment id="134">, presa por golpe com quadro de Tarsila do AmaralQuem foi Jean Boghici</segment>
    <segment id="135">, colecionador de arte pivô de roubo de Tarsila do AmaralConheça a história por trás de obra roubada de Tarsila do Amaral</segment>
    <segment id="136">, &amp;#</segment>
    <segment id="137">039;Sol Poente&amp;#039</segment>
    <segment id="138">;Obras de golpe que envolveu Tarsila do Amaral já saíram do Brasil</segment>
    <segment id="139">;</segment>
    <segment id="140">entendaAs obras</segment>
    <segment id="141">, após serem recuperadas</segment>
    <segment id="142">, segundo a polícia</segment>
    <segment id="143">, precisam voltar à idosa que é proprietária delas.</segment>
    <segment id="144">Ela, por sua vez</segment>
    <segment id="145">, pode decidir manter as vendas</segment>
    <segment id="146">, desde que as negociações sigam o trâmite legal.</segment>
    <segment id="147">"</segment>
    <segment id="148">Não vou dizer aqui que houve crime por parte do comprador</segment>
    <segment id="149">, masmas errou.</segment>
    <segment id="150">Na medida que ele compra roubada</segment>
    <segment id="151">, essa obra</segment>
    <segment id="152">tem que ser devolvida para recuperar.</segment>
    <segment id="153">E sese</segment>
    <segment id="154">, mais tarde</segment>
    <segment id="155">, essas obras forem vendidas de novo</segment>
    <segment id="156">, não sei.</segment>
    <segment id="157">Mas isso só vai ser possível saber depois que elas forem recuperadas</segment>
    <segment id="158">, apreendidas e entregues à idosa"</segment>
    <segment id="159">, conclui o delegado.</segment>
    <segment id="160">Numa entrevista ao jornal La Nación</segment>
    <segment id="161">, Constantini afirmou que Geneviève já disse a ele que não tem interesse em pedir as obras de volta.</segment>
    <segment id="162">​</segment>
  </rst>
</analysis>