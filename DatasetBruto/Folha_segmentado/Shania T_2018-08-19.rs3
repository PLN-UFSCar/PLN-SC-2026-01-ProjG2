  <rst>
    <segment id="1">Ao pisar no palco do lotado estádio de rodeios de Barretos na madrugada deste domingo (19)</segment>
    <segment id="2">, a cantora canadense Shania Twain apresentou cinco canções de seu novo álbum</segment>
    <segment id="3">, lançado após 15 anos</segment>
    <segment id="4">, masmas levantou o público da Festa do Peão de Boiadeiro em seu primeiro show no país foi com seus clássicos.</segment>
    <segment id="5">Todos, de "</segment>
    <segment id="6">Any Man of Mine" ao superhit "Man!</segment>
    <segment id="7">I Feel Like a Woman!</segment>
    <segment id="8">", embalaram as 55 mil pessoas presentes à noite mais aguardada da década na tradicional festa de Barretos (a 423 km de São Paulo).</segment>
    <segment id="9">O show foi aberto pelo cantor suíço Bastian Baker e</segment>
    <segment id="10">, pontualmente à 0h</segment>
    <segment id="11">, a banda da canadense subiu ao palco.</segment>
    <segment id="12">A apresentação de Shania</segment>
    <segment id="13">, que integrou a turnê "Now"</segment>
    <segment id="14">, foi dividida em cinco partes.</segment>
    <segment id="15">63º</segment>
    <segment id="16">Festa do Peão de Barretos 2018   novamente         de   de  de  representando um  Foram 20 musicas</segment>
    <segment id="17">, sem direito a bis</segment>
    <segment id="18">, num show de uma hora e quarenta minutos</segment>
    <segment id="19">, em que a cantora arriscou palavras em português —algumas com auxílio de ponto eletrônico.</segment>
    <segment id="20">A abertura foi com a canção de seu novo álbum "</segment>
    <segment id="21">Life</segment>
    <segment id="22">'s About to Get Good"</segment>
    <segment id="23">, que não foi bem nas paradas norte-americanas e que na arena de Barretos também não empolgou.</segment>
    <segment id="24">​</segment>
    <segment id="25">Na sequência</segment>
    <segment id="26">, embalou "</segment>
    <segment id="27">Come on</segment>
    <segment id="28">Over</segment>
    <segment id="29">"</segment>
    <segment id="30">, que dá nome ao terceiro álbum de estúdio da canadense</segment>
    <segment id="31">, de 1997</segment>
    <segment id="32">, e “Up”</segment>
    <segment id="33">, que mostraram ao público que a Shania desejada pela organização do evento desde a década passada estava presente.</segment>
    <segment id="34">Seus sucessos são tocados nos carros e rádios o tempo todo na cidade</segment>
    <segment id="35">, especialmente nas últimas semanas.</segment>
    <segment id="36">Engatou em seguida "</segment>
    <segment id="37">Poor</segment>
    <segment id="38">Me", do novo álbum</segment>
    <segment id="39">, e "</segment>
    <segment id="40">Don't Be Stupid".</segment>
    <segment id="41">O estilo próprio de Shania</segment>
    <segment id="42">, que mistura country e pop</segment>
    <segment id="43">, deu o tom a todo o show</segment>
    <segment id="44">, que entrou em sua segunda parte com "That Don't Impress Me Much" e a melosa "From This Moment" —o primeiro momento de catarse no estádio.</segment>
    <segment id="45">"</segment>
    <segment id="46">Any Man of Mine"</segment>
    <segment id="47">, uma das responsáveis por catapultar a carreira da canadense</segment>
    <segment id="48">comocomo ícone country nos anos 90 e que por aqui fez sucesso também na versão “Etc e Tal”</segment>
    <segment id="49">, de Sandy &amp;amp</segment>
    <segment id="50">; Junior</segment>
    <segment id="51">, veio na sequência e enlouqueceu o estádio de rodeios do Parque do Peão --projetado por Oscar Niemeyer (1907-2012).</segment>
    <segment id="52">Ela foi seguida por “Whose Bed Have Your Boots Been Under?</segment>
    <segment id="53">”, “Honey</segment>
    <segment id="54">, I’m Home” e “I’m Alright”</segment>
    <segment id="55">, outra do novo álbum.</segment>
    <segment id="56">A romântica “You’re Still the One” e “More Fun”</segment>
    <segment id="57">, do novo disco</segment>
    <segment id="58">, precederam “I’m Gonna Getcha Good”</segment>
    <segment id="59">, country pop da cantora.</segment>
    <segment id="60">“</segment>
    <segment id="61">Party for Two”</segment>
    <segment id="62">, “Swingin’ with my Eyes Closed” e “I’m Outta Here” fecharam a quarta parte.</segment>
    <segment id="63">A parte final do show foi composta pela instrumental “Blue Storm”</segment>
    <segment id="64">, o megahit "Man!</segment>
    <segment id="65">I Feel Like a Woman!</segment>
    <segment id="66">" e “Rock This Country”</segment>
    <segment id="67">Shania Twain   novamente         de   de  de  representando um    RECORDE</segment>
    <segment id="68">A apresentação de Shania custou US$ 1</segment>
    <segment id="69">,1 milhão (R$ 4</segment>
    <segment id="70">,3 milhões)</segment>
    <segment id="71">, a maior contratação da história de Barretos</segment>
    <segment id="72">, masmas a avaliação feita por integrantes de Os Independentes</segment>
    <segment id="73">, associação que organiza a festa</segment>
    <segment id="74">, é que “o show</segment>
    <segment id="75">sese pagou" e que o retorno de imagem do evento é outro ponto a ser avaliado.</segment>
    <segment id="76">Além do cachê</segment>
    <segment id="77">, um avião buscou a cantora nos EUA.</segment>
    <segment id="78">O voo fretado custou cerca de US$ 100 mil (R$ 391 mil).</segment>
    <segment id="79">À tarde</segment>
    <segment id="80">, protegida por um guarda-chuvas preto</segment>
    <segment id="81">, a cantora já tinha feito passagem de som de cerca de duas horas sob um sol forte.</segment>
    <segment id="82">O estádio estava fechado</segment>
    <segment id="83">, masmas a Folha acompanhou parte da preparação.</segment>
    <segment id="84">Ao deixar o local</segment>
    <segment id="85">, às 16h</segment>
    <segment id="86">, ao menos 50 fãs a aguardavam na entrada do veículo que a levou para a fazenda em que está hospedada</segment>
    <segment id="87">, do empresário Henrique Prata</segment>
    <segment id="88">, gestor do Hospital de Amor –novo nome do Hospital de Câncer de Barretos.</segment>
    <segment id="89">Após o show no interior paulista</segment>
    <segment id="90">, a turnê terá uma pausa de um mês e voltará na Europa</segment>
    <segment id="91">, com apresentações em Glasgow</segment>
    <segment id="92">, Manchester</segment>
    <segment id="93">, Birmingham</segment>
    <segment id="94">, Dublin</segment>
    <segment id="95">, Belfast e Londres.</segment>
    <segment id="96">Shania tem figurado em rankings das cantoras mais bem pagas do mundo.</segment>
    <segment id="97">Em 2016</segment>
    <segment id="98">, por exemplo</segment>
    <segment id="99">, amealhou US$ 27</segment>
    <segment id="100">,5 milhões (R$ 107</segment>
    <segment id="101">,25 milhões)</segment>
    <segment id="102">, segundo a Forbes.</segment>
  </rst>
</analysis>