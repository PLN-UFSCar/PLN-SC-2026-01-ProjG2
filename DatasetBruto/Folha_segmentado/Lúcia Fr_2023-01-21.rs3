  <rst>
    <segment id="1">Lúcia França (PSB)</segment>
    <segment id="2">, que estreou nas urnas</segment>
    <segment id="3">comocomo candidata a vice de Fernando Haddad (PT) na corrida ao Governo de São Paulo em 2022</segment>
    <segment id="4">, tem sido estimulada por aliados dela e do marido</segment>
    <segment id="5">, o ministro Márcio França (Portos e Aeroportos)</segment>
    <segment id="6">, a disputar em 2024 a Prefeitura de São Vicente</segment>
    <segment id="7">, berço político do casal.</segment>
    <segment id="8">Ela diz que ainda é cedo para</segment>
    <segment id="9">sese posicionar</segment>
    <segment id="10">, por ter recém-saído de "uma campanha acirrada".</segment>
    <segment id="11">"</segment>
    <segment id="12">Saí muito fortalecida</segment>
    <segment id="13">, aprendi bastante em muitos aspectos"</segment>
    <segment id="14">, afirma a ex-primeira-dama paulista.</segment>
    <segment id="15">Entusiastas da candidatura dizem que a imagem dela</segment>
    <segment id="16">sese fortaleceu na cidade após a campanha do ano passado e levaram a ideia à professora</segment>
    <segment id="17">, que inicialmente não teria descartado a hipótese.</segment>
    <segment id="18">A professora Lúcia França (PSB)</segment>
    <segment id="19">, que foi candidata a vice-governadora de Fernando Haddad (PT) - Karime Xavier - 13.set.2022/FolhapressO irmão dela</segment>
    <segment id="20">, Pedro Gouvêa (MDB)</segment>
    <segment id="21">, foi prefeito de São Vicente entre 2017 e 2020</segment>
    <segment id="22">, quando tentou a reeleição e não chegou ao segundo turno.</segment>
    <segment id="23">O atual governante da cidade é Kayo Amado (Podemos).</segment>
    <segment id="24">Para o clã França</segment>
    <segment id="25">, retomar o poder local ganhou importância depois de Márcio perder a corrida a uma vaga no Senado e da derrota da chapa Haddad/Lúcia.</segment>
    <segment id="26">Os rumos eleitorais da família</segment>
    <segment id="27">, que inclui ainda o deputado estadual Caio França (PSB)</segment>
    <segment id="28">, estão em aberto.</segment>
    <segment id="29">Professora Lúcia França</segment>
    <segment id="30">, mulher do ex-governador Márcio FrançaMais    novamente         de   de  de  representando um</segment>
  </rst>
