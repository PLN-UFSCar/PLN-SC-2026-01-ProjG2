  <rst>
    <segment id="1">A falta de variedades de cerveja nos supermercados bateu recorde em novembro e chegou a 19</segment>
    <segment id="2">,5%, segundo monitoramento da Neogrid</segment>
    <segment id="3">, de software para o varejo.</segment>
    <segment id="4">O indicador mostra que</segment>
    <segment id="5">, em m&amp;eacute</segment>
    <segment id="6">;dia, de cada cinco produtos</segment>
    <segment id="7">, considerando marca</segment>
    <segment id="8">, tamanho da embalagem e outras caracter&amp;iacute</segment>
    <segment id="9">;sticas</segment>
    <segment id="10">, um estava em falta.</segment>
    <segment id="11">H&amp;aacute</segment>
    <segment id="12">; um ano</segment>
    <segment id="13">, o &amp;iacute</segment>
    <segment id="14">;ndice era de 12%.  Rodrigo Le&amp;atilde</segment>
    <segment id="15">;o, diretor da Neogrid</segment>
    <segment id="16">, diz que a falta de produtos</segment>
    <segment id="17">sese concentrou nas marcas premium</segment>
    <segment id="18">, com custo acima de R$ 6.</segment>
    <segment id="19">Segundo ele ap&amp;oacute</segment>
    <segment id="20">;s per&amp;iacute</segment>
    <segment id="21">;odo de menor consumo</segment>
    <segment id="22">, clientes est&amp;atilde</segment>
    <segment id="23">;o buscando itens mais caros e em maior volume.</segment>
    <segment id="24">O mercado cervejeiro sofre com a falta de insumos</segment>
    <segment id="25">, como</segment>
    <segment id="26">como alum&amp;iacute</segment>
    <segment id="27">;nio, vidro e papel&amp;atilde</segment>
    <segment id="28">;o.</segment>
    <segment id="29">O Sindicerv (Sindicato Nacional da Ind&amp;uacute</segment>
    <segment id="30">;stria da Cerveja) diz que busca junto aos fornecedores solu&amp;ccedil</segment>
    <segment id="31">;&amp;otilde</segment>
    <segment id="32">;es para normalizar a situa&amp;ccedil</segment>
    <segment id="33">;&amp;atilde</segment>
    <segment id="34">;o.</segment>
    <segment id="35">Ida ao supermercado requer cuidados especiais   novamente         de   de  de  representando um   *</segment>
    <segment id="36">A C&amp;acirc</segment>
    <segment id="37">;mara Brasileira da Ind&amp;uacute</segment>
    <segment id="38">;stria da Constru&amp;ccedil</segment>
    <segment id="39">;&amp;atilde</segment>
    <segment id="40">;o (CBIC)</segment>
    <segment id="41">prev&amp;ecirc</segment>
    <segment id="42">; crescimento de 4% da produ&amp;ccedil</segment>
    <segment id="43">;&amp;atilde</segment>
    <segment id="44">;o do setor no pr&amp;oacute</segment>
    <segment id="45">;ximo ano</segment>
    <segment id="46">, principalmente com o desenvolvimento dos empreendimentos imobili&amp;aacute</segment>
    <segment id="47">;rios contratados neste ano.</segment>
    <segment id="48">Ser&amp;aacute</segment>
    <segment id="49">; o melhor desempenho das construtoras desde 2013</segment>
    <segment id="50">, sese for confirmado.</segment>
    <segment id="51">As empresas do setor sofreram nos &amp;uacute</segment>
    <segment id="52">;ltimos meses com a alta dos pre&amp;ccedil</segment>
    <segment id="53">;os praticados por fornecedores.</segment>
    <segment id="54">Para o presidente da CBIC</segment>
    <segment id="55">, Jos&amp;eacute</segment>
    <segment id="56">; Carlos Martins</segment>
    <segment id="57">, o desequil&amp;iacute</segment>
    <segment id="58">;brio na oferta de insumos de algumas cadeias</segment>
    <segment id="59">, especialmente na ind&amp;uacute</segment>
    <segment id="60">;stria sider&amp;uacute</segment>
    <segment id="61">;rgica e na petroqu&amp;iacute</segment>
    <segment id="62">;mica, ainda dever&amp;aacute</segment>
    <segment id="63">; demorar para ser resolvido.   *</segment>
    <segment id="64">O gasto m&amp;eacute</segment>
    <segment id="65">;dio dos brasileiros com animais de estima&amp;ccedil</segment>
    <segment id="66">;&amp;atilde</segment>
    <segment id="67">;o subiu 10% em um ano</segment>
    <segment id="68">, segundo an&amp;aacute</segment>
    <segment id="69">;lise do aplicativo de gerenciamento financeiro GuiaBolso.</segment>
    <segment id="70">Em m&amp;eacute</segment>
    <segment id="71">;dia, os consumidores avaliados gastaram R$ 97 por m&amp;ecirc</segment>
    <segment id="72">;s com os bichos.</segment>
    <segment id="73">Ricardo Balthazar (interino)</segment>
    <segment id="74">, com Filipe Oliveira e Mariana Grazini</segment>
  </rst>
</analysis>