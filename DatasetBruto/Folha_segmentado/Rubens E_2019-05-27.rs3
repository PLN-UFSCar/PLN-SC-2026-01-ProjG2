  <rst>
    <segment id="1">Crítico de cinema mais famoso do país</segment>
    <segment id="2">, até o ano passado responsável pelas transmissões e comentários do Oscar</segment>
    <segment id="3">, Rubens Ewald Filho</segment>
    <segment id="4">, 74 anos</segment>
    <segment id="5">, sofreu um infarto neste fim de semana</segment>
    <segment id="6">, O jornalista estava em um shopping quando desfaleceu e caiu numa escada rolante</segment>
    <segment id="7">, batendo a cabeça</segment>
    <segment id="8">; Infarto 2</segment>
    <segment id="9">Rubens Ewald teve ferimentos no rosto e na cabeça.</segment>
    <segment id="10">Até a conclusão desta edição</segment>
    <segment id="11">, ele permanecia em observação no Hospital Samaritano</segment>
    <segment id="12">, em São Paulo.</segment>
    <segment id="13">GRÁVIDA?</segment>
    <segment id="14">Alarme falso.</segment>
    <segment id="15">De férias nas Maldivas</segment>
    <segment id="16">, Bruno Gagliasso e Giovanna Ewbank têm publicado uma série de cliques ousados e sensuais.</segment>
    <segment id="17">Numa dessas</segment>
    <segment id="18">, o ator publicou uma imagem em que Gio parece ostentar uma barriguinha de grávida.</segment>
    <segment id="19">com uma foto de Giovanna estufando a barriga</segment>
    <segment id="20">, Gagliasso brincou: “Grávida de vento</segment>
    <segment id="21">, Giovanna Ewbank ostenta a barriguinha no Instagram do marido Bruno Gagliasso</segment>
    <segment id="22">, que está sofrendo por não conseguir ver o sexo na ultra-sonografia virtual”</segment>
    <segment id="23">, disse</segment>
    <segment id="24">, em tom de piada.</segment>
    <segment id="25">Bruno Gagliasso brinca com imagem da mulher</segment>
    <segment id="26">, Giovanna Ewbank</segment>
    <segment id="27">, sobre gravidez de &amp;quot</segment>
    <segment id="28">;vento&amp;quot</segment>
    <segment id="29">; nas Maldivas - @brunogagliasso no Instagram  CANUDO  Carla Perez celebrou a formatura da filha</segment>
    <segment id="30">, Camilly Victoria</segment>
    <segment id="31">, no ensino médio em Orlando</segment>
    <segment id="32">, nos Estados Unidos.</segment>
    <segment id="33">A ex-dançarina do Tchan e o marido</segment>
    <segment id="34">, Xanddy</segment>
    <segment id="35">, postaram fotos em família ao lado da filha.</segment>
    <segment id="36">Ela quer muito mais  Ex-coelhinha de “Playboy”</segment>
    <segment id="37">, Thaiz Schmitt não</segment>
    <segment id="38">sese dá por feliz com o corpinho que Deus lhe deu e que ela bem sabe</segment>
    <segment id="39">comocomo conservar.</segment>
    <segment id="40">Aos 26 anos</segment>
    <segment id="41">, a gaúcha investe no aprendizado de inglês e de artes dramáticas em Los Angeles</segment>
    <segment id="42">, palco dos grandes estúdios de cinema e TV dos Estados Unidos.</segment>
    <segment id="43">“Estou vivendo uma experiência única aproveitando cada minuto</segment>
    <segment id="44">, tanto para a minha vida pessoal</segment>
    <segment id="45">, quanto para a profissional”</segment>
    <segment id="46">, diz.</segment>
    <segment id="47">“Este ano</segment>
    <segment id="48">, decidi investir em mim e colocar todo o meu potencial para alcançar meu projeto de vida</segment>
    <segment id="49">, que é atuar”</segment>
    <segment id="50">, conta</segment>
    <segment id="51">, confiante no ofício das artes dramáticas.</segment>
    <segment id="52">Musas do Olá!</segment>
    <segment id="53">de maio (Agora São Paulo)Mais    novamente         de   de  de  representando um</segment>
  </rst>
