  <rst>
    <segment id="1">A MTV anunciou nesta terça-feira os indicados ao EMA</segment>
    <segment id="2">, o Europe Music Awards</segment>
    <segment id="3">, premiação que acontecerá no dia 5 de novembro em Paris.</segment>
    <segment id="4">O prêmio foi criado em 1994 para homenagear os artistas</segment>
    <segment id="5">, músicas e videoclipes mais populares na Europa.</segment>
    <segment id="6">Taylor Swift durante o VMA</segment>
    <segment id="7">, premiação da MTV realizada neste ano- Angela Weiss/AFPQuem lidera as indicações é a cantora Taylor Swift</segment>
    <segment id="8">, que concorre em seis categorias</segment>
    <segment id="9">, incluindo melhor música por "Anti-Hero"</segment>
    <segment id="10">, melhor artista e melhor vídeo.</segment>
    <segment id="11">Já a cantora Olivia Rodrigo está concorrendo a cinco prêmios</segment>
    <segment id="12">, como</segment>
    <segment id="13">como o de melhor artista pop.</segment>
    <segment id="14">Anitta foi indicada a melhor artista latino</segment>
    <segment id="15">, juntamente com Bad Bunny e Karol G.</segment>
    <segment id="16">A cantora brasileira já havia levado para casa esse prêmio no ano passado</segment>
    <segment id="17">, quando concorreu contra nomes de peso</segment>
    <segment id="18">, como</segment>
    <segment id="19">como Shakira e Rosalía.</segment>
    <segment id="20">Anitta no tapete vermelho do VMA 2023Mais    novamente         de   de  de  representando um</segment>
    <segment id="21">A funkeira</segment>
    <segment id="22">, porém</segment>
    <segment id="23">porém, não é o único nome nacional entre os indicados.</segment>
    <segment id="24">Luísa Sonza e Kevin</segment>
    <segment id="25">O Chris concorrem na categoria de melhor artista brasileiro.</segment>
