  <rst>
    <segment id="1">Trama golpista</segment>
    <segment id="2">Bolsonaro diz que saiu do governo há mais de um ano</segment>
    <segment id="3">, que sofre perseguição implacável e que já pediu que o esqueçam ("</segment>
    <segment id="4">Moraes tira sigilo de vídeo que expõe Bolsonaro e ministro debatendo golpe"</segment>
    <segment id="5">, Política</segment>
    <segment id="6">, 10/2).</segment>
    <segment id="7">Esquecê-lo na casa reformada de Angra dos Reis</segment>
    <segment id="8">, desfrutando de uma magnífica paisagem?</segment>
    <segment id="9">Ou na prisão</segment>
    <segment id="10">, que é onde deveria estar?</segment>
    <segment id="11">Rita Lopes (São Paulo</segment>
    <segment id="12">, SP)  </segment>
    <segment id="13">Um show de absurdos ("Bolsonaro pediu e aprovou alteração em minuta do golpe</segment>
    <segment id="14">, que previa prisão de Moraes</segment>
    <segment id="15">, diz PF"</segment>
    <segment id="16">, Política</segment>
    <segment id="17">, 9/2).</segment>
    <segment id="18">Fez parte de toda a história política de Bolsonaro.</segment>
    <segment id="19">Sempre agredindo a democracia.</segment>
    <segment id="20">A justiça deve ser feita.</segment>
    <segment id="21">Sebastião O. Teixeira (Ananindeua</segment>
    <segment id="22">, PA)</segment>
    <segment id="23">Quem é quem na operação da PF que mira Bolsonaro</segment>
    <segment id="24">, ex-ministros e militaresMais    novamente         de   de  de  representando um   Abin paralela Vimos em quatro anos um desgoverno e ameaça real à democracia e aos direitos do cidadão ("Fui monitorada pela Abin Paralela?</segment>
    <segment id="25">", Mariliz Pereira Jorge</segment>
    <segment id="26">, 9/2).</segment>
    <segment id="27">Todos os envolvidos não podem sair impunes.</segment>
    <segment id="28">Cris Passarelli (São Paulo</segment>
    <segment id="29">, SP)</segment>
    <segment id="30">Outdoor em Palmas (TO)</segment>
    <segment id="31">, em agosto de 2020 - Reprodução Julgamento de Daniel Alves</segment>
    <segment id="32">Na lei espanhola</segment>
    <segment id="33">, a embriaguez não planejada é causa de diminuição de pena ("Daniel Alves sustenta que jovem o seguiu ao banheiro e fez sexo consensual"</segment>
    <segment id="34">, Esporte</segment>
    <segment id="35">, 8/2).</segment>
    <segment id="36">Isso explica a tese defensiva.</segment>
    <segment id="37">O que sabemos sem errar é: traiu a esposa e paga preço</segment>
    <segment id="38">, que será barato demais</segment>
    <segment id="39">sese ele de fato estuprou a moça.</segment>
    <segment id="40">Denise Soares (Brasília</segment>
    <segment id="41">, DF)</segment>
    <segment id="42">Julgamento de Daniel Alves na EspanhaMais    novamente         de   de  de  representando um   Herança de Bill Gates Deveria servir de exemplo para os ricos brasileiros que não doam nada</segment>
    <segment id="43">, só passam para filhos que não trabalham ("Bill Gates decide deixar só 1% da riqueza para filhos"</segment>
    <segment id="44">, F5, 9/2).</segment>
    <segment id="45">Dannielle Miranda Maciel (São Paulo</segment>
    <segment id="46">, SP)  Veja imagens da trajetória de Bill GatesMais    novamente         de   de  de  representando um   Carnaval e religião</segment>
    <segment id="47">O problema está aí ("Carnaval e tradições culturais brasileiras vivem conflitos com evangélicos"</segment>
    <segment id="48">, Cotidiano</segment>
    <segment id="49">, 8/2).</segment>
    <segment id="50">Querer impor sua religião aos outros.</segment>
    <segment id="51">Convencer é uma coisa</segment>
    <segment id="52">, limitar é outra.</segment>
    <segment id="53">Todos podem conviver.</segment>
    <segment id="54">Os evangélicos nem lembram</segment>
    <segment id="55">, masmas já foram malvistos quando eram poucos.</segment>
    <segment id="56">Respeitar os demais é bom.</segment>
    <segment id="57">Com e sem religião.</segment>
    <segment id="58">Hercilio Silva (Brasília</segment>
    <segment id="59">, DF)</segment>
    <segment id="60">Carro alegórico da Grande Rio traz esculturas de Cosme</segment>
    <segment id="61">, Damião e Doum</segment>
    <segment id="62">, santos católicos sincretizados na umbanda e no candomblé - 20.fev.23/Folhapress Comer rima com viver Minha reminiscência do Carnaval é fuga para a praia</segment>
    <segment id="63">, após horas na estrada</segment>
    <segment id="64">, e chegar a uma praia fora dos mapas</segment>
    <segment id="65">, com a família do amigo abarrotada numa Kombi ("</segment>
    <segment id="66">Carnaval rima com comer mal"</segment>
    <segment id="67">, Cozinha Bruta</segment>
    <segment id="68">, Folha Corrida</segment>
    <segment id="69">, 10/2).</segment>
    <segment id="70">Depois do banho de mar</segment>
    <segment id="71">, surgia uma fome indescritível</segment>
    <segment id="72">, saciada pelo quibe frio que a mãe do amigo trazia num isopor.</segment>
    <segment id="73">Comer era questão de espírito.</segment>
    <segment id="74">Eu comia divinamente bem.</segment>
    <segment id="75">Vito Algirdas Sukys (Santo André</segment>
    <segment id="76">, SP)   Brasil</segment>
    <segment id="77">, país sem futuro Nas escolas da década de 50</segment>
    <segment id="78">, havia uma frase sobre o Brasil: País do futuro!</segment>
    <segment id="79">Setenta anos depois</segment>
    <segment id="80">, o futuro que chegou nada tem de maravilhoso ("Que</segment>
    <segment id="81">sese faça Justiça</segment>
    <segment id="82">, não vingança"</segment>
    <segment id="83">, Editoriais</segment>
    <segment id="84">, 10/2).</segment>
    <segment id="85">Por quê?</segment>
    <segment id="86">Como pode dar certo um país cujo comando é disputado por mais de 30 partidos políticos?</segment>
    <segment id="87">Jamais dará certo.</segment>
    <segment id="88">Seus membros olham só para verbas do Estado e</segment>
    <segment id="89">comocomo usá-las para seu proveito!</segment>
    <segment id="90">Enriquecem na politica e empobrecem a população.</segment>
    <segment id="91">Laércio Zannini (São Paulo</segment>
    <segment id="92">, SP)   Jornalistas no front</segment>
    <segment id="93">Enfim um texto sobre o que ocorre em Gaza</segment>
    <segment id="94">, trazendo número de mortos e a rotina do repórter ("Jornalistas em Gaza convivem com a morte</segment>
    <segment id="95">, o medo e a exaustão"</segment>
    <segment id="96">, Mundo</segment>
    <segment id="97">, 9/2).</segment>
    <segment id="98">Rogerio Siqueira (Osasco</segment>
    <segment id="99">, SP)  Jornalistas da AFP e familiares compartilham uma refeição em 10 de dezembro de 2023</segment>
    <segment id="100">, em Rafah</segment>
    <segment id="101">, no sul da Faixa de Gaza   -10.dez.2023/AFP</segment>
