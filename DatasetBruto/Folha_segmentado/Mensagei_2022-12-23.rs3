  <rst>
    <segment id="1">Nunca tinha feito uma viagem tão longa.</segment>
    <segment id="2">O Polo Norte</segment>
    <segment id="3">, como</segment>
    <segment id="4">como o nome indica</segment>
    <segment id="5">, fica lá no alto do globo</segment>
    <segment id="6">, em cima do teto da Terra.</segment>
    <segment id="7">Imagina que sua cabeça é um planeta.</segment>
    <segment id="8">Encosta o dedo lá no cucuruto.</segment>
    <segment id="9">Ali é que fica o Polo Norte.</segment>
    <segment id="10">O que é que eu fui fazer lá no alto?</segment>
    <segment id="11">Encontrar meu grande amigo NicoNico</segment>
    <segment id="12">, o Lalau</segment>
    <segment id="13">, também conhecido</segment>
    <segment id="14">comocomo Claus</segment>
    <segment id="15">, Natal</segment>
    <segment id="16">, ou Nicolau de Mira.</segment>
    <segment id="17">Não conhecem?</segment>
    <segment id="18">Conhecem</segment>
    <segment id="19">, sim.</segment>
    <segment id="20">Ilustração de Daniel Kondo para texto de Gregorio Duvivier - Daniel KondoÉ o papai mais famoso do mundo:</segment>
    <segment id="21">e olha que ele nunca teve filhos.</segment>
    <segment id="22">Não pode um papai sem filho?</segment>
    <segment id="23">Pode, sim.</segment>
    <segment id="24">Papai é maneira de dizer</segment>
    <segment id="25">, só porque</segment>
    <segment id="26">porque ele dá presente pra todo o mundo.</segment>
    <segment id="27">Sim, estou falando dele</segment>
    <segment id="28">, do Papai Noel</segment>
    <segment id="29">, que na verdade não</segment>
    <segment id="30">sese chama Noel nem é papai —esse é só seu nome artístico.</segment>
    <segment id="31">O nome dele de verdade é Nicolau de Mira</segment>
    <segment id="32">, e ele é santo.</segment>
    <segment id="33">Ou melhor</segment>
    <segment id="34">, era santo</segment>
    <segment id="35">, antes de</segment>
    <segment id="36">sese aposentar.</segment>
    <segment id="37">Sim, daqueles de verdade</segment>
    <segment id="38">, com superpoderes de curar doenças e ressuscitar gente.</segment>
    <segment id="39">Cansado de fazer milagres</segment>
    <segment id="40">, foi morar no Polo Norte e hoje vive de distribuir presentes pelo mundo todo</segment>
    <segment id="41">, com a ajuda das suas amigas renas.</segment>
    <segment id="42">Tive o prazer de conhecer a figura e comprovar: ele é mesmo um amor de pessoa.</segment>
    <segment id="43">Dá para sentir isso pelas respostas que ele deu às cartinhas que levei comigo.    "</segment>
    <segment id="44">Caro Papai Noel</segment>
    <segment id="45">, minha casa não tem chaminé</segment>
    <segment id="46">, por onde você vai entrar?</segment>
    <segment id="47">"</segment>
    <segment id="48">Tomé, 4 anos</segment>
    <segment id="49">Ilustração de Daniel Kondo para texto de Gregorio Duvivier - Daniel KondoVou te contar um segredo:</segment>
    <segment id="50">odeio chaminés.</segment>
    <segment id="51">Estão sempre sujas</segment>
    <segment id="52">, fico todo emporcalhado.</segment>
    <segment id="53">E pior: às vezes estão acesas!</segment>
    <segment id="54">Já queimei algumas vezes minha bunda.</segment>
    <segment id="55">Então faz muitos anos que não uso mais esse tipo de acesso.</segment>
    <segment id="56">Quem usava muito era o Lobo Mau</segment>
    <segment id="57">, até que aconteceu aquele acidente com os Três Porquinhos e ele foi obrigado a</segment>
    <segment id="58">sese aposentar.</segment>
    <segment id="59">Até hoje</segment>
    <segment id="60">, não consegue</segment>
    <segment id="61">sese sentar</segment>
    <segment id="62">, coitado.</segment>
    <segment id="63">"</segment>
    <segment id="64">Caro Papai Noel</segment>
    <segment id="65">, você só aparece no Natal!</segment>
    <segment id="66">O que você faz no resto do ano?</segment>
    <segment id="67">"  Marieta</segment>
    <segment id="68">, 5 anos</segment>
    <segment id="69">Ilustração de Daniel Kondo para texto de Gregorio Duvivier - Daniel KondoVocê não me vê no resto do ano</segment>
    <segment id="70">porque</segment>
    <segment id="71">porque estou disfarçado.</segment>
    <segment id="72">Ninguém me reconhece quando tiro a barba.</segment>
    <segment id="73">Em janeiro costumo dar a volta ao mundo</segment>
    <segment id="74">, só de bigode.</segment>
    <segment id="75">Gosto de passear por aí</segment>
    <segment id="76">, e nada me deixa mais feliz do que quando vejo as crianças usando os presentes que eu dei.</segment>
    <segment id="77">Mas o que eu mais gosto mesmo é de beach tennis.</segment>
    <segment id="78">Se você vir um gordinho bigodudo jogando tênis de praia em Copacabana</segment>
    <segment id="79">,</segment>
    <segment id="80">sou eu.</segment>
    <segment id="81">Mas não conta pra ninguém.</segment>
    <segment id="82">Gosto do anonimato</segment>
    <segment id="83">, que é</segment>
    <segment id="84">comocomo os adultos chamam quando ninguém sabe quem você é.</segment>
    <segment id="85">"</segment>
    <segment id="86">Caro Papai Noel</segment>
    <segment id="87">, esse ano talvez tenha me comportado mal.</segment>
    <segment id="88">Vou ganhar presente?</segment>
    <segment id="89">"  Valentim</segment>
    <segment id="90">, 4 anos</segment>
    <segment id="91">Ilustração de Daniel Kondo para texto de Gregorio Duvivier - Daniel KondoOlha</segment>
    <segment id="92">, esse negócio de</segment>
    <segment id="93">sese comportar é subjetivo.</segment>
    <segment id="94">E, quando um adulto diz que uma coisa é subjetiva</segment>
    <segment id="95">, significa que ele não sabe responder direito.</segment>
    <segment id="96">Mas olha: eu não ligo muito pra comportamento.</segment>
    <segment id="97">Eu ligo pra duas coisas: 1.</segment>
    <segment id="98">Você tem que ter escrito uma carta</segment>
    <segment id="99">, assinada</segment>
    <segment id="100">, com seu nome</segment>
    <segment id="101">, seu endereço certinho e um pedido explícito do que você quer.</segment>
    <segment id="102">Ah, e que não seja muito caro!</segment>
    <segment id="103">A crise chegou pra todo o mundo.</segment>
    <segment id="104">2.</segment>
    <segment id="105">A janela da sua casa tem que estar aberta.</segment>
    <segment id="106">Porque eu não atravesso parede.</segment>
    <segment id="107">Ah, e você tem que dormir.</segment>
    <segment id="108">Porque eu não posso encontrar gente acordada.</segment>
    <segment id="109">Sou um pouco tímido.</segment>
    <segment id="110">E muito</segment>
    <segment id="111">, masmas muito apressado.</segment>
    <segment id="112">"</segment>
    <segment id="113">Caro Papai Noel</segment>
    <segment id="114">, meu pai pediu pra perguntar em quem você votou"  Gaia</segment>
    <segment id="115">, 7 anos  Ilustração de Daniel Kondo para texto de Gregorio Duvivier - Daniel KondoQuerida</segment>
    <segment id="116">, eu sou funcionário público</segment>
    <segment id="117">, barbudo</segment>
    <segment id="118">, só me visto de vermelho.</segment>
    <segment id="119">Adivinha!  "</segment>
    <segment id="120">Caro Papai Noel</segment>
    <segment id="121">, você só dá presentes.</segment>
    <segment id="122">O que você vai pedir de Natal?</segment>
    <segment id="123">"  Luiza</segment>
    <segment id="124">, 7 anos</segment>
    <segment id="125">Meu presente é dar presentes.</segment>
    <segment id="126">Luiza, querida</segment>
    <segment id="127">, não é nada fácil ser um bom velhinho.</segment>
    <segment id="128">Amo meu trabalho</segment>
    <segment id="129">, masmas tem sempre alguém querendo me dispensar pra cortar gastos.</segment>
    <segment id="130">Na dúvida</segment>
    <segment id="131">, não atendo mais o telefone!</segment>
  </rst>
</analysis>