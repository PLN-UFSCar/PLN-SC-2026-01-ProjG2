  <rst>
    <segment id="1">Em ato com a presença de advogados e professores de direito</segment>
    <segment id="2">, na noite desta segunda-feira (29)</segment>
    <segment id="3">, a defesa de Lula disse que irá à ONU (Organização das Nações Unidas) denunciar o que chama de &amp;quot</segment>
    <segment id="4">;Estado de exceção&amp;quot</segment>
    <segment id="5">; no Brasil</segment>
    <segment id="6">, representado pelo processo que condenou o ex-presidente no episódio do tríplex.</segment>
    <segment id="7">Entre os pontos que serão atacados estão a celeridade no andamento da ação</segment>
    <segment id="8">, o cerceamento do direito de defesa e a gravação de ligações telefônicas do escritório que cuida do</segment>
    <segment id="9">casocaso do petista</segment>
    <segment id="10">, informou Cristiano Zanin Martins</segment>
    <segment id="11">, advogado que defende Lula na ação do apartamento de Guarujá e em outras acusações.&amp;quot</segment>
    <segment id="12">;Temos visto sistematicamente direitos e garantias serem desprezados</segment>
    <segment id="13">, não só no</segment>
    <segment id="14">casocaso do ex-presidente Lula&amp;quot</segment>
    <segment id="15">;, disse.</segment>
    <segment id="16">Para ele</segment>
    <segment id="17">, a Justiça ignorou a prova de inocência do petista que existe nos autos.</segment>
    <segment id="18">A condenação do ex-presidente em segunda instância levou em conta provas</segment>
    <segment id="19">comocomo planilhas indicando a reserva do apartamento para a família dele</segment>
    <segment id="20">, mensagens de celular rastreadas pela Operação Lava Jato e uma foto de Lula visitando o prédio.</segment>
    <segment id="21">Ele diz que o tríplex nunca foi seu.</segment>
    <segment id="22">Geoffrey Robertson</segment>
    <segment id="23">, advogado que representa o político na Comissão de Direitos Humanos da ONU</segment>
    <segment id="24">, disse no evento</segment>
    <segment id="25">, no teatro Tucarena (zona oeste)</segment>
    <segment id="26">, que o petista tem direito a um julgamento imparcial</segment>
    <segment id="27">, como</segment>
    <segment id="28">como qualquer cidadão.&amp;quot</segment>
    <segment id="29">;E não há</segment>
    <segment id="30">comocomo o juiz [Sergio] Moro ser esse juiz [que conduz um julgamento imparcial]&amp;quot</segment>
    <segment id="31">;, afirmou ele</segment>
    <segment id="32">, acrescentando que Lula não possui imunidade nem está acima da lei</segment>
    <segment id="33">, masmas &amp;quot</segment>
    <segment id="34">;tem direitos humanos fundamentais e por isso deve ser tratado de maneira justa&amp;quot</segment>
    <segment id="35">;.O evento</segment>
    <segment id="36">, promovido pelo Instituto Lawfare</segment>
    <segment id="37">, criado por Cristiano e Valeska Teixeira Martins (ambos da defesa de Lula) e pelo advogado Rafael Valim</segment>
    <segment id="38">, reuniu filiados ao PT e apoiadores da candidatura presidencial de Lula &amp;mdash</segment>
    <segment id="39">;que está em risco após a confirmação da condenação dele no TRF-4 (Tribunal Regional Federal da 4ª Região)</segment>
    <segment id="40">, na quarta-feira (24).&amp;quot</segment>
    <segment id="41">;O que aconteceu nesse processo</segment>
    <segment id="42">, e é o que eu entendo por 'lawfare'</segment>
    <segment id="43">, é que primeiro você acha o culpado e depois você busca o crime&amp;quot</segment>
    <segment id="44">;, disse no debate Celso Amorim</segment>
    <segment id="45">, ministro das Relações Exteriores no governo Lula</segment>
    <segment id="46">, resumindo o conceito jurídico discutido pelos advogados do ex-presidente.&amp;quot</segment>
    <segment id="47">;É o mau uso da lei com o objetivo de demonização e de deslegitimação de um adversário político&amp;quot</segment>
    <segment id="48">;, afirmou Valeska Martins</segment>
    <segment id="49">, citando</segment>
    <segment id="50">comocomo outro exemplo a &amp;quot</segment>
    <segment id="51">;guerra jurídica&amp;quot</segment>
    <segment id="52">; sofrida por Nelson Mandela</segment>
    <segment id="53">, ex-presidente da África do Sul.</segment>
    <segment id="54">Cristiano</segment>
    <segment id="55">, que vem apostando nos últimos tempos em discurso duro contra a Justiça para desqualificar as ações contra o ex-presidente</segment>
    <segment id="56">, falou que é preciso evitar generalização.</segment>
    <segment id="57">&amp;</segment>
    <segment id="58">quot;Não</segment>
    <segment id="59">sese pode fazer ataque</segment>
    <segment id="60">, crítica</segment>
    <segment id="61">, a todo o Judiciário brasileiro.</segment>
    <segment id="62">O que não podemos admitir é a perseguição a uma pessoa.&amp;quot</segment>
    <segment id="63">;'JUIZ PUERIL'O seminário acabou</segment>
    <segment id="64">sese transformando também em um ato de desagravo aos advogados do petista.</segment>
    <segment id="65">Cristiano e Valeska Martins foram classificados nos discursos</segment>
    <segment id="66">comocomo profissionais combativos que têm enfrentado escrutínio e críticas de adversários políticos do ex-presidente e de colegas de profissão.</segment>
    <segment id="67">Participaram da roda de conversa</segment>
    <segment id="68">comocomo debatedores os professores</segment>
    <segment id="69">Antonio Carlos Malheiros</segment>
    <segment id="70">, Pedro Serrano e Eneida Desiree Salgado e os advogados Walfrido Jorge Warde Jr.</segment>
    <segment id="71">, Rafael Valim e Belisário dos Santos Jr.</segment>
    <segment id="72">, entre outros.&amp;quot</segment>
    <segment id="73">;Ataque à democracia&amp;quot</segment>
    <segment id="74">;, &amp;quot</segment>
    <segment id="75">;ameaça à presunção de inocência&amp;quot</segment>
    <segment id="76">;, &amp;quot</segment>
    <segment id="77">;desrespeito à classe dos advogados&amp;quot</segment>
    <segment id="78">;, &amp;quot</segment>
    <segment id="79">;jogo de cartas marcadas&amp;quot</segment>
    <segment id="80">; e &amp;quot</segment>
    <segment id="81">;ato perverso&amp;quot</segment>
    <segment id="82">;</segment>
    <segment id="83">foram expressões que apareceram nas falas para</segment>
    <segment id="84">sese referir à ação do tríplex</segment>
    <segment id="85">, ao trabalho de Moro e da força-tarefa da Lava Jato e à condenação por unanimidade no TRF-4.Convidados usaram seu tempo ao microfone para reafirmar que a condenação carece de provas</segment>
    <segment id="86">, que o processo contém irregularidades e que houve desrespeito ao Estado democrático de Direito na condução do</segment>
    <segment id="87">casocaso.</segment>
    <segment id="88">A defesa reforçou no evento que insistirá na tese de nulidade perante o STF (Supremo Tribunal Federal)</segment>
    <segment id="89">, na tentativa de suspender a condenação.&amp;quot</segment>
    <segment id="90">;Na Europa ou na Austrália</segment>
    <segment id="91">, Lula nunca teria sido condenado pelo tríplex</segment>
    <segment id="92">, porque</segment>
    <segment id="93">porque ele nunca foi dono do tríplex&amp;quot</segment>
    <segment id="94">;, disse Geoffrey</segment>
    <segment id="95">, australiano naturalizado britânico.</segment>
    <segment id="96">&amp;quot;Não</segment>
    <segment id="97">há presunção de inocência no Brasil.</segment>
    <segment id="98">Há presunção de culpa.&amp;quot</segment>
    <segment id="99">;Para a advogada</segment>
    <segment id="100">Eleonora Nassif</segment>
    <segment id="101">, outra debatedora</segment>
    <segment id="102">, Sergio Moro</segment>
    <segment id="103">sese encaixa na classe de &amp;quot</segment>
    <segment id="104">;juiz pueril com desejo de ser herói&amp;quot</segment>
    <segment id="105">;.</segment>
    <segment id="106">Segundo ela</segment>
    <segment id="107">, há muitos magistrados do tipo no país.</segment>
    <segment id="108">&amp;quot;Que ato heroico é condenar um inocente</segment>
    <segment id="109">, condenar sem provas?</segment>
    <segment id="110">Não podemos nos calar diante de tal perversidade&amp;quot</segment>
    <segment id="111">;, afirmou.</segment>
    <segment id="112">Procurado por meio da assessoria de imprensa da Justiça Federal</segment>
    <segment id="113">, Moro disse que não</segment>
    <segment id="114">sese manifestaria.</segment>
  </rst>
</analysis>