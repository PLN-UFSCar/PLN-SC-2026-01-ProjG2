  <rst>
    <segment id="1">Estados Unidos e Uni&amp;atilde</segment>
    <segment id="2">;o Europeia aceitaram nesta ter&amp;ccedil</segment>
    <segment id="3">;a (15) uma tr&amp;eacute</segment>
    <segment id="4">;gua de cinco anos na batalha entre as fabricantes de avi&amp;otilde</segment>
    <segment id="5">;esamericana Boeing e europeia Airbus</segment>
    <segment id="6">, que j&amp;aacute</segment>
    <segment id="7">; durava 17 anos.</segment>
    <segment id="8">O acordo foi negociado durante a c&amp;uacute</segment>
    <segment id="9">;pula entre o presidente dos EUA</segment>
    <segment id="10">, Joe Biden</segment>
    <segment id="11">, o presidente do Conselho Europeu</segment>
    <segment id="12">, Charles Michel</segment>
    <segment id="13">, e a presidente da Comiss&amp;atilde</segment>
    <segment id="14">;o Europeia</segment>
    <segment id="15">, Ursula von der Leyen.</segment>
    <segment id="16">O acordo suspende tarifas retaliat&amp;oacute</segment>
    <segment id="17">;rias que somam US$ 11</segment>
    <segment id="18">,5 bilh&amp;otilde</segment>
    <segment id="19">;es (R$ 58 bi) &amp;mdash</segment>
    <segment id="20">;US$ 7</segment>
    <segment id="21">,5 bi dos EUA sobre exporta&amp;ccedil</segment>
    <segment id="22">;&amp;otilde</segment>
    <segment id="23">;es europeias e US$ 4 bi na Europa sobre exporta&amp;ccedil</segment>
    <segment id="24">;&amp;otilde</segment>
    <segment id="25">;es americanas.</segment>
    <segment id="26">Durante os cinco anos de tr&amp;eacute</segment>
    <segment id="27">;gua, um grupo de trabalho discutir&amp;aacute</segment>
    <segment id="28">; regras para prevenir desaven&amp;ccedil</segment>
    <segment id="29">;as futuras.</segment>
    <segment id="30">As duas partes tamb&amp;eacute</segment>
    <segment id="31">;m concordaram em usar par&amp;acirc</segment>
    <segment id="32">;metros da OMC (Organiza&amp;ccedil</segment>
    <segment id="33">;&amp;atilde</segment>
    <segment id="34">;o Mundial do Com&amp;eacute</segment>
    <segment id="35">;rcio) para quest&amp;otilde</segment>
    <segment id="36">;es que eram alvo de conflito</segment>
    <segment id="37">, como</segment>
    <segment id="38">como financiamento de pesquisa e desenvolvimento e limites de incentivo fiscal</segment>
    <segment id="39">, entre outros</segment>
    <segment id="40">, e estabelece reuni&amp;otilde</segment>
    <segment id="41">;es regulares em n&amp;iacute</segment>
    <segment id="42">;vel ministerial &amp;mdash</segment>
    <segment id="43">;durante a negocia&amp;ccedil</segment>
    <segment id="44">;&amp;atilde</segment>
    <segment id="45">;o desta semana</segment>
    <segment id="46">, isso ocorreu entre a representante de Com&amp;eacute</segment>
    <segment id="47">;rcio dos EUA</segment>
    <segment id="48">, Katherine Tai</segment>
    <segment id="49">, e o comiss&amp;aacute</segment>
    <segment id="50">;rio de Com&amp;eacute</segment>
    <segment id="51">;rcio da UE</segment>
    <segment id="52">, Valdis Dombrovskis.</segment>
    <segment id="53">Em mais um passo para demarcar territ&amp;oacute</segment>
    <segment id="54">;rio em rela&amp;ccedil</segment>
    <segment id="55">;&amp;atilde</segment>
    <segment id="56">;o &amp;agrave</segment>
    <segment id="57">; China</segment>
    <segment id="58">, os dois lados concordaram em cooperar no tratamento de participantes de &amp;ldquo</segment>
    <segment id="59">;economia sem mercado&amp;rdquo</segment>
    <segment id="60">; no mercado de avia&amp;ccedil</segment>
    <segment id="61">;&amp;atilde</segment>
    <segment id="62">;o civil.</segment>
    <segment id="63">Biden deixou mais claro o recado ao dizer que o alvo s&amp;atilde</segment>
    <segment id="64">;o &amp;ldquo</segment>
    <segment id="65">;pr&amp;aacute</segment>
    <segment id="66">;ticas n&amp;atilde</segment>
    <segment id="67">;o mercantis da China que d&amp;atilde</segment>
    <segment id="68">;o &amp;agrave</segment>
    <segment id="69">;s empresas chinesas uma vantagem injusta&amp;rdquo</segment>
    <segment id="70">;.</segment>
    <segment id="71">Conheça o Boeing 777XMais    novamente         de   de  de  representando um  Um dos temores que facilitou a tr&amp;eacute</segment>
    <segment id="72">;gua rec&amp;eacute</segment>
    <segment id="73">;m-obtida era o de que</segment>
    <segment id="74">, sese as companhias americana e europeia continuarem</segment>
    <segment id="75">sese enfraquecendo mutuamente</segment>
    <segment id="76">, abririam espa&amp;ccedil</segment>
    <segment id="77">;o para que</segment>
    <segment id="78">para que as chinesas avancem no mercado de aeronaves civis</segment>
    <segment id="79">, cada vez mais influenciado por tecnologias digitais</segment>
    <segment id="80">, que a China domina.</segment>
    <segment id="81">Apesar do al&amp;iacute</segment>
    <segment id="82">;vio representado pela atual tr&amp;eacute</segment>
    <segment id="83">;gua, um acordo final depender&amp;aacute</segment>
    <segment id="84">; das pr&amp;oacute</segment>
    <segment id="85">;prias companhias</segment>
    <segment id="86">, ressalva a especialista em com&amp;eacute</segment>
    <segment id="87">;rcio exterior e san&amp;ccedil</segment>
    <segment id="88">;&amp;otilde</segment>
    <segment id="89">;es do centro de estudos apartid&amp;aacute</segment>
    <segment id="90">;rio americano Atlantic Council</segment>
    <segment id="91">, Julia Friedman.</segment>
    <segment id="92">&amp;quot;Isso implica duas coisas: tempo e advogados&amp;quot</segment>
    <segment id="93">;, afirma ela.</segment>
    <segment id="94">Friedman diz que a solu&amp;ccedil</segment>
    <segment id="95">;&amp;atilde</segment>
    <segment id="96">;o final tamb&amp;eacute</segment>
    <segment id="97">;m depende da ades&amp;atilde</segment>
    <segment id="98">;o dos pa&amp;iacute</segment>
    <segment id="99">;ses em que avi&amp;otilde</segment>
    <segment id="100">;es Airbus s&amp;atilde</segment>
    <segment id="101">;o fabricados (Alemanha</segment>
    <segment id="102">, Fran&amp;ccedil</segment>
    <segment id="103">;a e Espanha) e</segment>
    <segment id="104">, no caso</segment>
    <segment id="105">caso americano</segment>
    <segment id="106">, do estado de Washington</segment>
    <segment id="107">, que sedia a Boeing.</segment>
    <segment id="108">Para Friedman</segment>
    <segment id="109">, a principal consequ&amp;ecirc</segment>
    <segment id="110">;ncia da atual tr&amp;eacute</segment>
    <segment id="111">;gua &amp;eacute</segment>
    <segment id="112">; que &amp;quot</segment>
    <segment id="113">;finalmente ser&amp;aacute</segment>
    <segment id="114">; poss&amp;iacute</segment>
    <segment id="115">;vel tirar o foco de uma disputa sobre ind&amp;uacute</segment>
    <segment id="116">;stria pesada</segment>
    <segment id="117">, cada vez mais anacr&amp;ocirc</segment>
    <segment id="118">;nica, e passar a discutir o que realmente vai mudar o futuro do mundo e das institui&amp;ccedil</segment>
    <segment id="119">;&amp;otilde</segment>
    <segment id="120">;es que o governam: privacidade de dados e mudan&amp;ccedil</segment>
    <segment id="121">;a clim&amp;aacute</segment>
    <segment id="122">;tica&amp;quot</segment>
    <segment id="123">;.</segment>
    <segment id="124">Airbus completa 50 anosMais    novamente         de   de  de  representando um  ENTENDA</segment>
    <segment id="125">A BATALHA</segment>
    <segment id="126">A disputa entre EUA e Uni&amp;atilde</segment>
    <segment id="127">;o Europeia come&amp;ccedil</segment>
    <segment id="128">;ou em 2004</segment>
    <segment id="129">, quando os americanos acusaram os europeus de fomentar a Airbus com subs&amp;iacute</segment>
    <segment id="130">;dios injustos</segment>
    <segment id="131">, permitindo &amp;agrave</segment>
    <segment id="132">;</segment>
    <segment id="133">fabricante liderar pela primeira vez no n&amp;uacute</segment>
    <segment id="134">;mero de avi&amp;otilde</segment>
    <segment id="135">;es entregues.</segment>
    <segment id="136">Os EUA entraram com uma queixa na OMC (Organiza&amp;ccedil</segment>
    <segment id="137">;&amp;atilde</segment>
    <segment id="138">;o Mundial do Com&amp;eacute</segment>
    <segment id="139">;rcio)</segment>
    <segment id="140">, afirmando que pa&amp;iacute</segment>
    <segment id="141">;ses com f&amp;aacute</segment>
    <segment id="142">;bricas da Airbus usavam recursos estatais para financiar o desenvolvimento de novos modelos.</segment>
    <segment id="143">O empr&amp;eacute</segment>
    <segment id="144">;stimo era depois devolvido por royalties sobre vendas futuras.</segment>
    <segment id="145">Em resposta</segment>
    <segment id="146">, a UE tamb&amp;eacute</segment>
    <segment id="147">;m fez uma reclama&amp;ccedil</segment>
    <segment id="148">;&amp;atilde</segment>
    <segment id="149">;o na organiza&amp;ccedil</segment>
    <segment id="150">;&amp;atilde</segment>
    <segment id="151">;o, apontado incentivos fiscais injustos no estado de Washington</segment>
    <segment id="152">, sede da Boeing.</segment>
    <segment id="153">A OMC abriu investiga&amp;ccedil</segment>
    <segment id="154">;&amp;atilde</segment>
    <segment id="155">;o sobre os dois lados da disputa</segment>
    <segment id="156">, e seguiu-</segment>
    <segment id="157">sese uma s&amp;eacute</segment>
    <segment id="158">;rie de descumprimentos de decis&amp;otilde</segment>
    <segment id="159">;es da entidade e novas queixas.</segment>
    <segment id="160">Os lances mais recentes foram as autoriza&amp;ccedil</segment>
    <segment id="161">;&amp;otilde</segment>
    <segment id="162">;es da OMC</segment>
    <segment id="163">para que</segment>
    <segment id="164">para que cada lado aplicasse tarifas retaliat&amp;oacute</segment>
    <segment id="165">;rias sobre exporta&amp;ccedil</segment>
    <segment id="166">;&amp;otilde</segment>
    <segment id="167">;es do rival</segment>
    <segment id="168">, em 2019 e 2020</segment>
    <segment id="169">, situa&amp;ccedil</segment>
    <segment id="170">;&amp;atilde</segment>
    <segment id="171">;o que vigorou at&amp;eacute</segment>
    <segment id="172">;</segment>
    <segment id="173">a pausa provis&amp;oacute</segment>
    <segment id="174">;ria de mar&amp;ccedil</segment>
    <segment id="175">;o.</segment>
    <segment id="176">Entre os pontos que travavam uma solu&amp;ccedil</segment>
    <segment id="177">;&amp;atilde</segment>
    <segment id="178">;o para a quest&amp;atilde</segment>
    <segment id="179">;o estavam a press&amp;atilde</segment>
    <segment id="180">;o da UE</segment>
    <segment id="181">para que</segment>
    <segment id="182">para que as regras de subs&amp;iacute</segment>
    <segment id="183">;dio se</segment>
    <segment id="184">se estendessem tamb&amp;eacute</segment>
    <segment id="185">;m a contratos de defesa e fundos de pesquisa e desenvolvimento</segment>
    <segment id="186">, e uma diverg&amp;ecirc</segment>
    <segment id="187">;ncia sobre o tamanho do fundo de ajuda estatal necess&amp;aacute</segment>
    <segment id="188">;rio para recuperar a Airbus.  C919</segment>
    <segment id="189">, a aposta da China para enfrentar Boeing e AirbusMais    novamente         de   de  de  representando um  pend&amp;ecirc</segment>
    <segment id="190">;ncias restantes</segment>
    <segment id="191">A Uni&amp;atilde</segment>
    <segment id="192">;o Europeia tamb&amp;eacute</segment>
    <segment id="193">;m pressiona por mais rapidez na solu&amp;ccedil</segment>
    <segment id="194">;&amp;atilde</segment>
    <segment id="195">;o de outros pontos de atrito</segment>
    <segment id="196">, como</segment>
    <segment id="197">como as tarifas sobre metais</segment>
    <segment id="198">, a tributa&amp;ccedil</segment>
    <segment id="199">;&amp;atilde</segment>
    <segment id="200">;o ambiental e regras de transfer&amp;ecirc</segment>
    <segment id="201">;ncia de dados.</segment>
    <segment id="202">Antes do encontro do G7</segment>
    <segment id="203">, o comiss&amp;aacute</segment>
    <segment id="204">;rio Dombrovskis chegou a dizer que Biden precisa &amp;ldquo</segment>
    <segment id="205">;fazer na pr&amp;aacute</segment>
    <segment id="206">;tica o que prega&amp;rdquo</segment>
    <segment id="207">;.</segment>
    <segment id="208">Na entrevista ap&amp;oacute</segment>
    <segment id="209">;s o f&amp;oacute</segment>
    <segment id="210">;rum de na&amp;ccedil</segment>
    <segment id="211">;&amp;otilde</segment>
    <segment id="212">;es industrializadas</segment>
    <segment id="213">, por&amp;eacute</segment>
    <segment id="214">;m, a uma pergunta sobre a escalada tarif&amp;aacute</segment>
    <segment id="215">;ria, o presidente americano respondeu:</segment>
    <segment id="216">&amp;ldquo</segment>
    <segment id="217">;D&amp;ecirc</segment>
    <segment id="218">; um tempo!</segment>
    <segment id="219">Estou h&amp;aacute</segment>
    <segment id="220">;</segment>
    <segment id="221">apenas 120 dias no cargo&amp;rdquo</segment>
    <segment id="222">;</segment>
    <segment id="223">.</segment>
    <segment id="224">Biden sofre press&amp;atilde</segment>
    <segment id="225">;o do setor sider&amp;uacute</segment>
    <segment id="226">;rgico americano para manter prote&amp;ccedil</segment>
    <segment id="227">;&amp;otilde</segment>
    <segment id="228">;es no</segment>
    <segment id="229">casocaso do a&amp;ccedil</segment>
    <segment id="230">;o e alum&amp;iacute</segment>
    <segment id="231">;nio, e a Uni&amp;atilde</segment>
    <segment id="232">;o Europeia critica a falta de transpar&amp;ecirc</segment>
    <segment id="233">;ncia dos EUA sobre</segment>
    <segment id="234">comocomo garantir a privacidade de informa&amp;ccedil</segment>
    <segment id="235">;&amp;otilde</segment>
    <segment id="236">;es de cidad&amp;atilde</segment>
    <segment id="237">;os europeus</segment>
    <segment id="238">, no caso</segment>
    <segment id="239">caso da transfer&amp;ecirc</segment>
    <segment id="240">;ncia de dados.</segment>
    <segment id="241">Na &amp;aacute</segment>
    <segment id="242">;rea ambiental</segment>
    <segment id="243">, a disc&amp;oacute</segment>
    <segment id="244">;rdia &amp;eacute</segment>
    <segment id="245">;</segment>
    <segment id="246">em torno da taxa de fronteira de carbono</segment>
    <segment id="247">, que a Europa quer cobrar em importa&amp;ccedil</segment>
    <segment id="248">;&amp;otilde</segment>
    <segment id="249">;es de alum&amp;iacute</segment>
    <segment id="250">;nio, cimento</segment>
    <segment id="251">, fertilizantes e eletricidade</segment>
    <segment id="252">, para compensar o custo mais baixo dos vendedores ao produzem em &amp;aacute</segment>
    <segment id="253">;reas com regras ambientais menos duras que as da UE.</segment>
    <segment id="254">Airbus A330-300 decola ao fundo enquanto Boeing 787-10 Dreamliner percorre pista no aeroporto Changi</segment>
    <segment id="255">, em Singapura  - Edgar Su - 28.mar.2018/</segment>
    <segment id="256">Reutes Tamb&amp;eacute</segment>
    <segment id="257">;m n&amp;atilde</segment>
    <segment id="258">;o sese esperam an&amp;uacute</segment>
    <segment id="259">;ncios de grandes acordos comerciais entre os dois blocos</segment>
    <segment id="260">, masmas de parcerias para coordenar regras e padr&amp;otilde</segment>
    <segment id="261">;es em &amp;aacute</segment>
    <segment id="262">;reas como</segment>
    <segment id="263">como intelig&amp;ecirc</segment>
    <segment id="264">;ncia artificial e computa&amp;ccedil</segment>
    <segment id="265">;&amp;atilde</segment>
    <segment id="266">;o qu&amp;acirc</segment>
    <segment id="267">;ntica.</segment>
    <segment id="268">Sob a gest&amp;atilde</segment>
    <segment id="269">;o Biden</segment>
    <segment id="270">, os EUA</segment>
    <segment id="271">tamb&amp;eacute</segment>
    <segment id="272">;m devem apoiar a reforma da OMC (Organiza&amp;ccedil</segment>
    <segment id="273">;&amp;atilde</segment>
    <segment id="274">;o Mundial do Com&amp;eacute</segment>
    <segment id="275">;rcio)</segment>
    <segment id="276">, que havia travado durante o governo de Donald Trump.</segment>
    <segment id="277">Durante a reuni&amp;atilde</segment>
    <segment id="278">;o do G7</segment>
    <segment id="279">, no final de semana</segment>
    <segment id="280">, o presidente americano indicou que considera a organiza&amp;ccedil</segment>
    <segment id="281">;&amp;atilde</segment>
    <segment id="282">;o multilateral um caminho vi&amp;aacute</segment>
    <segment id="283">;vel para combater pr&amp;aacute</segment>
    <segment id="284">;ticas desleais da China &amp;mdash</segment>
    <segment id="285">;comocomo subs&amp;iacute</segment>
    <segment id="286">;dios estatais e transfer&amp;ecirc</segment>
    <segment id="287">;ncias for&amp;ccedil</segment>
    <segment id="288">;adas de tecnologia&amp;mdash</segment>
    <segment id="289">;, algo que Trump n&amp;atilde</segment>
    <segment id="290">;o acreditava poss&amp;iacute</segment>
    <segment id="291">;vel.</segment>
    <segment id="292">Apesar dos acenos favor&amp;aacute</segment>
    <segment id="293">;veis &amp;agrave</segment>
    <segment id="294">; OMC e de ter destravado a escolha da nova dire&amp;ccedil</segment>
    <segment id="295">;&amp;atilde</segment>
    <segment id="296">;o-geral da entidade</segment>
    <segment id="297">, o governo Biden ainda n&amp;atilde</segment>
    <segment id="298">;o desbloqueou por&amp;eacute</segment>
    <segment id="299">;m a escolha de ju&amp;iacute</segment>
    <segment id="300">;zes do principal &amp;oacute</segment>
    <segment id="301">;rg&amp;atilde</segment>
    <segment id="302">;o de solu&amp;ccedil</segment>
    <segment id="303">;&amp;atilde</segment>
    <segment id="304">;o de disputas da organiza&amp;ccedil</segment>
    <segment id="305">;&amp;atilde</segment>
    <segment id="306">;o.</segment>
    <segment id="307">A batalha em torno dos fabricantes de avi&amp;otilde</segment>
    <segment id="308">;es era a maior disputa comercial entre os dois blocos</segment>
    <segment id="309">, cuja corrente comercial de bens em 2020 chegou a US$ 550 bilh&amp;otilde</segment>
    <segment id="310">;es (R$ 2</segment>
    <segment id="311">,78 tri)</segment>
    <segment id="312">, segundo a UE.</segment>
    <segment id="313">EUA e o bloco europeu s&amp;atilde</segment>
    <segment id="314">;o mutuamente seus principais parceiros comerciais</segment>
    <segment id="315">, tanto em produtos quanto em servi&amp;ccedil</segment>
    <segment id="316">;os &amp;mdash</segment>
    <segment id="317">;</segment>
    <segment id="318">em 2019</segment>
    <segment id="319">, o com&amp;eacute</segment>
    <segment id="320">;rcio de servi&amp;ccedil</segment>
    <segment id="321">;os gerou US$ 420 bilh&amp;otilde</segment>
    <segment id="322">;es (R$ 2</segment>
    <segment id="323">,13 tri).</segment>
    <segment id="324">Em seu perfil no Twitter</segment>
    <segment id="325">, Von der Leyen afirmou que o acordo &amp;quot</segment>
    <segment id="326">;abre um novo cap&amp;iacute</segment>
    <segment id="327">;tulo em nossa rela&amp;ccedil</segment>
    <segment id="328">;&amp;atilde</segment>
    <segment id="329">;o porque</segment>
    <segment id="330">porque passamos de lit&amp;iacute</segment>
    <segment id="331">;gio para coopera&amp;ccedil</segment>
    <segment id="332">;&amp;atilde</segment>
    <segment id="333">;o em avi&amp;otilde</segment>
    <segment id="334">;es&amp;quot</segment>
    <segment id="335">;.</segment>
    <segment id="336">Na mesma linha</segment>
    <segment id="337">, a representante de Com&amp;eacute</segment>
    <segment id="338">;rcio dos EUA</segment>
    <segment id="339">, Katherine Tai</segment>
    <segment id="340">, disse a jornalistas que o acordo &amp;quot</segment>
    <segment id="341">;permite come&amp;ccedil</segment>
    <segment id="342">;ar a virar a p&amp;aacute</segment>
    <segment id="343">;gina em uma longa disputa&amp;quot</segment>
    <segment id="344">;.</segment>
