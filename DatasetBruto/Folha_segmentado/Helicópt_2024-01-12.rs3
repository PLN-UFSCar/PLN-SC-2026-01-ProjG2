  <rst>
    <segment id="1">Destroços do helicóptero que havia desaparecido no dia 31 dezembro</segment>
    <segment id="2">, após decolar de São Paulo com destino a Ilhabela</segment>
    <segment id="3">, foram encontrados na manhã desta sexta-feira (12) em uma área de mata em Paraibuna (SP).</segment>
    <segment id="4">As quatro pessoas que estavam a bordo da aeronave</segment>
    <segment id="5">, um piloto e três passageiros</segment>
    <segment id="6">, morreram no acidente.</segment>
    <segment id="7">Veja, a seguir</segment>
    <segment id="8">, quem são as vítimas.</segment>
    <segment id="9">O piloto Cassiano Tete Teodoro (à esq.)</segment>
    <segment id="10">; e os passageiros Letícia Sakumoto</segment>
    <segment id="11">; Luciana Marley Rodzewics Santos</segment>
    <segment id="12">; e Raphael Torres - Montagem/@CassianoTete no Instagram e LeitorLuciana Marley Rodzewics Santos</segment>
    <segment id="13">, 46  Luciana vivia no bairro no Limão</segment>
    <segment id="14">, na zona norte da capital paulista.</segment>
    <segment id="15">Empresária</segment>
    <segment id="16">, ela possuía uma loja de roupas e sapatos.</segment>
    <segment id="17">"Gostava muito de adrenalina"</segment>
    <segment id="18">, disse sua irmã</segment>
    <segment id="19">, Silvia Santos.</segment>
    <segment id="20">Com ela na viagem estava a filha</segment>
    <segment id="21">, Letícia Ayumi Rodzewics Sakumoto</segment>
    <segment id="22">, 20.  Helicóptero que sumiu em SP é encontrado após 12 diasMais    novamente         de   de  de  representando um  Letícia Ayumi Rodzewics Sakumoto</segment>
    <segment id="23">, 20</segment>
    <segment id="24">A jovem também vivia no bairro do Limão</segment>
    <segment id="25">, em uma casa com os avós maternos.</segment>
    <segment id="26">A jovem era proprietária de um salão de cabeleireiro</segment>
    <segment id="27">, o qual sonhara em conquistar desde a adolescência.</segment>
    <segment id="28">Namorava havia cinco anos e tinha planos de viver com o companheiro.</segment>
    <segment id="29">A família conta que a relação de Letícia com a mãe era ótima.</segment>
    <segment id="30">Embarcavam em viagens juntas com frequência.</segment>
    <segment id="31">A última na véspera de Ano-Novo.</segment>
    <segment id="32">Letícia Ayumi Rodzewics Sakumoto</segment>
    <segment id="33">, 20, e a mãe</segment>
    <segment id="34">, Luciana Marley Rodzewics Santos</segment>
    <segment id="35">, 46 - LeitorRaphael Torres</segment>
    <segment id="36">, 41</segment>
    <segment id="37">O empresário era amigo de Luciana e foi ele quem a convidou para o passeio a Ilhabela.</segment>
    <segment id="38">Ele atuava no ramo de venda de medicamentos em São Paulo e possuía residência na cidade litorânea.</segment>
    <segment id="39">Segundo a família do empresário</segment>
    <segment id="40">, Raphael gostava de levar amigos ao local para confraternizações.</segment>
    <segment id="41">Ele deixa dois filhos</segment>
    <segment id="42">, um de 16 e outro de 6 anos.</segment>
    <segment id="43">O empresário Raphael Torres</segment>
    <segment id="44">, 41, outra vítima do acidente - LeitorCassiano Tete Teodoro</segment>
    <segment id="45">, 44</segment>
    <segment id="46">O piloto Cassiano possuía 17 anos de experiência na profissão</segment>
    <segment id="47">, mesma quantidade de multas acumuladas por infrações.</segment>
    <segment id="48">A advogada do piloto</segment>
    <segment id="49">, contudo</segment>
    <segment id="50">contudo</segment>
    <segment id="51">, já contestou parte dessas sanções.</segment>
    <segment id="52">Cassiano era sócio da CBA Investimentos</segment>
    <segment id="53">, dona do helicóptero que caiu</segment>
    <segment id="54">, junto da empresa RGI Locações.</segment>
    <segment id="55">A empresa prestava táxi aéreo clandestino.</segment>
    <segment id="56">O piloto Cassiano Teodoro</segment>
    <segment id="57">, 44, morto na queda do helicóptero - @CassianoTete no Instagram</segment>
  </rst>
</analysis>