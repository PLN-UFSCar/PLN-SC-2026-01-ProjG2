  <rst>
    <segment id="1">A queda de um ônibus em um despenhadeiro de 100 metros na região de La Libertad</segment>
    <segment id="2">, perto dos Andes peruanos</segment>
    <segment id="3">, deixou pelo menos 20 pessoas mortas e 33 feridas</segment>
    <segment id="4">, anunciaram as autoridades locais na tarde desta quinta-feira (10).</segment>
    <segment id="5">O acidente ocorreu na quarta (9)</segment>
    <segment id="6">, em uma estrada rural no trajeto entre as cidades de Tayabamba e Trujillo</segment>
    <segment id="7">, segundo as informações do governo regional.</segment>
    <segment id="8">A demora</segment>
    <segment id="9">para que</segment>
    <segment id="10">para que fosse notificado</segment>
    <segment id="11">sese deveu ao fato de a localidade ser uma das mais remotas na parte andina —a viagem de ônibus leva cerca de 14 horas.</segment>
    <segment id="12">Acidente com ônibus nos Andes peruanos deixa 20 mortos e 33 feridos - Reprodução/Rochex R. Robinson Bonilla no Twitter</segment>
    <segment id="13">O mau estado de conservação da estrada</segment>
    <segment id="14">, que obrigou o motorista a fazer uma manobra brusca</segment>
    <segment id="15">, teria sido a causa do acidente</segment>
    <segment id="16">, segundo apuração da emissora Canal N.</segment>
    <segment id="17">O episódio esquentou o debate no país sobre a precariedade das estradas e a baixa fiscalização das empresas de transporte</segment>
    <segment id="18">, fatores que têm levado a seguidos acidentes.</segment>
    <segment id="19">Omar Iparraguirre</segment>
    <segment id="20">, chefe do Executivo de Patáz</segment>
    <segment id="21">, província de La Libertad onde está localizada Tayabamba</segment>
    <segment id="22">, pediu ao governo do presidente Pedro Castillo que tome medidas contra a operação de empresas de transporte que não cumprem os requisitos operacionais exigidos.</segment>
    <segment id="23">"</segment>
    <segment id="24">Esse problema não é de hoje</segment>
    <segment id="25">, sempre acontece"</segment>
    <segment id="26">, disse ele a repórteres.</segment>
    <segment id="27">Lá foraReceba no seu email uma seleção semanal com o que de mais importante aconteceu no mundo</segment>
    <segment id="28">; aberta para não assinantes.</segment>
    <segment id="29">Carregando...</segment>
    <segment id="30">O Ministério Público do Peru</segment>
    <segment id="31">, segundo a agência de notícias Associated Press</segment>
    <segment id="32">, informou em dezembro</segment>
    <segment id="33">, em uma compilação de dados oficiais</segment>
    <segment id="34">, que apenas nos últimos cinco anos ocorreram mais de 420 mil acidentes de trânsito no país</segment>
    <segment id="35">, causando a morte de mais de 14 mil pessoas e deixando outras 272 mil feridas</segment>
    <segment id="36">, algumas com sequelas permanentes.</segment>
    <segment id="37">O órgão disse</segment>
    <segment id="38">, na ocasião</segment>
    <segment id="39">, que o problema de insegurança rodoviária já</segment>
    <segment id="40">sese estende e é de conhecimento público há mais de 20 anos.</segment>
    <segment id="41">Os números oficiais mais recentes disponíveis apontam que</segment>
    <segment id="42">, entre janeiro e outubro do último ano</segment>
    <segment id="43">, pelo menos 2.053 pessoas morreram em acidentes de trânsito no Peru.</segment>
    <segment id="44">Em junho</segment>
    <segment id="45">, 27 mineradores morreram e outros 16 ficaram feridos na queda de um ônibus em um abismo de 400 metros em uma estrada andina no sul do país</segment>
    <segment id="46">, perto das famosas Linhas de Nazca.</segment>
    <segment id="47">Dias antes</segment>
    <segment id="48">, outro acidente em uma estrada</segment>
    <segment id="49">, este na região de La Libertad —a mesma do acidente desta quarta—</segment>
    <segment id="50">, levou à morte de 17 pessoas.</segment>
  </rst>
</analysis>