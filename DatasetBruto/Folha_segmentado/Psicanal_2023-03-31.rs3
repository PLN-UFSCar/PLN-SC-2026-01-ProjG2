  <rst>
    <segment id="1">A intelectual russa</segment>
    <segment id="2">Lou Andreas-Salomé por muito tempo teve seu pioneirismo obscurecido por suas relações afetivas com alguns dos grandes pensadores de sua época —o filósofo Friedrich Nietzsche</segment>
    <segment id="3">, o poeta Rainer Maria Rilke</segment>
    <segment id="4">, o psicanalista Sigmund Freud.</segment>
    <segment id="5">Lou Andreas-Salomé</segment>
    <segment id="6">, à esquerda</segment>
    <segment id="7">, brinca com Paul Rée e Friedrich Nietzsche em foto tirada na Suíça em 1882 - Reprodução</segment>
    <segment id="8">Agora a editora</segment>
    <segment id="9">Nós busca reintroduzir Salomé ao mercado brasileiro com o devido destaque e sob lentes mais adequadas.</segment>
    <segment id="10">"</segment>
    <segment id="11">Ela ficou cristalizada</segment>
    <segment id="12">comocomo musa de Nietzsche e Rilke</segment>
    <segment id="13">, masmas lá atrás ela já abria clareiras</segment>
    <segment id="14">comocomo filósofa</segment>
    <segment id="15">, escritora e uma das primeiras psicanalistas da história"</segment>
    <segment id="16">, afirma a editora Simone Paulino.</segment>
    <segment id="17">Em julho sai "Retrospecções"</segment>
    <segment id="18">, uma espécie de retrato autobiográfico da escritora nascida em São Petersburgo em 1861 e radicada na Alemanha.</segment>
    <segment id="19">A obra tinha sido editada pela Brasiliense nos anos 1980</segment>
    <segment id="20">comocomo "Minha Vida".</segment>
    <segment id="21">O livro retraça em fragmentos a vida de uma mulher visionária e contestadora</segment>
    <segment id="22">, com reflexões sobre Deus</segment>
    <segment id="23">, o amor e a escrita.</segment>
    <segment id="24">"</segment>
    <segment id="25">Precisou aparecer Annie Ernaux para olharmos para trás e identificarmos algumas de suas precursoras"</segment>
    <segment id="26">, diz Paulino.</segment>
    <segment id="27">No ano que vem</segment>
    <segment id="28">, sai "Carta a Freud"</segment>
    <segment id="29">, um ensaio longo da intelectual dirigido ao colega austríaco que completava então 65 anos —e a considerava uma amiga e interlocutora inspiradora.</segment>
    <segment id="30">Ilustração de Hippolyte para o infantil &amp;#039</segment>
    <segment id="31">;O Tédio das Tardes sem Fim&amp;#039</segment>
    <segment id="32">;, que o franco-ruandês Gaël Faye publica pela Veneta - Divulgação  ENTREVISTA COM</segment>
    <segment id="33">O VAMPIRODalton Trevisan selecionou</segment>
    <segment id="34">, a próprio punho</segment>
    <segment id="35">, 91 de seus textos para compor uma nova coletânea que a Record leva às lojas já neste mês de abril.</segment>
    <segment id="36">A "Antologia Pessoal" de um dos maiores contistas brasileiros</segment>
    <segment id="37">, que em junho completa 98 anos</segment>
    <segment id="38">, terá prefácio do professor Augusto Massi</segment>
    <segment id="39">, da Universidade de São Paulo.</segment>
    <segment id="40">A MULHER E O PRIMATAE a Sextante vai romper um hiato de mais de 30 anos sem novos títulos de Jane Goodall no Brasil.</segment>
    <segment id="41">Sai em junho o "</segment>
    <segment id="42">Livro da Esperança"</segment>
    <segment id="43">, em que a naturalista britânica de 89 anos discute as experiências que moldaram suas descobertas revolucionárias sobre o comportamento dos animais.</segment>
    <segment id="44">Tudo a lerReceba no seu email uma seleção com lançamentos</segment>
    <segment id="45">, clássicos e curiosidades literárias</segment>
    <segment id="46">; aberta para não assinantes.</segment>
    <segment id="47">Carregando...  PÁGINAS DE PAGE</segment>
    <segment id="48">A Intrínseca acaba de abrir a pré-venda de uma de suas maiores apostas do ano.</segment>
    <segment id="49">"</segment>
    <segment id="50">Pageboy"</segment>
    <segment id="51">,</segment>
    <segment id="52">o livro de memórias do ator trans Elliot Page</segment>
    <segment id="53">, indicado ao Oscar por "Juno"</segment>
    <segment id="54">, chega às livrarias no dia 6 de junho</segment>
    <segment id="55">, simultaneamente ao lançamento nos Estados Unidos.</segment>
    <segment id="56">Imagens do ator Elliot PageMais    novamente         de   de  de  representando um    TOPO DO MUNDOE a Companhia das Letras vai reeditar ainda neste ano outro sucesso de vendas</segment>
    <segment id="57">, "</segment>
    <segment id="58">São Paulo nas Alturas"</segment>
    <segment id="59">, do jornalista Raul Juste Lores.</segment>
    <segment id="60">O livro sobre a evolução da arquitetura paulistana foi publicado em 2017 pela editora Três Estrelas</segment>
    <segment id="61">, hoje fora de atividade</segment>
    <segment id="62">, e se</segment>
    <segment id="63">se tornou artefato cada vez mais raro nas livrarias.</segment>
    <segment id="64">UM PEDACINHO DE PADREO escritor e roteirista Tailor Diniz entregou para a editora</segment>
    <segment id="65">Citadel um romance que soa</segment>
    <segment id="66">comocomo um "Sweeney</segment>
    <segment id="67">Todd" da geração</segment>
    <segment id="68">Z: um casal de universitários começa a assassinar pessoas e transformá-las em filés gourmet.</segment>
    <segment id="69">Com a ajuda de uma influenciadora</segment>
    <segment id="70">, o produto acaba indo para o topo dos trending topics e vira sensação.</segment>
  </rst>
