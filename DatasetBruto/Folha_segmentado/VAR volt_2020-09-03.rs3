  <rst>
    <segment id="1">Com o VAR em cena novamente</segment>
    <segment id="2">, o Santos empatou com o Vasco por 2 a 2</segment>
    <segment id="3">, pela 7ª rodada do Brasileirão</segment>
    <segment id="4">, na noite desta quarta-feira (2).</segment>
    <segment id="5">Os gols do Peixe foram marcados por Lucas Veríssimo e Marinho</segment>
    <segment id="6">, enquanto o Cruzmaltino fez com Fellipe Bastos e Cano.</segment>
    <segment id="7">O time de Cuca chega ao terceiro jogo sem vitória</segment>
    <segment id="8">, com duas derrotas e um empate</segment>
    <segment id="9">, e soma 8 pontos.</segment>
    <segment id="10">O Santos ficou no empate com o Vasco na Vila</segment>
    <segment id="11">Belmiro - Ivan Storti/Santos FC  No primeiro lance de jogo</segment>
    <segment id="12">, Alison recebeu passe na fogueira de Felipe Jonatan e perdeu a bola para Cano</segment>
    <segment id="13">, que bateu firme e carimbou o travessão santista.</segment>
    <segment id="14">Aos poucos o Santos cresceu na partida e abriu o placar aos 20min.</segment>
    <segment id="15">Depois de rebote no escanteio</segment>
    <segment id="16">, Soteldo gingou para cima de Ygor e cruzou na medida para Lucas Veríssimo</segment>
    <segment id="17">, que testou para o fundo da rede.</segment>
    <segment id="18">Na sequência do gol</segment>
    <segment id="19">, o jogo caiu de intensidade e as duas equipes encontravam dificuldade de furar a marcação adversária.</segment>
    <segment id="20">Apenas no segundo ataque efetivo na etapa inicial</segment>
    <segment id="21">, o Vasco chegou ao empate</segment>
    <segment id="22">, aos 39min.</segment>
    <segment id="23">Benítez cobrou escanteio</segment>
    <segment id="24">, Miranda desviou de cabeça para a pequena área e Fellipe Bastos</segment>
    <segment id="25">, livre</segment>
    <segment id="26">, marcou o gol.</segment>
    <segment id="27">O bandeirinha havia anulado o tento</segment>
    <segment id="28">, masmas depois de muita demora</segment>
    <segment id="29">, o árbitro de vídeo validou a jogada vascaína.</segment>
    <segment id="30">A partida esfriou nos minutos finais e foi para o intervalo empatada.</segment>
    <segment id="31">A equipe da casa voltou muito mais ligada para o segundo tempo.</segment>
    <segment id="32">Logo aos 2min</segment>
    <segment id="33">, Pará recebeu ótimo passe de Sánchez e bateu firme da entrada da área.</segment>
    <segment id="34">A bola acabou subindo muito e saiu por cima do gol.</segment>
    <segment id="35">Marinho fez um golaço de falta no segundo tempo - Ivan Storti/Santos FC  Menos de dois minutos depois</segment>
    <segment id="36">, em falta perto da área</segment>
    <segment id="37">, Soteldo calibrou o pé e exigiu uma grande defesa de Fernando Miguel.</segment>
    <segment id="38">O Vasco respondeu aos 7min.</segment>
    <segment id="39">Um passe de Cano foi interceptado</segment>
    <segment id="40">, masmas a bola sobrou com Andrey</segment>
    <segment id="41">, que soltou um foguete de fora da área que raspou a trave.</segment>
    <segment id="42">O Santos voltou a tomar a dianteira do placar aos 13min.</segment>
    <segment id="43">Marinho cobrou falta da entrada da área com perfeição e acertou o ângulo para marcar o segundo.</segment>
    <segment id="44">Aos 22min</segment>
    <segment id="45">, o VAR entrou em ação de novo.</segment>
    <segment id="46">Depois de escanteio cobrado por Benítez</segment>
    <segment id="47">, a bola bateu no braço de Alison.</segment>
    <segment id="48">Após analisar o lance na cabine</segment>
    <segment id="49">, o árbitro assinalou o pênalti para o Cruzmaltino.</segment>
    <segment id="50">Na cobrança</segment>
    <segment id="51">, Cano bateu bem e converteu.</segment>
    <segment id="52">A partida caiu de produção depois do gol e terminou empatada por 2 a 2.</segment>
  </rst>
</analysis>