  <rst>
    <segment id="1">Uma chama ininterrupta será acesa nesta terça-feira e formará</segment>
    <segment id="2">, por um ano</segment>
    <segment id="3">, um monumento ao luto durante a pandemia.</segment>
    <segment id="4">A obra de Nuno Ramos</segment>
    <segment id="5">, um isqueiro Zippo alimentado por combustível instalado no Sesc Avenida Paulista</segment>
    <segment id="6">, marca o começo e o fim de um projeto mais ambicioso</segment>
    <segment id="7">, chamado “</segment>
    <segment id="8">A Extinção É para Sempre”.</segment>
    <segment id="9">É no luto</segment>
    <segment id="10">, que atravessa todos nós</segment>
    <segment id="11">, que a série começa e termina</segment>
    <segment id="12">, masmas as sete ações previstas ao longo do ano são respostas a crises de várias ordens.</segment>
    <segment id="13">“</segment>
    <segment id="14">O projeto é uma tentativa de responder a uma agressão múltipla</segment>
    <segment id="15">, que vem um pouco de todos os lados</segment>
    <segment id="16">, com armas múltiplas também</segment>
    <segment id="17">, disparando coisas em várias direções”</segment>
    <segment id="18">, diz o artista plástico.</segment>
    <segment id="19">“Pensei isso</segment>
    <segment id="20">, antes de mais nada</segment>
    <segment id="21">, como</segment>
    <segment id="22">como uma tentativa de manter tudo vivo.</segment>
    <segment id="23">”  O piso de &amp;#039</segment>
    <segment id="24">;Chão-pão&amp;#039</segment>
    <segment id="25">;, uma das ações do projeto de um ano de Nuno Ramos intitulado &amp;#039</segment>
    <segment id="26">;A Extinção</segment>
    <segment id="27">É Para Sempre&amp;#039</segment>
    <segment id="28">; - DivulgaçãoRamos responde a essas várias agressões com linguagens distintas —as apresentações envolvem a participação de figuras</segment>
    <segment id="29">comocomo a escritora Noemi Jaffe</segment>
    <segment id="30">, o cineasta Jorge Bodanzky</segment>
    <segment id="31">, a atriz Edna de Cássia</segment>
    <segment id="32">, o coreógrafo Eduardo Fukushima e o encenador Antonio Araújo.</segment>
    <segment id="33">No caso</segment>
    <segment id="34">caso de “Chama”</segment>
    <segment id="35">, o fogo ininterrupto tem também participação do público e pretende ser um grande chamado internacional.</segment>
    <segment id="36">O site do Sesc fica aberto para inscrições</segment>
    <segment id="37">, e qualquer um pode transmitir sua própria chama</segment>
    <segment id="38">, desde que seja ao vivo</segment>
    <segment id="39">, nos mesmos moldes que a imagem do Zippo instalado no espaço cultural será transmitida online.</segment>
    <segment id="40">A interação torna mais latente o que Ramos persegue com esse trabalho e que parece tão distante durante o confinamento —viver o agora e estar presente</segment>
    <segment id="41">, simultaneamente.</segment>
    <segment id="42">Além de assistir ao fogo</segment>
    <segment id="43">, o público também pode ver as transmissões de "Chão-Pão" entre os dias 28 e 30 de maio.  &amp;#039</segment>
    <segment id="44">;Chão-pão&amp;#039</segment>
    <segment id="45">;, ação do projeto de Nuno Ramos   novamente         de   de  de  representando um  Na performance</segment>
    <segment id="46">, um grupo monta um chão de lajotas quebradas e pães impróprios para consumo.</segment>
    <segment id="47">Eles dançam</segment>
    <segment id="48">, quebram e mudam esses elementos.</segment>
    <segment id="49">Junto à estridência dos materiais</segment>
    <segment id="50">sese rachando vem a repetição da frase</segment>
    <segment id="51">"a culpa não é do povo"</segment>
    <segment id="52">, comum a dois filmes do diretor Glauber Rocha exibidos em monitores distintos —"Deus e o Diabo na Terra do Sol" e "Terra em Transe".</segment>
    <segment id="53">A cada uma das apresentações</segment>
    <segment id="54">, a equipe de artistas muda e a proposta flerta com outra linguagem</segment>
    <segment id="55">.</segment>
    <segment id="56">Em "</segment>
    <segment id="57">A Extinção É para Sempre"</segment>
    <segment id="58">, por exemplo</segment>
    <segment id="59">, um texto de Ramos será dirigido por Antonio Araújo</segment>
    <segment id="60">, numa montagem tragicômica inspirada numa tartaruga em vias de morrer.</segment>
    <segment id="61">Mas outras ações do projeto</segment>
    <segment id="62">, que ainda não têm data para acontecer</segment>
    <segment id="63">, trabalham na escala da cidade e no espaço público</segment>
    <segment id="64">, assim</segment>
    <segment id="65">comocomo o seu "Marcha a Ré".</segment>
    <segment id="66">Em agosto do ano passado</segment>
    <segment id="67">, o artista criou esse cortejo fúnebre também na avenida Paulista</segment>
    <segment id="68">, com o Teatro da Vertigem</segment>
    <segment id="69">, e amplificou os sons de respiradores mecânicos e monitores cardíacos de UTI em caixas de som de cem carros com as janelas abertas.</segment>
    <segment id="70">Performance &amp;#039</segment>
    <segment id="71">;Marcha a Ré&amp;#039</segment>
    <segment id="72">;, de Nuno Ramos e Teatro da Vertigem   novamente         de   de  de  representando um    "</segment>
    <segment id="73">O que costura esses trabalhos é uma ideia de luto</segment>
    <segment id="74">, de um Estado agressor</segment>
    <segment id="75">, de uma perda de contato com qualquer vocalização popular.</segment>
    <segment id="76">Parece que perdemos</segment>
    <segment id="77">, que há uma degradação absoluta da ideia de política"</segment>
    <segment id="78">, diz Ramos.</segment>
    <segment id="79">Dentro desse novo projeto com o Sesc</segment>
    <segment id="80">, uma obra pública de grandes dimensões em São Paulo será coberta com um pano e reinaugurada por uma nova figura de poder</segment>
    <segment id="81">, que, na verdade</segment>
    <segment id="82">, será um cidadão comum.</segment>
    <segment id="83">A disputa clássica entre Antígona e Creonte também será refeita em Heliópolis</segment>
    <segment id="84">, e em grandes proporções —</segment>
    <segment id="85">Creonte será um helicóptero que</segment>
    <segment id="86">, do céu</segment>
    <segment id="87">, batalha com essa Antígona de caixas de som ensurdecedoras</segment>
    <segment id="88">, uma funkeira que o desafia pelos microfones.</segment>
    <segment id="89">"</segment>
    <segment id="90">A política não consegue fazer uma frente ampla</segment>
    <segment id="91">, masmas a gente tem que fazer"</segment>
    <segment id="92">, afirma o artista.</segment>
    <segment id="93">"</segment>
    <segment id="94">É engraçado que existe algum fiasco do lado de lá</segment>
    <segment id="95">, masmas tenho a impressão de que nós ainda não conseguimos criar formas de atrair e analisar o outro</segment>
    <segment id="96">, o que torna ainda mais relevante o papel dos artistas.</segment>
    <segment id="97">"</segment>
    <segment id="98">A Extinção É Para SempreQuando</segment>
    <segment id="99">Estreia em 25/5Onde</segment>
    <segment id="100">Pelo site www.sescsp.org.br/aextincaoeparasempreDireção Nuno Ramos</segment>
  </rst>
</analysis>