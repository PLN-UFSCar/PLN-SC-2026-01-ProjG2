  <rst>
    <segment id="1">A tradicional marca Village</segment>
    <segment id="2">, que desde 2000 fornecia ovos de Páscoa a preços mais competitivos que os das líderes</segment>
    <segment id="3">, vai deixar de oferecer o produto este ano</segment>
    <segment id="4">, apurou a Folha.</segment>
    <segment id="5">O aumento do preço dos insumos</segment>
    <segment id="6">, especialmente de embalagens</segment>
    <segment id="7">, tornou a operação inviável.​</segment>
    <segment id="8">Enquanto isso</segment>
    <segment id="9">, nos supermercados</segment>
    <segment id="10">, as parreiras de ovos encolhem.</segment>
    <segment id="11">A combinação entre inflação em alta e poder de compra em queda tem feito o brasileiro trocar cada vez mais o tradicional ovo de Páscoa por bombons e barras de chocolate.</segment>
    <segment id="12">As antigas parreiras fartas de ovos</segment>
    <segment id="13">sese tornaram espaços mais enxutos</segment>
    <segment id="14">, até 30% menores em relação ao período pré-pandemia.</segment>
    <segment id="15">Os varejistas estão agora expondo barras e bombons em "ilhas"</segment>
    <segment id="16">, montadas na entrada ou em pontos estratégicos das lojas.</segment>
    <segment id="17">A expectativa da Abras (Associação Brasileira de Supermercados) é de um aumento de 5% em volume nas vendas de ovos</segment>
    <segment id="18">, para 9</segment>
    <segment id="19">,5 mil toneladas</segment>
    <segment id="20">, que ainda vão ficar abaixo das 10 mil toneladas vendidas em 2019</segment>
    <segment id="21">, antes da pandemia.</segment>
    <segment id="22">Já o preço médio dos chocolates deve saltar 12% este ano</segment>
    <segment id="23">, diz a associação.</segment>
    <segment id="24">Além de mais caros</segment>
    <segment id="25">, o valor dos ovos varia muito.</segment>
    <segment id="26">Para se</segment>
    <segment id="27">se ter uma ideia</segment>
    <segment id="28">, o ovo de Páscoa de 100 gramas da marca Kinder Ovo</segment>
    <segment id="29">, da Ferrero</segment>
    <segment id="30">, uma das preferidas das crianças</segment>
    <segment id="31">, pode ser encontrado de R$ 53 a R$ 80 a unidade.</segment>
    <segment id="32">Parreira de ovos no Chama Supermercados no Tatuapé</segment>
    <segment id="33">, zona leste da capital paulista.</segment>
    <segment id="34">- Zanone Fraissat/Folhapress"A venda de ovos de Páscoa vem caindo ano a ano"</segment>
    <segment id="35">, disse à FolhaFábio Iwamoto</segment>
    <segment id="36">, diretor do Chama Supermercados</segment>
    <segment id="37">, rede com 15 lojas na zona leste da capital paulista.</segment>
    <segment id="38">"</segment>
    <segment id="39">O consumidor não está a fim de pagar caro por um ovo</segment>
    <segment id="40">sese consegue consumir o mesmo chocolate no formato de barras ou bombons"</segment>
    <segment id="41">, diz ele</segment>
    <segment id="42">, que tem apostado em ilhas de chocolates e colombas em pontos estratégicos das lojas.</segment>
    <segment id="43">Na rede Chama Supermercados</segment>
    <segment id="44">, o espaço dedicado às parreiras de ovos nesta Páscoa foi reduzido em cerca de 30% em relação a 2019</segment>
    <segment id="45">, diz Iwamoto.</segment>
    <segment id="46">Segundo Diego Pereira</segment>
    <segment id="47">, economista da Apas (Associação Paulista de Supermercados)</segment>
    <segment id="48">, o cenário inflacionário tem feito o público buscar alternativas mais baratas em todas as categorias.</segment>
    <segment id="49">"</segment>
    <segment id="50">Os ovos de Páscoa</segment>
    <segment id="51">, especialmente aqueles com brinquedos</segment>
    <segment id="52">, ocupam muito espaço na loja e são muito caros para a média das famílias"</segment>
    <segment id="53">, afirma Pereira. "</segment>
    <segment id="54">Daí o fato de cada vez mais varejistas optarem pela redução das áreas ocupadas pelas parreiras e a instalação de ilhas de produtos com preços mais competitivos"</segment>
    <segment id="55">, afirma.​  &amp;quot</segment>
    <segment id="56">;Ilha&amp;quot</segment>
    <segment id="57">; de chocolates</segment>
    <segment id="58">, no Chama Supermercados</segment>
    <segment id="59">, oferece barras mais em conta que os tradicionais ovos de Páscoa.</segment>
    <segment id="60">- Zanone Fraissat/FolhapressJá a aposta do Carrefour está nos ovos de marca própria da rede.</segment>
    <segment id="61">Produzidos pela fabricante paranaense Barion</segment>
    <segment id="62">, os ovos do Carrefour são em média 30% mais baratos que os de marcas tradicionais.</segment>
    <segment id="63">"</segment>
    <segment id="64">Nesta Páscoa</segment>
    <segment id="65">, o número de itens de marca própria aumentou de nove para 17"</segment>
    <segment id="66">, diz Allan Hock Gate</segment>
    <segment id="67">, diretor de marca própria do Carrefour.</segment>
    <segment id="68">Entre as novidades</segment>
    <segment id="69">, uma marca própria premium</segment>
    <segment id="70">, a Selection.</segment>
    <segment id="71">"</segment>
    <segment id="72">Também estamos expandindo as linhas de bombons e trufas</segment>
    <segment id="73">, que são opções mais baratas para dar de presente do que os ovos"</segment>
    <segment id="74">, afirma Gate</segment>
    <segment id="75">, que conta ainda com colombas da marca Carrefour</segment>
    <segment id="76">, produzidas pela Romanato Alimentos</segment>
    <segment id="77">, de São Bernardo do Campo (SP).</segment>
    <segment id="78">Pesquisa recente da Asserj (Associação de Supermercados do Estado do Rio de Janeiro) sinalizou que mais de 80% dos consumidores estão substituindo produtos mais caros por marcas com valores mais baixos nas gôndolas dos supermercados.</segment>
    <segment id="79">Para Guilherme Mercês</segment>
    <segment id="80">, consultor da Asserj</segment>
    <segment id="81">, a derrubada de restrições este ano</segment>
    <segment id="82">, com mais famílias</segment>
    <segment id="83">sese reunindo</segment>
    <segment id="84">, deve ajudar as vendas</segment>
    <segment id="85">, masmas a inflação ainda faz com que boa parte do público opte por chocolates com preços menores.</segment>
    <segment id="86">"</segment>
    <segment id="87">Essa deve ser uma tendência para a Páscoa"</segment>
    <segment id="88">, afirma Mercês.</segment>
    <segment id="89">Na avaliação de Marcio Milan</segment>
    <segment id="90">, vice-presidente da Abras</segment>
    <segment id="91">, o consumidor não deixará de comprar chocolates para a confraternização</segment>
    <segment id="92">, masmas deve buscar mais ofertas e itens com preços mais baixos.</segment>
    <segment id="93">"</segment>
    <segment id="94">Houve aumentos importantes na pandemia.</segment>
    <segment id="95">As embalagens subiram muito.</segment>
    <segment id="96">Também tivemos altas em ingredientes usados na produção dos chocolates.</segment>
    <segment id="97">O avanço de 12% [dos preços] é uma somatória disso"</segment>
    <segment id="98">, afirma Milan.</segment>
    <segment id="99">Produção de ovos de Páscoa da Village</segment>
    <segment id="100">, em São Paulo: guloseimas só serão oferecidas na padaria Cepam este ano - ReproduçãoVendas melhores no varejo em 2022</segment>
    <segment id="101">, masmas ainda abaixo do pré-crise</segment>
    <segment id="102">As vendas da Páscoa de 2022 devem movimentar R$ 2</segment>
    <segment id="103">,16 bilhões no varejo brasileiro</segment>
    <segment id="104">, estima a CNC (Confederação Nacional do Comércio de Bens</segment>
    <segment id="105">, Serviços e Turismo).</segment>
    <segment id="106">O valor significaria uma alta aproximada de 1</segment>
    <segment id="107">,9% em relação a 2021 (R$ 2</segment>
    <segment id="108">,12 bilhões)</segment>
    <segment id="109">, já com o desconto da inflação.</segment>
    <segment id="110">O montante previsto</segment>
    <segment id="111">, contudo</segment>
    <segment id="112">contudo</segment>
    <segment id="113">, ainda é 5</segment>
    <segment id="114">,7% menor do que o registrado no pré-pandemia.</segment>
    <segment id="115">Em 2019</segment>
    <segment id="116">, antes da crise sanitária</segment>
    <segment id="117">, a Páscoa movimentou R$ 2</segment>
    <segment id="118">,29 bilhões no comércio</segment>
    <segment id="119">, diz a CNC.</segment>
    <segment id="120">A entidade sinaliza que a inflação elevada impede um avanço mais consistente neste ano.</segment>
    <segment id="121">Conforme a CNC</segment>
    <segment id="122">, uma cesta com oito itens típicos da Páscoa</segment>
    <segment id="123">, incluindo chocolates e outros alimentos</segment>
    <segment id="124">, teve alta de 7% nos preços</segment>
    <segment id="125">, em média</segment>
    <segment id="126">, frente a 2021.</segment>
    <segment id="127">É a maior variação da cesta em seis anos.</segment>
    <segment id="128">Na Páscoa da crise</segment>
    <segment id="129">, ovinho de 54 gramas a R$ 11</segment>
    <segment id="130">,99</segment>
    <segment id="131">Segundo o diretor comercial da Village</segment>
    <segment id="132">, Reinaldo Bertagnon</segment>
    <segment id="133">, os ovos de chocolate da companhia serão oferecidos este ano apenas na Cepam –a tradicional padaria na zona leste de São Paulo que deu origem à marca.  "</segment>
    <segment id="134">Com a pandemia</segment>
    <segment id="135">, o índice de devoluções de Páscoa ficou terrível.</segment>
    <segment id="136">No ano passado</segment>
    <segment id="137">, já reduzimos a oferta de ovos.</segment>
    <segment id="138">E neste ano decidimos nem lançar o produto"</segment>
    <segment id="139">, afirma Bertagnon.</segment>
    <segment id="140">O executivo chama a atenção em especial para o aumento dos preços do papel alumínio (50%) e do cacau (47%) no último ano.</segment>
    <segment id="141">"</segment>
    <segment id="142">Um ovo de 130 gramas por R$ 69 é muito caro para a maioria das famílias"</segment>
    <segment id="143">, diz ele.</segment>
    <segment id="144">"</segment>
    <segment id="145">Ninguém está rasgando dinheiro</segment>
    <segment id="146">, as pessoas cortam o supérfluo.</segment>
    <segment id="147">"</segment>
    <segment id="148">Já a líder de mercado Lacta</segment>
    <segment id="149">, marca da multinacional Mondelez</segment>
    <segment id="150">, lançou ovinhos recheados de chocolate de 54 gramas</segment>
    <segment id="151">, com preço sugerido de R$ 11</segment>
    <segment id="152">,99, além de manter outros produtos tradicionais da data e aqueles com embalagens maiores.</segment>
    <segment id="153">"</segment>
    <segment id="154">Estamos trazendo opções que começam em R$ 4</segment>
    <segment id="155">, R$ 5</segment>
    <segment id="156">, até um ovo maior.</segment>
    <segment id="157">Vão desde lembrancinhas até ovos para presentear e impressionar"</segment>
    <segment id="158">, afirma Renata Vieira</segment>
    <segment id="159">, diretora de marketing de chocolates da Mondelez Brasil.</segment>
    <segment id="160">Segundo ela</segment>
    <segment id="161">, a expectativa é avançar em 10% nas vendas em relação ao ano passado.</segment>
    <segment id="162">Alê Costa</segment>
    <segment id="163">, fundador e presidente da Cacau Show</segment>
    <segment id="164">, vai na mesma linha.</segment>
    <segment id="165">Segundo ele</segment>
    <segment id="166">, a marca ampliou a linha de produtos para a Páscoa</segment>
    <segment id="167">, que parte de preços abaixo de R$ 10 até ovos acima de R$ 100.</segment>
    <segment id="168">"</segment>
    <segment id="169">Atendemos a todos os tipos de bolso"</segment>
    <segment id="170">, diz.</segment>
    <segment id="171">Costa afirma que a rede pretende aumentar em 60% as vendas frente à Páscoa do ano passado</segment>
    <segment id="172">, ultrapassando os níveis pré-pandemia.</segment>
    <segment id="173">O crescimento vem na esteira da abertura de franquias da rede.</segment>
    <segment id="174">No ano passado</segment>
    <segment id="175">, a Cacau Show inaugurou 500 lojas.</segment>
    <segment id="176">Neste ano</segment>
    <segment id="177">, serão 1 mil novas unidades</segment>
    <segment id="178">, diz a empresa.</segment>
    <segment id="179">Venda de Ovos de Páscoa</segment>
    <segment id="180">Ano Volume (em toneladas)   2019 10 mil   2020 8</segment>
    <segment id="181">,5 mil   2021 9 mil   2022* 9</segment>
    <segment id="182">,5 mil     Fonte: Abicab</segment>
    <segment id="183">; *previsão Abras</segment>
    <segment id="184">Oferta de emprego temporário caiu 27% este ano</segment>
    <segment id="185">Por conta do reencontro das famílias na Páscoa deste ano</segment>
    <segment id="186">, celebrada em 17 de abril</segment>
    <segment id="187">, grandes fabricantes de chocolates veem condições para crescimento nas vendas em 2022.</segment>
    <segment id="188">"</segment>
    <segment id="189">Vai ser uma Páscoa boa</segment>
    <segment id="190">, masmas não temos expectativa de voltar a épocas bem anteriores</segment>
    <segment id="191">, em que a inflação estava menor</segment>
    <segment id="192">, e o PIB [Produto Interno Bruto]</segment>
    <segment id="193">, maior"</segment>
    <segment id="194">, diz Ubiracy Fonsêca</segment>
    <segment id="195">, presidente da Abicab (Associação Brasileira da Indústria de Chocolates</segment>
    <segment id="196">, Amendoim e Balas).  "</segment>
    <segment id="197">No ano passado</segment>
    <segment id="198">, mesmo com restrições mais fortes</segment>
    <segment id="199">, tivemos cenário positivo para as vendas.</segment>
    <segment id="200">Neste ano</segment>
    <segment id="201">, esperamos um momento melhor"</segment>
    <segment id="202">, diz Marcos Freitas</segment>
    <segment id="203">, gerente de marketing de sazonais da Nestlé Brasil.</segment>
    <segment id="204">A marca espera um crescimento de "duplo dígito" na receita com a Páscoa de 2022</segment>
    <segment id="205">, de acordo com o executivo.</segment>
    <segment id="206">"</segment>
    <segment id="207">A gente traz um portfólio bem variado</segment>
    <segment id="208">, com diferentes sabores e formatos"</segment>
    <segment id="209">, aponta.</segment>
    <segment id="210">A oferta de emprego sazonal está mais enxuta este ano: queda de 27% sobre 2021</segment>
    <segment id="211">, para 8</segment>
    <segment id="212">,5 mil vagas</segment>
    <segment id="213">, segundo a Abicab.</segment>
    <segment id="214">O cálculo envolve tanto vagas abertas em fábricas quanto em pontos de venda.</segment>
    <segment id="215">A associação considera que o número "</segment>
    <segment id="216">sese mantém relevante"</segment>
    <segment id="217">, apesar de ter ficado menor.</segment>
    <segment id="218">As contratações temporárias começaram no segundo semestre de 2021.</segment>
  </rst>
</analysis>