  <rst>
    <segment id="1">Clareza.</segment>
    <segment id="2">Foco.</segment>
    <segment id="3">Precisão.</segment>
    <segment id="4">Cuidar da saúde dos olhos é dever de todos.</segment>
    <segment id="5">Dona Valdomira estava contente.  —</segment>
    <segment id="6">Esse doutor Marco Aurélio é um gênio.</segment>
    <segment id="7">A operação de catarata tinha sido um sucesso.  —E já posso voltar para casa</segment>
    <segment id="8">, doutor?  —</segment>
    <segment id="9">Claro.</segment>
    <segment id="10">Hoje mesmo.</segment>
    <segment id="11">Dona Valdomira chegou aliviada ao seu amplo apartamento em Higienópolis.  —</segment>
    <segment id="12">Será que a Damiana ainda está me esperando?</segment>
    <segment id="13">Tratava-</segment>
    <segment id="14">sese da empregada doméstica.</segment>
    <segment id="15">Vinte e cinco anos de dedicação.</segment>
    <segment id="16">Logo no hall de entrada</segment>
    <segment id="17">, dona Valdomira reparou em alguns detalhes insatisfatórios.  —Não limpou o aparador... cheio de poeira.</segment>
    <segment id="18">A visão da viúva chegava a prodígios de nitidez.  —</segment>
    <segment id="19">Cocô de mosca no vaso de cristal.</segment>
    <segment id="20">Onde já</segment>
    <segment id="21">sese viu?</segment>
    <segment id="22">Na sala de estar</segment>
    <segment id="23">, dona Valdomira teve outra surpresa desagradável.  —Assistindo televisão</segment>
    <segment id="24">, Damiana?</segment>
    <segment id="25">Quem deu autorização?</segment>
    <segment id="26">As ordens eram estritas naquela residência.  —Esses canais só dizem mentira.</segment>
    <segment id="27">Uma vergonha.</segment>
    <segment id="28">Ela não queria que ideias subversivas atingissem o cérebro da criada.  —Só me faltava a Damiana virar comunista.</segment>
    <segment id="29">Imagens chocantes</segment>
    <segment id="30">, enquanto isso</segment>
    <segment id="31">, sucediam-</segment>
    <segment id="32">sese na tela plana de altíssima definição.</segment>
    <segment id="33">Pancadaria.</segment>
    <segment id="34">Quebra-quebra.</segment>
    <segment id="35">Ônibus incendiados.</segment>
    <segment id="36">Dona Valdemira contemplou o espetáculo com olhos agudos.</segment>
    <segment id="37">Penetrantes.</segment>
    <segment id="38">Percucientes.  —Não disse?</segment>
    <segment id="39">Bastou o Lula ganhar...</segment>
    <segment id="40">Ela deu um suspiro.  —</segment>
    <segment id="41">E esses maloqueiros tomam conta.</segment>
    <segment id="42">A idosa teve um leve arrependimento.  —</segment>
    <segment id="43">Sem querer ofender você</segment>
    <segment id="44">, Damiana.</segment>
    <segment id="45">A funcionária resolveu explicar.  —</segment>
    <segment id="46">São bolsonaristas</segment>
    <segment id="47">, dona Valdomira.</segment>
    <segment id="48">Invadindo a Polícia Federal.</segment>
    <segment id="49">Um manto de severidade cobriu repentinamente os traços da anciã.  —</segment>
    <segment id="50">Ah, é?</segment>
    <segment id="51">Ah, é?</segment>
    <segment id="52">As pulseiras de ouro tremeram no braço em riste.  —Considere-</segment>
    <segment id="53">sese despedida</segment>
    <segment id="54">, Damiana.  —Mas</segment>
    <segment id="55">, dona Valdomira... é verdade.  —Comunista dentro de casa?</segment>
    <segment id="56">Além de tudo</segment>
    <segment id="57">, respondona.</segment>
    <segment id="58">Dona Valdomira</segment>
    <segment id="59">sese olha no espelho.  —</segment>
    <segment id="60">Pensar que eu estive cega durante esses vinte e cinco anos.</segment>
    <segment id="61">Novas tecnologias tornam a operação de catarata uma coisa simples.</segment>
    <segment id="62">Mesmo assim</segment>
    <segment id="63">, cada pessoa continua com sua própria visão.</segment>
    <segment id="64">Bolsonaristas tentam invadir PF e queimam veículos em BrasíliaMais    novamente         de   de  de  representando um</segment>
  </rst>
</analysis>