  <rst>
    <segment id="1">No primeiro jogo após a derrota na final da Copa Libertadores</segment>
    <segment id="2">, o Flamengo bateu Ceará nesta terça (30) por 2 a 1</segment>
    <segment id="3">, no Maracanã.</segment>
    <segment id="4">O resultado adiou a festa do Atlético-MG</segment>
    <segment id="5">, que tinha chance de confirmar o título do Campeonato Brasileiro</segment>
    <segment id="6">casocaso os cariocas saíssem de campo sem a vitória.</segment>
    <segment id="7">Com o triunfo</segment>
    <segment id="8">, rubro-negro chegou aos 70 pontos</segment>
    <segment id="9">, oito a menos do que os atleticanos.</segment>
    <segment id="10">O Flamengo ainda tem três jogos por fazer na competição</segment>
    <segment id="11">, o mesmo número que os atleticanos.</segment>
    <segment id="12">Gabigol marcou pelo Flamengo em partida contra o Ceará</segment>
    <segment id="13">, no Maracanã - Ricardo Moraes/ReutersPara ser campeão</segment>
    <segment id="14">, a equipe da Gávea terá de vencer Sport</segment>
    <segment id="15">, Santos e Atlético-GO e torcer</segment>
    <segment id="16">para que</segment>
    <segment id="17">para que o Atlético-MG não faça mais de um ponto no total contra Bahia</segment>
    <segment id="18">, Red Bull Bragantino e Grêmio.</segment>
    <segment id="19">Vale lembrar que o elenco dirigido por Cuca está invicto há sete jogos</segment>
    <segment id="20">, com seis vitórias e um empate.</segment>
    <segment id="21">Do outro lado</segment>
    <segment id="22">, o Flamengo terá nas rodadas finais do Nacional o comando do interino Maurício Souza.</segment>
    <segment id="23">O auxiliar assumiu a equipe após a demissão de Renato Gaúcho</segment>
    <segment id="24">, que não resistiu à derrota para o Palmeiras na final do torneio continental</segment>
    <segment id="25">, no sábado (27)</segment>
    <segment id="26">, por 2 a 1</segment>
    <segment id="27">, na prorrogação.</segment>
    <segment id="28">A pressão sobre o comandante já era grande desde a eliminação na semifinal da Copa do Brasil</segment>
    <segment id="29">, em duelo com o Athletico</segment>
    <segment id="30">, sem contar o fato de ele ter deixado o time com chances remotas de ganhar o Nacional.</segment>
    <segment id="31">No reencontro com a torcida após a perda do título continental</segment>
    <segment id="32">, o Flamengo ganhou graças aos gols de Gabigol e Matheuzinho.</segment>
    <segment id="33">Rick descontou para o Ceará.</segment>
  </rst>
</analysis>