  <rst>
    <segment id="1">Dizem que o general inglês William Erskine</segment>
    <segment id="2">, que tinha vindo para Portugal com o Exército inglês para nos ajudar na luta contra Napoleão</segment>
    <segment id="3">, sese atirou de uma janela em Lisboa.</segment>
    <segment id="4">Não creio que a culpa tenha sido da cidade.</segment>
    <segment id="5">É certo que o grande mérito que</segment>
    <segment id="6">sese costuma atribuir a Lisboa não é propriamente muito impressionante.</segment>
    <segment id="7">Julgo que é unânime</segment>
    <segment id="8">, tanto entre portugueses</segment>
    <segment id="9">comocomo entre estrangeiros</segment>
    <segment id="10">, que a melhor coisa que Lisboa tem é a luz.</segment>
    <segment id="11">No entanto</segment>
    <segment id="12">, o modo particular</segment>
    <segment id="13">comocomo o sol brilha sobre uma cidade dificilmente será motivo de orgulho.</segment>
    <segment id="14">Mais: se</segment>
    <segment id="15">se a luz é o melhor</segment>
    <segment id="16">, quer dizer que aquilo que ela ilumina não é especialmente digno de nota.</segment>
    <segment id="17">Colunas e BlogsReceba no seu email uma seleção de colunas e blogs da FolhaCarregando...</segment>
    <segment id="18">Por outro lado</segment>
    <segment id="19">, contudo</segment>
    <segment id="20">contudo</segment>
    <segment id="21">, é fácil simpatizar com Lisboa.</segment>
    <segment id="22">Parece que</segment>
    <segment id="23">, no terremoto de 1755</segment>
    <segment id="24">, várias igrejas ficaram destruídas.</segment>
    <segment id="25">Mas a rua dos lupanares</segment>
    <segment id="26">, ao que dizem os historiadores —que</segment>
    <segment id="27">, aliás</segment>
    <segment id="28">, deviam dar mais atenção aos lupanares—</segment>
    <segment id="29">, ficou intacta.</segment>
    <segment id="30">Há que respeitar uma cidade em que isso acontece.</segment>
    <segment id="31">O certo é que</segment>
    <segment id="32">, em 1813</segment>
    <segment id="33">, indiferente à beleza da luz de Lisboa</segment>
    <segment id="34">, William Erskine resolveu atirar-</segment>
    <segment id="35">sese de uma janela.</segment>
    <segment id="36">E, segundo reza a lenda</segment>
    <segment id="37">, as suas últimas palavras</segment>
    <segment id="38">, já depois de</segment>
    <segment id="39">sese ter lançado</segment>
    <segment id="40">, foram: "</segment>
    <segment id="41">Ora bem</segment>
    <segment id="42">, por que é que eu fiz isto?</segment>
    <segment id="43">".</segment>
    <segment id="44">Esta ideia</segment>
    <segment id="45">, a última que Erskine teve</segment>
    <segment id="46">, é muito fresca.</segment>
    <segment id="47">"</segment>
    <segment id="48">Por que é que eu fiz isto?</segment>
    <segment id="49">", diz ele.</segment>
    <segment id="50">Não tentou imputar a outros a responsabilidade de uma opção que tomou.</segment>
    <segment id="51">O responsável foi ele</segment>
    <segment id="52">, e a última coisa que faz neste planeta é admiti-lo.</segment>
    <segment id="53">Duzentos anos depois</segment>
    <segment id="54">, não é essa a prática habitual —especialmente entre os famosos.</segment>
    <segment id="55">Ilustração de Luiza Pannunzio para coluna de Ricardo Araújo Pereira de 4 de fevereiro de 2024 - FolhapressUm ator de Hollywood destrata a namorada.</segment>
    <segment id="56">Quem é o responsável?</segment>
    <segment id="57">Os seus demônios.</segment>
    <segment id="58">Ele é um mero títere nas mãos cruéis de uma longa lista de traumas</segment>
    <segment id="59">, desilusões e complexos que o manipulam para ser</segment>
    <segment id="60">comocomo é</segment>
    <segment id="61">, completamente contra a sua vontade.</segment>
    <segment id="62">Já houve um tempo em que era tabu falar de saúde mental —o que</segment>
    <segment id="63">, obviamente</segment>
    <segment id="64">, estava errado.</segment>
    <segment id="65">Mas agora todo mundo fala de saúde mental</segment>
    <segment id="66">, mesmo quem não tem a menor competência.</segment>
    <segment id="67">Estrelas de cinema encomendam aos seus agentes um comunicado sobre a sua luta contra a ansiedade.</segment>
    <segment id="68">Em maior ou menor grau</segment>
    <segment id="69">, todo mundo luta contra a ansiedade.</segment>
    <segment id="70">Mas a ansiedade das estrelas é</segment>
    <segment id="71">, claro</segment>
    <segment id="72">, maior do que a nossa.</segment>
    <segment id="73">A literatura e a saúde mentalMais    novamente         de   de  de  representando um</segment>
    <segment id="74">Os comuns mortais não fazem ideia da pressão que a vida das estrelas exerce sobre elas.</segment>
    <segment id="75">Ser rico e famoso é uma cruz que</segment>
    <segment id="76">, felizmente</segment>
    <segment id="77">, nós não temos que carregar diariamente.</segment>
    <segment id="78">As conversas que as pacientes idosas costumavam ter na sala de espera do médico</segment>
    <segment id="79">, em que cada uma pretendia superiorizar-</segment>
    <segment id="80">sese às outras com a sua maleita física</segment>
    <segment id="81">, são as mesmas que decorrem agora no Instagram</segment>
    <segment id="82">, masmas sobre maleitas mentais.</segment>
    <segment id="83">É algo que</segment>
    <segment id="84">, confesso</segment>
    <segment id="85">, tem prejudicado a minha saúde mental.</segment>
  </rst>
