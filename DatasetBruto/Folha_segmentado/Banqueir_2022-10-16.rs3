  <rst>
    <segment id="1">O banqueiro Ricardo Lacerda</segment>
    <segment id="2">, do banco de investimento BR Partners</segment>
    <segment id="3">, decidiu</segment>
    <segment id="4">sese desfiliar do partido Novo neste sábado (15)</segment>
    <segment id="5">, depois da reação de correligionários contra João Amoêdo</segment>
    <segment id="6">, que declarou voto em Lula no 2º turno.</segment>
    <segment id="7">Fundador do Novo e presidenciável pelo partido em 2018</segment>
    <segment id="8">, Amoêdo disse que</segment>
    <segment id="9">, contra a reeleição de Bolsonaro</segment>
    <segment id="10">, vai votar no PT pela primeira vez na vida.</segment>
    <segment id="11">Em entrevista ao Painel S.A.</segment>
    <segment id="12">, ele afirmou que o atual presidente é "um governante autocrático que</segment>
    <segment id="13">sese coloca acima das instituições".</segment>
    <segment id="14">A fala desencadeou uma série de reações no partido.</segment>
    <segment id="15">Eduardo Ribeiro</segment>
    <segment id="16">, hoje presidente do Novo</segment>
    <segment id="17">, chamou de "vergonhosa</segment>
    <segment id="18">, constrangedora e incoerente"</segment>
    <segment id="19">a declaração de voto de Amoêdo.</segment>
    <segment id="20">Felipe D'Avila</segment>
    <segment id="21">, presidenciável do partido derrotado no 1º turno deste ano</segment>
    <segment id="22">, foi às redes sociais dizer "Amoêdo</segment>
    <segment id="23">, pega o boné e vai</segment>
    <segment id="24">embora</segment>
    <segment id="25">embora".</segment>
    <segment id="26">O diretório nacional do partido também divulgou nota semelhante.</segment>
    <segment id="27">Ricardo Lacerda</segment>
    <segment id="28">, fundador do banco BR Partners</segment>
    <segment id="29">, na sede da empresa</segment>
    <segment id="30">, em São Paulo - Bruno Santos/FolhapressEm desagravo</segment>
    <segment id="31">, Ricardo Lacerda disse que discorda da decisão de Amoêdo de votar em Lula</segment>
    <segment id="32">, masmas considerou sua iniciativa "corajosa</segment>
    <segment id="33">, fundamentada e estritamente pessoal".</segment>
    <segment id="34">Em mensagem nas redes sociais</segment>
    <segment id="35">, Lacerda lamentou o tom das críticas feitas pela legenda.</segment>
    <segment id="36">"</segment>
    <segment id="37">Lamentável a reação do partido Novo e seus líderes condenando-o</segment>
    <segment id="38">, numa humilhante tentativa de lamber as sobras do bolsonarismo.</segment>
    <segment id="39">Desfiliar-me-ei</segment>
    <segment id="40">", escreveu o banqueiro.</segment>
    <segment id="41">Ao declarar voto em Lula</segment>
    <segment id="42">, Amoêdo ressalvou que mantém críticas e restrições ao PT por diversos motivos</segment>
    <segment id="43">, como</segment>
    <segment id="44">como os escândalos de corrupção e crise econômica</segment>
    <segment id="45">, porém</segment>
    <segment id="46">porém, vê em Bolsonaro um risco substancialmente maior.</segment>
    <segment id="47">Entre os riscos que o fazem desistir do voto nulo</segment>
    <segment id="48">, ele cita a recente declaração de Bolsonaro sobre alterar a composição do STF.</segment>
    <segment id="49">João Amoêdo</segment>
    <segment id="50">, fundador do partido Novo - Gabriel Cabral/FolhapressQuestionado</segment>
    <segment id="51">sese esperava receber críticas do Novo</segment>
    <segment id="52">, Amoêdo afirmou que seria possível</segment>
    <segment id="53">, masmas não seria coerente.  "</segment>
    <segment id="54">O estatuto do Novo não prevê qualquer restrição ao filiado em situações</segment>
    <segment id="55">comocomo essa</segment>
    <segment id="56">, e um dos princípios do partido é a liberdade de expressão.</segment>
    <segment id="57">Além disso</segment>
    <segment id="58">, não tive conhecimento de qualquer crítica do partido aos mandatários que declararam voto e apoio a Bolsonaro logo após o término das eleições</segment>
    <segment id="59">, mesmo havendo uma diretriz partidária que orientava a instituição e as candidaturas para esse ano</segment>
    <segment id="60">comocomo oposição ao governo federal"</segment>
    <segment id="61">, disse Amoêdo.  Joana Cunha com Paulo Ricardo Martins e Diego</segment>
    <segment id="62">Felix</segment>
  </rst>
</analysis>