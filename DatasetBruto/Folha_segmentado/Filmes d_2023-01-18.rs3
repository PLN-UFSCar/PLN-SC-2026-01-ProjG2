  <rst>
    <segment id="1">Cinco filmes do diretor Sylvio Back</segment>
    <segment id="2">, 85 anos</segment>
    <segment id="3">, entraram no catálogo do Itaú Cultural Play e podem ser vistos gratuitamente no streaming.</segment>
    <segment id="4">É uma oportunidade de o público conhecer ou revisitar a obra do cineasta</segment>
    <segment id="5">, com quase seis décadas dedicadas ao cinema brasileiro.</segment>
    <segment id="6">Entre os títulos disponíveis estão o clássico ‘Aleluia</segment>
    <segment id="7">, Gretchen’ (1976) e ‘Lance Maior’ (1968)</segment>
    <segment id="8">, estreia de Back em longas-metragens.  ‘Voltei ao cartaz’</segment>
    <segment id="9">, sentencia o diretor</segment>
    <segment id="10">, sobre adição de cinco de seus longas de ficção ao Itaú Cultural Play.</segment>
    <segment id="11">Autor de mais de 30 obras</segment>
    <segment id="12">, entre curtas</segment>
    <segment id="13">, médias e longas</segment>
    <segment id="14">, de ficção e documentários</segment>
    <segment id="15">, Back é um entusiasta do streaming.</segment>
    <segment id="16">"É o cinema por excelência.</segment>
    <segment id="17">Um autor quer que seu trabalho seja visto.</segment>
    <segment id="18">A chegada dos meus filmes ao streaming mostram a longevidade da minha obra"</segment>
    <segment id="19">, afirma.  Obra que</segment>
    <segment id="20">, em boa parte</segment>
    <segment id="21">, trouxe o Sul do país para as telas do cinema brasileiro.</segment>
    <segment id="22">"</segment>
    <segment id="23">Não houve premeditação em formatar minha filmografia sobre as questões dos estados do Sul</segment>
    <segment id="24">, ela tem a ver com minha origem"</segment>
    <segment id="25">, diz Back</segment>
    <segment id="26">, nascido em Blumenau (SC)</segment>
    <segment id="27">, filho de imigrantes húngaro e alemã.</segment>
    <segment id="28">A região está em ‘Lance Maior’</segment>
    <segment id="29">, ‘a primeira vez que Curitiba apareceu nas telas’</segment>
    <segment id="30">, segundo Back.</segment>
    <segment id="31">E em ‘Aleluia</segment>
    <segment id="32">, Gretchen’</segment>
    <segment id="33">, longa sobre o nazismo em uma cidade paranaense</segment>
    <segment id="34">, e em ‘</segment>
    <segment id="35">A Guerra dos Pelados’</segment>
    <segment id="36">, que retrata o Contestado</segment>
    <segment id="37">, conflito entre o Paraná e Santa Catarina nos anos 1910.</segment>
    <segment id="38">Confira filmes de Sylvio</segment>
    <segment id="39">Back disponíveis no Itaú Cultural PlayMais    novamente         de   de  de  representando um  Além do olhar para o Sul</segment>
    <segment id="40">, o diretor</segment>
    <segment id="41">sese abastece de temas ligados à história do Brasil</segment>
    <segment id="42">, em um cinema</segment>
    <segment id="43">, como</segment>
    <segment id="44">como ele diz</segment>
    <segment id="45">, ‘que desconfia’.</segment>
    <segment id="46">"</segment>
    <segment id="47">Não quero fundar verdade alguma.</segment>
    <segment id="48">Tenho prazer em deixar o espectador desarvorado"</segment>
    <segment id="49">, afirma.</segment>
    <segment id="50">"</segment>
    <segment id="51">Daí meu interesse em buscar a história.</segment>
    <segment id="52">Meus filmes dialogam com o presente</segment>
    <segment id="53">, com assuntos de hoje</segment>
    <segment id="54">, como</segment>
    <segment id="55">como os indígenas em risco</segment>
    <segment id="56">, as células de nazifacismo encontradas no Sul e a situação do negro no país.</segment>
    <segment id="57">"</segment>
    <segment id="58">O cinema que faz</segment>
    <segment id="59">, diz Back</segment>
    <segment id="60">, além de desconfiar</segment>
    <segment id="61">, é 'desideologizado'.</segment>
    <segment id="62">"</segment>
    <segment id="63">Isso significa ficar equidistante das paixões</segment>
    <segment id="64">, não ter medo de me contradizer dentro da minha obra.</segment>
    <segment id="65">Gosto de autores que não têm medo do paradoxo</segment>
    <segment id="66">, pois</segment>
    <segment id="67">pois suas obras sobrevivem a qualquer claustro ideológico"</segment>
    <segment id="68">, afirma.</segment>
    <segment id="69">No segundo semestre</segment>
    <segment id="70">, mais sete filmes de Back serão incorporados ao catálogo do Itaú Cultural Play.</segment>
    <segment id="71">Além disso</segment>
    <segment id="72">, segundo o diretor</segment>
    <segment id="73">, a Cinemateca Brasileira está restaurando ‘</segment>
    <segment id="74">As Moradas’</segment>
    <segment id="75">, um curta de 1964 que foi sua primeira experiência no cinema.</segment>
    <segment id="76">Confira os filmes disponíveis 'Lance Maior’ (1968) ‘</segment>
    <segment id="77">A Guerra dos Pelados’ (1971) ‘Aleluia</segment>
    <segment id="78">, Gretchen’ (1976) ‘Cruz e Sousa - O Poeta do Desterro’ (1999) ‘Lost Zweig - Os Últimos Dias de Stefan Zweig no Brasil’ (2003)</segment>
    <segment id="79">Como assistir Itaú Cultural Play www.itauculturalplay.com.br Gratuito</segment>
  </rst>
</analysis>