  <rst>
    <segment id="1">O escritor Itamar Vieira Junior defendeu neste domingo (26)</segment>
    <segment id="2">, na Flip</segment>
    <segment id="3">, que a literatura tenha uma função coletiva e sirva para refletir sobre nossos tempos.</segment>
    <segment id="4">O colunista da Folha participou de um debate ao lado da artista indígena Glicéria Tupinambá e da professora Miriam Esposito.</segment>
    <segment id="5">O escritor Itamar Vieira Jr. na Flip - Divulgação"Muito</segment>
    <segment id="6">sese diz sobre o trabalho solitário de quem escreve.</segment>
    <segment id="7">Mas é impossível escrever sem pensar nos que estão à minha volta</segment>
    <segment id="8">, na minha capacidade de trazer isso para a narrativa"</segment>
    <segment id="9">, afirmou Vieira Jr. "</segment>
    <segment id="10">As personagens carregam consigo uma história que nos trouxe até aqui.</segment>
    <segment id="11">"  Casa Folha na Flip 2023Mais    novamente         de   de  de  representando um  Ele ainda afirmou que a ficção é uma tentativa de entender o mundo.</segment>
    <segment id="12">"</segment>
    <segment id="13">Durante muitos anos</segment>
    <segment id="14">, nos envergonhamos da história brasileira.</segment>
    <segment id="15">Mas conseguimos tirar dessa vergonha algo mais poderoso</segment>
    <segment id="16">, que é</segment>
    <segment id="17">sese reconhecer nessa história</segment>
    <segment id="18">, compreendê-la para projetar um presente e um futuro diferentes</segment>
    <segment id="19">,"</segment>
    <segment id="20">A tenda dos autores ficou lotada</segment>
    <segment id="21">, um momento raro nesta edição da Flip.</segment>
    <segment id="22">Os três convidados foram aplaudidos entusiasticamente várias vezes pela plateia.</segment>
    <segment id="23">No começo do debate</segment>
    <segment id="24">, Glicéria Tupinambá convidou o público a participar de de um ritual de seu povo</segment>
    <segment id="25">, no qual a plateia era convocada a responder gritos e bater o pé no chão enquanto ela cantava.</segment>
    <segment id="26">FLIP 2023Mais    novamente         de   de  de  representando um</segment>
    <segment id="27">A artista e pesquisadora falou sobre a confecção do manto tupinambá que tem sido exibido em cidades do país</segment>
    <segment id="28">, inspirada em saberes de seus antepassados</segment>
    <segment id="29">, que confeccionavam peças do tipo —hoje</segment>
    <segment id="30">, todos os mantos do século 16 conhecidos estão na Europa.</segment>
    <segment id="31">Um deles vai voltar pra o Brasil</segment>
    <segment id="32">, como</segment>
    <segment id="33">como doação do Museu Nacional da Dinamarca para a recomposição do Museu Nacional brasileiro.</segment>
    <segment id="34">"Não assino o manto.</segment>
    <segment id="35">Fico discutindo o parentesco</segment>
    <segment id="36">, sese sou filha do manto ou</segment>
    <segment id="37">sese ele é meu filho"</segment>
    <segment id="38">, disse ela. "</segment>
    <segment id="39">Na coletividade</segment>
    <segment id="40">, não trato a luta separadamente.</segment>
    <segment id="41">Utilizo a ferramenta da arte para chegar a algum lugar.</segment>
    <segment id="42">"  Glicéria também narrou de forma eloquente sua saga para confeccionar o novo manto.</segment>
    <segment id="43">Um trabalho que envolveu pesquisa</segment>
    <segment id="44">, visitas a instituições europeias —e também</segment>
    <segment id="45">, segundo ela</segment>
    <segment id="46">, revelações espirituais.</segment>
    <segment id="47">"</segment>
    <segment id="48">Tem o lugar do sonho.</segment>
    <segment id="49">Tem o gavião falando comigo.</segment>
    <segment id="50">Se eu fosse entender na filosofia do outro</segment>
    <segment id="51">, eu estava internada</segment>
    <segment id="52">"</segment>
    <segment id="53">, riu.</segment>
    <segment id="54">Tudo a lerReceba no seu email uma seleção com lançamentos</segment>
    <segment id="55">, clássicos e curiosidades literáriasCarregando...</segment>
  </rst>
</analysis>