  <rst>
    <segment id="1">O jornalista e escritor Edney Silvestre vai lançar o livro "</segment>
    <segment id="2">Segredos de um Repórter" na próxima terça (21)</segment>
    <segment id="3">, na Livraria da Travessa do shopping Iguatemi</segment>
    <segment id="4">, em São Paulo.</segment>
    <segment id="5">A obra reúne memórias de sua trajetória jornalística que teve início em 1992 e terminou em janeiro de 2023</segment>
    <segment id="6">, quando foi demitido da Globo.</segment>
    <segment id="7">Edney Silvestre durante a Flip - Leticia Moreira/FolhapressNo volume</segment>
    <segment id="8">, que considera a sua "despedida da profissão"</segment>
    <segment id="9">, Edney fala sobre os desafios que enfrentou ao</segment>
    <segment id="10">sese transferir da impressa escrita para a televisão no final de 1996</segment>
    <segment id="11">, quando virou correspondente da Globo em Nova York.</segment>
    <segment id="12">Na cidade americana</segment>
    <segment id="13">, ele cobriu os atentados terroristas de 11 de setembro de 2011.</segment>
    <segment id="14">No livro</segment>
    <segment id="15">, ele relembra também outras muitas reportagens feitas durante seus 30 anos de carreira</segment>
    <segment id="16">comocomo repórter.</segment>
    <segment id="17">Lançamento do livro Mais    novamente         de   de  de  representando um  Edney Silvestre é também autor de livros de ficção.</segment>
    <segment id="18">A sua obra de estreia</segment>
    <segment id="19">, "</segment>
    <segment id="20">Se Eu Fechar os Olhos Agora" (2009)</segment>
    <segment id="21">, lhe rendeu o prêmio Jabuti de Literatura e teve sua história transformada em minissérie</segment>
    <segment id="22">, pela emissora</segment>
    <segment id="23">, sob direção de Carlos Manga Jr. em 2018.</segment>
    <segment id="24">PALMAS</segment>
    <segment id="25">O ator Fernando Siqueira</segment>
    <segment id="26">, que está em cartaz com a peça &amp;quot</segment>
    <segment id="27">;Methusalem or the Eternal Bourgeois&amp;quot</segment>
    <segment id="28">;, na cidade de Culver City</segment>
    <segment id="29">, na Califórnia</segment>
    <segment id="30">, nos EUA - Arquivo pessoalO artista brasileiro</segment>
    <segment id="31">Fernando Siqueira foi parabenizado pelo ator norte-americano Shia LaBeouf por sua atuação no espetáculo "</segment>
    <segment id="32">Methusalem or the Eternal Bourgeois" (Matusalém ou o eterno burguês</segment>
    <segment id="33">, em tradução livre)</segment>
    <segment id="34">, que está em cartaz na cidade de Culver City</segment>
    <segment id="35">, na Califórnia</segment>
    <segment id="36">, nos EUA.</segment>
    <segment id="37">O encontro</segment>
    <segment id="38">, ocorrido nesta semana</segment>
    <segment id="39">, sese dá num momento em que o brasileiro de 25 anos tem ampliado sua presença na cena artística hollywoodiana.</segment>
    <segment id="40">Além de ator</segment>
    <segment id="41">, Siqueira é pintor e diretor de cinema.  com BIANKA VIEIRA</segment>
    <segment id="42">, KARINA MATIAS e MANOELLA SMITH</segment>
  </rst>
