  <rst>
    <segment id="1">Se estivesse vivo</segment>
    <segment id="2">, Prince completaria 65 anos nesta quarta-feira (7).</segment>
    <segment id="3">Além do nascimento da voz de "Purple Rain"</segment>
    <segment id="4">, a data marca ainda a mudança de seu nome para um símbolo impronunciável</segment>
    <segment id="5">, há 30 anos.</segment>
    <segment id="6">Capa do álbum conhecido</segment>
    <segment id="7">comocomo &amp;quot</segment>
    <segment id="8">;Love Symbol&amp;quot</segment>
    <segment id="9">;, com imagem de símbolo que Prince adotou</segment>
    <segment id="10">comocomo nome - ReproduçãoJunção das imagens que representam os gêneros masculino e feminino</segment>
    <segment id="11">, acrescida de um elemento que remete a uma corneta</segment>
    <segment id="12">, o símbolo representa um dos grandes mistérios da carreira de Prince</segment>
    <segment id="13">, marcada por excentricidades e rebeldia.</segment>
    <segment id="14">Ao anunciar a mudança</segment>
    <segment id="15">, em junho de 1993</segment>
    <segment id="16">, o artista</segment>
    <segment id="17">sese limitou a dizer:</segment>
    <segment id="18">"É um símbolo impronunciável cujo significado não foi identificado.</segment>
    <segment id="19">Diz respeito a pensar de novas formas</segment>
    <segment id="20">, a sincronizar com uma nova frequência".</segment>
    <segment id="21">Em inglês</segment>
    <segment id="22">, a nota brincava com a palavra frequência</segment>
    <segment id="23">, escrita</segment>
    <segment id="24">comocomo "free-quency"</segment>
    <segment id="25">, com o termo equivalente a liberdade à frente.</segment>
    <segment id="26">Por isso</segment>
    <segment id="27">, muitos assumiram na época que a mudança foi uma tentativa de Prince</segment>
    <segment id="28">sese livrar de sua gravadora</segment>
    <segment id="29">, a Warner Music</segment>
    <segment id="30">, que ele acusava de podar seus lançamentos musicais e de controlar decisões artísticas referentes à sua carreira.</segment>
    <segment id="31">Veja fotos de PrinceMais    novamente         de   de  de  representando um  Prince havia assinado um contrato com a empresa</segment>
    <segment id="32">, não sua nova persona inominável</segment>
    <segment id="33">, dizia.</segment>
    <segment id="34">Legalmente</segment>
    <segment id="35">, porém</segment>
    <segment id="36">porém, a troca de nome não tinha qualquer impacto.</segment>
    <segment id="37">Como o símbolo não existia</segment>
    <segment id="38">, veículos de imprensa e canais de televisão começaram a</segment>
    <segment id="39">sese referir ao músico com a própria imagem da insígnia ou</segment>
    <segment id="40">comocomo "o artista previamente conhecido</segment>
    <segment id="41">comocomo Prince".</segment>
    <segment id="42">Assim, a suposta tentativa de boicotar a gravadora acabou rendendo poucos frutos</segment>
    <segment id="43">, e se</segment>
    <segment id="44">se tornou piada na indústria.</segment>
    <segment id="45">Antes de ser adotado</segment>
    <segment id="46">comocomo nome</segment>
    <segment id="47">, o símbolo já havia aparecido em artes e capas de discos de Prince</segment>
    <segment id="48">, em diferentes versões.</segment>
    <segment id="49">Originalmente</segment>
    <segment id="50">, ele não tinha o elemento de corneta</segment>
    <segment id="51">, adicionado</segment>
    <segment id="52">para que</segment>
    <segment id="53">para que o músico pudesse registrá-lo</segment>
    <segment id="54">comocomo sua propriedade intelectual.</segment>
    <segment id="55">Prince em &amp;quot</segment>
    <segment id="56">;Purple Rain&amp;quot</segment>
    <segment id="57">; - DivulgaçãoSeu álbum conhecido</segment>
    <segment id="58">comocomo "Love Symbol"</segment>
    <segment id="59">, de 1992</segment>
    <segment id="60">, na verdade levava o símbolo</segment>
    <segment id="61">comocomo nome.</segment>
    <segment id="62">Na ausência de uma palavra para batizá-lo</segment>
    <segment id="63">, ele acabou ganhando</segment>
    <segment id="64">, popularmente</segment>
    <segment id="65">, o título de símbolo do amor.</segment>
    <segment id="66">Também era de longa data a tendência de Prince usar símbolos e números na escrita.</segment>
    <segment id="67">O dois e o quatro</segment>
    <segment id="68">, por exemplo</segment>
    <segment id="69">, com frequência faziam as vezes das preposições inglesas "to" e "for" nas notas que ele emitia.</segment>
    <segment id="70">Prince nunca deu uma explicação exata para a existência do símbolo e</segment>
    <segment id="71">, anos depois</segment>
    <segment id="72">, reverteu a mudança</segment>
    <segment id="73">, já fora da Warner Music.</segment>
    <segment id="74">Ele disse</segment>
    <segment id="75">, no entanto</segment>
    <segment id="76">, que ela aconteceu</segment>
    <segment id="77">porque</segment>
    <segment id="78">porque seu espírito o havia guiado para isso</segment>
    <segment id="79">, como</segment>
    <segment id="80">como uma forma de</segment>
    <segment id="81">sese divorciar de seu passado.</segment>
    <segment id="82">"</segment>
    <segment id="83">Assim que aconteceu</segment>
    <segment id="84">, muitas coisas começaram a mudar na minha vida.</segment>
    <segment id="85">As pessoas podem dizer algo sobre o Prince</segment>
    <segment id="86">, o que costumava me incomodar</segment>
    <segment id="87">, masmas assim que mudei de nome isso deixou de ter um efeito sobre mim"</segment>
    <segment id="88">, afirmou à MTV em 1999.</segment>
  </rst>
</analysis>