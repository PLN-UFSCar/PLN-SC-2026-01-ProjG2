  <rst>
    <segment id="1">A primeira pesquisa Datafolha de segundo turno destas eleições mostra Luiz Inácio Lula da Silva (PT) à frente entre eleitores que</segment>
    <segment id="2">sese declaram negros</segment>
    <segment id="3">, enquanto Jair Bolsonaro (PL) lidera nas intenções de voto de brancos.</segment>
    <segment id="4">O petista tem 49% contra 43% do adversário entre pardos</segment>
    <segment id="5">, no limite da margem de erro para esse grupo</segment>
    <segment id="6">, que é de três pontos percentuais.</segment>
    <segment id="7">A vantagem</segment>
    <segment id="8">sese alarga entre pretos</segment>
    <segment id="9">, passando para 57% a 35%</segment>
    <segment id="10">, sendo que a margem cresce para cinco pontos.</segment>
    <segment id="11">O ex-presidente Lula (PT) e o presidente Jair Bolsonaro (PL)</segment>
    <segment id="12">, que disputam o segundo turno - Ernesto Benavides/AFP e Andre Coelho/Pool via ReutersJá o presidente marca 50% a 43% de Lula entre o eleitorado branco</segment>
    <segment id="13">, portanto acima das margens de três pontos.</segment>
    <segment id="14">Os indecisos são 2% entre brancos e pardos e 1% entre pretos</segment>
    <segment id="15">, sem contar os que pretendem anular ou votar em branco.</segment>
    <segment id="16">O levantamento ouviu 2.884 pessoas de quarta (5) até esta sexta (7).</segment>
    <segment id="17">No Brasil</segment>
    <segment id="18">, 40% do eleitorado</segment>
    <segment id="19">sese declara pardo</segment>
    <segment id="20">, 35%, branco</segment>
    <segment id="21">, e 16%</segment>
    <segment id="22">, preto</segment>
    <segment id="23">, segundo o Datafolha.</segment>
    <segment id="24">Amarelos e indígenas não foram incluídos</segment>
    <segment id="25">porque</segment>
    <segment id="26">porque as bases de dados são muito pequenas.</segment>
    <segment id="27">Abaixo</segment>
    <segment id="28">, veja o desempenho dos rivais por cor nas respostas estimuladas</segment>
    <segment id="29">, ou seja</segment>
    <segment id="30">, em que os nomes dos candidatos são lidos ao entrevistado.</segment>
    <segment id="31">A pesquisa foi contratada pela Folha e pela TV Globo e está registrada na Justiça Eleitoral sob o número BR-02012/2022.</segment>
    <segment id="32">As sondagens de segundo turno não são comparáveis às de primeiro turno.</segment>
    <segment id="33">Lula X Bolsonaro</segment>
    <segment id="34">por grupoVeja os resultados da primeira pesquisa Datafolha de 2º turnoLula lidera entre mulheres</segment>
    <segment id="35">, masmas empata com Bolsonaro entre homensLula e Bolsonaro</segment>
    <segment id="36">têm empate técnico no Sudeste no 2º turnoLula lidera entre mais pobres</segment>
    <segment id="37">, masmas Bolsonaro ganha na faixa de renda acima no 2º turnoLula lidera entre negros</segment>
    <segment id="38">, e Bolsonaro</segment>
    <segment id="39">, entre brancos no 2º turnoLula lidera entre católicos e Bolsonaro</segment>
    <segment id="40">, entre evangélicos no 2º turnoEntenda</segment>
    <segment id="41">comocomo ler uma pesquisa eleitoral</segment>
    <segment id="42">Eleitores enfrentam filas para votar em todo o BrasilMais    novamente         de   de  de  representando um</segment>
  </rst>
