  <rst>
    <segment id="1">Galeria a céu aberto em São Paulo</segment>
    <segment id="2">, o Beco do Batman</segment>
    <segment id="3">, reduto de grafites</segment>
    <segment id="4">, ganha nesta sexta (3) mais uma obra para sua já extensa coleção: um mural do Piu-Piu.</segment>
    <segment id="5">A obra é uma homenagem aos 80 anos do icônico personagem</segment>
    <segment id="6">, que faz aniversário em novembro –ao todo</segment>
    <segment id="7">, o Brasil contará com cinco murais do famoso passarinho da série "Looney Tunes"</segment>
    <segment id="8">, produzida pela Warner Bros.</segment>
    <segment id="9">Dois deles já foram inaugurados</segment>
    <segment id="10">, no Rio e em Salvador.</segment>
    <segment id="11">Para o desenho do beco do Batman</segment>
    <segment id="12">, o artista escolhido foi o paulistano Kauê Fidelis</segment>
    <segment id="13">, 35, o Kuêio.  Mural em comemoração aos 80 anos do Piu-Piu</segment>
    <segment id="14">, assinado pelo artista Kuêio - Gui Tichauer/DivulgaçãoIlustrador e grafiteiro</segment>
    <segment id="15">, Kuêio nasceu e cresceu na zona norte paulistana</segment>
    <segment id="16">, onde teve o primeiro contato com a street art. "Comecei a me interessar com 6</segment>
    <segment id="17">, 7 anos.</segment>
    <segment id="18">Eu andava de ônibus</segment>
    <segment id="19">, ficava preso no trânsito da cidade</segment>
    <segment id="20">, e observava aquelas escritas</segment>
    <segment id="21">, aquelas cores todas nas paredes"</segment>
    <segment id="22">, conta.</segment>
    <segment id="23">Mas foi só ao cursar artes na Universidade Federal de Uberlândia</segment>
    <segment id="24">, em Minas Gerais</segment>
    <segment id="25">, que Kauê entendeu que poderia</segment>
    <segment id="26">, de fato</segment>
    <segment id="27">, viver do grafite.</segment>
    <segment id="28">"</segment>
    <segment id="29">Eu fazia por hobby.</segment>
    <segment id="30">Mas na faculdade entendi que existia mercado para essa arte.</segment>
    <segment id="31">"</segment>
    <segment id="32">A escolha de Kuêio pelo curador do projeto</segment>
    <segment id="33">, Marcelo Eco</segment>
    <segment id="34">, não foi por acaso.</segment>
    <segment id="35">A ideia era também fazer referência a junho</segment>
    <segment id="36">, Mês do Orgulho LGBTQIA+</segment>
    <segment id="37">, comunidade a qual o artista faz parte.</segment>
    <segment id="38">"Sempre me encaixei dentro do circuito da arte</segment>
    <segment id="39">, as pessoas são muito acolhedoras.</segment>
    <segment id="40">Mas com um adendo: sou um gay 'masculino'.</segment>
    <segment id="41">O grafite é machista.</segment>
    <segment id="42">Não está preparado para homem 'afeminado'</segment>
    <segment id="43">, mulher cis e muito menos mulher trans"</segment>
    <segment id="44">, avalia.</segment>
    <segment id="45">Mural grafitado e o artista Kauê Fidelis</segment>
    <segment id="46">, o Kuêio</segment>
    <segment id="47">, no Beco do Batman</segment>
    <segment id="48">, em SP - Gui Tichauer/DivulgaçãoPara o mural do Beco do Batman</segment>
    <segment id="49">, Kuêio conta que conseguiu "conversar" diretamente com o desenho e dar voz a ele em sua arte.</segment>
    <segment id="50">"Piu-Piu é aquele personagem que não sabemos o gênero ao certo.</segment>
    <segment id="51">Pensei que poderia falar sobre ele</segment>
    <segment id="52">comocomo alguém que também pode estar onde quiser.</segment>
    <segment id="53">E o fiz saindo da gaiola</segment>
    <segment id="54">, sese libertando.</segment>
    <segment id="55">Para mostrar isso: que ele pode.</segment>
    <segment id="56">"  *  Beco do Batman.</segment>
    <segment id="57">R. Medeiros de Albuquerque</segment>
    <segment id="58">, Vila Madalena</segment>
    <segment id="59">, São Paulo.  *  E você</segment>
    <segment id="60">, tem visitado galerias de arte</segment>
    <segment id="61">, bares ou restaurantes que marcaram?</segment>
    <segment id="62">Que filmes</segment>
    <segment id="63">, séries ou peças tem assistido?</segment>
    <segment id="64">Escreva para o email pitacocultural@gmail.com e envie sua resenha.</segment>
    <segment id="65">Não esqueça de mandar nome completo</segment>
    <segment id="66">, profissão</segment>
    <segment id="67">, idade e cidade.</segment>
  </rst>
</analysis>