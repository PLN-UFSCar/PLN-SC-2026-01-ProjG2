  <rst>
    <segment id="1">A série "Stranger Things" estreia sua quarta temporada nesta sexta (27) na Netflix.</segment>
    <segment id="2">Narrando as aventuras de um grupo de crianças que lidam com eventos sobrenaturais em uma pequena cidade dos Estados Unidos</segment>
    <segment id="3">, o drama</segment>
    <segment id="4">, desde quando foi lançado em 2016</segment>
    <segment id="5">, tem feito sucesso mesclando elementos de terror</segment>
    <segment id="6">, ficção científica e referências a filmes dos anos 1980.</segment>
    <segment id="7">Atriz britânica Millie Bobby Brown em foto de 2016</segment>
    <segment id="8">, à esquerda</segment>
    <segment id="9">, e em outra foto feita em 2022 - Chris Delmas/AFP e Cindy</segment>
    <segment id="10">Ord/</segment>
    <segment id="11">AFPMas um principais fatores que explicam a grande audiência da série dirigida pelos irmãos</segment>
    <segment id="12">Matt e Ross Duffer é seu jovem elenco carismático</segment>
    <segment id="13">, cujo envelhecimento está cada vez menos possível de disfarçar diante das telas.</segment>
    <segment id="14">Estrela do seriado interpretando a personagem Eleven</segment>
    <segment id="15">, a atriz britânica Millie Bobby Brown começou a atuar em "</segment>
    <segment id="16">Stanger Things" quando tinha 12 anos de idade</segment>
    <segment id="17">, e desde então já participou dos filmes "Godzilla vs Kong" e "Enola Homes".</segment>
    <segment id="18">Atualmente aos 18 anos</segment>
    <segment id="19">, sua aparência causou espanto em alguns fãs que viram fotos da atriz na pré-estreia da quarta temporada da série.</segment>
    <segment id="20">Veja antes e depois de atores de &amp;#039</segment>
    <segment id="21">;Stranger Things&amp;#039</segment>
    <segment id="22">;Mais    novamente         de   de  de  representando um</segment>
    <segment id="23">Em entrevista à Folha</segment>
    <segment id="24">, Ross Duffer</segment>
    <segment id="25">, um dos criadores do seriado</segment>
    <segment id="26">, comentou o crescimento dos atores.</segment>
    <segment id="27">"</segment>
    <segment id="28">Nosso objetivo com essa série é tentar algo diferente a cada temporada e garantir que ela está evoluindo</segment>
    <segment id="29">, o que tem acontecido de forma muito natural</segment>
    <segment id="30">, porque</segment>
    <segment id="31">porque nossas crianças estão crescendo.</segment>
    <segment id="32">Nós nem podemos mais chamar de crianças</segment>
    <segment id="33">, porque</segment>
    <segment id="34">porque eles são jovens adultos agora"</segment>
    <segment id="35">, disse ele.</segment>
    <segment id="36">Hoje com 19 anos</segment>
    <segment id="37">, o canadense Finn Wolfhard tinha 13 anos na primeira temporada e também teve a carreira alavancada por sua interpretação</segment>
    <segment id="38">comocomo Mike.</segment>
    <segment id="39">Desde 2016</segment>
    <segment id="40">, ele já participou de grandes produções de Hollywood</segment>
    <segment id="41">, como</segment>
    <segment id="42">como o remake de "</segment>
    <segment id="43">It - A Coisa"</segment>
    <segment id="44">, de 2017</segment>
    <segment id="45">, e "Ghostbusters:</segment>
    <segment id="46">Mais Além"</segment>
    <segment id="47">, lançado em 2021.</segment>
    <segment id="48">Confira</segment>
    <segment id="49">comocomo envelheceram os demais atores de "Stranger Things" desde o início da série até agora.</segment>
    <segment id="50">Millie Bobby Brown cresceu: veja imagens da atriz da estreia de &amp;#039</segment>
    <segment id="51">;Stranger Things&amp;#039</segment>
    <segment id="52">;</segment>
    <segment id="53">a hoje Mais    novamente         de   de  de  representando um</segment>
