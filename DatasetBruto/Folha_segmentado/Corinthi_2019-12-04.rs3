  <rst>
    <segment id="1">Ceará e Corinthians disputam</segment>
    <segment id="2">, na noite de quarta-feira (4)</segment>
    <segment id="3">, jogo importante na definição do último rebaixado no Campeonato Brasileiro.</segment>
    <segment id="4">O Cruzeiro é grande interessado em uma vitória do time paulista</segment>
    <segment id="5">, no Castelão</segment>
    <segment id="6">, em Fortaleza</segment>
    <segment id="7">, a partir das 19h30 (de Brasília).</segment>
    <segment id="8">A duas rodadas do fim da competição</segment>
    <segment id="9">, Ceará e Cruzeiro lutam para escapar do rebaixamento à Série B de 2020.</segment>
    <segment id="10">Avaí e Chapecoense já caíram</segment>
    <segment id="11">, e o CSA só espera a chancela matemática</segment>
    <segment id="12">, já que precisa tirar seis pontos e 26 gols de diferença no saldo para</segment>
    <segment id="13">sese salvar.</segment>
    <segment id="14">A vantagem</segment>
    <segment id="15">, no momento</segment>
    <segment id="16">, é do Ceará</segment>
    <segment id="17">, que soma 38 pontos</segment>
    <segment id="18">, contra 36 do Cruzeiro.</segment>
    <segment id="19">Há ainda uma diferença importante de 10 vitórias a 7.</segment>
    <segment id="20">Ou seja</segment>
    <segment id="21">, em caso</segment>
    <segment id="22">caso de igualdade em pontos ao fim da 38ª rodada</segment>
    <segment id="23">, a equipe mineira será rebaixada.</segment>
    <segment id="24">O atacante Pedrinho durante treino do Corinthians - Daniel Augusto - 8.11.2019/ Agência Corinthians  É muito importante para os torcedores celestes</segment>
    <segment id="25">, portanto</segment>
    <segment id="26">, que o Corinthians vença em Fortaleza.</segment>
    <segment id="27">Mesmo um empate pode ser decisivo para o Cruzeiro —que seria matematicamente rebaixado</segment>
    <segment id="28">, nesse cenário</segment>
    <segment id="29">, em caso</segment>
    <segment id="30">caso de derrota para o Grêmio</segment>
    <segment id="31">, na quinta (4)</segment>
    <segment id="32">, em Porto Alegre.</segment>
    <segment id="33">Os jogadores do Corinthians afirmam que a situação na parte de baixo da tabela não lhes diz respeito.</segment>
    <segment id="34">Oitavo colocado</segment>
    <segment id="35">, o time do Parque São Jorge precisa ao menos manter essa posição para</segment>
    <segment id="36">sese classificar à próxima Copa Libertadores e ainda sonha em tomar o sexto lugar do São Paulo</segment>
    <segment id="37">, o que valeria vaga direta na fase de grupos da competição continental.</segment>
    <segment id="38">"Temos um objetivo ainda muito grande neste Brasileiro</segment>
    <segment id="39">, que é a vaga na Libertadores.</segment>
    <segment id="40">O grupo está concentrado em jogar para vencer"</segment>
    <segment id="41">, disse o volante Gabriel</segment>
    <segment id="42">, minimizando um movimento de internet para a equipe prejudicar o Cruzeiro</segment>
    <segment id="43">, algoz do time alvinegro na final da Copa do Brasil de 2018.</segment>
    <segment id="44">Já o São Paulo poderá assegurar nesta quarta sua vaga na fase de grupos da próxima Copa Libertadores.</segment>
    <segment id="45">Para isso</segment>
    <segment id="46">, basta à equipe vencer o Internacional</segment>
    <segment id="47">, no Morumbi</segment>
    <segment id="48">, na capital paulista</segment>
    <segment id="49">, em jogo marcado para as 21h30 (de Brasília).</segment>
    <segment id="50">As maiores torcidas do Brasil</segment>
    <segment id="51">, segundo o Datafolha   novamente         de   de  de  representando um</segment>
    <segment id="52">Sexto colocado do Campeonato Brasileiro</segment>
    <segment id="53">, com 57 pontos</segment>
    <segment id="54">, o time tricolor está na última posição que oferece vaga direta.</segment>
    <segment id="55">O Inter é o sétimo</segment>
    <segment id="56">, com 54</segment>
    <segment id="57">, e ultrapassará os donos da casa nos critérios de desempate em</segment>
    <segment id="58">casocaso de vitória.</segment>
    <segment id="59">Nesse caso</segment>
    <segment id="60">caso, a definição ficaria para a rodada derradeira</segment>
    <segment id="61">, no domingo (8).</segment>
    <segment id="62">O jogo</segment>
    <segment id="63">, que abre a 37ª rodada do Brasileiro</segment>
    <segment id="64">, poderá definir o vice-campeão.</segment>
    <segment id="65">Isso ocorrerá em</segment>
    <segment id="66">casocaso de triunfo do Santos sobre o Athletico-PR na Arena da Baixada</segment>
    <segment id="67">, em Curitiba</segment>
    <segment id="68">, em duelo com início às 19h (de Brasília).</segment>
    <segment id="69">Três pontos à frente do Palmeiras que receberá o Goiás na quinta-feira (4)</segment>
    <segment id="70">, a formação da Vila</segment>
    <segment id="71">Belmiro não poderá mais ser alcançada pelo rival</segment>
    <segment id="72">sese vencer no Paraná.</segment>
  </rst>
</analysis>