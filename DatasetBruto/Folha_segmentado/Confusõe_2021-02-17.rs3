  <rst>
    <segment id="1">Pouca gente sabe</segment>
    <segment id="2">, masmas a famosa duplinha Tom &amp;amp</segment>
    <segment id="3">; Jerry não nasceu na TV</segment>
    <segment id="4">, masmas no cinema.</segment>
    <segment id="5">Foi em uma animação curta chamada “</segment>
    <segment id="6">Um Bichano em Maus Lençóis”</segment>
    <segment id="7">, criada por William Hanna e Joseph Barbera em 1940 para ser exibida antes de um filme</segment>
    <segment id="8">, como</segment>
    <segment id="9">como era comum naquele período.</segment>
    <segment id="10">Na época o nome deles ainda era Jasper e Jinx.</segment>
    <segment id="11">Eles fizeram tanto sucesso que ganharam vários outros curtas e venceram sete Oscars.</segment>
    <segment id="12">Ao migrarem para a TV</segment>
    <segment id="13">, logo integraram o catálogo da produtora Hanna-Barbera (os dois amigos lá em cima)</segment>
    <segment id="14">, que criaram alguns dos desenhos favoritos dos seus pais ou dos seus avós: ‘Scooby-Doo’</segment>
    <segment id="15">, ‘Os Flintstones’</segment>
    <segment id="16">, ‘</segment>
    <segment id="17">Os Jetsons’</segment>
    <segment id="18">, ‘Zé Colmeia’</segment>
    <segment id="19">, ‘Corrida Maluca’ etc.</segment>
    <segment id="20">Mas voltemos a Tom &amp;amp</segment>
    <segment id="21">; Jerry.</segment>
    <segment id="22">É meio fácil resumir qualquer história da dupla.</segment>
    <segment id="23">Funciona mais ou menos assim:</segment>
    <segment id="24">Tom tenta capturar Jerry.</segment>
    <segment id="25">E geralmente não consegue.  Desta vez</segment>
    <segment id="26">, Tom persegue Jerry em um hotel em Nova York - Divulgação</segment>
    <segment id="27">Ou porque</segment>
    <segment id="28">porque o rato é muito esperto</segment>
    <segment id="29">, ou porque</segment>
    <segment id="30">porque o próprio gato</segment>
    <segment id="31">sese atrapalha em seus planos mirabolantes.</segment>
    <segment id="32">E, entre uma tentativa e outra</segment>
    <segment id="33">, eles quebram tudo no caminho.</segment>
    <segment id="34">O que acontece em “Tom &amp;amp</segment>
    <segment id="35">; Jerry:</segment>
    <segment id="36">O Filme” (2021)</segment>
    <segment id="37">, que estreia nesta semana nos cinemas?</segment>
    <segment id="38">Exatamente isso.</segment>
    <segment id="39">Tom tenta de tudo para capturar Jerry</segment>
    <segment id="40">, e eles causam o caos enquanto um corre atrás do outro.</segment>
    <segment id="41">Desta vez</segment>
    <segment id="42">, a perseguição acontece em um luxuoso hotel de Nova York durante os preparativos para um casamento de celebridades.</segment>
    <segment id="43">E não confundir este com “Tom &amp;amp</segment>
    <segment id="44">; Jerry: O Filme”</segment>
    <segment id="45">, de 1992.</segment>
    <segment id="46">Aqui há uma grande diferença: atores de verdade contracenam com a dupla</segment>
    <segment id="47">, no chamado live-action</segment>
    <segment id="48">, como</segment>
    <segment id="49">como em ‘Zé Colmeia - O Filme’ (2010) e ‘</segment>
    <segment id="50">Sonic: O Filme’ (2020).</segment>
    <segment id="51">Aqui a parte animada</segment>
    <segment id="52">sese estende aos demais bichos que aparecem em cena: gatos</segment>
    <segment id="53">, ratos</segment>
    <segment id="54">, cachorro</segment>
    <segment id="55">, cavalo</segment>
    <segment id="56">, pombo e até elefante.</segment>
    <segment id="57">Sim, tem até elefante.</segment>
    <segment id="58">E todos eles falam</segment>
    <segment id="59">, com exceção de Tom e Jerry.</segment>
    <segment id="60">Assim, temos a atriz Chloë Grace Moretz no papel da esperta Kayla</segment>
    <segment id="61">, que consegue um emprego temporário no hotel para ajudar nos preparativos do casamento-evento</segment>
    <segment id="62">, masmas acaba com a função de expulsar um ratinho (Jerry) que começa a causar confusões.</segment>
    <segment id="63">Confira cenas de &amp;#039</segment>
    <segment id="64">;Tom &amp;amp</segment>
    <segment id="65">; Jerry - O Filme&amp;#039</segment>
    <segment id="66">;   novamente         de   de  de  representando um</segment>
    <segment id="67">E o que ela faz?</segment>
    <segment id="68">Contrata Tom.</segment>
    <segment id="69">Pronto</segment>
    <segment id="70">, a confusão está formada.</segment>
    <segment id="71">Tom e Jerry provocam verdadeiros furacões da bagunça enquanto correm pelo hotel</segment>
    <segment id="72">, para desespero de Kayla.</segment>
    <segment id="73">A interação de Chloë com os heróis animados funciona bem.</segment>
    <segment id="74">Para ajudar os atores</segment>
    <segment id="75">, os produtores chegaram a contratar titereiros (pessoas que manipulam marionetes)</segment>
    <segment id="76">, que ficavam em cena com bonecos de Tom e Jerry.</segment>
    <segment id="77">Apesar de já estrelar longas mais adultos</segment>
    <segment id="78">, Chloë mantém ligação com filmes infantis.</segment>
    <segment id="79">Ela empresta sua voz</segment>
    <segment id="80">, por exemplo</segment>
    <segment id="81">, para Wednesday</segment>
    <segment id="82">, aqui conhecida</segment>
    <segment id="83">comocomo Wandinha</segment>
    <segment id="84">, a filha sombria da “Família Addams” (2019).</segment>
    <segment id="85">E repete a dose dublando a personagem principal de “Sapatinho Vermelho e os Sete Anões”</segment>
    <segment id="86">, que estava em cartaz há pouco tempo.</segment>
    <segment id="87">Mas não será dessa vez que você vai reconhecer a voz dela</segment>
    <segment id="88">, já que “Sapatinho” e “Tom &amp;amp</segment>
    <segment id="89">; Jerry” chegaram ao Brasil somente em cópias dubladas.</segment>
    <segment id="90">TOM &amp;amp</segment>
    <segment id="91">; JERRY:</segment>
    <segment id="92">O FILMEClassificação LivreElenco</segment>
    <segment id="93">Com Chloë Grace Moretz</segment>
    <segment id="94">, Michael Peña e Rob Delaney.</segment>
    <segment id="95">Produção EUA</segment>
    <segment id="96">, 2021.Direção Tim Story.</segment>
    <segment id="97">Duração 101 min.</segment>
    <segment id="98">TODO MUNDO LÊ JUNTO Texto com este selo é indicado para ser lido por responsáveis e educadores com a criança</segment>
  </rst>
</analysis>