  <rst>
    <segment id="1">De acordo com o IBGE</segment>
    <segment id="2">, cerca de 35 milhões de pessoas —19% da população— têm algum tipo de deficiência visual.</segment>
    <segment id="3">O uso de óculos é realidade e faz parte do dia a dia de muitos desses brasileiros e essas condições podem evoluir.</segment>
    <segment id="4">Como saber</segment>
    <segment id="5">, então</segment>
    <segment id="6">, quando e com qual frequência</segment>
    <segment id="7">sese deve fazer exames de vista ou trocar de óculos?</segment>
    <segment id="8">Segundo José Augusto Alves Ottaiano</segment>
    <segment id="9">, presidente do Conselho Brasileiro de Oftalmologia</segment>
    <segment id="10">, a orientação médica é</segment>
    <segment id="11">para que</segment>
    <segment id="12">para que exames de vista sejam realizados anualmente na maior parte dos casos de miopia</segment>
    <segment id="13">, astigmatismo</segment>
    <segment id="14">, hipermetropia e presbiopia.</segment>
    <segment id="15">A Organização Mundial da Saúde recomenda que as pessoas visitem um oftalmologista uma vez ao ano - Sam Cox/FlickrEntretanto</segment>
    <segment id="16">, existem exceções.</segment>
    <segment id="17">Os míopes</segment>
    <segment id="18">, por exemplo</segment>
    <segment id="19">, precisam ficar atentos aos sinais de que o seu grau aumentou.</segment>
    <segment id="20">“</segment>
    <segment id="21">A miopia demanda mais atenção</segment>
    <segment id="22">porque</segment>
    <segment id="23">porque tende a</segment>
    <segment id="24">sese desenvolver até os 18 ou 20 anos</segment>
    <segment id="25">, sese mesmo dentro do intervalo de um ano [entre uma consulta e outra] o paciente perceber variações nas condições básicas</segment>
    <segment id="26">, recomendamos visitar um oftalmologista”</segment>
    <segment id="27">, explica Ottaiano.</segment>
    <segment id="28">As mudanças nas condições básicas citadas por Ottaiano são alterações de percepção do próprio paciente</segment>
    <segment id="29">, como</segment>
    <segment id="30">como a evolução natural do grau</segment>
    <segment id="31">, baixa visão ou dificuldade para enxergar em atividades que antes eram comuns</segment>
    <segment id="32">, como</segment>
    <segment id="33">como assistir televisão</segment>
    <segment id="34">, ler e estudar.</segment>
    <segment id="35">O especialista diz ainda que mesmo aqueles que nunca precisaram usar óculos também deveriam consultar oftalmologistas uma vez ao ano.</segment>
    <segment id="36">“</segment>
    <segment id="37">Dentro da oftalmologia</segment>
    <segment id="38">, a oportunidade de avaliar o paciente a cada 12 meses não</segment>
    <segment id="39">sese restringe ao uso do óculos</segment>
    <segment id="40">, a medida do grau é apenas uma parte da consulta.</segment>
    <segment id="41">Nelas é possível avaliar a pressão ocular e o fundo de olho</segment>
    <segment id="42">, por exemplo”</segment>
    <segment id="43">, diz.</segment>
    <segment id="44">Exames de fundo de olho podem ser úteis para a detecção de doenças sistêmicas</segment>
    <segment id="45">comocomo diabetes</segment>
    <segment id="46">, e infecciosas</segment>
    <segment id="47">, como</segment>
    <segment id="48">como a tuberculose e aids.</segment>
    <segment id="49">Ottaiano afirma que um grande número de doenças</segment>
    <segment id="50">sese manifesta através de exames oftalmológicos.</segment>
    <segment id="51">“</segment>
    <segment id="52">Não é incomum descobrirmos diabetes em pacientes por exames dos olhos.</segment>
    <segment id="53">Não são todos os diabéticos</segment>
    <segment id="54">, entretanto</segment>
    <segment id="55">, que têm alteração no fundo de olho</segment>
    <segment id="56">, masmas cerca de 40% apresentam a condição em algum momento”</segment>
    <segment id="57">, ressalta.</segment>
    <segment id="58">Além disso</segment>
    <segment id="59">, o médico alerta que é importante que crianças com idade inferior a sete anos passem por consultas oftalmológicas</segment>
    <segment id="60">, pois</segment>
    <segment id="61">pois até essa idade os olhos ainda estão em desenvolvimento e alterações na visão podem ser desaceleradas e até mesmo revertidas.</segment>
    <segment id="62">“</segment>
    <segment id="63">Depois dos sete anos as crianças já não respondem mais a esses tratamentos.</segment>
    <segment id="64">O olho cresce</segment>
    <segment id="65">, em tamanho</segment>
    <segment id="66">, até três ou quatro anos</segment>
    <segment id="67">, e se</segment>
    <segment id="68">se desenvolve até sete</segment>
    <segment id="69">, no máximo oito anos.</segment>
    <segment id="70">A preferência é abordar crianças em idade pré-escolar.</segment>
    <segment id="71">Grande parte delas podem ter restrição do desenvolvimento cognitivo por não haver correção adequada da visão</segment>
    <segment id="72">, por falta de um óculos.</segment>
    <segment id="73">”</segment>
  </rst>
</analysis>