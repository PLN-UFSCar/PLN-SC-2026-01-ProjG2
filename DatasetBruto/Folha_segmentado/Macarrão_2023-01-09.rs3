  <rst>
    <segment id="1">Apelidei esta receita de "macarrão de acampamento"</segment>
    <segment id="2">porque</segment>
    <segment id="3">porque ela pode ser feita até nas condições precárias de um camping.</segment>
    <segment id="4">O molho não precisa ser cozido</segment>
    <segment id="5">, então só uma panela e uma boca de fogão (ou um fogareiro) resolvem a parada facilmente.</segment>
    <segment id="6">Se você</segment>
    <segment id="7">, como</segment>
    <segment id="8">como eu</segment>
    <segment id="9">, tem alergia a dormir numa barraca</segment>
    <segment id="10">, não precisa</segment>
    <segment id="11">sese preocupar: a receita é boa em qualquer situação</segment>
    <segment id="12">, fica gostosa também quando é feita numa cozinha equipada com fogão de seis bocas.</segment>
    <segment id="13">Receita de &amp;#039</segment>
    <segment id="14">;macarrão de acampamento&amp;#039</segment>
    <segment id="15">;, que dá para preparar até no camping - FolhapressA base do molho frio</segment>
    <segment id="16">são bons tomates frescos e maduros –quanto menos você interfere no ingrediente (aqui a interferência é mínima)</segment>
    <segment id="17">, mais aparecem suas qualidades e defeitos.</segment>
    <segment id="18">De resto</segment>
    <segment id="19">, a receita é toda customizável ao gosto do freguês.</segment>
    <segment id="20">Você pode acrescentar tudo quanto é alimento cru ou em conserva:</segment>
    <segment id="21">aspargo</segment>
    <segment id="22">, alcachofra</segment>
    <segment id="23">, cebola</segment>
    <segment id="24">, sardinha</segment>
    <segment id="25">, atum</segment>
    <segment id="26">, presunto cru.</segment>
    <segment id="27">Eu fiz com alho</segment>
    <segment id="28">, azeitona preta</segment>
    <segment id="29">, alcaparra</segment>
    <segment id="30">, muçarela de búfala</segment>
    <segment id="31">, azeite e manjericão.</segment>
    <segment id="32">A combinação de sabores me agrada</segment>
    <segment id="33">, eu tinha as azeitonas e as alcaparras</segment>
    <segment id="34">, e a muçarela estava em promoção no mercado.</segment>
    <segment id="35">Apesar de cru</segment>
    <segment id="36">, não basta misturar tudo numa bacia para ter um molho.</segment>
    <segment id="37">Toda receita tem seus truques.</segment>
    <segment id="38">Receitas do MarcãoMais    novamente         de   de  de  representando um</segment>
    <segment id="39">O molho cru não exige nenhum talento específico</segment>
    <segment id="40">, só paciência.</segment>
    <segment id="41">Você deve deixá-lo numa peneira por cerca de uma hora</segment>
    <segment id="42">, até que o tomate e a muçarela soltem boa parte da água.</segment>
    <segment id="43">Caso contrário</segment>
    <segment id="44">, vai se</segment>
    <segment id="45">se formar uma piscininha no fundo do prato de macarrão.</segment>
    <segment id="46">O que faz o tomate "suar" é o sal –que pode ser adicionado ou estar contido nos ingredientes.</segment>
    <segment id="47">Como eu usei azeitona e alcaparra</segment>
    <segment id="48">, ambas bem salgadas</segment>
    <segment id="49">, não acrescentei tomate no início.</segment>
    <segment id="50">Deixe o manjericão para a finalização</segment>
    <segment id="51">, pois</segment>
    <segment id="52">pois ele oxida e escurece.</segment>
    <segment id="53">A mesma coisa com o azeite: ele vai escorrer pela peneira</segment>
    <segment id="54">sese você o usar no começo da preparação.  MACARRÃO DE ACAMPAMENTO</segment>
    <segment id="55">Rendimento: 2 porções  Dificuldade: fácil</segment>
    <segment id="56">Ingredientes   400 g de tomates maduros</segment>
    <segment id="57">, com pele e sementes</segment>
    <segment id="58">, picados 1 dente de alho picado fino</segment>
    <segment id="59">10 azeitonas pretas</segment>
    <segment id="60">, descaroçadas e picadas</segment>
    <segment id="61">1 colher (chá) de alcaparras picadas 200 g de muçarela de búfala fresca</segment>
    <segment id="62">, drenada e picada 250 g de massa seca Sal</segment>
    <segment id="63">, pimenta-do-reino</segment>
    <segment id="64">, manjericão</segment>
    <segment id="65">, azeite e queijo ralado a gosto</segment>
    <segment id="66">Modo de fazer  1 - Misture os tomates</segment>
    <segment id="67">, o alho</segment>
    <segment id="68">, as azeitonas</segment>
    <segment id="69">, a alcaparra e a muçarela.</segment>
    <segment id="70">Deixe numa peneira por pelo menos uma hora</segment>
    <segment id="71">, agitando de vez em quando</segment>
    <segment id="72">, para perder líquido</segment>
    <segment id="73">;  2 - Cozinhe a massa de acordo com as instruções da embalagem</segment>
    <segment id="74">;  3 - Transfira o molho para uma travessa.</segment>
    <segment id="75">Ajuste o sal e tempere com pimenta-do-reino</segment>
    <segment id="76">, manjericão e azeite</segment>
    <segment id="77">;  4 - Escorra a massa e misture ao molho.</segment>
    <segment id="78">Sirva com queijo ralado à parte.</segment>
  </rst>
</analysis>