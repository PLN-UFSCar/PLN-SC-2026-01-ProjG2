    <segment id="78">,00   Tailândia 11.340</segment>
    <segment id="79">,00   Autodeclarada República Turca de Chipre do Norte 8.800</segment>
    <segment id="80">,00   Mongólia 8.486</segment>
    <segment id="81">,00   Líbano 7.720</segment>
    <segment id="82">,00   Albânia 6.002</segment>
