  <rst>
    <segment id="1">A cantora Elza Soares viveu 17 anos com Mané Garrincha</segment>
    <segment id="2">, que morreu em 1983.</segment>
    <segment id="3">A morte da cantora</segment>
    <segment id="4">, nesta quinta-feira</segment>
    <segment id="5">, ocorreu no mesmo dia em que a do jogador de futebol</segment>
    <segment id="6">, num 20 de janeiro.</segment>
    <segment id="7">"</segment>
    <segment id="8">Ele foi uma gracinha</segment>
    <segment id="9">, quero falar só o lado bom"</segment>
    <segment id="10">, disse Elza em entrevista a este em 1997.</segment>
    <segment id="11">"</segment>
    <segment id="12">O Mané também tinha um lado muito bom.</segment>
    <segment id="13">Foi o grande amor da minha vida.</segment>
    <segment id="14">"  Elza Soares e GarrinchaMais    novamente         de   de  de  representando um  Garrincha agredia</segment>
    <segment id="15">Elza.</segment>
    <segment id="16">Depois de tentar ajudá-lo a vencer o alcoolismo sem sucesso</segment>
    <segment id="17">, ela decidiu</segment>
    <segment id="18">sese separar do jogador para dar um basta à violência doméstica.</segment>
    <segment id="19">Em entrevista a Pedro Bial em 2018</segment>
    <segment id="20">, ela relembrou o relacionamento com o craque do Botafogo</segment>
    <segment id="21">, que lhe teria prometido vencer a Copa de 1962 e lhe dedicar o título.</segment>
    <segment id="22">Na ocasião</segment>
    <segment id="23">, Pelé</segment>
    <segment id="24">, o então craque da seleção</segment>
    <segment id="25">, acabou fora do jogo depois de sofrer uma contusão.</segment>
    <segment id="26">"Ele me prometeu e disse: 'Olha</segment>
    <segment id="27">, crioula</segment>
    <segment id="28">, essa Copa vou dar para você.</segment>
    <segment id="29">Vou fazer gol para você.</segment>
    <segment id="30">Eu nunca gostei de ser mulher de fulano.</segment>
    <segment id="31">Eu sou eu.</segment>
    <segment id="32">Não era preciso ser mulher do Garrincha para ser a Elza Soares.</segment>
    <segment id="33">O Garrincha era marido da Elza Soares.</segment>
    <segment id="34">"</segment>
    <segment id="35">A cantora e o jogador tiveram um filho</segment>
    <segment id="36">, Manoel Francisco dos Santos Júnior</segment>
    <segment id="37">, o Garrinchinha</segment>
    <segment id="38">, que morreu aos nove anos num acidente de carro.  Morre Elza Soares</segment>
    <segment id="39">, considerada a cantora do milênio</segment>
    <segment id="40">, aos 91 anosMais    novamente         de   de  de  representando um  Leia mais sobre Elza Soares</segment>
    <segment id="41">, morta aos 91 anosMorre Elza Soares</segment>
    <segment id="42">, considerada a cantora do milênio</segment>
    <segment id="43">, aos 91 anos</segment>
    <segment id="44">Elza Soares gravou DVD dois dias antes de morrer e tem disco político inédito</segment>
    <segment id="45">Famosos e clubes de futebol lamentam a morte da cantora Elza SoaresAnálise:</segment>
    <segment id="46">Elza Soares foi uma artista invencível</segment>
    <segment id="47">, que ninguém destruiriaOpinião: Elza Soares teve uma vida surreal e da qual ela nunca desistiu Opiniaõ: Elza Soares provou que idade nada tem a ver com conservadorismo baratoElza Soares disse que Brasil estava doente</segment>
    <segment id="48">, masmas que não</segment>
    <segment id="49">sese reconhecia fora daquiElza Soares narrou à Folha o dia em que conheceu João Gilberto</segment>
