  <rst>
    <segment id="1">[RESUMO] Deboche</segment>
    <segment id="2">, incompet&amp;ecirc</segment>
    <segment id="3">;ncia e indisciplina de Eduardo Pazuello &amp;mdash</segment>
    <segment id="4">;que ocupou o Minist&amp;eacute</segment>
    <segment id="5">;rio da Sa&amp;uacute</segment>
    <segment id="6">;de durante o per&amp;iacute</segment>
    <segment id="7">;odo mais agudo da pandemia</segment>
    <segment id="8">, passeou sem m&amp;aacute</segment>
    <segment id="9">;scara e subiu em palanque&amp;mdash</segment>
    <segment id="10">; uniu as For&amp;ccedil</segment>
    <segment id="11">;as Armadas em torno da sua imediata puni&amp;ccedil</segment>
    <segment id="12">;&amp;atilde</segment>
    <segment id="13">;o e passagem para a reserva.</segment>
    <segment id="14">Essa expectativa</segment>
    <segment id="15">, por&amp;eacute</segment>
    <segment id="16">;m, foi frustrada pelos custos e consequ&amp;ecirc</segment>
    <segment id="17">;ncias de uma nova crise militar</segment>
    <segment id="18">, que poderia permitir a Bolsonaro nomear &amp;quot</segment>
    <segment id="19">;seu&amp;quot</segment>
    <segment id="20">; general para comandar &amp;quot</segment>
    <segment id="21">;seu&amp;quot</segment>
    <segment id="22">;</segment>
    <segment id="23">Ex&amp;eacute</segment>
    <segment id="24">;rcito.  </segment>
    <segment id="25">As a&amp;ccedil</segment>
    <segment id="26">;&amp;otilde</segment>
    <segment id="27">;es do general Eduardo Pazuello &amp;agrave</segment>
    <segment id="28">; frente do Minist&amp;eacute</segment>
    <segment id="29">;rio da Sa&amp;uacute</segment>
    <segment id="30">;de e sua participa&amp;ccedil</segment>
    <segment id="31">;&amp;atilde</segment>
    <segment id="32">;o em um ato de apoio a Bolsonaro depois de deixar a pasta trouxeram para o julgamento da cidadania</segment>
    <segment id="33">, mais uma vez</segment>
    <segment id="34">, o papel dos militares na vida pol&amp;iacute</segment>
    <segment id="35">;tica do Brasil.</segment>
    <segment id="36">Depois de in&amp;uacute</segment>
    <segment id="37">;meras interven&amp;ccedil</segment>
    <segment id="38">;&amp;otilde</segment>
    <segment id="39">;es no processo pol&amp;iacute</segment>
    <segment id="40">;tico e administrativo ao longo da hist&amp;oacute</segment>
    <segment id="41">;ria brasileira</segment>
    <segment id="42">, desde a Constitui&amp;ccedil</segment>
    <segment id="43">;&amp;atilde</segment>
    <segment id="44">;o de 1988 consider&amp;aacute</segment>
    <segment id="45">;vamos que o risco de militariza&amp;ccedil</segment>
    <segment id="46">;&amp;atilde</segment>
    <segment id="47">;o das institui&amp;ccedil</segment>
    <segment id="48">;&amp;otilde</segment>
    <segment id="49">;es era baixo.</segment>
    <segment id="50">No entanto</segment>
    <segment id="51">, ap&amp;oacute</segment>
    <segment id="52">;s um per&amp;iacute</segment>
    <segment id="53">;odo de &amp;ldquo</segment>
    <segment id="54">;profissionalismo&amp;rdquo</segment>
    <segment id="55">;, em que</segment>
    <segment id="56">sese dedicaram aos deveres da caserna</segment>
    <segment id="57">, fizeram dezenas de MBAs especializados e foram contratados em funda&amp;ccedil</segment>
    <segment id="58">;&amp;otilde</segment>
    <segment id="59">;es privadas</segment>
    <segment id="60">, os militares acharam que havia chegado a hora de promover um retorno &amp;agrave</segment>
    <segment id="61">; pol&amp;iacute</segment>
    <segment id="62">;tica.</segment>
    <segment id="63">Bolsonaro participa de homenagem ao Exército em 2019Mais    novamente         de   de  de  representando um  Buscando uma breve interven&amp;ccedil</segment>
    <segment id="64">;&amp;atilde</segment>
    <segment id="65">;o &amp;ndash</segment>
    <segment id="66">;em nome das boas pr&amp;aacute</segment>
    <segment id="67">;ticas</segment>
    <segment id="68">, embevecidos pela performance do juiz de Curitiba e horrorizados pelas &amp;ldquo</segment>
    <segment id="69">;provas&amp;rdquo</segment>
    <segment id="70">; do lavajatismo&amp;ndash</segment>
    <segment id="71">;, apenas repetiram a hist&amp;oacute</segment>
    <segment id="72">;ria, consolidando um habitus de &amp;ldquo</segment>
    <segment id="73">;salvar&amp;rdquo</segment>
    <segment id="74">; a Rep&amp;uacute</segment>
    <segment id="75">;blica de seus v&amp;iacute</segment>
    <segment id="76">;cios.</segment>
    <segment id="77">Isso j&amp;aacute</segment>
    <segment id="78">; havia acontecido antes:</segment>
    <segment id="79">no tenentismo dos anos 1920</segment>
    <segment id="80">, na Revolu&amp;ccedil</segment>
    <segment id="81">;&amp;atilde</segment>
    <segment id="82">;o de 1930</segment>
    <segment id="83">, no golpe do Estado Novo de 1937</segment>
    <segment id="84">, na deposi&amp;ccedil</segment>
    <segment id="85">;&amp;atilde</segment>
    <segment id="86">;o de Vargas em 1945</segment>
    <segment id="87">, nos constantes &amp;ldquo</segment>
    <segment id="88">;pronunciamentos&amp;rdquo</segment>
    <segment id="89">; do Clube Militar durante a Quarta Rep&amp;uacute</segment>
    <segment id="90">;blica (1946-1964)</segment>
    <segment id="91">, culminando no regime civil-militar de 1964-1985 &amp;mdash</segment>
    <segment id="92">;em que tiveram uma Rep&amp;uacute</segment>
    <segment id="93">;blica para dizer e fazer</segment>
    <segment id="94">comocomo imaginavam o Brasil.</segment>
    <segment id="95">Os resultados todos conhecem.</segment>
    <segment id="96">A transi&amp;ccedil</segment>
    <segment id="97">;&amp;atilde</segment>
    <segment id="98">;o para democracia</segment>
    <segment id="99">, o projeto Geisel-Golbery</segment>
    <segment id="100">, foi o mais longo e tortuoso da hist&amp;oacute</segment>
    <segment id="101">;ria de qualquer Rep&amp;uacute</segment>
    <segment id="102">;blica</segment>
    <segment id="103">, sese estendendo de 1977 a 1988.</segment>
    <segment id="104">Em 1979</segment>
    <segment id="105">, foi dada anistia a torturadores e torturados</segment>
    <segment id="106">; depois</segment>
    <segment id="107">, calou-</segment>
    <segment id="108">sese sobre os terroristas que</segment>
    <segment id="109">, em 1980 e 1981</segment>
    <segment id="110">, lutaram contra a democracia de dentro do Estado</segment>
    <segment id="111">, atacando com bombas a oposi&amp;ccedil</segment>
    <segment id="112">;&amp;atilde</segment>
    <segment id="113">;o.</segment>
    <segment id="114">Os epis&amp;oacute</segment>
    <segment id="115">;dios do Riocentro</segment>
    <segment id="116">, da OAB e da C&amp;acirc</segment>
    <segment id="117">;mara dos Vereadores do Rio &amp;mdash</segment>
    <segment id="118">;todos crimes de sangue</segment>
    <segment id="119">, terroristas e p&amp;oacute</segment>
    <segment id="120">;s-anistia&amp;mdash</segment>
    <segment id="121">;</segment>
    <segment id="122">s&amp;atilde</segment>
    <segment id="123">;o bons exemplos dessa atua&amp;ccedil</segment>
    <segment id="124">;&amp;atilde</segment>
    <segment id="125">;o, al&amp;eacute</segment>
    <segment id="126">;m dos crimes &amp;ldquo</segment>
    <segment id="127">;continuados&amp;rdquo</segment>
    <segment id="128">;, de sequestro e desapari&amp;ccedil</segment>
    <segment id="129">;&amp;atilde</segment>
    <segment id="130">;o de cad&amp;aacute</segment>
    <segment id="131">;veres.</segment>
    <segment id="132">A Constitui&amp;ccedil</segment>
    <segment id="133">;&amp;atilde</segment>
    <segment id="134">;o de 1988 incorporou a Lei da Anistia de 1979 em nome da conc&amp;oacute</segment>
    <segment id="135">;rdia.</segment>
    <segment id="136">No entanto</segment>
    <segment id="137">, nem todos a aceitaram.</segment>
    <segment id="138">O projeto Geisel-Golbery</segment>
    <segment id="139">, superado pelas ruas</segment>
    <segment id="140">, continuou a ser combatido pelo lado de dentro</segment>
    <segment id="141">, pelos bols&amp;otilde</segment>
    <segment id="142">;es &amp;ldquo</segment>
    <segment id="143">;radicais</segment>
    <segment id="144">, por&amp;eacute</segment>
    <segment id="145">;m sinceros&amp;rdquo</segment>
    <segment id="146">; no seu desamor ao Estado de Direito</segment>
    <segment id="147">, que nunca aceitaram</segment>
    <segment id="148">sese habituar com a democracia.</segment>
    <segment id="149">Esses setores</segment>
    <segment id="150">sese consideravam herdeiros do ex-ministro golpista general Sylvio Frota</segment>
    <segment id="151">, que tinha</segment>
    <segment id="152">comocomo ajudante de ordens um certo capit&amp;atilde</segment>
    <segment id="153">;o Augusto Heleno.</segment>
    <segment id="154">Os setores terroristas</segment>
    <segment id="155">, que planejavam ataques at&amp;eacute</segment>
    <segment id="156">; contra companheiros de farda</segment>
    <segment id="157">, continuaram pregando a n&amp;atilde</segment>
    <segment id="158">;o exist&amp;ecirc</segment>
    <segment id="159">;ncia da ditadura</segment>
    <segment id="160">, do golpe</segment>
    <segment id="161">, de sequestros e avan&amp;ccedil</segment>
    <segment id="162">;aram at&amp;eacute</segment>
    <segment id="163">; a nega&amp;ccedil</segment>
    <segment id="164">;&amp;atilde</segment>
    <segment id="165">;o da escravid&amp;atilde</segment>
    <segment id="166">;o e do racismo no Brasil &amp;mdash</segment>
    <segment id="167">;chegando</segment>
    <segment id="168">, por fim</segment>
    <segment id="169">, &amp;agrave</segment>
    <segment id="170">; vacina.</segment>
    <segment id="171">A máquina da repressão da ditadura militarMais</segment>
    <segment id="172">novamente         de   de  de  representando um  Aos poucos</segment>
    <segment id="173">, passou a ser poss&amp;iacute</segment>
    <segment id="174">;vel perceber que a transi&amp;ccedil</segment>
    <segment id="175">;&amp;atilde</segment>
    <segment id="176">;o democr&amp;aacute</segment>
    <segment id="177">;tica, a abertura de Ernesto Geisel e Golbery do Couto e Silva</segment>
    <segment id="178">, n&amp;atilde</segment>
    <segment id="179">;o havia acontecido para amplos setores das For&amp;ccedil</segment>
    <segment id="180">;as Armadas.</segment>
    <segment id="181">Entre os modelos de transi&amp;ccedil</segment>
    <segment id="182">;&amp;atilde</segment>
    <segment id="183">;o &amp;ndash</segment>
    <segment id="184">;na Argentina</segment>
    <segment id="185">, com puni&amp;ccedil</segment>
    <segment id="186">;&amp;otilde</segment>
    <segment id="187">;es; na &amp;Aacute</segment>
    <segment id="188">;frica do Sul</segment>
    <segment id="189">, com o reconhecimento p&amp;uacute</segment>
    <segment id="190">;blico do passado e a defesa da conc&amp;oacute</segment>
    <segment id="191">;rdia; na Espanha</segment>
    <segment id="192">, com pactos de &amp;ldquo</segment>
    <segment id="193">;esquecimento&amp;rdquo</segment>
    <segment id="194">;, mas</segment>
    <segment id="195">mas sem repeti&amp;ccedil</segment>
    <segment id="196">;&amp;atilde</segment>
    <segment id="197">;o&amp;mdash</segment>
    <segment id="198">; o Brasil escolheu um modelo especial: o esquecimento repetitivo.</segment>
    <segment id="199">O tu&amp;iacute</segment>
    <segment id="200">;te do ent&amp;atilde</segment>
    <segment id="201">;o comandante do Ex&amp;eacute</segment>
    <segment id="202">;rcito</segment>
    <segment id="203">, Eduardo Villas B&amp;ocirc</segment>
    <segment id="204">;as, pressionando o Supremo Tribunal Federal a n&amp;atilde</segment>
    <segment id="205">;o conceder habeas corpus ao ex-presidente Luis In&amp;aacute</segment>
    <segment id="206">;cio Lula da Silva</segment>
    <segment id="207">, em 2018</segment>
    <segment id="208">, marcou definitivamente o retorno dos comandantes militares &amp;agrave</segment>
    <segment id="209">; pol&amp;iacute</segment>
    <segment id="210">;tica.  &amp;Eacute</segment>
    <segment id="211">; verdade que esse processo j&amp;aacute</segment>
    <segment id="212">; sese desenrolava desde 2016</segment>
    <segment id="213">, quando a c&amp;uacute</segment>
    <segment id="214">;pula das For&amp;ccedil</segment>
    <segment id="215">;as Armadas participou ativamente &amp;ndash</segment>
    <segment id="216">;ao lado da &amp;ldquo</segment>
    <segment id="217">;frente parlamentar&amp;rdquo</segment>
    <segment id="218">; e da &amp;ldquo</segment>
    <segment id="219">;frente empresarial&amp;rdquo</segment>
    <segment id="220">;, constituindo a &amp;ldquo</segment>
    <segment id="221">;frente militar&amp;rdquo</segment>
    <segment id="222">;&amp;ndash</segment>
    <segment id="223">; da garantia do impeachment da presidenta Dilma Rousseff (PT) por motivos hoje sabidamente irris&amp;oacute</segment>
    <segment id="224">;rios.</segment>
    <segment id="225">O que os comandantes militares da &amp;eacute</segment>
    <segment id="226">;poca colocaram em jogo abusivamente</segment>
    <segment id="227">, no seu retorno &amp;agrave</segment>
    <segment id="228">; pol&amp;iacute</segment>
    <segment id="229">;tica, foi a imagem permanente das For&amp;ccedil</segment>
    <segment id="230">;as</segment>
    <segment id="231">Armadas brasileiras</segment>
    <segment id="232">, evidenciando que a institui&amp;ccedil</segment>
    <segment id="233">;&amp;atilde</segment>
    <segment id="234">;o n&amp;atilde</segment>
    <segment id="235">;o realizou a transi&amp;ccedil</segment>
    <segment id="236">;&amp;atilde</segment>
    <segment id="237">;o democr&amp;aacute</segment>
    <segment id="238">;tica e a habitua&amp;ccedil</segment>
    <segment id="239">;&amp;atilde</segment>
    <segment id="240">;o &amp;agrave</segment>
    <segment id="241">; Nova Rep&amp;uacute</segment>
    <segment id="242">;blica.</segment>
    <segment id="243">O mesmo pode ser dito das pol&amp;iacute</segment>
    <segment id="244">;cias brasileiras</segment>
    <segment id="245">, em especial a PM</segment>
    <segment id="246">, da diplomacia e de boa parte da alta administra&amp;ccedil</segment>
    <segment id="247">;&amp;atilde</segment>
    <segment id="248">;o nacional</segment>
    <segment id="249">, incluindo a&amp;iacute</segment>
    <segment id="250">; a Justi&amp;ccedil</segment>
    <segment id="251">;a &amp;mdash</segment>
    <segment id="252">;que o diga</segment>
    <segment id="253">comocomo o sistema judici&amp;aacute</segment>
    <segment id="254">;rio lida com casos de racismo estrutural e com as chacinas de negros e pardos no pa&amp;iacute</segment>
    <segment id="255">;s.</segment>
    <segment id="256">Apesar dessa conjuntura</segment>
    <segment id="257">, parte dos analistas considerava que a presen&amp;ccedil</segment>
    <segment id="258">;a de alguns generais no governo de Jair Bolsonaro (sem partido) era bem-vinda</segment>
    <segment id="259">, dado o car&amp;aacute</segment>
    <segment id="260">;ter &amp;ldquo</segment>
    <segment id="261">;ideol&amp;oacute</segment>
    <segment id="262">;gico&amp;rdquo</segment>
    <segment id="263">; da nova gest&amp;atilde</segment>
    <segment id="264">;o, podendo desempenhar a fun&amp;ccedil</segment>
    <segment id="265">;&amp;atilde</segment>
    <segment id="266">;o de tutelar e conter os arroubos do presidente.</segment>
    <segment id="267">Os militares no início do governo BolsonaroMais    novamente         de   de  de  representando um</segment>
    <segment id="268">Com as primeiras demiss&amp;otilde</segment>
    <segment id="269">;es de militares de alta patente do governo &amp;mdash</segment>
    <segment id="270">;comocomo os generais Carlos Alberto dos Santos Cruz e Maynard Santa Rosa</segment>
    <segment id="271">, ambos extremamente conservadores e defenestrados exatamente por acreditarem na &amp;ldquo</segment>
    <segment id="272">;tutela&amp;rdquo</segment>
    <segment id="273">; do presidente&amp;mdash</segment>
    <segment id="274">;, evidenciou-</segment>
    <segment id="275">sese que Bolsonaro era o &amp;uacute</segment>
    <segment id="276">;nico respons&amp;aacute</segment>
    <segment id="277">;vel por seu governo.</segment>
    <segment id="278">O avan&amp;ccedil</segment>
    <segment id="279">;o da pandemia &amp;mdash</segment>
    <segment id="280">;previsto e calculado dia a dia por cientistas e institui&amp;ccedil</segment>
    <segment id="281">;&amp;otilde</segment>
    <segment id="282">;es&amp;mdash</segment>
    <segment id="283">; fez emergir o &amp;ldquo</segment>
    <segment id="284">;lado oculto&amp;rdquo</segment>
    <segment id="285">; do governo:</segment>
    <segment id="286">n&amp;atilde</segment>
    <segment id="287">;o sua incapacidade de agir</segment>
    <segment id="288">, masmas sua capacidade de colocar em pr&amp;aacute</segment>
    <segment id="289">;tica um governo paralelo</segment>
    <segment id="290">, camuflado</segment>
    <segment id="291">, impondo aos brasileiros uma pol&amp;iacute</segment>
    <segment id="292">;tica de cont&amp;aacute</segment>
    <segment id="293">;gio impositivo de Covid-19.  Sucederam-</segment>
    <segment id="294">sese ministros da Sa&amp;uacute</segment>
    <segment id="295">;de at&amp;eacute</segment>
    <segment id="296">;</segment>
    <segment id="297">chegar ao &amp;ldquo</segment>
    <segment id="298">;homem no posto&amp;rdquo</segment>
    <segment id="299">;: o general Eduardo Pazuello</segment>
    <segment id="300">, dito especialista em log&amp;iacute</segment>
    <segment id="301">;stica</segment>
    <segment id="302">, grande estrategista</segment>
    <segment id="303">, trazendo nos ombros a expertise do Ex&amp;eacute</segment>
    <segment id="304">;rcito.</segment>
    <segment id="305">A&amp;iacute</segment>
    <segment id="306">; come&amp;ccedil</segment>
    <segment id="307">;aria o desastre.</segment>
    <segment id="308">Os n&amp;uacute</segment>
    <segment id="309">;meros de doentes</segment>
    <segment id="310">, mortos e sequelados transbordam.</segment>
    <segment id="311">Bolsonaro debochou</segment>
    <segment id="312">, Pazuello obedeceu.</segment>
    <segment id="313">A imagem do Ex&amp;eacute</segment>
    <segment id="314">;rcito</segment>
    <segment id="315">, e por antonom&amp;aacute</segment>
    <segment id="316">;sia das For&amp;ccedil</segment>
    <segment id="317">;as Armadas</segment>
    <segment id="318">, sese retraiu em pesquisas sobre a confiabilidade das institui&amp;ccedil</segment>
    <segment id="319">;&amp;otilde</segment>
    <segment id="320">;es nacionais.</segment>
    <segment id="321">A visibilidade n&amp;atilde</segment>
    <segment id="322">;o buscada trouxe</segment>
    <segment id="323">, ainda</segment>
    <segment id="324">, a publicidade sobre compras</segment>
    <segment id="325">comocomo de leite condensado</segment>
    <segment id="326">, carnes e bebidas no momento em que brasileiros tinham que ser socorridos pelo aux&amp;iacute</segment>
    <segment id="327">;lio emergencial e</segment>
    <segment id="328">, ainda mais grave</segment>
    <segment id="329">, de hospitais militares fechados &amp;</segment>
    <segment id="330">mdash;incluindo Manaus</segment>
    <segment id="331">, epicentro da cat&amp;aacute</segment>
    <segment id="332">;strofe&amp;ndash</segment>
    <segment id="333">; ao mesmo tempo que pessoas morriam e o general Pazuello</segment>
    <segment id="334">, em visita &amp;agrave</segment>
    <segment id="335">; cidade</segment>
    <segment id="336">, receitava cloroquina.</segment>
    <segment id="337">Mortes e mentiras</segment>
    <segment id="338">sese acumulavam.</segment>
    <segment id="339">A aus&amp;ecirc</segment>
    <segment id="340">;ncia de prontid&amp;atilde</segment>
    <segment id="341">;o, de estrat&amp;eacute</segment>
    <segment id="342">;gia ou de log&amp;iacute</segment>
    <segment id="343">;stica para salvar vidas ficou evidente.</segment>
    <segment id="344">O general mentiu</segment>
    <segment id="345">, sese portou de forma relaxada</segment>
    <segment id="346">, descuidada e com grave inc&amp;uacute</segment>
    <segment id="347">;ria, assim</segment>
    <segment id="348">comocomo seus subordinados diretos</segment>
    <segment id="349">, enquanto faltava oxig&amp;ecirc</segment>
    <segment id="350">;nio para os internados por Covid-19.</segment>
    <segment id="351">O drama em ManausMais    novamente         de   de  de  representando um  A soma desses comportamentos</segment>
    <segment id="352">sese choca diretamente com os valores b&amp;aacute</segment>
    <segment id="353">;sicos que qualquer aluno deveria ter assimilado na Aman (Academia Militar das Agulhas Negras):</segment>
    <segment id="354">dire&amp;ccedil</segment>
    <segment id="355">;&amp;atilde</segment>
    <segment id="356">;o, comando</segment>
    <segment id="357">, coragem moral</segment>
    <segment id="358">, cumprimento da miss&amp;atilde</segment>
    <segment id="359">;o, criatividade</segment>
    <segment id="360">, aprimoramento t&amp;eacute</segment>
    <segment id="361">;cnico</segment>
    <segment id="362">, civismo</segment>
    <segment id="363">, f&amp;eacute</segment>
    <segment id="364">; na miss&amp;atilde</segment>
    <segment id="365">;o, patriotismo.</segment>
    <segment id="366">Pazuello faltou com todos esses valores b&amp;aacute</segment>
    <segment id="367">;sicos.</segment>
    <segment id="368">Alguns outros preciosos valores</segment>
    <segment id="369">, de extrema sensibilidade exigidos na academia e na vida de qualquer um</segment>
    <segment id="370">, tamb&amp;eacute</segment>
    <segment id="371">;m foram estranhos ao general Pazuello: sensibilidade moral: capacidade de</segment>
    <segment id="372">sese sentir moralmente afetado</segment>
    <segment id="373">; julgamento moral: capacidade que permite refletir sobre situa&amp;ccedil</segment>
    <segment id="374">;&amp;otilde</segment>
    <segment id="375">;es que exigem interface com valores</segment>
    <segment id="376">; empatia: capacidade que permite compreender ideais e valores dos demais</segment>
    <segment id="377">;</segment>
    <segment id="378">contextualiza&amp;ccedil</segment>
    <segment id="379">;&amp;atilde</segment>
    <segment id="380">;o moral: capacidade que permite a reflex&amp;atilde</segment>
    <segment id="381">;o moral.</segment>
    <segment id="382">Em resumo</segment>
    <segment id="383">, no caso</segment>
    <segment id="384">caso de Eduardo Pazuello</segment>
    <segment id="385">, a Aman formou um general sem alma.</segment>
    <segment id="386">Infelizmente</segment>
    <segment id="387">, a hist&amp;oacute</segment>
    <segment id="388">;ria nos relata a trajet&amp;oacute</segment>
    <segment id="389">;ria de generais desse tipo</segment>
    <segment id="390">, sem alma</segment>
    <segment id="391">, sempre associadas a genoc&amp;iacute</segment>
    <segment id="392">;dios.</segment>
    <segment id="393">O caso</segment>
    <segment id="394">caso Pazuello refor&amp;ccedil</segment>
    <segment id="395">;ou e estimulou o movimento do Ex&amp;eacute</segment>
    <segment id="396">;rcito em dire&amp;ccedil</segment>
    <segment id="397">;&amp;atilde</segment>
    <segment id="398">;o a um discreto distanciamento do governo Bolsonaro &amp;mdash</segment>
    <segment id="399">;t&amp;atilde</segment>
    <segment id="400">;o discreto que muitos nem sequer o percebem.</segment>
    <segment id="401">O afastamento</segment>
    <segment id="402">, como</segment>
    <segment id="403">como tudo no Ex&amp;eacute</segment>
    <segment id="404">;rcito</segment>
    <segment id="405">, deveria ser lento</segment>
    <segment id="406">, seguro e gradual</segment>
    <segment id="407">, sem dar raz&amp;atilde</segment>
    <segment id="408">;o e motivos aos cr&amp;iacute</segment>
    <segment id="409">;ticos e sem despertar rancores.</segment>
    <segment id="410">No entanto</segment>
    <segment id="411">, por sua pr&amp;oacute</segment>
    <segment id="412">;pria lentid&amp;atilde</segment>
    <segment id="413">;o e aus&amp;ecirc</segment>
    <segment id="414">;ncia de rumo</segment>
    <segment id="415">, esse movimento despertou a desconfian&amp;ccedil</segment>
    <segment id="416">;a de todos os lados.</segment>
    <segment id="417">Os militares encastelados no governo Bolsonaro temeram ficar isolados</segment>
    <segment id="418">, denunciados na solid&amp;atilde</segment>
    <segment id="419">;o do Planalto.</segment>
    <segment id="420">Aqueles que queriam o afastamento</segment>
    <segment id="421">, enojados com a indisciplina</segment>
    <segment id="422">, a incompet&amp;ecirc</segment>
    <segment id="423">;ncia e o cabotinismo de Pazuello</segment>
    <segment id="424">, queriam a puni&amp;ccedil</segment>
    <segment id="425">;&amp;atilde</segment>
    <segment id="426">;o imediata</segment>
    <segment id="427">, como</segment>
    <segment id="428">como claro sinal do distanciamento em curso.</segment>
    <segment id="429">Jair Bolsonaro (esq.) e o general Eduardo Pazuello em cerimônia no Palácio do Planalto sobre a vacinação contra a Covid-19 - Ueslei Marcelino - 16.dez.20/ReutersFez-</segment>
    <segment id="430">sese o impasse.</segment>
    <segment id="431">Eram os primeiros dias de junho</segment>
    <segment id="432">, dois meses depois da exonera&amp;ccedil</segment>
    <segment id="433">;&amp;atilde</segment>
    <segment id="434">;o dos generais Edson Pujol e Fernando Azevedo e Silva do Comando do Ex&amp;eacute</segment>
    <segment id="435">;rcito e do Minist&amp;eacute</segment>
    <segment id="436">;rio da Defesa</segment>
    <segment id="437">, respectivamente &amp;ndash</segment>
    <segment id="438">;a segunda crise militar do governo dos generais.  Por&amp;eacute</segment>
    <segment id="439">;m, havia mais.</segment>
    <segment id="440">A crise desencadeada por Pazuello deixou escapar um nojo maior</segment>
    <segment id="441">, uma escala de ressentimentos ainda mais profunda.</segment>
    <segment id="442">N&amp;atilde</segment>
    <segment id="443">;o eram apenas os cargos disputados em termos de &amp;ldquo</segment>
    <segment id="444">;quem &amp;eacute</segment>
    <segment id="445">; o mais antigo?</segment>
    <segment id="446">Agora &amp;eacute</segment>
    <segment id="447">;</segment>
    <segment id="448">minha vez!&amp;rdquo</segment>
    <segment id="449">;.</segment>
    <segment id="450">Eram os sinais evidentes de vaidade e arrog&amp;acirc</segment>
    <segment id="451">;ncia.</segment>
    <segment id="452">Era a compra de ternos caros</segment>
    <segment id="453">, mochilas importadas</segment>
    <segment id="454">, &amp;ldquo</segment>
    <segment id="455">;pins&amp;rdquo</segment>
    <segment id="456">; americanos &amp;ldquo</segment>
    <segment id="457">;de Armas&amp;rdquo</segment>
    <segment id="458">; para as gravatas</segment>
    <segment id="459">, &amp;ldquo</segment>
    <segment id="460">;cases&amp;rdquo</segment>
    <segment id="461">; e, claro</segment>
    <segment id="462">, computadores</segment>
    <segment id="463">, visitas constantes ao eBay</segment>
    <segment id="464">, corrida para vagas em embaixadas e miss&amp;otilde</segment>
    <segment id="465">;es diplom&amp;aacute</segment>
    <segment id="466">;ticas.</segment>
    <segment id="467">Por mais traum&amp;aacute</segment>
    <segment id="468">;tico e cruel que tenha sido 1964</segment>
    <segment id="469">, havia um projeto: 2019 teve um ar de festa na prov&amp;iacute</segment>
    <segment id="470">;ncia.</segment>
    <segment id="471">Ao longo de maio</segment>
    <segment id="472">, Pazuello passeava leve e solto sem m&amp;aacute</segment>
    <segment id="473">;scara em shoppings</segment>
    <segment id="474">, participava de motociatas e subia em palanques.</segment>
    <segment id="475">Tal atua&amp;ccedil</segment>
    <segment id="476">;&amp;atilde</segment>
    <segment id="477">;o, que beirava o deboche</segment>
    <segment id="478">, conseguiu uma fa&amp;ccedil</segment>
    <segment id="479">;anha, na primeira semana de junho: uniu quase toda a For&amp;ccedil</segment>
    <segment id="480">;a ativa</segment>
    <segment id="481">, boa parte da reserva &amp;ndash</segment>
    <segment id="482">;e eis aqui uma novidade&amp;ndash</segment>
    <segment id="483">; a Marinha e</segment>
    <segment id="484">, bem ou mal</segment>
    <segment id="485">, a Aeron&amp;aacute</segment>
    <segment id="486">;utica em torno de dois pontos: puni&amp;ccedil</segment>
    <segment id="487">;&amp;atilde</segment>
    <segment id="488">;o e imediata passagem para a reserva do general.</segment>
    <segment id="489">Bolsonaro faz passeio de moto no Rio e gera aglomeraçãoMais    novamente         de   de  de  representando um  N&amp;atilde</segment>
    <segment id="490">;o bastava pass&amp;aacute</segment>
    <segment id="491">;-lo para a reserva</segment>
    <segment id="492">, era necess&amp;aacute</segment>
    <segment id="493">;ria uma puni&amp;ccedil</segment>
    <segment id="494">;&amp;atilde</segment>
    <segment id="495">;o, escrita ou oral</segment>
    <segment id="496">, e uma advert&amp;ecirc</segment>
    <segment id="497">;ncia, mais ou menos dura.</segment>
    <segment id="498">Haveria uma puni&amp;ccedil</segment>
    <segment id="499">;&amp;atilde</segment>
    <segment id="500">;o.  Ent&amp;atilde</segment>
    <segment id="501">;o, entrou em cena a tropa do presidente.</segment>
    <segment id="502">Coube ao general Luiz Eduardo Ramos</segment>
    <segment id="503">, ministro-chefe da Casa Civil</segment>
    <segment id="504">, a defesa do ministro da Sa&amp;uacute</segment>
    <segment id="505">;de respons&amp;aacute</segment>
    <segment id="506">;vel pela cat&amp;aacute</segment>
    <segment id="507">;strofe</segment>
    <segment id="508">, tendo no ministro da Defesa</segment>
    <segment id="509">, general Walter Braga Netto</segment>
    <segment id="510">, o suporte fundamental</segment>
    <segment id="511">, desde abril e maio</segment>
    <segment id="512">, para a defesa da &amp;ldquo</segment>
    <segment id="513">;exemplar&amp;rdquo</segment>
    <segment id="514">; gest&amp;atilde</segment>
    <segment id="515">;o de Pazuello na pasta.</segment>
    <segment id="516">Assim, o Comando do Ex&amp;eacute</segment>
    <segment id="517">;rcito foi paralisado pelo ministro da Defesa: uma puni&amp;ccedil</segment>
    <segment id="518">;&amp;atilde</segment>
    <segment id="519">;o do general entraria em choque direto com o ministro e</segment>
    <segment id="520">, claro</segment>
    <segment id="521">, com o presidente.</segment>
    <segment id="522">Bolsonaro</segment>
    <segment id="523">, como</segment>
    <segment id="524">como comandante em chefe</segment>
    <segment id="525">, n&amp;atilde</segment>
    <segment id="526">;o aceitaria e faria reverter o ato.</segment>
    <segment id="527">O rec&amp;eacute</segment>
    <segment id="528">;m nomeado comandante do Ex&amp;eacute</segment>
    <segment id="529">;rcito</segment>
    <segment id="530">, general Paulo S&amp;eacute</segment>
    <segment id="531">;rgio Nogueira de Oliveira</segment>
    <segment id="532">, e o Alto-Comando do Ex&amp;eacute</segment>
    <segment id="533">;rcito tiveram que avaliar o pre&amp;ccedil</segment>
    <segment id="534">;o, os custos e as consequ&amp;ecirc</segment>
    <segment id="535">;ncias de uma terceira crise militar em t&amp;atilde</segment>
    <segment id="536">;o pouco tempo.</segment>
    <segment id="537">Na &amp;uacute</segment>
    <segment id="538">;ltima quarta-feira (23)</segment>
    <segment id="539">, Bolsonaro publicou um decreto que permite que oficiais das For&amp;ccedil</segment>
    <segment id="540">;as n&amp;atilde</segment>
    <segment id="541">;o sejam obrigados a passar para a reserva depois de dois anos em cargos civis</segment>
    <segment id="542">, podendo exercer fun&amp;ccedil</segment>
    <segment id="543">;&amp;otilde</segment>
    <segment id="544">;es administrativas sem restri&amp;ccedil</segment>
    <segment id="545">;&amp;atilde</segment>
    <segment id="546">;o de tempo.</segment>
    <segment id="547">A medida vai na contram&amp;atilde</segment>
    <segment id="548">;o da expectativa dos comandantes do Ex&amp;eacute</segment>
    <segment id="549">;rcito e pode levar a um novo acirramento da rela&amp;ccedil</segment>
    <segment id="550">;&amp;atilde</segment>
    <segment id="551">;o dos militares com o Pal&amp;aacute</segment>
    <segment id="552">;cio do Planalto.</segment>
    <segment id="553">Novos comandantes das Forças Armadas escolhidos por BolsonaroMais    novamente         de   de  de  representando um</segment>
    <segment id="554">O presidente</segment>
    <segment id="555">, ao exonerar os generais Edson Pujol e Fernando Azevedo e Silva no final de mar&amp;ccedil</segment>
    <segment id="556">;o, conseguiu uma meia vit&amp;oacute</segment>
    <segment id="557">;ria no seu processo de bolsonariza&amp;ccedil</segment>
    <segment id="558">;&amp;atilde</segment>
    <segment id="559">;o das institui&amp;ccedil</segment>
    <segment id="560">;&amp;otilde</segment>
    <segment id="561">;es.</segment>
    <segment id="562">O caso</segment>
    <segment id="563">caso Pazuello</segment>
    <segment id="564">, orientado pelo general Ramos e secundado pela tremenda aus&amp;ecirc</segment>
    <segment id="565">;ncia e abandono da tropa pelo general Braga Netto</segment>
    <segment id="566">, deveria ser a ceifada final do bolsonarismo contra a t&amp;iacute</segment>
    <segment id="567">;mida tentativa do Ex&amp;eacute</segment>
    <segment id="568">;rcito de</segment>
    <segment id="569">sese manter distante da cat&amp;aacute</segment>
    <segment id="570">;strofe.</segment>
    <segment id="571">Tudo culminaria na exonera&amp;ccedil</segment>
    <segment id="572">;&amp;atilde</segment>
    <segment id="573">;o do general Paulo S&amp;eacute</segment>
    <segment id="574">;rgio de Oliveira.</segment>
    <segment id="575">Bolsonaro estaria</segment>
    <segment id="576">, ent&amp;atilde</segment>
    <segment id="577">;o, livre para nomear o &amp;ldquo</segment>
    <segment id="578">;seu&amp;rdquo</segment>
    <segment id="579">; general para comandar o &amp;ldquo</segment>
    <segment id="580">;seu Ex&amp;eacute</segment>
    <segment id="581">;rcito&amp;rdquo</segment>
    <segment id="582">;.</segment>
    <segment id="583">Com isso</segment>
    <segment id="584">, finalmente</segment>
    <segment id="585">, o tenente expulso da For&amp;ccedil</segment>
    <segment id="586">;a por indisciplina e aus&amp;ecirc</segment>
    <segment id="587">;ncia de f&amp;eacute</segment>
    <segment id="588">;, que</segment>
    <segment id="589">sese tornou capit&amp;atilde</segment>
    <segment id="590">;o por ato de gra&amp;ccedil</segment>
    <segment id="591">;a, teria um Ex&amp;eacute</segment>
    <segment id="592">;rcito para chamar de seu.</segment>
    <segment id="593">No entanto</segment>
    <segment id="594">, esse roteiro n&amp;atilde</segment>
    <segment id="595">;o sese concretizou.</segment>
    <segment id="596">Ainda.</segment>
