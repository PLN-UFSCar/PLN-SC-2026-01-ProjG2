  <rst>
    <segment id="1">Morreu nesta segunda (26)</segment>
    <segment id="2">, em Roma</segment>
    <segment id="3">, o cineasta italiano Bernardo Bertolucci</segment>
    <segment id="4">, um dos últimos remanescentes da geração de autores revelada na Europa nos anos 1960.</segment>
    <segment id="5">Ele tinha 77 anos e sofria de um câncer</segment>
    <segment id="6">, segundo informou sua assessora.</segment>
    <segment id="7">Nascido na cidade de Parma</segment>
    <segment id="8">, Bertolucci construiu uma obra ancorada no espírito libertário da década em que iniciou sua carreira e deixou filmes carregados de sensualidade</segment>
    <segment id="9">, alguma dose de politização e</segment>
    <segment id="10">, não raro</segment>
    <segment id="11">, controvérsia.</segment>
    <segment id="12">Também foi um revelador de jovens talentos</segment>
    <segment id="13">, incluindo Liv Tyler</segment>
    <segment id="14">, Eva Green</segment>
    <segment id="15">, Maria Schneider e Louis Garrel.</segment>
    <segment id="16">Ex-assistente de Pier Paolo Pasolini</segment>
    <segment id="17">, estreou em voo solo com “A Morte”</segment>
    <segment id="18">, de 1962</segment>
    <segment id="19">, apoiado em roteiro escrito pelo antigo chefe.</segment>
    <segment id="20">Dois anos mais tarde</segment>
    <segment id="21">, viria “</segment>
    <segment id="22">Antes da Revolução”.</segment>
    <segment id="23">Chama a atenção a partir de 1970 com “</segment>
    <segment id="24">O Conformista”</segment>
    <segment id="25">, adaptação do romance homônimo de Alberto Moravia sobre a normalização do fascismo.</segment>
    <segment id="26">Protagonizado por uma das estrelas da época</segment>
    <segment id="27">, o francês Jean-Louis Trintignant</segment>
    <segment id="28">, o longa foi premiado no Festival de Berlim e indicado ao Oscar de roteiro adaptado.</segment>
    <segment id="29">A consagração viria com “</segment>
    <segment id="30">O Último Tango em Paris” (1972)</segment>
    <segment id="31">,  repleto de aura existencialista e cercado de polêmicas.</segment>
    <segment id="32">A história acompanha a relação</segment>
    <segment id="33">, basicamente sexual</segment>
    <segment id="34">, entre uma jovem parisiense e um americano mais velho.</segment>
    <segment id="35">O diretor italiano Bernardo Bertolucci</segment>
    <segment id="36">, de &amp;quot</segment>
    <segment id="37">;O Último Tango em Paris&amp;quot</segment>
    <segment id="38">; - AFPUma cena de sexo anal envolvendo os personagens interpretados por Marlon Brando e Maria Schneider levou a cortes ou à censura total do longa-metragem em vários países.</segment>
    <segment id="39">Ela ficaria conhecida</segment>
    <segment id="40">comocomo a “cena da manteiga”.</segment>
    <segment id="41">Na Itália</segment>
    <segment id="42">, onde “Tango” só pôde estrear três anos depois</segment>
    <segment id="43">, todas as cópias foram confiscadas depois de uma semana do filme em cartaz.</segment>
    <segment id="44">Bertolucci</segment>
    <segment id="45">sese viu processado por obscenidade</segment>
    <segment id="46">, e a Justiça ordenou que elas fossem destruídas</segment>
    <segment id="47">, além de condená-lo à prisão.</segment>
    <segment id="48">A produção só cumpriu carreira no circuito italiano em 1987.</segment>
    <segment id="49">No Brasil</segment>
    <segment id="50">, onde foi proibida pela censura da ditadura</segment>
    <segment id="51">, o filme estreou em 1979.</segment>
    <segment id="52">A voltagem sexual em “Tango” fez com que ele alcançasse status simbólico nessa guerra cultural dos costumes</segment>
    <segment id="53">, opondo liberais e conservadores.</segment>
    <segment id="54">Entrevistada</segment>
    <segment id="55">, Schneider repetia ter sido coagida a fazer a cena controversa</segment>
    <segment id="56">, cujo nível de violência ela teria descoberto só na hora da filmagem.</segment>
    <segment id="57">O diretor confirmou essa versão em 2013</segment>
    <segment id="58">, dois anos após a morte da atriz</segment>
    <segment id="59">, que sofreu com o alcoolismo.</segment>
    <segment id="60">Bertolucci contou que ele e Brando haviam combinado em segredo que o ator usaria manteiga</segment>
    <segment id="61">comocomo lubrificante.</segment>
    <segment id="62">“Queria que Maria sentisse</segment>
    <segment id="63">, e não atuasse</segment>
    <segment id="64">, diante da raiva e da humilhação”</segment>
    <segment id="65">, afirmou em entrevista.</segment>
    <segment id="66">Marlon Brando e Maria Schneider em &amp;quot</segment>
    <segment id="67">;O Último Tango em Paris&amp;quot</segment>
    <segment id="68">; - DivulgaçãoEm 1976</segment>
    <segment id="69">, depois do fuzuê de seu longa mais famoso</segment>
    <segment id="70">, Bertolucci escalou um elenco internacional liderado por Robert De Niro e Gérard Depardieu na superprodução “1900”.</segment>
    <segment id="71">O épico aborda luta de classes por meio da história de dois velhos amigos que</segment>
    <segment id="72">sese estranham.</segment>
    <segment id="73">O cineasta teve a confirmação de sua estatura global com “</segment>
    <segment id="74">O Último Imperador” (1987)</segment>
    <segment id="75">, outro épico de grandes proporções</segment>
    <segment id="76">, dessa vez sobre o derradeiro monarca chinês</segment>
    <segment id="77">, aprisionado pelos comunistas.</segment>
    <segment id="78">Vencedor de nove estatuetas no Oscar</segment>
    <segment id="79">, incluindo as de melhor filme e diretor</segment>
    <segment id="80">, o trabalho inaugura a fase hollywoodiana</segment>
    <segment id="81">, que incluiria ainda os menos aclamados</segment>
    <segment id="82">“O Céu que nos Protege”</segment>
    <segment id="83">, de 1990</segment>
    <segment id="84">,</segment>
    <segment id="85">e “</segment>
    <segment id="86">O Pequeno Buda”</segment>
    <segment id="87">, três anos depois.</segment>
    <segment id="88">Ele volta à Itália (</segment>
    <segment id="89">masmas em língua inglesa) com “Beleza Roubada” (1996)</segment>
    <segment id="90">, sobre a viagem existencial de uma jovem</segment>
    <segment id="91">, vivida por Liv Tyler.</segment>
    <segment id="92">Mas só faz pazes com crítica e cinéfilos graças a “Os Sonhadores” (2003)</segment>
    <segment id="93">, que trata das ondulações lúbricas e intelectuais de um trio de jovens franco-americanos</segment>
    <segment id="94">, com o Maio de 68 parisiense de pano fundo.</segment>
    <segment id="95">Debilitado</segment>
    <segment id="96">, ele se</segment>
    <segment id="97">se despediria dos longas-metragens rodando o doce “Eu e Você” (2012)</segment>
    <segment id="98">, mais uma adaptação literária.</segment>
    <segment id="99">Estava escrevendo um roteiro novo</segment>
    <segment id="100">, segundo disse à Folha seu ex-assistente</segment>
    <segment id="101">, o diretor brasileiro André Ristum.​  Quem perdemos em 2018   novamente         de   de  de  representando um</segment>
  </rst>
</analysis>