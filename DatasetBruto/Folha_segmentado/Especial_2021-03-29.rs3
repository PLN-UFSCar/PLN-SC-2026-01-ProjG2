  <rst>
    <segment id="1">Em debate sobre a aplica&amp;ccedil</segment>
    <segment id="2">;&amp;atilde</segment>
    <segment id="3">;o da LSN (Lei de Seguran&amp;ccedil</segment>
    <segment id="4">;a Nacional) nesta segunda-feira (29)</segment>
    <segment id="5">, mesmo especialistas que consideram que a norma atual n&amp;atilde</segment>
    <segment id="6">;o &amp;eacute</segment>
    <segment id="7">; compat&amp;iacute</segment>
    <segment id="8">;vel com a Constitui&amp;ccedil</segment>
    <segment id="9">;&amp;atilde</segment>
    <segment id="10">;o ponderaram que a revoga&amp;ccedil</segment>
    <segment id="11">;&amp;atilde</segment>
    <segment id="12">;o completa da norma pelo Supremo Tribunal Federal (STF) n&amp;atilde</segment>
    <segment id="13">;o necessariamente seria o melhor caminho.</segment>
    <segment id="14">No mesmo painel online</segment>
    <segment id="15">, o ministro da AGU (Advocacia-Geral da Uni&amp;atilde</segment>
    <segment id="16">;o), Jos&amp;eacute</segment>
    <segment id="17">; Levi Mello do Amaral</segment>
    <segment id="18">, defendeu que o problema a ser discutido</segment>
    <segment id="19">, muitas vezes</segment>
    <segment id="20">, n&amp;atilde</segment>
    <segment id="21">;o &amp;eacute</segment>
    <segment id="22">;</segment>
    <segment id="23">sese uma norma &amp;eacute</segment>
    <segment id="24">; boa ou ruim</segment>
    <segment id="25">, masmas a interpreta&amp;ccedil</segment>
    <segment id="26">;&amp;atilde</segment>
    <segment id="27">;o e aplica&amp;ccedil</segment>
    <segment id="28">;&amp;atilde</segment>
    <segment id="29">;o que</segment>
    <segment id="30">sese faz dela.</segment>
    <segment id="31">O ministro do governo Jair Bolsonaro defendeu que a LSN</segment>
    <segment id="32">, criada durante a ditadura militar</segment>
    <segment id="33">, pode ser aplicada em face da Constitui&amp;ccedil</segment>
    <segment id="34">;&amp;atilde</segment>
    <segment id="35">;o de 1988.</segment>
    <segment id="36">Al&amp;eacute</segment>
    <segment id="37">;m dele</segment>
    <segment id="38">, participaram do painel o ex-ministro da Justi&amp;ccedil</segment>
    <segment id="39">;a e professor da USP Miguel Reale J&amp;uacute</segment>
    <segment id="40">;nior, o professor e advogado Lenio Streck e a advogada Ta&amp;iacute</segment>
    <segment id="41">;s Gasparian</segment>
    <segment id="42">, que defende a Folha diferentes a&amp;ccedil</segment>
    <segment id="43">;&amp;otilde</segment>
    <segment id="44">;es.</segment>
    <segment id="45">A Máquina da Repressão   novamente         de   de  de  representando um</segment>
    <segment id="46">O evento online foi promovido pelo Instituto LGPD (Legal Grounds for Privacy Design)</segment>
    <segment id="47">, com transmiss&amp;atilde</segment>
    <segment id="48">;o pelo canal do Youtube da organiza&amp;ccedil</segment>
    <segment id="49">;&amp;atilde</segment>
    <segment id="50">;o.</segment>
    <segment id="51">O evento desta segunda-feira (29) foi realizado em parceria com ANJ (Associa&amp;ccedil</segment>
    <segment id="52">;&amp;atilde</segment>
    <segment id="53">;o Nacional dos Jornais)</segment>
    <segment id="54">, Escola Superior de Advocacia da OAB Nacional</segment>
    <segment id="55">, Abert (Associa&amp;ccedil</segment>
    <segment id="56">;&amp;atilde</segment>
    <segment id="57">;o Brasileira de Emissoras de R&amp;aacute</segment>
    <segment id="58">;dio e Televis&amp;atilde</segment>
    <segment id="59">;o) e Aner (Associa&amp;ccedil</segment>
    <segment id="60">;&amp;atilde</segment>
    <segment id="61">;o Nacional de Editores de Revistas.  Miguel Reale mencionou a exist&amp;ecirc</segment>
    <segment id="62">;ncia de projetos no Legislativo que buscam alterar ou revogar a lei</segment>
    <segment id="63">, masmas afirmou que n&amp;atilde</segment>
    <segment id="64">;o considera ser este o melhor caminho no momento.  &amp;quot</segment>
    <segment id="65">;Vale a pena correr o risco de a C&amp;acirc</segment>
    <segment id="66">;mara que a&amp;iacute</segment>
    <segment id="67">;</segment>
    <segment id="68">est&amp;aacute</segment>
    <segment id="69">; fazer uma Lei de Seguran&amp;ccedil</segment>
    <segment id="70">;a ou uma Lei de Defesa do Estado de Direito que pode ser uma nova Lei de Seguran&amp;ccedil</segment>
    <segment id="71">;a?&amp;quot</segment>
    <segment id="72">;, questionou ele.</segment>
    <segment id="73">O professor defendeu que o tema seja debatido no Supremo</segment>
    <segment id="74">para que</segment>
    <segment id="75">para que a lei seja interpretada conforme a Constitui&amp;ccedil</segment>
    <segment id="76">;&amp;atilde</segment>
    <segment id="77">;o Federal ou</segment>
    <segment id="78">para que</segment>
    <segment id="79">para que parte dos dispositivos seja considerada inconstitucional.  &amp;quot</segment>
    <segment id="80">;&amp;Eacute</segment>
    <segment id="81">; muito mais confi&amp;aacute</segment>
    <segment id="82">;vel ir ao STF e arguir a constitucionalidade de alguns artigos.</segment>
    <segment id="83">Ningu&amp;eacute</segment>
    <segment id="84">;m est&amp;aacute</segment>
    <segment id="85">; dizendo que a Lei de Seguran&amp;ccedil</segment>
    <segment id="86">;a Nacional deve ser considerada inconstitucional no seu todo.&amp;quot</segment>
    <segment id="87">;  J&amp;aacute</segment>
    <segment id="88">; o advogado Lenio Streck</segment>
    <segment id="89">, que &amp;eacute</segment>
    <segment id="90">; um dos autores de um projeto para uma Lei de Defesa do Estado Democr&amp;aacute</segment>
    <segment id="91">;tico de Direito</segment>
    <segment id="92">, afirmou que est&amp;aacute</segment>
    <segment id="93">; dividido entre as duas frentes:</segment>
    <segment id="94">tanto a de discuss&amp;atilde</segment>
    <segment id="95">;o no Judici&amp;aacute</segment>
    <segment id="96">;rio sobre a constitucionalidade da norma quanto a discuss&amp;atilde</segment>
    <segment id="97">;o legislativa.</segment>
    <segment id="98">Ele fez uma ressalva</segment>
    <segment id="99">, no entanto</segment>
    <segment id="100">, e disse compreender a posi&amp;ccedil</segment>
    <segment id="101">;&amp;atilde</segment>
    <segment id="102">;o de Reale quanto ao projeto que pode vir a ser aprovado e sobre a preocupa&amp;ccedil</segment>
    <segment id="103">;&amp;atilde</segment>
    <segment id="104">;o de que haja um v&amp;aacute</segment>
    <segment id="105">;cuo legislativo com a revoga&amp;ccedil</segment>
    <segment id="106">;&amp;atilde</segment>
    <segment id="107">;o total da norma atual.</segment>
    <segment id="108">&amp;ldquo</segment>
    <segment id="109">;Se extingue-</segment>
    <segment id="110">sese totalmente a lei</segment>
    <segment id="111">, eu tenho humildade cient&amp;iacute</segment>
    <segment id="112">;fica e jur&amp;iacute</segment>
    <segment id="113">;dica para reconhecer o perigo e</segment>
    <segment id="114">, porque</segment>
    <segment id="115">porque n&amp;atilde</segment>
    <segment id="116">;o, aderir a essa tese da interpreta&amp;ccedil</segment>
    <segment id="117">;&amp;atilde</segment>
    <segment id="118">;o conforme [a Constitui&amp;ccedil</segment>
    <segment id="119">;&amp;atilde</segment>
    <segment id="120">;o] e salvar aqueles peda&amp;ccedil</segment>
    <segment id="121">;os importantes da lei&amp;quot</segment>
    <segment id="122">;, afirmou Streck.</segment>
    <segment id="123">Em live</segment>
    <segment id="124">, especialistas em direito debateram a aplicação da Lei de Segurança Nacional e</segment>
    <segment id="125">sese a norma é ou não compatível com a Constituição - Reprodução YoutubeO ministro da AGU</segment>
    <segment id="126">, Jos&amp;eacute</segment>
    <segment id="127">; Levi</segment>
    <segment id="128">, afirmou que leis anteriores &amp;agrave</segment>
    <segment id="129">; Constitui&amp;ccedil</segment>
    <segment id="130">;&amp;atilde</segment>
    <segment id="131">;o e que sejam consideradas recepcionadas por ela ganham um novo fundamento.</segment>
    <segment id="132">&amp;ldquo</segment>
    <segment id="133">;A lei anterior ganha um novo fundamento de validade</segment>
    <segment id="134">, qual seja</segment>
    <segment id="135">, a nova Constitui&amp;ccedil</segment>
    <segment id="136">;&amp;atilde</segment>
    <segment id="137">;o que veio a existir.</segment>
    <segment id="138">Essa lei anterior pode e deve ser compreendida e aplicada em face da nova Constitui&amp;ccedil</segment>
    <segment id="139">;&amp;atilde</segment>
    <segment id="140">;o.&amp;rdquo</segment>
    <segment id="141">;     &amp;ldquo</segment>
    <segment id="142">;Em boa medida</segment>
    <segment id="143">, quem aplica a norma &amp;eacute</segment>
    <segment id="144">;</segment>
    <segment id="145">respons&amp;aacute</segment>
    <segment id="146">;vel direto pela percep&amp;ccedil</segment>
    <segment id="147">;&amp;atilde</segment>
    <segment id="148">;o positiva ou negativa de uma determinada lei</segment>
    <segment id="149">, sobretudo em face da Constitui&amp;ccedil</segment>
    <segment id="150">;&amp;atilde</segment>
    <segment id="151">;o&amp;rdquo</segment>
    <segment id="152">;, disse.</segment>
    <segment id="153">Miguel Reale questionou o posicionamento da AGU: &amp;quot</segment>
    <segment id="154">;Por que n&amp;atilde</segment>
    <segment id="155">;o reconhecer que &amp;eacute</segment>
    <segment id="156">; inconstitucional?</segment>
    <segment id="157">Qual preju&amp;iacute</segment>
    <segment id="158">;zo tem a AGU [em] reconhecer que &amp;eacute</segment>
    <segment id="159">; inconstitucional</segment>
    <segment id="160">o que &amp;eacute</segment>
    <segment id="161">; manifestamente inconstitucional?&amp;quot</segment>
    <segment id="162">;</segment>
    <segment id="163">Tanto Reale quanto a advogada</segment>
    <segment id="164">Tais Gasparian destacaram a reda&amp;ccedil</segment>
    <segment id="165">;&amp;atilde</segment>
    <segment id="166">;o dos artigos 16 e 17 da lei</segment>
    <segment id="167">, que estabelecem crimes contra &amp;quot</segment>
    <segment id="168">;o regime vigente ou o Estado de Direito&amp;quot</segment>
    <segment id="169">;.</segment>
    <segment id="170">&amp;</segment>
    <segment id="171">quot;N&amp;atilde</segment>
    <segment id="172">;o sese pode achar que uma lei que fala do regime vigente em oposi&amp;ccedil</segment>
    <segment id="173">;&amp;atilde</segment>
    <segment id="174">;o ao Estado de Direito que ela seja agora ainda constitucional&amp;quot</segment>
    <segment id="175">;, afirmou Gasparian</segment>
    <segment id="176">, defendendo que o Supremo</segment>
    <segment id="177">sese debruce sobre a constitucionalidade da norma tendo em vista a liberdade de express&amp;atilde</segment>
    <segment id="178">;o.</segment>
    <segment id="179">A advogada tamb&amp;eacute</segment>
    <segment id="180">;m apontou a responsabilidade do pr&amp;oacute</segment>
    <segment id="181">;prio STF no ressurgimento do uso da lei</segment>
    <segment id="182">, ao aplicar a legisla&amp;ccedil</segment>
    <segment id="183">;&amp;atilde</segment>
    <segment id="184">;o nos &amp;uacute</segment>
    <segment id="185">;ltimos dois anos.</segment>
    <segment id="186">O presidente Jair Bolsonaro em 2021   novamente         de   de  de  representando um  Editada em 1983</segment>
    <segment id="187">, a Lei de Seguran&amp;ccedil</segment>
    <segment id="188">;a Nacional tem 35 artigos e trata</segment>
    <segment id="189">, em suma</segment>
    <segment id="190">, de crimes contra a &amp;quot</segment>
    <segment id="191">;a integridade territorial e a soberania nacional</segment>
    <segment id="192">, o regime representativo e democr&amp;aacute</segment>
    <segment id="193">;tico, a federa&amp;ccedil</segment>
    <segment id="194">;&amp;atilde</segment>
    <segment id="195">;o e o Estado de Direito e a pessoa dos chefes dos Poderes da Uni&amp;atilde</segment>
    <segment id="196">;o&amp;quot</segment>
    <segment id="197">;.</segment>
    <segment id="198">A escalada no uso da legisla&amp;ccedil</segment>
    <segment id="199">;&amp;atilde</segment>
    <segment id="200">;o do regime militar para investigar cr&amp;iacute</segment>
    <segment id="201">;ticos ao governo Bolsonaro (sem partido) mobilizou congressistas</segment>
    <segment id="202">, partidos pol&amp;iacute</segment>
    <segment id="203">;ticos e organiza&amp;ccedil</segment>
    <segment id="204">;&amp;otilde</segment>
    <segment id="205">;es da sociedade civil a pressionarem o STF</segment>
    <segment id="206">, para que</segment>
    <segment id="207">para que a corte avalie</segment>
    <segment id="208">sese a norma &amp;eacute</segment>
    <segment id="209">; ou n&amp;atilde</segment>
    <segment id="210">;o compat&amp;iacute</segment>
    <segment id="211">;vel com a Constitui&amp;ccedil</segment>
    <segment id="212">;&amp;atilde</segment>
    <segment id="213">;o de 1988.</segment>
    <segment id="214">A lei tamb&amp;eacute</segment>
    <segment id="215">;m tem sido usada pelo pr&amp;oacute</segment>
    <segment id="216">;prio Supremo nos inqu&amp;eacute</segment>
    <segment id="217">;ritos das fake news e dos atos antidemocr&amp;aacute</segment>
    <segment id="218">;ticos</segment>
    <segment id="219">, foi com base nela que o ministro Alexandre de Moraes determinou a pris&amp;atilde</segment>
    <segment id="220">;o do deputado Daniel Silveira (PSL-RJ) em fevereiro deste ano.</segment>
    <segment id="221">Na &amp;uacute</segment>
    <segment id="222">;ltima semana</segment>
    <segment id="223">, em uma das a&amp;ccedil</segment>
    <segment id="224">;&amp;otilde</segment>
    <segment id="225">;es que questionam a constitucionalidade da norma</segment>
    <segment id="226">, a AGU afirmou ao STF que a Lei de Seguran&amp;ccedil</segment>
    <segment id="227">;a Nacional &amp;eacute</segment>
    <segment id="228">; constitucional e n&amp;atilde</segment>
    <segment id="229">;o viola a liberdade de express&amp;atilde</segment>
    <segment id="230">;o, pedindo a rejei&amp;ccedil</segment>
    <segment id="231">;&amp;atilde</segment>
    <segment id="232">;o do pedido.</segment>
    <segment id="233">Os partidos PTB</segment>
    <segment id="234">, PSDB e PSB</segment>
    <segment id="235">, por exemplo</segment>
    <segment id="236">, apresentaram a&amp;ccedil</segment>
    <segment id="237">;&amp;otilde</segment>
    <segment id="238">;es no STF sobre o tema.</segment>
    <segment id="239">Os dois primeiros pedem a suspens&amp;atilde</segment>
    <segment id="240">;o de toda a legisla&amp;ccedil</segment>
    <segment id="241">;&amp;atilde</segment>
    <segment id="242">;o, enquanto o terceiro solicita a invalida&amp;ccedil</segment>
    <segment id="243">;&amp;atilde</segment>
    <segment id="244">;o de trechos da lei.</segment>
    <segment id="245">O Supremo ainda n&amp;atilde</segment>
    <segment id="246">;o marcou uma data para analisar o</segment>
    <segment id="247">casocaso.</segment>
    <segment id="248">Mais de 30 projetos em tramita&amp;ccedil</segment>
    <segment id="249">;&amp;atilde</segment>
    <segment id="250">;o na C&amp;acirc</segment>
    <segment id="251">;mara dos Deputados tratam de altera&amp;ccedil</segment>
    <segment id="252">;&amp;otilde</segment>
    <segment id="253">;es ou revoga&amp;ccedil</segment>
    <segment id="254">;&amp;atilde</segment>
    <segment id="255">;o da LSN</segment>
    <segment id="256">, que seria substitu&amp;iacute</segment>
    <segment id="257">;da por uma Lei de Defesa do Estado Democr&amp;aacute</segment>
    <segment id="258">;tico de Direito.</segment>
    <segment id="259">Apesar de ser uma demanda antiga</segment>
    <segment id="260">, a revoga&amp;ccedil</segment>
    <segment id="261">;&amp;atilde</segment>
    <segment id="262">;o ou atualiza&amp;ccedil</segment>
    <segment id="263">;&amp;atilde</segment>
    <segment id="264">;o da norma nunca</segment>
    <segment id="265">sese efetivou.</segment>
    <segment id="266">Uma das tentativas de alterar a LSN foi ainda no governo de Fernando Henrique Cardoso (PSDB).</segment>
    <segment id="267">O trabalho da comiss&amp;atilde</segment>
    <segment id="268">;o montada por FHC resultou em um projeto de lei que revogava a LSN e introduzia no C&amp;oacute</segment>
    <segment id="269">;digo Penal um t&amp;iacute</segment>
    <segment id="270">;tulo espec&amp;iacute</segment>
    <segment id="271">;fico sobre crimes contra o Estado democr&amp;aacute</segment>
    <segment id="272">;tico de Direito</segment>
    <segment id="273">, entre eles o golpe de Estado.</segment>
    <segment id="274">A proposta foi encaminhada a FHC por Miguel Reale J&amp;uacute</segment>
    <segment id="275">;nior, ent&amp;atilde</segment>
    <segment id="276">;o ministro da Justi&amp;ccedil</segment>
    <segment id="277">;a, em abril de 2002</segment>
    <segment id="278">, masmas nunca prosperou.</segment>
    <segment id="279">O advogado e professor Lenio Streck foi um dos especialistas respons&amp;aacute</segment>
    <segment id="280">;veis pela elabora&amp;ccedil</segment>
    <segment id="281">;&amp;atilde</segment>
    <segment id="282">;o do projeto de lei 3864/2020 apresentado no ano passado pelos deputados Paulo Teixeira (PT-SP) e Jo&amp;atilde</segment>
    <segment id="283">;o Daniel (PT-SE).</segment>
    <segment id="284">O STF (Supremo Tribunal Federal) em 2021   novamente         de   de  de  representando</segment>
    <segment id="285">um</segment>
  </rst>
</analysis>