    <segment id="400">”, questiona.</segment>
    <segment id="401">Este é Alexandre de Moraes</segment>
    <segment id="402">, do STFMais    novamente         de   de  de  representando um  OS CAMINHOS PARA UM MINISTRO DO STF SER PROCESSADO</segment>
    <segment id="403">Em caso</segment>
