  <rst>
    <segment id="1">O cantor Gilberto Gil será um dos homenageados da segunda edição do Festival Instrumental Nacional (Fina)</segment>
    <segment id="2">, que reunirá músicos</segment>
    <segment id="3">comocomo Toninho Horta</segment>
    <segment id="4">, Mestrinho</segment>
    <segment id="5">, Cristina Braga e Turibio Santos em São Luís</segment>
    <segment id="6">, no Maranhão</segment>
    <segment id="7">, entre os dias 18 e 20 de agosto.</segment>
    <segment id="8">O show do grupo Carlos Malta e Pife Muderno será dedicado ao artista baiano.</segment>
    <segment id="9">Gilberto Gil durante o segundo dia do festival Turá</segment>
    <segment id="10">, no parque Ibirapuera - Rubens Cavallari - 24.jun.2023/Folhapress LETRAS</segment>
    <segment id="11">O escritor Itamar Vieira Júnior - Raquel Espíritio Santo/Divulgação</segment>
    <segment id="12">O escritor Itamar Vieira Júnior</segment>
    <segment id="13">, colunista da Folha e autor do best-seller "Torto Arado"</segment>
    <segment id="14">, estampará a capa da nova revista GOL Smiles.</segment>
    <segment id="15">Em entrevista à publicação</segment>
    <segment id="16">, ele fala sobre literatura e o seu mais recente romance</segment>
    <segment id="17">, "</segment>
    <segment id="18">Salvar o Fogo".</segment>
    <segment id="19">"</segment>
    <segment id="20">Eu digo que tenho fé na literatura</segment>
    <segment id="21">, porque</segment>
    <segment id="22">porque a literatura alarga o nosso horizonte</segment>
    <segment id="23">, o nosso mundo.</segment>
    <segment id="24">A ficção entra</segment>
    <segment id="25">comocomo uma arma poderosa</segment>
    <segment id="26">, porque</segment>
    <segment id="27">porque ela nos restitui a possibilidade de existir"</segment>
    <segment id="28">, diz Itamar.  com BIANKA VIEIRA</segment>
    <segment id="29">, KARINA MATIAS e MANOELLA SMITH</segment>
  </rst>
