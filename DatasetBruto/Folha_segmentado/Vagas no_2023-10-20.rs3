  <rst>
    <segment id="1">Os Jogos Pan-Americanos de Santiago dão sua largada oficial nesta sexta-feira (20)</segment>
    <segment id="2">, com a cerimônia de abertura no estádio Nacional do Chile</segment>
    <segment id="3">, carregando a promessa de ser um evento histórico embalado por grandes nomes.</segment>
    <segment id="4">Como ocorre nas Olimpíadas</segment>
    <segment id="5">, o Pan já tem disputas iniciadas –no boxe e no beisebol– antes mesmo da festa de apresentação ao público.</segment>
    <segment id="6">As primeiras medalhas serão distribuídas neste sábado (21).</segment>
    <segment id="7">A competição que vai até 5 de novembro é impulsionada por uma intensa movimentação nos bastidores da Panam</segment>
    <segment id="8">, a organização continental que realiza o Pan.</segment>
    <segment id="9">A ideia é fazer do evento o maior deste século</segment>
    <segment id="10">, superando as edições de Santo Domingo-2003</segment>
    <segment id="11">, Rio de Janeiro-2007</segment>
    <segment id="12">, Guadalajara-2011</segment>
    <segment id="13">, Toronto-2015 e Lima-2019.</segment>
    <segment id="14">Das 58 modalidades em disputa</segment>
    <segment id="15">, 21 darão vagas diretas para os Jogos Olímpicos de Paris.</segment>
    <segment id="16">Outras 12 têm influência nas vagas –contarão pontos para o ranking ou índices</segment>
    <segment id="17">, casos de atletismo e natação.</segment>
    <segment id="18">É o maior número envolvendo um Pan.</segment>
    <segment id="19">Rayssa Leal é um dos principais nomes do Brasil em Santiago - Karim Sahib - 5.fev.23/AFP"Nosso principal objetivo é classificar o maior número de atletas para Paris.</segment>
    <segment id="20">Temos uma edição muito diferente</segment>
    <segment id="21">, com Estados Unidos e Canadá agora trazendo o que têm de melhor"</segment>
    <segment id="22">, disse à Folha Rogério Sampaio</segment>
    <segment id="23">, diretor-geral do COB (Comitê Olímpico Brasileiro).</segment>
    <segment id="24">"</segment>
    <segment id="25">Só dos Estados Unidos são 31 atletas medalhistas olímpicos presentes.</segment>
    <segment id="26">"</segment>
    <segment id="27">A Panam anunciou a presença de 11 atletas com títulos olímpicos e mundiais confirmados no evento.</segment>
    <segment id="28">A entidade estampou orgulhosa os rostos desses esportistas e classificou</segment>
    <segment id="29">comocomo "superestrelas</segment>
    <segment id="30">" a ginasta brasileira</segment>
    <segment id="31">Rebeca Andrade</segment>
    <segment id="32">, medalha de ouro no salto nos Jogos de Tóquio-2020</segment>
    <segment id="33">, a nadadora canadense Maggie Mac Neil</segment>
    <segment id="34">, dona de um ouro</segment>
    <segment id="35">, uma prata e um bronze no Japão</segment>
    <segment id="36">, e o cubano Mijaín López</segment>
    <segment id="37">, atual tetracampeão olímpico na luta greco-romana</segment>
    <segment id="38">, considerado o maior da história da modalidade.</segment>
    <segment id="39">O cronograma foi remanejado</segment>
    <segment id="40">, e, na referência anual do calendário</segment>
    <segment id="41">, será a edição mais tardia da história do evento –superando o Pan de Guadalajara</segment>
    <segment id="42">, realizado entre 14 e 30 de outubro.</segment>
    <segment id="43">Isso foi feito para evitar a concorrência com outros eventos</segment>
    <segment id="44">, um problema visto em Lima-2019.</segment>
    <segment id="45">"Estamos com uma estrutura muito parecida com a de Tóquio</segment>
    <segment id="46">, olímpica mesmo.</segment>
    <segment id="47">Toda a equipe de saúde conta com médicos</segment>
    <segment id="48">, fisioterapeutas</segment>
    <segment id="49">, massoterapeutas</segment>
    <segment id="50">, psicólogos</segment>
    <segment id="51">, nutricionistas</segment>
    <segment id="52">, além de uma área só para a tecnologia.</segment>
    <segment id="53">E há outra para a bioquímica"</segment>
    <segment id="54">, disse Sampaio.</segment>
    <segment id="55">Segundo o diretor do COB</segment>
    <segment id="56">, a meta oficial estabelecida é a terceira colocação no quadro geral de medalhas</segment>
    <segment id="57">, masmas há a ambição de superar o Canadá</segment>
    <segment id="58">comocomo a segunda potência das Américas no esporte.</segment>
    <segment id="59">Medalhista de ouro nas Olimpíadas de Barcelona</segment>
    <segment id="60">, em 1992</segment>
    <segment id="61">, o ex-judoca que chefia a missão brasileira em Santiago jamais esteve em um Pan.</segment>
    <segment id="62">Ao lado de Aurélio Miguel e outros nomes</segment>
    <segment id="63">, Rogério Sampaio ficou praticamente dois anos e meio sem participar de grandes competições internacionais pela adesão ao boicote à CBJ (Confederação Brasileira de Judô).</segment>
    <segment id="64">Só retornou em janeiro de 1992</segment>
    <segment id="65">, meses antes dos Jogos Olímpicos.</segment>
    <segment id="66">"Perdi o Pan de Havana (em 1991) pela briga por benefícios para uma modalidade que não tinha a menor estrutura.</segment>
    <segment id="67">Hoje digo aos atletas: ‘Valorizem’.</segment>
    <segment id="68">Não existe mais esse posto de competição de patamar inferior"</segment>
    <segment id="69">, afirmou.</segment>
    <segment id="70">O Brasil obteve em 2019</segment>
    <segment id="71">, no Peru</segment>
    <segment id="72">, seu recorde de medalhas no Pan</segment>
    <segment id="73">, 170.</segment>
    <segment id="74">Na ocasião</segment>
    <segment id="75">, as disputas ocorreram simultaneamente a outros torneios importantes.</segment>
    <segment id="76">Competições</segment>
    <segment id="77">comocomo o Mundial de esportes aquáticos e os pré-olímpicos de vôlei esvaziaram o evento.  Desta vez</segment>
    <segment id="78">, isso não ocorre.</segment>
    <segment id="79">E o Brasil tem 621 atletas em sua delegação</segment>
    <segment id="80">, além de 11 reservas.</segment>
    <segment id="81">Um dos destaques é a skatista Rayssa Leal</segment>
    <segment id="82">, de 15 anos</segment>
    <segment id="83">, a mais jovem do grupo</segment>
    <segment id="84">, um dos 20 atletas medalhistas olímpicos presentes.</segment>
    <segment id="85">Chega como</segment>
    <segment id="86">como favorita a ginasta Rebeca Andrade</segment>
    <segment id="87">, que fará sua estreia em Pans</segment>
    <segment id="88">, após ausência por lesões em 2015 e 2019.</segment>
    <segment id="89">Ela não terá pelo caminho sua principal rival</segment>
    <segment id="90">, a norte-americana Simone Biles.</segment>
    <segment id="91">Rebeca Andrade é favorita a múltiplas medalhas no Chile - Zhao Dingzhe - 9.out.23/XinhuaOutro nome de peso é o da nadadora Ana Marcela Cunha</segment>
    <segment id="92">, ouro em Tóquio na prova dos 10 km.</segment>
    <segment id="93">Ela passou cerca de cinco meses parada em 2023 após ter sido submetida a uma cirurgia no ombro esquerdo.</segment>
    <segment id="94">Também brigam por medalhas</segment>
    <segment id="95">Hugo Calderano (tênis de mesa)</segment>
    <segment id="96">, Beatriz Ferreira (boxe)</segment>
    <segment id="97">, Isaquias Queiroz (canoagem)</segment>
    <segment id="98">, Fernando Scheffer (natação)</segment>
    <segment id="99">, Rafaela Silva (judô)</segment>
    <segment id="100">, Arthur Nory (ginástica artística)</segment>
    <segment id="101">, Guilherme Costa (natação)</segment>
    <segment id="102">, Tatiana Weston-Webb (surfe) e Luisa Stefani (tênis).</segment>
    <segment id="103">Stefani e Scheffer são os porta-bandeiras.</segment>
    <segment id="104">"</segment>
    <segment id="105">Não precisamos convencer ninguém</segment>
    <segment id="106">, persuadir ninguém.</segment>
    <segment id="107">Praticamente todos os chamados vieram</segment>
    <segment id="108">, com exceção ao Alison dos Santos</segment>
    <segment id="109">, que disputou o Mundial</segment>
    <segment id="110">, masmas</segment>
    <segment id="111">sese recuperou de recente cirurgia e precisava de tempo para a recuperação"</segment>
    <segment id="112">, afirmou Rogério Sampaio.</segment>
  </rst>
</analysis>