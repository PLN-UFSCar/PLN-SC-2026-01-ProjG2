  <rst>
    <segment id="1">Biscoita</segment>
    <segment id="2">, minha filha Elis</segment>
    <segment id="3">, de oito anos</segment>
    <segment id="4">, me olhou da cabeça aos pés num relance</segment>
    <segment id="5">, fez uma cara de mistério e preocupação</segment>
    <segment id="6">, e saiu correndo pelo condomínio.</segment>
    <segment id="7">"</segment>
    <segment id="8">Pirou com o calor"</segment>
    <segment id="9">, pensei</segment>
    <segment id="10">, e segui rodando despretensiosamente</segment>
    <segment id="11">, conhecendo os detalhes da morada do primo.</segment>
    <segment id="12">Sala de jogos</segment>
    <segment id="13">, sala de "games</segment>
    <segment id="14">", brinquedoteca</segment>
    <segment id="15">, mercadinho</segment>
    <segment id="16">, sala</segment>
    <segment id="17">casocaso falte alguma sala</segment>
    <segment id="18">, quadra</segment>
    <segment id="19">–não reparei</segment>
    <segment id="20">sese era de jogos ou de "games"—</segment>
    <segment id="21">, jardins.</segment>
    <segment id="22">"</segment>
    <segment id="23">Biscoita tá demorando</segment>
    <segment id="24">, né?</segment>
    <segment id="25">", questionou a prima que me ciceroneava por ali.</segment>
    <segment id="26">"</segment>
    <segment id="27">Ah, certeza que foi engambelada por algum parquinho</segment>
    <segment id="28">, fica tranquila"</segment>
    <segment id="29">, disse eu</segment>
    <segment id="30">, que sou desses pais que entrega na não de nossa senhora da bicicletinha o zelo da cria em situações que não pode ter total controle.</segment>
    <segment id="31">Bandeira exposta em passeata realizada em SP pedindo paz nas escolas (20.04.23) - Danilo Verpa/FolhapressNum repente</segment>
    <segment id="32">, eis que vem correndo em minha direção</segment>
    <segment id="33">, a cria esbaforida.</segment>
    <segment id="34">Tinha um sorriso colado na cara e um lume de satisfação nos olhos.</segment>
    <segment id="35">A prima respirou aliviada e a pulga de minha orelha saltou.  "</segment>
    <segment id="36">Pai, fui procurar seus óculos!</segment>
    <segment id="37">Vi que você não estava com eles e fiquei preocupada</segment>
    <segment id="38">, Imagina</segment>
    <segment id="39">sese tivesse perdido?</segment>
    <segment id="40">Mas encontrei</segment>
    <segment id="41">, pai, e nem quebrou nada.</segment>
    <segment id="42">Você não consegue ler sem eles</segment>
    <segment id="43">, né, pai?</segment>
    <segment id="44">", disse Elis</segment>
    <segment id="45">, depois de me dar um abraço cheio de orgulho de seu ato</segment>
    <segment id="46">, cheio de orgulho de pai.</segment>
    <segment id="47">No dia seguinte</segment>
    <segment id="48">, a prima me manda uma mensagem.</segment>
    <segment id="49">"</segment>
    <segment id="50">Primo, fiquei muito comovida.</segment>
    <segment id="51">Sua filha</segment>
    <segment id="52">, tão pequena</segment>
    <segment id="53">, com esse cuidado contigo.</segment>
    <segment id="54">Como é bom ter quem</segment>
    <segment id="55">sese importa com a gente".</segment>
    <segment id="56">Em casa</segment>
    <segment id="57">, a troca que tenho com minha pequena é a da convivência onde todos fazem por todos.</segment>
    <segment id="58">Celebramos as festas juntos e curamos os calundus de braços dados.</segment>
    <segment id="59">Importar-</segment>
    <segment id="60">sese com o outro é uma lição diária que já tornou-</segment>
    <segment id="61">sese prazer de viver</segment>
    <segment id="62">, sentido de amor.</segment>
    <segment id="63">Defender os próprios interesses é importante</segment>
    <segment id="64">, tem seu espaço</segment>
    <segment id="65">, masmas a harmonia entre os desejos</segment>
    <segment id="66">, o respeito ao "estar bem" do outro é o que nos faz melhor.</segment>
    <segment id="67">É gostoso quando isso</segment>
    <segment id="68">sese realiza e melhor ainda quando essa demonstração é coletiva.</segment>
    <segment id="69">Muros da Vila Flávia ganham cor com o projeto Favela Galeria</segment>
    <segment id="70">; veja imagensMais    novamente         de   de  de  representando um  Há algumas semanas</segment>
    <segment id="71">, nos EUA</segment>
    <segment id="72">, um grupo de fãs da cantora Beyoncé</segment>
    <segment id="73">sese mobilizou para conseguir que uma pessoa com deficiência</segment>
    <segment id="74">, que havia passado maus bocados para ir a um show da diva</segment>
    <segment id="75">, sem sucesso</segment>
    <segment id="76">, conseguisse ver a um espetáculo</segment>
    <segment id="77">, como</segment>
    <segment id="78">como qualquer outro aficionado.</segment>
    <segment id="79">Quando um bocado de gente</segment>
    <segment id="80">sese importa com uma exclusão</segment>
    <segment id="81">, com uma injustiça</segment>
    <segment id="82">, com uma dor</segment>
    <segment id="83">, com uma invisibilidade</segment>
    <segment id="84">, é como</segment>
    <segment id="85">como se</segment>
    <segment id="86">se o degelo dos polos estancasse por alguns instantes</segment>
    <segment id="87">, o aquecimento global desse um alívio diante nosso frescor de respeito à vida.</segment>
    <segment id="88">Importar-</segment>
    <segment id="89">sese com o outro significa abrir mão</segment>
    <segment id="90">, ampliar o que</segment>
    <segment id="91">sese sente</segment>
    <segment id="92">, ceder</segment>
    <segment id="93">, rever</segment>
    <segment id="94">, reaprender</segment>
    <segment id="95">, aquietar-</segment>
    <segment id="96">sese ou esgoelar-</segment>
    <segment id="97">sese.</segment>
    <segment id="98">São cada vez mais trincheiras para defender o meu e cada vez menos terrenos para compartilhar entre nós.</segment>
    <segment id="99">Penso que ser inquieto na busca por auxiliar crianças a entender a existência</segment>
    <segment id="100">comocomo plural</segment>
    <segment id="101">, como</segment>
    <segment id="102">como oportunidade de convivência em muitos quintais</segment>
    <segment id="103">, pode ser determinante no silenciar de explosões multidoloridas e para o cortejar dias em que a dor e as perdas de todo o mundo importa.</segment>
  </rst>
