  <rst>
    <segment id="1">Maior premiação da indústria musical</segment>
    <segment id="2">, o Grammy divulgou nesta terça (23) os indicados à sua premiação do ano que vem.</segment>
    <segment id="3">Um dos principais destaques da lista é Olivia Rodrigo</segment>
    <segment id="4">, que foi a única artista a concorrer simultaneamente nas categorias de álbum</segment>
    <segment id="5">, gravação</segment>
    <segment id="6">, canção e artista revelação do ano</segment>
    <segment id="7">, as principais da disputa.</segment>
    <segment id="8">O pianista Jon Batiste teve 11 indicações</segment>
    <segment id="9">, sendo o mais citado na cerimônia.</segment>
    <segment id="10">Justin Bieber</segment>
    <segment id="11">, Doja Cat e H.E.R tiveram oito citações cada um</segment>
    <segment id="12">, e Billie Eilish teve sete.</segment>
    <segment id="13">A 64ª edição da premiação teve ainda "</segment>
    <segment id="14">Love for Sale"</segment>
    <segment id="15">, disco de Lady Gaga com Tony Bennet</segment>
    <segment id="16">, indicado ao prêmio de melhor álbum do ano</segment>
    <segment id="17">, assim</segment>
    <segment id="18">comocomo "Planet Her" de Doja Cat e "</segment>
    <segment id="19">We Are</segment>
    <segment id="20">"</segment>
    <segment id="21">, de Jon Batiste.</segment>
    <segment id="22">"</segment>
    <segment id="23">Donda"</segment>
    <segment id="24">, o novo álbum de Kanye West</segment>
    <segment id="25">, foi indicado ao melhor álbum de rap.</segment>
    <segment id="26">Outro destaque foi a indicação da pianista brasileira Eliane Elias na categoria de melhor álbum de jazz latino com "Mirror Mirror"</segment>
    <segment id="27">, gravado em parceria com Chick Corea.</segment>
    <segment id="28">Kanye WestMais    novamente         de   de  de  representando um  Para melhor clipe musical</segment>
    <segment id="29">, estão entre os selecionados "Montero (Call Me By Your Name)"</segment>
    <segment id="30">, de Lil Nas X</segment>
    <segment id="31">; "I Get a Kick Of You"</segment>
    <segment id="32">, de Lady Gaga com Tony Bennet</segment>
    <segment id="33">; e "Peaches"</segment>
    <segment id="34">, de Justin Bieber</segment>
    <segment id="35">, que também concorre na categoia de melhor performance de R&amp;amp</segment>
    <segment id="36">;B. Olivia Rodrigo está entre as finalistas</segment>
    <segment id="37">comocomo artista revelação</segment>
    <segment id="38">, entre outras categorias.</segment>
