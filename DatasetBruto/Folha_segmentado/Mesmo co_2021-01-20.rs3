  <rst>
    <segment id="1">Ainda que o crescimento do ecommerce tenha turbinado os resultados de transportadoras no país no ano passado</segment>
    <segment id="2">, essa bonança não</segment>
    <segment id="3">sese refletiu em todo o setor.</segment>
    <segment id="4">Segundo o Ilos (Instituto de Logística e Supply Chain)</segment>
    <segment id="5">, as vendas pela internet movimentaram uma quantidade de carga muito pequena</segment>
    <segment id="6">, sese comparada por exemplo ao carregamento de commodities.</segment>
    <segment id="7">O instituto estima que o segmento</segment>
    <segment id="8">comocomo um todo tenha mantido estável o volume transportado em 2020</segment>
    <segment id="9">, ante 2019.</segment>
    <segment id="10">Caminhões parados em posto de gasolina da Dutra - Mathilde Missioneiro/Folhapress  Maurício Lima</segment>
    <segment id="11">, sócio-diretor do Ilos</segment>
    <segment id="12">, afirma que</segment>
    <segment id="13">, no caso</segment>
    <segment id="14">caso do transporte rodoviário</segment>
    <segment id="15">, um indicativo do desempenho é a venda de óleo diesel no país.</segment>
    <segment id="16">Até novembro do ano passado</segment>
    <segment id="17">, o volume comercializado chegava a 53</segment>
    <segment id="18">,6 milhões de metros cúbicos</segment>
    <segment id="19">, retração de 0</segment>
    <segment id="20">,6% em relação ao mesmo intervalo de 2019.</segment>
    <segment id="21">Dos modais</segment>
    <segment id="22">, o único que deve ter crescimento em volume transportado é o aquaviário.</segment>
    <segment id="23">Segundo Lima</segment>
    <segment id="24">, isso ocorre pelo aumento da produção de petróleo no país.</segment>
    <segment id="25">Dados da Antaq (Agência de Transportes Aquaviários) mostram que</segment>
    <segment id="26">, de janeiro a outubro</segment>
    <segment id="27">, houve alta de 17</segment>
    <segment id="28">,4% na cabotagem de granéis.</segment>
    <segment id="29">Entenda o que é a cabotagem e por que ela cresceuMais    novamente         de   de  de  representando um</segment>
    <segment id="30">Apesar do pouco impacto no resultado final do setor de transporte</segment>
    <segment id="31">, o ecommerce chama atenção por outro motivo.</segment>
    <segment id="32">Mirele Mautschke</segment>
    <segment id="33">, presidente da DHL Express no país</segment>
    <segment id="34">, diz que em 2020 houve alta na exportação relativa ao comércio eletrônico.</segment>
    <segment id="35">Mautschke diz que setores de moda</segment>
    <segment id="36">, eletrônicos e alta tecnologia foram os que</segment>
    <segment id="37">sese destacaram.</segment>
    <segment id="38">A empresa alemã deve investir no Brasil em 2021 entre R$ 18 milhões e R$ 19 milhões</segment>
    <segment id="39">, expandindo de 11 para 16 lojas próprias.</segment>
    <segment id="40">No país</segment>
    <segment id="41">, a DHL Express ainda possui 386 lojas parceiras.</segment>
    <segment id="42">Leia tambémJustiça suspende liminar que impedia reajuste de ICMS para hospitais privadosAção de alunos na Justiça pede reagendamento do Enem para quem perdeu a provaPara apoiar Manaus</segment>
    <segment id="43">, empresas tentam contratar avião cargueiro russoCompras com cupom de desconto ou dinheiro de volta na internet crescem 50% em 2020</segment>
    <segment id="44">,</segment>
    <segment id="45">diz empresaJustiça suspende redução de benefício fiscal para medicamentos em SPFacebook atualiza inteligência artificial que descreve imagens para cegos  Filipe Oliveira (interino)</segment>
    <segment id="46">, com Mariana Grazini e Arthur Cagliari</segment>
  </rst>
