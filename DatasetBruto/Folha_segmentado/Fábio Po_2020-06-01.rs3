    <segment id="78">Burnt Orange Heresy&amp;quot</segment>
    <segment id="79">;</segment>
    <segment id="80">out of competition - Red Carpet Arrivals - Venice</segment>
    <segment id="81">, Italy</segment>
    <segment id="82">, September 7</segment>
    <segment id="83">, 2019 - Mick Jagger poses.</segment>
