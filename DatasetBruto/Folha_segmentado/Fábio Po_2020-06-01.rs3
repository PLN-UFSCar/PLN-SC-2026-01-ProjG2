  <rst>
    <segment id="1">Fábio Porchat</segment>
    <segment id="2">, 36 anos</segment>
    <segment id="3">, está disposto a ajudar pequenos empreendedores que estão sofrendo com a pandemia.</segment>
    <segment id="4">O humorista será garoto-propaganda de pequenos empresários</segment>
    <segment id="5">, sem cobrar cachê por isso.</segment>
    <segment id="6">Apoio 2</segment>
    <segment id="7">Interessados devem</segment>
    <segment id="8">sese inscrever pelo email divulga@fabioporchat.com.br enviando um texto com vídeos ou fotos sobre a empresa</segment>
    <segment id="9">, que deve ter CNPJ (Cadastro Nacional da Pessoa Jurídica)</segment>
    <segment id="10">, uma plataforma de venda online (site ou rede social) e um produto já existente no mercado.</segment>
    <segment id="11">FORA</segment>
    <segment id="12">O chef de cozinha Thiago Salvático</segment>
    <segment id="13">, que diz ter tido uma relação com Gugu Liberato nos três últimos anos de sua vida</segment>
    <segment id="14">, comunicou à Justiça que desistiu de disputar a herança do apresentador.</segment>
    <segment id="15">MINHA CASA</segment>
    <segment id="16">, SUA CASA  Ficar em casa é recomendação de praxe para quem pode</segment>
    <segment id="17">, neste momento.</segment>
    <segment id="18">Isso não impede que as beldades deixem de faturar com campanhas que vendem uma boa dose de sedução para o Dia dos Namorados</segment>
    <segment id="19">, inclusive</segment>
    <segment id="20">comocomo incentivo para comemorações entre quatro paredes</segment>
    <segment id="21">, aproveitando o ambiente doméstico.</segment>
    <segment id="22">Deborah Secco</segment>
    <segment id="23">, 40 anos</segment>
    <segment id="24">, é expert em ser fotografada de todos os ângulos.</segment>
    <segment id="25">A bonitona tem</segment>
    <segment id="26">sese mostrado ainda mais leve depois que</segment>
    <segment id="27">sese livrou do aplique de cabelos exigido por sua personagem em “Salve-</segment>
    <segment id="28">sese</segment>
    <segment id="29">Quem Puder”</segment>
    <segment id="30">, novela que entrou em recesso  O Olá nosso de cada dia   novamente         de   de  de  representando um  ​ FRASE     "</segment>
    <segment id="31">Depois de refletir</segment>
    <segment id="32">, ouvir amigos e familiares</segment>
    <segment id="33">, decidi não interagir nem dar trela a um entrevistado que considero um desequilibrado</segment>
    <segment id="34">, que causou muito mal ao Brasil com suas posições intolerantes</segment>
    <segment id="35">, promovendo um discurso de ódio</segment>
    <segment id="36">, especialmente contra vítimas da ditadura</segment>
    <segment id="37">, seguindo seu mentor charlatão</segment>
    <segment id="38">, Olavo de Carvalho.</segment>
    <segment id="39">Mesmo que ele</segment>
    <segment id="40">sese mostre arrependido</segment>
    <segment id="41">, considero uma pessoa que não tem muito a oferecer ao debate</segment>
    <segment id="42">, por conta de suas posturas e valores.</segment>
    <segment id="43">"</segment>
    <segment id="44">Marcelo Rubens Paiva</segment>
    <segment id="45">, que recusou convite da TV Cultura para entrevistar Lobão no Roda Viva</segment>
    <segment id="46">, em textono seu perfil pelo Facebook  CEGONHA</segment>
    <segment id="47">A atriz Sthefany Brito</segment>
    <segment id="48">, 32 anos</segment>
    <segment id="49">, mostrou a barriguinha da primeira gravidez em seu Instagram.</segment>
    <segment id="50">“Barriga pós-almoço de domingo +</segment>
    <segment id="51">um nenê crescendo”</segment>
    <segment id="52">, afirmou a atriz.</segment>
    <segment id="53">Casada com o empresário Igor Raschkovsky</segment>
    <segment id="54">, 30, há quase dois anos</segment>
    <segment id="55">, ela espera um menino</segment>
    <segment id="56">, que se</segment>
    <segment id="57">se chamará Antônio Enrico</segment>
    <segment id="58">, como</segment>
    <segment id="59">como ela havia anunciado aos fãs</segment>
    <segment id="60">, homenagem ao seu pai e ao avô.</segment>
    <segment id="61">PROTESTO</segment>
    <segment id="62">A indústria musical dos EUA planeja fazer nesta terça-feira (2) um dia de silêncio em solidariedade aos protestos pela morte de George Floyd</segment>
    <segment id="63">, negro asfixiado por um policial branco com os joelhos em seu pescoço</segment>
    <segment id="64">, em Minneapolis.</segment>
    <segment id="65">O caso</segment>
    <segment id="66">caso vem gerando uma série de manifestações em todo o país</segment>
    <segment id="67">, com repercussão mundial e adesão de celebridades.</segment>
    <segment id="68">Mick Jagger foi um dos artistas que aderiram à campanha:</segment>
    <segment id="69">“É de partir o coração ver os EUA</segment>
    <segment id="70">sese despedaçarem de novo por questões raciais.</segment>
    <segment id="71">Amanhã [hoje] vou ficar com meus colegas artistas e entrar no ‘blackout de terça’ para combater a discriminação racial e a injustiça social.</segment>
    <segment id="72">Eu rezo</segment>
    <segment id="73">para que</segment>
    <segment id="74">para que depois desse dia nós possamos superar esse ódio e divisão e começar a curar a dor e o sofrimento”.</segment>
    <segment id="75">FILE PHOTO: The 76th</segment>
    <segment id="76">Venice Film Festival -Screening of the film &amp;quot</segment>
