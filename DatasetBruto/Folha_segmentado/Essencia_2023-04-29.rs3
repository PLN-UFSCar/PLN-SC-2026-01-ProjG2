  <rst>
    <segment id="1">Um autor pode ser moralmente problemático —"do mal"</segment>
    <segment id="2">, sese é lícito tomar emprestada a terminologia infantil— e produzir uma obra relevante?</segment>
    <segment id="3">Vivemos em uma época que parece julgar antes de pensar</segment>
    <segment id="4">, masmas não é</segment>
    <segment id="5">porque</segment>
    <segment id="6">porque nossa época faz isso que somos obrigados a seguir-lhe os passos.</segment>
    <segment id="7">E nenhum autor</segment>
    <segment id="8">sese presta melhor a provocar esse tipo de reflexão do que Martin Heidegger (1889-1976)</segment>
    <segment id="9">, o filósofo nazista.</segment>
    <segment id="10">"Heidegger in</segment>
    <segment id="11">Ruins"</segment>
    <segment id="12">(Heidegger em ruínas)</segment>
    <segment id="13">, de Richard Wolin</segment>
    <segment id="14">, é uma obra devastadora.</segment>
    <segment id="15">Wolin se</segment>
    <segment id="16">se debruça sobre os chamados "</segment>
    <segment id="17">Cadernos Negros"</segment>
    <segment id="18">, publicados a partir de 2014</segment>
    <segment id="19">, uma espécie de diário em que Heidegger anotou seus pensamentos</segment>
    <segment id="20">, e outros materiais só recentemente divulgados</segment>
    <segment id="21">, como</segment>
    <segment id="22">como a correspondência com o irmão Fritz</segment>
    <segment id="23">,</segment>
    <segment id="24">e mostra que o nazismo e o antissemitismo são indissociáveis da obra do pensador alemão.</segment>
    <segment id="25">Ilustração de Annette Schwartsman para a coluna de Hélio Schwartsman - Annette Schwartsman</segment>
    <segment id="26">Se, até a década anterior</segment>
    <segment id="27">, admiradores de Heidegger ainda podiam descrever seu envolvimento com o nazismo</segment>
    <segment id="28">comocomo oportunismo ou desvio de caráter</segment>
    <segment id="29">, que não afetava os fundamentos de sua metafísica</segment>
    <segment id="30">, fazê-lo agora tornou-</segment>
    <segment id="31">sese bem mais difícil.</segment>
    <segment id="32">É o próprio Heidegger</segment>
    <segment id="33">, afinal</segment>
    <segment id="34">, quem anota que o desenraizamento ("Bodenlosigkeit") do povo judeu o aproximava do não-ser</segment>
    <segment id="35">, não havendo alternativa que não o seu aniquilamento ("Vernichtung").</segment>
    <segment id="36">Ele também sugere que o problema do nazismo foi não ter sido radical o bastante.</segment>
    <segment id="37">O livro de Wolin vai aos detalhes</segment>
    <segment id="38">, a ponto de tornar-</segment>
    <segment id="39">sese repetitivo.</segment>
    <segment id="40">O tom tem algo de inquisitorial.</segment>
    <segment id="41">O resultado não é bom para Heidegger.</segment>
    <segment id="42">Mas Wolin faz questão de dizer que seu objetivo não é cancelar o alemão</segment>
    <segment id="43">, que pode e deve ser lido.</segment>
    <segment id="44">Se ele ainda hoje influencia figuras detestáveis</segment>
    <segment id="45">comocomo Steve Bannon e Aleksandr Dugin</segment>
    <segment id="46">, também foi importante para um séquito de autores</segment>
    <segment id="47">comocomo Sartre</segment>
    <segment id="48">, Beauvoir</segment>
    <segment id="49">, Foucault</segment>
    <segment id="50">, Derrida</segment>
    <segment id="51">, cujo pensamento tem alguma relevância.</segment>
    <segment id="52">Wolin pode ser duro com o alemão</segment>
    <segment id="53">, masmas está fazendo o que na faculdade de filosofia chamávamos de história das ideias.</segment>
  </rst>
</analysis>