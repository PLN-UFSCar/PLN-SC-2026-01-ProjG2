  <rst>
    <segment id="1">Ir a aniversário de criança é mole hoje em dia.</segment>
    <segment id="2">O bolo é sempre de chocolate</segment>
    <segment id="3">, o que é bom –</segment>
    <segment id="4">masmas também tira um pouco da emoção do rolê.</segment>
    <segment id="5">Na minha infância</segment>
    <segment id="6">, nos tempos do orelhão e do vasilhame retornável</segment>
    <segment id="7">, festa infantil causava certa ansiedade.</segment>
    <segment id="8">Eu chegava e já inspecionava o recinto para localizar o bolo.</segment>
    <segment id="9">Alguns pais sádicos disfarçavam o bolo de paisagem –campo de futebol</segment>
    <segment id="10">, praia etc.</segment>
    <segment id="11">–</segment>
    <segment id="12">, com alegorias que tornavam impossível distinguir o sabor.</segment>
    <segment id="13">Mas nem sempre.</segment>
    <segment id="14">Às vezes a aparência do bolo entregava seu conteúdo.</segment>
    <segment id="15">Festinha no cercadinho com bolinho de ameixinha e abacaxizinho para o presidentinho da republicazinha - Pedro Ladeira/FolhapressBolo marrom</segment>
    <segment id="16">, joinha</segment>
    <segment id="17">, era de chocolate.</segment>
    <segment id="18">Bolo rosa</segment>
    <segment id="19">, morango: longe de ser o meu favorito</segment>
    <segment id="20">, masmas encarava.</segment>
    <segment id="21">Bolo branco</segment>
    <segment id="22">, alerta vermelho.</segment>
    <segment id="23">O bolo branco poderia ser de coco</segment>
    <segment id="24">, no limite do aceitável.</segment>
    <segment id="25">De abacaxi</segment>
    <segment id="26">, o horror</segment>
    <segment id="27">, o horror.</segment>
    <segment id="28">O pior do bolo branco era a ameixa seca</segment>
    <segment id="29">, arma química</segment>
    <segment id="30">, insidiosa</segment>
    <segment id="31">, camuflada num recheio capcioso de doce de leite ou baba de moça.</segment>
    <segment id="32">Nunca me ocorreu de pegar um bolo de abacaxi E ameixa.</segment>
    <segment id="33">Nunca me passou pela cabeça que pudessem fazer algo tão perverso.</segment>
    <segment id="34">Eis que hoje vejo que um grupo de gente desocupada que</segment>
    <segment id="35">sese autodenomina "tias do zap" foi oferecer um bolo</segment>
    <segment id="36">, de aparência horrenda</segment>
    <segment id="37">, para o aniversariante do dia: o animador de malucos do cercadinho da Alvorada.</segment>
    <segment id="38">O bolo que as tias ofereceram a Bolsonaro era de ameixa com abacaxi.</segment>
    <segment id="39">Muito adequado.</segment>
    <segment id="40">O pior bolo possível para o pior presidente que já tivemos.  (Siga e curta a Cozinha Bruta nas redes sociais.</segment>
    <segment id="41">Acompanhe os posts do Instagram e do Twitter.)</segment>
    <segment id="42">​</segment>
  </rst>
</analysis>