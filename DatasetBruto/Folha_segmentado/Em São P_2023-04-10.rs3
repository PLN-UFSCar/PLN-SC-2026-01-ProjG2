  <rst>
    <segment id="1">BAIXAR PESQUISA COMPLETA</segment>
    <segment id="2">No estado mais populoso do país</segment>
    <segment id="3">, o terceiro mandato de Lula (PT)</segment>
    <segment id="4">comocomo presidente completa três meses dividindo opiniões entre três grandes segmentos.</segment>
    <segment id="5">Em São Paulo</segment>
    <segment id="6">, 33% da população com 16 anos ou mais aprova a gestão do petista nesse período</segment>
    <segment id="7">, e uma parcela similar (34%) a avalia</segment>
    <segment id="8">comocomo regular.</segment>
    <segment id="9">A reprovação fica em patamar próximo (30%)</segment>
    <segment id="10">, e 3% não têm opinião sobre o assunto.</segment>
    <segment id="11">A aprovação do governo Lula no estado de São Paulo nesses três primeiros meses fica abaixo do registrado nacionalmente (38%)</segment>
    <segment id="12">, e o índice de reprovação é similar à registrada entre os brasileiros de maneira geral (29%).</segment>
    <segment id="13">No 2º turno da eleição presidencial de 2022</segment>
    <segment id="14">, Lula teve 45% dos votos válidos em São Paulo</segment>
    <segment id="15">, onde foi derrotado por Jair Bolsonaro (PL)</segment>
    <segment id="16">, escolhido por 55% dos eleitores do estado.</segment>
    <segment id="17">Na região metropolitana de São Paulo</segment>
    <segment id="18">, incluindo a capital</segment>
    <segment id="19">, 37% aprovam o governo Lula</segment>
    <segment id="20">, ante 29% entre quem vive no interior do estado.</segment>
    <segment id="21">Na parcela de católicos paulistas</segment>
    <segment id="22">, a aprovação é de 38%</segment>
    <segment id="23">, e entre evangélicos cai para 24%.</segment>
    <segment id="24">Os mais jovens</segment>
    <segment id="25">, de 16 a 24 anos</segment>
    <segment id="26">, tendem a aprovar (26%) e reprovar (23%) menos o governo</segment>
    <segment id="27">, o que leva a um índice acima da média de avaliação regular (49%).</segment>
    <segment id="28">Entre os paulistas que votaram em Lula no 2º turno da eleição</segment>
    <segment id="29">, 68% agora aprovam seu governo</segment>
    <segment id="30">, 27% o consideram regular</segment>
    <segment id="31">, e apenas 3% o reprovam.</segment>
    <segment id="32">Na parcela que escolheu Bolsonaro</segment>
    <segment id="33">, o petista tem 8% de aprovação</segment>
    <segment id="34">, 33% de avaliação regular e 56% de reprovação.</segment>
    <segment id="35">Para 11% dos moradores do Estado de São Paulo</segment>
    <segment id="36">, Lula fez pelo país</segment>
    <segment id="37">, nesses três meses</segment>
    <segment id="38">, mais do que esperavam</segment>
    <segment id="39">, e 28% avaliam que o petista fez o que esperavam que ele fizesse.</segment>
    <segment id="40">A maioria (56%) acredita que o petista fez menos do que o esperado até agora</segment>
    <segment id="41">, e 5% não opinaram ou deram outras respostas.</segment>
    <segment id="42">Uma parcela de 54% da população paulista adulta avalia que Lula vai cumprir parte de suas promessas de campanha</segment>
    <segment id="43">, masmas não a maioria delas</segment>
    <segment id="44">, e 22% acreditam que nenhuma promessa será cumprida.</segment>
    <segment id="45">Outros 23% pensam o oposto</segment>
    <segment id="46">, que o petista irá cumprir a maioria de suas promessas de campanha</segment>
    <segment id="47">, e 1% preferiu não opinar.</segment>
    <segment id="48">Daqui para frente</segment>
    <segment id="49">, 42% acreditam que Lula fará um governo ótimo ou bom</segment>
    <segment id="50">, e 31% esperam que seja regular.</segment>
    <segment id="51">Há 26% com expectativa negativa</segment>
    <segment id="52">, que esperam que o governo do petista seja ruim ou péssimo daqui para frente</segment>
    <segment id="53">, e 1% não opinou.</segment>
    <segment id="54">Na população brasileira</segment>
    <segment id="55">, o otimismo em relação ao futuro da gestão Lula é mais alto: 50% esperam que ele faça um governo ótimo ou bom daqui para frente</segment>
    <segment id="56">, e 21% têm expectativa negativa</segment>
    <segment id="57">, com 27% esperando por um governo regular.</segment>
  </rst>
</analysis>