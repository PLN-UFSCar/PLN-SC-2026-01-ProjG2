  <rst>
    <segment id="1">Demi</segment>
    <segment id="2">Lovato fez jus à sua nova fase roqueirinha</segment>
    <segment id="3">ao sese apresentar no palco Mundo do Rock in Rio neste domingo (4).</segment>
    <segment id="4">A cantora começou o show às 20h35</segment>
    <segment id="5">, vestida de preto da cabeça aos pés</segment>
    <segment id="6">, e agitou o público com arrastados solos de guitarra e vocais gritados.</segment>
    <segment id="7">Demi abriu o show com "</segment>
    <segment id="8">Holy Fvck"</segment>
    <segment id="9">, faixa que dá nome ao seu novo disco</segment>
    <segment id="10">, lançado semanas atrás com letras que atravessam temas</segment>
    <segment id="11">comocomo sexo</segment>
    <segment id="12">, religião e vício em drogas.</segment>
    <segment id="13">Demi</segment>
    <segment id="14">Lovato faz show de pop punk cativante só com mulheres no palco do Rock in Rio - Divulgação/MultishowOs lovatics</segment>
    <segment id="15">, nome dado aos fãs da cantora</segment>
    <segment id="16">, puderam sentir um gostinho nostálgico em canções</segment>
    <segment id="17">comocomo "La La Land"</segment>
    <segment id="18">, hit de sua fase Disney.</segment>
    <segment id="19">A cantora foi uma das estrelas da emissora</segment>
    <segment id="20">, tendo sido protagonista da sitcom "Sunny entre Estrelas" e dos filmes de "Camp Rock"</segment>
    <segment id="21">, que também tinha no elenco os extintos Jonas Bothers.  Rock in Rio 2022:</segment>
    <segment id="22">Como foi o show de Demi LovatoMais    novamente         de   de  de  representando um</segment>
    <segment id="23">A atmosfera nostálgica lembra o show de Miley Cyrus no Lollapalooza em março.</segment>
    <segment id="24">Nele, a ex-protagonista da série "Hannah Montana"</segment>
    <segment id="25">, que também vive uma fase roqueira na esteira do revival dos anos de 1980</segment>
    <segment id="26">, agitou o público com hits da década passada.</segment>
    <segment id="27">Rock in Rio 2022Mais    novamente         de   de  de  representando</segment>
    <segment id="28">um  Lovato tocou ainda "</segment>
    <segment id="29">Remember December"</segment>
    <segment id="30">, "Skyscraper"</segment>
    <segment id="31">, "</segment>
    <segment id="32">Cool for the Summer"</segment>
    <segment id="33">, "29"</segment>
    <segment id="34">e "</segment>
    <segment id="35">Heart Attack" para uma plateia que a acompanhava cantando do começo ao fim</segment>
    <segment id="36">, principalmente as canções antigas.</segment>
    <segment id="37">Foi um show animado e contagiante</segment>
    <segment id="38">, já consagrado</segment>
    <segment id="39">comocomo um dos melhores da edição na seara do rock.</segment>
    <segment id="40">Veja looks dos famosos no show de Demi LovatoMais    novamente         de   de  de  representando um</segment>
