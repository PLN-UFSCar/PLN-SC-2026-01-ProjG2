  <rst>
    <segment id="1">Ninguém está preocupado com este flagelo</segment>
    <segment id="2">, masmas há cada vez mais gente que</segment>
    <segment id="3">sese gaba de ser humilde.</segment>
    <segment id="4">Ora, gabar-</segment>
    <segment id="5">sese de ser humilde é o equivalente a anunciar aos gritos que</segment>
    <segment id="6">sese é mudo.</segment>
    <segment id="7">A humildade aconselharia alguma modéstia na hora de publicitar qualidades</segment>
    <segment id="8">comocomo a humildade.</segment>
    <segment id="9">Uma pessoa verdadeiramente humilde talvez devesse</segment>
    <segment id="10">, de vez em quando</segment>
    <segment id="11">, comportar-</segment>
    <segment id="12">sese de forma ligeiramente arrogante</segment>
    <segment id="13">, para humildemente camuflar o fato de ser humilde.</segment>
    <segment id="14">Se alguém tem orgulho na sua humildade</segment>
    <segment id="15">, em princípio ficou um pouco menos humilde.</segment>
    <segment id="16">Trata-</segment>
    <segment id="17">sese de uma virtude traiçoeira e difícil de manter.</segment>
    <segment id="18">É por isso que eu só cultivo defeitos.</segment>
    <segment id="19">É mais seguro.</segment>
    <segment id="20">Ilustração publicada em 25 de dezembro de 2022 - Luiza Pannunzio</segment>
    <segment id="21">O lugar mais vezes escolhido para a divulgação de qualidades é o Instagram.</segment>
    <segment id="22">E não há momento mais propício para a exibição das nossas virtudes do que a morte de outra pessoa.</segment>
    <segment id="23">Sempre que alguém morre</segment>
    <segment id="24">, há usuários do Instagram que não resistem a publicar uma humilde homenagem ao defunto que é</segment>
    <segment id="25">, no fim</segment>
    <segment id="26">, uma fanfarrona homenagem a si mesmos.</segment>
    <segment id="27">Normalmente</segment>
    <segment id="28">, a morte de determinada figura pública causa ao usuário um sofrimento tal que não sabemos</segment>
    <segment id="29">sese a desgraça maior tocou ao falecido ou ao que teve o azar de ficar vivo a testemunhar o desaparecimento do outro.</segment>
    <segment id="30">São mensagens que</segment>
    <segment id="31">, na verdade</segment>
    <segment id="32">, dizem o seguinte: "</segment>
    <segment id="33">Esta figura muito querida de todos</segment>
    <segment id="34">, realmente</segment>
    <segment id="35">, morreu.</segment>
    <segment id="36">Mas creio que é apenas justo que alguma da comiseração que lhe dedicamos agora me seja dirigida.</segment>
    <segment id="37">"</segment>
    <segment id="38">Às vezes</segment>
    <segment id="39">, quem vai sofrer para o Instagram conhecia o finado</segment>
    <segment id="40">, e já vi lamentos deste tipo: "</segment>
    <segment id="41">Recordarei para sempre a última conversa que tivemos</segment>
    <segment id="42">, em que ele me disse o quanto me admirava.</segment>
    <segment id="43">"</segment>
    <segment id="44">Ou: "</segment>
    <segment id="45">Jamais olvidarei o profundo respeito com que ele</segment>
    <segment id="46">sese dirigia a mim.</segment>
    <segment id="47">"</segment>
    <segment id="48">Ou ainda:</segment>
    <segment id="49">"</segment>
    <segment id="50">Perdi um fã.</segment>
    <segment id="51">"  De vez em quando</segment>
    <segment id="52">, no momento da morte de uma pessoa conhecida</segment>
    <segment id="53">, alguém resolve fazer uma piada e gera-</segment>
    <segment id="54">sese uma vasta revolta.</segment>
    <segment id="55">Mas não creio que haja nada mais obsceno do que estas homenagens em que os humildes usam um cadáver</segment>
    <segment id="56">comocomo adereço para embelezar a sua reputação.  Fala-</segment>
    <segment id="57">sese muito em piadas de mau gosto e nada em humildades de mau gosto.</segment>
    <segment id="58">Acho as segundas mais nocivas.</segment>
  </rst>
</analysis>