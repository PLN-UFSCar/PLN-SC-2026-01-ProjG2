  <rst>
    <segment id="1">As últimas pesquisas eleitorais indicam chances de reeleição no 1º turno de governadores em até 13 estados do país.</segment>
    <segment id="2">São eles:</segment>
    <segment id="3">Acre, Distrito Federal</segment>
    <segment id="4">, Espírito Santo</segment>
    <segment id="5">, Goiás</segment>
    <segment id="6">, Maranhão</segment>
    <segment id="7">, Mato Grosso</segment>
    <segment id="8">, Minas Gerais</segment>
    <segment id="9">, Pará</segment>
    <segment id="10">, Paraná</segment>
    <segment id="11">, Rio Grande do Norte</segment>
    <segment id="12">, Rio de Janeiro</segment>
    <segment id="13">, Roraima e Tocantins.</segment>
    <segment id="14">Em alguns</segment>
    <segment id="15">, como</segment>
    <segment id="16">como Pará e Mato Grosso</segment>
    <segment id="17">, os levantamentos indicam que esse cenário é provável</segment>
    <segment id="18">, dada a vantagem dos líderes nas corridas</segment>
    <segment id="19">, segundo as pesquisas.</segment>
    <segment id="20">Em outros casos</segment>
    <segment id="21">, como</segment>
    <segment id="22">como Rio e Maranhão</segment>
    <segment id="23">, porém</segment>
    <segment id="24">porém, a possibilidade é mais difícil.</segment>
    <segment id="25">A Folha reúne abaixo os resultados das mais recentes pesquisas de intenção de voto nas disputas estaduais</segment>
    <segment id="26">, segundo os institutos Datafolha e Ipec</segment>
    <segment id="27">, que divulgou nesta terça (27) nova rodada em SP</segment>
    <segment id="28">, RJ, MG</segment>
    <segment id="29">, DF e PE.</segment>
    <segment id="30">Esta página é atualizada semanalmente e inclui os políticos que atingiram pelo menos 1% nos levantamentos.</segment>
    <segment id="31">São consideradas sempre as perguntas estimuladas</segment>
    <segment id="32">, em que os nomes são lidos aos entrevistados.</segment>
    <segment id="33">Entenda as pesquisas eleitoraisDiferentes</segment>
    <segment id="34">metodologias explicam divergência de resultadosConheça as principais pesquisas e quem as financiaO que é margem de erro</segment>
    <segment id="35">, intervalo de confiança e empate técnicoVídeo explica</segment>
    <segment id="36">comocomo Datafolha faz pesquisas eleitoraisCabine eleitoral em 2010</segment>
    <segment id="37">, na escola João 23</segment>
    <segment id="38">, na Penha</segment>
