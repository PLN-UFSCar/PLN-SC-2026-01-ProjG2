    <segment id="361">, do PT</segment>
    <segment id="362">, que se</segment>
    <segment id="363">se reelegeu em primeiro turno no Rio Grande do Norte.</segment>
    <segment id="364">Se na Câmara houve um crescimento</segment>
    <segment id="365">, ainda que frustrante</segment>
    <segment id="366">, no Senado a gente pode acabar com menos senadoras.</segment>
    <segment id="367">É que além da baixa eleição de mulheres neste ano</segment>
