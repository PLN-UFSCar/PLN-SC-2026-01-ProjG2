    <segment id="403">Ela terminou a disputa</segment>
    <segment id="404">comocomo suplente</segment>
    <segment id="405">, com 76 mil votos.</segment>
    <segment id="406">Essas candidatas cumprem todo o check list do que faz uma mulher ser eleita.</segment>
