    <segment id="472">, potencializar os seus devidos representantes.</segment>
    <segment id="473">Porque eu entendo que o movimento negro precisa de mulheres lá que representem as mulheres negras ou mulheres de periferia</segment>
    <segment id="474">, assim</segment>
    <segment id="475">comocomo mulheres quilombolas e por aí vai</segment>
    <segment id="476">O Vamos Juntas nasceu em 2019 e nas eleições de 2020</segment>
    <segment id="477">, apoiou 51 candidatas.</segment>
    <segment id="478">Onze delas</segment>
