  <rst>
    <segment id="1">São</segment>
    <segment id="2">Roque recebe o São Paulo Wine Fest</segment>
    <segment id="3">, entre 18 e 27 de agosto</segment>
    <segment id="4">, com vinhos nacionais e importados de 12 países.</segment>
    <segment id="5">As atividades acontecem em vinícolas</segment>
    <segment id="6">, clubes</segment>
    <segment id="7">, hotéis</segment>
    <segment id="8">, restaurantes e casa de eventos da cidade.</segment>
    <segment id="9">Os visitantes poderão participar de uma feira de vinhos</segment>
    <segment id="10">, com degustações temáticas</segment>
    <segment id="11">, master classes</segment>
    <segment id="12">, workshops</segment>
    <segment id="13">, palestras e um almoço harmonizado.</segment>
    <segment id="14">Os ingressos variam entre R$ 50 e R$ 429.</segment>
    <segment id="15">São Paulo Wine Fest acontece de 18 a 27 de agosto em São Roque - Divulgação/São Paulo Wine FestA cidade de São Roque</segment>
    <segment id="16">, situada a 60 km de São Paulo</segment>
    <segment id="17">, conta com 18 vinícolas que formam a Roteiro do Vinho.</segment>
    <segment id="18">O local atrai turistas todos os finais de semana interessados em degustar seus produtos.</segment>
    <segment id="19">A programação completa do São Paulo Wine Fest pode ser encontrada no Instagram @saopaulowinefest e os ingressos</segment>
    <segment id="20">, no site Wine Locals.</segment>
    <segment id="21">Veja os vinhos brasileiros premiados com prata no International Wine and Spirits CompetitionMais    novamente         de   de  de  representando um</segment>
