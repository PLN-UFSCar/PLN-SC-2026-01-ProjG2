  <rst>
    <segment id="1">O Dia da Consciência Negra</segment>
    <segment id="2">, comemorado nesta segunda-feira (20)</segment>
    <segment id="3">, não é considerado feriado nacional</segment>
    <segment id="4">, apesar de celebrar o valor e a contribuição da comunidade negra para o Brasil.</segment>
    <segment id="5">Somente os estados de Alagoas</segment>
    <segment id="6">, Amazonas</segment>
    <segment id="7">, Amapá</segment>
    <segment id="8">, Mato Grosso</segment>
    <segment id="9">, Rio de Janeiro e São Paulo e as capitais Goiânia (GO)</segment>
    <segment id="10">, João Pessoa (PB) e Florianópolis (SC) reconhecem a data</segment>
    <segment id="11">comocomo dia de descanso.</segment>
    <segment id="12">Cinco mãos negras levantadas com punho fechado- Catarina Pignato - 11.set.23/FolhapressCalcule o que falta para sua independência financeiraFerramenta exclusiva da Folha permite estimar poupança necessáriaNos estados em que é feriado</segment>
    <segment id="13">, as capitais e demais municípios também têm o dia de descanso do trabalho garantido.</segment>
    <segment id="14">Segundo a Fundação Cultural Palmares</segment>
    <segment id="15">, cerca de 1.260 municípios tem a data decretada</segment>
    <segment id="16">comocomo feriado municipal.</segment>
    <segment id="17">A data foi criada em homenagem a Zumbi dos Palmares</segment>
    <segment id="18">, líder do Quilombo dos Palmares e uma das maiores figuras de resistência negra à escravidão no Brasil</segment>
    <segment id="19">, morto em 20 de novembro de 1695.</segment>
    <segment id="20">No feriado</segment>
    <segment id="21">, profissionais contratados pelo regime da CLT (Consolidação das Leis do Trabalho) não têm expediente</segment>
    <segment id="22">, assim</segment>
    <segment id="23">comocomo servidores públicos.</segment>
    <segment id="24">Mas, nas áreas consideradas essenciais</segment>
    <segment id="25">, a convocação é permitida.</segment>
    <segment id="26">Nos locais onde não é feriado</segment>
    <segment id="27">, não há folga</segment>
    <segment id="28">, e o expediente é normal.</segment>
    <segment id="29">Folha MercadoReceba no seu email o que de mais importante acontece na economia</segment>
    <segment id="30">; aberta para não assinantes.</segment>
    <segment id="31">Carregando...</segment>
    <segment id="32">Para que o dia seja considerado feriado</segment>
    <segment id="33">, é necessário uma lei</segment>
    <segment id="34">, seja municipal</segment>
    <segment id="35">, estadual ou federal para criar um dia de descanso fixo em que é obrigatória a paralisação do trabalho</segment>
    <segment id="36">, como</segment>
    <segment id="37">como previsto no artigo 70 da CLT (Consolidação das Leis do Trabalho).</segment>
    <segment id="38">Atualmente</segment>
    <segment id="39">, o projeto de lei nº 3.268/2021</segment>
    <segment id="40">, do senador Randolfe Rodrigues (sem partido-AP)</segment>
    <segment id="41">, está em tramitação no Congresso Nacional e debate a criação oficial do feriado nacional em celebração à data.</segment>
    <segment id="42">A proposta aguarda votação na Câmara dos Deputados.</segment>
    <segment id="43">Em setembro deste ano</segment>
    <segment id="44">, o governador de São Paulo Tarcísio de Freitas (Republicanos) sancionou projeto que torna o Dia da Consciência</segment>
    <segment id="45">Negra feriado no estado e seus municípios.</segment>
    <segment id="46">Leia TambémGoverno</segment>
    <segment id="47">Lula dificulta trabalho nos feriados no comércio e favorece sindicatos</segment>
    <segment id="48">; setor reageBahia é o estado com maior população quilombola do Brasil</segment>
    <segment id="49">, diz o Censo 2022Escravidão forjou o Brasil</segment>
    <segment id="50">comocomo país do café</segment>
    <segment id="51">, e setor segue excludente 200 anos depoisMercado de trabalho só alcançará igualdade racial em 167 anos</segment>
    <segment id="52">, diz estudoA Febraban (Federação Brasileira de Bancos) informa que agências bancárias não terão atendimento presencial ao público nos estados e municípios em que a data é feriado.</segment>
    <segment id="53">Na terça-feira</segment>
    <segment id="54">, 21 de novembro</segment>
    <segment id="55">, os bancos abrem normalmente nestas localidades.</segment>
    <segment id="56">Nas demais cidades</segment>
    <segment id="57">, o funcionamento será no horário habitual de atendimento.</segment>
    <segment id="58">Contas de luz</segment>
    <segment id="59">, água</segment>
    <segment id="60">, telefone e carnês que tenham vencimento na data do feriado poderão ser pagas no próximo dia útil.</segment>
    <segment id="61">No entanto</segment>
    <segment id="62">, especialistas recomendam checar</segment>
    <segment id="63">sese a data foi realmente alterada no boleto para evitar pagar juros.</segment>
    <segment id="64">Além disso</segment>
    <segment id="65">, é possível agendar a quitação dos boletos ou fazer os pagamentos pela internet</segment>
    <segment id="66">, por meio do aplicativo ou site do banco.</segment>
    <segment id="67">O banco por telefone tem funcionamento normal.</segment>
    <segment id="68">"</segment>
    <segment id="69">Os meios eletrônicos são uma alternativa prática e extremamente segura</segment>
    <segment id="70">, e oferecem praticamente a totalidade das transações financeiras do sistema bancário"</segment>
    <segment id="71">, diz o diretor-adjunto de serviços da Febraban</segment>
    <segment id="72">, Walter Tadeu de Faria.</segment>
    <segment id="73">Veja o que mudou na regra que autoriza trabalho em feriadosMais    novamente         de   de  de  representando um  Quais os direitos dos trabalhadores nos feriados?</segment>
    <segment id="74">Profissionais convocados para trabalhar no feriado devem receber em dobro pelo dia de trabalho</segment>
    <segment id="75">, caso</segment>
    <segment id="76">caso não haja folga compensatória.</segment>
    <segment id="77">O pagamento dos valores</segment>
    <segment id="78">, no entanto</segment>
    <segment id="79">, está condicionado ao que diz a convenção coletiva de trabalho de cada categoria.</segment>
    <segment id="80">A legislação brasileira proíbe o trabalho em feriados nacionais</segment>
    <segment id="81">, masmas há exceções</segment>
    <segment id="82">, conforme as categorias e o tipo de atividade exercida</segment>
    <segment id="83">, sese é essencial ou não.</segment>
    <segment id="84">A hora extra tem cálculo diferente da habitual.</segment>
    <segment id="85">Em dias normais</segment>
    <segment id="86">, ela é de 50% do valor da remuneração.</segment>
    <segment id="87">Nos feriados</segment>
    <segment id="88">, esse pagamento deve ser de 100%.</segment>
    <segment id="89">O artigo 67 da CLT libera o expediente aos domingos e feriados em áreas essenciais</segment>
    <segment id="90">, masmas é necessário haver escala de revezamento.</segment>
    <segment id="91">Há ainda lei específica</segment>
    <segment id="92">, de 2020</segment>
    <segment id="93">, que regulamenta o trabalho no comércio.</segment>
    <segment id="94">Além da folga</segment>
    <segment id="95">, as convenções coletivas e acordos de trabalho podem prever banco de horas e outras compensações.</segment>
    <segment id="96">Com Cristiane Gercina</segment>
  </rst>
</analysis>