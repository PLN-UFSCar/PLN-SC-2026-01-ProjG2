  <rst>
    <segment id="1">Machos</segment>
    <segment id="2">, não se</segment>
    <segment id="3">se enganem: desde que Eva comeu a maçã oferecida pela serpente sabemos o quanto somos tentados por mulheres</segment>
    <segment id="4">, pela Apple e por formas fálicas sinuosas cheias de veneno.</segment>
    <segment id="5">A verdade que não querem que você saiba sobre Galileu Galilei não tem nada a ver com a Terra girando em torno do Sol.</segment>
    <segment id="6">O cientista</segment>
    <segment id="7">, na realidade</segment>
    <segment id="8">, revelou que nosso planeta orbita num movimento falocêntrico.</segment>
    <segment id="9">Ou seja</segment>
    <segment id="10">, meu caro Macho</segment>
    <segment id="11">, a ciência comprova que o seu pau é o Centro do Universo.  Mulheres</segment>
    <segment id="12">, maçãs e serpentes que não quiserem</segment>
    <segment id="13">sese submeter a essa hierarquia não merecem orbitar sua vida.</segment>
    <segment id="14">Observação: estamos calvos e carecas de saber</segment>
    <segment id="15">, masmas não custa lembrar que a expressão "mulher" não contempla nossa mãe.</segment>
    <segment id="16">Esses são os fundamentos religiosos e científicos que sustentam o movimento Blue Pill</segment>
    <segment id="17">, cujo nome homenageia o único remédio que atende aos anseios falocêntricos.</segment>
    <segment id="18">Ilustração de Débora Gonzales para a coluna de Renato Terra de 2.mar.23 - Débora</segment>
    <segment id="19">GonzalesÉ importante</segment>
    <segment id="20">lembrar que essa aversão às mulheres é recíproca.</segment>
    <segment id="21">A gente decidiu não gostar delas a partir do momento em que elas passaram a rejeitar a gente</segment>
    <segment id="22">porque</segment>
    <segment id="23">porque a gente rejeitou elas antes (que fique claro).</segment>
    <segment id="24">Machos e mulheres são</segment>
    <segment id="25">comocomo água e azeite extra virgem.</segment>
    <segment id="26">Ou como</segment>
    <segment id="27">como Campari e cerveja.</segment>
    <segment id="28">Pra não esquecer: a expressão "mulher" não contempla nossa mãe (aliás: mãe</segment>
    <segment id="29">, sese você estiver lendo esta coluna</segment>
    <segment id="30">, não esquece de dobrar as minhas meias daquele jeito que eu gosto).</segment>
    <segment id="31">Acossados por um mundo cada vez mais brutal</segment>
    <segment id="32">, lacrador e feminista</segment>
    <segment id="33">, os Machos foram obrigados a criar uma rede de apoio.</segment>
    <segment id="34">Primeiro</segment>
    <segment id="35">, num esforço hercúleo de sobrevivência</segment>
    <segment id="36">, desenvolvemos técnicas de reprodução solo.</segment>
    <segment id="37">Ainda não conseguimos lograr êxito na autorreprodução desassistida</segment>
    <segment id="38">, masmas a prática manual tem demonstrado alinhamento ideológico com os princípios de prazer falocêntrico.</segment>
    <segment id="39">Como diz Simão do Mafuá:</segment>
    <segment id="40">"</segment>
    <segment id="41">Não se</segment>
    <segment id="42">se nasce macho</segment>
    <segment id="43">, torna-</segment>
    <segment id="44">sese um".</segment>
    <segment id="45">Num mundo em que homens querem</segment>
    <segment id="46">sese transformar em mulheres</segment>
    <segment id="47">, não binários querem</segment>
    <segment id="48">sese transformar em lagartas e lagartas querem</segment>
    <segment id="49">sese transformar em borboleta</segment>
    <segment id="50">, fizemos nossa opção: o Macho quer transformar homens em moleques.</segment>
    <segment id="51">É como</segment>
    <segment id="52">como tomar uma pílula de pirulito que nos faz ver o mundo pelos olhos do Quico.</segment>
    <segment id="53">Esse ser mitológico</segment>
    <segment id="54">, verdadeiro Tesouro que nunca</segment>
    <segment id="55">sese mistura com a gentalha.</segment>
    <segment id="56">Um mártir que conquistou</segment>
    <segment id="57">, com mérito e esforço</segment>
    <segment id="58">, um lugar de empoderamento.</segment>
    <segment id="59">Sua influência colossal é capaz de mover legiões em busca do desejo genuíno de conquistar uma bola quadrada.</segment>
    <segment id="60">A expressão "bola quadrada"</segment>
    <segment id="61">, claro</segment>
    <segment id="62">, é usada aqui no sentido figurado.</segment>
    <segment id="63">Nós, os Machos</segment>
    <segment id="64">, gostamos de usar o sentido figurado.</segment>
  </rst>
