  </header>
  <rst>
    <segment id="1">Sempre fui um curioso e um entusiasta de práticas de fé.</segment>
    <segment id="2">Minha mãe nunca foi carola</segment>
    <segment id="3">, nunca tive um chamamento divino e muito menos me sinto um pecador de vidas passadas para ter a necessidade de procurar "gzus" para redimir minhas derrapadas pretéritas.</segment>
    <segment id="4">Simplesmente é uma questão e uma vontade bem humanas.</segment>
    <segment id="5">Na pré-adolescência</segment>
    <segment id="6">, adotei práticas orientais de reza longuíssimas</segment>
    <segment id="7">, com queima de incensos</segment>
    <segment id="8">, tilintar de sinos</segment>
    <segment id="9">, era lindo e terapêutico</segment>
    <segment id="10">, masmas meus irmãos chiavam bastante pela fumaça e pela "ladainha" que bloqueava o quarto de dormir por muito tempo.</segment>
    <segment id="11">Em outro momento</segment>
    <segment id="12">, ia à missa aos domingos e sabia até cantar "Hosana</segment>
    <segment id="13">, Hosana nas alturas".</segment>
    <segment id="14">Frequentei sessões mediúnicas e senti um enorme engrandecimento.</segment>
    <segment id="15">Já fui a cultos evangélicos e não tentaram me levantar da cadeira de rodas</segment>
    <segment id="16">, ufa!</segment>
    <segment id="17">Fiéis acendem velas e fazem orações na Basílica de Nossa Senhora Aparecida</segment>
    <segment id="18">, no interior de SP - Rubens Cavallari/FolhapressPratico meditação com uma pegada mais espiritual também</segment>
    <segment id="19">, embora</segment>
    <segment id="20">embora o guru tenha uma tendência forte em tratar de finanças para o equilíbrio terreno.</segment>
    <segment id="21">Por fim</segment>
    <segment id="22">, tenho mergulhado nas práticas da umbanda e achado divino e maravilhoso.</segment>
    <segment id="23">No terreiro</segment>
    <segment id="24">, assim</segment>
    <segment id="25">comocomo nos demais templos</segment>
    <segment id="26">, porém</segment>
    <segment id="27">porém, a minha sensação é que o diverso é sempre o "atendido"</segment>
    <segment id="28">, o vitimizado</segment>
    <segment id="29">, o espectador das manifestações religiosas.</segment>
    <segment id="30">O diferente nunca é –ou é</segment>
    <segment id="31">, excepcionalmente— o mensageiro</segment>
    <segment id="32">, o padre</segment>
    <segment id="33">, o xamã</segment>
    <segment id="34">, o líder espiritual</segment>
    <segment id="35">, o pai ou mãe de santo.</segment>
    <segment id="36">Sinto um certo descolamento da fé com os legítimos anseios da plenitude de existir.</segment>
    <segment id="37">Os pastores mirins são bem mais comuns que os "malacabados".</segment>
    <segment id="38">Quantos são os padres negros</segment>
    <segment id="39">, mesmo?</segment>
    <segment id="40">E sese um cadeirante tiver a vocação de incorporar Ogum</segment>
    <segment id="41">, como</segment>
    <segment id="42">como será com aqueles degraus do terreiro?</segment>
    <segment id="43">As mulheres líderes de fé ainda são minguadas</segment>
    <segment id="44">, monja Coen nada de braçada.</segment>
    <segment id="45">Também sinto</segment>
    <segment id="46">, nas casas de oração</segment>
    <segment id="47">, de qualquer profissão de fé</segment>
    <segment id="48">, uma falta de um ponto de atenção àqueles cujo interesse por uma crença não está em nada ligado a sua condição.</segment>
    <segment id="49">Não quero ser salvo da minha deficiência</segment>
    <segment id="50">, masmas quero condições de ir aos templos</segment>
    <segment id="51">, pessoas LGBTQIAP+ não estão atrás da cura gay</segment>
    <segment id="52">, masmas querem ter o amplo direito às práticas religiosas.</segment>
    <segment id="53">E dá para enfileirar os outros grupos todos na toada.</segment>
    <segment id="54">Veja templos religiosos</segment>
    <segment id="55">Mais    novamente         de   de  de  representando um</segment>
    <segment id="56">O nosso tempo clama por reconhecimento de questões que</segment>
    <segment id="57">sese somam à pobreza</segment>
    <segment id="58">, à violência</segment>
    <segment id="59">, aos abandonos</segment>
    <segment id="60">, à doença ao sofrimento emocional e ao desalento.</segment>
    <segment id="61">Olhares menos estigmatizados para o que diverge do todo e mais caloroso para as aflições de querer</segment>
    <segment id="62">sese manifestar</segment>
    <segment id="63">comocomo qualquer outro vivente pode ser de muita luz.</segment>
    <segment id="64">A "bênção gay"</segment>
    <segment id="65">, autorizada pelo papa Francisco</segment>
    <segment id="66">, na Igreja Católica</segment>
    <segment id="67">, pode até ter ares de mudança diante de princípios milenares que precisam de amadurecimento histórico e tals</segment>
    <segment id="68">, masmas é uma migalha de deixar a hóstia envergonhada.</segment>
    <segment id="69">Aceita-</segment>
    <segment id="70">sese até você ter lá suas questões de gênero</segment>
    <segment id="71">, masmas as manifestações dela precisam ser bem regradas.</segment>
    <segment id="72">São nos palcos da fé que a gente gostaria de presenciar a inclusão pura e simples</segment>
    <segment id="73">, por ser humana</segment>
    <segment id="74">, ser justa e ser genuinamente de Deus.</segment>
    <segment id="75">Sem leis</segment>
    <segment id="76">, sem regras</segment>
    <segment id="77">, sem prioridades</segment>
    <segment id="78">, sem alguém avisar</segment>
    <segment id="79">, sem alguém mandar</segment>
    <segment id="80">, sem papa dizer que é certo ou errado</segment>
    <segment id="81">, sem haver autorização.</segment>
    <segment id="82">Só ser.</segment>
    <segment id="83">Só vir.</segment>
    <segment id="84">Só sermos.</segment>
    <segment id="85">Só estarmos.</segment>
    <segment id="86">Boas festas!</segment>
  </rst>
</analysis>