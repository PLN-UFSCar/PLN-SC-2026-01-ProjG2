  <rst>
    <segment id="1">A morte aos 92 anos de Mario Jorge Lobo Zagallo</segment>
    <segment id="2">, figura marcante</segment>
    <segment id="3">comocomo jogador e treinador da seleção brasileira</segment>
    <segment id="4">, teve forte repercussão entre atletas</segment>
    <segment id="5">, ex-atletas e autoridades.</segment>
    <segment id="6">Figura icônica no futebol mundial</segment>
    <segment id="7">, o tetracampeão mundial estava internado havia alguns dias em um hospital do Rio de Janeiro.</segment>
    <segment id="8">Veja a seguir algumas das reações.</segment>
    <segment id="9">Zagallo na final da Copa do Mundo de 1998</segment>
    <segment id="10">, quando o Brasil perdeu de 3 a 0 para a França</segment>
    <segment id="11">- AFP     Zagallo foi um dos maioresjogadores e técnicos de futebol de todos os tempos</segment>
    <segment id="12">, um grande vencedor e símbolo de amor pela seleção brasileira e pelo Brasil.</segment>
    <segment id="13">Corajoso</segment>
    <segment id="14">, dedicado</segment>
    <segment id="15">, apaixonado e superticioso</segment>
    <segment id="16">, era exemplo de brasileiro que não desistia nunca.</segment>
    <segment id="17">É essa lição e espírito de carinho</segment>
    <segment id="18">, amor</segment>
    <segment id="19">, dedicação e superação que ele deixa para todo o nosso país e para o futebol mundial.</segment>
    <segment id="20">Nesse momento de despedida</segment>
    <segment id="21">, minha solidariedade aos familiares</segment>
    <segment id="22">, seus filhos e netos</segment>
    <segment id="23">, aos amigos e aos milhões de admiradores.</segment>
    <segment id="24">Luiz Inácio Lula da SilvaPresidente do BrasilQue Deus</segment>
    <segment id="25">, em sua infinita bondade</segment>
    <segment id="26">, o acolha em seus braços e conforte seus familiares</segment>
    <segment id="27">, amigos e admiradores.</segment>
    <segment id="28">Jair BolsonaroEx-presidente do BrasilTristeza imensa com a notícia do falecimento de Zagallo.</segment>
    <segment id="29">Deus nos dá um tempo por aqui e devemos aproveitá-lo ao máximo.</segment>
    <segment id="30">Assim foi Zagallo que deixa um grande legado de realizações e uma legião de fãs e amigos.</segment>
    <segment id="31">Sentimentos à família.</segment>
    <segment id="32">Descanse em paz</segment>
    <segment id="33">, meu querido amigo!Evaristo de MacedoEx-treinador brasileiroO futebol chora com a perda do nosso @zagallooficial.</segment>
    <segment id="34">Muito obrigado por tudo que o senhor fez por mim e pelo futebol</segment>
    <segment id="35">, não só brasileiro</segment>
    <segment id="36">, masmas sim mundial.</segment>
    <segment id="37">Descanse em Paz</segment>
    <segment id="38">, MESTRE.Roberto CarlosEx-jogador da seleção</segment>
    <segment id="39">brasileiraUma lenda do nosso futebol partiu hoje.</segment>
    <segment id="40">Obrigado por tudo!</segment>
    <segment id="41">Descanse em paz</segment>
    <segment id="42">, ZagalloCasemirovolante da seleçãoDescanse em paz</segment>
    <segment id="43">, Zagallo!</segment>
    <segment id="44">E obrigado por tudo que fez pelo futebol brasileiro!</segment>
    <segment id="45">Que Deus conforte todos seus familiares e amigos!Éder MilitãoJogador da seleçãoO futebol brasileiro está de luto mais uma vez.</segment>
    <segment id="46">Depois de Pelé</segment>
    <segment id="47">, lamentamos agora a morte de Mário Jorge Lobo Zagallo.</segment>
    <segment id="48">O Velho Lobo.</segment>
    <segment id="49">92 anos.</segment>
    <segment id="50">Uma lenda.</segment>
    <segment id="51">Único tetracampeão mundial - e por pouco não foi penta.</segment>
    <segment id="52">Alguém que será sempre lembrado por valorizar o patriotismo e também por sua superstição inconfundível.</segment>
    <segment id="53">Minhas orações e meus sentimentos aos familiares.</segment>
    <segment id="54">Tarcísio de FreitasGovernador de São PauloNos despedimos de uma lenda do futebol.</segment>
    <segment id="55">Zagallo escreveu seu nome na história</segment>
    <segment id="56">comocomo o único tetracampeão do mundo</segment>
    <segment id="57">, conquistado com a Seleção Brasileira.</segment>
    <segment id="58">E também esteve em campo</segment>
    <segment id="59">, ao lado de Pelé e Garrincha</segment>
    <segment id="60">, na vitória do nosso primeiro mundial.</segment>
    <segment id="61">Ídolo de dois times cariocas</segment>
    <segment id="62">, Flamengo e Botafogo</segment>
    <segment id="63">, e maior vencedor de Copas do Mundo</segment>
    <segment id="64">, o Velho Lobo nos deixa um legado marcante que passará por todas as gerações.</segment>
    <segment id="65">Meus sentimentos aos familiares</segment>
    <segment id="66">, amigos e admiradores do Zagallo.</segment>
    <segment id="67">Descanse em paz</segment>
    <segment id="68">, gigante!</segment>
    <segment id="69">Cláudio CastroGovernador do Estado do Rio de JaneiroIsto é ZagalloMais    novamente         de   de  de  representando um</segment>
