  <rst>
    <segment id="1">Em participação no podcast "</segment>
    <segment id="2">Quem Pode</segment>
    <segment id="3">, Pod"</segment>
    <segment id="4">, a cantora Iza disse ser demissexual.</segment>
    <segment id="5">A orientação sexual</segment>
    <segment id="6">, pouco conhecida</segment>
    <segment id="7">, consiste em</segment>
    <segment id="8">sese relacionar sexualmente somente com quem tem conexões emocionais.</segment>
    <segment id="9">"</segment>
    <segment id="10">Eu demoro muito para querer transar com alguém.</segment>
    <segment id="11">Acho que só</segment>
    <segment id="12">sese tiver alguma conexão com a pessoa.</segment>
    <segment id="13">Transei uma vez e fiquei 'meu Deus</segment>
    <segment id="14">, fui violada</segment>
    <segment id="15">, invadida'</segment>
    <segment id="16">, com aquela sensação de ‘</segment>
    <segment id="17">porque</segment>
    <segment id="18">porque fiz isso?</segment>
    <segment id="19">’.</segment>
    <segment id="20">Demorei para entender que não tinha nada a ver com o boy</segment>
    <segment id="21">, masmas comigo"</segment>
    <segment id="22">, afirmou a cantora.</segment>
    <segment id="23">Demissexuais</segment>
    <segment id="24">comocomo Iza estão dentro do espectro da assexualidade</segment>
    <segment id="25">(o "</segment>
    <segment id="26">A" da sigla LGBTQIA+).</segment>
    <segment id="27">Isso indica a falta de atração sexual parcial</segment>
    <segment id="28">, condicional ou total por outras pessoas – e apesar de não ter vontade de fazer sexo</segment>
    <segment id="29">, não há nada que impeça a pessoa de ter relações</segment>
    <segment id="30">, sentir prazer ou ter libido</segment>
    <segment id="31">, por exemplo.</segment>
    <segment id="32">No caso</segment>
    <segment id="33">caso dos demissexuais</segment>
    <segment id="34">, a situação é condicionante:</segment>
    <segment id="35">casocaso estabeleça um vínculo afetivo forte com outra pessoa</segment>
    <segment id="36">, sente atração física e</segment>
    <segment id="37">sese relaciona sexualmente</segment>
    <segment id="38">, afirma a sexóloga Priscila Junqueira.</segment>
    <segment id="39">A cantora Iza - Instagram/IZAA profissional reforça que essa falta de atração não deve ser confundida com ausência de desejo.</segment>
    <segment id="40">"</segment>
    <segment id="41">Quando é disfunção</segment>
    <segment id="42">, desejo hipoativo</segment>
    <segment id="43">, que acomete tanto homens quanto mulheres</segment>
    <segment id="44">, precisa ser olhado e cuidado.</segment>
    <segment id="45">Na assexualidade simplesmente não tem essa atração sexual pelo outro</segment>
    <segment id="46">, e a demissexualidade está dentro do espectro.</segment>
    <segment id="47">Vai ter atração sexual sim</segment>
    <segment id="48">, masmas por alguém que esteja envolvida emocionalmente"</segment>
    <segment id="49">, diz Junqueira.</segment>
    <segment id="50">Existem outras subcategorias de assexualidade</segment>
    <segment id="51">, como</segment>
    <segment id="52">como o arromântico</segment>
    <segment id="53">, que não sente atração sexual nem romântica</segment>
    <segment id="54">;</segment>
    <segment id="55">o demirromântico</segment>
    <segment id="56">, que sente atração afetiva só com fortes laços emocionais</segment>
    <segment id="57">; o romântico</segment>
    <segment id="58">, que pode sentir atração romântica e pode ser homossexual</segment>
    <segment id="59">, heterossexual ou pansexual</segment>
    <segment id="60">; e, por fim</segment>
    <segment id="61">, a menos conhecida</segment>
    <segment id="62">, a gray-a</segment>
    <segment id="63">, que sente atração sexual ocasional</segment>
    <segment id="64">, masmas não precisa de vínculo forte.  Imagens da cantora IzaMais    novamente         de   de  de  representando um  Psicóloga há 20 anos e co-fundadora do Ipser (Instituto de Psicologia e Sexologia Essência Rara)</segment>
    <segment id="65">, Junqueira afirma que todas essas categorias ajudam as pessoas a entenderem melhor quem verdadeiramente fato.</segment>
    <segment id="66">"</segment>
    <segment id="67">O que acontece é que as pessoas não conseguem nem nomear e ficam</segment>
    <segment id="68">sese sentindo fora de um grupo</segment>
    <segment id="69">, sem se</segment>
    <segment id="70">se entender sem</segment>
    <segment id="71">sese conhecer"</segment>
    <segment id="72">, afirma a sexóloga.</segment>
    <segment id="73">A consequência é que uma condição normal acaba gerando ansiedade e preocupação.</segment>
    <segment id="74">"</segment>
    <segment id="75">Isso nos leva de novo à necessidade de falar da sexualidade</segment>
    <segment id="76">, de ter uma educação em sexualidade.</segment>
    <segment id="77">Porque com esse conhecimento</segment>
    <segment id="78">, já se</segment>
    <segment id="79">se consegue ter essa nomeação e a pessoa pode</segment>
    <segment id="80">sese apropriar daquilo que é parte da sua identidade</segment>
    <segment id="81">, sese aceitar"</segment>
    <segment id="82">, declara.</segment>
    <segment id="83">A produtora de eventos Jeanine Adler</segment>
    <segment id="84">, 27, levava na brincadeira a falta de atração por outras pessoas</segment>
    <segment id="85">, até que</segment>
    <segment id="86">sese identificou com a definição de demissexual que viu em um blog.  "</segment>
    <segment id="87">O vínculo do demissexual não é necessariamente gostar.</segment>
    <segment id="88">Pode ser afetivo</segment>
    <segment id="89">, romântico</segment>
    <segment id="90">, intelectual</segment>
    <segment id="91">, já vi acontecer.</segment>
    <segment id="92">Para mim</segment>
    <segment id="93">, tem que ser muito forte para gerar atração.</segment>
    <segment id="94">Namorei quatro pessoas e senti com apenas uma"</segment>
    <segment id="95">, afirma.</segment>
    <segment id="96">Adler chegou a pensar que havia algo errado com ela</segment>
    <segment id="97">, masmas a identificação de demissexualidade tirou um peso de suas costas.</segment>
    <segment id="98">"</segment>
    <segment id="99">Já tinha sofrido muito sem saber o que era</segment>
    <segment id="100">, me senti aliviada</segment>
    <segment id="101">, me senti mais confortável e totalmente validada"</segment>
    <segment id="102">, conta a produtora.</segment>
  </rst>
</analysis>