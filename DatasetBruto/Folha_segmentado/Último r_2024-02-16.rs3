  <rst>
    <segment id="1">Maior ou menor</segment>
    <segment id="2">, qualquer que seja o tamanho da adesão ao ato convocado para o próximo dia 25 por Jair Bolsonaro</segment>
    <segment id="3">, a foto estará garantida.</segment>
    <segment id="4">Basta que</segment>
    <segment id="5">sese reduza ou</segment>
    <segment id="6">sese amplie o foco da lente</segment>
    <segment id="7">, lá será visto um amontoado de pessoas prestando apoio ao ex-presidente.</segment>
    <segment id="8">Perfeito para efeito de postagens e reportagens.</segment>
    <segment id="9">Mas e daí?</segment>
    <segment id="10">É a pergunta que</segment>
    <segment id="11">sese impõe.</segment>
    <segment id="12">Isso partindo-</segment>
    <segment id="13">sese do pressuposto de que a manifestação será mantida</segment>
    <segment id="14">, sese daqui até lá os fatos e/ou as contas de chegar sobre custos e benefícios não aconselharem a um recuo.</segment>
    <segment id="15">Ato de apoiadores do então presidente Jair Bolsonaro no dia de comemoração da Independência do Brasil</segment>
    <segment id="16">, na avenida Paulista</segment>
    <segment id="17">, em 2022 - Mathilde Missioneiro - 15.set.22/Folhapress - FolhapressSeria um alívio para políticos que já confirmaram presença apenas</segment>
    <segment id="18">porque</segment>
    <segment id="19">porque não poderiam recusar de pronto o convite sem sinalizar oneroso rompimento.</segment>
    <segment id="20">Caso do governador de São Paulo</segment>
    <segment id="21">, Tarcísio de Freitas (Republicanos)</segment>
    <segment id="22">, quando lhe apresentaram a saia justa para vestir e de outros que ainda hesitam em aderir.</segment>
    <segment id="23">Se confirmado o ato</segment>
    <segment id="24">, voltamos à questão da fotografia e sua serventia ante a grave materialidade dos enroscos legais enfrentados por Bolsonaro.</segment>
    <segment id="25">Ele constrangerá meia dúzia de aliados de projeção</segment>
    <segment id="26">, reunirá</segment>
    <segment id="27">sabe-se</segment>
    <segment id="28">se lá quantos apoiadores (vamos que sejam milhares) na avenida Paulista</segment>
    <segment id="29">, dormirá feliz naquele domingo</segment>
    <segment id="30">, masmas na segunda-feira acordará ainda enredado na teia de investigações.</segment>
    <segment id="31">Valente quando no exercício da Presidência</segment>
    <segment id="32">, na posse da estrutura e da imunidade temporária inerentes ao cargo</segment>
    <segment id="33">, subia em carros de som para distribuir ofensas a pessoas e pregar contra as instituições.</segment>
    <segment id="34">Agora acuado</segment>
    <segment id="35">, pede que não</segment>
    <segment id="36">sese fale mal de ninguém</segment>
    <segment id="37">, que não</segment>
    <segment id="38">sese faça nada além de lhe prestar solidariedade e reverência.</segment>
    <segment id="39">É o último refúgio.</segment>
    <segment id="40">Nem diria recurso</segment>
    <segment id="41">, porque</segment>
    <segment id="42">porque não é crível que o ministro Alexandre de Moraes e a Polícia Federal</segment>
    <segment id="43">sese deixem emocionar ou intimidar</segment>
    <segment id="44">, seja qual for a quantidade de gente disposta a protestar contra uma alegada "perseguição política".</segment>
    <segment id="45">O único efeito concreto que o ex-presidente pode obter é piorar sua situação</segment>
    <segment id="46">sese não resistir à tentação de dar tiros no pé.</segment>
  </rst>
</analysis>