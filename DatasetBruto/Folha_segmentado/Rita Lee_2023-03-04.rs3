  <rst>
    <segment id="1">Rita Lee recebeu alta hospitalar e está em casa.</segment>
    <segment id="2">A informação foi divulgada por Roberto de Carvalho</segment>
    <segment id="3">, músico e marido da cantora</segment>
    <segment id="4">, que publicou nas redes sociais uma foto da artista neste sábado.</segment>
    <segment id="5">A cantora Rita Lee em casa</segment>
    <segment id="6">, na primeira foto depois de ser internada no Hospital Israelita Albert Einstein - Roberto de CarvalhoO registro é o primeiro de Rita Lee depois de sua internação no Hospital Israelita Albert Einstein</segment>
    <segment id="7">, em São Paulo</segment>
    <segment id="8">, onde estava desde a noite do dia 23 de fevereiro para o tratamento de complicações decorrentes de um câncer no pulmão.</segment>
    <segment id="9">Além de Roberto</segment>
    <segment id="10">, João Lee</segment>
    <segment id="11">, filho do casal</segment>
    <segment id="12">, compartilhou a publicação com empolgação de ver a mãe melhor.</segment>
    <segment id="13">"</segment>
    <segment id="14">Bem-vinda em casa"</segment>
    <segment id="15">, escreveu em língua inglesa.</segment>
    <segment id="16">Veja imagens de Rita Lee desde que descobriu tumor no pulmãoMais    novamente         de   de  de  representando um  No último sábado (25)</segment>
    <segment id="17">, Roberto escreveu nas redes sociais que a internação era parte do processo de recuperação da doença da cantora de 75 anos</segment>
    <segment id="18">, que recebeu o diagnóstico no ano retrasado.</segment>
    <segment id="19">Segundo o músico</segment>
    <segment id="20">, ela estava bem e "</segment>
    <segment id="21">sese fortalecendo"</segment>
    <segment id="22">, ciente de que a passagem pelo hospital fazia parte de exames de monitoramento e terapia.</segment>
    <segment id="23">No dia 1° de março</segment>
    <segment id="24">, João Lee mostrou Rita Lee tomando sorvete em postagem no seu perfil no Instagram</segment>
    <segment id="25">, voltando a garantir que ela estava bem.</segment>
  </rst>
