  <rst>
    <segment id="1">A senadora eleita Damares Alves (Republicanos-DF) diz que desistiu de ser candidata à presidência da Casa.</segment>
    <segment id="2">A primeira-dama Michelle Bolsonaro com a senadora eleita Damares Alves (Republicanos-DF) - Zanone Fraissat/Folhapress"Eu falei sobre isso de uma forma descontraída com jornalistas</segment>
    <segment id="3">, e soou</segment>
    <segment id="4">comocomo uma coisa séria.</segment>
    <segment id="5">Eu só faria algum movimento</segment>
    <segment id="6">sese o meu presidente [Bolsonaro] autorizasse.</segment>
    <segment id="7">Com o presidente Lula eleito</segment>
    <segment id="8">, nós de oposição não teremos força para isso"</segment>
    <segment id="9">, diz.</segment>
    <segment id="10">Ex-ministra dos Direitos Humanos</segment>
    <segment id="11">, Damares Alves promete oposição "técnica e independente" contra o petista</segment>
    <segment id="12">, sem fazer radicalismo.</segment>
    <segment id="13">"</segment>
    <segment id="14">Serei oposição</segment>
    <segment id="15">, masmas não</segment>
    <segment id="16">comocomo a deles</segment>
    <segment id="17">, oposição pela oposição.</segment>
    <segment id="18">Eles são cruéis</segment>
    <segment id="19">, vis"</segment>
    <segment id="20">, afirma.</segment>
    <segment id="21">Damares diz que seu mandato será pautado pela proteção da infância e dos povos tradicionais</segment>
    <segment id="22">, além da atualização do Código Penal.</segment>
    <segment id="23">Também</segment>
    <segment id="24">sese dedicará à fiscalização das ações de Luiz Inácio Lula da Silva.</segment>
    <segment id="25">"</segment>
    <segment id="26">Não vou me omitir</segment>
    <segment id="27">sese vir irregularidades no lado de lá.</segment>
    <segment id="28">Não vou me acovardar.</segment>
    <segment id="29">Serei firme na fiscalização do Orçamento"</segment>
    <segment id="30">, afirma.</segment>
    <segment id="31">A senadora eleita diz que acompanhou a apuração ao lado de Michelle Bolsonaro e que ela aceitou a derrota do marido "em paz".</segment>
    <segment id="32">"</segment>
    <segment id="33">Acreditamos que Deus está sempre no controle de tudo"</segment>
    <segment id="34">, diz.</segment>
    <segment id="35">A primeira-dama deverá seguir fazendo trabalho social após o fim do governo</segment>
    <segment id="36">, diz a ex-ministra.</segment>
    <segment id="37">"</segment>
    <segment id="38">Michelle tem uma cosmovisão</segment>
    <segment id="39">, é mais preparada do que vocês possam imaginar"</segment>
    <segment id="40">, afirma.</segment>
  </rst>
