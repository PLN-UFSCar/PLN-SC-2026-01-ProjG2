  <rst>
    <segment id="1">Na banda Restart</segment>
    <segment id="2">, todo mundo diz ser heterossexual.</segment>
    <segment id="3">Mas isso não impediu que Pe Lu</segment>
    <segment id="4">, Pe Lanza</segment>
    <segment id="5">, Koba e Thomas fossem alvo de ataques homofóbicos.</segment>
    <segment id="6">Os músicos Pedro Lanza</segment>
    <segment id="7">, Pedro Lucas</segment>
    <segment id="8">, Koba e Thomas</segment>
    <segment id="9">, da banda Restart - Bruno Santos/ Folhapress  Conhecida por suas roupas coloridas</segment>
    <segment id="10">, justas e suas franjas alisadas e compridas</segment>
    <segment id="11">, a banda era feita de chacota.</segment>
    <segment id="12">Seu visual excêntrico era motivo de piadas preconceituosas</segment>
    <segment id="13">, e a sexualidade dos integrantes</segment>
    <segment id="14">, sempre posta em dúvida.</segment>
    <segment id="15">Leia maisComo será o retorno do grupo Restart</segment>
    <segment id="16">, que recupera roupas coloridas em turnê  "</segment>
    <segment id="17">As pessoas achavam que estavam desmerecendo nosso trabalho [com essas piadas].</segment>
    <segment id="18">Criamos empatia e compreensão pela luta</segment>
    <segment id="19">porque</segment>
    <segment id="20">porque tínhamos muitos fãs da comunidade LGBTQIA+"</segment>
    <segment id="21">, afirma Pe Lu.</segment>
    <segment id="22">Veja como</segment>
    <segment id="23">como eram e</segment>
    <segment id="24">comocomo estão os membros da banda RestartMais    novamente         de   de  de  representando um</segment>
    <segment id="25">A banda vai voltar à ativa depois de oito anos de hiato.</segment>
    <segment id="26">Febre entre os adolescentes no início dos anos 2010</segment>
    <segment id="27">, o grupo de rock "good vibes</segment>
    <segment id="28">"</segment>
    <segment id="29">fará uma turnê de despedida em comemoração dos 15 anos de sua criação.</segment>
