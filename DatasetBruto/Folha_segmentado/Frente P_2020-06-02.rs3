  <rst>
    <segment id="1">A Frente Povo</segment>
    <segment id="2">Sem Medo</segment>
    <segment id="3">, formada por movimentos sociais</segment>
    <segment id="4">comocomo o MTST (Movimento dos Trabalhadores Sem Teto) e a UNE (União Nacional dos estudantes) também está convocando as pessoas para um ato no domingo (7)</segment>
    <segment id="5">, na avenida Paulista.</segment>
    <segment id="6">O evento foi definido</segment>
    <segment id="7">comocomo um protesto antifascista e antirracista e em defesa da democracia.</segment>
    <segment id="8">Manifestante levanta o punho durante ato contra o presidente Jair Bolsonaro realizado na avenida Paulista</segment>
    <segment id="9">, em São Paulo</segment>
    <segment id="10">, durante a pandemia da Covid-19 - Mathilde Missioneiro - 31.mai.2020/Folhapress</segment>
    <segment id="11">Os organizadores dizem que vão montar uma brigada de saúde</segment>
    <segment id="12">, com álcool</segment>
    <segment id="13">, distribuição de máscaras e orientações</segment>
    <segment id="14">para que</segment>
    <segment id="15">para que o distanciamento social seja mantido.</segment>
    <segment id="16">Segundo eles</segment>
    <segment id="17">, é possível seguir regras</segment>
    <segment id="18">, como</segment>
    <segment id="19">como já ocorre em protestos em outros países.</segment>
    <segment id="20">O ponto de encontro será o vão do Masp.</segment>
    <segment id="21">No Facebook</segment>
    <segment id="22">, 45 mil pessoas já confirmaram presença ou mostraram interesse no evento.</segment>
  </rst>
