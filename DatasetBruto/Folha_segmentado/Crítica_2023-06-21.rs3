  <rst>
    <segment id="1">ElementosOnde Estreia nesta quinta (22) nos cinemasClassificação LivreProdução Estados Unidos</segment>
    <segment id="2">, 2023Direção Peter Sohn</segment>
    <segment id="3">Boas alegorias são inesperadas e surpreendem o público.</segment>
    <segment id="4">A Pixar mantém um bom histórico nesse departamento</segment>
    <segment id="5">, masmas ganhou fama pelas morais mais próximas das premissas.</segment>
    <segment id="6">Casos como</segment>
    <segment id="7">como as emoções de "Divertida Mente"</segment>
    <segment id="8">, de 2015</segment>
    <segment id="9">, e as almas de "Soul"</segment>
    <segment id="10">, de 2020</segment>
    <segment id="11">, mostram que isso não é ruim.</segment>
    <segment id="12">"Elementos"</segment>
    <segment id="13">, novo filme do estúdio</segment>
    <segment id="14">, promete repetir isso</segment>
    <segment id="15">, principalmente por fazer dos elementos naturais os protagonistas da vez.</segment>
    <segment id="16">Se o estúdio contou histórias sobre emoções e almas humanas</segment>
    <segment id="17">, pensa o público</segment>
    <segment id="18">, o mesmo é possível com o fogo</segment>
    <segment id="19">, a água</segment>
    <segment id="20">, a terra e o ar.</segment>
    <segment id="21">Mas a alegoria</segment>
    <segment id="22">, desta vez</segment>
    <segment id="23">, é mais complexa.</segment>
    <segment id="24">Cena de &amp;#039</segment>
    <segment id="25">;Elementos&amp;#039</segment>
    <segment id="26">;</segment>
    <segment id="27">, da Pixar - DivulgaçãoO filme não esconde que é uma alegoria sobre imigração.</segment>
    <segment id="28">Começa com um casal de personagens feitos de fogo em um barco</segment>
    <segment id="29">, que navega entre as brumas para chegar ao cais do que logo</segment>
    <segment id="30">sese revela uma metrópole.</segment>
    <segment id="31">A cena encanta pelos seres criados de outros elementos e o universo onde coexistem</segment>
    <segment id="32">, masmas a recepção aos recém-chegados</segment>
    <segment id="33">, em si</segment>
    <segment id="34">, é cruel.</segment>
    <segment id="35">Todos ao redor ignoram o casal</segment>
    <segment id="36">, e o simples ato de encontrar um lar vira um desafio.</segment>
    <segment id="37">Ninguém quer um inquilino que pode provocar um incêndio</segment>
    <segment id="38">, quanto mais três —já que a mulher está grávida.</segment>
    <segment id="39">Os dois</segment>
    <segment id="40">, então</segment>
    <segment id="41">, sese estabelecem em um prédio abandonado</segment>
    <segment id="42">, localizado em uma região menos nobre.</segment>
    <segment id="43">O marido reforma o lugar</segment>
    <segment id="44">, a filha nasce</segment>
    <segment id="45">, a família abre uma loja.</segment>
    <segment id="46">O tempo passa e vemos uma comunidade nascer.</segment>
    <segment id="47">A trama dá protagonismo a esses herdeiros.</segment>
    <segment id="48">A filha</segment>
    <segment id="49">, agora adulta e chamada Faísca</segment>
    <segment id="50">, ajuda o pai a tocar a loja</segment>
    <segment id="51">, masmas as coisas não correm bem.</segment>
    <segment id="52">O patriarca tosse muito e não tem o mesmo fogo —literal</segment>
    <segment id="53">, no caso</segment>
    <segment id="54">caso— para tocar o negócio.</segment>
    <segment id="55">Ele sofre até para fazer os pequenos doces de carvão que vende.</segment>
    <segment id="56">A promessa é que a filha assuma o seu lugar.</segment>
    <segment id="57">O problema é que a moça</segment>
    <segment id="58">, por ansiedade ou nervosismo</segment>
    <segment id="59">, tem um temperamento curto para os negócios</segment>
    <segment id="60">, e sua fúria com frequência acaba provocando incêndios.</segment>
    <segment id="61">Veja cenas de &amp;#039</segment>
    <segment id="62">;Elementos&amp;#039</segment>
    <segment id="63">;, novo filme da PixarMais    novamente         de   de  de  representando um  Uma dessas explosões vai disparar a história de vez.</segment>
    <segment id="64">A ira de Faísca um dia cria um rombo no encanamento e</segment>
    <segment id="65">, além do vazamento</segment>
    <segment id="66">, ele traz um inspetor chamado Gota</segment>
    <segment id="67">, feito de água —raça odiada pela família.</segment>
    <segment id="68">Uma série de multas depois</segment>
    <segment id="69">, a lojinha corre o risco de fechar.</segment>
    <segment id="70">A disposição dos elementos narrativos indica que o filme vai</segment>
    <segment id="71">sese guiar pela busca emocional</segment>
    <segment id="72">, na luta da protagonista para controlar as emoções.</segment>
    <segment id="73">Mas "Elementos" segue um caminho mais interessante</segment>
    <segment id="74">, dentro do assunto menos instigante: a burocracia.</segment>
    <segment id="75">Na busca de Faísca para salvar o negócio da família</segment>
    <segment id="76">, ela descobre que o seu problema é generalizado na região</segment>
    <segment id="77">, que corre risco de enchente.</segment>
    <segment id="78">Ela se</segment>
    <segment id="79">se associa a Gota para resolver a situação e eliminar as multas</segment>
    <segment id="80">, e assim a história</segment>
    <segment id="81">sese reorganiza em torno dos dois.</segment>
    <segment id="82">É uma relação de extremos.</segment>
    <segment id="83">Ela é fogo e ele é água</segment>
    <segment id="84">, ela estoura fácil e ele chora em toda oportunidade.</segment>
    <segment id="85">Mas o amor encontra um jeito de desabrochar</segment>
    <segment id="86">, da mesma forma que Faísca descobre o mundo e a si própria.</segment>
    <segment id="87">A garota encontra seu equilíbrio enquanto percebe sua individualidade</segment>
    <segment id="88">, que inclui um talento para moldar o vidro.</segment>
    <segment id="89">O que é um problema</segment>
    <segment id="90">, pois</segment>
    <segment id="91">pois nada disso envolve seu futuro na lojinha.</segment>
    <segment id="92">O dilema final de "Elementos"</segment>
    <segment id="93">, então</segment>
    <segment id="94">, é da ordem clássica</segment>
    <segment id="95">, do duelo entre honrar os pais ou seguir com os próprios sonhos.</segment>
    <segment id="96">A questão não é inédita na Pixar</segment>
    <segment id="97">, bem como</segment>
    <segment id="98">como o contexto das famílias imigrantes.</segment>
    <segment id="99">O estúdio fez algo parecido no ano passado com "</segment>
    <segment id="100">Red:</segment>
    <segment id="101">Crescer É uma Fera"</segment>
    <segment id="102">, que encenava melhor o conflito pelo drama geracional e do adolescente.</segment>
    <segment id="103">Confira cenas de &amp;#</segment>
    <segment id="104">039;Red:</segment>
    <segment id="105">Crescer</segment>
    <segment id="106">É Uma Fera&amp;#039</segment>
    <segment id="107">;Mais    novamente         de   de  de  representando um  Mas o novo longa-metragem</segment>
    <segment id="108">, dirigido por Peter Sohn</segment>
    <segment id="109">, sese destaca pela sutileza.</segment>
    <segment id="110">Segue a lógica da fábula</segment>
    <segment id="111">, tradicional e mais acessível</segment>
    <segment id="112">, construindo alegorias simples de maneira elaborada</segment>
    <segment id="113">, que contemplam o percurso da história.</segment>
    <segment id="114">A bela trilha sonora de Thomas Newman reforça isso nos sons minimalistas e inusitados —</segment>
    <segment id="115">comocomo uma cítara ou um coro de vozes borbulhante.</segment>
    <segment id="116">Já a premissa faz tudo funcionar.</segment>
    <segment id="117">"</segment>
    <segment id="118">Elementos</segment>
    <segment id="119">" evita a correlação direta entre o equilíbrio de Faísca e o dos elementos naturais.</segment>
    <segment id="120">O pano de fundo da história alimenta a oposição dela com Gota</segment>
    <segment id="121">, que recusam a admitir sua paixão</segment>
    <segment id="122">porque</segment>
    <segment id="123">porque o fogo e a água não podem</segment>
    <segment id="124">sese tocar —a razão diz que um apaga o outro</segment>
    <segment id="125">, bom lembrar.</segment>
    <segment id="126">O contato dos dois leva a uma cena bonita</segment>
    <segment id="127">, masmas também a um clímax à altura da história do estúdio.</segment>
    <segment id="128">Um pequeno spoiler: no momento de maior apuro do filme</segment>
    <segment id="129">, Faísca</segment>
    <segment id="130">sese vê presa</segment>
    <segment id="131">, obrigada a decidir entre os valores de sua família e o amor</segment>
    <segment id="132">, apenas</segment>
    <segment id="133">porque</segment>
    <segment id="134">porque</segment>
    <segment id="135">sese fechou demais para ambos.</segment>
  </rst>
</analysis>