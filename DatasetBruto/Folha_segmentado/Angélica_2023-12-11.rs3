  <rst>
    <segment id="1">Angélica comentou a possibilidade de Luciano Huck</segment>
    <segment id="2">, seu marido</segment>
    <segment id="3">, sese candidatar à Presidência</segment>
    <segment id="4">, durante o programa Roda Viva na noite desta segunda-feira.</segment>
    <segment id="5">O apresentador considerou disputar o cargo nas eleições do ano passado</segment>
    <segment id="6">, masmas acabou desistindo.</segment>
    <segment id="7">A apresentadora também elogiou a atual primeira-dama</segment>
    <segment id="8">, Janja</segment>
    <segment id="9">, por sua participação ativa no governo Lula.</segment>
    <segment id="10">"</segment>
    <segment id="11">Quando começaram a cogitar [Luciano Huck para presidente]</segment>
    <segment id="12">, me perguntaram que primeira-dama é essa</segment>
    <segment id="13">, e acho difícil</segment>
    <segment id="14">, porque</segment>
    <segment id="15">porque a gente tem que ter referência"</segment>
    <segment id="16">, disse.</segment>
    <segment id="17">"</segment>
    <segment id="18">Não sou um ser político</segment>
    <segment id="19">comocomo o Luciano é.</segment>
    <segment id="20">Eu estaria do lado dele nessa missão</segment>
    <segment id="21">, masmas eu precisaria de referências.</segment>
    <segment id="22">"</segment>
    <segment id="23">A apresentadora Angélica - Alex Santanna/GloboA apresentadora citou</segment>
    <segment id="24">comocomo inspiração Ruth Cardoso</segment>
    <segment id="25">, a mulher do ex-presidente Fernando Henrique Cardoso.</segment>
    <segment id="26">"Seria uma inspiração.</segment>
    <segment id="27">Ela era uma mulher inteligentíssima.</segment>
    <segment id="28">"</segment>
    <segment id="29">Angélica também negou que tenha desincentivado</segment>
    <segment id="30">Huck a disputar a Presidência.</segment>
    <segment id="31">Ela disse que apoiaria o apresentador</segment>
    <segment id="32">casocaso ele</segment>
    <segment id="33">sese tornasse presidente e que buscaria ser ativa nos temas que a interessassem.</segment>
    <segment id="34">Foi quando ela elogiou Janja por trabalhar com Lula.</segment>
    <segment id="35">"</segment>
    <segment id="36">Ela é muito criticada por isso</segment>
    <segment id="37">, masmas acho legal que ela seja participativa</segment>
    <segment id="38">, esteja cuidando</segment>
    <segment id="39">, defendendo.</segment>
    <segment id="40">Isso vale muito —ter uma mulher ativa</segment>
    <segment id="41">, onde quer que seja.</segment>
    <segment id="42">"</segment>
    <segment id="43">Veja fotos do Programa Angélica: 50 &amp;amp</segment>
    <segment id="44">;</segment>
    <segment id="45">Tanto (1ª temporada)Mais    novamente         de   de  de  representando um</segment>
    <segment id="46">A apresentadora disse que a decisão de Huck de desistir das eleições esteve ligada à vida que eles construíram</segment>
    <segment id="47">, incluindo os três filhos.</segment>
    <segment id="48">Ela também afirmou que acha que ele fez uma boa decisão</segment>
    <segment id="49">, citando a contratação do apresentador para o Domingão com Huck</segment>
    <segment id="50">, da Rede Globo.</segment>
    <segment id="51">"</segment>
    <segment id="52">A gente fez a decisão correta.</segment>
    <segment id="53">Hoje ele vive o maior desafio da carreira dele.</segment>
    <segment id="54">"</segment>
    <segment id="55">Leia maisAngélica faz 50</segment>
    <segment id="56">, volta à Globo e diz por que fala mais de sexo</segment>
    <segment id="57">, política e feminismo</segment>
  </rst>
