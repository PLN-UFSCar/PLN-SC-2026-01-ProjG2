  <rst>
    <segment id="1">Vencedor da semana: o novo ministro da Justiça</segment>
    <segment id="2">, Ricardo Lewandowski</segment>
    <segment id="3">, que deve</segment>
    <segment id="4">sese tornar o principal conselheiro jurídico de Lula</segment>
    <segment id="5">, além de receber</segment>
    <segment id="6">comocomo missão formular estratégias de combate à criminalidade.</segment>
    <segment id="7">Perdedor da semana: o ministro da Secretaria-Geral da Presidência</segment>
    <segment id="8">, Márcio Macêdo</segment>
    <segment id="9">, na corda bamba após assessores terem viajado com dinheiro público para uma micareta em Aracaju (SE).</segment>
    <segment id="10">Fique de olho: Dino e Lewandowski iniciam transição na Justiça</segment>
    <segment id="11">; Pacheco e Haddad tentam acordo por MP da reoneração da folha de pagamentos</segment>
    <segment id="12">; PT deve definir filiação de Marta.</segment>
  </rst>
