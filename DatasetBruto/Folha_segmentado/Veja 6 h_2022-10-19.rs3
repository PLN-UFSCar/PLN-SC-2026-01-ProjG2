  <rst>
    <segment id="1">O ritmo do segundo semestre não é mole</segment>
    <segment id="2">, não.</segment>
    <segment id="3">Para quem estuda</segment>
    <segment id="4">, trabalha ou faz os dois</segment>
    <segment id="5">, ver que o fim do ano está cada vez mais perto assusta —e faz a gente correr mais ainda.</segment>
    <segment id="6">Não por acaso</segment>
    <segment id="7">, é nessa época também que os hotéis e pousadas especializados em esvaziar a mente dos hóspedes são tão concorridos.</segment>
    <segment id="8">Diretora de marketing do Lake Vilas Charm Hotel &amp;amp</segment>
    <segment id="9">; Spa, em Amparo</segment>
    <segment id="10">, onde uma casa de vidro no meio da floresta fica reservada para praticantes de meditação</segment>
    <segment id="11">, Gabriela Achcar afirma que a busca por paz e relaxamento vem aumentando nos últimos anos.</segment>
    <segment id="12">Hotel Munay</segment>
    <segment id="13">, em Santo Antônio do Pinhal</segment>
    <segment id="14">, oferece diversas massagens e terapias  - Divulgação"Casais ou executivos vêm recarregar as energias e descansar.</segment>
    <segment id="15">Notamos que a Casa de Meditação e locais</segment>
    <segment id="16">comocomo a cachoeira escondida são disputados por quem procura silêncio para praticar meditação ou mindfulness.</segment>
    <segment id="17">"</segment>
    <segment id="18">O que faz de um lugar um destino especial para descansar corpo</segment>
    <segment id="19">, mente e espírito?</segment>
    <segment id="20">Para Pedro Fadida</segment>
    <segment id="21">, sócio da pousada Munay Pousada e Centro Holístico</segment>
    <segment id="22">, em Santo Antônio do Pinhal (SP)</segment>
    <segment id="23">, é fundamental estar inserido em uma paisagem inspiradora</segment>
    <segment id="24">, em contato íntimo com a natureza</segment>
    <segment id="25">, para silenciar a mente e desacelerar de verdade.</segment>
    <segment id="26">"Estamos no meio das montanhas da Serra da Mantiqueira</segment>
    <segment id="27">, com vista para a Pedra do Baú.</segment>
    <segment id="28">Aqui é possível caminhar</segment>
    <segment id="29">, fazer terapias integrativas e restauradoras ou</segment>
    <segment id="30">, simplesmente</segment>
    <segment id="31">, contemplar a vida"</segment>
    <segment id="32">, afirma.</segment>
    <segment id="33">O roteiro a seguir lista seis empreendimentos paulistas que</segment>
    <segment id="34">sese encaixam nesse espírito —ficam em regiões belíssimas</segment>
    <segment id="35">, sem muros que bloqueiem a visão da paisagem</segment>
    <segment id="36">, e permitem que os hóspedes alternem atividades bem calminhas e momentos de introspecção e autoconhecimento.</segment>
    <segment id="37">  Fazenda da Lila</segment>
    <segment id="38">A 1.300 m de altitude</segment>
    <segment id="39">, a propriedade é cercada pelas montanhas da Serra da Mantiqueira e permite aos hóspedes a escolha entre os retiros de autoconhecimento e as estadias livres.</segment>
    <segment id="40">Saiba o que comer</segment>
    <segment id="41">, visitar e comprar em São Bento do Sapucaí e Santo Antônio do PinhalMais    novamente         de   de  de  representando um  Todo o entorno convida ao relaxamento</segment>
    <segment id="42">, da piscina de água mineral de água transparente ao salão para práticas e workshops</segment>
    <segment id="43">, que descortina a vista exuberante da Pedra do Baú.</segment>
    <segment id="44">Não faltam recantos acolhedores para curtir momentos de sossego</segment>
    <segment id="45">, como</segment>
    <segment id="46">como a sala de massagem e terapias</segment>
    <segment id="47">, a sala de leitura</segment>
    <segment id="48">, um deque onde</segment>
    <segment id="49">sese acende a fogueira e o Monte Varshana</segment>
    <segment id="50">, mirante com visão de 360 graus do vale</segment>
    <segment id="51">, de onde</segment>
    <segment id="52">sese observa o pôr do sol.</segment>
    <segment id="53">As suítes</segment>
    <segment id="54">, adaptadas nas antigas baias dos cavalos</segment>
    <segment id="55">, têm confortos</segment>
    <segment id="56">comocomo closet</segment>
    <segment id="57">, box de vidro</segment>
    <segment id="58">, aquecedor a gás e roupa de cama de algodão 400 fios.</segment>
    <segment id="59">As refeições</segment>
    <segment id="60">, preparadas com ingredientes locais orgânicos</segment>
    <segment id="61">, são servidas na casinha mais antiga da fazenda.</segment>
    <segment id="62">Vale do Baú</segment>
    <segment id="63">, São Bento do Sapucaí (a geolocalização precisa é enviada aos hóspedes).</segment>
    <segment id="64">Pacote de duas diárias</segment>
    <segment id="65">, para casal</segment>
    <segment id="66">, a partir de R$ 2.500</segment>
    <segment id="67">, com refeições e práticas de ioga incluídas.  Krishna Shaktí Ashram   Funciona</segment>
    <segment id="68">comocomo um autêntico ashram indiano</segment>
    <segment id="69">, como</segment>
    <segment id="70">como são chamados os lugares propícios para prática de ioga</segment>
    <segment id="71">, sob coordenação de Regina Shakti</segment>
    <segment id="72">, presidente do Instituto de Yoga de São Paulo e famosa entre celebridades.</segment>
    <segment id="73">Quem se</segment>
    <segment id="74">se hospeda em um dos oito chalés com lareira</segment>
    <segment id="75">, individuais ou coletivos</segment>
    <segment id="76">, não deve esperar mordomias —</segment>
    <segment id="77">o conceito é cada um ser responsável por si.</segment>
    <segment id="78">A programação começa na sexta-feira</segment>
    <segment id="79">, às 14h</segment>
    <segment id="80">, e termina domingo.</segment>
    <segment id="81">"</segment>
    <segment id="82">Logo na chegada</segment>
    <segment id="83">, as pessoas meditam para entender o que foram buscar e</segment>
    <segment id="84">comocomo podem aproveitar o espaço"</segment>
    <segment id="85">, diz Regina.</segment>
    <segment id="86">Hotéis a até 200 km da capital têm terapias para esvaziar a menteMais    novamente         de   de  de  representando um  Banhos de água mineral</segment>
    <segment id="87">, caminhadas pela floresta</segment>
    <segment id="88">, exercícios de respiração</segment>
    <segment id="89">, aulas de ioga</segment>
    <segment id="90">, massagens e leitura de mãos são algumas das atividades propostas —</segment>
    <segment id="91">masmas quem preferir pode só tomar sol.</segment>
    <segment id="92">Uma missa indiana acontece no templo</segment>
    <segment id="93">, onde o monge Sripad B.V.</segment>
    <segment id="94">Trivikram Maharaj também conduz o estudo das escrituras antigas da Índia.</segment>
    <segment id="95">O ashram fornece todas as refeições lactovegetarianas e não impede o uso de tecnologia</segment>
    <segment id="96">, masmas Regina recomenda deixar o celular na bolsa —a TV comunitária só exibe conteúdo indiano.</segment>
    <segment id="97">Após 21h</segment>
    <segment id="98">, o silêncio é norma.</segment>
    <segment id="99">Est.</segment>
    <segment id="100">Tabatinga</segment>
    <segment id="101">, km 6</segment>
    <segment id="102">, s/nº</segment>
    <segment id="103">, Campos do Jordão.</segment>
    <segment id="104">Diária para uma pessoa</segment>
    <segment id="105">, em quarto individual</segment>
    <segment id="106">, a R$ 800</segment>
    <segment id="107">, com refeições e atividades.</segment>
    <segment id="108">Lake Vilas Charm Hotel &amp;amp</segment>
    <segment id="109">;</segment>
    <segment id="110">Spa   A propriedade de 3</segment>
    <segment id="111">,5 milhões de m² tem matas preservadas</segment>
    <segment id="112">, riacho</segment>
    <segment id="113">, 12 lagos</segment>
    <segment id="114">, cachoeiras</segment>
    <segment id="115">, piscinas naturais e uma casa de vidro cercada pelo verde</segment>
    <segment id="116">, reservada para a prática de meditação.</segment>
    <segment id="117">Oito vilas sofisticadas hospedam os visitantes</segment>
    <segment id="118">, todas com sala</segment>
    <segment id="119">, varanda e jardim privativo —a maior delas</segment>
    <segment id="120">, Vila Presidencial</segment>
    <segment id="121">, tem dois andares e três quartos</segment>
    <segment id="122">, que somam 500 m².</segment>
    <segment id="123">Hoteis para o Natal e o Réveillon no BrasilMais    novamente         de   de  de  representando um  No spa</segment>
    <segment id="124">, sessões de shiatsu</segment>
    <segment id="125">, massagem</segment>
    <segment id="126">, reflexologia e ducha escocesa prometem relaxamento</segment>
    <segment id="127">, masmas também é possível agendar tratamentos estéticos</segment>
    <segment id="128">, treinar na academia</segment>
    <segment id="129">, jogar tênis</segment>
    <segment id="130">, frescobol</segment>
    <segment id="131">, beach tênis e beach vôlei.</segment>
    <segment id="132">O café da manhã é uma degustação em nove etapas</segment>
    <segment id="133">, servida na Casa do Lago —todas as refeições são preparadas com ingredientes que vêm da horta orgânica e biodinâmica.</segment>
    <segment id="134">Est.</segment>
    <segment id="135">Antenor Cézar</segment>
    <segment id="136">, km 10</segment>
    <segment id="137">, Amparo.</segment>
    <segment id="138">Diárias para casal</segment>
    <segment id="139">, com café da manhã</segment>
    <segment id="140">, a partir de R$ 3.995.</segment>
    <segment id="141">Munay Pousada e Centro Holístico</segment>
    <segment id="142">O casal Pedro Fadida e Luana Mantegazza mora na propriedade com os filhos</segment>
    <segment id="143">, faz questão de acolher os hóspedes pessoalmente e promove momentos de interação</segment>
    <segment id="144">, como</segment>
    <segment id="145">como conversas ao redor da fogueira.</segment>
    <segment id="146">"</segment>
    <segment id="147">Gostamos de conversar para entender as pessoas que vêm aqui"</segment>
    <segment id="148">, diz Pedro.</segment>
    <segment id="149">Formada em ayurveda</segment>
    <segment id="150">, Luana conduz o atendimento inicial e recomenda as terapias para cada hóspede.</segment>
    <segment id="151">O cardápio inclui massagens relaxantes e desintoxicantes</segment>
    <segment id="152">, tratamentos de beleza e rejuvenescimento</segment>
    <segment id="153">, ofurô com ervas e sais de banho</segment>
    <segment id="154">, ioga e caminhada terapêutica —</segment>
    <segment id="155">masmas quem preferir pode apenas relaxar</segment>
    <segment id="156">, sem compromisso.</segment>
    <segment id="157">São três chalés</segment>
    <segment id="158">, todos equipados com cozinha</segment>
    <segment id="159">, para que</segment>
    <segment id="160">para que os visitantes tenham autonomia —quem não levar ingredientes para cozinhar (a colheita na horta é liberada) pode comer nos restaurantes da cidade</segment>
    <segment id="161">, a dez minutos de carro</segment>
    <segment id="162">, ou pedir delivery.</segment>
    <segment id="163">O café da manhã</segment>
    <segment id="164">, com produtos artesanais</segment>
    <segment id="165">, é fornecido em uma cesta.  Rod.</segment>
    <segment id="166">SP-46, km 156</segment>
    <segment id="167">, Santo Antônio do Pinhal.</segment>
    <segment id="168">Diária da casa</segment>
    <segment id="169">, com café da manhã</segment>
    <segment id="170">, a partir de R$ 470 (terapias à parte).</segment>
    <segment id="171">Ponto de Luz   Fundada pelos amigos</segment>
    <segment id="172">Sergio Savian e Libertad Sanchez</segment>
    <segment id="173">, nasceu com foco na meditação</segment>
    <segment id="174">, masmas hoje oferece um amplo leque de vivências</segment>
    <segment id="175">, oficinas e ações culturais.</segment>
    <segment id="176">Sessões de ioga</segment>
    <segment id="177">, medicina chinesa</segment>
    <segment id="178">, danças circulares e constelação familiar</segment>
    <segment id="179">sese somam a terapias</segment>
    <segment id="180">comocomo integração craniossacral</segment>
    <segment id="181">, cataplasma de argila</segment>
    <segment id="182">, alinhamento dos chakras</segment>
    <segment id="183">, reiki</segment>
    <segment id="184">, limpeza quântica e massagens.</segment>
    <segment id="185">Os apartamentos têm varanda com rede e vista para o verde</segment>
    <segment id="186">, sem TV ou telefone.</segment>
    <segment id="187">Há ainda quartos compartilhados</segment>
    <segment id="188">, uma suíte com hidromassagem e chalés completos</segment>
    <segment id="189">, com uma ou duas suítes.</segment>
    <segment id="190">Aos sábados</segment>
    <segment id="191">, os shows de talentos envolvem artistas consagrados</segment>
    <segment id="192">, estreantes</segment>
    <segment id="193">, visitantes</segment>
    <segment id="194">, funcionários e membros da comunidade.</segment>
    <segment id="195">As refeições saem quase inteiramente da horta e da roça próprias: no check-out</segment>
    <segment id="196">, os hóspedes ganham uma cesta de alimentos naturais recém-colhidos.</segment>
    <segment id="197">Estrada Sertãozinho</segment>
    <segment id="198">, s/nº</segment>
    <segment id="199">, Joanópolis.</segment>
    <segment id="200">O programa Bem-Estar</segment>
    <segment id="201">, de dois dias</segment>
    <segment id="202">, custa a partir de R$ 1.438 por pessoa</segment>
    <segment id="203">, em quarto duplo</segment>
    <segment id="204">, nos dias de semana.</segment>
    <segment id="205">Inclui refeições</segment>
    <segment id="206">, duas terapias individuais</segment>
    <segment id="207">, dois banhos de ervas</segment>
    <segment id="208">, dois sucos desintoxicantes e um banho de ofurô.</segment>
    <segment id="209">Templo do Ser</segment>
    <segment id="210">O lugar não tem fins lucrativos e estimula os hóspedes a fazer um retiro espiritual para reconectar corpo</segment>
    <segment id="211">, mente e alma.</segment>
    <segment id="212">Os visitantes pernoitam na Casa de Descanso Hale Moe Moe</segment>
    <segment id="213">, que tem confortáveis acomodações para solteiros ou casais cercadas pela Mata Atlântica —todas são equipadas com aquecimento central de água</segment>
    <segment id="214">, ar condicionado</segment>
    <segment id="215">, frigobar</segment>
    <segment id="216">, wi-fi e varandas com vista panorâmica.</segment>
    <segment id="217">Depois do café da manhã caseiro</segment>
    <segment id="218">, à base de alimentos orgânicos</segment>
    <segment id="219">, têm início as atividades na Casa da Vida Hale</segment>
    <segment id="220">Ola —massagens</segment>
    <segment id="221">, shiatsu</segment>
    <segment id="222">, escalda pés com reflexologia</segment>
    <segment id="223">, terapia com ventosas</segment>
    <segment id="224">, reiki</segment>
    <segment id="225">, meditação</segment>
    <segment id="226">, ioga</segment>
    <segment id="227">, constelação familiar e relaxamento individual ou em grupo.  Av. Engenho Velho</segment>
    <segment id="228">, 185, Feiticeira</segment>
    <segment id="229">, Ilhabela.</segment>
    <segment id="230">Diárias a partir de R$ 982 (uma pessoa)</segment>
    <segment id="231">, R$ 1.266 (duas pessoas</segment>
    <segment id="232">, em quarto duplo) ou R$ 1.551 (três pessoas</segment>
    <segment id="233">, em quarto triplo)</segment>
    <segment id="234">, com refeições e atividades incluídas</segment>
  </rst>
</analysis>