  <rst>
    <segment id="1">O ex-juiz Sergio Moro corre o risco de</segment>
    <segment id="2">sese candidatar à Presidência neste ano com baixíssimo tempo de propaganda eleitoral gratuita disponível para apresentar propostas e com um quinto de verba em relação a adversários.</segment>
    <segment id="3">O esforço de Moro é</segment>
    <segment id="4">para que</segment>
    <segment id="5">para que o Podemos consiga atrair o apoio do Cidadania e</segment>
    <segment id="6">, principalmente</segment>
    <segment id="7">, da União Brasil —fusão de PSL e DEM— para sua coligação.</segment>
    <segment id="8">Nos últimos dias</segment>
    <segment id="9">, entretanto</segment>
    <segment id="10">, ambas as negociações esfriaram.</segment>
    <segment id="11">No próximo dia 15</segment>
    <segment id="12">, o diretório nacional do Cidadania irá</segment>
    <segment id="13">sese reunir para decidir</segment>
    <segment id="14">sese compõe uma federação com o partido do ex-magistrado ou com o PSDB.</segment>
    <segment id="15">A tendência é que siga para uma aliança com os tucanos.</segment>
    <segment id="16">Sergio Moro</segment>
    <segment id="17">, ex-ministro de Jair Bolsonaro    - Adriano Vizoni/FolhapressA União Brasil</segment>
    <segment id="18">, por sua vez</segment>
    <segment id="19">, tem enfrentado pressão para não dar peso à candidatura de Moro</segment>
    <segment id="20">, que é acusado por boa parte do Congresso de ter criminalizado a política quando esteve à frente da Operação Lava Jato.</segment>
    <segment id="21">O novo partido tem o maior naco da propaganda eleitoral gratuita e dispõe da maior parcela do fundo eleitoral.</segment>
    <segment id="22">O apoio da sigla daria musculatura ao ex-juiz e ajudaria a atrair novas adesões ao projeto do ex-ministro da Justiça do governo Jair Bolsonaro (PL).</segment>
    <segment id="23">Uma série de empecilhos políticos</segment>
    <segment id="24">, no entanto</segment>
    <segment id="25">, distanciou a União Brasil do Podemos nas últimas semanas.</segment>
    <segment id="26">A Justiça Eleitoral ainda irá anunciar exatamente quanto tempo de televisão terá cada partido.</segment>
    <segment id="27">O Podemos calcula que serão cerca de 20 segundos</segment>
    <segment id="28">, o que dificultaria o projeto de dar mais popularidade a Moro.</segment>
    <segment id="29">Bolsonaro e o ex-presidente Luiz Inácio Lula da Silva (PT)</segment>
    <segment id="30">, que estão à frente nas pesquisas</segment>
    <segment id="31">, têm partidos com maior tempo para propaganda gratuita e</segment>
    <segment id="32">, além disso</segment>
    <segment id="33">, têm tratativas mais avançadas para compor alianças que ampliem ainda mais a exposição.</segment>
    <segment id="34">A mesma regra vale para dinheiro de campanha.</segment>
    <segment id="35">As siglas de ambos dispõem de parte maior do fundo eleitoral</segment>
    <segment id="36">, assim</segment>
    <segment id="37">comocomo os potenciais aliados dos dois.</segment>
    <segment id="38">O Podemos receberá cerca de R$ 169 milhões</segment>
    <segment id="39">, enquanto o PT deverá ter mais de R$ 486 milhões e o PL</segment>
    <segment id="40">, um valor superior a R$ 275 milhões.</segment>
    <segment id="41">Das conversas em andamento</segment>
    <segment id="42">, apenas a União Brasil poderia fazer Moro competir com eles nesses dois quesitos.</segment>
    <segment id="43">As resistências no novo partido à aliança</segment>
    <segment id="44">, no entanto</segment>
    <segment id="45">, cresceram nas últimas semanas.</segment>
    <segment id="46">Um dos empecilhos para o acordo é a candidatura do vice-presidente da sigla e ex-presidente do DEM</segment>
    <segment id="47">, ACM Neto.</segment>
    <segment id="48">Ele disputará o Governo da Bahia neste ano e avalia nos bastidores que o apoio a Moro poderia enfraquecê-lo no estado.</segment>
    <segment id="49">Isso porque</segment>
    <segment id="50">porque o ex-juiz consolidou-</segment>
    <segment id="51">sese como</segment>
    <segment id="52">como um dos maiores adversários de Lula</segment>
    <segment id="53">, e a Bahia é justamente uma das unidades da Federação em que o petista tem maior popularidade.</segment>
    <segment id="54">As negociações para Moro ter o apoio da União Brasil envolvem a indicação do deputado federal e presidente do partido</segment>
    <segment id="55">, Luciano Bivar (PE)</segment>
    <segment id="56">, a vice.</segment>
    <segment id="57">A proximidade entre ambos os partidos já foi tanta que chegou-</segment>
    <segment id="58">sese a cogitar a filiação do ex-juiz à legenda recém-criada com a anuência do Podemos.</segment>
    <segment id="59">O atual partido de Moro cogitou a ideia</segment>
    <segment id="60">porque</segment>
    <segment id="61">porque ela daria força ao ex-juiz e também</segment>
    <segment id="62">porque</segment>
    <segment id="63">porque a legenda não precisaria destinar parte do fundo eleitoral à candidatura ao Palácio do Planalto</segment>
    <segment id="64">, sobrando mais verba para os deputados.</segment>
    <segment id="65">Nas últimas semanas</segment>
    <segment id="66">, porém</segment>
    <segment id="67">porém, o namoro esfriou.</segment>
    <segment id="68">Hoje, nos bastidores</segment>
    <segment id="69">, aliados de Moro já admitem que o apoio da União Brasil está distante.</segment>
    <segment id="70">O ex-juiz Sergio Moro em pré-campanhaMais    novamente         de   de  de  representando um  Um dos sintomas do distanciamento é a negociação que passou a ser articulada entre o novo partido e o MDB</segment>
    <segment id="71">para que</segment>
    <segment id="72">para que formem uma federação.</segment>
    <segment id="73">Caso isso</segment>
    <segment id="74">sese concretize</segment>
    <segment id="75">, o apoio ao Podemos torna-</segment>
    <segment id="76">sese praticamente impossível.</segment>
    <segment id="77">Além da dificuldade que esse movimento criaria em palanques estaduais</segment>
    <segment id="78">, os caciques do MDB foram um dos mais atingidos pelas ações de Moro quando era juiz da Lava Jato</segment>
    <segment id="79">, o que tem levado o pré-candidato a ser descartado de antemão das negociações entre as legendas.</segment>
    <segment id="80">A federação é uma nova possibilidade surgida com base em uma mudança eleitoral aprovada pelo Congresso no ano passado.</segment>
    <segment id="81">Após o veto às coligações em eleições proporcionais</segment>
    <segment id="82">, o Legislativo aprovou o novo modelo a fim de salvar siglas pequenas que corriam o risco de não atingir a cláusula de barreira</segment>
    <segment id="83">, o que impediria o acesso delas ao fundo partidário.</segment>
    <segment id="84">Diferentemente das coligações</segment>
    <segment id="85">, que se</segment>
    <segment id="86">se encerram na data do pleito</segment>
    <segment id="87">, a federação obriga legendas a caminharem juntas por quatro anos</segment>
    <segment id="88">, o que inclui</segment>
    <segment id="89">, além de 2022</segment>
    <segment id="90">, as eleições municipais de 2024.</segment>
    <segment id="91">A intenção do Podemos é</segment>
    <segment id="92">sese federar com o Cidadania</segment>
    <segment id="93">, o que lhe daria maior musculatura política em estados importantes e também maior tempo de propaganda eleitoral gratuita.</segment>
    <segment id="94">No entanto</segment>
    <segment id="95">, essa possibilidade também perdeu força no início deste ano.</segment>
    <segment id="96">Em votação na executiva do Cidadania</segment>
    <segment id="97">, órgão de cúpula do partido</segment>
    <segment id="98">, houve</segment>
    <segment id="99">, por margem apertada de voto</segment>
    <segment id="100">, preferência pela união com o PSDB em vez do Podemos.</segment>
    <segment id="101">No próximo dia 15</segment>
    <segment id="102">, o diretório nacional da legenda</segment>
    <segment id="103">, que conta com maior número de integrantes e é o responsável por tomar uma decisão sobre o tema</segment>
    <segment id="104">, irá se</segment>
    <segment id="105">se reunir para discutir o assunto.</segment>
    <segment id="106">A tendência atual é que o partido aprove uma resolução</segment>
    <segment id="107">para que</segment>
    <segment id="108">para que seja encaminhada uma federação com a legenda tucana.</segment>
    <segment id="109">Alguns fatores têm pesado nesse sentido.</segment>
    <segment id="110">Um deles diz respeito à avaliação de que o Podemos é um partido com menos debate interno do que o PSDB.</segment>
    <segment id="111">Assim, o Cidadania teria menos peso nas decisões internas.</segment>
    <segment id="112">Além disso</segment>
    <segment id="113">, os acenos de Moro a pautas conservadoras nos costumes também irritaram caciques da sigla</segment>
    <segment id="114">, que se</segment>
    <segment id="115">se considera progressista.</segment>
    <segment id="116">A preferência do presidente nacional da sigla</segment>
    <segment id="117">, Roberto Freire</segment>
    <segment id="118">, pelo PSDB também pesa nessa decisão.</segment>
    <segment id="119">O pré-candidato a presidente tucano e governador de São Paulo</segment>
    <segment id="120">, João Doria</segment>
    <segment id="121">, inclusive</segment>
    <segment id="122">, já trabalha com a possibilidade de ter a senadora Eliziane Gama (Cidadania-MA)</segment>
    <segment id="123">comocomo vice em sua chapa.</segment>
    <segment id="124">O senador Álvaro Dias (Podemos-PR)</segment>
    <segment id="125">, que ajudou a atrair Moro para o partido</segment>
    <segment id="126">, diz que as conversas com os dois potenciais aliados "prosseguem"</segment>
    <segment id="127">, masmas admite que</segment>
    <segment id="128">sese trata de um "processo lento".</segment>
    <segment id="129">Dias afirma que a ideia seria entregar o posto de vice à União Brasil e que deseja compor uma federação com o Cidadania.</segment>
    <segment id="130">Ele diz que ainda acredita em uma aliança com ambos</segment>
    <segment id="131">, masmas comenta sobre um cenário em que o Podemos fique isolado.</segment>
    <segment id="132">"</segment>
    <segment id="133">São essas articulações que estão em curso e é evidente que nosso desejo é que elas</segment>
    <segment id="134">sese concretizem e sejam oficializadas.</segment>
    <segment id="135">Se não ocorrerem</segment>
    <segment id="136">, teremos de caminhar com as próprias pernas e isso também é possível"</segment>
    <segment id="137">, afirma.</segment>
    <segment id="138">Este é Sergio Moro em 2022Mais    novamente         de   de  de  representando um</segment>
  </rst>
</analysis>