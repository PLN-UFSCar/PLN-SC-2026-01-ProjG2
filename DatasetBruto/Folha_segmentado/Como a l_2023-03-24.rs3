  <rst>
    <segment id="1">Quem tem gatinho em casa já deve ter reparado: eles passam boa tarde do tempo dormindo e</segment>
    <segment id="2">, quando acordados</segment>
    <segment id="3">, provavelmente estarão tomando banho.</segment>
    <segment id="4">Mas gatos não usam nem chuveiro nem banheira</segment>
    <segment id="5">, e também não costumam ir ao pet shop</segment>
    <segment id="6">, como</segment>
    <segment id="7">como fazem os cachorros</segment>
    <segment id="8">, para manter a higiene.</segment>
    <segment id="9">Os gatos</segment>
    <segment id="10">sese limpam sozinhos</segment>
    <segment id="11">, dando "banho" em si mesmos usando a língua.</segment>
    <segment id="12">E, sese mais de um gatinho faz parte do bando</segment>
    <segment id="13">, provavelmente eles</segment>
    <segment id="14">sese ajudarão passando a língua um no outro.</segment>
    <segment id="15">Mas, será que depois de tanto lambe-lambe a língua deles não resseca?</segment>
    <segment id="16">Os gatinhos Morganson (siamês) e Merlington (preto)</segment>
    <segment id="17">sese lambem - Reprodução/Instagram/memomeow_dailyA médica veterinária Mayara Mello</segment>
    <segment id="18">, especializada em felinos</segment>
    <segment id="19">, responde à pergunta desta semana na seção</segment>
    <segment id="20">Um Adulto Responde.</segment>
    <segment id="21">E, sese você também tem uma pergunta sem resposta</segment>
    <segment id="22">, mande-a para folhinha@grupofolha.com.br e encontraremos um especialista para ajudar.</segment>
    <segment id="23">  Como é que os gatos não ficam com a língua seca</segment>
    <segment id="24">sese tomam banho o dia inteiro?</segment>
    <segment id="25">Nina L.</segment>
    <segment id="26">, 6 anos</segment>
    <segment id="27">Essa curiosidade é muito boa.</segment>
    <segment id="28">Você sabia que os gatos são autolimpantes?</segment>
    <segment id="29">Isso acontece</segment>
    <segment id="30">porque</segment>
    <segment id="31">porque eles possuem papilas filiformes</segment>
    <segment id="32">, que são estruturas na língua que</segment>
    <segment id="33">sese parecem com espinhos.</segment>
    <segment id="34">Elas são compostas de queratina</segment>
    <segment id="35">, mesma composição das garrinhas deles.</segment>
    <segment id="36">Por isso</segment>
    <segment id="37">, quando o gato lambe a gente</segment>
    <segment id="38">, sentimos a língua áspera.</segment>
    <segment id="39">Ela não é úmida</segment>
    <segment id="40">comocomo a dos humanos</segment>
    <segment id="41">, e possui esses "espinhos".</segment>
    <segment id="42">Essas papilas têm várias funções.</segment>
    <segment id="43">Uma delas é armazenar a saliva para a hora do "banho de gato"</segment>
    <segment id="44">, que é quando eles ficam</segment>
    <segment id="45">sese lambendo.</segment>
    <segment id="46">Essa saliva precisa ser distribuída entre a pele e os pelos dos bichanos.</segment>
    <segment id="47">É importante que a gente tome cuidado</segment>
    <segment id="48">para que</segment>
    <segment id="49">para que os gatinhos não fiquem ingerindo uma quantidade grande de pelos durante esses banhos.</segment>
    <segment id="50">Isso pode gerar problemas graves</segment>
    <segment id="51">, chegando até a ser necessário</segment>
    <segment id="52">, às vezes</segment>
    <segment id="53">, fazer cirurgias para remover os pelos do estômago deles.</segment>
    <segment id="54">Por isso também a escovação dos gatos é essencial —assim</segment>
    <segment id="55">, tiramos todos os fios mortos</segment>
    <segment id="56">, que aparecem principalmente durante as trocas de pelo que são na primavera e no outono.</segment>
    <segment id="57">Mesmo com essa sensação um pouco estranha do gatinho lambendo a gente</segment>
    <segment id="58">, por sua língua ser áspera</segment>
    <segment id="59">, saiba que as lambidas são sinal de afeto.</segment>
    <segment id="60">Na natureza</segment>
    <segment id="61">, a mãe lambe seus filhotes</segment>
    <segment id="62">comocomo forma de carinho</segment>
    <segment id="63">, e também para estimulá-los a fazer cocô e xixi.</segment>
    <segment id="64">Quando os filhotes crescem</segment>
    <segment id="65">, eles lambem outros animais e as pessoas de quem eles gostam.</segment>
    <segment id="66">Então, sinta-</segment>
    <segment id="67">sese privilegiado por conquistar o amor de um felino.</segment>
  </rst>
</analysis>