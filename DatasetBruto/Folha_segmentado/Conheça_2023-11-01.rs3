  <rst>
    <segment id="1">Desde 1991</segment>
    <segment id="2">, o Instituto Datafolha ouve consumidores de todo o Brasil sobre quais marcas lhes vêm a cabeça quando pensam em produtos</segment>
    <segment id="3">, categorias e tendências que eles compram</segment>
    <segment id="4">,</segment>
    <segment id="5">vendem</segment>
    <segment id="6">, consomem</segment>
    <segment id="7">, almejam ou têm gravado em sua memória</segment>
    <segment id="8">, de alguma forma</segment>
    <segment id="9">, pelas inúmeras formas com as quais essas marcas interagem com a população por meios diversos.</segment>
    <segment id="10">No início</segment>
    <segment id="11">, no princípio da década de 90</segment>
    <segment id="12">, eram 12 categorias</segment>
    <segment id="13">, que cresceram e hoje somam 80 categorias de produtos e serviços diversos</segment>
    <segment id="14">, incluindo categorias especiais</segment>
    <segment id="15">comocomo Top do Top (a "mais mais" das marcas)</segment>
    <segment id="16">, Top Feminino e Top Masculino (que medem marcas que mais</segment>
    <segment id="17">sese destacam entre homens e mulheres)</segment>
    <segment id="18">, e Top especial para regiões (sobre marcas que destacam em cada região do país)</segment>
    <segment id="19">, entre outras que foram incorporadas ao longo das décadas.</segment>
    <segment id="20">Premiação da Folha Top of Mind 2023Mais    novamente         de   de  de  representando um  Para descobrir quais são as marcas mais lembradas do país em 2023</segment>
    <segment id="21">,</segment>
    <segment id="22">O Datafolha entrevistou 7.597 brasileiros com idade a partir de 16 anos</segment>
    <segment id="23">, pertencentes a todas as classes e com diferentes graus de escolaridade</segment>
    <segment id="24">Como sempre</segment>
    <segment id="25">, a pergunta inicial dos pesquisadores foi "qual a primeira marca que lhe vem à cabeça?</segment>
    <segment id="26">", e depois</segment>
    <segment id="27">sese seguiram perguntas</segment>
    <segment id="28">, com formulação igual</segment>
    <segment id="29">, para diferentes categorias.</segment>
    <segment id="30">As respostas são sempre espontâneas e únicas</segment>
    <segment id="31">, e além da primeira marca o Datafolha também investiga as demais marcas mais lembradas em cada categoria.</segment>
    <segment id="32">Parte dos resultados desse grande estudo que une marcas e o cotidiano dos brasileiros você pode conferir no relatório abaixo e</segment>
    <segment id="33">, para saber mais</segment>
    <segment id="34">, é só entrar em contato com nossa equipe.</segment>
    <segment id="35">Baixe aqui os dados do relatório do Top of Mind 2023.</segment>
    <segment id="36">Para saber mais</segment>
    <segment id="37">, escreva para datafolha@datafolha.com.br ou</segment>
    <segment id="38">, nos chame pelo Whatsapp (11 94150-7099).</segment>
  </rst>
</analysis>