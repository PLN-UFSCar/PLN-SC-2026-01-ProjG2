  <rst>
    <segment id="1">Você sabia que uma roupa é usada</segment>
    <segment id="2">, em média</segment>
    <segment id="3">, apenas 10 vezes e que 73% das peças descartadas vão parar em aterros ou são incineradas?</segment>
    <segment id="4">No caso</segment>
    <segment id="5">caso dos alimentos</segment>
    <segment id="6">, o desperdício é ainda maior.</segment>
    <segment id="7">Pesquisas mostram que até 60% das pessoas jogam comida fora pelo menos uma vez por semana</segment>
    <segment id="8">, porque</segment>
    <segment id="9">porque estragam ou vencem.</segment>
    <segment id="10">E sese os eletrodomésticos pudessem ajudar a mudar essa realidade?</segment>
    <segment id="11">É o que o Electrolux Group já faz.</segment>
    <segment id="12">Multinacional de origem sueca presente em mais de 120 países</segment>
    <segment id="13">, a empresa quer transformar a vida para melhor</segment>
    <segment id="14">, reinventando experiências de sabor</segment>
    <segment id="15">, de cuidado e de bem-estar.</segment>
    <segment id="16">Para alcançar essa premissa</segment>
    <segment id="17">, o Grupo traçou metas de sustentabilidade que vão além dos compromissos com a redução das emissões de CO2 nas suas operações.</segment>
    <segment id="18">A marca quer tornar as casas mais sustentáveis</segment>
    <segment id="19">, com produtos que ajudem a mudar hábitos e a reduzir desperdícios.</segment>
    <segment id="20">Para isso</segment>
    <segment id="21">, a estratégia de sustentabilidade do Electrolux Group foi estruturada com base em três pilares</segment>
    <segment id="22">, chamados Melhor Companhia</segment>
    <segment id="23">, Melhores Soluções e Melhor Viver.</segment>
    <segment id="24">Para cada um deles</segment>
    <segment id="25">, a empresa traçou metas específicas e já colhe resultados.  "</segment>
    <segment id="26">Nos últimos anos</segment>
    <segment id="27">, fortalecemos nossa governança em sustentabilidade na América Latina e intensificamos nosso entendimento sobre os hábitos do consumidor.</segment>
    <segment id="28">Queremos estar juntos nessa jornada de transformação por meio do uso correto dos produtos</segment>
    <segment id="29">, do consumo consciente e do descarte responsável.</segment>
    <segment id="30">No ano passado</segment>
    <segment id="31">, por exemplo</segment>
    <segment id="32">, nossos produtos mais eficientes em energia e água representaram 24% do total de unidades vendidas e 39% do lucro bruto</segment>
    <segment id="33">, globalmente.</segment>
    <segment id="34">Temos trabalhado na democratização de tecnologias sustentáveis e na ampliação de diálogos com o consumidor</segment>
    <segment id="35">, para aumentar esse número a cada ano"</segment>
    <segment id="36">, destaca Leandro Jasiocha</segment>
    <segment id="37">, CEO do Electrolux Group na América Latina.</segment>
    <segment id="38">No final de 2022</segment>
    <segment id="39">, uma auditoria independente atestou que o Grupo já reduziu as emissões de gases de efeito estufa três anos antes da meta estabelecida (veja infográfico nesta página).</segment>
    <segment id="40">"Sustentabilidade é transversal no Electrolux Group e nosso programa For the Better 2030 abrange não só as pessoas e operações internas</segment>
    <segment id="41">, masmas acompanha a jornada do consumidor desde o momento em que o produto deixa a nossa operação para alguma casa.</segment>
    <segment id="42">Desde 2021</segment>
    <segment id="43">, na América Latina</segment>
    <segment id="44">, 100% da energia elétrica consumida nas operações já vêm de fontes renováveis e as seis fábricas da região são certificadas</segment>
    <segment id="45">, por auditoria independente</segment>
    <segment id="46">, em Zero Aterro</segment>
    <segment id="47">, o que significa que menos de 1% dos resíduos vão para aterros sanitários.</segment>
    <segment id="48">Além disso</segment>
    <segment id="49">, temos uma frota de meios de transporte verde</segment>
    <segment id="50">, com caminhões elétricos e bicicletas</segment>
    <segment id="51">, que já nos ajudaram a reduzir a emissão de 160 toneladas de CO2"</segment>
    <segment id="52">, afirma Fernando Keske</segment>
    <segment id="53">, diretor de Sustentabilidade em Operações do Electrolux Group na América Latina.  Produtos que mudam hábitos</segment>
    <segment id="54">Com vendas globais de mais de 60 milhões de produtos por ano</segment>
    <segment id="55">, o Electrolux Group investe em tecnologia para lançar eletrodomésticos mais eficientes no consumo de água e energia</segment>
    <segment id="56">, com menos matéria-prima e uso de material reciclado.</segment>
    <segment id="57">"</segment>
    <segment id="58">Hoje 85% do impacto do ciclo de vida de nossos produtos está no uso.</segment>
    <segment id="59">Por isso</segment>
    <segment id="60">, esse é um pilar tão fundamental na nossa estratégia"</segment>
    <segment id="61">, afirma João Zeni</segment>
    <segment id="62">, diretor de Sustentabilidade do Electrolux Group na América Latina.  "</segment>
    <segment id="63">Na cadeia de alimentação e têxtil</segment>
    <segment id="64">, por exemplo</segment>
    <segment id="65">, o Electrolux Group pode contribuir para melhorar o armazenamento e reduzir o desperdício</segment>
    <segment id="66">, além de aumentar a durabilidade das roupas.</segment>
    <segment id="67">Podemos ser uma peça importante nessa mudança</segment>
    <segment id="68">, porque</segment>
    <segment id="69">porque estamos presentes em 67% dos lares brasileiros</segment>
    <segment id="70">, masmas</segment>
    <segment id="71">, para isso</segment>
    <segment id="72">, o diálogo é fundamental"</segment>
    <segment id="73">,", afirma Zeni.</segment>
    <segment id="74">Refrigeradores produzidos na fábrica de Curitiba (PR) já trazem inovações</segment>
    <segment id="75">comocomo gavetas específicas com temperaturas ajustáveis</segment>
    <segment id="76">, que mantêm os alimentos frescos por mais tempo</segment>
    <segment id="77">, prolongando sua durabilidade em até 30%.</segment>
    <segment id="78">A tecnologia AutoSense</segment>
    <segment id="79">, que faz o controle automático de temperatura</segment>
    <segment id="80">, usa inteligência artificial</segment>
    <segment id="81">para que</segment>
    <segment id="82">para que o refrigerador reconheça e aprenda com as rotinas da casa.</segment>
    <segment id="83">Assim, nos momentos de maior uso ou de abertura de portas</segment>
    <segment id="84">, a geladeira fica automaticamente mais fria.</segment>
    <segment id="85">Quando é menos utilizada</segment>
    <segment id="86">, o sistema estabiliza a temperatura.</segment>
    <segment id="87">Eficiência energética é outra preocupação do Electrolux Group.</segment>
    <segment id="88">Além de preservar os alimentos por mais tempo</segment>
    <segment id="89">, os refrigeradores frost free modelos IF56B/IT56S/</segment>
    <segment id="90">IT56 têm a maior eficiência do mercado brasileiro</segment>
    <segment id="91">, com economia de até 47% de energia</segment>
    <segment id="92">, em relação ao mínimo para a classificação</segment>
    <segment id="93">A do Inmetro.  Produtos mais eficientes também geram retorno para os negócios.</segment>
    <segment id="94">Em 2022</segment>
    <segment id="95">, no Brasil</segment>
    <segment id="96">, os eletrodomésticos com maior eficiência de recursos das principais categorias de produtos da empresa representaram 68% do lucro líquido.</segment>
    <segment id="97">"</segment>
    <segment id="98">As pesquisas de tendência mostram que</segment>
    <segment id="99">, para 76% dos consumidores jovens</segment>
    <segment id="100">, a sustentabilidade já faz parte dos critérios de compra"</segment>
    <segment id="101">, conclui Zeni.</segment>
    <segment id="102">O objetivo do Electrolux Group é mostrar aos consumidores que os eletrodomésticos são aliados e facilitadores de hábitos de consumo mais conscientes.</segment>
    <segment id="103">Para isso</segment>
    <segment id="104">, a empresa colocou metas dentro do eixo Melhor Sociedade (veja infográfico nesta página)</segment>
    <segment id="105">, que estimulam diálogos e a conscientização do consumidor</segment>
    <segment id="106">, sendo que uma delas é fazer com que</segment>
    <segment id="107">, até 2030</segment>
    <segment id="108">, as roupas durem o dobro do tempo com metade do impacto ambiental.</segment>
    <segment id="109">Para isso</segment>
    <segment id="110">, lançou lavadoras</segment>
    <segment id="111">, conhecidas</segment>
    <segment id="112">comocomo máquinas de cuidar</segment>
    <segment id="113">, que reduzem em até 50% o desgaste das roupas e em até 35% o desbotamento das cores.</segment>
    <segment id="114">A tecnologia foi desenvolvida para lavar as roupas de forma mais suave e eficiente</segment>
    <segment id="115">, para que</segment>
    <segment id="116">para que possam ser usadas mais vezes.</segment>
    <segment id="117">Além disso</segment>
    <segment id="118">, até 50 litros de água são economizados a cada lavagem.</segment>
    <segment id="119">Só no Brasil</segment>
    <segment id="120">, estima-</segment>
    <segment id="121">sese que as máquinas de lavar mais eficientes da marca geraram</segment>
    <segment id="122">, em 2022</segment>
    <segment id="123">, uma economia potencial estimada em 3 bilhões de litros de água na casa do consumidor.</segment>
    <segment id="124">Isso equivale ao volume de cerca de 1.500 piscinas olímpicas.</segment>
    <segment id="125">A marca lançou a campanha "Roupa</segment>
    <segment id="126">Sem Data</segment>
    <segment id="127">De Validade"</segment>
    <segment id="128">, com o objetivo de inspirar e convidar o consumidor a estabelecer uma nova relação de cuidado com as roupas</segment>
    <segment id="129">, por meio do consumo consciente.</segment>
    <segment id="130">Estima-</segment>
    <segment id="131">sese que</segment>
    <segment id="132">, ao prolongar em pelo menos 9 meses a vida útil das roupas</segment>
    <segment id="133">, é possível reduzir a pegada de carbono</segment>
    <segment id="134">, os resíduos e a água de 20% a 30%.</segment>
    <segment id="135">Do começo ao fim da cadeia</segment>
    <segment id="136">A Electrolux foi também a primeira marca de linha branca no Brasil a fornecer um serviço de coleta e descarte de eletrodomésticos usados de qualquer marca no momento da entrega de um novo modelo</segment>
    <segment id="137">, adquirido pela loja online da marca.</segment>
    <segment id="138">Desde o seu lançamento</segment>
    <segment id="139">, o Serviço de Coleta e Descarte Consciente já recolheu quase 3.000 produtos e gerou 90 toneladas de materiais reaproveitados</segment>
    <segment id="140">, além de fazer com que a empresa deixasse de emitir 45 toneladas de CO2 em transportes.</segment>
    <segment id="141">Atualmente</segment>
    <segment id="142">, a iniciativa está disponível para compras realizadas em mais de 85% do território nacional</segment>
    <segment id="143">, e a empresa busca uma ampliação que cubra todo o Brasil até o fim de 2023.</segment>
    <segment id="144">E a busca por sustentabilidade não para.</segment>
    <segment id="145">"</segment>
    <segment id="146">Em 2025 iniciaremos uma nova operação em São José dos Pinhais (PR)</segment>
    <segment id="147">, que será 100% sustentável</segment>
    <segment id="148">, da construção à operação"</segment>
    <segment id="149">, afirma Fernando Keske.</segment>
    <segment id="150">A fábrica adotará práticas de controle do desperdício de matérias-primas</segment>
    <segment id="151">, construção eficiente apoiada pelo LEED (certificação para empreendimentos sustentáveis)</segment>
    <segment id="152">, zero resíduos para aterro</segment>
    <segment id="153">, zero emissões de carbono e gases de efeito estufa</segment>
    <segment id="154">, utilização de energia elétrica renovável</segment>
    <segment id="155">, consumo eficiente e reuso de energias</segment>
    <segment id="156">, coleta da água da chuva e reaproveitamento de efluentes industriais/sanitários.</segment>
  </rst>
</analysis>