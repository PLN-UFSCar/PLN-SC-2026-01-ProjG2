  <rst>
    <segment id="1">A cineasta Tata Amaral ("Antonia" e "Sequestro Relâmpago") embarcou nesta segunda-feira (15) para o Festival de Cannes</segment>
    <segment id="2">, na França</segment>
    <segment id="3">, em busca de coprodutores internacionais para seu novo projeto.</segment>
    <segment id="4">A cineasta Tata Amaral na abertura do festival</segment>
    <segment id="5">É Tudo Verdade</segment>
    <segment id="6">, em São Paulo - Mathilde Missioneiro - 12.abr.2022/FolhapressIntitulado "</segment>
    <segment id="7">Sexo e Luta"</segment>
    <segment id="8">, o longa narra a história de uma jovem eleita para a prefeitura de uma grande cidade que precisa lidar com grandes corporações imobiliárias ao mesmo em que sua mãe</segment>
    <segment id="9">, uma cineasta</segment>
    <segment id="10">, está lançando um filme sobre suas aventuras amorosas.</segment>
    <segment id="11">O roteiro é escrito por Tata e pelo diretor Marcelo Caetano ("Corpo Elétrico").</segment>
    <segment id="12">A cineasta paulista ainda vai participar</segment>
    <segment id="13">, durante sua viagem à Riviera Francesa</segment>
    <segment id="14">, de um evento para produtores no Marché du Filme</segment>
    <segment id="15">, braço empresarial do festival.</segment>
    <segment id="16">REGÊNCIA  Concerto &amp;#</segment>
    <segment id="17">039;Israel 75 anos - Yom Haatzmaut&amp;#039</segment>
    <segment id="18">;Mais    novamente         de   de  de  representando um</segment>
    <segment id="19">A apresentadora Didi Wagner prestigiou o "Concerto</segment>
    <segment id="20">Israel 75 anos</segment>
    <segment id="21">– Yom Haatzmaut"</segment>
    <segment id="22">, ocorrido no Clube Hebraica de São Paulo</segment>
    <segment id="23">, na semana passada.</segment>
    <segment id="24">O presidente do grupo Bandeirantes</segment>
    <segment id="25">, Johnny Saad</segment>
    <segment id="26">, também compareceu ao evento</segment>
    <segment id="27">, realizado em celebração aos 75 anos da criação do Estado de Israel.</segment>
    <segment id="28">A secretária municipal de Segurança Urbana de São Paulo</segment>
    <segment id="29">, Elza Paulina de Souza</segment>
    <segment id="30">, passou por lá.  com BIANKA VIEIRA</segment>
    <segment id="31">, KARINA MATIAS e MANOELLA SMITH</segment>
  </rst>
