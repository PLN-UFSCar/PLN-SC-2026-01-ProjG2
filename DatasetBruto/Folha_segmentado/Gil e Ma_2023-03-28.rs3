  <rst>
    <segment id="1">O Rio2C</segment>
    <segment id="2">, festival dedicado à indústria criativa</segment>
    <segment id="3">, promoverá um encontro entre o cantor Gilberto Gil e o diretor Andrucha Waddington para revisitar a parceria de décadas dos dois no audiovisual.</segment>
    <segment id="4">A conversa entre eles será mediada pela produtora Flora Gil</segment>
    <segment id="5">, esposa do artista baiano.</segment>
    <segment id="6">O cantor Gilberto Gil durante o Coala Festival</segment>
    <segment id="7">,no Memorial da América Latina</segment>
    <segment id="8">, em São Paulo - Mathilde Missioneiro - 16.set.2022/FolhapressDesde os anos 1990</segment>
    <segment id="9">, Waddington dirigiu 11 dos 17 projetos com Gil feitos pela produtora Conspiração</segment>
    <segment id="10">, em que é um dos diretores.</segment>
    <segment id="11">Entre as produções assinadas por ele estão os longas "Tempo Rei Gilberto Gil" (1996) e "Doces Bárbaros" (2002)</segment>
    <segment id="12">, a série documental "</segment>
    <segment id="13">Em Casa com os Gil" (2022) e o ainda inédito "</segment>
    <segment id="14">Viajando com os Gil"</segment>
    <segment id="15">, que registra a turnê europeia mais recente do cantor.</segment>
    <segment id="16">O Rio2C será realizado entre os dias 11 e 16 de abril</segment>
    <segment id="17">, na Cidade das Artes</segment>
    <segment id="18">, no Rio de Janeiro.</segment>
    <segment id="19">Além da presença de Gil</segment>
    <segment id="20">, que é ex-ministro da Cultura</segment>
    <segment id="21">, o evento levará aos seus palcos a atual chefe da pasta</segment>
    <segment id="22">, Margareth Menezes.</segment>
    <segment id="23">A expectativa é que a ministra apresente e detalhe projetos do MinC.  Saiba quem é quem no Ministério da Cultura de Margareth MenezesMais    novamente         de   de  de  representando um    DONA DE MIM</segment>
    <segment id="24">A cantora Iza</segment>
    <segment id="25">, em ensaio fotográfico feito na sede da Fendi</segment>
    <segment id="26">, em Roma</segment>
    <segment id="27">, na Itália - Federico Barbieri/MKS Milano/Divulgação</segment>
    <segment id="28">A cantora Iza estampará a capa digital da edição de abril da Marie Claire.</segment>
    <segment id="29">Fotografada na sede da grife Fendi</segment>
    <segment id="30">, em Roma</segment>
    <segment id="31">, a artista falou à publicação sobre temas</segment>
    <segment id="32">comocomo trabalho</segment>
    <segment id="33">, privilégios</segment>
    <segment id="34">, machismo e colorismo.</segment>
    <segment id="35">"</segment>
    <segment id="36">Para uma mulher retinta</segment>
    <segment id="37">comocomo eu</segment>
    <segment id="38">, ser vista</segment>
    <segment id="39">comocomo padrão de beleza era impensável.</segment>
    <segment id="40">Quando você não</segment>
    <segment id="41">sese enxerga nos lugares</segment>
    <segment id="42">, é difícil sonhar com este lugar"</segment>
    <segment id="43">, afirmou.</segment>
    <segment id="44">Iza contou</segment>
    <segment id="45">, pela primeira vez</segment>
    <segment id="46">, como</segment>
    <segment id="47">como conheceu o seu namorado</segment>
    <segment id="48">, o jogador Yuri Lima</segment>
    <segment id="49">, do Mirassol.</segment>
    <segment id="50">E não usou meias palavras ao falar sobre sexo: "</segment>
    <segment id="51">Não posso desperdiçar minha energia sexual com qualquer pessoa.</segment>
    <segment id="52">Se for para gozar</segment>
    <segment id="53">, gozo bem sozinha".</segment>
    <segment id="54">A Marie Claire chega às bancas em 5 de abril.  com CLEO GUIMARÃES (interina)</segment>
    <segment id="55">, BIANKA VIEIRA</segment>
    <segment id="56">, KARINA MATIAS e MANOELLA SMITH</segment>
  </rst>
</analysis>