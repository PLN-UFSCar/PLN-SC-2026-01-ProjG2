  <rst>
    <segment id="1">A Anatel (Agência Nacional de Telecomunicações) antecipou a liberação de sinal 5</segment>
    <segment id="2">G</segment>
    <segment id="3">em mais de 78 municípios próximos a capitais ou cidades com mais de 500 mil habitantes.</segment>
    <segment id="4">As operadoras que compraram direito de operar na frequência da telefonia de quinta geração precisam solicitar à agência a ativação de estações.</segment>
    <segment id="5">Na lista estão cidades da Grande São Paulo</segment>
    <segment id="6">comocomo Cotia</segment>
    <segment id="7">, Barueri</segment>
    <segment id="8">, Mauá e Embu das Artes.</segment>
    <segment id="9">A instalação antecipada da nova infraestrutura de internet móvel nessas cidades depende do planejamento individual de cada prestadora</segment>
    <segment id="10">, de acordo com a Anatel.</segment>
    <segment id="11">Anatel (Agência Nacional de Telecomunicações) vai liberar a partir desta quarta-feira (25) a ativação do sinal 5G em 178 cidades.</segment>
    <segment id="12">- Roberto Casimiro/Fotoarena/Agência</segment>
    <segment id="13">O GloboDisponibilizar o sinal 5G depende da limpeza da faixa de frequência de 3</segment>
    <segment id="14">,5 GHz —espécie de avenida no ar pela qual trafegam ondas de telefonia</segment>
    <segment id="15">, televisão e rádio.</segment>
    <segment id="16">Para funcionar sem interferência e garantir mais velocidade</segment>
    <segment id="17">, apenas o sinal 5</segment>
    <segment id="18">G deve ocupar esse espaço.</segment>
    <segment id="19">Até o final do semestre</segment>
    <segment id="20">, a Anatel planeja incluir na área de cobertura 5</segment>
    <segment id="21">G centenas de municípios</segment>
    <segment id="22">e estima alcançar 1.610 cidades.</segment>
    <segment id="23">O informe foi divulgado pelo Grupo de Acompanhamento da Implantação de Soluções para os Problemas de Interferência (Gaispi)</segment>
    <segment id="24">, que enfrenta as falhas na rede.</segment>
    <segment id="25">Hoje, 140 municípios</segment>
    <segment id="26">, que abrigam 38</segment>
    <segment id="27">,5% da população</segment>
    <segment id="28">, estão aptos a utilizar estações de "5</segment>
    <segment id="29">G puro</segment>
    <segment id="30">".</segment>
    <segment id="31">Folha MercadoReceba no seu email o que de mais importante acontece na economia</segment>
    <segment id="32">; aberta para não assinantes.</segment>
    <segment id="33">Carregando...</segment>
    <segment id="34">Veja as cidades que terão a faixa liberada amanhã:</segment>
    <segment id="35">No estado de São Paulo</segment>
    <segment id="36">Alumínio Araçoiaba da Serra</segment>
    <segment id="37">Arujá</segment>
    <segment id="38">Barueri</segment>
    <segment id="39">Caieiras</segment>
    <segment id="40">Cajamar Carapicuíba Cotia</segment>
    <segment id="41">Cravinhos</segment>
    <segment id="42">Embu</segment>
    <segment id="43">das Artes</segment>
    <segment id="44">Embu-Guaçu Ferraz de Vasconcelos Francisco Morato Franco da Rocha Guararema Hortolândia Indaiatuba Itapecerica da Serra Itapevi Itaquaquecetuba Itu Itupeva Jacareí Jaguariúna Jambeiro Jandira Mairinque Mairiporã Mauá Mogi das Cruzes Monte Mor Pirapora do Bom Jesus Poá Ribeirão Pires Rio Grande da Serra Santa Isabel Santana de Parnaíba São Lourenço da Serra Serrana Sumaré Suzano Taboão da Serra Valinhos Vargem Grande Paulista Votorantim</segment>
    <segment id="45">Em Minas Gerais   Betim Chácara Coronel Pacheco Ibirité Igarapé Mário Campos Matias Barbosa Ribeirão das Neves São Joaquim de Bicas Sarzedo</segment>
    <segment id="46">Em Santa Catarina   Araquari Balneário Barra do Sul Garuva Guaramirim Schroeder</segment>
    <segment id="47">No Pará   Benevides Marituba Santa Bárbara do Pará Santa Izabel do Pará</segment>
    <segment id="48">No Espírito Santo</segment>
    <segment id="49">Cariacica Fundão Guarapari Viana</segment>
    <segment id="50">No Rio Grande do Sul</segment>
    <segment id="51">Farroupilha Flores da Cunha São Marcos   No Paraná   Ibiporã Tamarana</segment>
    <segment id="52">Em Pernambuco   Cabo de Santo Agostinho Camaragibe   No Rio de Janeiro   Japeri Queimados</segment>
    <segment id="53">Na Bahia   São Gonçalo dos Campos   ComboA newsletter da Folha com o que interessa sobre a indústria de games e com as dicas do que você ainda vai jogar.</segment>
    <segment id="54">Carregando...</segment>
    <segment id="55">Solicite kit para evitar interferências</segment>
    <segment id="56">Quem recebe as transmissões de TV aberta via antena parabólica precisa adaptar o equipamento para evitar interferências.</segment>
    <segment id="57">Pessoas com inscrição em qualquer programa social do governo e uma antena parabólica instalada no imóvel podem pedir gratuitamente acesso ao kit que previne interferências entre as ondas de televisão e as de conexão 5G.</segment>
    <segment id="58">A entidade responsável pela frequência da nova rede móvel</segment>
    <segment id="59">, a Siga Antenado</segment>
    <segment id="60">, também instala os novos equipamentos.</segment>
    <segment id="61">O serviço requer agendamento</segment>
    <segment id="62">, disponível neste site.</segment>
    <segment id="63">Não inscritos no Cadastro Único precisam comprar o adaptador e arcar com a instalação.</segment>
    <segment id="64">Quem utiliza antenas digitais não precisa fazer adaptações.</segment>
    <segment id="65">Mais informações estão disponíveis no site da Siga Antenado ou pelo telefone 0800-729-2404.</segment>
    <segment id="66">Celular e internet avançam em lares brasileiros</segment>
    <segment id="67">; TV e computador caemMais    novamente         de   de  de  representando um</segment>
  </rst>
