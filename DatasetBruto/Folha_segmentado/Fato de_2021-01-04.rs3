  </header>
  <rst>
    <segment id="1">O esfor&amp;ccedil</segment>
    <segment id="2">;o incessante do presidente Donald Trump para reverter o resultado da elei&amp;ccedil</segment>
    <segment id="3">;&amp;atilde</segment>
    <segment id="4">;o que ele perdeu</segment>
    <segment id="5">sese tornou o teste de tens&amp;atilde</segment>
    <segment id="6">;o mais s&amp;eacute</segment>
    <segment id="7">;rio para a democracia americana em v&amp;aacute</segment>
    <segment id="8">;rias gera&amp;ccedil</segment>
    <segment id="9">;&amp;otilde</segment>
    <segment id="10">;es, conduzido n&amp;atilde</segment>
    <segment id="11">;o por revolucion&amp;aacute</segment>
    <segment id="12">;rios de fora decididos a derrubar o sistema</segment>
    <segment id="13">, masmas pelo pr&amp;oacute</segment>
    <segment id="14">;prio l&amp;iacute</segment>
    <segment id="15">;der encarregado de defend&amp;ecirc</segment>
    <segment id="16">;-lo.</segment>
    <segment id="17">Nos 220 anos desde que John Adams</segment>
    <segment id="18">, derrotado</segment>
    <segment id="19">, entregou a Casa Branca a seu rival</segment>
    <segment id="20">, estabelecendo firmemente a transfer&amp;ecirc</segment>
    <segment id="21">;ncia pac&amp;iacute</segment>
    <segment id="22">;fica de poder</segment>
    <segment id="23">comocomo princ&amp;iacute</segment>
    <segment id="24">;pio fundamental</segment>
    <segment id="25">, nenhum presidente no cargo que perdeu a elei&amp;ccedil</segment>
    <segment id="26">;&amp;atilde</segment>
    <segment id="27">;o tentou</segment>
    <segment id="28">sese agarrar ao poder rejeitando o Col&amp;eacute</segment>
    <segment id="29">;gio Eleitoral e subvertendo a vontade dos eleitores &amp;mdash</segment>
    <segment id="30">;at&amp;eacute</segment>
    <segment id="31">; agora.</segment>
    <segment id="32">&amp;Eacute</segment>
    <segment id="33">; um roteiro ao mesmo tempo totalmente impens&amp;aacute</segment>
    <segment id="34">;vel, por&amp;eacute</segment>
    <segment id="35">;m temido desde o in&amp;iacute</segment>
    <segment id="36">;cio do mandato de Trump.</segment>
    <segment id="37">O presidente Donald Trump fala com jornalistas após conferência com membros do exército no Dia de Ação de Graças - Andrew Caballero Reynolds - 26.nov.20/AFPO presidente foi muito al&amp;eacute</segment>
    <segment id="38">;m de simplesmente expressar suas queixas ou de criar uma narrativa salvadora para explicar a derrota</segment>
    <segment id="39">, como</segment>
    <segment id="40">como assessores sugeriram em particular a ele nos dias ap&amp;oacute</segment>
    <segment id="41">;s a vota&amp;ccedil</segment>
    <segment id="42">;&amp;atilde</segment>
    <segment id="43">;o em 3 de novembro.</segment>
    <segment id="44">Em vez disso</segment>
    <segment id="45">, Trump for&amp;ccedil</segment>
    <segment id="46">;ou os limites da tradi&amp;ccedil</segment>
    <segment id="47">;&amp;atilde</segment>
    <segment id="48">;o, da propriedade e da lei para encontrar qualquer maneira poss&amp;iacute</segment>
    <segment id="49">;vel de</segment>
    <segment id="50">sese agarrar ao cargo al&amp;eacute</segment>
    <segment id="51">;m de seu mandato</segment>
    <segment id="52">, que expira em duas semanas.</segment>
    <segment id="53">O fato de que ele quase certamente falhar&amp;aacute</segment>
    <segment id="54">; n&amp;atilde</segment>
    <segment id="55">;o diminui o dano que est&amp;aacute</segment>
    <segment id="56">; causando &amp;agrave</segment>
    <segment id="57">; democracia</segment>
    <segment id="58">, ao minar a confian&amp;ccedil</segment>
    <segment id="59">;a p&amp;uacute</segment>
    <segment id="60">;blica no sistema eleitoral.</segment>
    <segment id="61">Seu telefonema de uma hora no fim de semana para a maior autoridade eleitoral da Ge&amp;oacute</segment>
    <segment id="62">;rgia, Brad Raffensperger</segment>
    <segment id="63">, pressionando-o a &amp;quot</segment>
    <segment id="64">;encontrar&amp;quot</segment>
    <segment id="65">; votos suficientes para anular a vit&amp;oacute</segment>
    <segment id="66">;ria do presidente eleito</segment>
    <segment id="67">, Joe Biden</segment>
    <segment id="68">, naquele estado s&amp;oacute</segment>
    <segment id="69">; p&amp;ocirc</segment>
    <segment id="70">;s em destaque o que Trump vem fazendo h&amp;aacute</segment>
    <segment id="71">; semanas.</segment>
    <segment id="72">Ele telefonou aos governadores republicanos da Ge&amp;oacute</segment>
    <segment id="73">;rgia e do Arizona para faz&amp;ecirc</segment>
    <segment id="74">;-los intervir.</segment>
    <segment id="75">Convocou os l&amp;iacute</segment>
    <segment id="76">;deres republicanos do Legislativo de Michigan &amp;agrave</segment>
    <segment id="77">;</segment>
    <segment id="78">Casa Branca para pression&amp;aacute</segment>
    <segment id="79">;-los a alterar os resultados em seu estado.</segment>
    <segment id="80">Ele ligou para o presidente republicano da C&amp;acirc</segment>
    <segment id="81">;mara da Pensilv&amp;acirc</segment>
    <segment id="82">;nia por duas vezes para tentar o mesmo.</segment>
    <segment id="83">Veja imagens dos protestos a favor de Trump em WashingtonMais    novamente         de   de  de  representando um  Ele e sua equipe aventaram a ideia de retardar a posse de Biden</segment>
    <segment id="84">, que est&amp;aacute</segment>
    <segment id="85">; gravada em pedra pela Constitui&amp;ccedil</segment>
    <segment id="86">;&amp;atilde</segment>
    <segment id="87">;o, e Trump</segment>
    <segment id="88">sese reuniu com um ex-assessor pedindo-lhe para declarar a lei marcial.</segment>
    <segment id="89">Seu comportamento err&amp;aacute</segment>
    <segment id="90">;tico alarmou tanto os militares de que ele poderia tentar usar a for&amp;ccedil</segment>
    <segment id="91">;a para ficar na Casa Branca que todos os ex-secret&amp;aacute</segment>
    <segment id="92">;rios da Defesa vivos &amp;</segment>
    <segment id="93">mdash;incluindo dois que ele mesmo nomeou&amp;mdash</segment>
    <segment id="94">; emitiram uma advert&amp;ecirc</segment>
    <segment id="95">;ncia contra o envolvimento das For&amp;ccedil</segment>
    <segment id="96">;as Armadas.</segment>
    <segment id="97">E ele incentivou o vice-presidente Mike Pence e legisladores aliados a fazer o que pudessem para bloquear a declara&amp;ccedil</segment>
    <segment id="98">;&amp;atilde</segment>
    <segment id="99">;o formal da vit&amp;oacute</segment>
    <segment id="100">;ria de Biden quando o Congresso</segment>
    <segment id="101">sese reunir nesta quarta-feira (6)</segment>
    <segment id="102">, tentando transformar um momento cerimonial hist&amp;oacute</segment>
    <segment id="103">;rico em um &amp;uacute</segment>
    <segment id="104">;ltimo duelo sobre a elei&amp;ccedil</segment>
    <segment id="105">;&amp;atilde</segment>
    <segment id="106">;o.</segment>
    <segment id="107">A ideia perturbou at&amp;eacute</segment>
    <segment id="108">; mesmo muitos republicanos veteranos</segment>
    <segment id="109">, e certamente dever&amp;aacute</segment>
    <segment id="110">; fracassar</segment>
    <segment id="111">, para frustra&amp;ccedil</segment>
    <segment id="112">;&amp;atilde</segment>
    <segment id="113">;o do presidente.  &amp;quot</segment>
    <segment id="114">;O &amp;#</segment>
    <segment id="115">39;C&amp;aacute</segment>
    <segment id="116">;ucus da Rendi&amp;ccedil</segment>
    <segment id="117">;&amp;atilde</segment>
    <segment id="118">;o&amp;#39</segment>
    <segment id="119">; do Partido Republicano cair&amp;aacute</segment>
    <segment id="120">; na inf&amp;acirc</segment>
    <segment id="121">;mia como</segment>
    <segment id="122">como &amp;#</segment>
    <segment id="123">39;guardi&amp;otilde</segment>
    <segment id="124">;es&amp;#39</segment>
    <segment id="125">; fracos e ineficazes de nossa na&amp;ccedil</segment>
    <segment id="126">;&amp;atilde</segment>
    <segment id="127">;o, que</segment>
    <segment id="128">sese dispuseram a aceitar a certifica&amp;ccedil</segment>
    <segment id="129">;&amp;atilde</segment>
    <segment id="130">;o de n&amp;uacute</segment>
    <segment id="131">;meros presidenciais fraudulentos!&amp;quot</segment>
    <segment id="132">;, escreveu Trump no Twitter na segunda (4)</segment>
    <segment id="133">, rapidamente atraindo uma advert&amp;ecirc</segment>
    <segment id="134">;ncia da rede social.</segment>
    <segment id="135">Ele negou subverter a democracia</segment>
    <segment id="136">, postando uma frase que atribuiu ao senador Ron Johnson</segment>
    <segment id="137">, de Wisconsin</segment>
    <segment id="138">, um de seus aliados republicanos: &amp;quot</segment>
    <segment id="139">;N&amp;atilde</segment>
    <segment id="140">;o estamos agindo para frustrar o processo democr&amp;aacute</segment>
    <segment id="141">;tico, estamos agindo para proteg&amp;ecirc</segment>
    <segment id="142">;-lo&amp;quot</segment>
    <segment id="143">;.</segment>
    <segment id="144">Mas os esfor&amp;ccedil</segment>
    <segment id="145">;os de Trump soam familiares a muitos que estudaram os regimes autorit&amp;aacute</segment>
    <segment id="146">;rios em pa&amp;iacute</segment>
    <segment id="147">;ses do mundo todo</segment>
    <segment id="148">, como</segment>
    <segment id="149">como os dirigidos pelo presidente Vladimir Putin na R&amp;uacute</segment>
    <segment id="150">;ssia e pelo premi&amp;ecirc</segment>
    <segment id="151">; Viktor Orb&amp;aacute</segment>
    <segment id="152">;n na Hungria.</segment>
    <segment id="153">Americanos comemoram nas ruas a vitória de Joe Biden na eleiçãoMais    novamente         de   de  de  representando um  &amp;quot</segment>
    <segment id="154">;A tentativa de Trump de derrubar a elei&amp;ccedil</segment>
    <segment id="155">;&amp;atilde</segment>
    <segment id="156">;o e sua t&amp;aacute</segment>
    <segment id="157">;tica de press&amp;atilde</segment>
    <segment id="158">;o com essa finalidade com Brad Raffensperger s&amp;atilde</segment>
    <segment id="159">;o um exemplo de</segment>
    <segment id="160">comocomo funciona o autoritarismo no s&amp;eacute</segment>
    <segment id="161">;culo 21&amp;quot</segment>
    <segment id="162">;, disse Ruth Ben-Ghiat</segment>
    <segment id="163">, autora de &amp;quot</segment>
    <segment id="164">;Strongmen: From Mussolini to the Present&amp;quot</segment>
    <segment id="165">; (homens-fortes: de Mussolini at&amp;eacute</segment>
    <segment id="166">; hoje).  &amp;</segment>
    <segment id="167">quot;Os l&amp;iacute</segment>
    <segment id="168">;deres de hoje chegam por meio de elei&amp;ccedil</segment>
    <segment id="169">;&amp;otilde</segment>
    <segment id="170">;es e depois manipulam as elei&amp;ccedil</segment>
    <segment id="171">;&amp;otilde</segment>
    <segment id="172">;es para continuar no cargo &amp;mdash</segment>
    <segment id="173">;at&amp;eacute</segment>
    <segment id="174">; que tenham poder suficiente para for&amp;ccedil</segment>
    <segment id="175">;ar os &amp;</segment>
    <segment id="176">oacute</segment>
    <segment id="177">;rg&amp;atilde</segment>
    <segment id="178">;os legislativos a mant&amp;ecirc</segment>
    <segment id="179">;-los l&amp;aacute</segment>
    <segment id="180">; indefinidamente.&amp;quot</segment>
    <segment id="181">;</segment>
    <segment id="182">As afirma&amp;ccedil</segment>
    <segment id="183">;&amp;otilde</segment>
    <segment id="184">;es de Trump de que a elei&amp;ccedil</segment>
    <segment id="185">;&amp;atilde</segment>
    <segment id="186">;o foi de certa forma roubada n&amp;atilde</segment>
    <segment id="187">;o conquistaram apoio em dezenas de tribunais que ele e seus aliados acionaram</segment>
    <segment id="188">, incluindo a Suprema Corte</segment>
    <segment id="189">, com tr&amp;ecirc</segment>
    <segment id="190">;s ju&amp;iacute</segment>
    <segment id="191">;zes que ele mesmo nomeou.</segment>
    <segment id="192">Autoridades eleitorais republicanas em estados-p&amp;ecirc</segment>
    <segment id="193">;ndulo</segment>
    <segment id="194">comocomo Raffensperger rejeitaram suas alega&amp;ccedil</segment>
    <segment id="195">;&amp;otilde</segment>
    <segment id="196">;es como</segment>
    <segment id="197">como falsas.</segment>
    <segment id="198">At&amp;eacute</segment>
    <segment id="199">; o procurador-geral (secret&amp;aacute</segment>
    <segment id="200">;rio de Justi&amp;ccedil</segment>
    <segment id="201">;a) de Trump</segment>
    <segment id="202">, William Barr</segment>
    <segment id="203">, disse que n&amp;atilde</segment>
    <segment id="204">;o viu fraude generalizada que pudesse alterar o resultado da elei&amp;ccedil</segment>
    <segment id="205">;&amp;atilde</segment>
    <segment id="206">;o.</segment>
    <segment id="207">Mas isso n&amp;atilde</segment>
    <segment id="208">;o dissuadiu o presidente.</segment>
    <segment id="209">A fidelidade de Trump ao conceito americano de democracia &amp;eacute</segment>
    <segment id="210">; discutida h&amp;aacute</segment>
    <segment id="211">; tempo.</segment>
    <segment id="212">Ele manifestou admira&amp;ccedil</segment>
    <segment id="213">;&amp;atilde</segment>
    <segment id="214">;o por homens-fortes</segment>
    <segment id="215">comocomo Putin</segment>
    <segment id="216">, Orb&amp;aacute</segment>
    <segment id="217">;n, Xi Jinping</segment>
    <segment id="218">, da China</segment>
    <segment id="219">, e Recep Tayyip Erdogan</segment>
    <segment id="220">, da Turquia</segment>
    <segment id="221">, revelando inveja de sua capacidade de agir decisivamente sem as restri&amp;ccedil</segment>
    <segment id="222">;&amp;otilde</segment>
    <segment id="223">;es de um governo democr&amp;aacute</segment>
    <segment id="224">;tico.</segment>
    <segment id="225">Ele afirmou em v&amp;aacute</segment>
    <segment id="226">;rios momentos que a Constitui&amp;ccedil</segment>
    <segment id="227">;&amp;atilde</segment>
    <segment id="228">;o &amp;quot</segment>
    <segment id="229">;me permite fazer o que eu quiser&amp;quot</segment>
    <segment id="230">;</segment>
    <segment id="231">com o advogado especial que o investigava e que teria &amp;quot</segment>
    <segment id="232">;autoridade total&amp;quot</segment>
    <segment id="233">; para ordenar que os estados acatassem seus desejos.</segment>
    <segment id="234">Ele tentou transformar &amp;</segment>
    <segment id="235">oacute</segment>
    <segment id="236">;rg&amp;atilde</segment>
    <segment id="237">;os do governo em instrumentos de poder pol&amp;iacute</segment>
    <segment id="238">;tico, pressionando o Departamento de Justi&amp;ccedil</segment>
    <segment id="239">;a a processar seus inimigos e facilitar as coisas a seus amigos.</segment>
    <segment id="240">Fez amplo uso de decretos executivos que</segment>
    <segment id="241">, para os tribunais</segment>
    <segment id="242">, &amp;agrave</segment>
    <segment id="243">;s vezes foram longe demais.</segment>
    <segment id="244">Ele foi condenado ao impeachment pela C&amp;acirc</segment>
    <segment id="245">;mara em 2019 por abuso de poder</segment>
    <segment id="246">, ao pressionar a Ucr&amp;acirc</segment>
    <segment id="247">;nia para ajud&amp;aacute</segment>
    <segment id="248">;-lo a sujar a reputa&amp;ccedil</segment>
    <segment id="249">;&amp;atilde</segment>
    <segment id="250">;o de Biden</segment>
    <segment id="251">, e depois absolvido pelo Senado no ano passado.</segment>
    <segment id="252">Desde seus primeiros dias de campanha</segment>
    <segment id="253">, os cr&amp;iacute</segment>
    <segment id="254">;ticos sugeriram que ele abrigava tend&amp;ecirc</segment>
    <segment id="255">;ncias autocr&amp;aacute</segment>
    <segment id="256">;ticas que levantavam perguntas sobre</segment>
    <segment id="257">sese um dia subverteria a democracia ou tentaria</segment>
    <segment id="258">sese manter no poder mesmo que perdesse &amp;mdash</segment>
    <segment id="259">;perguntas que</segment>
    <segment id="260">sese tornaram t&amp;atilde</segment>
    <segment id="261">;o intensas que ele</segment>
    <segment id="262">sese sentiu obrigado a responder: &amp;quot</segment>
    <segment id="263">;N&amp;atilde</segment>
    <segment id="264">;o h&amp;aacute</segment>
    <segment id="265">; ningu&amp;eacute</segment>
    <segment id="266">;m menos fascista que Donald Trump&amp;quot</segment>
    <segment id="267">;, insistiu em 2016.</segment>
    <segment id="268">Mesmo assim</segment>
    <segment id="269">, Trump pouco fez para dissipar esses temores nos anos seguintes:</segment>
    <segment id="270">sugeriu que a elei&amp;ccedil</segment>
    <segment id="271">;&amp;atilde</segment>
    <segment id="272">;o de novembro fosse adiada e</segment>
    <segment id="273">sese recusou a prometer uma transfer&amp;ecirc</segment>
    <segment id="274">;ncia pac&amp;iacute</segment>
    <segment id="275">;fica do poder</segment>
    <segment id="276">casocaso perdesse.</segment>
    <segment id="277">Mesmo agora</segment>
    <segment id="278">, apenas duas semanas antes do fim de seu mandato</segment>
    <segment id="279">, Trump causa d&amp;uacute</segment>
    <segment id="280">;vidas sobre</segment>
    <segment id="281">comocomo deixar&amp;aacute</segment>
    <segment id="282">; a Casa Branca quando Biden for empossado.</segment>
    <segment id="283">O que ele poderia tentar para impedir isso n&amp;atilde</segment>
    <segment id="284">;o est&amp;aacute</segment>
    <segment id="285">; claro</segment>
    <segment id="286">, pois</segment>
    <segment id="287">pois aparentemente n&amp;atilde</segment>
    <segment id="288">;o tem op&amp;ccedil</segment>
    <segment id="289">;&amp;otilde</segment>
    <segment id="290">;es.</segment>
    <segment id="291">Mas ainda n&amp;atilde</segment>
    <segment id="292">;o est&amp;aacute</segment>
    <segment id="293">; disposto a admitir a realidade de sua situa&amp;ccedil</segment>
    <segment id="294">;&amp;atilde</segment>
    <segment id="295">;o e seguir o exemplo de John Adams.</segment>
  </rst>
</analysis>