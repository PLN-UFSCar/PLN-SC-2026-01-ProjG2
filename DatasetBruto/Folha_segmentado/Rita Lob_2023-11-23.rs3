  <rst>
    <segment id="1">Depois de duas décadas apresentando programas culinários no canal pago GNT</segment>
    <segment id="2">, Rita Lobo finalmente estreia na TV aberta.</segment>
    <segment id="3">Cada um dos quatro episódios da série documental Prato Feito Brasil foi gravado numa capital diferente —Belém</segment>
    <segment id="4">, Belo Horizonte</segment>
    <segment id="5">, Porto Alegre e Salvador.</segment>
    <segment id="6">Lobo investiga as diversas maneiras regionais de</segment>
    <segment id="7">sese preparar arroz</segment>
    <segment id="8">, feijão</segment>
    <segment id="9">, carne e verduras</segment>
    <segment id="10">, os quatro pilares da nossa cozinha.</segment>
    <segment id="11">Rita Lobo na gravação do Prato Feito Brasil - Amanda Tropicana/Divulgação</segment>
    <segment id="12">A direção é da Patrícia Carvalho.  Globo</segment>
    <segment id="13">, 23h15</segment>
    <segment id="14">, livre</segment>
    <segment id="15">Julia  Chega à segunda temporada a série sobre Julia Child</segment>
    <segment id="16">, que apresentou por anos o programa de receitas de maior sucesso da TV americana.</segment>
