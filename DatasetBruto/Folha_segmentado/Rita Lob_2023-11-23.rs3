    <segment id="21">De Volta à Grande Festa</segment>
    <segment id="22">Nesta série cômica</segment>
    <segment id="23">, uma moça que vive em Londres fica noiva de um britânico de origem paquistanesa.</segment>
    <segment id="24">Mas as coisas não vão bem quando ela o apresenta à família</segment>
    <segment id="25">, em seu país natal</segment>
    <segment id="26">, a Arábia Saudita.</segment>
    <segment id="27">Netflix</segment>
    <segment id="28">, 12 anos   LOL:</segment>
    <segment id="29">Se Rir</segment>
    <segment id="30">, Já Era!  Tom Cavalcante e Fabiana Karla comandam a terceira temporada da competição entre humoristas.</segment>
    <segment id="31">Aquele que rir da piada do outro</segment>
    <segment id="32">, corre o risco de ser eliminado.</segment>
