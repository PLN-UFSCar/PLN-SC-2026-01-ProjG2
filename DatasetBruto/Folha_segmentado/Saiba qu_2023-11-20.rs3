  <rst>
    <segment id="1">Com a vitória do opositor Javier Milei sobre o peronista Sergio Massa nas eleições presidenciais da Argentina deste domingo (19)</segment>
    <segment id="2">, a atriz e humorista Fátima Flórez</segment>
    <segment id="3">, 42, deverá ser a futura primeira-dama do país vizinho.</segment>
    <segment id="4">Acompanhe as últimas notícias sobre as eleições na Argentina</segment>
    <segment id="5">O candidato presidencial da Argentina</segment>
    <segment id="6">, Javier Milei</segment>
    <segment id="7">, chega ao Teatro Colón</segment>
    <segment id="8">, em Buenos Aires</segment>
    <segment id="9">, com sua namorada</segment>
    <segment id="10">, Fátima Florez</segment>
    <segment id="11">, antes do segundo turno das eleições - Ramiro Souto - 17.nov.2023/Reuters  Imitadora de personalidades</segment>
    <segment id="12">comocomo Shakira e Madonna</segment>
    <segment id="13">, María Eugenia</segment>
    <segment id="14">, nome verdadeiro de Fátima</segment>
    <segment id="15">,</segment>
    <segment id="16">ficou famosa principalmente por parodiar na televisão os trejeitos e a voz de Cristina Kirchner</segment>
    <segment id="17">, ex-presidente e atual número dois do chefe do Executivo argentino</segment>
    <segment id="18">, Alberto Fernández.</segment>
    <segment id="19">Foi nesse mesmo veículo</segment>
    <segment id="20">, aliás</segment>
    <segment id="21">, que seu atual namorado ganhou notoriedade —no</segment>
    <segment id="22">casocaso dele</segment>
    <segment id="23">, porém</segment>
    <segment id="24">porém, com comentários polêmicos contra a peronista e quase todos os outros notórios políticos argentinos</segment>
    <segment id="25">, a quem chama de forma pejorativa de "casta".</segment>
    <segment id="26">A vocação de Flórez desabrochou na infância</segment>
    <segment id="27">, conta a humorista</segment>
    <segment id="28">, quando ela começou a imitar professoras para seus colegas de classe.</segment>
    <segment id="29">Na época</segment>
    <segment id="30">, a atriz chegou a participar de um concurso para imitar a apresentadora brasileira Xuxa</segment>
    <segment id="31">, muito popular na Argentina.</segment>
    <segment id="32">"</segment>
    <segment id="33">Eu tinha 5 ou 6 anos.</segment>
    <segment id="34">Fui a um casting e ganhei</segment>
    <segment id="35">, peguei uma boneca.</segment>
    <segment id="36">Eu a admirava tanto que sempre ia ao programa dela</segment>
    <segment id="37">, tenho mil fotos com ela.</segment>
    <segment id="38">Ela já me conhecia de tanto que eu ia lá"</segment>
    <segment id="39">, disse a humorista em entrevista à Rádio Rivadavia</segment>
    <segment id="40">, um veículo local.</segment>
    <segment id="41">De acordo com o portal argentino Infobae</segment>
    <segment id="42">, a apresentadora brasileira já enviou um vídeo para Flórez em comemoração ao aniversário da humorista</segment>
    <segment id="43">, em fevereiro de 2016.</segment>
    <segment id="44">Ele teria sido exibido em um telão após o espetáculo Fátima para Todos</segment>
    <segment id="45">, como</segment>
    <segment id="46">como uma surpresa para a atriz.</segment>
    <segment id="47">Conheça Fátima Flórez</segment>
    <segment id="48">, a namorada de Javier MileiMais    novamente         de   de  de  representando um    "Do Brasil</segment>
    <segment id="49">, quero te desejar o melhor.</segment>
    <segment id="50">Vi que você me imita</segment>
    <segment id="51">, e muito bem"</segment>
    <segment id="52">, disse a brasileira</segment>
    <segment id="53">, de acordo com o site.</segment>
    <segment id="54">A apresentação</segment>
    <segment id="55">, segundo o portal</segment>
    <segment id="56">, aconteceu na Villa Carlos Paz</segment>
    <segment id="57">, um município da província de Córdoba</segment>
    <segment id="58">, na Argentina.</segment>
    <segment id="59">Um jornal local</segment>
    <segment id="60">, El Diario de Carlos Paz</segment>
    <segment id="61">, também registrou o evento.  "</segment>
    <segment id="62">Foi tudo uma surpresa</segment>
    <segment id="63">, eles não me contaram nada"</segment>
    <segment id="64">, disse a atriz na ocasião</segment>
    <segment id="65">, segundo o jornal. "</segment>
    <segment id="66">Meu marido sempre faz algo legal para mim no meu aniversário</segment>
    <segment id="67">, masmas isso superou tudo.</segment>
    <segment id="68">Todos expressaram seu carinho</segment>
    <segment id="69">, masmas a mensagem da Xuxa me quebrou.</segment>
    <segment id="70">Ela é minha ídola desde quando eu era pequena.</segment>
    <segment id="71">"</segment>
    <segment id="72">O pseudônimo pelo qual é conhecida foi sugestão do então marido citado na entrevista e ex-produtor Norberto Marcos.</segment>
    <segment id="73">Após 22 anos juntos</segment>
    <segment id="74">, eles romperam no início deste ano</segment>
    <segment id="75">, meses antes de Flórez</segment>
    <segment id="76">sese envolver com o então candidato à Presidência.</segment>
    <segment id="77">Àquela altura</segment>
    <segment id="78">, porém</segment>
    <segment id="79">porém, ela já conhecia Milei</segment>
    <segment id="80">, segundo afirmou a humorista em entrevistas.</segment>
    <segment id="81">Segundo Flórez</segment>
    <segment id="82">, o encontro com o ultraliberal ocorreu no fim de 2022</segment>
    <segment id="83">, em um programa de entrevistas de Mirtha Legrand</segment>
    <segment id="84">, famosa apresentadora argentina que intermediou imitações da atriz e comentários políticos do economista.</segment>
    <segment id="85">Lá foraReceba no seu email uma seleção semanal com o que de mais importante aconteceu no mundoCarregando...</segment>
    <segment id="86">Em outra conversa com Legrand</segment>
    <segment id="87">, em outubro</segment>
    <segment id="88">, Flórez diz que "muito depois" do encontro eles começaram a trocar mensagens pelas redes sociais.</segment>
    <segment id="89">O relacionamento teria começado meses depois</segment>
    <segment id="90">, diz ela</segment>
    <segment id="91">, quando já estava solteira.</segment>
    <segment id="92">"Eu estava no Uruguai e começamos a nos escrever.</segment>
    <segment id="93">Tivemos uma conexão diferente</segment>
    <segment id="94">, alguma coisa aconteceu"</segment>
    <segment id="95">, disse a humorista a Legrand.</segment>
    <segment id="96">O namoro foi anunciado uma semana depois das primárias argentinas</segment>
    <segment id="97">, nas quais Milei teve uma votação surpreendente de 30%</segment>
    <segment id="98">, suficiente para alcançar a liderança.</segment>
    <segment id="99">A primeira aparição pública aconteceu semanas depois</segment>
    <segment id="100">, 15 dias antes do primeiro turno.</segment>
    <segment id="101">Assim como</segment>
    <segment id="102">como para seu namorado</segment>
    <segment id="103">, as redes sociais são uma importante vitrine da atriz</segment>
    <segment id="104">, que acumula mais de 500 mil seguidores no TikTok e 1</segment>
    <segment id="105">,1 milhão no Instagram —ela</segment>
    <segment id="106">, porém</segment>
    <segment id="107">porém, não costuma publicar muitas fotos dos dois nas plataformas.</segment>
    <segment id="108">Antes de assumir o namoro com Flórez</segment>
    <segment id="109">, Milei dizia que sua irmã</segment>
    <segment id="110">, Karina</segment>
    <segment id="111">, faria o papel da primeira-dama.</segment>
    <segment id="112">Ela é dois anos mais nova que o ultradireitista</segment>
    <segment id="113">, de 53 anos</segment>
    <segment id="114">, e estrategista de sua campanha.</segment>
    <segment id="115">Veja imagens da vitória de Javier Milei nas eleições argentinasMais    novamente         de   de  de  representando</segment>
    <segment id="116">um</segment>
  </rst>
