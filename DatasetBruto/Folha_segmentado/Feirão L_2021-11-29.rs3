  <rst>
    <segment id="1">O Feirão Serasa Limpa Nome</segment>
    <segment id="2">, realizado na semana passada em seis capitais do país</segment>
    <segment id="3">, intermediou mais de 3</segment>
    <segment id="4">,3 milhões de acordos para quitar dívidas de consumidores inadimplentes.</segment>
    <segment id="5">Segundo a empresa</segment>
    <segment id="6">, foram oferecidos descontos equivalentes a R$ 6 bilhões para regularização de débitos nos cinco dias do evento</segment>
    <segment id="7">, realizado presencialmente pela primeira vez desde o início da pandemia de Covid-19.</segment>
    <segment id="8">No estado de São Paulo</segment>
    <segment id="9">, mais de um milhão de acordos foram fechados.</segment>
    <segment id="10">Segundo a Serasa</segment>
    <segment id="11">, o Brasil tinha mais de 63 milhões de pessoas inadimplentes em outubro.</segment>
    <segment id="12">Só no estado de São Paulo</segment>
    <segment id="13">, eram 15 milhões.  Rivaldo Gomes -19.mar.2018/FolhapressForam oferecidos descontos de até 99% no pagamento de débitos atrasados ou negativados</segment>
    <segment id="14">, com mais de cem empresas participantes</segment>
    <segment id="15">, incluindo bancos</segment>
    <segment id="16">, faculdades</segment>
    <segment id="17">, financeiras</segment>
    <segment id="18">, limpadoras de crédito e lojas.</segment>
    <segment id="19">O Feirão Serasa Limpa Nome segue até 5 de dezembro pelos canais digitais oficiais da companhia e em mais de 7.000 agências parceiras dos Correios.</segment>
    <segment id="20">Neste caso</segment>
    <segment id="21">caso, será cobrada uma taxa de R$ 3</segment>
    <segment id="22">,60 para cada consulta.</segment>
    <segment id="23">Ricardo Balthazar (editor interino)</segment>
    <segment id="24">, com Andressa Motter e Ana Paula Branco</segment>
  </rst>
</analysis>