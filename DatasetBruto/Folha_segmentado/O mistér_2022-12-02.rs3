<analysis>
  <header>
    <relations>
      <rel name="antithesis" type="rst"/>
      <rel name="attribution" type="rst"/>
      <rel name="circumstance" type="rst"/>
      <rel name="comparison" type="rst"/>
      <rel name="concession" type="rst"/>
      <rel name="conclusion" type="rst"/>
      <rel name="condition" type="rst"/>
      <rel name="elaboration" type="rst"/>
      <rel name="enablement" type="rst"/>
      <rel name="explanation" type="rst"/>
      <rel name="evaluation" type="rst"/>
      <rel name="evidence" type="rst"/>
      <rel name="interpretation" type="rst"/>
      <rel name="elaboration" type="rst"/>
      <rel name="non-volitional-cause" type="rst"/>
      <rel name="non-volitional-result" type="rst"/>
      <rel name="volitional-cause" type="rst"/>
      <rel name="volitional-result" type="rst"/>
    </relations>
  </header>
  <rst>
    <segment id="1">Era o meio do inverno e o céu do Alasca era instável.</segment>
    <segment id="2">De um lado</segment>
    <segment id="3">, o curso tranquilo do rio Colville.</segment>
    <segment id="4">Do outro</segment>
    <segment id="5">, um alto rochedo de pedra cinza-estanho congelada</segment>
    <segment id="6">, rodeado por centenas de quilômetros de tundra deserta.</segment>
    <segment id="7">Armado com um machado de gelo e ganchos</segment>
    <segment id="8">, fustigado pelos ventos gelados do Ártico</segment>
    <segment id="9">, sob temperaturas de cerca de -28 °C</segment>
    <segment id="10">, Pat Druckenmiller estava procurando algo especial.</segment>
    <segment id="11">O ano era 2021.</segment>
    <segment id="12">O simples trajeto até o rochedo já havia sido uma tremenda expedição.</segment>
    <segment id="13">Os dinossauros do Ártico teriam testemunhado regularmente a aurora boreal - Alamy via BBC News BrasilNeste canto remoto no norte do Alasca</segment>
    <segment id="14">, não há estradas</segment>
    <segment id="15">, o que levou o paleontólogo e seus colegas da Universidade do Alasca a viajar em motos de neve até o local</segment>
    <segment id="16">, onde montaram um acampamento.</segment>
    <segment id="17">O frio era tanto que cada tenda tinha seu próprio fogão a lenha.</segment>
    <segment id="18">Nas semanas seguintes</segment>
    <segment id="19">, a equipe lutaria constantemente contra as queimaduras de frio ("foi por pouco</segment>
    <segment id="20">, em alguns casos"</segment>
    <segment id="21">, relembra Druckenmiller)</segment>
    <segment id="22">, desabamentos e ursos</segment>
    <segment id="23">polares famintos.</segment>
    <segment id="24">Mas valeu a pena.</segment>
    <segment id="25">Observando através dos seus óculos de esqui e com pouca luz</segment>
    <segment id="26">, Druckenmiller finalmente encontrou o que estava procurando.</segment>
    <segment id="27">Enterrada nos estratos do rochedo</segment>
    <segment id="28">, cerca de 15 metros acima do rio</segment>
    <segment id="29">, havia uma camada isolada de areia e argila com cerca de 10 cm de espessura.</segment>
    <segment id="30">Quando esse sedimento foi depositado</segment>
    <segment id="31">, cerca de 73 milhões de anos atrás</segment>
    <segment id="32">, o mundo era mais quente do que é agora</segment>
    <segment id="33">, masmas esta região estaria ainda mais ao norte.</segment>
    <segment id="34">Hoje, esta parte do Alasca recebe algumas horas de penumbra todos os dias durante o inverno.</segment>
    <segment id="35">Mas, naquela época</segment>
    <segment id="36">, ela mergulhava na escuridão completa por quatro meses do ano</segment>
    <segment id="37">, entre outubro e fevereiro.</segment>
    <segment id="38">A temperatura caía regularmente abaixo de -10°C e nevava ocasionalmente.</segment>
    <segment id="39">Mas, ainda assim</segment>
    <segment id="40">, escondidos entre esse conjunto de sedimentos</segment>
    <segment id="41">, encontram-</segment>
    <segment id="42">sese os últimos restos de uma época bizarra da história do planeta: ossos e dentes minúsculos</segment>
    <segment id="43">, com poucos milímetros de comprimento</segment>
    <segment id="44">, que pertenceram a ninhadas de gigantes.</segment>
    <segment id="45">Foi aqui que milhares de dinossauros fizeram seus ninhos e os fetos que não eclodiram permaneceram enterrados até hoje.</segment>
    <segment id="46">"</segment>
    <segment id="47">Provavelmente</segment>
    <segment id="48">, é a camada de ossos de dinossauro mais interessante de todo o Estado do Alasca"</segment>
    <segment id="49">, afirma Druckenmiller.</segment>
    <segment id="50">"</segment>
    <segment id="51">Eles viviam praticamente no Polo Norte.</segment>
    <segment id="52">"</segment>
    <segment id="53">Nós tendemos a imaginar os dinossauros</segment>
    <segment id="54">comocomo criaturas tropicais —répteis monstruosos e cheios de dentes que patrulhavam as florestas e pântanos de um planeta quente e úmido.</segment>
    <segment id="55">Mas os cientistas vêm percebendo cada vez mais que isso não é totalmente correto.</segment>
    <segment id="56">O peso do nanuquessauro era equivalente a cerca de dois ursos polares machos grandes - Alamy via BBC News BrasilExistiam também dinossauros em lugares mais frios e está cada vez mais claro que eles estavam longe de serem visitantes ocasionais de climas mais amenos.</segment>
    <segment id="57">Da Austrália até a Rússia</segment>
    <segment id="58">, cientistas já desenterraram dezenas de dinossauros que podem um dia ter vivido no frio extremo</segment>
    <segment id="59">, fechando seus olhos brilhantes para dormir enquanto olhavam para as luzes da aurora dançando todas as noites e</segment>
    <segment id="60">, às vezes</segment>
    <segment id="61">, procurando alimento entre camadas de neve cristalina.</segment>
    <segment id="62">Esses dinossauros não estavam lutando para sobreviver à margem da sua zona habitável.</segment>
    <segment id="63">Em lugares</segment>
    <segment id="64">comocomo o Alasca</segment>
    <segment id="65">, eles estavam</segment>
    <segment id="66">sese multiplicando.</segment>
    <segment id="67">Essas descobertas têm implicações que vão muito além das estranhas cenas que elas inspiram</segment>
    <segment id="68">, com tiranossauros sacudindo a neve das suas (possíveis) penas ou</segment>
    <segment id="69">sese preparando para enfrentar uma nevasca.</segment>
    <segment id="70">Cada nova descoberta revela informações fascinantes sobre a fisiologia e o comportamento de grupo dos dinossauros polares.</segment>
    <segment id="71">E, à medida que os cientistas aprendem mais sobre eles</segment>
    <segment id="72">, ficamos mais perto da resposta a uma das questões mais complexas da paleontologia: os dinossauros tinham sangue quente ou frio?</segment>
    <segment id="73">Uma descoberta surpreendente</segment>
    <segment id="74">Em 1961</segment>
    <segment id="75">, o geólogo Robert Liscomb estava mapeando as margens do rio Colville para a companhia petrolífera Shell quando encontrou algo inesperado: um punhado de ossos saindo dos estratos do rochedo.</segment>
    <segment id="76">Ele acreditava que deviam ser ossos de mamíferos</segment>
    <segment id="77">, masmas os levou consigo e guardou em um armário.</segment>
    <segment id="78">Naquele mesmo ano</segment>
    <segment id="79">, Liscomb morreu tragicamente em um desabamento.</segment>
    <segment id="80">Por duas décadas</segment>
    <segment id="81">, os ossos ficaram esquecidos</segment>
    <segment id="82">, trancados nos arquivos da empresa.</segment>
    <segment id="83">Enquanto isso</segment>
    <segment id="84">, fósseis de dinossauros espalhados começaram a surgir em outros locais no norte do planeta</segment>
    <segment id="85">, incluindo pegadas na ilha norueguesa de Svalbard.</segment>
    <segment id="86">Até que</segment>
    <segment id="87">, um dia</segment>
    <segment id="88">, em 1984</segment>
    <segment id="89">, houve uma descoberta fascinante:</segment>
    <segment id="90">cientistas encontraram pegadas e impressões da pele de dinossauros na mesma encosta ao norte do rio Colville</segment>
    <segment id="91">, onde Liscomb encontrou seus ossos.</segment>
    <segment id="92">Esta descoberta fez com que os ossos antigos fossem rapidamente retirados da gaveta e concluiu-</segment>
    <segment id="93">sese que aqueles também eram ossos de dinossauro.</segment>
    <segment id="94">A descoberta gerou intenso debate entre os paleontólogos.</segment>
    <segment id="95">Animais de sangue frio certamente não conseguiriam viver naquele ponto tão ao norte.</segment>
    <segment id="96">Convicções mantidas há séculos começaram a ser questionadas e os estudos começaram a fervilhar.</segment>
    <segment id="97">Logo ficaria claro que os ossos do rio Colville não foram encontrados por acaso.</segment>
    <segment id="98">Os afloramentos ao longo das margens do rio estavam definitivamente repletos de fósseis de dinossauros</segment>
    <segment id="99">, mais do que havia sido encontrado em qualquer local da região ártica ou antártica.</segment>
    <segment id="100">"E, o mais importante</segment>
    <segment id="101">, é de longe o maior sítio de dinossauros polares"</segment>
    <segment id="102">, afirma Druckenmiller.</segment>
    <segment id="103">À medida que as descobertas</segment>
    <segment id="104">sese acumulavam</segment>
    <segment id="105">, as evidências acabaram ficando irrefutáveis.</segment>
    <segment id="106">Logo no princípio</segment>
    <segment id="107">, já havia inúmeros fósseis</segment>
    <segment id="108">comocomo o herbívoro edmontossauro (conhecido</segment>
    <segment id="109">comocomo "a vaca do cretáceo")</segment>
    <segment id="110">, um parente não identificado do tricerátops e um único dente do predador alectrossauro —um tiranossauro com o tamanho aproximado de uma morsa.</segment>
    <segment id="111">Existiram</segment>
    <segment id="112">, de fato</segment>
    <segment id="113">, dinossauros polares</segment>
    <segment id="114">, masmas continuamos sem entender</segment>
    <segment id="115">comocomo eles sobreviveram.</segment>
    <segment id="116">Por sorte</segment>
    <segment id="117">, havia uma explicação simples: eles só viviam ali durante o calor —os dinossauros migravam.</segment>
    <segment id="118">Como suas primas distantes</segment>
    <segment id="119">, as andorinhas-do-ártico dos dias atuais</segment>
    <segment id="120">, os dinossauros poderiam ter visitado os polos durante o verão e retornado para climas mais quentes durante o inverno.</segment>
    <segment id="121">Alguns especialistas sugeriram que eles viajavam por até 3</segment>
    <segment id="122">,2 mil quilômetros de distância.</segment>
    <segment id="123">Mas esta teoria também encontrou um obstáculo.</segment>
    <segment id="124">Em um dia fresco de verão no cretáceo superior</segment>
    <segment id="125">, um enorme grupo de hadrossauros cruzou uma planície lamacenta no Ártico.</segment>
    <segment id="126">A temperatura era de cerca de 10-12ºC e esses animais herbívoros - com seus bicos usados para moer a vegetação e suas caudas enormes —haviam acabado de sobreviver a um intenso inverno</segment>
    <segment id="127">, com temperaturas quase congelantes.</segment>
    <segment id="128">Um espécime de paquirrinossauro encontrado nas margens do rio Colville viveu até os 19 anos de idade - Alamy via BBC News BrasilEram milhares de indivíduos de todas as idades - filhotes</segment>
    <segment id="129">, adolescentes e adultos.</segment>
    <segment id="130">Sua caminhada através da lama pode ter durado apenas alguns minutos</segment>
    <segment id="131">, masmas seus rastros foram rapidamente cobertos por novos sedimentos e preservados por milênios</segment>
    <segment id="132">, até serem encontrados por cientistas humanos em 2014.</segment>
    <segment id="133">As pegadas estavam tão bem preservadas que foi possível até vislumbrar as escamas das patas dos dinossauros.</segment>
    <segment id="134">Os fósseis foram localizados em uma reserva natural do Alasca</segment>
    <segment id="135">, a centenas de quilômetros ao sul das margens do rio Colville</segment>
    <segment id="136">, masmas ainda na região do Ártico.</segment>
    <segment id="137">A presença de rastros de dinossauros jovens indicava que provavelmente eles permaneciam na região por todo o ano.</segment>
    <segment id="138">Afinal</segment>
    <segment id="139">, os animais mais jovens não teriam conseguido fazer a longa migração.</segment>
    <segment id="140">Mas nem todos ficaram convencidos.</segment>
    <segment id="141">Como Druckenmiller na sua faixa rochosa</segment>
    <segment id="142">, que ele lutou para encontrar.</segment>
    <segment id="143">Tarefa delicada</segment>
    <segment id="144">Enquanto paleontólogos escavavam ossos da coxa do tamanho de golfinhos nas planícies queimadas pelo sol na Argentina</segment>
    <segment id="145">, Druckenmiller precisou adotar uma estratégia diferente.</segment>
    <segment id="146">Quando a sua equipe começou a trabalhar no sítio do rio Colville</segment>
    <segment id="147">, as visitas ocorriam no verão</segment>
    <segment id="148">, quando as temperaturas hoje são de cerca de 1ºC a 10°C.</segment>
    <segment id="149">E eles descobriram rapidamente que aquilo estava longe do ideal.</segment>
    <segment id="150">Entre junho e agosto</segment>
    <segment id="151">, o Alasca é invadido por mosquitos.</segment>
    <segment id="152">Nuvens gigantes atacam seres humanos incautos.</segment>
    <segment id="153">Os mosquitos são tantos que foram apelidados de "as aves do Estado do Alasca".</segment>
    <segment id="154">Mas esta era a menor das preocupações.</segment>
    <segment id="155">As faces do rochedo onde eles trabalhavam eram compostas principalmente de rocha lamacenta</segment>
    <segment id="156">, unida apenas pelo gelo</segment>
    <segment id="157">, de forma instável.  "</segment>
    <segment id="158">O calor do verão é suficiente</segment>
    <segment id="159">para que</segment>
    <segment id="160">para que parte desse gelo derreta e os rochedos podem desabar de forma catastrófica"</segment>
    <segment id="161">, afirma Druckenmiller.</segment>
    <segment id="162">"</segment>
    <segment id="163">Se você estiver perto de um deles</segment>
    <segment id="164">, é o fim.</segment>
    <segment id="165">"</segment>
    <segment id="166">Os cientistas decidiram passar a visitar o local no inverno</segment>
    <segment id="167">, o que também traz seus próprios problemas.</segment>
    <segment id="168">Eles estavam trabalhando a apenas 32 km do Oceano Ártico e era simplesmente frio demais</segment>
    <segment id="169">para que</segment>
    <segment id="170">para que eles ficassem sentados o dia todo</segment>
    <segment id="171">, peneirando ossos de bebês de dinossauros.</segment>
    <segment id="172">Por isso</segment>
    <segment id="173">, assim que a equipe encontrou sua tão esperada camada de rocha</segment>
    <segment id="174">, o silêncio do cenário vazio foi rapidamente interrompido pelo som das britadeiras e motosserras.</segment>
    <segment id="175">Primeiramente</segment>
    <segment id="176">, a equipe cortou degraus no rochedo para poder atravessá-lo.</segment>
    <segment id="177">Depois começou a escavar blocos inteiros de sedimentos que pareciam promissores e não ossos específicos.</segment>
    <segment id="178">Os blocos foram carregados sobre trenós e motos de neve e transportados por centenas de quilômetros através da tundra congelada até o laboratório.</segment>
    <segment id="179">E, quando essas amostras enormes estavam seguras na Universidade do Alasca</segment>
    <segment id="180">, elas foram lavadas para retirar a argila.</segment>
    <segment id="181">"</segment>
    <segment id="182">O que sobrou foi basicamente uma fração de areia e olhamos cada grão de areia no microscópio em busca de pequenos ossos e dentes"</segment>
    <segment id="183">, explica Druckenmiller.</segment>
    <segment id="184">"É um processo muito lento e demorado.</segment>
    <segment id="185">É como</segment>
    <segment id="186">como batear em busca de ouro</segment>
    <segment id="187">, masmas procurando dinossauros.</segment>
    <segment id="188">"</segment>
    <segment id="189">Ele estima que</segment>
    <segment id="190">, em uma década</segment>
    <segment id="191">, sua equipe examinou milhões de partículas de areia em busca desses fósseis minúsculos.</segment>
    <segment id="192">E o que eles encontraram foi extraordinário.</segment>
    <segment id="193">"</segment>
    <segment id="194">Nós não tínhamos apenas um ou dois tipos de bebês dinossauros"</segment>
    <segment id="195">, afirma Druckenmiller.</segment>
    <segment id="196">"</segment>
    <segment id="197">Na verdade</segment>
    <segment id="198">, temos evidências de sete grupos diferentes de dinossauros</segment>
    <segment id="199">, herbívoros e carnívoros</segment>
    <segment id="200">, espécies grandes e pequenas.</segment>
    <segment id="201">"  É importante observar que o fato de que os dinossauros faziam ninhos significa que</segment>
    <segment id="202">, com quase total certeza</segment>
    <segment id="203">, eles não migravam quando o tempo esfriava.</segment>
    <segment id="204">Algumas espécies comuns de dinossauros</segment>
    <segment id="205">, como</segment>
    <segment id="206">como os hadrossauros com bico de pato</segment>
    <segment id="207">, precisavam de seis meses para incubar seus ovos.</segment>
    <segment id="208">Por isso</segment>
    <segment id="209">, sese as mães começassem a chocá-los na primavera</segment>
    <segment id="210">, seria quase inverno na época da eclosão.</segment>
    <segment id="211">Para nascer no Ártico e evitar o inverno com seus meses de escuridão</segment>
    <segment id="212">, esses bebês precisariam</segment>
    <segment id="213">, de alguma forma</segment>
    <segment id="214">, migrar imediatamente após o nascimento por milhares de quilômetros.</segment>
    <segment id="215">O tempo simplesmente não era suficiente.</segment>
    <segment id="216">"</segment>
    <segment id="217">Isso desafia a lógica"</segment>
    <segment id="218">, segundo Druckenmiller.</segment>
    <segment id="219">"</segment>
    <segment id="220">Temos quase certeza de que esses dinossauros eram moradores permanentes.</segment>
    <segment id="221">"  Neste</segment>
    <segment id="222">casocaso</segment>
    <segment id="223">, como</segment>
    <segment id="224">como teria sido a vida desses dinossauros polares?</segment>
    <segment id="225">E como</segment>
    <segment id="226">como eles conseguiam sobreviver?</segment>
    <segment id="227">Mistério no gelo</segment>
    <segment id="228">Era início de março no cretáceo superior</segment>
    <segment id="229">, na floresta aberta no Ártico que</segment>
    <segment id="230">sese transformaria</segment>
    <segment id="231">, um dia</segment>
    <segment id="232">, no sítio arqueológico do rio Colville.</segment>
    <segment id="233">Os ramos das coníferas e antigas árvores gingko biloba estavam começando a criar folhas</segment>
    <segment id="234">, fornecendo sombras coloridas a uma camada inferior de samambaias e cavalinhas abaixo delas.</segment>
    <segment id="235">Grupos de hadrossauros alimentavam-</segment>
    <segment id="236">sese distraídos das folhagens</segment>
    <segment id="237">, enquanto paquirrinossauros machos</segment>
    <segment id="238">, parentes fortes dos tricerátops</segment>
    <segment id="239">, exibiam seus extravagantes adornos no pescoço na esperança de atrair uma parceira</segment>
    <segment id="240">, talvez bufando ocasionalmente pelo nariz longo e volumoso.</segment>
    <segment id="241">Essa relativa calma pode ter sido interrompida de vez em quando por uma perseguição e um grasnado</segment>
    <segment id="242">, quando as garras de um nanuquessauro ("lagarto urso polar")</segment>
    <segment id="243">faminto conseguiam capturar um tescelossauro bicudo e escamoso.</segment>
    <segment id="244">Com o sangue escorrendo pela cobertura macia das suas penas de tom branco-neve</segment>
    <segment id="245">, como</segment>
    <segment id="246">como às vezes é ilustrado</segment>
    <segment id="247">, ele pode ter sido muito parecido com o seu homônimo atual.</segment>
    <segment id="248">Perto dali</segment>
    <segment id="249">, havia diversos ninhos —talvez em berçários comunitários</segment>
    <segment id="250">, sese os dinossauros polares fossem</segment>
    <segment id="251">comocomo seus parentes do sul.</segment>
    <segment id="252">Neles, os moradores locais incubavam seus ovos.</segment>
    <segment id="253">Saurornitolestinas —parentes dos velociraptores</segment>
    <segment id="254">, parecidos com aves— acomodavam-</segment>
    <segment id="255">sese sobre seus ovos e podem ter usado seus dentes característicos para alisar as penas.</segment>
    <segment id="256">Um dos dinossauros mais estranhos do Alasca talvez fosse o terizinossauro —um herbívoro lento e colossal com longos e assustadores dedos em forma de foice - Alamy via BBC News BrasilPor décadas ou séculos</segment>
    <segment id="257">, alguns dos dinossauros que morreram na região acabaram sendo levados pela água para um rio ou lago próximo.</segment>
    <segment id="258">"</segment>
    <segment id="259">Mas os sedimentos foram espalhados de forma que os ossos e dentes</segment>
    <segment id="260">sese concentrassem nesses pequenos depósitos pontuais"</segment>
    <segment id="261">, explica Druckenmiller.</segment>
    <segment id="262">Diversos dinossauros identificados nos sedimentos em sítios arqueológicos ao longo do rio Colville nunca foram encontrados em outro local</segment>
    <segment id="263">, como</segment>
    <segment id="264">como o Ugrunaaluk kuukpikensis ("antigo animal que pastava"</segment>
    <segment id="265">, no idioma local inupiat)</segment>
    <segment id="266">, uma espécie de hadrossauro.</segment>
    <segment id="267">É claro que isso não significa que eles não possam ser encontrados algum dia</segment>
    <segment id="268">, nem comprova necessariamente que eles tivessem alguma adaptação especial para o frio.</segment>
    <segment id="269">Mas é algo promissor.</segment>
    <segment id="270">Druckenmiller acredita que é provável que os dinossauros do Alasca tivessem pelo menos algumas características exclusivas</segment>
    <segment id="271">, como</segment>
    <segment id="272">como comportamentos que evoluíram para ajudá-los a enfrentar as condições do Ártico.  "</segment>
    <segment id="273">Existem razões para acreditar que talvez algumas das espécies menores</segment>
    <segment id="274">, especialmente os herbívoros</segment>
    <segment id="275">, fossem suficientemente pequenas para fazer uma toca e hibernar no inverno"</segment>
    <segment id="276">, afirma ele.</segment>
    <segment id="277">Essas indicações preliminares vêm dos anéis de crescimento em cortes transversais dos ossos</segment>
    <segment id="278">, como</segment>
    <segment id="279">como os dos troncos das árvores —marcas que mostram as variações do padrão de crescimento dos animais ano após ano.</segment>
    <segment id="280">Se o crescimento for suspenso</segment>
    <segment id="281">, como</segment>
    <segment id="282">como ocorre durante a hibernação</segment>
    <segment id="283">, esse espaço deixa um anel.</segment>
    <segment id="284">Segundo Druckenmiller</segment>
    <segment id="285">, foram encontradas essas faixas distintas em diversos dinossauros das margens do rio Colville e alguns deles podem ter hibernado.</segment>
    <segment id="286">Elas vêm</segment>
    <segment id="287">sese somar às evidências encontradas em outros locais</segment>
    <segment id="288">, de que os dinossauros podem ter tido pelo menos algumas das adaptações necessárias</segment>
    <segment id="289">, como</segment>
    <segment id="290">como a formação de tocas.</segment>
    <segment id="291">Em 2007</segment>
    <segment id="292">, o esqueleto fossilizado de um orictodromeu— um dinossauro com o tamanho aproximado de um pastor-alemão— foi encontrado ao lado de dois animais jovens em um buraco pequeno e confortável no sudoeste de Montana</segment>
    <segment id="293">, nos Estados Unidos.</segment>
    <segment id="294">Mercado de ossos de dinossauro está em altaMais    novamente         de   de  de  representando um  Todo o conjunto havia sido sepultado e permaneceu ali intocado por cerca de 100 milhões de anos.</segment>
    <segment id="295">Eles fazem parte do mesmo gênero do tescelossauro e seus membros também foram encontrados no sítio arqueológico do rio Colville.</segment>
    <segment id="296">"</segment>
    <segment id="297">E o fato de termos esses parentes próximos no Alasca indica que talvez essas espécies também façam tocas</segment>
    <segment id="298">, masmas para hibernar"</segment>
    <segment id="299">, segundo Druckenmiller.</segment>
    <segment id="300">Mas, infelizmente</segment>
    <segment id="301">, comprovar isso seria extremamente difícil</segment>
    <segment id="302">, a menos que fosse encontrada outra toca no Ártico.</segment>
    <segment id="303">Outra possibilidade é que os dinossauros enfrentassem o frio da mesma forma que fazem muitos mamíferos modernos</segment>
    <segment id="304">, formando uma camada de gordura corporal.</segment>
    <segment id="305">Druckenmiller menciona o alce e o caribu</segment>
    <segment id="306">comocomo exemplos.</segment>
    <segment id="307">Eles aumentam de peso todo verão e sobrevivem com uma combinação das suas reservas de gordura e forragem de baixa qualidade no inverno</segment>
    <segment id="308">, quando o alimento é escasso.</segment>
    <segment id="309">E esta estratégia tem ainda a vantagem de mantê-los quentes.</segment>
    <segment id="310">"</segment>
    <segment id="311">Eles fazem isso</segment>
    <segment id="312">, basicamente</segment>
    <segment id="313">, passando fome lentamente"</segment>
    <segment id="314">, explica ele.</segment>
    <segment id="315">"</segment>
    <segment id="316">Não existe motivo por que os dinossauros não poderiam ter feito o mesmo.</segment>
    <segment id="317">"</segment>
    <segment id="318">Mas existe uma adaptação mais óbvia:</segment>
    <segment id="319">comocomo os dinossauros regulavam sua temperatura corporal.</segment>
    <segment id="320">Os cientistas vêm debatendo</segment>
    <segment id="321">sese os dinossauros eram animais de sangue frio ou quente desde que eles foram descobertos.</segment>
    <segment id="322">No século 19</segment>
    <segment id="323">, considerava-</segment>
    <segment id="324">sese geralmente que eles fossem essencialmente enormes répteis ectotérmicos —eles não conseguiam gerar seu próprio calor corporal e precisavam banhar-</segment>
    <segment id="325">sese ao sol</segment>
    <segment id="326">, como</segment>
    <segment id="327">como fazem os répteis modernos.</segment>
    <segment id="328">Quando as simbólicas esculturas de dinossauros do Palácio de Cristal</segment>
    <segment id="329">, em Londres</segment>
    <segment id="330">, foram inauguradas em 1854</segment>
    <segment id="331">, elas</segment>
    <segment id="332">sese pareciam com robustos lagartos escamosos.</segment>
    <segment id="333">Mas, à medida que os especialistas aprendiam mais sobre as vidas dos dinossauros e começavam a perceber que as aves modernas são</segment>
    <segment id="334">, essencialmente</segment>
    <segment id="335">, dinossauros com bicos e penas</segment>
    <segment id="336">, muitos começaram a questionar</segment>
    <segment id="337">sese aquilo era verdade.</segment>
    <segment id="338">Por fim</segment>
    <segment id="339">, eles formaram um consenso de que os dinossauros provavelmente mantinham suas temperaturas em algum ponto entre os répteis e as aves —e</segment>
    <segment id="340">, até recentemente</segment>
    <segment id="341">, ainda havia certa falta de evidências concretas.</segment>
    <segment id="342">Os dinossauros do Ártico vieram mudar tudo isso.  "</segment>
    <segment id="343">Um dos pontos que consideramos em toda esta história é que esses dinossauros</segment>
    <segment id="344">, com quase total certeza</segment>
    <segment id="345">, eram animais de sangue quente</segment>
    <segment id="346">, até certo ponto"</segment>
    <segment id="347">, explica Druckenmiller.</segment>
    <segment id="348">"</segment>
    <segment id="349">Certamente</segment>
    <segment id="350">, esses dinossauros tinham algum grau de endotermia —eles produziam seu próprio calor interno.</segment>
    <segment id="351">É uma espécie de pré-requisito para viver em um ambiente frio.</segment>
    <segment id="352">"</segment>
    <segment id="353">Surpreendentemente</segment>
    <segment id="354">, nunca foram encontrados restos fossilizados de répteis nos sítios arqueológicos do Alasca — apenas aves e mamíferos</segment>
    <segment id="355">, além dos dinossauros.</segment>
    <segment id="356">"</segment>
    <segment id="357">Agora,</segment>
    <segment id="358">sese você trabalhar em Montana e procurar dinossauros</segment>
    <segment id="359">, por todo o caminho você irá encontrar crocodilos</segment>
    <segment id="360">, tartarugas</segment>
    <segment id="361">, lagartos... nós nunca encontramos nenhum vestígio desses grupos de sangue frio"</segment>
    <segment id="362">, afirma Druckenmiller.</segment>
    <segment id="363">É claro que nem todos os dinossauros eram necessariamente de sangue quente.</segment>
    <segment id="364">Existem evidências de que sua temperatura corporal pode ter variado em até 17°C</segment>
    <segment id="365">, dependendo do grupo</segment>
    <segment id="366">, de 29 até 46°C.</segment>
    <segment id="367">Comparativamente</segment>
    <segment id="368">, a maioria dos mamíferos mantém-</segment>
    <segment id="369">sese na faixa de 36 a 40°C</segment>
    <segment id="370">, enquanto as aves são significativamente mais quentes</segment>
    <segment id="371">, variando de 41 até 43°C.</segment>
    <segment id="372">Brasileiro registra em fotos quando chegou ao ponto mais alto da América do NorteMais    novamente         de   de  de  representando um</segment>
    <segment id="373">Mas as consequências são enormes.</segment>
    <segment id="374">Os animais endotérmicos tipicamente possuem certas características comuns</segment>
    <segment id="375">, como</segment>
    <segment id="376">como maiores velocidades de crescimento e maior necessidade de alimento.</segment>
    <segment id="377">Fundamentalmente</segment>
    <segment id="378">, acreditava-</segment>
    <segment id="379">sese que isso foi o que permitiu que alguns grupos sobrevivessem ao resfriamento global historicamente responsabilizado pela extinção dos dinossauros.</segment>
    <segment id="380">Mas, se</segment>
    <segment id="381">se os mamíferos e as aves conseguiram lidar com isso</segment>
    <segment id="382">, por que não os dinossauros do Ártico?</segment>
    <segment id="383">À medida que as evidências dos dinossauros do Ártico começaram a acumular-</segment>
    <segment id="384">sese nos anos 1980</segment>
    <segment id="385">, os cientistas já percebiam que eles poderiam precisar de outra explicação.</segment>
    <segment id="386">Atualmente</segment>
    <segment id="387">, acredita-</segment>
    <segment id="388">sese que o motivo real da extinção da maioria deles tenha sido seu tamanho</segment>
    <segment id="389">, que significava que eles simplesmente precisavam de mais alimento do que havia disponível.</segment>
    <segment id="390">A exceção é o maniraptor ("mãos de captura").</segment>
    <segment id="391">Os membros menores deste grupo emplumado chegavam a pesar cerca de 1 kg e conseguiram resistir e adaptar-</segment>
    <segment id="392">sese.</segment>
    <segment id="393">Sua linhagem resultou nas aves atuais.</segment>
    <segment id="394">A cada nova descoberta</segment>
    <segment id="395">, esses dinossauros quase polares trazem indicações sobre a diversidade e a resiliência dos seus parentes em todo o planeta —e nos mostram que eles eram muito mais do que apenas lagartos gigantes.</segment>
  </rst>
</analysis>