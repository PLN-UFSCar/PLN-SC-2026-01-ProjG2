  <rst>
    <segment id="1">Conversas sobre dinheiro podem</segment>
    <segment id="2">sese tornar tão longas entre brasileiros na Argentina quanto o maço de notas na carteira.</segment>
    <segment id="3">"</segment>
    <segment id="4">É fácil</segment>
    <segment id="5">sese embolar"</segment>
    <segment id="6">, diz o carioca Well Rodrigues</segment>
    <segment id="7">, 30, que viu as cédulas "evaporarem" ao longo do dia em Bariloche e teve que ir buscar mais no hotel.</segment>
    <segment id="8">A inflação</segment>
    <segment id="9">, que bate três dígitos</segment>
    <segment id="10">, faz o peso</segment>
    <segment id="11">sese desvalorizar e o país ficar mais barato.</segment>
    <segment id="12">"</segment>
    <segment id="13">Preços baixaram em média 15% a 20% em um ano"</segment>
    <segment id="14">, diz Adriana Molha</segment>
    <segment id="15">, sócia da agência Brasileiros na Argentina.</segment>
    <segment id="16">Se 40 mil brasileiros voaram a Buenos Aires no primeiro trimestre de 2022</segment>
    <segment id="17">, o número chegou a 106 mil no mesmo período deste ano</segment>
    <segment id="18">, segundo o Indec (IBGE argentino).</segment>
    <segment id="19">A região de Puerto Madero</segment>
    <segment id="20">, uma das mais visitadas pelos turistas em Buenos Aires - Ronaldo Schemidt/AFPCom isso</segment>
    <segment id="21">, crescem perguntas sobre a melhor maneira de fazer pagamentos no país.</segment>
    <segment id="22">Abaixo</segment>
    <segment id="23">, tire dúvidas de qual moeda é mais vantajosa</segment>
    <segment id="24">, como</segment>
    <segment id="25">como fazer a conversão</segment>
    <segment id="26">, sese o uso de cartão é boa opção e</segment>
    <segment id="27">sese há perigo em andar com cédulas.    Veja as principais dúvidas sobre</segment>
    <segment id="28">comocomo fazer pagamentos na ArgentinaClique nas perguntas e navegue pelo textoComo funcionam as cotações do dólar?</segment>
    <segment id="29">Quais devo conhecer?Levo dólar</segment>
    <segment id="30">, real ou peso?Como fazer a conversão?É vantajoso fazer a troca de moeda de uma vez só?Vale a pena usar cartões de débito e crédito?Como pagar a hospedagem?É perigoso andar com notas?Como posso economizar na compra de passagens?Como economizar no transporte?Como funcionam as cotações do dólar?</segment>
    <segment id="31">Quais devo conhecer?</segment>
    <segment id="32">Existem mais de 15 cotações diferentes</segment>
    <segment id="33">, a depender do setor.</segment>
    <segment id="34">Para o turista</segment>
    <segment id="35">, o mais importante é o câmbio paralelo chamado de blue</segment>
    <segment id="36">, que vale praticamente o dobro do dólar oficial</segment>
    <segment id="37">, que é controlado pelo governo e só existe na teoria.</segment>
    <segment id="38">Nesta quarta (31)</segment>
    <segment id="39">, a cotação era de 493 pesos e 249 pesos</segment>
    <segment id="40">, respectivamente.</segment>
    <segment id="41">Outro câmbio com o qual o viajante pode</segment>
    <segment id="42">sese deparar é o dólar MEP</segment>
    <segment id="43">, usado pelo mercado financeiro —cartões de crédito</segment>
    <segment id="44">, débito e internacionais.</segment>
    <segment id="45">Normalmente</segment>
    <segment id="46">, ele vale um pouco menos do que o blue (466 pesos nesta quarta).</segment>
    <segment id="47">Sua viagem só será realmente barata</segment>
    <segment id="48">sese você usar essas conversões</segment>
    <segment id="49">, que são referência no valor pago pelo real.</segment>
    <segment id="50">Levo dólar</segment>
    <segment id="51">, real ou peso?</segment>
    <segment id="52">Quanto menos conversões você fizer</segment>
    <segment id="53">, menos dinheiro vai perder.</segment>
    <segment id="54">Por isso</segment>
    <segment id="55">, levar reais pode ser mais favorável.</segment>
    <segment id="56">Em cidades grandes ou que recebem muitos brasileiros</segment>
    <segment id="57">, como</segment>
    <segment id="58">como Buenos Aires e Bariloche</segment>
    <segment id="59">, é fácil trocar a moeda.</segment>
    <segment id="60">Em algumas localidades menores</segment>
    <segment id="61">, no entanto</segment>
    <segment id="62">, é bom ter dólares também.</segment>
    <segment id="63">Quanto aos pesos</segment>
    <segment id="64">, vale trocar um pouco no Brasil ou no aeroporto só para o transporte ou alimentação na chegada.</segment>
    <segment id="65">Mas você pagará a cotação oficial</segment>
    <segment id="66">, ou seja</segment>
    <segment id="67">, o dobro</segment>
    <segment id="68">, então não troque muito.</segment>
    <segment id="69">Como fazer a conversão?</segment>
    <segment id="70">Há diversas maneiras de trocar ou fazer a transferência da quantia (em dólares ou reais) e é importante avaliar qual</segment>
    <segment id="71">sese adequa melhor às suas necessidades.</segment>
    <segment id="72">Em todos os casos</segment>
    <segment id="73">, é preciso levar documento pessoal</segment>
    <segment id="74">, como</segment>
    <segment id="75">como passaporte.</segment>
    <segment id="76">Nas casas de câmbio paralelas é onde</segment>
    <segment id="77">sese pratica a cotação blue</segment>
    <segment id="78">, como</segment>
    <segment id="79">como as "cuevas" da rua Florida</segment>
    <segment id="80">, no centro de Buenos Aires.</segment>
    <segment id="81">Lá, ficam os "arbolitos"</segment>
    <segment id="82">, pessoas que sussurram "câmbio" no ouvido dos turistas.</segment>
    <segment id="83">Todos sabem que elas existem</segment>
    <segment id="84">, masmas são ilegais.</segment>
    <segment id="85">Se quiser arriscar</segment>
    <segment id="86">, o ideal é pedir indicação a conhecidos</segment>
    <segment id="87">, ao hotel ou à agência de viagem.</segment>
    <segment id="88">Uma das maneiras mais vantajosas de sacar dinheiro é por empresas</segment>
    <segment id="89">comocomo a Western Union</segment>
    <segment id="90">, com transações legalizadas.</segment>
    <segment id="91">Dá para transferir reais pelo app ou site da companhia (por Pix</segment>
    <segment id="92">, por exemplo) e sacar em pesos em uma loja na Argentina.</segment>
    <segment id="93">Mesmo com as taxas</segment>
    <segment id="94">, a cotação costuma ser melhor do que em casas de câmbio paralelas.</segment>
    <segment id="95">As desvantagens são as filas nas zonas turísticas e a possibilidade de não haver pesos suficientes na hora do saque</segment>
    <segment id="96">, o que pode levar a uma peregrinação por outras lojas.</segment>
    <segment id="97">Há outras alternativas</segment>
    <segment id="98">, como</segment>
    <segment id="99">como Wise e Remessa Online</segment>
    <segment id="100">, com diferentes taxas.</segment>
    <segment id="101">Também é possível ir a agências do Banco de la Nación Argentina e trocar dólares por pesos em espécie pela cotação MEP</segment>
    <segment id="102">, desde que o cliente comprove que é turista estrangeiro.</segment>
    <segment id="103">É legal</segment>
    <segment id="104">, masmas rende menos do que o câmbio blue.</segment>
    <segment id="105">Roteiro de baixo custo para conhecer Buenos AiresMais    novamente         de   de  de  representando um  É vantajoso fazer a troca de moeda de uma vez só?  Se sua estadia for mais longa</segment>
    <segment id="106">, vale trocar dinheiro a cada sete dias.</segment>
    <segment id="107">Como a moeda argentina</segment>
    <segment id="108">sese desvaloriza rapidamente</segment>
    <segment id="109">, na semana seguinte seus reais ou dólares estarão rendendo mais (e os preços também subirão).</segment>
    <segment id="110">A nota mais alta em circulação no país é a de 2.000 pesos</segment>
    <segment id="111">, ou seja</segment>
    <segment id="112">, cerca de R$ 20 ou US$ 4 na cotação blue.</segment>
    <segment id="113">Mas ela foi lançada recentemente pelo Banco Central</segment>
    <segment id="114">, devido à inflação</segment>
    <segment id="115">, portanto a nota mais comum ainda é a de 1.000 pesos (R$ 10).</segment>
    <segment id="116">Não se</segment>
    <segment id="117">se esqueça de levar uma mochila ou bolsinha para carregar o dinheiro</segment>
    <segment id="118">, porque</segment>
    <segment id="119">porque ele não vai caber no bolso.</segment>
    <segment id="120">Também não termine a viagem com pesos na carteira</segment>
    <segment id="121">, eles provavelmente não valerão nada quando você voltar à Argentina.</segment>
    <segment id="122">Vale a pena usar cartões de débito e crédito?</segment>
    <segment id="123">Até pouco tempo atrás</segment>
    <segment id="124">, usar qualquer cartão era desvantajoso</segment>
    <segment id="125">, porque</segment>
    <segment id="126">porque eles funcionavam na cotação oficial.</segment>
    <segment id="127">Em meados de março</segment>
    <segment id="128">, porém</segment>
    <segment id="129">porém, entrou em prática uma cotação próxima ao dólar MEP para cartões estrangeiros</segment>
    <segment id="130">, o que tornou a alternativa viável.</segment>
    <segment id="131">Quando você passa o cartão de crédito</segment>
    <segment id="132">, débito ou pré-pago no exterior</segment>
    <segment id="133">, o banco converte o preço em pesos para dólares</segment>
    <segment id="134">, e depois para reais.</segment>
    <segment id="135">Agora, a Visa já faz essa conversão na cotação MEP e a Mastercard cobra no câmbio oficial e estorna a diferença na fatura em até 72 horas.</segment>
    <segment id="136">Ainda assim</segment>
    <segment id="137">, há IOF de 5</segment>
    <segment id="138">,38% para cada compra.</segment>
    <segment id="139">Uma outra opção são os cartões de débito de contas digitais internacionais</segment>
    <segment id="140">, como</segment>
    <segment id="141">como Wise</segment>
    <segment id="142">, Nomad e dos bancos Inter e C6.</segment>
    <segment id="143">Elas também praticam o dólar MEP</segment>
    <segment id="144">, masmas têm a vantagem do IOF de 1</segment>
    <segment id="145">,1%.</segment>
    <segment id="146">Todas essas opções continuam um pouco mais caras do que o câmbio blue em dinheiro vivo</segment>
    <segment id="147">, masmas trazem praticidade.</segment>
    <segment id="148">Como pagar a hospedagem?</segment>
    <segment id="149">Com um cartão de crédito ou débito emitido no Brasil</segment>
    <segment id="150">, porque</segment>
    <segment id="151">porque assim o turista estrangeiro tem isenção total do IVA (imposto sobre bens e serviços da Argentina)</segment>
    <segment id="152">, de 21%</segment>
    <segment id="153">, em hotéis</segment>
    <segment id="154">, pousadas e similares.</segment>
    <segment id="155">Mas para isso é preciso pagar in loco</segment>
    <segment id="156">, e não pela internet.</segment>
    <segment id="157">"Ou seja</segment>
    <segment id="158">, isso não vale para plataformas</segment>
    <segment id="159">comocomo Airbnb"</segment>
    <segment id="160">, lembra Thaís Donatelli</segment>
    <segment id="161">, do perfil @thademochila</segment>
    <segment id="162">, que está fazendo um "mochilão" pelo país há mais de um mês.</segment>
    <segment id="163">A mesma isenção vale para compras em comércios credenciados no sistema Global Blue</segment>
    <segment id="164">, masmas nesse</segment>
    <segment id="165">casocaso é preciso pedir reembolso ao final da viagem.</segment>
    <segment id="166">É perigoso andar com notas?</segment>
    <segment id="167">No geral</segment>
    <segment id="168">, é uma prática comum no país.</segment>
    <segment id="169">Com a piora da crise econômica e da pobreza</segment>
    <segment id="170">, não é raro ouvir os argentinos reclamando do aumento da insegurança e de furtos de celulares</segment>
    <segment id="171">, masmas ainda não</segment>
    <segment id="172">sese compara ao cenário de grandes cidades do Brasil.  "</segment>
    <segment id="173">Para o turista isso ainda não apareceu</segment>
    <segment id="174">, não identificamos aumento de reclamações"</segment>
    <segment id="175">, diz Adriana Molha</segment>
    <segment id="176">, sócia da agência Brasileiros na Argentina.</segment>
    <segment id="177">Também não são habituais queixas sobre golpes ou notas falsas nas casas de câmbio paralelas</segment>
    <segment id="178">, masmas é sempre bom seguir indicações de locais de confiança.</segment>
    <segment id="179">Vinícolas de Mendoza</segment>
    <segment id="180">, na Argentina</segment>
    <segment id="181">, abraçam vinhos brancos e rosésMais    novamente         de   de  de  representando um</segment>
    <segment id="182">Como posso economizar na compra de passagens?</segment>
    <segment id="183">Os meses mais caros são dezembro</segment>
    <segment id="184">, janeiro e julho</segment>
    <segment id="185">, com preços voláteis que dependem da antecedência da compra.</segment>
    <segment id="186">Quem visita outros destinos além da capital encontra</segment>
    <segment id="187">, no geral</segment>
    <segment id="188">, mais vantagem indo a Buenos Aires e depois comprando voos internos.</segment>
    <segment id="189">O guia e youtuber Well Rodrigues</segment>
    <segment id="190">, do canal Well Viajando</segment>
    <segment id="191">, recomenda um caminho alternativo mais longo para quem quer economizar.</segment>
    <segment id="192">"</segment>
    <segment id="193">Consegui um desconto de R$ 600 indo do Rio para Foz do Iguaçu (PR)</segment>
    <segment id="194">, em relação a um voo direto para Buenos Aires.</segment>
    <segment id="195">Aproveitei para conhecer Ciudad del Este (Paraguai)</segment>
    <segment id="196">, atravessei para Puerto Iguazú (Argentina) de ônibus por R$ 15 e de lá peguei um voo interno para Buenos Aires.</segment>
    <segment id="197">"</segment>
    <segment id="198">Como economizar no transporte?</segment>
    <segment id="199">O transporte público (ônibus e metrô) funciona bem em Buenos Aires e custa menos de R$ 1.</segment>
    <segment id="200">Basta comprar e recarregar o cartão "</segment>
    <segment id="201">Sube</segment>
    <segment id="202">"</segment>
    <segment id="203">nas estações de metrô ou em algum "kiosco"</segment>
    <segment id="204">, pequenas lojas de conveniência espalhadas a cada esquina</segment>
    <segment id="205">, onde é possível ainda comprar um chip pré-pago de celular com internet</segment>
    <segment id="206">.</segment>
    <segment id="207">Aplicativos de transporte</segment>
    <segment id="208">comocomo Uber e Cabify também são usados e um pouco mais econômicos do que os táxis</segment>
    <segment id="209">, masmas não são legalizados no país —o melhor é sempre pagar em espécie.</segment>
    <segment id="210">Para quem vai a outras cidades</segment>
    <segment id="211">, o aluguel de carro é um dos mais baratos do mundo.</segment>
    <segment id="212">Recomenda-</segment>
    <segment id="213">sese fechar pela internet com antecedência.</segment>
  </rst>
</analysis>