      <rel name="non-volitional-result" type="rst"/>
      <rel name="volitional-cause" type="rst"/>
      <rel name="volitional-result" type="rst"/>
    </relations>
  </header>
  <rst>
    <segment id="1">Era uma manh&amp;atilde</segment>
    <segment id="2">; de sexta-feira e curiosos</segment>
    <segment id="3">sese revezavam para conseguir o melhor &amp;acirc</segment>
    <segment id="4">;ngulo da selfie em frente &amp;agrave</segment>
    <segment id="5">; pira ol&amp;iacute</segment>
    <segment id="6">;mpica.</segment>
    <segment id="7">N&amp;atilde</segment>
    <segment id="8">;o a de T&amp;oacute</segment>
    <segment id="9">;quio,</segment>
    <segment id="10">masmas a do Rio de Janeiro</segment>
    <segment id="11">, acesa horas antes para homenagear os jogos no Jap&amp;atilde</segment>
    <segment id="12">;o, que come&amp;ccedil</segment>
    <segment id="13">;avam naquele dia.</segment>
    <segment id="14">Cravado na zona portu&amp;aacute</segment>
    <segment id="15">;ria da cidade</segment>
    <segment id="16">, que foi s&amp;iacute</segment>
    <segment id="17">;mbolo da competi&amp;ccedil</segment>
    <segment id="18">;&amp;atilde</segment>
    <segment id="19">;o esportiva no Brasil em 2016</segment>
    <segment id="20">, o monumento agora revitalizado anuncia uma tentativa de ressuscitar a regi&amp;atilde</segment>
    <segment id="21">;o central carioca ap&amp;oacute</segment>
    <segment id="22">;s anos de poucos investimentos e baixa ocupa&amp;ccedil</segment>
    <segment id="23">;&amp;atilde</segment>
    <segment id="24">;o.</segment>
    <segment id="25">Levar moradores para a &amp;aacute</segment>
    <segment id="26">;rea, hoje preenchida por escrit&amp;oacute</segment>
    <segment id="27">;rios, &amp;eacute</segment>
    <segment id="28">;</segment>
    <segment id="29">a principal aposta novamente.</segment>
    <segment id="30">A constru&amp;ccedil</segment>
    <segment id="31">;&amp;atilde</segment>
    <segment id="32">;o de edif&amp;iacute</segment>
    <segment id="33">;cios residenciais come&amp;ccedil</segment>
    <segment id="34">;a a ser negociada</segment>
    <segment id="35">, obras de conserva&amp;ccedil</segment>
    <segment id="36">;&amp;atilde</segment>
    <segment id="37">;o s&amp;atilde</segment>
    <segment id="38">;o retomadas e novos projetos culturais e tur&amp;iacute</segment>
    <segment id="39">;sticos despontam</segment>
    <segment id="40">, prometendo uma transforma&amp;ccedil</segment>
    <segment id="41">;&amp;atilde</segment>
    <segment id="42">;o nos pr&amp;oacute</segment>
    <segment id="43">;ximos anos.</segment>
    <segment id="44">O Museu do Amanh&amp;atilde</segment>
    <segment id="45">; negocia com um local para abrir uma escola de anima&amp;ccedil</segment>
    <segment id="46">;&amp;atilde</segment>
    <segment id="47">;o e games para 500 alunos.</segment>
    <segment id="48">A Marinha e o IAB (Instituto de Arquitetos do Brasil) escolhem projetos para transformar um p&amp;iacute</segment>
    <segment id="49">;er num museu mar&amp;iacute</segment>
    <segment id="50">;timo de n&amp;iacute</segment>
    <segment id="51">;vel internacional</segment>
    <segment id="52">, ainda a depender de verba federal.</segment>
    <segment id="53">E um novo museu tem&amp;aacute</segment>
    <segment id="54">;tico est&amp;aacute</segment>
    <segment id="55">; para ser anunciado.  Porto Maravilha no RioMais    novamente         de   de  de  representando um</segment>
    <segment id="56">Um espa&amp;ccedil</segment>
    <segment id="57">;o dedicado a feiras tamb&amp;eacute</segment>
    <segment id="58">;m ser&amp;aacute</segment>
    <segment id="59">; inaugurado no edif&amp;iacute</segment>
    <segment id="60">;cio hist&amp;oacute</segment>
    <segment id="61">;rico Moinho Fluminense</segment>
    <segment id="62">, e um complexo gastron&amp;ocirc</segment>
    <segment id="63">;mico batizado de Mercado do Porto deve ocupar um palacete da Pra&amp;ccedil</segment>
    <segment id="64">;a Mau&amp;aacute</segment>
    <segment id="65">;.</segment>
    <segment id="66">J&amp;aacute</segment>
    <segment id="67">; o Terreir&amp;atilde</segment>
    <segment id="68">;o do Samba</segment>
    <segment id="69">, fechado desde 2019</segment>
    <segment id="70">, passa por estudos para ser concedido e abrigar eventos o ano todo.</segment>
    <segment id="71">&amp;ldquo</segment>
    <segment id="72">;Para mim</segment>
    <segment id="73">, que assisti esse projeto desde o in&amp;iacute</segment>
    <segment id="74">;cio, &amp;eacute</segment>
    <segment id="75">; um momento de gl&amp;oacute</segment>
    <segment id="76">;ria&amp;quot</segment>
    <segment id="77">;, exalta Gustavo Guerrante</segment>
    <segment id="78">, diretor da companhia municipal respons&amp;aacute</segment>
    <segment id="79">;vel por administrar a regi&amp;atilde</segment>
    <segment id="80">;o (Cdurp) e ex-subsecret&amp;aacute</segment>
    <segment id="81">;rio de concess&amp;otilde</segment>
    <segment id="82">;es e parcerias p&amp;uacute</segment>
    <segment id="83">;blico-privadas.</segment>
    <segment id="84">O Porto Maravilha foi uma das maiores obras de revitaliza&amp;ccedil</segment>
    <segment id="85">;&amp;atilde</segment>
    <segment id="86">;o urbana do Rio.</segment>
    <segment id="87">Antes, passava por ali a Perimetral</segment>
    <segment id="88">, viaduto que interligava v&amp;aacute</segment>
    <segment id="89">;rias regi&amp;otilde</segment>
    <segment id="90">;es da cidade e fazia do entorno um ambiente sombrio.</segment>
    <segment id="91">O elevado foi demolido e deu lugar a um boulevard p&amp;uacute</segment>
    <segment id="92">;blico &amp;agrave</segment>
    <segment id="93">; beira do mar.</segment>
    <segment id="94">&amp;Agrave</segment>
    <segment id="95">;quela altura</segment>
    <segment id="96">, &amp;agrave</segment>
    <segment id="97">;s v&amp;eacute</segment>
    <segment id="98">;speras dos eventos esportivos</segment>
    <segment id="99">, a cidade atra&amp;iacute</segment>
    <segment id="100">;a investidores e triplicava seu estoque de im&amp;oacute</segment>
    <segment id="101">;veis.</segment>
    <segment id="102">A crise econ&amp;ocirc</segment>
    <segment id="103">;mica que</segment>
    <segment id="104">sese seguiu</segment>
    <segment id="105">, por&amp;eacute</segment>
    <segment id="106">;m, fez diversas companhias fecharem e devolverem seus espa&amp;ccedil</segment>
    <segment id="107">;os.</segment>
    <segment id="108">O resultado foi muito pr&amp;eacute</segment>
    <segment id="109">;dio e pouca gente na &amp;aacute</segment>
    <segment id="110">;rea, chegando a uma taxa de vac&amp;acirc</segment>
    <segment id="111">;ncia de 94% em 2016.</segment>
    <segment id="112">&amp;ldquo</segment>
    <segment id="113">;</segment>
    <segment id="114">Atraiu-</segment>
    <segment id="115">sese uma s&amp;eacute</segment>
    <segment id="116">;rie de empresas para l&amp;aacute</segment>
    <segment id="117">;, mas</segment>
    <segment id="118">mas se</segment>
    <segment id="119">se olhou isso s&amp;oacute</segment>
    <segment id="120">; pelo aspecto f&amp;iacute</segment>
    <segment id="121">;sico, e n&amp;atilde</segment>
    <segment id="122">;o conjuntural e econ&amp;ocirc</segment>
    <segment id="123">;mico da cidade.</segment>
    <segment id="124">O local continua em decad&amp;ecirc</segment>
    <segment id="125">;ncia, desocupado</segment>
    <segment id="126">, sem vitalidade&amp;rdquo</segment>
    <segment id="127">;, avalia o urbanista Luiz Fernando Janot</segment>
    <segment id="128">, conselheiro do Instituto de Arquitetos do Brasil (IAB-RJ).</segment>
    <segment id="129">A partir de 2018</segment>
    <segment id="130">, o mercado voltou a</segment>
    <segment id="131">sese aquecer e o Porto come&amp;ccedil</segment>
    <segment id="132">;ou a se</segment>
    <segment id="133">se fortalecer com edif&amp;iacute</segment>
    <segment id="134">;cios mais novos e baratos que a Barra da Tijuca</segment>
    <segment id="135">, por exemplo.</segment>
    <segment id="136">Mas veio a pandemia e a regi&amp;atilde</segment>
    <segment id="137">;o foi esvaziada novamente</segment>
    <segment id="138">, com o home office e o trabalho h&amp;iacute</segment>
    <segment id="139">;brido.</segment>
    <segment id="140">Mesmo assim</segment>
    <segment id="141">, a zona tem hoje menos espa&amp;ccedil</segment>
    <segment id="142">;os vagos que a m&amp;eacute</segment>
    <segment id="143">;dia do Rio de Janeiro (29% contra 39%) e representa um ter&amp;ccedil</segment>
    <segment id="144">;o das loca&amp;ccedil</segment>
    <segment id="145">;&amp;otilde</segment>
    <segment id="146">;es na cidade nos &amp;uacute</segment>
    <segment id="147">;ltimos tr&amp;ecirc</segment>
    <segment id="148">;s anos</segment>
    <segment id="149">, segundo a consultoria imobili&amp;aacute</segment>
    <segment id="150">;ria Binswanger Brazil.</segment>
    <segment id="151">A diretora da empresa</segment>
    <segment id="152">, Evie Kempf</segment>
    <segment id="153">, prev&amp;ecirc</segment>
    <segment id="154">; agora um per&amp;iacute</segment>
    <segment id="155">;odo f&amp;eacute</segment>
    <segment id="156">;rtil.  &amp;ldquo</segment>
    <segment id="157">;Com a vacina</segment>
    <segment id="158">, as empresas come&amp;ccedil</segment>
    <segment id="159">;am a voltar parcialmente.</segment>
    <segment id="160">A pandemia tamb&amp;eacute</segment>
    <segment id="161">;m fez o setor residencial crescer absurdamente.</segment>
    <segment id="162">Estamos muito otimistas no Porto Maravilha</segment>
    <segment id="163">, deve vir muita coisa&amp;rdquo</segment>
    <segment id="164">;, diz ela</segment>
    <segment id="165">, que trabalha com a regi&amp;atilde</segment>
    <segment id="166">;o central h&amp;aacute</segment>
    <segment id="167">; mais de 20 anos.</segment>
    <segment id="168">A primeira coisa que veio</segment>
    <segment id="169">, em junho</segment>
    <segment id="170">, foi o Rio Wonder Residences</segment>
    <segment id="171">, com tr&amp;ecirc</segment>
    <segment id="172">;s torres de 20 andares e 1.200 apartamentos a serem erguidos.</segment>
    <segment id="173">Os primeiros 470 &amp;agrave</segment>
    <segment id="174">; venda esgotaram em menos de um m&amp;ecirc</segment>
    <segment id="175">;s, e a mesma construtora j&amp;aacute</segment>
    <segment id="176">; adquiriu um segundo terreno para ofertar mais 700 unidades.</segment>
    <segment id="177">O plano de seduzir moradores tamb&amp;eacute</segment>
    <segment id="178">;m &amp;eacute</segment>
    <segment id="179">; impulsionado por um novo programa no entorno</segment>
    <segment id="180">, chamado Reviver Centro.</segment>
    <segment id="181">Sancionado pelo prefeito Eduardo Paes (PSD) em julho</segment>
    <segment id="182">, ele d&amp;aacute</segment>
    <segment id="183">; incentivos fiscais nos bairros mais abaixo do Porto</segment>
    <segment id="184">para que</segment>
    <segment id="185">para que o mercado construa habita&amp;ccedil</segment>
    <segment id="186">;&amp;otilde</segment>
    <segment id="187">;es e transforme pr&amp;eacute</segment>
    <segment id="188">;dios comerciais ociosos em residenciais ou mistos (o chamado retrofit).</segment>
    <segment id="189">&amp;ldquo</segment>
    <segment id="190">;Nossas pesquisas mostram que as pessoas gostam do Centro e at&amp;eacute</segment>
    <segment id="191">;</segment>
    <segment id="192">morariam l&amp;aacute</segment>
    <segment id="193">;, mas</segment>
    <segment id="194">mas t&amp;ecirc</segment>
    <segment id="195">;m medo&amp;rdquo</segment>
    <segment id="196">;, diz o secret&amp;aacute</segment>
    <segment id="197">;rio municipal de Planejamento Urbano</segment>
    <segment id="198">, Washington Fajardo.</segment>
    <segment id="199">&amp;ldquo</segment>
    <segment id="200">;Queremos atrair uma classe m&amp;eacute</segment>
    <segment id="201">;dia que mora na zona norte</segment>
    <segment id="202">, por exemplo</segment>
    <segment id="203">, masmas trabalha ali</segment>
    <segment id="204">, al&amp;eacute</segment>
    <segment id="205">;m de destinar uma parte &amp;agrave</segment>
    <segment id="206">; loca&amp;ccedil</segment>
    <segment id="207">;&amp;atilde</segment>
    <segment id="208">;o social e &amp;agrave</segment>
    <segment id="209">;</segment>
    <segment id="210">moradia assistida para moradores de rua.&amp;rdquo</segment>
    <segment id="211">;  &amp;Eacute</segment>
    <segment id="212">;</segment>
    <segment id="213">um consenso entre urbanistas que a gest&amp;atilde</segment>
    <segment id="214">;o anterior</segment>
    <segment id="215">, de Marcelo Crivella (PRB)</segment>
    <segment id="216">, pouco fez pela regi&amp;atilde</segment>
    <segment id="217">;o.</segment>
    <segment id="218">Agora, Paes</segment>
    <segment id="219">, que levou o &amp;ocirc</segment>
    <segment id="220">;nus pela revitaliza&amp;ccedil</segment>
    <segment id="221">;&amp;atilde</segment>
    <segment id="222">;o e voltou &amp;agrave</segment>
    <segment id="223">; cadeira de prefeito</segment>
    <segment id="224">, quer terminar o que come&amp;ccedil</segment>
    <segment id="225">;ou.  Segundo Guerrante</segment>
    <segment id="226">, diretor da Cdurp</segment>
    <segment id="227">, a ideia &amp;eacute</segment>
    <segment id="228">; que o munic&amp;iacute</segment>
    <segment id="229">;pio d&amp;ecirc</segment>
    <segment id="230">; mais aten&amp;ccedil</segment>
    <segment id="231">;&amp;atilde</segment>
    <segment id="232">;o &amp;agrave</segment>
    <segment id="233">; manuten&amp;ccedil</segment>
    <segment id="234">;&amp;atilde</segment>
    <segment id="235">;o, invista numa rotina de eventos assim que a pandemia permitir e termine as obras de reurbaniza&amp;ccedil</segment>
    <segment id="236">;&amp;atilde</segment>
    <segment id="237">;o de ruas que estavam previstas no projeto &amp;mdash</segment>
    <segment id="238">;faltam 13% delas.</segment>
    <segment id="239">Tamb&amp;eacute</segment>
    <segment id="240">;m est&amp;aacute</segment>
    <segment id="241">; nos planos estender a linha do VLT (ve&amp;iacute</segment>
    <segment id="242">;culo leve sobre trilhos) que atravessa o Porto e interlig&amp;aacute</segment>
    <segment id="243">;-la com o BRT (corredor exclusivo de &amp;ocirc</segment>
    <segment id="244">;nibus) at&amp;eacute</segment>
    <segment id="245">; 2023.</segment>
    <segment id="246">J&amp;aacute</segment>
    <segment id="247">; o telef&amp;eacute</segment>
    <segment id="248">;rico do morro da Provid&amp;ecirc</segment>
    <segment id="249">;ncia, parado desde 2016</segment>
    <segment id="250">, passa por uma avalia&amp;ccedil</segment>
    <segment id="251">;&amp;atilde</segment>
    <segment id="252">;o de engenharia.</segment>
    <segment id="253">Guerrante sustenta que h&amp;aacute</segment>
    <segment id="254">; condi&amp;ccedil</segment>
    <segment id="255">;&amp;otilde</segment>
    <segment id="256">;es financeiras para as mudan&amp;ccedil</segment>
    <segment id="257">;as.</segment>
    <segment id="258">&amp;ldquo</segment>
    <segment id="259">;Evidentemente &amp;eacute</segment>
    <segment id="260">; feita uma adapta&amp;ccedil</segment>
    <segment id="261">;&amp;atilde</segment>
    <segment id="262">;o do projeto para adequ&amp;aacute</segment>
    <segment id="263">;-lo a uma realidade e um prazo diferentes.</segment>
    <segment id="264">Antes precisava acontecer at&amp;eacute</segment>
    <segment id="265">; as Olimp&amp;iacute</segment>
    <segment id="266">;adas [de 2016] e erguer tudo do zero.</segment>
    <segment id="267">Agora n&amp;atilde</segment>
    <segment id="268">;o h&amp;aacute</segment>
    <segment id="269">; essa necessidade.&amp;rdquo</segment>
    <segment id="270">;  Museu de Arte Urbana do Porto (Maup)</segment>
    <segment id="271">, no Rio de JaneiroMais    novamente         de   de  de  representando um  Mas h&amp;aacute</segment>
    <segment id="272">; uma pedra no meio do caminho.</segment>
    <segment id="273">O contrato de parceria p&amp;uacute</segment>
    <segment id="274">;blico-privada que previa toda a manuten&amp;ccedil</segment>
    <segment id="275">;&amp;atilde</segment>
    <segment id="276">;o e as reformas na regi&amp;atilde</segment>
    <segment id="277">;o pela concession&amp;aacute</segment>
    <segment id="278">;ria Porto Novo foi cancelado por falta de repasses da prefeitura</segment>
    <segment id="279">, que agora tenta negociar a volta da empresa.</segment>
    <segment id="280">O modelo da concess&amp;atilde</segment>
    <segment id="281">;o &amp;eacute</segment>
    <segment id="282">; baseado nos chamados Cepacs (Certificados de Potencial Adicional de Constru&amp;ccedil</segment>
    <segment id="283">;&amp;atilde</segment>
    <segment id="284">;o), pap&amp;eacute</segment>
    <segment id="285">;is que as construtoras t&amp;ecirc</segment>
    <segment id="286">;m que comprar quando querem construir na zona portu&amp;aacute</segment>
    <segment id="287">;ria.</segment>
    <segment id="288">Era esse dinheiro que custearia as obras e a zeladoria ali.</segment>
    <segment id="289">Com a crise</segment>
    <segment id="290">, a Caixa Econ&amp;ocirc</segment>
    <segment id="291">;mica, que det&amp;eacute</segment>
    <segment id="292">;m todos os t&amp;iacute</segment>
    <segment id="293">;tulos</segment>
    <segment id="294">, s&amp;oacute</segment>
    <segment id="295">; conseguiu vender menos de 10% deles.</segment>
    <segment id="296">A fonte secou e os servi&amp;ccedil</segment>
    <segment id="297">;os foram sendo paralisados</segment>
    <segment id="298">, at&amp;eacute</segment>
    <segment id="299">; que a prefeitura teve que assumi-los com verba pr&amp;oacute</segment>
    <segment id="300">;pria em 2018.</segment>
    <segment id="301">O imbr&amp;oacute</segment>
    <segment id="302">;glio est&amp;aacute</segment>
    <segment id="303">; na Justi&amp;ccedil</segment>
    <segment id="304">;a Federal</segment>
    <segment id="305">, a quem o banco j&amp;aacute</segment>
    <segment id="306">;</segment>
    <segment id="307">afirmou que a opera&amp;ccedil</segment>
    <segment id="308">;&amp;atilde</segment>
    <segment id="309">;o urbana era invi&amp;aacute</segment>
    <segment id="310">;vel desde o in&amp;iacute</segment>
    <segment id="311">;cio.</segment>
    <segment id="312">Outra decep&amp;ccedil</segment>
    <segment id="313">;&amp;atilde</segment>
    <segment id="314">;o recente foi a falta de interessados no leil&amp;atilde</segment>
    <segment id="315">;o do hist&amp;oacute</segment>
    <segment id="316">;rico edif&amp;iacute</segment>
    <segment id="317">;cio</segment>
    <segment id="318">A Noite​</segment>
    <segment id="319">, primeiro arranha-c&amp;eacute</segment>
    <segment id="320">;u da Am&amp;eacute</segment>
    <segment id="321">;rica Latina e que est&amp;aacute</segment>
    <segment id="322">; vazio desde 2012.</segment>
    <segment id="323">Mesmo com desconto</segment>
    <segment id="324">, a burocracia por ser um pr&amp;eacute</segment>
    <segment id="325">;dio da Uni&amp;atilde</segment>
    <segment id="326">;o e a necessidade de grandes reformas dificultam a venda.</segment>
    <segment id="327">Para o urbanista Janot</segment>
    <segment id="328">, a tentativa de atrair moradores ao Porto e ao Centro &amp;eacute</segment>
    <segment id="329">; positiva</segment>
    <segment id="330">, masmas a responsabilidade novamente est&amp;aacute</segment>
    <segment id="331">; sendo dada nas m&amp;atilde</segment>
    <segment id="332">;os do mercado imobili&amp;aacute</segment>
    <segment id="333">;rio, o que j&amp;aacute</segment>
    <segment id="334">; foi um erro no passado.</segment>
    <segment id="335">&amp;ldquo</segment>
    <segment id="336">;No papel tudo &amp;eacute</segment>
    <segment id="337">; muito bacana</segment>
    <segment id="338">, masmas na pr&amp;aacute</segment>
    <segment id="339">;tica n&amp;atilde</segment>
    <segment id="340">;o &amp;eacute</segment>
    <segment id="341">; t&amp;atilde</segment>
    <segment id="342">;o f&amp;aacute</segment>
    <segment id="343">;cil&amp;rdquo</segment>
    <segment id="344">;, diz.</segment>
    <segment id="345">A consultora imobili&amp;aacute</segment>
    <segment id="346">;ria Evie Kempf argumenta que n&amp;atilde</segment>
    <segment id="347">;o h&amp;aacute</segment>
    <segment id="348">;</segment>
    <segment id="349">outro jeito: &amp;ldquo</segment>
    <segment id="350">;H&amp;aacute</segment>
    <segment id="351">; controv&amp;eacute</segment>
    <segment id="352">;rsias e pensamentos diferentes sempre.</segment>
    <segment id="353">Mas a primeira coisa &amp;eacute</segment>
    <segment id="354">; resolver</segment>
    <segment id="355">, e quem vai ajudar &amp;eacute</segment>
    <segment id="356">; o mercado.</segment>
    <segment id="357">O Centro est&amp;aacute</segment>
    <segment id="358">; na UTI&amp;rdquo</segment>
