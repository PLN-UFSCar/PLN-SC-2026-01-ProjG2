  <rst>
    <segment id="1">Conhecida pelo bordão "</segment>
    <segment id="2">Ai, que loucura"</segment>
    <segment id="3">, a socialite Narcisa Tamborindeguy adicionou outras frases do mesmo estilo ao virar garota propaganda de um brechó de luxo.</segment>
    <segment id="4">"</segment>
    <segment id="5">Ai, que reciclagem</segment>
    <segment id="6">, ai, que desapego"</segment>
    <segment id="7">, repetia ela durante uma live no Instagram</segment>
    <segment id="8">, realizada na noite desta segunda (28)</segment>
    <segment id="9">, para o Cansei Vendi.</segment>
    <segment id="10">A empresa</segment>
    <segment id="11">, que tem entre seus sócios a atriz Luana Piovani</segment>
    <segment id="12">, sese define</segment>
    <segment id="13">comocomo um canal de compra e venda de artigos seminovos.</segment>
    <segment id="14">A socialite Narcisa Tamborindeguy mostra bolsa</segment>
    <segment id="15">Birkin</segment>
    <segment id="16">de R$ 82 mil em live de brechó de luxo -</segment>
    <segment id="17">@narcisat no InstagramNa quase uma hora em que ficou ao vivo promovendo as peças de luxo para cerca de mil pessoas conectadas</segment>
    <segment id="18">, Narcisa fez piadas e</segment>
    <segment id="19">sese apaixonou por uma bolsa Birkin</segment>
    <segment id="20">, da grife</segment>
    <segment id="21">Hermès</segment>
    <segment id="22">, comercializada por R$ 82.418.</segment>
    <segment id="23">"</segment>
    <segment id="24">Essa é a minha cara.</segment>
    <segment id="25">É muito chique</segment>
    <segment id="26">, tem duas cores.</segment>
    <segment id="27">Ninguém tem"</segment>
    <segment id="28">, dizia ela.</segment>
    <segment id="29">Batizada em homenagem à atriz Jane Birkin</segment>
    <segment id="30">, a bolsa Birkin é considerada uma das mais caras e exclusivas do mundo.</segment>
    <segment id="31">O modelo apresentado por Narcisa seria uma edição limitada feita especialmente para a sua primeira dona</segment>
    <segment id="32">, nas cores azul e laranja.</segment>
    <segment id="33">"</segment>
    <segment id="34">Eu amei essa.</segment>
    <segment id="35">Quem vai me dar essa de presente?</segment>
    <segment id="36">", indagou a socialite.</segment>
    <segment id="37">Narcisa também anunciou outras peças "mais em conta"</segment>
    <segment id="38">, como</segment>
    <segment id="39">como bolsas Chanel na faixa dos R$ 20 mil</segment>
    <segment id="40">, e óculos de sol</segment>
    <segment id="41">, broches e itens de luxo diversos.</segment>
    <segment id="42">Aproveitou também para vender as suas próprias peças expostas no site da Cansei Vendi</segment>
    <segment id="43">, como</segment>
    <segment id="44">como uma bolsa Karl Lagerfeld por R$ 2.200.</segment>
    <segment id="45">"</segment>
    <segment id="46">Adoro vir desapegar das minhas coisas aqui"</segment>
    <segment id="47">, dizia ela.</segment>
    <segment id="48">Segundo o anunciado</segment>
    <segment id="49">, os interessados deveriam ir até o site para comprar as peças.</segment>
    <segment id="50">"</segment>
    <segment id="51">Dá pra parcelar em 12 vezes</segment>
    <segment id="52">, masmas é melhor à vista"</segment>
    <segment id="53">, aconselhou a socialite.</segment>
    <segment id="54">Narcisa disse também que comprar bolsas de luxo pouco usadas era um investimento e contribuía para a sustentabilidade ambiental.</segment>
    <segment id="55">"</segment>
    <segment id="56">Vamos reciclar os produtos de luxo.</segment>
    <segment id="57">Ai, que desapego</segment>
    <segment id="58">, ai, que moda circular.</segment>
    <segment id="59">Ai, que second hand [segunda mão].</segment>
    <segment id="60">"  Imagens da socialite Narcisa TamborindeguyMais    novamente         de   de  de  representando um</segment>
    <segment id="61">Em outro momento</segment>
    <segment id="62">, ela disse que a loja aceitava todas as formas de pagamento</segment>
    <segment id="63">, inclusive cheque.</segment>
    <segment id="64">"</segment>
    <segment id="65">Só não pode ser sem fundos"</segment>
    <segment id="66">, brincou.</segment>
    <segment id="67">Informada por uma das donas do brechó de que eles não aceitavam cheque</segment>
    <segment id="68">, Narcisa pareceu inicialmente um pouco contrariada.</segment>
    <segment id="69">"Tem que aceitar.</segment>
    <segment id="70">Eu sou raiz"</segment>
    <segment id="71">, afirmou.</segment>
    <segment id="72">Mas depois ela mesma contemporizou.</segment>
    <segment id="73">"</segment>
    <segment id="74">O mundo inteiro digital</segment>
    <segment id="75">, e eu aqui com o meu cheque.</segment>
    <segment id="76">"  "</segment>
    <segment id="77">Me manda um Pixão"</segment>
    <segment id="78">, brincou</segment>
    <segment id="79">, em referência ao Pix.</segment>
    <segment id="80">"</segment>
    <segment id="81">A gente só não aceita lavagem de dinheiro</segment>
    <segment id="82">, o dinheiro aqui tem que ter origem"</segment>
    <segment id="83">, acrescentou</segment>
    <segment id="84">, entre risos.</segment>
    <segment id="85">Perto do fim da live</segment>
    <segment id="86">, Narcisa contou que comprou a sua primeira bolsa Louis Vuitton quando tinha oito anos</segment>
    <segment id="87">, em Paris</segment>
    <segment id="88">, incentivada pela mãe.</segment>
    <segment id="89">"</segment>
    <segment id="90">Acho que tenho até hoje.</segment>
    <segment id="91">Ela dura</segment>
    <segment id="92">, dura.</segment>
    <segment id="93">"</segment>
    <segment id="94">Ainda durante o evento</segment>
    <segment id="95">, ela mandou beijos para os amigos</segment>
    <segment id="96">comocomo Bia Doria.</segment>
    <segment id="97">"</segment>
    <segment id="98">Sei que você está me assistindo.</segment>
    <segment id="99">Eu te amo"</segment>
    <segment id="100">, disse.  com BIANKA VIEIRA</segment>
    <segment id="101">, KARINA MATIAS e MANOELLA SMITH</segment>
  </rst>
</analysis>