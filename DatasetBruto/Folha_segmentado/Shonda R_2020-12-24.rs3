  <rst>
    <segment id="1">A roteirista e produtora americana Shonda Rhimes é responsável por alguns dos maiores sucessos da TV dos últimos anos</segment>
    <segment id="2">, como</segment>
    <segment id="3">como “Grey’s Anatomy” e “Scandal”.</segment>
    <segment id="4">Agora, sob contrato exclusivo com a Netflix</segment>
    <segment id="5">, ela lança a sua primeira série de época</segment>
    <segment id="6">, "Bridgerton"</segment>
    <segment id="7">, ambientada na Londres do século 19.</segment>
    <segment id="8">A história da família Bridgerton</segment>
    <segment id="9">, em busca de amor e status social</segment>
    <segment id="10">, soa como</segment>
    <segment id="11">como um amontoado de clichês</segment>
    <segment id="12">, não fosse por um diferencial importante: o elenco é multirracial</segment>
    <segment id="13">, com atores não brancos interpretando nobres ingleses.</segment>
    <segment id="14">&amp;#039;Bridgerton&amp;#039</segment>
    <segment id="15">;, série da Netflix produzida por Shonda RhimesMais    novamente         de   de  de  representando um    Netflix</segment>
    <segment id="16">, 16 anos</segment>
    <segment id="17">PéPequeno Migo é um homem das neves nem tão abominável assim.</segment>
    <segment id="18">Ele morre de medo de uma coisa: o lendário PéPequeno</segment>
    <segment id="19">, também conhecido</segment>
    <segment id="20">comocomo ser humano.</segment>
    <segment id="21">Esta animação conta o que acontece quando as duas criaturas</segment>
    <segment id="22">sese encontram.</segment>
    <segment id="23">PéPequenoMais    novamente         de   de  de  representando um    Globo</segment>
    <segment id="24">, 15h, livre</segment>
    <segment id="25">O Começo do Natal</segment>
    <segment id="26">Um ladrão ateu e um padre católico são transportados magicamente para a Palestina de 2.000 anos atrás e presenciam o nascimento de Jesus Cristo.</segment>
    <segment id="27">Inédita</segment>
    <segment id="28">, esta comédia é uma autêntica representante do subgênero natalino que os italianos chamam de cinepanettone.</segment>
    <segment id="29">HBO Mundi</segment>
    <segment id="30">, 22h, 12 anos   Gilda</segment>
    <segment id="31">, Lúcia e o Bode Fernanda Montenegro e Fernanda Torres voltam</segment>
    <segment id="32">comocomo as mãe e filha que interpretaram em um episódio da série “Amor e Sorte”</segment>
    <segment id="33">, exibida em setembro.</segment>
    <segment id="34">Agora elas moram juntas no Rio de Janeiro</segment>
    <segment id="35">, e precisam</segment>
    <segment id="36">sese livrar de um bode que ganharam na rifa.</segment>
    <segment id="37">Especial &amp;#</segment>
    <segment id="38">039;Gilda</segment>
    <segment id="39">, Lúcia e o Bode&amp;#039</segment>
    <segment id="40">;Mais    novamente         de   de  de  representando um    Globo</segment>
    <segment id="41">, 22h30</segment>
    <segment id="42">, 12 anos</segment>
    <segment id="43">Paulo, Apóstolo de Cristo Jim Caviezel</segment>
    <segment id="44">, de “</segment>
    <segment id="45">A Paixão de Cristo”</segment>
    <segment id="46">, encarna mais um personagem bíblico: são Lucas</segment>
    <segment id="47">, que visita são Paulo na prisão.</segment>
    <segment id="48">Os dois então relembram a vida desse último</segment>
    <segment id="49">, de perseguidor de cristãos a propagador dos evangelhos.    Record</segment>
    <segment id="50">, 22h45</segment>
    <segment id="51">, 12 anos   Dê Lembranças a Todos</segment>
