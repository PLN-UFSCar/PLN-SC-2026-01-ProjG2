  <rst>
    <segment id="1">O governador do Pará</segment>
    <segment id="2">, Helder Barbalho (MDB)</segment>
    <segment id="3">, foi eleito presidente do Consórcio Amazônia Legal</segment>
    <segment id="4">, formado pelos nove estados que compõem a região: Acre</segment>
    <segment id="5">, Amapá</segment>
    <segment id="6">, Amazonas</segment>
    <segment id="7">, Mato Grosso</segment>
    <segment id="8">, Maranhão</segment>
    <segment id="9">, Rondônia</segment>
    <segment id="10">, Roraima e Tocantins</segment>
    <segment id="11">, além do próprio estado do emedebista.</segment>
    <segment id="12">Barbalho foi eleito por unanimidade e ficará à frente do colegiado durante o ano de 2023.</segment>
    <segment id="13">Ele assume o posto atualmente ocupado por Waldez Góes (PDT)</segment>
    <segment id="14">, do Amapá.</segment>
    <segment id="15">O consórcio foi criado para a elaboração de políticas conjuntas e a defesa articulada dos interesses dos estados da região.</segment>
    <segment id="16">A meta estabelecida pelo bloco de estados quando o consórcio foi   ser referência global em articulação</segment>
    <segment id="17">, estratégia e governança para transformar a Amazônia Legal em uma região competitiva</segment>
    <segment id="18">, integrada e sustentável</segment>
    <segment id="19">, até 2030.</segment>
    <segment id="20">Como representante do consórcio</segment>
    <segment id="21">, o governador do Pará participou da COP27</segment>
    <segment id="22">, conferência da ONU para mudanças climáticas no Egito</segment>
    <segment id="23">, durante a qual negociou novos aportes ao Fundo Amazônia e propôs que a COP30</segment>
    <segment id="24">, marcada para 2025</segment>
    <segment id="25">, seja realizada em algum estado da Amazônia.</segment>
    <segment id="26">Helder Barbalho (MDB) durante evento de campanha de governadores com Lula (PT) - Mathilde Missioneiro-5.out.2022/Folhapress</segment>
  </rst>
</analysis>