    <segment id="8">, Toni Garrido e outros</segment>
    <segment id="9">sese apresentam na "Viva Cazuza Live"</segment>
    <segment id="10">, que marca os 30 anos da morte de Cazuza.</segment>
    <segment id="11">Nomes como</segment>
    <segment id="12">como Elza Soares</segment>
    <segment id="13">, Gal Costa e Marcelo D2 fazem participações.</segment>
    <segment id="14">O show pode ser visto nos canais da dupla Overdrive Duo</segment>
    <segment id="15">, que comanda o evento junto com o ex-Kid Abelha George Israel.</segment>
    <segment id="16">CazuzaMais    novamente         de   de  de  representando um  Facebook</segment>
    <segment id="17">, Tik Tok</segment>
    <segment id="18">, Cifras e canais 500 e 530 da Claro</segment>
    <segment id="19">, 20h</segment>
    <segment id="20">Safári em Casa</segment>
    <segment id="21">A ONG Onçafari</segment>
    <segment id="22">, atuante no estudo e conservação da onça-pintada</segment>
    <segment id="23">, disponibiliza em vídeo um safári virtual pelo Refúgio Ecológico Caiman</segment>
    <segment id="24">, no Pantanal sul-mato-grossense.</segment>
    <segment id="25">Os biólogos Lilian Rampim e Pedro Reali e o guia Mario Nelson conduzem a visita.</segment>
    <segment id="26">Canal Onçafari no YouTube</segment>
    <segment id="27">, grátis   Círculo de Fogo - A Revolta</segment>
    <segment id="28">Uma nova invasão de monstros</segment>
    <segment id="29">Kaiju ameaça a Terra</segment>
    <segment id="30">, e Jake Pendergast (John Boyega</segment>
    <segment id="31">, da franquia “Star Wars”) —filho de Stacker Pentecost</segment>
    <segment id="32">, o herói do primeiro filme—</segment>
    <segment id="33">sese junta a uma equipe de pilotos para salvar o planeta.</segment>
    <segment id="34">Inédito na TV aberta.</segment>
    <segment id="35">Globo, 14h05</segment>
    <segment id="36">, 12 anos</segment>
    <segment id="37">Morros</segment>
    <segment id="38">O artista Santídio Pereira conversa sobre sua nova série de xilogravuras</segment>
    <segment id="39">, “Morros”</segment>
    <segment id="40">, com Vilma Eid</segment>
    <segment id="41">, diretora da galeria Estação</segment>
    <segment id="42">, e o colecionador Ricardo Kugelmas</segment>
    <segment id="43">, fundador do espaço Auroras.</segment>
    <segment id="44">Canal da galeria Estação no YouTube</segment>
    <segment id="45">, 20h   Persona em Foco</segment>
    <segment id="46">O ator Marco Ricca conversa sobre sua carreira com o diretor teatral Roberto Lage e o crítico José Cetra Filho.  Cultura</segment>
    <segment id="47">, 21h30</segment>
    <segment id="48">, 10 anos</segment>
    <segment id="49">The Vow</segment>
    <segment id="50">A misteriosa seita NIXVM</segment>
    <segment id="51">, que servia de fachada para um esquema de tráfico de mulheres</segment>
    <segment id="52">, é o tema desta nova série documental</segment>
    <segment id="53">, dirigida por Jehane Noujaim e Karim Aimer (“Privacidade Hackeada”).    HBO</segment>
