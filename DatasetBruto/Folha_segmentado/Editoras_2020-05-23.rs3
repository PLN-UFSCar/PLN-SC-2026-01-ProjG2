  <rst>
    <segment id="1">As editoras começam a apostar em livros que tenham a ver com o cenário de pandemia —seja com obras planejadas especialmente para o momento</segment>
    <segment id="2">, resgate do catálogo ou antecipação de lançamentos.</segment>
    <segment id="3">A Todavia</segment>
    <segment id="4">, por exemplo</segment>
    <segment id="5">, aposta na coleção de ebooks "Breves</segment>
    <segment id="6">Ensaios</segment>
    <segment id="7">Sobre a Pandemia"</segment>
    <segment id="8">, que começa a publicar no dia 29.</segment>
    <segment id="9">A série reúne autores que refletem sobre diversos aspectos da pandemia.</segment>
    <segment id="10">O primeiro é um livro no qual Marcos Nobre analisa o governo Bolsonaro.</segment>
    <segment id="11">Retrato de Marcos Nobre</segment>
    <segment id="12">, professor da UNICAMP.</segment>
    <segment id="13">- Jardiel Carvalho/UOL</segment>
    <segment id="14">Já a antropóloga Aparecida Villaça escreverá sobre a situação dos povos indígenas em meio a uma emergência sanitária.</segment>
    <segment id="15">Ao todo</segment>
    <segment id="16">, são 14 autores</segment>
    <segment id="17">, como</segment>
    <segment id="18">como Joice Berth</segment>
    <segment id="19">, Ricarto Terto e Leonardo Avritzer</segment>
    <segment id="20">, entre outros.  PANDEMIA</segment>
    <segment id="21">A outra opção é correr com lançamentos.</segment>
    <segment id="22">Foi o que a Intrínseca fez com "</segment>
    <segment id="23">A Grande Gripe"</segment>
    <segment id="24">, de John M. Barry</segment>
    <segment id="25">, sobre a gripe espanhola</segment>
    <segment id="26">, e "Inimigo Mortal - Nossa Guerra Contra os Germes Assassinos"</segment>
    <segment id="27">, de Michael T. Osterholm e Mark Olshakerco.  PANDEMIA 2</segment>
    <segment id="28">Outra das práticas é resgatar títulos do catálogo que tenham a ver com o momento.</segment>
    <segment id="29">A Intrínseca tem resgatado</segment>
    <segment id="30">, em ebook</segment>
    <segment id="31">, obras</segment>
    <segment id="32">comocomo "Estação 11"</segment>
    <segment id="33">, de Emily St. John Mandel</segment>
    <segment id="34">, sobre uma gripe que devasta o planeta</segment>
    <segment id="35">, e "</segment>
    <segment id="36">A Sexta Extinção"</segment>
    <segment id="37">, de Elizabeth Kolbert</segment>
    <segment id="38">, sobre a devastação provocada pelo homem.  PANDEMIA 3</segment>
    <segment id="39">No caso</segment>
    <segment id="40">caso da HarperCollins</segment>
    <segment id="41">, o resgate foi com "Imune"</segment>
    <segment id="42">, de Matt Richtel</segment>
    <segment id="43">, sobre</segment>
    <segment id="44">comocomo o organismo</segment>
    <segment id="45">sese defende de doenças.</segment>
    <segment id="46">Lançado no fim de 2019</segment>
    <segment id="47">, havia passado sem grande atenção —e agora é promovido outra vez.  PANDEMIA 4</segment>
    <segment id="48">A Rocco lança em ebook "</segment>
    <segment id="49">Dentes</segment>
    <segment id="50">Negros</segment>
    <segment id="51">", de André de Leones</segment>
    <segment id="52">, livro antigo que só tinha edição física</segment>
    <segment id="53">.</segment>
    <segment id="54">Num mundo pós-apocalíptico</segment>
    <segment id="55">, parte da população brasileira foi varrida por uma doença misteriosa.</segment>
    <segment id="56">PANDEMIA 5</segment>
    <segment id="57">Já a Record antecipou para agosto dois livros que só eram para o fim do ano ou ano que vem.</segment>
    <segment id="58">"Meninas Selvagens"</segment>
    <segment id="59">, ficção científica de Rory Power</segment>
    <segment id="60">, sobre meninas em quarentena numa escola</segment>
    <segment id="61">, e "The Division"</segment>
    <segment id="62">, de Alex Irvine</segment>
    <segment id="63">, baseado no game de mesmo nome</segment>
    <segment id="64">, sobre um vírus que</segment>
    <segment id="65">sese dissemina por Nova York.</segment>
  </rst>
</analysis>