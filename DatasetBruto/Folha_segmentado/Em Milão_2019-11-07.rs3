    <segment id="179">, 1, 20143</segment>
    <segment id="180">Oferece petiscos e pratos com sotaque francês</segment>
    <segment id="181">, como</segment>
    <segment id="182">como os escargots na manteiga de alho (€ 13 ou R$ 57) e a bouillabaisse</segment>
