  <rst>
    <segment id="1">Orgulho.</segment>
    <segment id="2">Pátria.</segment>
    <segment id="3">Independência.</segment>
    <segment id="4">No Sete de Setembro</segment>
    <segment id="5">, o presidente Bolsonaro</segment>
    <segment id="6">sese autodefine.  —Imbrochável.</segment>
    <segment id="7">Imbrochável.</segment>
    <segment id="8">Imbrochável.</segment>
    <segment id="9">Não se</segment>
    <segment id="10">se pode dizer que ele tenha medo de repetições.</segment>
    <segment id="11">O dr. Cavalini</segment>
    <segment id="12">sese mostrava irritado.  —</segment>
    <segment id="13">Pouca vergonha.</segment>
    <segment id="14">Onde já</segment>
    <segment id="15">sese viu?</segment>
    <segment id="16">O bem-sucedido empresário não escondia sua decepção.  —</segment>
    <segment id="17">Pensar que votei nesse babaca.</segment>
    <segment id="18">A esposa de Cavallini</segment>
    <segment id="19">sese chamava Lubiana.  —</segment>
    <segment id="20">Ih, quanta inveja</segment>
    <segment id="21">, amor.</segment>
    <segment id="22">Haha.  —Inveja?</segment>
    <segment id="23">Como assim?  —</segment>
    <segment id="24">Vai dizer que você não queria ser</segment>
    <segment id="25">comocomo ele...  —</segment>
    <segment id="26">Imbrochável?</segment>
    <segment id="27">Eu?</segment>
    <segment id="28">Ora essa.</segment>
    <segment id="29">Cavallini fixou os olhos na ponta do sapato.  —</segment>
    <segment id="30">Também</segment>
    <segment id="31">, com o monte de Viagra que o Exército andou comprando...</segment>
    <segment id="32">Lubiana abriu as portas do terraço climatizado.  —Deixa o presidente falar o que ele quiser</segment>
    <segment id="33">, ué.</segment>
    <segment id="34">O fabricante de autopeças continuava bufando.  —</segment>
    <segment id="35">A questão não é essa</segment>
    <segment id="36">, Lubiana.  —Qual é</segment>
    <segment id="37">, então?  —</segment>
    <segment id="38">É que ele não é imbrochável coisa nenhuma.</segment>
    <segment id="39">Lubiana regava as orquídeas no jardim da cobertura.  —</segment>
    <segment id="40">Então tá.</segment>
    <segment id="41">Tudo bem.  —E eu te digo por quê.</segment>
    <segment id="42">O dr. Cavallini fez uma pausa dramática.  —</segment>
    <segment id="43">Porque ele brochou.</segment>
    <segment id="44">Brochou lamentavelmente.  —Mas</segment>
    <segment id="45">comocomo é que você sabe</segment>
    <segment id="46">, amor?  —Não era para ele ter dado o golpe?</segment>
    <segment id="47">A voz de Cavallini</segment>
    <segment id="48">sese enchia de indignação.</segment>
    <segment id="49">--Todo mundo ali.</segment>
    <segment id="50">Pronto para apoiar ele.  —</segment>
    <segment id="51">Isso é verdade.  —</segment>
    <segment id="52">Na hora do vamos ver...  —Michou.  —No ano passado</segment>
    <segment id="53">, a mesma coisa.</segment>
    <segment id="54">Brochou também.  Do alto da cobertura</segment>
    <segment id="55">, Cavallini emitiu um grito de proporções imperiais.  —Cadê o golpe</segment>
    <segment id="56">, caraca?  Lubiana achou que era melhor o marido</segment>
    <segment id="57">sese acalmar.  —Vem</segment>
    <segment id="58">, amor.</segment>
    <segment id="59">Vem descansar um pouco na suíte.</segment>
    <segment id="60">A noite descia sem calor pelo espigão da Paulista.  —Amooor...  —Que foi</segment>
    <segment id="61">, Lubiana?  —</segment>
    <segment id="62">Como é que está o seu bolsonarinho hoje?</segment>
    <segment id="63">O sexagenário emudeceu.</segment>
    <segment id="64">Na verdade</segment>
    <segment id="65">, a situação estava mais para assessoria do Senado do que para Poder Executivo.  —</segment>
    <segment id="66">Tudo bem</segment>
    <segment id="67">, amor.</segment>
    <segment id="68">Fica para outra vez.</segment>
    <segment id="69">Ou então toma um comprimidinho.</segment>
    <segment id="70">No mundo animal</segment>
    <segment id="71">, podem ser imbrocháveis os impulsos de um macho.</segment>
    <segment id="72">Mas, na vida humana</segment>
    <segment id="73">, por vezes pesam mais o clima</segment>
    <segment id="74">, o tempo e a ocasião.</segment>
    <segment id="75">Veja as comemorações do 7 de Setembro em Brasília Mais    novamente         de   de  de  representando um</segment>
  </rst>
</analysis>