  <rst>
    <segment id="1">Iates até onde a vista alcança no cais da "Marina" de Dubai:</segment>
    <segment id="2">com o retorno do turismo</segment>
    <segment id="3">, as viagens a bordo desses luxuosos barcos nos lagos artificiais</segment>
    <segment id="4">sese tornaram a nova moda nesses tempos de pandemia no movimentado emirado do Golfo.</segment>
    <segment id="5">Aberta aos turistas desde julho de 2020</segment>
    <segment id="6">, a cidade-emirado atrai visitantes por seus restaurantes e praias</segment>
    <segment id="7">, masmas também por seus iates</segment>
    <segment id="8">, em um momento em que o distanciamento social permanece em vigor.</segment>
    <segment id="9">Desde o começo da crise de saúde</segment>
    <segment id="10">, Nada Naim saiu ao mar quatro vezes.</segment>
    <segment id="11">"É mais íntimo</segment>
    <segment id="12">, você está apenas com sua família e amigos"</segment>
    <segment id="13">, comenta esta mulher saudita de 36 anos que reside em Dubai.</segment>
    <segment id="14">"Sente que pode respirar.</segment>
    <segment id="15">É como</segment>
    <segment id="16">como se</segment>
    <segment id="17">se tivesse saído para fazer uma viagem"</segment>
    <segment id="18">, acrescenta Nada</segment>
    <segment id="19">, que não saiu de Dubai desde fevereiro de 2020.</segment>
    <segment id="20">Mercado de iates em Dubai ganha forçaMais    novamente         de   de  de  representando um</segment>
    <segment id="21">Com um horizonte repleto de arranha-céus e de ilhas artificiais</segment>
    <segment id="22">, os iates operam a 70% de sua capacidade.</segment>
    <segment id="23">As empresas de aluguel constataram um crescente interesse por essa atividade.  "</segment>
    <segment id="24">As medidas de confinamento foram flexibilizadas</segment>
    <segment id="25">, e a situação voltou (quase) à normalidade.</segment>
    <segment id="26">As pessoas optaram por algo seguro e de acordo com as regulamentações</segment>
    <segment id="27">, frequentando junto a familiares e amigos"</segment>
    <segment id="28">, diz à AFP Mohamed al Sayed</segment>
    <segment id="29">, diretor de uma empresa de aluguel dessas luxuosas embarcações</segment>
    <segment id="30">, a Royal Star Yachts.</segment>
    <segment id="31">Tanto residentes quanto turistas sonham com "cruzeiros" para relaxarem</segment>
    <segment id="32">, afirma este profissional</segment>
    <segment id="33">, que trabalha há oito anos no setor.</segment>
    <segment id="34">Aumento da demanda</segment>
    <segment id="35">Essas viagens não são nada baratas.</segment>
    <segment id="36">Custam até 18.000 dirhams (em torno de US$ 4.850) para navegar durante três horas em um barco de 42 metros de comprimento.</segment>
    <segment id="37">O valor é</segment>
    <segment id="38">, em geral</segment>
    <segment id="39">, compartilhado entre os passageiros a bordo.</segment>
    <segment id="40">Bilionários brasileirosMais    novamente         de   de  de  representando um  Conhecida por suas torres gigantescas e pela ostentação de luxo</segment>
    <segment id="41">, Dubai tem a economia mais diversificada do Golfo</segment>
    <segment id="42">, uma região que depende principalmente do petróleo.</segment>
    <segment id="43">O centro financeiro</segment>
    <segment id="44">, comercial e aeroportuário também desenvolveu um vasto setor turístico</segment>
    <segment id="45">, com quase 16 milhões de visitantes por ano antes da pandemia.</segment>
    <segment id="46">"</segment>
    <segment id="47">Foi constatado um aumento da demanda de aluguel de iates desde março de 2021</segment>
    <segment id="48">, já que algumas restrições ainda estavam em vigor nos hotéis e praias privadas"</segment>
    <segment id="49">, explica à AFP o diretor de outra empresa de aluguel de iates.</segment>
    <segment id="50">Enquanto o país</segment>
    <segment id="51">sese encontra entre os mais rápidos em começar sua campanha de vacinação</segment>
    <segment id="52">, o fluxo de turistas desde o início do ano permitiu que várias atividades comerciais voltassem a recuperar seu nível anterior à crise sanitária.</segment>
  </rst>
