  <rst>
    <segment id="1">O deputado estadual Arthur do Val ‘</segment>
    <segment id="2">Mamãe Falei (Patriota)</segment>
    <segment id="3">, que quer</segment>
    <segment id="4">sese lançar à Prefeitura de SP</segment>
    <segment id="5">, montou um site para recrutar interessados em</segment>
    <segment id="6">sese candidatarem a vereador em sua chapa.</segment>
    <segment id="7">TRIBO   “</segment>
    <segment id="8">A gente está querendo recrutar gente que tem vontade de entrar na política</segment>
    <segment id="9">, masmas que é travado por um cacique partidário”</segment>
    <segment id="10">, afirma ele</segment>
    <segment id="11">, que lançou o site MudaSP.</segment>
    <segment id="12">“Mamãe” cita o ex-subprefeito de Pinheiros Paulo Mathias</segment>
    <segment id="13">comocomo exemplo.</segment>
    <segment id="14">DERIVA   Mathias</segment>
    <segment id="15">sese candidatou a deputado estadual pelo PSDB</segment>
    <segment id="16">, masmas não foi eleito.</segment>
    <segment id="17">Filiou-</segment>
    <segment id="18">sese ao Novo para tentar a Câmara Municipal</segment>
    <segment id="19">, masmas foi barrado pela legenda.</segment>
    <segment id="20">“É justamente o que precisamos: um cara que</segment>
    <segment id="21">sese ferrou com o partido.</segment>
    <segment id="22">Tem militância</segment>
    <segment id="23">, quer fazer</segment>
    <segment id="24">, masmas está à deriva.</segment>
    <segment id="25">Se ele sair comigo</segment>
    <segment id="26">, é um case”</segment>
    <segment id="27">, diz.</segment>
    <segment id="28">“Vou entrar em contato.</segment>
    <segment id="29">”</segment>
    <segment id="30">Líderes dos movimentos de 2016 triunfam nas urnas   novamente         de   de  de  representando um     LEIA</segment>
    <segment id="31">TODOS OS TEMAS ABORDADOS PELA COLUNA</segment>
    <segment id="32">NESTA QUINTA (5)  Regina Duarte é bomba perto de explodir</segment>
    <segment id="33">, avalia núcleo de Bolsonaro  Tutuca vai fazer media training para sabatina no Senado   Bebianno diz que general Heleno não liga 'nome à pessoa' no</segment>
    <segment id="34">casocaso de Abin paralela   Viúva de Gugu vai à Justiça para receber mensalidades atrasadas   'Esse mundo tá louco'</segment>
    <segment id="35">, diz Drauzio Varella sobre concorrer à Presidência   ​Escritório de advocacia promove debate sobre avanços e desafios femininos</segment>
    <segment id="36">O rapper Emicida posa para a revista GQ Brasil - Caroline LimaHUMANIDADE</segment>
    <segment id="37">“Se tenho a oportunidade de ter a vida que tenho</segment>
    <segment id="38">, é óbvio que vou alcançar o máximo do meu potencial”</segment>
    <segment id="39">, diz o rapper Emicida à revista GQ Brasil deste mês</segment>
    <segment id="40">; na entrevista</segment>
    <segment id="41">, ele diz que começou a cultivar uma horta e que está à procura de serenidade:</segment>
    <segment id="42">“Nossa vitória não é ser bilionário</segment>
    <segment id="43">, é ser humano”.</segment>
    <segment id="44">Estreia do filme &amp;#039</segment>
    <segment id="45">;Fim de Festa&amp;#039</segment>
    <segment id="46">;   novamente         de   de  de  representando um  SALA CHEIA</segment>
    <segment id="47">O ator Silvero Pereira e o diretor Kiko Goifman foram à estreia do filme “Fim de Festa”</segment>
    <segment id="48">, no Reserva Cultural</segment>
    <segment id="49">, em SP</segment>
    <segment id="50">, na terça-feira (3).</segment>
    <segment id="51">A produtora Paula Cosenza e a cantora Assucena Assucena também estiveram lá.   CURTO-CIRCUITO</segment>
    <segment id="52">O Auditório Ibirapuera recebe a 7ª Mostra Internacional de Teatro de SP.</segment>
    <segment id="53">Na quinta (5)</segment>
    <segment id="54">, às 20h.</segment>
    <segment id="55">O Pavilhão da Bienal de SP recebe</segment>
    <segment id="56">, a partir de sexta (6)</segment>
    <segment id="57">, o Festival Sesi de Robótica.</segment>
    <segment id="58">A estilista Fernanda Yamamoto expõe peças desfiladas na SPFW.</segment>
    <segment id="59">No Senac Santo Amaro</segment>
    <segment id="60">, até 30 de junho.  com BRUNO B. SORAGGI</segment>
    <segment id="61">, BIANKA VIEIRA e VICTORIA AZEVEDO</segment>
