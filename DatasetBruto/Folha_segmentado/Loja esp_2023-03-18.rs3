  <rst>
    <segment id="1">A marca</segment>
    <segment id="2">, que nasceu em plena pandemia</segment>
    <segment id="3">, quando a arquiteta Marília Lima enviou um bolo de cenoura para alegrar o dia de uma amiga</segment>
    <segment id="4">, abre hoje oficialmente a sua segunda loja</segment>
    <segment id="5">, em Pinheiros.</segment>
    <segment id="6">Operando em "soft opening" desde o dia 2</segment>
    <segment id="7">, a nova unidade já consumiu mais de 2 toneladas de leite condensado nesses 16 dias</segment>
    <segment id="8">, revelando o sucesso do empreendimento.</segment>
    <segment id="9">O endereço escolhido é a rua Artur de Azevedo</segment>
    <segment id="10">, 1597.</segment>
    <segment id="11">A primeira loja</segment>
    <segment id="12">, inaugurada em maio de 2022</segment>
    <segment id="13">, fica no Itaim</segment>
    <segment id="14">, na rua Tabapuã</segment>
    <segment id="15">, 82.</segment>
    <segment id="16">Interior da nova loja da Cenoradas</segment>
    <segment id="17">, em Pinheiros - Divulgação</segment>
    <segment id="18">A Cenoradas é a primeira loja do mundo especializada em bolo de cenoura.</segment>
    <segment id="19">Hoje, o negócio vai além dos bolos nas marmitinhas.</segment>
    <segment id="20">Nas lojas físicas é possível encontrar bombons de chocolate recheados com bolo de cenoura</segment>
    <segment id="21">, barras cenoradas</segment>
    <segment id="22">, picolés</segment>
    <segment id="23">, brigadeiros</segment>
    <segment id="24">, tudo criado a partir do tema que inspirou a marca.</segment>
    <segment id="25">No ano passado</segment>
    <segment id="26">, o Cenottone</segment>
    <segment id="27">, panetone de bolo de cenoura com chocolate ou nutella fez sucesso nas festas de final de ano pela originalidade e pelo sabor.</segment>
    <segment id="28">Vale a pena conhecer!</segment>
    <segment id="29">Clique aqui para ver o novo endereço.</segment>
    <segment id="30">Bolo de cenoura com cobertura de chocolate e picolé de chocolate com recheio de bolo - Divulgação</segment>
  </rst>
