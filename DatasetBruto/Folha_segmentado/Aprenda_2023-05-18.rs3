  <rst>
    <segment id="1">Provoleta é uma versão do queijo provolone grelhado</segment>
    <segment id="2">, com uma casquinha crocante por fora e cremoso por dentro.</segment>
    <segment id="3">Colunas e BlogsReceba no seu email uma seleção de colunas e blogs da Folha</segment>
    <segment id="4">; exclusiva para assinantes.</segment>
    <segment id="5">Carregando...</segment>
    <segment id="6">Prato típico dos assados argentinos e também encontrados nas parrillas uruguaias</segment>
    <segment id="7">, a provoleta une os "asados" da América Latina com o costume italiano de consumo de queijos.  Servido</segment>
    <segment id="8">comocomo entrada ou acompanhamento</segment>
    <segment id="9">, a provoleta sacia bem pelo seu gosto marcante</segment>
    <segment id="10">, com um leve toque defumado e um alto teor de gordura.</segment>
    <segment id="11">Para contrastar esses sabores</segment>
    <segment id="12">, uma salsa ou chimichurri mais ácidos combinam bem.</segment>
    <segment id="13">Para preparar queijos na churrasqueira existem alguns acessórios que ajudam</segment>
    <segment id="14">, como</segment>
    <segment id="15">como a manta ou uma frigideira de ferro</segment>
    <segment id="16">, pois</segment>
    <segment id="17">pois assim o queijo não escorre pelos espaços da grelha.</segment>
    <segment id="18">E para virá-lo use uma espátula.</segment>
    <segment id="19">Existe também um acessório chamado provoleta —feito de cerâmica ou de ferro—</segment>
    <segment id="20">, como</segment>
    <segment id="21">como se</segment>
    <segment id="22">se fosse uma chapa de ferro</segment>
    <segment id="23">, masmas com ondulações para colocar pequenos pedaços do queijo (parece até um porta ovos).</segment>
    <segment id="24">Ele pode ser levado ao forno na temperatura alta para aquecê-lo e depois finalizar voltando com o queijo para o forno para criar uma casquinha.</segment>
    <segment id="25">Provoleta com salsa de Larissa Morales - Felipe MargaridoPROVOLETA</segment>
    <segment id="26">COM SALSA</segment>
    <segment id="27">Ingredientes  250 g de provolone (1 fatia)  1 xícara de salsinha picada finamente  ¼ xícara de cebolinha picada finamente  ½ cebola roxa picada finamente</segment>
    <segment id="28">2 dentes de alho espremidos  1 tomate picado finamente</segment>
    <segment id="29">Suco de 1 limão  ¼ xícara de azeite</segment>
    <segment id="30">Sal a gosto</segment>
    <segment id="31">Pimenta a gosto (pode usar dedo de moça picada ou calabresa seca)</segment>
    <segment id="32">Modo de preparo</segment>
    <segment id="33">Prepare a salsa misturando todos os ingredientes e reserve.</segment>
    <segment id="34">Aqueça bem a frigideira de ferro ou leve a manta para o fogo alto.</segment>
    <segment id="35">Coloque o provolone sobre essa superfície e espere em torno de 5 minutos</segment>
    <segment id="36">, até criar uma crosta e vire.</segment>
    <segment id="37">Deixe por mais 5 minutos e observe a lateral do queijo.</segment>
    <segment id="38">Quando ela estiver estufada é sinal de que está pronto</segment>
    <segment id="39">, pois</segment>
    <segment id="40">pois o centro terá derretido completamente.</segment>
    <segment id="41">Sirva com a salsa por cima.</segment>
  </rst>
</analysis>