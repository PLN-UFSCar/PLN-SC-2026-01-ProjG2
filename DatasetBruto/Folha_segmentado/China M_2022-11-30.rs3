  <rst>
    <segment id="1">Jiang Zemin</segment>
    <segment id="2">, líder chinês de 1993 a 2003</segment>
    <segment id="3">, período de crescimento econômico e abertura diplomática após o massacre da praça da Paz Celestial</segment>
    <segment id="4">, morreu nesta quarta-feira (30)</segment>
    <segment id="5">, aos 96 anos</segment>
    <segment id="6">, em Xangai.</segment>
    <segment id="7">Segundo a agência oficial de notícias Xinhua</segment>
    <segment id="8">, a causa da morte foi leucemia e falência de múltiplos órgãos.  "</segment>
    <segment id="9">O camarada Jiang Zemin foi um líder excepcional</segment>
    <segment id="10">, um grande marxista</segment>
    <segment id="11">, um grande revolucionário proletário</segment>
    <segment id="12">, estadista</segment>
    <segment id="13">, estrategista militar</segment>
    <segment id="14">, diplomata</segment>
    <segment id="15">, um combatente comunista de longa data e um líder excepcional da grande causa do socialismo com características chinesas"</segment>
    <segment id="16">, diz uma carta publicada pela Xinhua e assinada por Partido Comunista</segment>
    <segment id="17">, Parlamento</segment>
    <segment id="18">, gabinete e militares.</segment>
    <segment id="19">"É uma perda incalculável para o nosso partido</segment>
    <segment id="20">, nossos militares e nosso povo de todos os grupos étnicos.</segment>
    <segment id="21">"  Antes de</segment>
    <segment id="22">sese tornar secretário-geral do Partido Comunista da China</segment>
    <segment id="23">, cargo que ocupou de 1989 a 2002</segment>
    <segment id="24">, Jiang foi prefeito de Xangai.</segment>
    <segment id="25">Durante seu governo Hong Kong foi devolvida à China</segment>
    <segment id="26">, em 1997.</segment>
    <segment id="27">O ex-líder chinês Jiang Zemin durante evento para anunciar os membros do Comitê Permanente do Partido Comunista</segment>
    <segment id="28">, em Pequim - Mike Fiala - 19.out.92/AFPO ex-líder foi escolhido a dedo após o massacre de manifestantes na praça da Paz Celestial</segment>
    <segment id="29">, em Pequim</segment>
    <segment id="30">, em 1989.</segment>
    <segment id="31">Segundo o regime</segment>
    <segment id="32">, 300 pessoas morreram nos atos pró-democracia</segment>
    <segment id="33">, a maioria soldados.</segment>
    <segment id="34">ONGs de direitos humanos e testemunhas</segment>
    <segment id="35">, porém</segment>
    <segment id="36">porém, dizem que milhares de pessoas foram assassinadas.</segment>
    <segment id="37">Analistas esperavam que Jiang</segment>
    <segment id="38">, ao ser nomeado</segment>
    <segment id="39">, fosse mais uma figura transitória na história política da China.</segment>
    <segment id="40">Seu objetivo à época seria apenas substituir Zhao Ziyang</segment>
    <segment id="41">, derrubado pela linha dura do partido por simpatizar com o movimento democrático de Tiananmen</segment>
    <segment id="42">, como</segment>
    <segment id="43">como também é conhecida a praça —Zhao passou o resto de sua vida em prisão domiciliar</segment>
    <segment id="44">, até morrer</segment>
    <segment id="45">, em 2005.China</segment>
    <segment id="46">, terra do meioReceba no seu email os grandes temas da China explicados e contextualizados</segment>
    <segment id="47">; exclusiva para assinantes.</segment>
    <segment id="48">Carregando...</segment>
    <segment id="49">Foi sob sua gestão</segment>
    <segment id="50">, no entanto</segment>
    <segment id="51">, que o país conseguiu sair do isolamento diplomático pós-massacre</segment>
    <segment id="52">, normalizando relações com Washington e mantendo crescimento econômico sem precedentes.</segment>
    <segment id="53">Ele visitou os EUA em 1997</segment>
    <segment id="54">, quando</segment>
    <segment id="55">sese encontrou com o então presidente Bill Clinton.</segment>
    <segment id="56">Depois</segment>
    <segment id="57">, em 2002</segment>
    <segment id="58">, foi um dos poucos líderes mundiais a visitar o rancho de George W. Bush em Crawford</segment>
    <segment id="59">, no Texas.</segment>
    <segment id="60">Na mesma linha</segment>
    <segment id="61">, coube ao ex-líder chinês gerenciar crises nas relações sino-americanas após a Otan</segment>
    <segment id="62">, a aliança militar do Ocidente</segment>
    <segment id="63">, bombardear</segment>
    <segment id="64">, em 1999</segment>
    <segment id="65">, a embaixada de Pequim em Belgrado.</segment>
    <segment id="66">Dois anos depois</segment>
    <segment id="67">, um caça chinês e um avião espião dos EUA</segment>
    <segment id="68">sese chocaram no espaço aéreo da China</segment>
    <segment id="69">, causando uma das piores crises entre os dois países desde o restabelecimento diplomático</segment>
    <segment id="70">, em 1971.</segment>
    <segment id="71">Paralelamente</segment>
    <segment id="72">, Jiang manteve laços com a Rússia</segment>
    <segment id="73">, onde chegou a ser trainee de uma fábrica de automóveis nos anos 1950.</segment>
    <segment id="74">Nesta quarta</segment>
    <segment id="75">, o presidente Vladimir Putin disse que o chinês foi um amigo sincero de seu país.</segment>
    <segment id="76">Veja líderes que comandaram a China desde Mao Tsé-tungMais    novamente         de   de  de  representando um  Jiang também convidou empresários para</segment>
    <segment id="77">sese juntarem ao Partido Comunista Chinês</segment>
    <segment id="78">, defendeu a inclusão de Pequim na OMC (Organização Mundial do Comércio) e protocolou a candidatura do país para sediar os Jogos Olímpicos de 2008.</segment>
    <segment id="79">A transformação gerou efeitos positivos e contribuiu para o crescimento extraordinário da economia.</segment>
    <segment id="80">De 1993 a 2003</segment>
    <segment id="81">, o PIB (Produto Interno Bruto) do país mais do que triplicou —em conta que não considera correções inflacionárias.</segment>
    <segment id="82">Embora bem-sucedida economicamente</segment>
    <segment id="83">, a China sob Jiang estagnou politicamente.</segment>
    <segment id="84">Os debates de reforma dos anos 1980 foram esmagados pelo medo da instabilidade após os protestos de 1989 e o colapso da União Soviética.</segment>
    <segment id="85">Além disso</segment>
    <segment id="86">, a corrupção piorou e a desigualdade social aumentou.</segment>
    <segment id="87">Jiang exibia</segment>
    <segment id="88">comocomo um dos seus legados o retorno de Hong Kong à China</segment>
    <segment id="89">, em 1997</segment>
    <segment id="90">, após mais de 150 anos de domínio britânico —ainda que a volta do território tenha sido negociada por Deng Xiaoping em 1984.</segment>
    <segment id="91">O dirigente lutou também</segment>
    <segment id="92">para que</segment>
    <segment id="93">para que Taiwan</segment>
    <segment id="94">, considerada por Pequim uma província rebelde</segment>
    <segment id="95">, aceitasse a soberania chinesa.</segment>
    <segment id="96">Para tal</segment>
    <segment id="97">, ameaçou a ilha com exercícios militares e testes de mísseis antes da primeira eleição presidencial direta do território</segment>
    <segment id="98">, em 1996</segment>
    <segment id="99">, azedando as relações bilaterais por mais de uma década.</segment>
    <segment id="100">À frente do Comitê Permanente do Politburo</segment>
    <segment id="101">, o órgão máximo do Partido Comunista e do regime</segment>
    <segment id="102">comocomo um todo</segment>
    <segment id="103">, ele formou um grupo com aliados e seguidores informalmente conhecidos</segment>
    <segment id="104">comocomo "gangue de Xangai"</segment>
    <segment id="105">, cuja influência sobre a política chinesa permaneceu mesmo depois da mudança no comando.</segment>
    <segment id="106">Escultura em memória do massacre da Praça da Paz Celestial é removidaMais    novamente         de   de  de  representando um  Jiang foi visto pela última vez em público em outubro de 2019</segment>
    <segment id="107">, assistindo ao desfile militar na praça da Paz Celestial em comemoração ao 70º aniversário da fundação da República Popular da China.</segment>
    <segment id="108">Antes disso</segment>
    <segment id="109">, sua morte chegou a ser anunciada por engano pela imprensa de Hong Kong</segment>
    <segment id="110">, em 2011</segment>
    <segment id="111">, depois que ele não compareceu às comemorações de 90 anos do Partido Comunista.</segment>
    <segment id="112">Quebrando a tradição de discrição chinesa</segment>
    <segment id="113">, era um líder muito mais extravagante que os antecessores.</segment>
    <segment id="114">Às vezes cantava</segment>
    <segment id="115">, recitava poemas ou tocava instrumentos musicais em encontros importantes.</segment>
    <segment id="116">Em algumas ocasiões</segment>
    <segment id="117">, jornais chineses estamparam poemas seus na primeira página.</segment>
    <segment id="118">A peculiaridade marcou também seus últimos anos de vida pública.</segment>
    <segment id="119">Um dos momentos mais lembrados aconteceu durante um longo discurso do atual líder chinês</segment>
    <segment id="120">, Xi Jinping</segment>
    <segment id="121">, em um congresso do Partido Comunista em 2017.</segment>
    <segment id="122">Na ocasião</segment>
    <segment id="123">, Jiang olhou sem qualquer constrangimento para seu relógio em diversas ocasiões</segment>
    <segment id="124">, e a cena virou meme em redes sociais —no mínimo</segment>
    <segment id="125">, um simbolismo das diferenças políticas entre os dois líderes.</segment>
    <segment id="126">Nesta quarta</segment>
    <segment id="127">, Xi disse que a China vai transformar o luto em força.</segment>
    <segment id="128">"</segment>
    <segment id="129">Jiang Zemin estava mais pronto para ser natural</segment>
    <segment id="130">, embora</segment>
    <segment id="131">embora às vezes pudesse ser percebido</segment>
    <segment id="132">comocomo vulgar</segment>
    <segment id="133">, não muito sofisticado"</segment>
    <segment id="134">, disse Jean Pierre Cabestan</segment>
    <segment id="135">, professor de política da Universidade Batista de Hong Kong</segment>
    <segment id="136">, à agência de notícias Reuters.</segment>
    <segment id="137">Apesar dos rumores de que ele queria</segment>
    <segment id="138">sese apegar ao poder</segment>
    <segment id="139">, Jiang</segment>
    <segment id="140">sese aposentou</segment>
    <segment id="141">comocomo chefe do partido em 2002</segment>
    <segment id="142">, entregando as rédeas a Hu Jintao na primeira transição de liderança sem derramamento de sangue na China desde a Revolução de 1949.</segment>
  </rst>
</analysis>