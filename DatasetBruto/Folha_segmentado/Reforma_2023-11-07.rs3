  <rst>
    <segment id="1">O ministro da Fazenda</segment>
    <segment id="2">, Fernando Haddad (PT)</segment>
    <segment id="3">, pediu a empresários nesta terça-feira (7) que telefonem para os senadores para pedir a aprovação da Reforma Tributária nesta semana.</segment>
    <segment id="4">O petista disse que trata-</segment>
    <segment id="5">sese de uma votação histórica que pode colocar o Brasil no trilho do desenvolvimento e que é discutida há quatro décadas.</segment>
    <segment id="6">"</segment>
    <segment id="7">Se alguém aqui conhece um senador</segment>
    <segment id="8">, não perca a oportunidade de dar um telefonema para esse senador hoje e fazer um apelo.</segment>
    <segment id="9">Não se</segment>
    <segment id="10">se trata de governo e oposição</segment>
    <segment id="11">, não se</segment>
    <segment id="12">se trata de PT e PL</segment>
    <segment id="13">, não se</segment>
    <segment id="14">se trata disso"</segment>
    <segment id="15">, afirmou em evento da Agência Brasileira de Promoção de Exportações e Investimentos com empresários.</segment>
    <segment id="16">O ministro da Fazenda</segment>
    <segment id="17">, Fernando Haddad</segment>
    <segment id="18">, durante evento da Agência Brasileira de Promoção de Exportações e Investimentos com empresários - Diogo Zacarias/Ministério da FazendaSegundo o ministro</segment>
    <segment id="19">, trata-</segment>
    <segment id="20">sese de uma mudança "que vai produzir por décadas os efeitos" e que "não pode ser objeto de polarização política".  Cerveja</segment>
    <segment id="21">, cigarro e refrigerantes podem ter taxa extra com imposto seletivoMais    novamente         de   de  de  representando um  "Não</segment>
    <segment id="22">sese fecha questão contra Reforma Tributária.</segment>
    <segment id="23">Faça apelo ao senador da sua relação</segment>
    <segment id="24">, diga para ele colocar a disputa partidária de lado hoje e colocar os interesses do país em primeiro lugar"</segment>
    <segment id="25">, afirmou.</segment>
    <segment id="26">"</segment>
    <segment id="27">É hora de nós fazermos chegar ao Senado um coro só</segment>
    <segment id="28">, do país todo</segment>
    <segment id="29">, para que</segment>
    <segment id="30">para que hoje ou no máximo amanhã o plenário da Casa possa dar a palavra final sobre esse anseio de 40 anos.</segment>
    <segment id="31">"</segment>
    <segment id="32">Com a reforma</segment>
    <segment id="33">, segundo Haddad</segment>
    <segment id="34">, o Brasil terá um dos sistemas tributários "mais modernos do mundo".</segment>
    <segment id="35">Ele disse que o país tem um dos sistemas mais equivocados do planeta</segment>
    <segment id="36">, que isso é "vergonhoso" e que o Brasil "não vai a lugar nenhum" com o formato atual.</segment>
  </rst>
