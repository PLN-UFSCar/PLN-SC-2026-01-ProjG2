  <rst>
    <segment id="1">O Vino!</segment>
    <segment id="2">Pinheiros sempre</segment>
    <segment id="3">sese destacou com sua ampla carta de vinhos vendidos em taças a preços atraentes e um menu de comidinhas perfeitas para acompanhar a bebida.</segment>
    <segment id="4">Pois a casa deu uma repaginada em seu cardápio e apresenta agora três novidades para o verão.</segment>
    <segment id="5">Seis rótulos de espumantes disponíveis no open bar promovido às terças-feiras pela Vino!</segment>
    <segment id="6">Pinheiros - DivulgaçãoA primeira é a nova seção de pizzas com massa de fermentação natural.</segment>
    <segment id="7">Há opções</segment>
    <segment id="8">comocomo a Caprese (R$ 49) com tomates cereja confitados</segment>
    <segment id="9">, tapenade de azeitona e mozzarella de búfala</segment>
    <segment id="10">, e a pizza de Brócolis com bacon (R$ 49) com passata italiana</segment>
    <segment id="11">, mozzarella de búfala</segment>
    <segment id="12">, brócolis</segment>
    <segment id="13">, bacon</segment>
    <segment id="14">, alho e catupiry.</segment>
    <segment id="15">A segunda é o menu harmonizado oferecido às quartas-feiras com quatro aperitivos combinados com quatro taças de vinho (75 ml) por R$ 110 por pessoa.</segment>
    <segment id="16">Perfeito para apreciar as harmonizações criadas pelo sommelier com os petiscos da casa.</segment>
    <segment id="17">E a terceira é o open bar de espumantes</segment>
    <segment id="18">, que acontece toda terça-feira até as 22h.</segment>
    <segment id="19">Por R$ 76 você pode consumir quantas taças quiser de seis rótulos selecionados.</segment>
    <segment id="20">Tem espumante nature</segment>
    <segment id="21">, extra brut</segment>
    <segment id="22">, brut</segment>
    <segment id="23">, demi-sec e moscatel.</segment>
    <segment id="24">Um deleite para quem aprecia espumantes.</segment>
    <segment id="25">Essa novidade eu já fui conferir e gostei muito: os rótulos são bons e perfeitos para essas noites quentes.</segment>
    <segment id="26">Abaixo</segment>
    <segment id="27">, os pratos que degustei nessa noite</segment>
    <segment id="28">, acompanhados dos espumantes da seleção do dia.</segment>
    <segment id="29">Vino!</segment>
    <segment id="30">Pinheiros apresenta as novidades para o verãoMais    novamente         de   de  de  representando um</segment>
    <segment id="31">O ambiente não sofreu alterações: o térreo segue com o amplo balcão e algumas mesas altas na lateral e nos fundos.</segment>
    <segment id="32">Já o piso superior conta com mesas e uma varanda com teto retrátil</segment>
    <segment id="33">, ideal para aproveitar as noites ao ar livre.</segment>
    <segment id="34">Vino!</segment>
    <segment id="35">Pinheiros - mapinha aqui Rua Fradique Coutinho</segment>
    <segment id="36">, 47, Pinheiros</segment>
    <segment id="37">, telefone (11) 2614-0145.</segment>
    <segment id="38">Horários de funcionamento:</segment>
    <segment id="39">2ª a 5ª das 17h às 23h30</segment>
    <segment id="40">; 6ª e sábado das 17h às 0h30.</segment>
    <segment id="41">Capacidade: 70 lugares.</segment>
    <segment id="42">Aconselhável fazer reservas.</segment>
  </rst>
</analysis>