  <rst>
    <segment id="1">A decisão da Ancine (Agência Nacional do Cinema) de rever o resultado de um edital que causou polêmica por ignorar projetos da região Norte do Brasil</segment>
    <segment id="2">sese deu após intervenção direta da ministra da Cultura</segment>
    <segment id="3">, Margareth Menezes.</segment>
    <segment id="4">A ministra da Cultura</segment>
    <segment id="5">, Margareth Menezes</segment>
    <segment id="6">, em evento em Brasília - Mauro Pimentel/AFPNa terça-feira (17)</segment>
    <segment id="7">, ela se</segment>
    <segment id="8">se reuniu com o diretor-presidente da Ancine</segment>
    <segment id="9">, Alex Braga</segment>
    <segment id="10">, em Brasília.</segment>
    <segment id="11">Um dos temas da conversa teria sido justamente a importância de fomentar projetos culturais fora do eixo Sudeste —o tema é visto</segment>
    <segment id="12">comocomo prioritário pela gestão da cantora.</segment>
    <segment id="13">Um dia após o encontro</segment>
    <segment id="14">, porém</segment>
    <segment id="15">porém, a Ancine publicou o resultado do edital para novos realizadores que previa uma cota regional para Nordeste</segment>
    <segment id="16">, Centro-Oeste e Norte –este último</segment>
    <segment id="17">, porém</segment>
    <segment id="18">porém, não foi contemplado.</segment>
    <segment id="19">A decisão enfureceu o setor audiovisual</segment>
    <segment id="20">, que criticou a agência nas redes sociais.</segment>
    <segment id="21">Saiba quem é quem no Ministério da Cultura de Margareth MenezesMais    novamente         de   de  de  representando um  Segundo pessoas próximas ouvidas pela coluna</segment>
    <segment id="22">, a ministra teria</segment>
    <segment id="23">, então</segment>
    <segment id="24">, ligado para Alex Braga cobrando uma solução imediata.</segment>
    <segment id="25">Na noite de quinta-feira (19)</segment>
    <segment id="26">, a Ancine publicou em seu site uma nota voltando atrás na decisão.  "</segment>
    <segment id="27">Com o compromisso de manter a equidade da política pública e o consequente desenvolvimento de todas as regiões do país</segment>
    <segment id="28">, o Ministério da Cultura e a Ancine irão adotar</segment>
    <segment id="29">, em regime de urgência</segment>
    <segment id="30">, providências para atender também aos realizadores da região Norte"</segment>
    <segment id="31">, diz o texto.</segment>
    <segment id="32">Mônica BergamoReceba no seu email as informações exclusivas da coluna</segment>
    <segment id="33">Mônica BergamoCarregando..."Uma ampliação do resultado da chamada pública</segment>
    <segment id="34">, a partir de uma suplementação de recursos</segment>
    <segment id="35">, está sendo avaliada"</segment>
    <segment id="36">, afirma ainda a nota.</segment>
    <segment id="37">A Ancine também anunciou que vai adotar providências</segment>
    <segment id="38">para que</segment>
    <segment id="39">para que</segment>
    <segment id="40">, no futuro</segment>
    <segment id="41">, "não ocorram distorções nos indutores regionais</segment>
    <segment id="42">, e que a diversidade de investimentos seja preservada".</segment>
    <segment id="43">PALCO</segment>
    <segment id="44">Pré-estreia do espetáculo &amp;#</segment>
    <segment id="45">039;Humilhação&amp;#039</segment>
    <segment id="46">;Mais    novamente         de   de  de  representando um</segment>
    <segment id="47">A atriz Andrea Tedesco recebeu convidados na estreia do espetáculo "Humilhação"</segment>
    <segment id="48">, na Oficina Cultural Oswald de Andrade</segment>
    <segment id="49">, na noite de quarta (18)</segment>
    <segment id="50">, em São Paulo.</segment>
    <segment id="51">O ator e colega de elenco Marcos Gomes esteve presente.</segment>
    <segment id="52">Ele divide a direção da peça com Lucas Mayor</segment>
    <segment id="53">, que também compareceu.  com BIANKA VIEIRA (interina)</segment>
    <segment id="54">, KARINA MATIAS e MANOELLA SMITH</segment>
  </rst>
