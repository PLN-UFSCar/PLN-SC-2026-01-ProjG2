  <rst>
    <segment id="1">Dotado de um sorriso conquistador e uma voz mansa</segment>
    <segment id="2">, João era aclamado por personagens que representavam sempre um lado acolhedor</segment>
    <segment id="3">, passando momentos de ternura</segment>
    <segment id="4">, seja nos espetáculos em que atuava</segment>
    <segment id="5">, novelas</segment>
    <segment id="6">, ou programas de TV.</segment>
    <segment id="7">O texto está na nota de pesar distribuída pelo SBT sobre João Acaiabe: o ator</segment>
    <segment id="8">, que interpretou o cozinheiro Chico na novela “Chiquititas” (2013-2015)</segment>
    <segment id="9">, morreu na quarta-feira (31)</segment>
    <segment id="10">, aos 76 anos</segment>
    <segment id="11">, vítima de Covid-19.</segment>
    <segment id="12">Há quase oito meses</segment>
    <segment id="13">, também pelo coronavírus</segment>
    <segment id="14">, morria Gésio Amadeu</segment>
    <segment id="15">, que fez o mesmo personagem na versão dos anos 1990.</segment>
    <segment id="16">Acaiabe testou positivo em 15 de março</segment>
    <segment id="17">, quando São Paulo começava a vacinar pessoas da sua faixa etária</segment>
    <segment id="18">, e, na véspera</segment>
    <segment id="19">, chegou a comemorar a iminência da imunização nas redes sociais.</segment>
    <segment id="20">O ator fez 23 filmes</segment>
    <segment id="21">, além de ter dado vida ao Tio Barnabé</segment>
    <segment id="22">, no “Sítio do Picapau Amarelo”</segment>
    <segment id="23">, entre 2001 e 2006</segment>
    <segment id="24">, e participado da novela “</segment>
    <segment id="25">Segundo Sol”</segment>
    <segment id="26">comocomo o pai de santo Didico.</segment>
    <segment id="27">João Acaiabe</segment>
    <segment id="28">comocomo Tio Barnabé - Instagram/#joaoacaiabe   VACINADOS  Evandro Mesquita</segment>
    <segment id="29">, que não parece</segment>
    <segment id="30">, masmas tem 69 anos</segment>
    <segment id="31">, tomou a primeira dose da vacina contra a Covid nesta quinta-feira</segment>
    <segment id="32">, no Rio.</segment>
    <segment id="33">Da mesma idade</segment>
    <segment id="34">, Ritchie ambém foi imunizado e brincou com a letra de “Menina Veneno”: “Covid veneno</segment>
    <segment id="35">, o mundo é pequeno demais pra nós dois”.</segment>
    <segment id="36">Susana Vieira</segment>
    <segment id="37">, 78 anos</segment>
    <segment id="38">, já recebeu a sua segunda dose.</segment>
    <segment id="39">Evandro Mesquita sendo vacinado contra a Covid-19 (Foto: @evandromesquita  no Instagram) - @evandromesquita no InstagramIMUNIZADA</segment>
    <segment id="40">A rainha Elizabeth 2ª</segment>
    <segment id="41">, 94 anos</segment>
    <segment id="42">, recebeu a segunda dose da vacina contra a Covid-19 nesta quarta-feira (31)</segment>
    <segment id="43">, segundo o jornal The Sun.</segment>
    <segment id="44">Essa foi a primeira aparição pública da monarca nos últimos cinco meses.</segment>
    <segment id="45">A mãe do príncipe Charles teria recebido o imunizante antes de visitar o memorial das Forças Aéreas em Runnymede</segment>
    <segment id="46">, na Inglaterra</segment>
    <segment id="47">, marcando o centenário da Força Aérea Real Australiana.</segment>
    <segment id="48">“Está um dia lindo.</segment>
    <segment id="49">Estou contente de estar aqui”</segment>
    <segment id="50">, disse a rainha.</segment>
    <segment id="51">A rainha Elizabeth durante o centenário da Força Aérea Australiana</segment>
    <segment id="52">, em 31 de março de 2021.- Foto de Steve Reigate/POOL/ AFPLIGADA NO MODO PAUSA</segment>
    <segment id="53">A partir desta sexta (2)</segment>
    <segment id="54">, Juliana Paes finalmente ganhará uma folga para sua imagem</segment>
    <segment id="55">, que tem ocupado a tela da Globo ao longo de toda a temporada da pandemia</segment>
    <segment id="56">, por meio de reprises.</segment>
    <segment id="57">Primeiro foi “Totalmente Demais”</segment>
    <segment id="58">, depois</segment>
    <segment id="59">, “</segment>
    <segment id="60">A Força do Querer”</segment>
    <segment id="61">, e termina agora</segment>
    <segment id="62">“Laços de Família” no Vale a Pena Ver de Novo</segment>
    <segment id="63">, primeira novela de sua carreira.</segment>
    <segment id="64">Enquanto as reapresentações não deixavam espaço para o público sentir saudade dela</segment>
    <segment id="65">, a atriz esteve assim</segment>
    <segment id="66">, como</segment>
    <segment id="67">como na foto</segment>
    <segment id="68">, navegando de mar em mar</segment>
    <segment id="69">, sempre pronta para os holofotes.</segment>
    <segment id="70">“No doce balanço a caminho do mar”</segment>
    <segment id="71">, publicou ela na legenda desta foto</segment>
    <segment id="72">Elas estão na áreaMais    novamente         de   de  de  representando um  DEMISSÃO</segment>
    <segment id="73">Após ser acusada de racismo por contestar declarações de Meghan Markle a Oprah Winfrey</segment>
    <segment id="74">, Sharon Osbourne foi oficialmente dispensada pela rede CBS</segment>
    <segment id="75">, onde comandava o programa “The Talk”.</segment>
    <segment id="76">Segundo o site Page Six</segment>
    <segment id="77">, a mulher de Ozzy Osbourne não saiu de mãos abanando e embolsou pelo menos US$ 57 milhões (R$ 324 milhões).</segment>
    <segment id="78">Sharon Osbourne - Instagram/sharonosbourne</segment>
  </rst>
