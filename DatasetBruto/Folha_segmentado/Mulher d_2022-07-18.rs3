  <rst>
    <segment id="1">Horas depois da publicação do sétimo episódio da série</segment>
    <segment id="2">A Mulher da Casa Abandonada</segment>
    <segment id="3">, o apresentador do podcast</segment>
    <segment id="4">, Chico Felitti</segment>
    <segment id="5">, participou de uma live na Folha.</segment>
    <segment id="6">A transmissão começou às 18h desta quarta-feira (20) e foi exclusiva para assinantes da Folha.</segment>
    <segment id="7">Felitti conversou com a editora de Podcasts do jornal</segment>
    <segment id="8">, Magê Flores</segment>
    <segment id="9">, sobre os bastidores da produção</segment>
    <segment id="10">, a repercussão do programa e os desdobramentos da história.</segment>
    <segment id="11">No último episódio de A Mulher da Casa Abandonada</segment>
    <segment id="12">, Chico entrevista Margarida Bonetti.</segment>
    <segment id="13">Ela dá a versão dela sobre as acusações de ter mantido uma funcionária em condições análogas à escravidão.</segment>
    <segment id="14">O podcast</segment>
    <segment id="15">, que está no ar desde o começo de junho</segment>
    <segment id="16">, teve grande repercussão ao contar a história da moradora de um degradado casarão de Higienópolis</segment>
    <segment id="17">, bairro nobre de São Paulo</segment>
    <segment id="18">, e discutir a escravidão contemporânea.</segment>
    <segment id="19">Para participar da live basta ser assinante e entrar nesta matéria no horário da transmissão.</segment>
    <segment id="20">A conversa vai acontecer aqui mesmo —não deixe de salvar este link para não perder.</segment>
    <segment id="21">Para assinar a Folha</segment>
    <segment id="22">, clique aqui.</segment>
    <segment id="23">Ouça</segment>
    <segment id="24">A Mulher da Casa Abandonada:</segment>
    <segment id="25">O podcast</segment>
    <segment id="26">A Mulher da Casa Abandonada investiga a vida de uma brasileira procurada pelo FBI - Editoria de Arte</segment>
