  <rst>
    <segment id="1">Apoiador de Eduardo Leite (RS) nas prévias do PSDB</segment>
    <segment id="2">, o deputado federal Aécio Neves (MG) diz que João Doria (SP) recebe apoios entusiasmados somente dos amigos do vice-governador de São Paulo</segment>
    <segment id="3">, Rodrigo Garcia.</segment>
    <segment id="4">"</segment>
    <segment id="5">Mas não</segment>
    <segment id="6">porque</segment>
    <segment id="7">porque eles acham que Doria tenha alguma chance de ser presidente</segment>
    <segment id="8">, masmas sim para vê-lo pelas costas para o Rodrigo [Garcia] sentar na cadeira de governador e passar a ter alguma chance na disputa com o [Geraldo] Alckmin"</segment>
    <segment id="9">, afirma Neves ao Painel.</segment>
    <segment id="10">"</segment>
    <segment id="11">Só que o preço que o restante do partido teria que pagar seria alto demais</segment>
    <segment id="12">" caso</segment>
    <segment id="13">caso Doria vencesse as prévias contra o governador gaúcho</segment>
    <segment id="14">, conclui Neves.</segment>
    <segment id="15">Trajetória de Aécio NevesMais    novamente         de   de  de  representando um</segment>
    <segment id="16">O deputado e o governador de SP são desafetos.</segment>
    <segment id="17">Em fevereiro</segment>
    <segment id="18">, Doria fez ofensiva para tentar expulsar Neves do PSDB</segment>
    <segment id="19">, masmas não teve sucesso.</segment>
    <segment id="20">Ligado ao deputado</segment>
    <segment id="21">, o diretório de Minas Gerais do PSDB</segment>
    <segment id="22">, na companhia dos diretórios de Ceará</segment>
    <segment id="23">, Rio Grande do Sul e Bahia</segment>
    <segment id="24">, protocolou denúncia em que acusa o diretório paulista</segment>
    <segment id="25">, comandado por aliados de João Doria</segment>
    <segment id="26">, de fraudar as datas de filiações de 92 prefeitos e vice-prefeitos.</segment>
    <segment id="27">​As regras das prévias tucanas determinam que apenas filiados até 31 de maio deste ano podem participar da votação.</segment>
    <segment id="28">Os diretórios apoiadores de Leite apontam que esses 92 políticos foram filiados posteriormente e registrados no sistema do partido com datas retroativas.</segment>
    <segment id="29">A comissão das prévias acatou o argumento e</segment>
    <segment id="30">, por isso</segment>
    <segment id="31">, decidiu invalidar a participação deles.</segment>
    <segment id="32">Eles têm 72 horas para recorrer da decisão.</segment>
    <segment id="33">Prévias do PSDB à PresidênciaMais    novamente         de   de  de  representando um</segment>
  </rst>
