  <rst>
    <segment id="1">Os cat cafés</segment>
    <segment id="2">sese destacam entre tantas opções de cafeterias em São Paulo pela oportunidade de tomar a bebida e relaxar na companhia de um gato.</segment>
    <segment id="3">Ou, ao menos</segment>
    <segment id="4">, observar os felinos através de um vidro.</segment>
    <segment id="5">Isso porque</segment>
    <segment id="6">porque uma norma da Anvisa (Agência Nacional de Vigilância Sanitária) proíbe manter animais no mesmo ambiente em que</segment>
    <segment id="7">sese vende alimento.</segment>
    <segment id="8">De acordo com a Gerência Geral de Alimentos da agência</segment>
    <segment id="9">, "as áreas internas e externas do comércio devem estar livres de objetos em desuso ou estranhos ao ambiente</segment>
    <segment id="10">, não sendo permitida a presença de animais".</segment>
    <segment id="11">Essa medida é necessária para a prevenção de zoonoses.</segment>
    <segment id="12">A alternativa encontrada pelos donos dos estabelecimentos foi construir um espaço à parte</segment>
    <segment id="13">, separado por vidros</segment>
    <segment id="14">, onde os bichanos podem viver sossegados</segment>
    <segment id="15">, masmas ao alcance dos olhos dos humanos.</segment>
    <segment id="16">Dependendo do cat café</segment>
    <segment id="17">, é possível entrar nessas salas e brincar com os gatos ao pagar uma taxa que ajuda a cobrir as despesas do animal.</segment>
    <segment id="18">Muitos estão sob cuidados de ONGs e disponíveis para adoção.</segment>
    <segment id="19">Gatcha  Localizado no segundo andar da galeria Metrópole</segment>
    <segment id="20">, na República</segment>
    <segment id="21">, região central de São Paulo</segment>
    <segment id="22">, o Gatcha é especializado em matchá</segment>
    <segment id="23">, um chá-verde em pó.</segment>
    <segment id="24">Os gatinhos ficam em um espaço separado e estão disponíveis para adoção.</segment>
    <segment id="25">Endereço: Galeria Metrópole</segment>
    <segment id="26">, av. São Luís</segment>
    <segment id="27">, 187, República</segment>
    <segment id="28">, região central de São Paulo</segment>
    <segment id="29">, 2º andar</segment>
    <segment id="30">; de seg.</segment>
    <segment id="31">a sáb.</segment>
    <segment id="32">das 10h às 18h</segment>
    <segment id="33">;</segment>
    <segment id="34">Instagram @gatchasp</segment>
    <segment id="35">Gatcha é o primeiro café com gatos de SPMais    novamente         de   de  de  representando um  Gato Pingado</segment>
    <segment id="36">Em uma casa em Pinheiros</segment>
    <segment id="37">, na zona oeste</segment>
    <segment id="38">, que também tem espaço para coworking</segment>
    <segment id="39">, os clientes podem apreciar os gatos que vivem no local enquanto tomam café ou comem lanches e bolos.</segment>
    <segment id="40">Os felinos estão disponíveis para adoção.</segment>
    <segment id="41">Endereço: rua João Moura</segment>
    <segment id="42">, 607, Pinheiros</segment>
    <segment id="43">, região oeste</segment>
    <segment id="44">; de segunda a sábado</segment>
    <segment id="45">, das 9h às 18h30</segment>
    <segment id="46">, e domingo</segment>
    <segment id="47">, das 9h às 17h</segment>
    <segment id="48">;</segment>
    <segment id="49">Instagram @gatopingadocafe  Conheça o Gato Pingado</segment>
    <segment id="50">, &amp;#039</segment>
    <segment id="51">;cat café&amp;#039</segment>
    <segment id="52">;</segment>
    <segment id="53">em PinheirosMais    novamente         de   de  de  representando um  Gateria</segment>
    <segment id="54">O espaço fica na Vila Mariana</segment>
    <segment id="55">, na zona sul de São Paulo.</segment>
    <segment id="56">Além dos bichanos disponíveis para adoção e das comidinhas servidas no local</segment>
    <segment id="57">, o Gateria também conta com uma área pet friendly que recebe os cães dos clientes.</segment>
    <segment id="58">Endereço: rua Dr. José de Queirós Aranha</segment>
    <segment id="59">, 358A</segment>
    <segment id="60">, na Vila Mariana</segment>
    <segment id="61">, na zona sul</segment>
    <segment id="62">; de terça a sexta</segment>
    <segment id="63">, das 10h30 às 18h</segment>
    <segment id="64">, sábado e domingo</segment>
    <segment id="65">, das 9h30 às 17h</segment>
    <segment id="66">;</segment>
    <segment id="67">Instagram @gateriacatcafe</segment>
    <segment id="68">Cat cafés atraem amantes de gatos e curiososMais    novamente         de   de  de  representando um  + GaticesLeia</segment>
    <segment id="69">mais sobre gatosGatos adultos</segment>
    <segment id="70">, frajolas e escaminhas são rejeitados na adoçãoCafé com Gato promove aula de ioga com bichanos no interior de SPRio de Janeiro ganha cat café que promove adoção de gatosSiga o blog Gatices no Twitter</segment>
    <segment id="71">, Instagram e Facebook.</segment>
