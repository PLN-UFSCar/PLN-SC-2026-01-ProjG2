  <rst>
    <segment id="1">A vereadora de São Paulo Janaína Lima (MDB) prepara uma ação judicial coletiva contra a concessionária de energia</segment>
    <segment id="2">Enel em razão do apagão que começou na última sexta-feira (3).</segment>
    <segment id="3">A vereadora Janaina Lima</segment>
    <segment id="4">, do MDB - DivulgaçãoEla abriu espaço em suas redes sociais</segment>
    <segment id="5">para que</segment>
    <segment id="6">para que moradores afetados</segment>
    <segment id="7">sese manifestem.</segment>
    <segment id="8">Também disponibilizou um formulário online</segment>
    <segment id="9">para que</segment>
    <segment id="10">para que as pessoas relatem quanto tempo ficaram sem energia e prejuízos materiais que tiveram</segment>
    <segment id="11">, com comida ou mercadorias</segment>
    <segment id="12">, por exemplo.  "</segment>
    <segment id="13">Fora Enel</segment>
    <segment id="14">, vamos acabar com essa concessão</segment>
    <segment id="15">, quebrar esse monopólio e multar pelo péssimo serviço que você presta ao paulistano"</segment>
    <segment id="16">, disse a vereadora.</segment>
    <segment id="17">A Câmara Municipal deve criar também ainda nesta semana uma CPI para investigar o apagão</segment>
