  <rst>
    <segment id="1">O tema do “anexo negativo” na delação de Henrique Constantino</segment>
    <segment id="2">, um dos sócios da Gol</segment>
    <segment id="3">, é sobre uma doação de horas de voo equivalentes a R$ 20 milhões</segment>
    <segment id="4">para que</segment>
    <segment id="5">para que o ex-presidente Michel Temer aprovasse a abertura de capital do setor aéreo para empresas estrangeiras.</segment>
    <segment id="6">Constantino disse aos procuradores que R$ 20 milhões em horas de voo não é um número compatível com a realidade e que nunca houve essa troca - www.fotoarena.com.brEU DECLARO</segment>
    <segment id="7">Constantino firmou um acordo com o Ministério Público Federal.</segment>
    <segment id="8">Sua delação tem 12 anexos</segment>
    <segment id="9">, um deles é o negativo</segment>
    <segment id="10">, ou seja</segment>
    <segment id="11">, onde ele nega uma negociação.</segment>
    <segment id="12">FANTASIA</segment>
    <segment id="13">O empresário afirmou aos procuradores que tal negociação nunca aconteceu.</segment>
    <segment id="14">O tema foi tratado na delação do doleiro Lucio Funaro</segment>
    <segment id="15">, em 2017.</segment>
    <segment id="16">NEGOCIATA</segment>
    <segment id="17">O doleiro disse</segment>
    <segment id="18">, em seu acordo</segment>
    <segment id="19">, que houve uma articulação para a liberação da participação estrangeira em empresas aéreas entre Constantino e o ex-presidente Michel Temer</segment>
    <segment id="20">, o ex-deputado Eduardo Cunha e o ex-ministro Henrique Eduardo Alves.  MILHAS</segment>
    <segment id="21">Constantino disse aos procuradores que R$ 20 milhões em horas de voo não é um número compatível com a realidade e que nunca houve essa troca.</segment>
    <segment id="22">SILÊNCIO   Procurado</segment>
    <segment id="23">, o advogado de Constantino</segment>
    <segment id="24">, Alexandre Wunderlich</segment>
    <segment id="25">, disse que a defesa só</segment>
    <segment id="26">sese manifestará nos autos do processo.</segment>
    <segment id="27">Ele afirma ainda que “seguirá atuando para o total esclarecimento dos fatos e em favor do interesse público”.  DEFESA</segment>
    <segment id="28">A Rede Justiça Criminal</segment>
    <segment id="29">, colegiado formado por organizações</segment>
    <segment id="30">comocomo Conectas e Sou da Paz</segment>
    <segment id="31">, protocolou um ofício na Assembleia Legislativa do Estado do Rio (Alerj) em apoio ao mandato da deputada Renata Souza (PSOL).</segment>
    <segment id="32">TOMA LÁ</segment>
    <segment id="33">, DÁ CÁ</segment>
    <segment id="34">A parlamentar denunciou na semana passada o governador do Rio</segment>
    <segment id="35">, Wilson Witzel (PSC)</segment>
    <segment id="36">, à Organização dos Estados Americanos (OEA) e à ONU.</segment>
    <segment id="37">Em resposta</segment>
    <segment id="38">, deputados do PSC entraram com uma representação contra a deputada pedindo sua cassação do mandato.</segment>
    <segment id="39">AQUI NÃO</segment>
    <segment id="40">“</segment>
    <segment id="41">Não podemos aceitar que haja uma tentativa de intimidação de um parlamentar que exerce seu mandato”</segment>
    <segment id="42">, explica a secretária executiva da Rede</segment>
    <segment id="43">, Janaína Homerin.</segment>
    <segment id="44">Abertura da exposição Mais    novamente         de   de  de  representando um  ROLO DE FILME</segment>
    <segment id="45">A fotógrafa Vania Toledo inaugurou a mostra “Corpo Livre”</segment>
    <segment id="46">, na Galeria MaPa</segment>
    <segment id="47">, em São Paulo</segment>
    <segment id="48">, na quinta-feira (16).</segment>
    <segment id="49">O galerista Marcelo Pallotta</segment>
    <segment id="50">, a curadora Marly Porto</segment>
    <segment id="51">, o jornalista Milton Faria e o publicitário Ruy Nogueira estiveram presentes.</segment>
    <segment id="52">QUANTO…</segment>
    <segment id="53">O show do cantor Caetano Veloso e seus filhos Moreno</segment>
    <segment id="54">, Zeca e Tom custará R$ 200 mil para a Secretaria Municipal de Cultura de SP.</segment>
    <segment id="55">Eles vão</segment>
    <segment id="56">sese apresentar no sábado (18)</segment>
    <segment id="57">, na Virada Cultural.   ...</segment>
    <segment id="58">CUSTA</segment>
    <segment id="59">A cantora Maria Rita receberá R$ 145 mil e a banda Nação Zumbi levará R$ 100 mil para tocar no evento.</segment>
    <segment id="60">PÁGINAS</segment>
    <segment id="61">A história da freira Irmã Dulce</segment>
    <segment id="62">, que será proclamada a primeira santa nascida no Brasil pelo papa Francisco</segment>
    <segment id="63">, vai virar uma biografia lançada pela editora Planeta.</segment>
    <segment id="64">VIDA</segment>
    <segment id="65">O livro foi escrito por Graciliano Rocha e vai trazer os encontros com Madre Teresa de Calcutá e com João Paulo 2º e a relação da freira com o ex-governador da Bahia Antônio Carlos Magalhães e com o empreiteiro Norberto Odebrecht.</segment>
    <segment id="66">Pré-estreia do filme Mais    novamente         de   de  de  representando um  TOGA</segment>
    <segment id="67">A atriz Marisa Orth</segment>
    <segment id="68">, a presidente do Instituto Alana</segment>
    <segment id="69">, Ana Lucia Villela</segment>
    <segment id="70">, e a distribuidora Luana Lobo foram à pré-estreia do filme “</segment>
    <segment id="71">A Juíza”</segment>
    <segment id="72">, realizada no Espaço Itaú de Cinema Pompeia</segment>
    <segment id="73">, na quarta-feira (15).   CURTO-CIRCUITO</segment>
    <segment id="74">A Ocupação 9 de Julho</segment>
    <segment id="75">, na rua Álvaro de Carvalho</segment>
    <segment id="76">, 427, fará uma feijoada com versão vegana</segment>
    <segment id="77">, shows e oficinas.</segment>
    <segment id="78">A partir das 12h.</segment>
    <segment id="79">O chef Luciano Boseggia</segment>
    <segment id="80">, ex-Fasano</segment>
    <segment id="81">, assina cardápio na Cantina Montechiaro</segment>
    <segment id="82">, em SP</segment>
    <segment id="83">, de sábado (18) até agosto.</segment>
    <segment id="84">A Academia de Ópera do Theatro São Pedro apresenta trechos de óperas.</segment>
    <segment id="85">No sábado (18) e no domingo (19).</segment>
    <segment id="86">A soprano Carla Cottini faz recital no aniversário da arquiteta Débora Aguiar.</segment>
    <segment id="87">No sábado (18)</segment>
    <segment id="88">, em São Paulo.   com  BRUNA NARCIZO</segment>
    <segment id="89">, BRUNO B. SORAGGI e VICTORIA AZEVEDO</segment>
  </rst>
</analysis>