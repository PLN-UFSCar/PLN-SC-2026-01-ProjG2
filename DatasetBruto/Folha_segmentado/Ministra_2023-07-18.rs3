  <rst>
    <segment id="1">A ministra Luciana Santos (Ciência e Tecnologia) aposta num conjunto de fatores para</segment>
    <segment id="2">sese segurar na cadeira</segment>
    <segment id="3">, cobiçada pelo centrão: é mulher</segment>
    <segment id="4">, negra</segment>
    <segment id="5">, nordestina e presidente de um partido historicamente fiel ao presidente Luiz Inácio Lula da Silva (PT)</segment>
    <segment id="6">, o PCdoB.</segment>
    <segment id="7">A ministra da Ciência e Tecnologia</segment>
    <segment id="8">, Luciana Santos - Evaristo Sá/AFPTambém conta com a simpatia da primeira-dama</segment>
    <segment id="9">, Janja</segment>
    <segment id="10">, além de ter</segment>
    <segment id="11">sese dedicado à área que hoje comanda quando era deputada federal.</segment>
    <segment id="12">Nos próximos dias</segment>
    <segment id="13">, Santos deve receber apoio da comunidade científica para permanecer na pasta.</segment>
    <segment id="14">O presidente</segment>
    <segment id="15">, contudo</segment>
    <segment id="16">contudo</segment>
    <segment id="17">, ainda não assumiu compromisso com sua manutenção da mesma forma</segment>
    <segment id="18">comocomo fez com outras ministras</segment>
    <segment id="19">, como</segment>
    <segment id="20">como Ana Moser (Esporte) e Nísia Trindade (Saúde).</segment>
  </rst>
