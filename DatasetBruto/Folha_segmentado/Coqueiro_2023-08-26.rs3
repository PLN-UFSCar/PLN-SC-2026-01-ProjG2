  <rst>
    <segment id="1">Da latinha direto para o sanduíche</segment>
    <segment id="2">, a salada ou o macarrão.</segment>
    <segment id="3">A praticidade do atum em conserva é reforçada por uma campanha feita pela Coqueiro nos seus canais digitais.</segment>
    <segment id="4">A marca foi apontada</segment>
    <segment id="5">comocomo a preferida por 23% dos entrevistados pelo Datafolha e</segment>
    <segment id="6">sese destaca especialmente entre os paulistanos de 41 anos ou mais</segment>
    <segment id="7">, com 38% das menções.</segment>
    <segment id="8">A empresa</segment>
    <segment id="9">, que tem uma linha de patês prontos</segment>
    <segment id="10">, conta também com uma cozinha experimental responsável por criar diferentes receitas com o peixe</segment>
    <segment id="11">, divulgadas em seu site e nas redes sociais.</segment>
    <segment id="12">"É uma casa dentro da fábrica de Osasco</segment>
    <segment id="13">, onde a equipe de culinaristas foca tendências.</segment>
    <segment id="14">Já bombaram a salada de pote e os wraps"</segment>
    <segment id="15">, diz Juliana Connti</segment>
    <segment id="16">, gerente-executiva de marketing e insights da Camil Alimentos</segment>
    <segment id="17">, dona da marca.</segment>
    <segment id="18">Coqueiro divide neste ano o posto de melhor atum com a Gomes da Costa -Keiny Andrade/FolhapressDepois de ocupar o pódio sozinha na última edição</segment>
    <segment id="19">, a Coqueiro divide neste ano o posto com a catarinense Gomes da Costa</segment>
    <segment id="20">, que teve 26% das citações.</segment>
    <segment id="21">O índice sobe entre os paulistanos de 26 a 40 anos (37%).</segment>
    <segment id="22">A companhia</segment>
    <segment id="23">, que completa 70 anos no ano que vem</segment>
    <segment id="24">, pertence ao grupo espanhol Calvo desde 2004.</segment>
    <segment id="25">A marca busca mostrar que o atum em conserva faz parte de uma alimentação saudável.</segment>
    <segment id="26">"</segment>
    <segment id="27">Felizmente</segment>
    <segment id="28">, mitos do passado vêm sendo quebrados.</segment>
    <segment id="29">São produtos sem conservantes</segment>
    <segment id="30">, à base de ingredientes naturais"</segment>
    <segment id="31">, diz Camila Garcia Cruz</segment>
    <segment id="32">, gerente de categoria e inovação.</segment>
    <segment id="33">Conheça as melhores marcas relacionadas a almoço segundo o DatafolhaMais    novamente         de   de  de  representando um</segment>
    <segment id="34">A empresa tem investido também na linha premium</segment>
    <segment id="35">, em embalagem de vidro transparente</segment>
    <segment id="36">, que traz o peixe em filés</segment>
    <segment id="37">, conservado em azeite extravirgem.</segment>
    <segment id="38">"</segment>
    <segment id="39">São para servir</segment>
    <segment id="40">comocomo antepasto</segment>
    <segment id="41">, entre amigos</segment>
    <segment id="42">, ou até para dar de presente"</segment>
    <segment id="43">, afirma a executiva.</segment>
    <segment id="44">O levantamento do Datafolha foi realizado na cidade de São Paulo com pessoas de 16 anos ou mais das classes</segment>
    <segment id="45">A e B, que costumam cozinhar ao menos uma vez por semana.</segment>
  </rst>
