  <rst>
    <segment id="1">O livreiro Robson Melo é o vencedor da categoria Inovação para o Século 21 do Prêmio Empreendedor Social 2023.</segment>
    <segment id="2">Fundador da Estante Mágica</segment>
    <segment id="3">, o carioca estimula estudantes a escrever livros na plataforma educacional gratuita.</segment>
    <segment id="4">Em parceria com 7.000 escolas no país</segment>
    <segment id="5">, a edtech democratiza o processo de escrita e aprendizagem.</segment>
    <segment id="6">Já foram 2</segment>
    <segment id="7">,5 milhões de livros publicados.</segment>
    <segment id="8">"</segment>
    <segment id="9">Gente é história.</segment>
    <segment id="10">E a gente veio aqui para celebrá-las.</segment>
    <segment id="11">Agradeço a todos que vêm transformando a vida dessas crianças"</segment>
    <segment id="12">, disse Robson Melo ao receber o troféu no palco do Teatro Porto Seguro</segment>
    <segment id="13">, em São Paulo</segment>
    <segment id="14">, nesta terça-feira (24)</segment>
    <segment id="15">, entregue por Judith Brito</segment>
    <segment id="16">, superintendente da Folha.  Robson Melo</segment>
    <segment id="17">, vencedor do Prêmio Empreendedor Social 2023</segment>
    <segment id="18">, na categoria Inovações para o Século 21</segment>
    <segment id="19">, recebe o troféu no Teatro Porto Seguro - Jardiel Carvalho/FolhapressO empreendedor social é nascido e criado na favela da Rocinha</segment>
    <segment id="20">, de onde saía todo dia às 5h30 e voltava meia-noite entre estudos e trabalho.</segment>
    <segment id="21">Foi o primeiro da sua família a conquistar diploma superior.</segment>
    <segment id="22">Em 2009</segment>
    <segment id="23">, ele fundou a Estante Mágica</segment>
    <segment id="24">, que garante o livro digital gratuito para todos os alunos.</segment>
    <segment id="25">A monetização vem pela venda da versão impressa</segment>
    <segment id="26">, adquirida pela família ou financiada por crowdfunding</segment>
    <segment id="27">, empresas ou secretarias de educação.</segment>
    <segment id="28">"</segment>
    <segment id="29">Às vezes o livro da Estante Mágica é o primeiro que os pais dessas crianças lêem.</segment>
    <segment id="30">Acreditem na história de vocês</segment>
    <segment id="31">, nas histórias verdadeiras.</segment>
    <segment id="32">Cada história conta.</segment>
    <segment id="33">"</segment>
    <segment id="34">Em Inovações para o Século 21</segment>
    <segment id="35">, Robson Melo concorreu com Bruno Sindona</segment>
    <segment id="36">, da incorporadora Sindona</segment>
    <segment id="37">, que muda o padrão das moradias para baixa renda</segment>
    <segment id="38">, e com João Piedrafita e Rodrigo Belli</segment>
    <segment id="39">, da Água Camelo</segment>
    <segment id="40">, que garante acesso a água tratada em comunidades ribeirinhas e periféricas</segment>
    <segment id="41">Brasil afora.</segment>
    <segment id="42">Estante MágicaMais    novamente         de   de  de  representando um</segment>
    <segment id="43">Os quatro chegaram à final na categoria que dá visibilidade para iniciativas conectadas com grandes agendas do novo século em territórios vulneráveis</segment>
    <segment id="44">, periferias e biomas ameaçados.</segment>
    <segment id="45">A escolha foi feita por um júri composto de personalidades e especialistas</segment>
    <segment id="46">, que contou</segment>
    <segment id="47">, entre outros</segment>
    <segment id="48">, com empreendedores sociais</segment>
    <segment id="49">comocomo Jerro Billimoria e Celso Athayde</segment>
    <segment id="50">, empresários de destaque</segment>
    <segment id="51">comocomo Marta Pinheiro e Helena Bertho</segment>
    <segment id="52">, e atores do ecossistema de impacto social</segment>
    <segment id="53">, como</segment>
    <segment id="54">como Ana Moser e Marcel Fukuyama.</segment>
    <segment id="55">A cerimônia do Empreendedor Social desta noite anuncia ainda os vencedores em Inclusão Social e Produtiva</segment>
    <segment id="56">, Soluções que Inspiram e Escolha do Leitor.</segment>
    <segment id="57">O Prêmio Empreendedor Social tem patrocínio de Gerdau</segment>
    <segment id="58">, Ambev</segment>
    <segment id="59">, Coca-Cola</segment>
    <segment id="60">, Instituto Liberta</segment>
    <segment id="61">, Vedacit</segment>
    <segment id="62">, CNI/Sesi/Senai e VR.</segment>
    <segment id="63">Conta também com apoio da Porto e parceria estratégica de Ashoka</segment>
    <segment id="64">, ESPM</segment>
    <segment id="65">, Fundação Dom Cabral</segment>
    <segment id="66">, Pacto Global</segment>
    <segment id="67">, Prosas</segment>
    <segment id="68">, SBSA Advogados e UOL</segment>
    <segment id="69">, além de 15 parceiros institucionais e 7 de divulgação.</segment>
  </rst>
</analysis>