  </header>
  <rst>
    <segment id="1">Os produtores rurais poderão discutir política agrícola e cenários do setor com a ministra da Agricultura</segment>
    <segment id="2">, Tereza Cristina</segment>
    <segment id="3">, em um evento online na próxima semana.</segment>
    <segment id="4">Entre os principais temas a serem abordados estarão política agrícola</segment>
    <segment id="5">, liberação de novas tecnologias</segment>
    <segment id="6">, sustentabilidade na produção</segment>
    <segment id="7">, financiamento e questões fundiárias.</segment>
    <segment id="8">Mediado por André Pessôa</segment>
    <segment id="9">, da Agroconsult</segment>
    <segment id="10">, o evento terá as participações de Walter Horita</segment>
    <segment id="11">, produtor de soja</segment>
    <segment id="12">, milho e algodão no oeste da Bahia</segment>
    <segment id="13">, e de Paulo Pires</segment>
    <segment id="14">, presidente da Fecoagro</segment>
    <segment id="15">, que reúne as cooperativas do Rio Grande do Sul.</segment>
    <segment id="16">Esta é Tereza CristinaMais    novamente         de   de  de  representando um</segment>
    <segment id="17">Além deles</segment>
    <segment id="18">, participarão dessas discussões Simon Veldt</segment>
    <segment id="19">, presidente da Cooperativa Agro Industrial Holambra</segment>
    <segment id="20">, e Aurélio Pavinato</segment>
    <segment id="21">, diretor-presidente da SLC.</segment>
    <segment id="22">O evento online ocorrerá em 27 de abril</segment>
    <segment id="23">, às 19h.</segment>
    <segment id="24">A Agroconsult</segment>
    <segment id="25">, que organiza o Rally da Safra</segment>
    <segment id="26">, estimou a safra brasileira de soja em 137</segment>
    <segment id="27">,1 milhões de toneladas neste ano.</segment>
    <segment id="28">A produtividade média foi de de 59</segment>
    <segment id="29">,3 sacas por hectare.</segment>
    <segment id="30">  Comércio aquecidoCom um intenso aumento na área de plantio e com o preço da carne bovina na estratosfera</segment>
    <segment id="31">, imaginem quais os itens mais procurados no comércio eletrônico no primeiro trimestre deste ano?</segment>
    <segment id="32">Quem arriscou bezerro e trator</segment>
    <segment id="33">, acertou.</segment>
    <segment id="34">Item valorizado</segment>
    <segment id="35">Um levantamento da OLX</segment>
    <segment id="36">, uma plataforma de compra e venda</segment>
    <segment id="37">, apontou que a procura por bezerro cresceu 168% nos três primeiros meses deste ano em relação a igual período do ano passado.</segment>
    <segment id="38">No mesmo período</segment>
    <segment id="39">, a busca por trator aumentou 31%.</segment>
    <segment id="40">Acertos na fazendaA plataforma constatou</segment>
    <segment id="41">, ainda</segment>
    <segment id="42">, que houve um aumento de 97% por retroescavadeiras.</segment>
    <segment id="43">Com o caixa em alta</segment>
    <segment id="44">, devido aos bons preços do momento</segment>
    <segment id="45">, os produtores tiveram um tempinho para melhorar a estrutura da propriedade.</segment>
    <segment id="46">Alta consistente</segment>
    <segment id="47">A OLX constatou que a demanda por produtos do setor do agronegócio cresceu 45% nos três primeiros meses do ano</segment>
    <segment id="48">, em comparação a igual período de 2020.</segment>
    <segment id="49">As vendas cresceram 43% no período.</segment>
  </rst>
</analysis>