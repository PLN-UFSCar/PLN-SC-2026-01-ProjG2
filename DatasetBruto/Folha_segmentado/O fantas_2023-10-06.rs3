  <rst>
    <segment id="1">Mais interessado em emparedar o STF</segment>
    <segment id="2">, o Senado esqueceu a votação da minirreforma</segment>
    <segment id="3">, inviabilizada para as eleições municipais de 2024.</segment>
    <segment id="4">Aprovado na Câmara</segment>
    <segment id="5">, uma das muitas maracutaias do projeto envolve o fundo eleitoral</segment>
    <segment id="6">, mina de dinheiro —cerca de R$ 6 bilhões— com recursos públicos empregada sem transparência e controle.</segment>
    <segment id="7">Colunas e BlogsReceba no seu email uma seleção de colunas e blogs da Folha</segment>
    <segment id="8">; exclusiva para assinantes.</segment>
    <segment id="9">Carregando...</segment>
    <segment id="10">Em novembro de 2022</segment>
    <segment id="11">, Valdemar Costa Neto entrou em pânico quando o ministro Alexandre de Moraes</segment>
    <segment id="12">, do STF</segment>
    <segment id="13">, bloqueou o fundo do PL</segment>
    <segment id="14">, reagindo a mais uma etapa do golpe contra a eleição de Lula.</segment>
    <segment id="15">À época</segment>
    <segment id="16">, o partido pediu ao TSE a impugnação de quase 280 mil urnas usadas no segundo turno.</segment>
    <segment id="17">No primeiro</segment>
    <segment id="18">, com 99 deputados federais e oito senadores eleitos pelo PL</segment>
    <segment id="19">, elas continuariam valendo.</segment>
    <segment id="20">A ação aloprada de Valdemar custou caro.</segment>
    <segment id="21">Os pagamentos ao partido só foram liberados em fevereiro com a quitação da multa de R$ 22</segment>
    <segment id="22">,9 milhões.</segment>
    <segment id="23">Esse tipo de episódio —que também respingou no PP e no Republicanos</segment>
    <segment id="24">, coligados ao PL na eleição presidencial— foi aumentando a insatisfação do Congresso com o STF</segment>
    <segment id="25">, que explode agora com a possibilidade de o Legislativo reverter decisões da corte.</segment>
    <segment id="26">O recado é claro:</segment>
    <segment id="27">sese mexer comigo e com meu poder de mandar e ganhar</segment>
    <segment id="28">, aguente o garrote.</segment>
    <segment id="29">Valendo-</segment>
    <segment id="30">sese do fundo</segment>
    <segment id="31">, o PL</segment>
    <segment id="32">, em seis meses</segment>
    <segment id="33">, torrou R$ 870 mil para honrar salários de Bolsonaro</segment>
    <segment id="34">, da ex-primeira-dama Michelle e do ex-ministro Braga Netto</segment>
    <segment id="35">, três próceres enrolados na Justiça.</segment>
    <segment id="36">Na função de cabo eleitoral de luxo</segment>
    <segment id="37">, o ex-presidente</segment>
    <segment id="38">, como</segment>
    <segment id="39">como de hábito</segment>
    <segment id="40">, tem optado pela moleza: visitar cidades do interior paulista</segment>
    <segment id="41">, onde seus aliados têm mais chance.</segment>
    <segment id="42">No plano nacional</segment>
    <segment id="43">, o capitão perdeu o apoio do governador de Minas</segment>
    <segment id="44">, Romeu Zema.</segment>
    <segment id="45">E o general Heleno</segment>
    <segment id="46">, na CPI do 8/1</segment>
    <segment id="47">, tentou</segment>
    <segment id="48">sese descolar dele.</segment>
    <segment id="49">Se Bolsonaro acabar preso antes das eleições</segment>
    <segment id="50">, restará o vitimismo —que até rima</segment>
    <segment id="51">, masmas não combina com bolsonarismo.</segment>
    <segment id="52">Sempre haverá</segment>
    <segment id="53">, contudo</segment>
    <segment id="54">contudo</segment>
    <segment id="55">, o fantasma do golpe parlamentar assombrando o país.</segment>
    <segment id="56">O ex-ministro de Bolsonaro</segment>
    <segment id="57">, general Heleno</segment>
    <segment id="58">, depõe na CPI do 8 de Janeiro - Gabriela Biló - 26.set.23/Folhapress</segment>
  </rst>
</analysis>