  <rst>
    <segment id="1">Maior artilheiro e ídolo da história do Barcelona</segment>
    <segment id="2">, Lionel Messi</segment>
    <segment id="3">, 34, compareceu ao Camp Nou neste domingo (8) para sua despedida do clube catalão.</segment>
    <segment id="4">Ao lado das 35 taças que conquistou com a camisa do Barça</segment>
    <segment id="5">, o argentino fez um pronunciamento</segment>
    <segment id="6">, sese emocionou ao falar sobre sua passagem de 21 anos pela Catalunha e respondeu a perguntas dos repórteres presentes.</segment>
    <segment id="7">Lionel Messi</segment>
    <segment id="8">, emocionado</segment>
    <segment id="9">, durante a sua coletiva de despedida do Barcelona - Albert Gea/ReutersAlém da imprensa</segment>
    <segment id="10">, compareceram ao evento dirigentes e também jogadores do elenco atual do Barcelona</segment>
    <segment id="11">, assim</segment>
    <segment id="12">comocomo atletas que já não defendem a equipe e foram companheiros de Messi</segment>
    <segment id="13">, caso</segment>
    <segment id="14">caso de Xavi Hernández</segment>
    <segment id="15">, tetracampeão europeu pelo clube junto do camisa 10.</segment>
    <segment id="16">"</segment>
    <segment id="17">Cheguei muito jovem com 13 anos</segment>
    <segment id="18">, e 21 anos depois vou</segment>
    <segment id="19">embora</segment>
    <segment id="20">embora com minha esposa e meus três filhos catalães-argentinos.</segment>
    <segment id="21">Esta é a nossa casa.</segment>
    <segment id="22">Cabe a mim agradecer por tudo o que vivi</segment>
    <segment id="23">, aos meus companheiros e às pessoas do clube.</segment>
    <segment id="24">Sempre tentei trabalhar com humildade</segment>
    <segment id="25">, respeito e fiz isso com todos nesta casa.</segment>
    <segment id="26">Espero que seja isso o que fique de mim"</segment>
    <segment id="27">, disse Messi</segment>
    <segment id="28">, que não conteve as lágrimas durante seu discurso.</segment>
    <segment id="29">"Gostaria de me despedir de outra maneira</segment>
    <segment id="30">, com torcida</segment>
    <segment id="31">, no campo.</segment>
    <segment id="32">Queria sentir uma última ovação.</segment>
    <segment id="33">O carinho das pessoas foi o mesmo e senti o reconhecimento e o amor deste clube.</segment>
    <segment id="34">Oxalá possa voltar um dia ao clube</segment>
    <segment id="35">, da forma que for.</segment>
    <segment id="36">Que eu possa aportar algo</segment>
    <segment id="37">para que</segment>
    <segment id="38">para que este clube continue sendo o melhor do mundo.</segment>
    <segment id="39">"</segment>
    <segment id="40">Ao terminar o pronunciamento</segment>
    <segment id="41">, Lionel Messi foi aplaudido de pé pelos jogadores do Barcelona presentes no auditório.</segment>
    <segment id="42">O gesto durou mais de um minuto e antecedeu as perguntas dos repórteres</segment>
    <segment id="43">, ávidos por saberem os próximos passos do jogador.</segment>
    <segment id="44">Sobre seu futuro</segment>
    <segment id="45">, o argentino afirmou que recebeu muitas propostas desde o anúncio do Barça de que o clube e ele não renovariam contrato.</segment>
    <segment id="46">Perguntado sobre a possibilidade de reforçar o Paris Saint-Germain</segment>
    <segment id="47">, Messi disse não ter fechado com nenhum clube</segment>
    <segment id="48">, masmas não negou que converse com os parisienses.</segment>
    <segment id="49">A trajetória de Messi pelo Barcelona   novamente         de   de  de  representando um</segment>
    <segment id="50">O camisa 10 estava sem contrato desde o dia 30 de junho</segment>
    <segment id="51">, quando expirou o último acordo com que ele havia assinado com o Barcelona.</segment>
    <segment id="52">Apesar de ele ter externado sua insatisfação com os rumos do clube no fim da penúltima temporada</segment>
    <segment id="53">, quando começaram as especulações em torno de sua saída</segment>
    <segment id="54">, havia uma expectativa de que as partes iriam firmar um novo vínculo.</segment>
    <segment id="55">Messi reiterou o desejo de permanecer</segment>
    <segment id="56">, masmas disse que a renovação não foi possível por conta de limitações financeiras do Barça e também por medidas de fair play financeiro impostas por LaLiga</segment>
    <segment id="57">, a organizadora do Campeonato Espanhol.</segment>
    <segment id="58">Pelas regras definidas por LaLiga</segment>
    <segment id="59">, há um teto salarial para cada clube baseado em seu faturamento.</segment>
    <segment id="60">A ideia é que os times não gastem mais que 70% do que arrecadaram na temporada anterior.</segment>
    <segment id="61">Além de ver suas receitas caírem</segment>
    <segment id="62">, a agremiação catalã viu crescer sua dívida</segment>
    <segment id="63">, que atualmente é de cerca de R$ 1 bilhão.</segment>
    <segment id="64">Eleito para a presidência em março deste ano</segment>
    <segment id="65">, Joan Laporta assumiu o compromisso de reorganizar a instituição e tentou liberar jogadores para fazer o craque argentino caber na folha salarial</segment>
    <segment id="66">, porém</segment>
    <segment id="67">porém não chegou aos números necessários para evitar o adeus do ídolo.</segment>
    <segment id="68">Em 778 jogos pelo Barcelona</segment>
    <segment id="69">, Lionel Messi marcou 672 gols</segment>
    <segment id="70">, distribuiu 288 assistências e conquistou 35 títulos.</segment>
    <segment id="71">Também com a camisa do clube</segment>
    <segment id="72">, foi eleito seis vezes o melhor jogador do mundo.</segment>
    <segment id="73">Entre suas principais conquistas estão os quatro títulos europeus e os Campeonatos Espanhóis.</segment>
    <segment id="74">Messi chegou em 2000 ao Barça</segment>
    <segment id="75">, com apenas 12 anos de idade</segment>
    <segment id="76">, e se</segment>
    <segment id="77">se despede mais de duas décadas depois</segment>
    <segment id="78">comocomo o maior jogador da história do clube catalão.</segment>
  </rst>
</analysis>