  <rst>
    <segment id="1">Em abril deste ano</segment>
    <segment id="2">, o comediante brasileiro Whindersson Nunes venceu o rapper polonês Filip "Filipek"</segment>
    <segment id="3">Marcinek</segment>
    <segment id="4">nas quartas de final do Torneio High Stakes de Boxe</segment>
    <segment id="5">, uma competição entre celebridades.</segment>
    <segment id="6">Agora ele mede forças com o youtuber inglês King Kenny em Dublin</segment>
    <segment id="7">, na Irlanda.</segment>
    <segment id="8">Whindersson Nunes divulga momentos de sua preparação física para o confronto com King Kenny em Dublin - Divulgação  Narração de Rhodes Lima e comentários do medalhista olímpico Hebert Conceição.</segment>
    <segment id="9">Combate</segment>
    <segment id="10">, a partir de 15h</segment>
