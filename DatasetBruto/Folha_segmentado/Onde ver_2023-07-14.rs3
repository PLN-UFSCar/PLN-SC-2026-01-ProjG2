    <segment id="15">Design</segment>
    <segment id="16">O programa chega à terceira temporada com documentários sobre arte</segment>
    <segment id="17">, arquitetura</segment>
    <segment id="18">, design</segment>
    <segment id="19">, gastronomia e sustentabilidade.</segment>
    <segment id="20">Apresentado por Fabio Leblon e Jean Visconti.</segment>
    <segment id="21">Cultura</segment>
    <segment id="22">, 20h, livre</segment>
    <segment id="23">Strangest Things: Objetos Misteriosos da História</segment>
    <segment id="24">Esta nova série examina artefatos estranhos e curiosos</segment>
    <segment id="25">, espalhados por museus e laboratórios do mundo inteiro.</segment>
    <segment id="26">A estreia trata de um besouro de vidro encontrado na tumba do faraó Tutancâmon.</segment>
    <segment id="27">Traços do rosto do faraó Tutancâmon são criados em computação gráficaMais    novamente         de   de  de  representando um  History</segment>
    <segment id="28">, 20h20</segment>
    <segment id="29">, 10 anos   Babilônia  Damien Chazelle</segment>
    <segment id="30">, diretor de "La La Land"</segment>
    <segment id="31">, acompanha três personagens na Hollywood dos anos 1920: uma atriz em ascensão</segment>
    <segment id="32">, um ator decadente e um aspirante a produtor.</segment>
    <segment id="33">Com Brad Pitt e Margot Robbie.</segment>
