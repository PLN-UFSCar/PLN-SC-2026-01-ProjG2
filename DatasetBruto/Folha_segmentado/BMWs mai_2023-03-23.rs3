  <rst>
    <segment id="1">Os carros mais caros da BMW no Brasil só estão próximos na tabela de preços.</segment>
    <segment id="2">Há um oceano de gasolina separando o esportivo X6M Competition (R$ 1</segment>
    <segment id="3">,07 milhão) do elétrico iX50 (R$ 861 mil).</segment>
    <segment id="4">Ambos passaram pelo teste Folha-Mauá.</segment>
    <segment id="5">O iX chegou primeiro.</segment>
    <segment id="6">Seu propósito é ser uma vitrine tecnológica</segment>
    <segment id="7">, o que nem sempre agrada.</segment>
    <segment id="8">Tudo é estranho no primeiro contato</segment>
    <segment id="9">, a começar pelo console central</segment>
    <segment id="10">, com alguns poucos botões de cristal instalados sobre uma lâmina de madeira.</segment>
    <segment id="11">Ao sese acostumar com o ambiente</segment>
    <segment id="12">, as coisas melhoram.</segment>
    <segment id="13">É até fácil</segment>
    <segment id="14">sese entender com o carro</segment>
    <segment id="15">, embora</segment>
    <segment id="16">embora a ausência de comandos físicos dificulte operações simples</segment>
    <segment id="17">comocomo aumentar a velocidade do ar-condicionado.</segment>
    <segment id="18">E ainda há a possibilidade de acionar a central multimídia por gestos.</segment>
    <segment id="19">Não tem muita utilidade</segment>
    <segment id="20">, masmas diverte.</segment>
    <segment id="21">BMW iX50 é o modelo elétrico mais caro da marca alemã no mercado brasileiro - DivulgaçãoSuperadas as peculiaridades tecnológicas</segment>
    <segment id="22">, chega a hora de colocar o carro em movimento.</segment>
    <segment id="23">O torque imediato dos elétricos ainda impressiona</segment>
    <segment id="24">, principalmente em um SUV com 523 cv de potência divididos em dois motores.</segment>
    <segment id="25">A aceleração</segment>
    <segment id="26">, porém</segment>
    <segment id="27">porém, não é o principal destaque do carro.</segment>
    <segment id="28">Seu foco está no luxo.</segment>
    <segment id="29">BMW iX50  Preço: R$ 861 mil Motores: elétricos</segment>
    <segment id="30">, instalados na dianteira e na traseira Potência: 272 cv no motor dianteiro</segment>
    <segment id="31">, 340 cv no traseiro (523 cv combinados)</segment>
    <segment id="32">Torque combinado: 78 kgfm a partir de zero rpm Transmissão: câmbio automático</segment>
    <segment id="33">, marcha única</segment>
    <segment id="34">; tração integral</segment>
    <segment id="35">Pneus: 275/40 R22</segment>
    <segment id="36">Peso: 2.585 kg</segment>
    <segment id="37">Porta-malas: 500 litros</segment>
    <segment id="38">Comprimento: 4</segment>
    <segment id="39">,95 m Largura: 1</segment>
    <segment id="40">,98 m Altura: 1</segment>
    <segment id="41">,70 m Entre-eixos: 3</segment>
    <segment id="42">,0 m</segment>
    <segment id="43">Aceleração (0 a 100 km/h):</segment>
    <segment id="44">4,8s Retomada (80 km/h a 120 km/h):</segment>
    <segment id="45">2,8s Frenagem (80 km/h a 0):</segment>
    <segment id="46">33,8 m</segment>
    <segment id="47">Consumo urbano: 18</segment>
    <segment id="48">,9 kW/100 km</segment>
    <segment id="49">Consumo rodoviário: 21</segment>
    <segment id="50">,3 kW/100 km</segment>
    <segment id="51">Carros elétricos</segment>
    <segment id="52">comocomo o iX50 vão revolucionar o segmento habitado pelos automóveis mais sofisticados do planeta.</segment>
    <segment id="53">Ao remover o motor a combustão</segment>
    <segment id="54">, ruídos e vibrações são eliminados sem a necessidade de quilos e mais quilos de isolamento acústico.</segment>
    <segment id="55">O pacote de baterias permite ir longe no trânsito urbano.</segment>
    <segment id="56">Segundo os dados aferidos pelo Instituto Mauá de Tecnologia</segment>
    <segment id="57">, é possível rodar 580 km na cidade com uma carga completa.</segment>
    <segment id="58">O jipão de 2.585 quilos</segment>
    <segment id="59">sese move sem emitir sons nem para dentro</segment>
    <segment id="60">, nem para fora.</segment>
    <segment id="61">Para quebrar o silêncio</segment>
    <segment id="62">, há 30 alto-falantes –alguns são instalados dentro dos bancos</segment>
    <segment id="63">, o que faz a experiência ao volante parecer um cinema com poltronas que vibram.</segment>
    <segment id="64">BMW apresenta novos modelos elétricosMais    novamente         de   de  de  representando um</segment>
    <segment id="65">O teto de vidro fica translúcido ao toque de um botão</segment>
    <segment id="66">, reduzindo a entrada de luminosidade na cabine.</segment>
    <segment id="67">Os bancos dianteiros são macios e não tem muito apoio lateral</segment>
    <segment id="68">, como</segment>
    <segment id="69">como convém a um SUV com vocação para ser limusine.</segment>
    <segment id="70">Também não</segment>
    <segment id="71">sese deve esperar um comportamento muito aguerrido nas curvas.</segment>
    <segment id="72">Embora seja rápido</segment>
    <segment id="73">, o iX50 gosta mesmo é de estradas retas.</segment>
    <segment id="74">Quer mais esportividade por metro quadrado?</segment>
    <segment id="75">A opção é o X6M Competition.</segment>
    <segment id="76">É o velho mundo</segment>
    <segment id="77">, porém</segment>
    <segment id="78">porém modernizado.</segment>
    <segment id="79">O motor V8 biturbo é barulhento e oferece 625 cv de potência.</segment>
    <segment id="80">O banco de espuma rígida abraça o motorista e tem regulagens elétricas até das abas.</segment>
    <segment id="81">Tudo beira os limites do exagero</segment>
    <segment id="82">, a começar pela aceleração do zero aos 100 km/h em quatro segundos.</segment>
    <segment id="83">Com tanta força disponível</segment>
    <segment id="84">, o consumo não é dos melhores.</segment>
    <segment id="85">A média na estrada</segment>
    <segment id="86">, a 90 km/h e com o ar-condicionado desligado</segment>
    <segment id="87">, ficou em 11</segment>
    <segment id="88">,2 km/l.</segment>
    <segment id="89">Com preço acima de R$ 1 milhão</segment>
    <segment id="90">, BMW X6M Competition é o modelo mais caro da marca no mercado brasileiro - DivulgaçãoBMW X6M Competition  Preço: R$ 1</segment>
    <segment id="91">,07 milhão Motor: dianteiro</segment>
    <segment id="92">, longitudinal</segment>
    <segment id="93">, a gasolina</segment>
    <segment id="94">, 4.4 V8 turbo Potência: 625 cv a 6.000 rpm Torque: 76</segment>
    <segment id="95">,5 kgfm a 1.800 rpm Transmissão: câmbio automático</segment>
    <segment id="96">, oito marchas</segment>
    <segment id="97">; tração integral Pneus: 295/35 R21 na dianteira</segment>
    <segment id="98">, 315/30 R22 na traseira Peso:</segment>
    <segment id="99">2.320 kg Porta-malas: 580 litros</segment>
    <segment id="100">Comprimento: 4</segment>
    <segment id="101">,94 m</segment>
    <segment id="102">Largura: 2</segment>
    <segment id="103">,02 m Altura: 1</segment>
    <segment id="104">,69 m Entre-eixos: 2</segment>
    <segment id="105">,97 m</segment>
    <segment id="106">Aceleração (0 a 100 km/h):</segment>
    <segment id="107">4,0s Retomada (80 km/h a 120 km/h): 2</segment>
    <segment id="108">,6s</segment>
    <segment id="109">Frenagem: (80 km/h a 0):</segment>
    <segment id="110">34,7 m</segment>
    <segment id="111">Consumo urbano: 5</segment>
    <segment id="112">,8 km/l Consumo rodoviário: 11</segment>
    <segment id="113">,2 km/l  Seu comportamento na pista surpreende pela estabilidade.</segment>
    <segment id="114">Não se</segment>
    <segment id="115">se espera que um carro tão grande faça curvas tão bem.</segment>
    <segment id="116">Esse é o resultado de muita eletrônica e de suspensões desenvolvidas sem economias</segment>
    <segment id="117">, como</segment>
    <segment id="118">como mostra o preço final acima de R$ 1 milhão.</segment>
    <segment id="119">Não há motivos racionais que justifiquem a compra.</segment>
    <segment id="120">O X6M é puramente emocional</segment>
    <segment id="121">, e um dos últimos de sua geração.</segment>
    <segment id="122">Carros desse porte e com motores apenas a gasolina começam a desaparecer do mercado europeu.</segment>
    <segment id="123">E até esse jipão superesportivo</segment>
    <segment id="124">sese rendeu à eletrificação.</segment>
    <segment id="125">Interior do SUV BMW X6M Competition tem forrações em duas cores e telas digitais-</segment>
    <segment id="126">DivulgaçãoA linha 2024 recebeu um sistema híbrido leve para reduzir as emissões</segment>
    <segment id="127">, e a potência foi mantida.</segment>
    <segment id="128">Essa opção deve chegar ao Brasil no fim deste ano.</segment>
    <segment id="129">Com legislações antipoluição cada vez mais restritivas</segment>
    <segment id="130">, o futuro dos carros premium pertence a modelos</segment>
    <segment id="131">comocomo o iX50.</segment>
    <segment id="132">O ronco do V8 vai deixar saudades</segment>
    <segment id="133">, masmas as montadoras trabalham para manter a emoção ao volante.</segment>
  </rst>
</analysis>