  <rst>
    <segment id="1">Três torcedores foram presos após uma confusão durante a partida entre Fluminense e Argentinos Juniors</segment>
    <segment id="2">, no Maracanã</segment>
    <segment id="3">, na noite desta terça-feira (8).</segment>
    <segment id="4">O Fluminense venceu por 2 a 0 e</segment>
    <segment id="5">sese classificou para as quartas de final da Libertadores.</segment>
    <segment id="6">Segundo a Polícia Militar</segment>
    <segment id="7">, houve uma confusão generalizada na torcida visitante</segment>
    <segment id="8">, situada no setor norte superior do estádio.</segment>
    <segment id="9">Inicialmente</segment>
    <segment id="10">, houve a intervenção de seguranças do Maracanã e um dos profissionais foi agredido.</segment>
    <segment id="11">Em seguida</segment>
    <segment id="12">, equipes do Bepe (Batalhão Especializado de Policiamento em Estádios) intervieram e uma policial também foi agredida.  "</segment>
    <segment id="13">Foi necessário o emprego de armamento de menor potencial letal para estabilizar o local"</segment>
    <segment id="14">, diz nota da PM.</segment>
    <segment id="15">Segundo a polícia</segment>
    <segment id="16">, dois torcedores argentinos foram detidos e encaminhados ao Juizado Especial do Torcedor e Grandes Eventos.</segment>
    <segment id="17">Durante a confusão</segment>
    <segment id="18">, uma torcedora argentina foi presa em flagrante pelo crime de racismo contra um policial.</segment>
    <segment id="19">Policiais do Batalhão Especializado em Policiamento em Estádios no Maracanã - Divulgação/PMRJVídeo que circula nas redes sociais mostra policiais dando golpes de cassetete em torcedores argentinos envolvidos na confusão.</segment>
    <segment id="20">Não há informações oficiais sobre feridos.</segment>
    <segment id="21">Em outro</segment>
    <segment id="22">casocaso</segment>
    <segment id="23">, um torcedor foi detido após agredir a funcionária de um dos bares do Maracanã</segment>
    <segment id="24">, no setor leste.</segment>
    <segment id="25">O Fluminense vai enfrentar</segment>
    <segment id="26">, nas quartas de final</segment>
    <segment id="27">, o vencedor do jogo entre Olímpia e Flamengo</segment>
    <segment id="28">, que se</segment>
    <segment id="29">se enfrentam na quinta-feira (10)</segment>
    <segment id="30">, em Assunção.</segment>
  </rst>
</analysis>