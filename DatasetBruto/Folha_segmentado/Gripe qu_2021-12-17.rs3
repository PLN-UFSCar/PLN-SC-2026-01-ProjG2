  <rst>
    <segment id="1">Olá, leitores da Folhinha.</segment>
    <segment id="2">Meu nome é Paulo.</segment>
    <segment id="3">Sou médico pediatra</segment>
    <segment id="4">, cuido da saúde de crianças de todas as idades e tenho dois filhos: o Léo</segment>
    <segment id="5">, de 9 anos</segment>
    <segment id="6">, e a Nina</segment>
    <segment id="7">, de 7 anos.</segment>
    <segment id="8">Vocês já devem imaginar que quando chamam o pediatra para conversar com vocês é</segment>
    <segment id="9">porque</segment>
    <segment id="10">porque o assunto é sério!</segment>
    <segment id="11">Sei também que ninguém aguenta mais falar de doença</segment>
    <segment id="12">, e que vocês ficaram muito chateados em ter que ficar sem ir a escola por causa da pandemia de coronavírus.</segment>
    <segment id="13">Lavar as mãos é uma das formas mais importantes de</segment>
    <segment id="14">sese proteger de vírus - Catarina Pignato</segment>
    <segment id="15">Mas preciso explicar para vocês esta gripe nova que está circulando por aí.</segment>
    <segment id="16">Ela tem nome estranho</segment>
    <segment id="17">, gripe H3N2.</segment>
    <segment id="18">Os cientistas adoram usar letras para as doenças.</segment>
    <segment id="19">Estávamos sem ouvir falar de gripe nestes últimos dois anos</segment>
    <segment id="20">, masmas</segment>
    <segment id="21">, infelizmente</segment>
    <segment id="22">, ela voltou.</segment>
    <segment id="23">Isso pode ter acontecido</segment>
    <segment id="24">, talvez</segment>
    <segment id="25">, porque</segment>
    <segment id="26">porque poucas pessoas tomaram a vacina neste ano.</segment>
    <segment id="27">Ou também</segment>
    <segment id="28">porque</segment>
    <segment id="29">porque estamos relaxando um pouco mais</segment>
    <segment id="30">, encontrando os amigos e passeando por aí sem os mesmos cuidados de antes.</segment>
    <segment id="31">A notícia mais importante é que ela é</segment>
    <segment id="32">comocomo a gripe que vocês já conhecem e não é tão grave</segment>
    <segment id="33">comocomo o coronavírus.</segment>
    <segment id="34">Claro que</segment>
    <segment id="35">, como</segment>
    <segment id="36">como toda doença</segment>
    <segment id="37">, ela é chata</segment>
    <segment id="38">, porque</segment>
    <segment id="39">porque pode dar febre</segment>
    <segment id="40">, dor no corpo</segment>
    <segment id="41">, tosse</segment>
    <segment id="42">, nariz escorrendo e nariz entupido.</segment>
    <segment id="43">Isso acaba deixando vocês mais caídos e sem poder brincar.</segment>
    <segment id="44">Mas, do lado bom</segment>
    <segment id="45">, como</segment>
    <segment id="46">como ela é bem menos preocupante do que a Covid</segment>
    <segment id="47">, ninguém vai querer fechar as escolas</segment>
    <segment id="48">, ou deixar vocês sem irem a casa dos avós.</segment>
    <segment id="49">Nem sem ir ao parque para brincar.</segment>
    <segment id="50">E querem saber o mais importante?</segment>
    <segment id="51">Vocês já sabem</segment>
    <segment id="52">comocomo</segment>
    <segment id="53">sese proteger e também</segment>
    <segment id="54">comocomo</segment>
    <segment id="55">sese prevenir</segment>
    <segment id="56">, porque</segment>
    <segment id="57">porque ela é transmitida pela tosse</segment>
    <segment id="58">, por gotículas e pela saliva.</segment>
    <segment id="59">Por isso os cuidados são iguais aos da Covid</segment>
    <segment id="60">, que vocês já conhecem muito bem.</segment>
    <segment id="61">Para evitar este vírus cheio de letras</segment>
    <segment id="62">, não esqueçam de usar máscara</segment>
    <segment id="63">, lavar as mãos</segment>
    <segment id="64">, usar álcool em gel</segment>
    <segment id="65">, evitar aglomerações e lugares fechados.</segment>
    <segment id="66">E, claro</segment>
    <segment id="67">, não deixem nunca de</segment>
    <segment id="68">sese vacinar!</segment>
    <segment id="69">A vacinação é essencial para evitar que vocês tenham que ir ao hospital!</segment>
    <segment id="70">Eu também tenho medo de vacina</segment>
    <segment id="71">, masmas a picada vale a pena para nos proteger.</segment>
    <segment id="72">Conversem com os pais de vocês para ajudá-los a seguir tomando estes cuidados.</segment>
    <segment id="73">Se estiverem doentes não encontrem amigos</segment>
    <segment id="74">, e fiquem em casa por sete dias.</segment>
    <segment id="75">Assim evitamos que outras crianças ou algum familiar também adoeça.</segment>
    <segment id="76">Com todos estes cuidados</segment>
    <segment id="77">, tenho certeza que vocês conseguirão aproveitar e</segment>
    <segment id="78">sese divertir nas férias sem ficar doente.</segment>
    <segment id="79">Boa diversão</segment>
    <segment id="80">, e vamos mandar esta gripe lá para longe!</segment>
    <segment id="81">TODO MUNDO LÊ JUNTO</segment>
    <segment id="82">​  Texto com este selo é indicado para ser lido por responsáveis e educadores com a criança</segment>
  </rst>
</analysis>