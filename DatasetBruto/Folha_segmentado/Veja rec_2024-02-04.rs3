  <rst>
    <segment id="1">Este bolo super chocolatudo é de tirar o fôlego.</segment>
    <segment id="2">Ele cresce alto no forno e depois dá uma murchadinha de volta</segment>
    <segment id="3">, criando uma parte superior crocante e um centro fofo e úmido.</segment>
    <segment id="4">A lista de ingredientes é simples</segment>
    <segment id="5">, masmas os ovos ajudam a tornar este bolo especial</segment>
    <segment id="6">, incluindo as gemas de ovos batidas</segment>
    <segment id="7">, junto com uma generosa quantidade de manteiga e chocolate.</segment>
    <segment id="8">Sirva fatias simples</segment>
    <segment id="9">, com sorvete ou um pouco de chantili.</segment>
    <segment id="10">Para dar um sabor mais profundo</segment>
    <segment id="11">, escolha um chocolate com cerca de 70% de cacau.</segment>
    <segment id="12">Bolo de suflê de chocolate.</segment>
    <segment id="13">Cubra as fatias com pedaços de chantili levemente adoçado ou bolas de sorvete.</segment>
    <segment id="14">Comida estilizada por Yossy Arefi.</segment>
    <segment id="15">- Mark Weinberg/The New York Times  Rendimento:</segment>
    <segment id="16">Um bolo de 22</segment>
    <segment id="17">,8 cm (6 a 8 porções)</segment>
    <segment id="18">Tempo total: 1 hora</segment>
    <segment id="19">, mais o tempo de resfriamento  Ingredientes   ¾ xícara (170 g) de manteiga sem sal</segment>
    <segment id="20">, cortada em pedaços</segment>
    <segment id="21">, e mais para untar a forma 2 xícaras (300 g) de chocolate amargo finamente picado (não gotas)</segment>
    <segment id="22">, preferencialmente com cerca de 70% de cacau 1 xícara (200 g) de açúcar granulado 5 ovos grandes 2 colheres de sopa de rum escuro (opcional</segment>
    <segment id="23">, masmas dá mais sabor) 2 colheres de chá de extrato de baunilha 1 colher de chá de café solúvel em pó (também opcional)</segment>
    <segment id="24">¾ colher de chá de sal 2 colheres de chá de cacau em pó</segment>
    <segment id="25">, para decorar Chantili levemente adoçado ou sorvete</segment>
    <segment id="26">, para servir</segment>
    <segment id="27">Modo de preparo    Pré-aqueça o forno a 170ºC.</segment>
    <segment id="28">Unte</segment>
    <segment id="29">uma forma de fundo removível de 22</segment>
    <segment id="30">,8 cm e forre o fundo com papel manteiga.</segment>
    <segment id="31">Em uma tigela grande resistente ao calor sobre uma panela de água fervente</segment>
    <segment id="32">, ou no micro-ondas</segment>
    <segment id="33">, derreta a manteiga e o chocolate juntos</segment>
    <segment id="34">; mexa até ficar homogêneo.</segment>
    <segment id="35">Adicione ¼ de xícara (50 g) do açúcar à tigela de uma batedeira com batedor.</segment>
    <segment id="36">Separe 4 dos ovos e adicione as gemas e o ovo inteiro restante ao açúcar na tigela da batedeira (você também pode usar uma tigela grande e uma batedeira elétrica de mão).</segment>
    <segment id="37">Bata em velocidade médio-alta até ficar claro</segment>
    <segment id="38">, espumoso e com o dobro de volume</segment>
    <segment id="39">, cerca de 5 minutos.</segment>
    <segment id="40">A mistura de ovos deve cair do batedor em fitas.</segment>
    <segment id="41">Adicione a mistura de ovos à mistura de chocolate derretido.</segment>
    <segment id="42">Coloque o rum (</segment>
    <segment id="43">sese estiver usando)</segment>
    <segment id="44">, a baunilha</segment>
    <segment id="45">, o café solúvel (</segment>
    <segment id="46">sese desejar) e o sal até obter uma mistura homogênea.</segment>
    <segment id="47">Lave e seque a tigela da batedeira</segment>
    <segment id="48">, adicione as claras de ovos restantes e bata em velocidade médio-alta até ficar espumoso.</segment>
    <segment id="49">Adicione lentamente os restantes ¾ de xícara (150 g) de açúcar</segment>
    <segment id="50">, 1 colher de sopa de cada vez</segment>
    <segment id="51">, e bata até formar picos suaves</segment>
    <segment id="52">, cerca de 4 minutos.</segment>
    <segment id="53">Acrescente cerca de 1 xícara da mistura de claras de ovos à mistura de chocolate e mexa cuidadosamente até ficar bem combinado.</segment>
    <segment id="54">Coloque o restante da mistura de claras de ovos e misture gentilmente.</segment>
    <segment id="55">Transfira a massa para a forma e alise a parte superior.</segment>
    <segment id="56">Asse o bolo até que esteja inchado um pouco sobre a borda da forma e as bordas estejam firmes</segment>
    <segment id="57">, masmas o centro ainda esteja um pouco úmido</segment>
    <segment id="58">, de 25 a 30 minutos.</segment>
    <segment id="59">Deixe o bolo esfriar na forma sobre uma grade por cerca de 30 minutos</segment>
    <segment id="60">, até atingir a temperatura ambiente ou apenas um pouco quente.</segment>
    <segment id="61">Passe cuidadosamente uma faca fina ou uma espátula de ao redor das laterais da forma</segment>
    <segment id="62">, em seguida</segment>
    <segment id="63">, remova o aro.</segment>
    <segment id="64">Polvilhe com cacau em pó e sirva à temperatura ambiente ou ligeiramente aquecido</segment>
    <segment id="65">, com chantili ou sorvete.</segment>
    <segment id="66">Use uma faca limpa</segment>
    <segment id="67">, seca e aquecida para obter fatias mais arrumadas.</segment>
    <segment id="68">Cubra levemente earmazene na geladeira por até 3 dias.    Dica:</segment>
    <segment id="69">Opte por barras de chocolate picado em vez de gotas para esta receita</segment>
    <segment id="70">, pois</segment>
    <segment id="71">pois as gotas contêm estabilizadores que afetarão negativamente a textura do bolo final.</segment>
  </rst>
</analysis>