  <rst>
    <segment id="1">O Atl&amp;eacute</segment>
    <segment id="2">;tico de Madrid (ESP) anunciou nesta quarta-feira (23) a contrata&amp;ccedil</segment>
    <segment id="3">;&amp;atilde</segment>
    <segment id="4">;o do atacante uruguaio</segment>
    <segment id="5">Luis Su&amp;aacute</segment>
    <segment id="6">;rez, 33</segment>
    <segment id="7">, ex-Barcelona (ESP).</segment>
    <segment id="8">O atacante</segment>
    <segment id="9">sese despede do clube catal&amp;atilde</segment>
    <segment id="10">;o como</segment>
    <segment id="11">como o terceiro maior artilheiro da hist&amp;oacute</segment>
    <segment id="12">;ria do Bar&amp;ccedil</segment>
    <segment id="13">;a, com 198 gols em 283 jogos.</segment>
    <segment id="14">Em seis temporadas na Catalunha</segment>
    <segment id="15">, conquistou 13 t&amp;iacute</segment>
    <segment id="16">;tulos</segment>
    <segment id="17">, entre eles a Champions League da temporada 2015/2015</segment>
    <segment id="18">, al&amp;eacute</segment>
    <segment id="19">;m de quatro ta&amp;ccedil</segment>
    <segment id="20">;as de LaLiga.</segment>
    <segment id="21">Suárez conquistou 13 títulos com a camisa do Barcelona - Lluis Gene - 29.set.2015/AFPSu&amp;aacute</segment>
    <segment id="22">;rez ir&amp;aacute</segment>
    <segment id="23">; concedor uma entrevista coletiva nesta quinta (24) para formalizar o adeus ao Barcelona.</segment>
    <segment id="24">&amp;quot;O conjunto madrileno pagar&amp;aacute</segment>
    <segment id="25">; ao Barcelona 6 milh&amp;otilde</segment>
    <segment id="26">;es de euros (R$ 39 milh&amp;otilde</segment>
    <segment id="27">;es) em vari&amp;aacute</segment>
    <segment id="28">;veis.</segment>
    <segment id="29">O Barcelona expressa publicamente seu agradecimento a Luis Su&amp;aacute</segment>
    <segment id="30">;rez por seu compromisso e sua dedica&amp;ccedil</segment>
    <segment id="31">;&amp;atilde</segment>
    <segment id="32">;o e lhe deseja muita sorte e &amp;ecirc</segment>
    <segment id="33">;xitos no futuro&amp;quot</segment>
    <segment id="34">;, disse o clube catal&amp;atilde</segment>
    <segment id="35">;o, em comunicado.</segment>
    <segment id="36">O uruguaio chegou ao Bar&amp;ccedil</segment>
    <segment id="37">;a em 2014</segment>
    <segment id="38">, logo ap&amp;oacute</segment>
    <segment id="39">;s a Copa do Mundo disputada no Brasil</segment>
    <segment id="40">, e precisou esperar por sua estreia j&amp;aacute</segment>
    <segment id="41">; que havia recebido uma puni&amp;ccedil</segment>
    <segment id="42">;&amp;atilde</segment>
    <segment id="43">;o da Fifa por morder o italiano Chiellini</segment>
    <segment id="44">, da It&amp;aacute</segment>
    <segment id="45">;lia, em partida v&amp;aacute</segment>
    <segment id="46">;lida pelo Mundial.</segment>
    <segment id="47">Das seis temporadas em que atuou pelo clube</segment>
    <segment id="48">, a de 2016/2016 foi a sua mais produtiva.</segment>
    <segment id="49">Com 40 gols em LaLiga e 59 somando todas as competi&amp;ccedil</segment>
    <segment id="50">;&amp;otilde</segment>
    <segment id="51">;es, faturou a Chuteira de Ouro</segment>
    <segment id="52">, superando Lionel Messi e Cristiano Ronaldo.</segment>
    <segment id="53">Al&amp;eacute</segment>
    <segment id="54">;m dos 198 gols que anotou em sua passagem pelo Barcelona</segment>
    <segment id="55">, o que s&amp;oacute</segment>
    <segment id="56">;</segment>
    <segment id="57">o colocam atr&amp;aacute</segment>
    <segment id="58">;s de C&amp;eacute</segment>
    <segment id="59">;sar e Messi na artilharia hist&amp;oacute</segment>
    <segment id="60">;rica, distribuiu tamb&amp;eacute</segment>
    <segment id="61">;m 98 assist&amp;ecirc</segment>
    <segment id="62">;ncias</segment>
    <segment id="63">, formando com o argentino</segment>
    <segment id="64">, de quem &amp;eacute</segment>
    <segment id="65">; amigo</segment>
    <segment id="66">, uma das duplas mais letais do futebol mundial.</segment>
    <segment id="67">Contratado nesta temporada</segment>
    <segment id="68">, o t&amp;eacute</segment>
    <segment id="69">;cnico holand&amp;ecirc</segment>
    <segment id="70">;s Ronald Koeman conversou com Su&amp;aacute</segment>
    <segment id="71">;rez e disse que o centroavante uruguaio n&amp;atilde</segment>
    <segment id="72">;o formava parte de seus planos para a sequ&amp;ecirc</segment>
    <segment id="73">;ncia do trabalho.</segment>
    <segment id="74">Agora, o atacante</segment>
    <segment id="75">sese incorpora a um rival direto do Bar&amp;ccedil</segment>
    <segment id="76">;a, o Atl&amp;eacute</segment>
    <segment id="77">;tico de Madrid</segment>
    <segment id="78">, comandado pelo treinador argentino Diego Simeone.</segment>
    <segment id="79">O Atl&amp;eacute</segment>
    <segment id="80">;tico foi casa de importantes jogadores uruguaios ao longo dos &amp;uacute</segment>
    <segment id="81">;ltimos anos.</segment>
    <segment id="82">Al&amp;eacute</segment>
    <segment id="83">;m de Jos&amp;eacute</segment>
    <segment id="84">; Gim&amp;eacute</segment>
    <segment id="85">;nez, zagueiro titular da equipe atualmente</segment>
    <segment id="86">, o clube de Madri</segment>
    <segment id="87">, que ainda n&amp;atilde</segment>
    <segment id="88">;o informou a dura&amp;ccedil</segment>
    <segment id="89">;&amp;atilde</segment>
    <segment id="90">;o do contrato de Su&amp;aacute</segment>
    <segment id="91">;rez, teve o zagueiro Diego God&amp;iacute</segment>
    <segment id="92">;n e o meia-atacante Diego Forl&amp;aacute</segment>
    <segment id="93">;n como</segment>
    <segment id="94">como capit&amp;atilde</segment>
    <segment id="95">;es nas duas &amp;uacute</segment>
    <segment id="96">;ltimas d&amp;eacute</segment>
    <segment id="97">;cadas.</segment>
  </rst>
</analysis>