  <rst>
    <segment id="1">Vivek Ramaswamy</segment>
    <segment id="2">, 38, e Asa Hutchinson</segment>
    <segment id="3">, 73, desistiram da corrida pela indicação republicana à Casa Branca nesta terça-feira (16)</segment>
    <segment id="4">, um dia após o favorito</segment>
    <segment id="5">, o ex-presidente Donald Trump</segment>
    <segment id="6">, vencer com ampla vantagem a primeira batalha pela nomeação do partido</segment>
    <segment id="7">, em Iowa.</segment>
    <segment id="8">Com 95% dos votos apurados</segment>
    <segment id="9">, Trump tinha 51% de apoio no estado —maior percentual já obtido em uma disputa da legenda.</segment>
    <segment id="10">O governador da Flórida</segment>
    <segment id="11">, Ron DeSantis (21</segment>
    <segment id="12">,2% dos votos)</segment>
    <segment id="13">, ficou em segundo</segment>
    <segment id="14">, e a ex-embaixadora dos EUA na ONU Nikki Haley (19</segment>
    <segment id="15">,1%), em terceiro.</segment>
    <segment id="16">O resultado fortaleceu a perspectiva de um novo embate entre Trump e o democrata Joe Biden em novembro.</segment>
    <segment id="17">O empresário Vivek Ramaswamy</segment>
    <segment id="18">, que desistiu da candidatura republicana à Casa Branca - Kevin Dietsch/Getty Images via AFP</segment>
    <segment id="19">Após a desistência</segment>
    <segment id="20">, Ramaswamy</segment>
    <segment id="21">, um bilionário filho de indianos que angariou 7</segment>
    <segment id="22">,7% dos votos dos eleitores do estado</segment>
    <segment id="23">, declarou apoio a Trump.</segment>
    <segment id="24">Ele é defensor ferrenho do empresário</segment>
    <segment id="25">, que já chamou de "o melhor presidente americano do século 21"</segment>
    <segment id="26">, e durante a sua campanha</segment>
    <segment id="27">sese comprometeu a conceder indulto ao colega de partido</segment>
    <segment id="28">casocaso fosse eleito</segment>
    <segment id="29">, cobrando uma posição quanto a isso dos outros candidatos.</segment>
    <segment id="30">Trump tem uma série de problemas com a Justiça.</segment>
    <segment id="31">O republicano tornou-</segment>
    <segment id="32">sese réu pela primeira vez em abril do ano passado</segment>
    <segment id="33">, num caso</segment>
    <segment id="34">caso que investiga a compra do silêncio de uma atriz pornô em sua campanha presidencial de 2016.</segment>
    <segment id="35">Em junho</segment>
    <segment id="36">, foi alvo de uma segunda acusação</segment>
    <segment id="37">, esta por ter guardado consigo arquivos secretos após deixar a Casa Branca.</segment>
    <segment id="38">Lá foraReceba no seu email uma seleção semanal com o que de mais importante aconteceu no mundoCarregando...</segment>
    <segment id="39">O ex-presidente também é réu no</segment>
    <segment id="40">casocaso que apura a invasão do Capitólio de 6 de janeiro de 2021 e as tentativas do político de reverter sua derrota na eleição presidencial de 2020.</segment>
    <segment id="41">Os imbróglios de Trump na Justiça eram um problema para Hutchinson</segment>
    <segment id="42">, que conseguiu os votos de menos de 1% dos eleitores do estado.</segment>
    <segment id="43">Principal opositor do ex-presidente dentro do partido</segment>
    <segment id="44">, o republicano foi governador do Arkansas entre 2015 e 2023 e tem experiência na política partidária desde os anos 1980.</segment>
    <segment id="45">Hutchinson foi promotor federal</segment>
    <segment id="46">, cumpriu três mandatos na Câmara e ocupou cargos importantes na administração de George W. Bush.</segment>
    <segment id="47">O político é crítico de correligionários que sustentam que a eleição de 2020 foi roubada e pediu reiteradamente que Trump</segment>
    <segment id="48">sese retirasse da corrida eleitoral.</segment>
    <segment id="49">A tentativa de resgatar a memória do Partido Republicano do passado</segment>
    <segment id="50">, porém</segment>
    <segment id="51">porém, não teve êxito.</segment>
    <segment id="52">"</segment>
    <segment id="53">Hoje estou suspendendo minha campanha para presidente e voltando para o Arkansas"</segment>
    <segment id="54">, disse Hutchinson em um comunicado.</segment>
    <segment id="55">"</segment>
    <segment id="56">Minha mensagem de ser um republicano de princípios</segment>
    <segment id="57">, com experiência</segment>
    <segment id="58">, e dizer a verdade sobre o atual favorito não deu certo em Iowa.</segment>
    <segment id="59">Defendo a campanha que fiz.</segment>
    <segment id="60">"</segment>
    <segment id="61">O fracasso é reflexo do controle que Trump exerce sobre grande parte do eleitorado republicano.</segment>
    <segment id="62">O ex-governador de Nova Jersey</segment>
    <segment id="63">, Chris Christie</segment>
    <segment id="64">, que é crítico do empresário assim</segment>
    <segment id="65">comocomo Hutchinson</segment>
    <segment id="66">, também definhou nas sondagens.</segment>
    <segment id="67">Após anunciar sua candidatura em abril</segment>
    <segment id="68">, Hutchinson participou apenas do primeiro debate do Partido Republicano</segment>
    <segment id="69">, em agosto</segment>
    <segment id="70">, e registrou o menor tempo de fala entre os postulantes.</segment>
    <segment id="71">Posteriormente</segment>
    <segment id="72">, o político não conseguiu os níveis necessários de pontuação nas pesquisas e de arrecadação de fundos para ser incluído no segundo debate.</segment>
    <segment id="73">Quem são os pré-candidatos do Partido Republicano à Presidência dos EUA em 2024Mais    novamente         de   de  de  representando um    Ramaswamy</segment>
    <segment id="74">, por sua vez</segment>
    <segment id="75">, chegou a mudar de estratégia nos dias que antecederam o caucus de Iowa</segment>
    <segment id="76">, chamando o ex-presidente de fraude e</segment>
    <segment id="77">sese apresentando</segment>
    <segment id="78">comocomo um candidato "do outro lado" no Partido Republicano.</segment>
    <segment id="79">O político começou a ganhar projeção entre o eleitorado conservador há pouco mais de dois anos ao criticar a adesão de empresas a causas sociais e políticas.</segment>
    <segment id="80">Em 2021</segment>
    <segment id="81">, ele lançou o best-seller "Woke</segment>
    <segment id="82">, Inc.:</segment>
    <segment id="83">Por Dentro do Golpe de Justiça Social da América Corporativa".</segment>
    <segment id="84">Ele defende que empresas não devem abraçar bandeiras</segment>
    <segment id="85">comocomo diversidade e proteção do meio ambiente</segment>
    <segment id="86">porque</segment>
    <segment id="87">porque não cabe a elas fazer o julgamento moral necessário para definir quais valores sociais devem ser seguidos.</segment>
    <segment id="88">Essa tarefa</segment>
    <segment id="89">, argumenta</segment>
    <segment id="90">, deve ser desempenhada apenas por representantes democraticamente eleitos.</segment>
    <segment id="91">Como empresário</segment>
    <segment id="92">, ele teria</segment>
    <segment id="93">sese negado</segment>
    <segment id="94">, por exemplo</segment>
    <segment id="95">, a divulgar um posicionamento sobre o assassinato de George Floyd</segment>
    <segment id="96">, que desencadeou uma onda protestos antirracistas nos Estados Unidos e mundo afora.</segment>
    <segment id="97">Os pais de Ramaswamy migraram da Índia para Ohio</segment>
    <segment id="98">, nos EUA</segment>
    <segment id="99">, onde o político nasceu e foi criado.</segment>
    <segment id="100">O pai trabalhou</segment>
    <segment id="101">comocomo engenheiro na General Electric e a mãe</segment>
    <segment id="102">, como</segment>
    <segment id="103">como psiquiatra geriátrica.</segment>
    <segment id="104">O filho de imigrantes indianos conseguiu chamar a atenção no primeiro debate das primárias do partido</segment>
    <segment id="105">, em agosto do ano passado.</segment>
    <segment id="106">No Google</segment>
    <segment id="107">, seu nome foi o mais buscado durante o programa.</segment>
    <segment id="108">No X, Elon Musk descreveu sua performance</segment>
    <segment id="109">comocomo "impressionante".</segment>
    <segment id="110">O empresário e investidor</segment>
    <segment id="111">, contudo</segment>
    <segment id="112">contudo</segment>
    <segment id="113">, nunca concorreu a um cargo público e ainda é em grande parte desconhecido entre o eleitorado.</segment>
  </rst>
</analysis>