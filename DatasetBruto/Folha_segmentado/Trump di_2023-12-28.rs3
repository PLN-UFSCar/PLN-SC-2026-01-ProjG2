  <rst>
    <segment id="1">Donald Trump criticou o diretor de "Esqueceram de Mim 2"</segment>
    <segment id="2">, Chris Columbus</segment>
    <segment id="3">, nesta quarta-feira</segment>
    <segment id="4">, por dizer em uma entrevista que o ex-presidente dos Estados Unidos forçou sua participação no filme de 1992.</segment>
    <segment id="5">Trump afirmou que sua aparição fez o longa</segment>
    <segment id="6">sese tornar um sucesso.</segment>
    <segment id="7">Cena de &amp;#039</segment>
    <segment id="8">;Esqueceram de Mim 2&amp;#039</segment>
    <segment id="9">; no hotel Plaza</segment>
    <segment id="10">, em Nova York - DivulgaçãoEm seu perfil da rede social Truth Social</segment>
    <segment id="11">, Trump disse que a produção do filme e o diretor imploraram</segment>
    <segment id="12">para que</segment>
    <segment id="13">para que ele aparecesse.</segment>
    <segment id="14">Na época</segment>
    <segment id="15">, ele era dono do hotel Plaza em Nova York</segment>
    <segment id="16">, onde o longa foi gravado —antes de ser presidente</segment>
    <segment id="17">, ele ganhou fez fortuna</segment>
    <segment id="18">comocomo empresário do ramo imobiliário.</segment>
    <segment id="19">"Eu estava muito ocupado e não queria fazer isso.</segment>
    <segment id="20">Eles foram muito gentis</segment>
    <segment id="21">, masmas acima de tudo</segment>
    <segment id="22">, persistentes.</segment>
    <segment id="23">Eu concordei</segment>
    <segment id="24">, e o resto é história"</segment>
    <segment id="25">, escreveu.</segment>
    <segment id="26">"</segment>
    <segment id="27">Aquela pequena participação decolou</segment>
    <segment id="28">comocomo um foguete</segment>
    <segment id="29">, e o filme foi um grande sucesso</segment>
    <segment id="30">, e ainda é</segment>
    <segment id="31">, especialmente na época do Natal.</segment>
    <segment id="32">As pessoas me ligam sempre que ele é exibido.</segment>
    <segment id="33">"</segment>
    <segment id="34">Dez filmes de Natal para assistir nesta época do anoMais    novamente         de   de  de  representando um    Numa entrevista ao Business Insider em 2020</segment>
    <segment id="35">, Columbus</segment>
    <segment id="36">, o diretor</segment>
    <segment id="37">, disse que ele e sua equipe queriam filmar no saguão do hotel</segment>
    <segment id="38">porque</segment>
    <segment id="39">porque não conseguiriam reconstruir o lugar num estúdio.</segment>
    <segment id="40">Achavam que só teriam de pagar uma taxa</segment>
    <segment id="41">, masmas Trump teria surgido com outra condição.</segment>
    <segment id="42">Segundo Columbus</segment>
    <segment id="43">, Trump disse "a única maneira de você poder usar o Plaza é</segment>
    <segment id="44">sese eu estiver no filme".</segment>
    <segment id="45">"</segment>
    <segment id="46">Então concordamos e</segment>
    <segment id="47">, quando exibimos pela primeira vez</segment>
    <segment id="48">, algo muito estranho aconteceu.</segment>
    <segment id="49">As pessoas aplaudiram quando Trump apareceu na tela.</segment>
    <segment id="50">Então eu disse ao meu editor ‘deixe que ele fique no filme</segment>
    <segment id="51">, é um momento para a plateia’.</segment>
    <segment id="52">Mas ele realmente</segment>
    <segment id="53">sese impôs no filme"</segment>
    <segment id="54">, disse o diretor.</segment>
    <segment id="55">Despedida de Donald TrumpMais    novamente         de   de  de  representando um</segment>
    <segment id="56">Em postagem na rede social</segment>
    <segment id="57">, Trum rebateu.</segment>
    <segment id="58">"</segment>
    <segment id="59">Nada poderia estar mais longe da verdade.</segment>
    <segment id="60">Essa participação especial ajudou a tornar o filme um sucesso</segment>
    <segment id="61">, masmas</segment>
    <segment id="62">sese eles</segment>
    <segment id="63">sese sentiram intimidados ou não me queriam</segment>
    <segment id="64">, por que me incluíram e me mantiveram lá por mais de 30 anos?</segment>
    <segment id="65">Porque eu era</segment>
    <segment id="66">, e ainda sou</segment>
    <segment id="67">, ótimo para o filme</segment>
    <segment id="68">, é por isso!</segment>
    <segment id="69">", escreveu.</segment>
    <segment id="70">"</segment>
    <segment id="71">Apenas mais um cara de Hollywood do passado em busca de publicidade rápida de Trump para si mesmo!</segment>
    <segment id="72">"</segment>
  </rst>
