  <rst>
    <segment id="1">Bob Dylan</segment>
    <segment id="2">, ganhador do Nobel de Literatura e lenda da música folk e rock</segment>
    <segment id="3">, deve publicar um novo livro em novembro</segment>
    <segment id="4">, anunciou sua editora americana</segment>
    <segment id="5">, a Simon and Schuster</segment>
    <segment id="6">, nesta terça-feira.  "</segment>
    <segment id="7">The Philosophy of Modern Song</segment>
    <segment id="8">"</segment>
    <segment id="9">, com lançamento previsto para 8 de novembro</segment>
    <segment id="10">, será a primeira publicação de Dylan em quase duas décadas</segment>
    <segment id="11">, desde o livro "Crônicas".</segment>
    <segment id="12">O livro será publicado no Brasil pela editora Companhia das Letras.</segment>
    <segment id="13">Músico e escritor Bob Dylan em apresentação em 1978</segment>
    <segment id="14">, no Pavillon de Paris</segment>
    <segment id="15">, na capital francesa - Pierre Guillaud/AFP</segment>
    <segment id="16">O poeta e artista americano</segment>
    <segment id="17">, nascido em 1941 no estado de Minnesota</segment>
    <segment id="18">, começou a escrever seu mais novo livro em 2010</segment>
    <segment id="19">, que inclui mais de 60 ensaios inspirados em artistas</segment>
    <segment id="20">comocomo Hank Williams e Nina Simone</segment>
    <segment id="21">, além de letras de suas músicas</segment>
    <segment id="22">, informou a editora.  "</segment>
    <segment id="23">O lançamento do brilhante trabalho caleidoscópico de Bob Dylan será uma celebração internacional das músicas de um dos maiores artistas de todos os tempos"</segment>
    <segment id="24">, disse o diretor da Simon e Schuster</segment>
    <segment id="25">, Jonathan Karp</segment>
    <segment id="26">, em comunicado.</segment>
    <segment id="27">O estilo do autor</segment>
    <segment id="28">, tanto em suas composições musicais quanto nas estritamente editoriais</segment>
    <segment id="29">, é marcado por entrelaçar temas</segment>
    <segment id="30">comocomo politica</segment>
    <segment id="31">, amor e ódio</segment>
    <segment id="32">, crítica social e até assuntos cotidianos do noticiário.</segment>
    <segment id="33">Para além de suas letras</segment>
    <segment id="34">, que já possuem grande valor poético por si mesmas</segment>
    <segment id="35">, Dylan lançou outros dois livros em prosa</segment>
    <segment id="36">, que estão publicados no Brasil.</segment>
    <segment id="37">"Tarântula" foi publicado pela primeira vez em 1971</segment>
    <segment id="38">, masmas desde 1966 já era lido por meio de edições underground.</segment>
    <segment id="39">Exercício delirante de prosa poética</segment>
    <segment id="40">, a obra reflete a afinidade do autor com surrealistas e beats</segment>
    <segment id="41">, justapondo "imagens díspares</segment>
    <segment id="42">, sem abrir mão da oralidade"</segment>
    <segment id="43">, avaliou Leonardo Gandolfi em crítica do livro em 2016.</segment>
    <segment id="44">Bob Dylan no documentário &amp;#039</segment>
    <segment id="45">;Rolling Thunder Revue&amp;#039</segment>
    <segment id="46">;Mais    novamente         de   de  de  representando um  "Crônicas"</segment>
    <segment id="47">, que seria inicialmente a primeira parte de uma trilogia autobiográfica não completada</segment>
    <segment id="48">, é um livro que conta momentos cruciais da vida e da obra de Bob Dylan.</segment>
    <segment id="49">Com uma narrativa confessional</segment>
    <segment id="50">, o autor retrata acontecimentos da Nova York dos anos 1960 e momentos de sua carreira</segment>
    <segment id="51">, como</segment>
    <segment id="52">como a vida levada em festas noturnas</segment>
    <segment id="53">, seus amores e amizades.</segment>
    <segment id="54">Ainda há rumores de que Dylan publique a continuação da obra.</segment>
    <segment id="55">Outra produção editorial lançada no Brasil é a antologia "Letras"</segment>
    <segment id="56">, publicada em dois volumes pela Companhia das Letras com tradução de Caetano Galindo.</segment>
    <segment id="57">Dylan surgiu na cena folk de Nova York no início dos anos 1960 e vendeu mais de 125 milhões de discos em todo o mundo.</segment>
    <segment id="58">O artista</segment>
    <segment id="59">, com 80 anos atualmente</segment>
    <segment id="60">, manteve uma intensa programação de shows</segment>
    <segment id="61">, que deve terminar em 2024.</segment>
    <segment id="62">Em 2020</segment>
    <segment id="63">, ele lançou seu 39º álbum de estúdio</segment>
    <segment id="64">, "Rough and Rowdy Ways"</segment>
    <segment id="65">, com aclamação da crítica.</segment>
    <segment id="66">Em 2016</segment>
    <segment id="67">, ganhou o prêmio Nobel de literatura por "ter criado uma nova expressão poética com a grande tradição da canção americana"</segment>
    <segment id="68">, segundo justificou a Academia Sueca.</segment>
  </rst>
</analysis>