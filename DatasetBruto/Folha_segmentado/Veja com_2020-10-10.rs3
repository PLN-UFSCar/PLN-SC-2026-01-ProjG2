  <rst>
    <segment id="1">Chega o calor e</segment>
    <segment id="2">, com ele</segment>
    <segment id="3">, os pernilongos.</segment>
    <segment id="4">Das coceira e manchas que ficam da pele depois da picada ao zumbido ao pé do ouvido durante a noite</segment>
    <segment id="5">, ou até mesmo doenças graves</segment>
    <segment id="6">comocomo a dengue ou chikungunya</segment>
    <segment id="7">, ter que conviver com esses insetos não é uma tarefa fácil.</segment>
    <segment id="8">O problema é comum nas cidades devido à poluição dos rios e canais.</segment>
    <segment id="9">Na capital</segment>
    <segment id="10">, são duas as espécies mais comuns de mosquitos: o Culex quinquefasciatus</segment>
    <segment id="11">, que provoca o incômodo de manchas e coceira</segment>
    <segment id="12">, e o Aedes aegypti</segment>
    <segment id="13">, causador da dengue</segment>
    <segment id="14">, masmas que tem características diferentes</segment>
    <segment id="15">, como</segment>
    <segment id="16">como o hábito diurno e início do ciclo de vida em água limpa.  "</segment>
    <segment id="17">Em São Paulo temos um dos maiores criadouros</segment>
    <segment id="18">, que é o rio Pinheiros</segment>
    <segment id="19">, além dos córregos e um pedaço do rio Tietê.</segment>
    <segment id="20">Por isso esse mosquito</segment>
    <segment id="21">sese adaptou bem nessas regiões"</segment>
    <segment id="22">, afirma Paulo Roberto Urbinatti</segment>
    <segment id="23">, biólogo e pesquisador da Faculdade de Saúde Pública da USP.</segment>
    <segment id="24">Até que fique adulto e saia picando as pessoas</segment>
    <segment id="25">, um pernilongo tem um ciclo de vida de 10 a 15 dias</segment>
    <segment id="26">comocomo larva nas águas poluídas.</segment>
    <segment id="27">No calor</segment>
    <segment id="28">, contudo</segment>
    <segment id="29">contudo</segment>
    <segment id="30">, esse tempo é encurtado --e as mudanças climáticas podem favorecer ainda mais a proliferação deles</segment>
    <segment id="31">, diz Urbinatti.</segment>
    <segment id="32">Como ele precisa de água com alto teor de matéria orgânica para</segment>
    <segment id="33">sese desenvolver</segment>
    <segment id="34">, a poluição é essencial.</segment>
    <segment id="35">No caso</segment>
    <segment id="36">caso do Culex</segment>
    <segment id="37">, a fêmea</segment>
    <segment id="38">, que costuma picar as pessoas em busca de sangue para desenvolver as larvas</segment>
    <segment id="39">, não transmite doenças.</segment>
    <segment id="40">Já em algumas cidades das regiões Norte e Nordeste</segment>
    <segment id="41">, pode transmitir a filariose</segment>
    <segment id="42">, que afeta os vasos linfáticos.</segment>
    <segment id="43">As áreas mais próximas a corpos</segment>
    <segment id="44">d'água poluídos são as mais afetadas pelos pernilongos</segment>
    <segment id="45">, afirma Sérgio Bocalini</segment>
    <segment id="46">, biólogo especialista em entomologia urbana e vice-presidente executivo da Aprag (Associação dos Controladores de Vetores e Pragas Urbanas).</segment>
    <segment id="47">Combate aos mosquitos - Arte Agora</segment>
    <segment id="48">São PauloMas quem mora em regiões a até 4 km dessas águas também é afetado.</segment>
    <segment id="49">"</segment>
    <segment id="50">Especialmente no calor</segment>
    <segment id="51">, com a evaporação da água</segment>
    <segment id="52">, há muitas correntes de ar ascendentes.</segment>
    <segment id="53">Como o pernilongo é leve</segment>
    <segment id="54">, isso faz com ele ganhe altura e seja empurrado para grandes distâncias.</segment>
    <segment id="55">"</segment>
    <segment id="56">Há muitos métodos para tentar minimizar o problema</segment>
    <segment id="57">, dos mais naturais</segment>
    <segment id="58">, como</segment>
    <segment id="59">como plantar ervas</segment>
    <segment id="60">, até os mais agressivos</segment>
    <segment id="61">, como</segment>
    <segment id="62">como o uso de inseticidas.</segment>
    <segment id="63">Mas nem todos</segment>
    <segment id="64">, afirma Bocalini</segment>
    <segment id="65">, são realmente eficientes.</segment>
    <segment id="66">"</segment>
    <segment id="67">É muito importante que as pessoas tenham cuidado</segment>
    <segment id="68">porque</segment>
    <segment id="69">porque</segment>
    <segment id="70">, na tentativa de resolver</segment>
    <segment id="71">, muitas pessoas buscam métodos principalmente na internet</segment>
    <segment id="72">, e acabam fazendo coisas que podem não funcionar e até trazer problema.</segment>
    <segment id="73">"</segment>
    <segment id="74">Em casa</segment>
    <segment id="75">, os métodos mais eficientes são os que impedem a entrada dos mosquitos</segment>
    <segment id="76">, como</segment>
    <segment id="77">como a instalação de telas em janelas e portas.</segment>
    <segment id="78">Para quem não tem</segment>
    <segment id="79">, a dica é fechar os acessos no fim da tarde</segment>
    <segment id="80">, o horário de pico da atividade desses mosquitos.</segment>
    <segment id="81">Poder público deve limpar córregos e rios  Inseticidas e repelentes até conseguem diminuir o problema dos pernilongos naquele momento</segment>
    <segment id="82">, masmas livrar a população desses insetos é uma missão que cabe aos gestores públicos</segment>
    <segment id="83">, com a limpeza de córregos e rios</segment>
    <segment id="84">, dizem os especialistas.</segment>
    <segment id="85">Por nota</segment>
    <segment id="86">, a Empresa Metropolitana de Águas e Energia afirma que o Programa Novo Rio Pinheiros</segment>
    <segment id="87">, iniciado em 2019 para despoluir o curso da água</segment>
    <segment id="88">, deve ser concluído em 2022.</segment>
    <segment id="89">Até lá</segment>
    <segment id="90">, são executadas ações de combate a pernilongos em apoio à Secretaria Municipal de Saúde</segment>
    <segment id="91">, com aplicação de larvicida na água</segment>
    <segment id="92">, fumacê e inseticida nas margens.</segment>
    <segment id="93">A pasta afirma que mantém uma ação conjunta com o governo do estado para controle de pernilongos nas proximidades de córregos e rios.</segment>
    <segment id="94">Segundo o órgão</segment>
    <segment id="95">, o fumacê teve início na região do rio Pinheiros em agosto e continua nas próximas semanas.</segment>
    <segment id="96">Combate ao mosquito Aedes aegypti em Higienópolis   novamente         de   de  de  representando um  COMO SE PROTEGER  EM CASA</segment>
    <segment id="97">Passar repelente (crianças pequenas exigem atenção</segment>
    <segment id="98">, já que nem todos os repelentes são apropriados para elas)</segment>
    <segment id="99">Instalar telas em janelas e portas</segment>
    <segment id="100">Colocar mosquiteiros sobre berços e</segment>
    <segment id="101">, quando possível</segment>
    <segment id="102">, camas</segment>
    <segment id="103">Passar extrato de citronela no chão (durante a limpeza) ou queimar velas com a mesma substância --ela ajuda a afastar os mosquitos   NA RUA</segment>
    <segment id="104">Passar repelente em todos os membros expostos antes de sair de casa Sempre usar roupa comprida</segment>
    <segment id="105">, chapéus e botas em áreas com mato ou áreas de reprodução de mosquitos</segment>
    <segment id="106">, como</segment>
    <segment id="107">como locais próximos a rios e lagos</segment>
    <segment id="108">Em pontos com muitos borrachudos</segment>
    <segment id="109">, vestir meias ou espalhar óleo (de cozinha ou amêndoa) nas pernas ajuda a evitar picadas</segment>
    <segment id="110">, já que esses insetos costumam atacar mais os membros inferiores</segment>
    <segment id="111">O QUE ATRAI</segment>
    <segment id="112">OS MOSQUITOS</segment>
    <segment id="113">No caso</segment>
    <segment id="114">caso de borrachudos e pernilongos</segment>
    <segment id="115">, o que mais os atrai é o cheiro das pessoas.</segment>
    <segment id="116">Por isso</segment>
    <segment id="117">, algumas são mais picadas do que outras</segment>
    <segment id="118">O cheiro do suor também pode atrair os insetos</segment>
    <segment id="119">O sangue humano é usado pelas fêmeas para maturar os ovos</segment>
    <segment id="120">A picada coça</segment>
    <segment id="121">porque</segment>
    <segment id="122">porque</segment>
    <segment id="123">, para facilitar a penetração na pele</segment>
    <segment id="124">, o mosquito libera uma proteína que lubrifica a área atingida.</segment>
    <segment id="125">Ela contém substâncias que irritam e formam inflamações</segment>
    <segment id="126">Métodos mais usados para combater o mosquito  Vela ou incenso de citronela   Eficiência: mediana</segment>
    <segment id="127">Como funciona: a essência liberada afasta o mosquito Cuidados: deve ser mantida longe de papéis e cortinas</segment>
    <segment id="128">Inseticida espiral</segment>
    <segment id="129">Eficiência: alta Como funciona: afasta os mosquitos quando queima</segment>
    <segment id="130">Cuidados: evite a fumaça e não coloque perto de cortinas ou móveis</segment>
    <segment id="131">Repelente líquido e em pastilhas na eletricidade   Eficiência: alta Como funciona: o líquido é evaporado e a pastilha é queimada</segment>
    <segment id="132">, liberando o repelente Cuidados: deixe janelas abertas</segment>
    <segment id="133">para que</segment>
    <segment id="134">para que os mosquitos saiam</segment>
    <segment id="135">Raquete   Eficiência: Baixa Como funciona: eletrocuta os mosquitos que entram em contato com o equipamento Cuidados: não deixe perto de crianças</segment>
    <segment id="136">Inseticida aerossol</segment>
    <segment id="137">Eficiência: Alta Como funciona:</segment>
    <segment id="138">Tem um princípio ativo que mata os mosquitos Cuidados: não deve ser aplicado com pessoas no ambiente</segment>
    <segment id="139">Repelente de pele   Eficiência: alta Como funciona: impede que os mosquitos</segment>
    <segment id="140">sese aproximem da pessoa que aplicou Cuidados: é muito importante comprar apenas produtos registrados na Anvisa e atentar</segment>
    <segment id="141">sese há algum ingrediente ao qual a pessoa tenha alergia</segment>
    <segment id="142">Telas e mosquiteiros   Eficiência: alta Como funciona: impedem que o pernilongo entre na casa ou que</segment>
    <segment id="143">sese aproxime da pessoa</segment>
    <segment id="144">Cuidados:</segment>
    <segment id="145">No caso</segment>
    <segment id="146">caso do mosquiteiro</segment>
    <segment id="147">, deve ficar longe do rosto da criança</segment>
    <segment id="148">para que</segment>
    <segment id="149">para que não haja risco de asfixia   Fonte: Aprag (Associação dos Controladores de Vetores e Pragas Urbanas)</segment>
    <segment id="150">;</segment>
    <segment id="151">Sociedade Brasileira de Dermatologia</segment>
  </rst>
</analysis>