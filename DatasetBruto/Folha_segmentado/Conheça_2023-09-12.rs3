  <rst>
    <segment id="1">No último domingo (10)</segment>
    <segment id="2">, o cantor Anderson Leonardo</segment>
    <segment id="3">, de 51 anos</segment>
    <segment id="4">, vocalista do grupo de pagode Molejo</segment>
    <segment id="5">, foi internado no Rio de Janeiro com sintomas de pneumonia.</segment>
    <segment id="6">Depois de ser submetido a exames mais específicos</segment>
    <segment id="7">, seu diagnóstico foi atualizado para um quadro de embolia pulmonar.</segment>
    <segment id="8">De acordo com nota da assessoria de imprensa do grupo musical</segment>
    <segment id="9">, o quadro é estável.</segment>
    <segment id="10">Sintomas da embolia pulmonar incluem dor no peito</segment>
    <segment id="11">; falta de ar e tosse repentina- Getty ImagesO quadro geralmente começa</segment>
    <segment id="12">sese há a presença de uma condição que favorece a formação de coágulos no sangue</segment>
    <segment id="13">, como</segment>
    <segment id="14">como imobilização prolongada (para pacientes acamados</segment>
    <segment id="15">, por exemplo)</segment>
    <segment id="16">, cirurgia</segment>
    <segment id="17">, lesões</segment>
    <segment id="18">, gravidez e câncer -</segment>
    <segment id="19">comocomo é o</segment>
    <segment id="20">casocaso do cantor</segment>
    <segment id="21">, que está em tratamento contra um câncer de testículo desde outubro de 2022.</segment>
    <segment id="22">Um coágulo sanguíneo em partes do corpo</segment>
    <segment id="23">comocomo as pernas pode ter consequências graves</segment>
    <segment id="24">, interrompendo o fluxo sanguíneo a ponto de gangrenar o membro e precisar de amputação.</segment>
    <segment id="25">Mas o risco à vida é mais direto quando o coágulo</segment>
    <segment id="26">sese desloca e viaja através da corrente sanguínea até chegar ao coração.</segment>
    <segment id="27">"</segment>
    <segment id="28">O sangue passa pelos pulmões para receber oxigênio antes de ir para órgãos vitais</segment>
    <segment id="29">comocomo o cérebro.</segment>
    <segment id="30">Devido ao tamanho pequeno dos vasos sanguíneos nos pulmões</segment>
    <segment id="31">, o coágulo pode ficar preso e obstruir o fluxo sanguíneo"</segment>
    <segment id="32">, descreve o pneumologista Gunther Kissmann</segment>
    <segment id="33">, especialista pela PUC-Rio.</segment>
    <segment id="34">Após o coágulo</segment>
    <segment id="35">sese alojar nos pulmões</segment>
    <segment id="36">, obstruindo o fluxo sanguíneo</segment>
    <segment id="37">, podem ocorrer diferentes complicações</segment>
    <segment id="38">, incluindo danos aos tecidos pulmonares</segment>
    <segment id="39">, redução da oxigenação do sangue</segment>
    <segment id="40">, aumento da pressão nas artérias pulmonares (hipertensão pulmonar)</segment>
    <segment id="41">, síndrome do desconforto respiratório agudo (SDRA)</segment>
    <segment id="42">, insuficiência cardíaca direita e embolia em outros órgãos</segment>
    <segment id="43">, como</segment>
    <segment id="44">como cérebro</segment>
    <segment id="45">, coração ou rins</segment>
    <segment id="46">, o que pode ser potencialmente fatal.</segment>
    <segment id="47">O risco aumenta quando existem vários coágulos</segment>
    <segment id="48">, ou o embolismo dura por muito tempo</segment>
    <segment id="49">, causando a embolia maciça ou infarto pulmonar (quando parte do tecido pulmonar não recebe fluxo de sangue e oxigênio suficientes e parece estar morto em exames de imagem).</segment>
    <segment id="50">De acordo com o médico</segment>
    <segment id="51">, além do coágulo sanguíneo</segment>
    <segment id="52">, em casos mais raros</segment>
    <segment id="53">, gordura e fragmento de tumores também podem causar embolia pulmonar.</segment>
    <segment id="54">Sintomas e diagnóstico</segment>
    <segment id="55">Os sintomas da embolia pulmonar incluem:</segment>
    <segment id="56">Dor no peito</segment>
    <segment id="57">;</segment>
    <segment id="58">Falta de ar</segment>
    <segment id="59">;</segment>
    <segment id="60">Tosse repentina (com possibilidade de expectorar sangue)</segment>
    <segment id="61">;</segment>
    <segment id="62">Sudorese</segment>
    <segment id="63">; Tontura</segment>
    <segment id="64">; Síncope (menos comum)</segment>
    <segment id="65">;</segment>
    <segment id="66">De acordo com o médico Flávio Arbex</segment>
    <segment id="67">, o primeiro sinal costuma ser a falta de ar.</segment>
    <segment id="68">"</segment>
    <segment id="69">Acontece de uma hora para outra.</segment>
    <segment id="70">A pessoa pode estar fazendo uma atividade rotineira</segment>
    <segment id="71">, cozinhando</segment>
    <segment id="72">, por exemplo</segment>
    <segment id="73">, e não consegue puxar o ar"</segment>
    <segment id="74">, explica ele</segment>
    <segment id="75">, que é doutor em pneumologia pela Universidade Federal de São Paulo - Escola Paulista de Medicina (Unifesp/EPM).</segment>
    <segment id="76">Nesses casos</segment>
    <segment id="77">, alerta Arbex</segment>
    <segment id="78">, o melhor é procurar ajuda imediatamente para conseguir tratamento rápido e evitar morte ou agravamento do quadro.</segment>
    <segment id="79">O diagnóstico definitivo da tromboembolia pulmonar é realizado por meio de exames de imagem</segment>
    <segment id="80">, mais frequentemente a angiografia pulmonar por tomografia computadorizada.</segment>
    <segment id="81">Em centros mais modernos</segment>
    <segment id="82">, algoritmos de diagnóstico que levam em consideração a probabilidade de tromboembolia pulmonar também podem ser aplicados para otimizar o uso de exames de imagem.  Tratamento e prevenção contra trombose pulmonar</segment>
    <segment id="83">O tratamento</segment>
    <segment id="84">, basicamente</segment>
    <segment id="85">, consiste no uso de anticoagulantes.</segment>
    <segment id="86">Portanto</segment>
    <segment id="87">, usamos medicamentos popularmente conhecidos por afinar o sangue.</segment>
    <segment id="88">Isso ajuda a evitar a formação de novos trombos e permite que o nosso próprio corpo absorva os trombos já existentes.</segment>
    <segment id="89">O uso de anticoagulantes pode variar de três a seis meses ou</segment>
    <segment id="90">, em alguns casos</segment>
    <segment id="91">, por tempo indeterminado</segment>
    <segment id="92">, dependendo dos fatores de risco e das causas.</segment>
    <segment id="93">Quanto à prevenção</segment>
    <segment id="94">, segundo os médicos</segment>
    <segment id="95">, as orientações também vão depender da história clínica do paciente.</segment>
    <segment id="96">Por exemplo</segment>
    <segment id="97">, após cirurgias</segment>
    <segment id="98">, é comum orientar o uso de meias elásticas e anticoagulantes profiláticos para prevenir essa condição.</segment>
    <segment id="99">Imagens do cantor Anderson LeonardoMais    novamente         de   de  de  representando um  Durante viagens aéreas</segment>
    <segment id="100">, é recomendado que o paciente</segment>
    <segment id="101">sese movimente</segment>
    <segment id="102">, tente ficar em pé e utilize meias elásticas</segment>
    <segment id="103">, além de evitar o consumo excessivo de bebidas alcoólicas.</segment>
    <segment id="104">"</segment>
    <segment id="105">Em casos específicos</segment>
    <segment id="106">, como</segment>
    <segment id="107">como quando os pacientes têm doenças genéticas</segment>
    <segment id="108">, o uso de anticoagulantes.</segment>
    <segment id="109">Precisamos</segment>
    <segment id="110">, portanto</segment>
    <segment id="111">, olhar para o paciente de forma individualizada</segment>
    <segment id="112">, levando em consideração esses fatores"</segment>
    <segment id="113">, afirma Arbex.</segment>
    <segment id="114">Kissmann</segment>
    <segment id="115">, especialista pela PUC-Rio</segment>
    <segment id="116">, complementa dizendo que recomendações gerais incluem não fumar</segment>
    <segment id="117">, manter-</segment>
    <segment id="118">sese ativo fisicamente (já que a imobilidade favorece formação de coágulos) e evitar sobrepeso ou obesidade [condições que alteram a circulação sanguínea].</segment>
    <segment id="119">Quanto às sequelas</segment>
    <segment id="120">, em caso</segment>
    <segment id="121">caso de um grande infarto</segment>
    <segment id="122">, pode haver dor por algum tempo.</segment>
    <segment id="123">Em 4% dos casos</segment>
    <segment id="124">, a doença pode</segment>
    <segment id="125">sese tornar crônica</segment>
    <segment id="126">, resultando em uma condição conhecida</segment>
    <segment id="127">comocomo embolia pulmonar crônica.</segment>
    <segment id="128">"</segment>
    <segment id="129">Nesses casos</segment>
    <segment id="130">, o paciente precisará continuar usando anticoagulantes por um período prolongado e avaliar</segment>
    <segment id="131">sese há repercussões cardíacas</segment>
    <segment id="132">, especialmente no lado direito do coração</segment>
    <segment id="133">, que possam exigir intervenção médica"</segment>
    <segment id="134">, conclui Arbex.</segment>
    <segment id="135">Este texto foi publicado aqui</segment>
  </rst>
</analysis>