  <rst>
    <segment id="1">Um vigilante de 59 anos foi preso sob a suspeita de matar a tiros um morador de rua</segment>
    <segment id="2">, após ambos supostamente discutirem</segment>
    <segment id="3">, por volta das 19h50 desta quinta-feira (13)</segment>
    <segment id="4">, em Santo André (ABC).</segment>
    <segment id="5">A arma do crime ainda não foi localizada pela polícia.</segment>
    <segment id="6">O vigilante</segment>
    <segment id="7">, segundo a Polícia Civil</segment>
    <segment id="8">, já havia sido preso em outra ocasião por homicídio.</segment>
    <segment id="9">O Agora não conseguiu contato com a defesa dele até a publicação desta reportagem.</segment>
    <segment id="10">Imagens de uma câmera de monitoramento</segment>
    <segment id="11">, já apreendidas pela polícia</segment>
    <segment id="12">, mostram o vigilante</segment>
    <segment id="13">sese aproximando do morador de rua em uma moto vermelha.</segment>
    <segment id="14">Em seguida</segment>
    <segment id="15">, os dois começam a conversar.</segment>
    <segment id="16">A vítima</segment>
    <segment id="17">, que estava sem documentos</segment>
    <segment id="18">, não teve sua identidade confirmada pela polícia.</segment>
    <segment id="19">Em uma primeiro momento</segment>
    <segment id="20">, de acordo com as imagens</segment>
    <segment id="21">, a vítima aparentemente pega objetos pessoais.</segment>
    <segment id="22">Porém, em seguida</segment>
    <segment id="23">, retorna e confronta o suspeito</segment>
    <segment id="24">, que saca uma arma</segment>
    <segment id="25">, atira e foge em seguida.</segment>
    <segment id="26">Guardas-civis municipais faziam ronda pela região e viram a dupla conversando</segment>
    <segment id="27">, pouco antes do crime.</segment>
    <segment id="28">Em depoimento na delegacia</segment>
    <segment id="29">, os GCMs afirmam ter ouvido ao menos três disparos e</segment>
    <segment id="30">, por isso</segment>
    <segment id="31">, retornaram ao local</segment>
    <segment id="32">, quando viram a vítima caída no chão.</segment>
    <segment id="33">O Samu (Serviço de Atendimento Móvel de Urgência) foi acionado e constatou a morte do morador de rua</segment>
    <segment id="34">, ainda no local do crime.</segment>
    <segment id="35">Notificados sobre o homicídio</segment>
    <segment id="36">, investigadores do 6º DP de Santo André localizaram uma câmera que registrou o crime.</segment>
    <segment id="37">A partir das imagens</segment>
    <segment id="38">, começaram a procurar o suspeito pela região e</segment>
    <segment id="39">, duas horas depois</segment>
    <segment id="40">, encontraram o vigilante em uma praça</segment>
    <segment id="41">, a poucos metros de distância do local do crime.</segment>
    <segment id="42">Ao ser abordado</segment>
    <segment id="43">, segundo a polícia</segment>
    <segment id="44">, o homem afirmou conhecer a vítima e que "era o motociclista que aparecia nas imagens"</segment>
    <segment id="45">, segundo trecho de boletim de ocorrência</segment>
    <segment id="46">, no qual consta que a arma não havia sido localizada.</segment>
    <segment id="47">O vigilante foi indiciado por homicídio simples.</segment>
    <segment id="48">Em audiência de custódia nesta sexta-feira (14)</segment>
    <segment id="49">, o TJ-SP (Tribunal de Justiça de São Paulo) converteu a prisão em flagrante do suspeito para preventiva</segment>
    <segment id="50">, ou seja</segment>
    <segment id="51">, por tempo indeterminado.</segment>
    <segment id="52">Entre janeiro e março deste ano</segment>
    <segment id="53">, ao menos nove pessoas foram assassinadas em Santo André</segment>
    <segment id="54">, segundo a SSP (Secretaria da Segurança Pública).</segment>
    <segment id="55">O 6º DP</segment>
    <segment id="56">, que investiga a morte do morador de rua</segment>
    <segment id="57">, computou um terço do total de vítimas de homicídio no período.</segment>
    <segment id="58">Moradores de rua reclamam de construção de canteiros para retirá-los de praça Mais    novamente         de   de  de  representando um</segment>
  </rst>
</analysis>