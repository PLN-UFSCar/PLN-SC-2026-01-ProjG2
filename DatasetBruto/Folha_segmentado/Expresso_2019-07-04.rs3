  <rst>
    <segment id="1">Homenageado na 17ª Flip (Festa Literária Internacional de Paraty)</segment>
    <segment id="2">, Euclides da Cunha e sua obra "</segment>
    <segment id="3">Os Sertões" são o tema do novo episódio do Expresso Ilustrada.</segment>
    <segment id="4">Para falar do assunto</segment>
    <segment id="5">, o podcast recebe Fernanda Diamant</segment>
    <segment id="6">, curadora desta edição da Flip</segment>
    <segment id="7">, que acontece entre 10 e 14 de julho</segment>
    <segment id="8">, em Paraty.</segment>
    <segment id="9">Além de dar dicas práticas para quem quer ler "</segment>
    <segment id="10">Os Sertões"</segment>
    <segment id="11">, masmas acha que o livro é difícil demais</segment>
    <segment id="12">, Diamant conta</segment>
    <segment id="13">comocomo concebeu a programação e cita alguns destaques da festa literária.</segment>
    <segment id="14">A apresentação é de Maurício Meireles</segment>
    <segment id="15">, repórter e colunista de literatura da Folha</segment>
    <segment id="16">, e Lívia Sampaio</segment>
    <segment id="17">, editora-adjunta de Cultura do jornal</segment>
    <segment id="18">, com edição do Renan Sukevicius.</segment>
    <segment id="19">Os episódios do Expresso Ilustrada são publicados toda quinta-feira</segment>
    <segment id="20">, às 16h.</segment>
    <segment id="21">O podcast discute os principais assuntos da música</segment>
    <segment id="22">, cinema</segment>
    <segment id="23">, literatura</segment>
    <segment id="24">, moda</segment>
    <segment id="25">, teatro</segment>
    <segment id="26">, artes plásticas e televisão.</segment>
    <segment id="27">O feed RSS é https://folhaexpressoilustrada.libsyn.com/rss.</segment>
    <segment id="28">O PODCAST ESTÁ DISPONÍVEL</segment>
    <segment id="29">EM TODAS AS PLATAFORMAS DE STREAMING.</segment>
    <segment id="30">AQUI ESTÃO ALGUMAS DELAS:</segment>
    <segment id="31">Spotify  iTunes  Deezer  Google Podcasts  Castbox  Stitcher</segment>
    <segment id="32">RadioPublic​</segment>
  </rst>
