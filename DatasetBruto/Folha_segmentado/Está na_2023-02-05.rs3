  <rst>
    <segment id="1">O empresário Abilio Diniz defendeu em evento de João Doria</segment>
    <segment id="2">, neste fim de semana</segment>
    <segment id="3">, em Lisboa</segment>
    <segment id="4">, que está na hora de acabar com a polarização.</segment>
    <segment id="5">"</segment>
    <segment id="6">É o momento de a gente procurar encerrar isso [polarização].</segment>
    <segment id="7">É preciso haver união.</segment>
    <segment id="8">Todo governo tem oposição</segment>
    <segment id="9">, masmas precisa ser oposição em relação às coisas em que</segment>
    <segment id="10">sese pense que o governo não está fazendo certo.</segment>
    <segment id="11">Fazer oposição em tudo impede o país de crescer"</segment>
    <segment id="12">, disse o empresário na conferência do Lide.</segment>
    <segment id="13">Painel S.A.Receba no seu email as informações exclusivas da coluna</segment>
    <segment id="14">Painel S.A.Carregando...</segment>
    <segment id="15">Abilio também disse que "ainda há um certo receio do BC para baixar juros</segment>
    <segment id="16">, masmas inflação está dominada".</segment>
    <segment id="17">Ele pediu segurança política e jurídica.</segment>
    <segment id="18">"</segment>
    <segment id="19">Para que as pessoas cresçam</segment>
    <segment id="20">, o Brasil precisa crescer.</segment>
    <segment id="21">Nessa parte</segment>
    <segment id="22">, o governo precisa ajudar.</segment>
    <segment id="23">Precisa promover investimento público e</segment>
    <segment id="24">, principalmente</segment>
    <segment id="25">, privado.</segment>
    <segment id="26">Existe muita poupança interna e externa para ajudar o país a crescer.</segment>
    <segment id="27">É preciso de segurança política e jurídica</segment>
    <segment id="28">para que</segment>
    <segment id="29">para que os investimentos venham"</segment>
    <segment id="30">, afirmou.  Joana Cunha com Paulo Ricardo Martins e Diego Felix  Abilio Diniz</segment>
    <segment id="31">, que é membro do conselho de administração do Carrefour</segment>
    <segment id="32">, na sede da Península Participações</segment>
    <segment id="33">, na avenida Paulista</segment>
    <segment id="34">, em São Paulo - Bruno Santos - 1.set.22/Folhapress</segment>
