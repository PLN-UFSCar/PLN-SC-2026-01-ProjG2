    <segment id="295">MARCELO BLANCO DA COSTA – Ex-assessor do Departamento de Logística do Ministério da Saúde e intermediador nas tratativas da Davati - art. 333</segment>
    <segment id="296">, caput</segment>
    <segment id="297">, do Código Penal (corrupção ativa)</segment>
    <segment id="298">;    15)</segment>
    <segment id="299">EMANUELA</segment>
    <segment id="300">BATISTA DE SOUZA MEDRADES – Diretora-Executiva e responsável técnica farmacêutica da empresa Precisa - arts.</segment>
    <segment id="301">299, caput (falsidade ideológica)</segment>
