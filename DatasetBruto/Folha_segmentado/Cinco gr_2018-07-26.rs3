  <rst>
    <segment id="1">Visitar obras grandiosas da engenharia também é uma oportunidade para aprender de que forma elas foram feitas e</segment>
    <segment id="2">comocomo funcionam.</segment>
    <segment id="3">Confira cinco construções imponentes em áreas diversas</segment>
    <segment id="4">, nas Américas</segment>
    <segment id="5">, na Europa e no Oriente Médio.        ​Itaipu Binacional (Foz do Iguaçu</segment>
    <segment id="6">, Brasil)</segment>
    <segment id="7">A usina hidrelétrica que o Brasil divide com o Paraguai foi construída com concreto suficiente para erguer 210 estádios do Maracanã e sua barragem chega a 196 metros de altura.</segment>
    <segment id="8">Os passeios guiados custam a partir de R$ 38.</segment>
    <segment id="9">Saiba mais aqui.</segment>
    <segment id="10">Canal do Panamá (Cidade do Panamá)</segment>
    <segment id="11">Liga os oceanos</segment>
    <segment id="12">Atlântico e Pacífico</segment>
    <segment id="13">, tem 77 quilômetros de extensão e foi aberto para navios em 1914.</segment>
    <segment id="14">A entrada pelo centro de visitantes de Miraflores custa 15 balboas (R$ 56).</segment>
    <segment id="15">Saiba mais aqui.</segment>
    <segment id="16">Hoover Dam (Boulder City</segment>
    <segment id="17">, Estados Unidos)</segment>
    <segment id="18">A usina hidrelétrica foi inaugurada em 1936</segment>
    <segment id="19">, em Nevada.</segment>
    <segment id="20">Fornece energia para três estados americanos e recebe cerca de 1 milhão de visitantes ao ano.</segment>
    <segment id="21">A entrada custa a partir de US$ 15 (R$ 56).</segment>
    <segment id="22">Saiba mais aqui.</segment>
    <segment id="23">Eurotúnel (Inglaterra e França)</segment>
    <segment id="24">O túnel que liga o Reino Unido à Europa continental foi pensado em 1802</segment>
    <segment id="25">, masmas aberto em 1994.</segment>
    <segment id="26">Dos 50 quilômetros de extensão</segment>
    <segment id="27">, 38 são por baixo do mar.</segment>
    <segment id="28">Os trens Eurostar</segment>
    <segment id="29">, de passageiros</segment>
    <segment id="30">, e Le Shuttle</segment>
    <segment id="31">, para veículos</segment>
    <segment id="32">, passam por ele  Palm Islands (Dubai</segment>
    <segment id="33">, Emirados Árabes Unidos)</segment>
    <segment id="34">O arquipélago com três ilhas artificiais em forma de palmeira foi construído com areia retirada do mar.</segment>
    <segment id="35">A ilha principal</segment>
    <segment id="36">, Palm Jumeirah</segment>
    <segment id="37">, foi feita entre 2001 e 2006.</segment>
    <segment id="38">Há lojas</segment>
    <segment id="39">, casas e hotéis</segment>
    <segment id="40">, como</segment>
    <segment id="41">como as redes de luxo Anantara e Waldorf Astoria</segment>
    <segment id="42">Grandes obras da engenharia para conhecer   novamente         de   de  de  representando um</segment>
  </rst>
