  <rst>
    <segment id="1">Pelé enfrentava um câncer de intestino desde 31 de agosto de 2021</segment>
    <segment id="2">, quando teve diagnosticado um tumor no cólon (intestino grosso) durante exames de rotina</segment>
    <segment id="3">, sendo operado quatro dias depois.</segment>
    <segment id="4">Na última internação</segment>
    <segment id="5">, dia 29 de novembro</segment>
    <segment id="6">, o craque chegou ao hospital com um quadro de inchaço generalizado e uma insuficiência cardíaca descompensada</segment>
    <segment id="7">, conforme revelou a ESPN.</segment>
    <segment id="8">A Folha confirmou essas informações.</segment>
    <segment id="9">Retrato de Pelé</segment>
    <segment id="10">,no museu que leva seu nome</segment>
    <segment id="11">, em Santos - Bruno Santos - 28.nov.2018/ FolhapressDias antes de ir para o hospital</segment>
    <segment id="12">, Pelé havia testado positivo para Covid-19</segment>
    <segment id="13">, segundo a família revelou.</segment>
    <segment id="14">Em boletins médicos divulgados nos dias seguintes à internação</segment>
    <segment id="15">, o Einstein informou que Pelé teve diagnosticada uma infecção respiratória</segment>
    <segment id="16">, após internação para uma reavaliação da terapia quimioterápica do tumor de cólon</segment>
    <segment id="17">, iniciada logo após a cirurgia</segment>
    <segment id="18">, em setembro de 2021.</segment>
    <segment id="19">A Folha revelou</segment>
    <segment id="20">, porém</segment>
    <segment id="21">porém, que o Rei já estava sob cuidados paliativos.</segment>
    <segment id="22">Como o corpo não respondia mais à quimioterapia</segment>
    <segment id="23">, o tratamento foi suspenso</segment>
    <segment id="24">, e Pelé seguiu recebendo medidas de conforto</segment>
    <segment id="25">, para aliviar a dor e a falta de ar</segment>
    <segment id="26">, por exemplo</segment>
    <segment id="27">, sem ser submetido a terapias invasivas</segment>
    <segment id="28">, como</segment>
    <segment id="29">como a intubação.</segment>
    <segment id="30">A revelação levou a uma série de homenagens ao ex-camisa 10 da seleção ao redor do mundo</segment>
    <segment id="31">, com figuras do futebol e de fora dele mandando mensagens de apoio ao ídolo.</segment>
    <segment id="32">O entorno de Pelé</segment>
    <segment id="33">, porém</segment>
    <segment id="34">porém, sempre tentou manter o tom otimista.</segment>
    <segment id="35">A situação mudou no dia 21 de dezembro</segment>
    <segment id="36">, quando o próprio hospital informou em nota que o câncer</segment>
    <segment id="37">, de fato</segment>
    <segment id="38">, havia progredido e que o Rei precisava de cuidados no coração e nos rins.</segment>
    <segment id="39">A Folha apurou que desde o dia 21</segment>
    <segment id="40">, Pelé estava com dieta zero</segment>
    <segment id="41">porque</segment>
    <segment id="42">porque os tumores no intestino</segment>
    <segment id="43">, inoperáveis</segment>
    <segment id="44">, passaram a impedir que os alimentos e líquidos percorressem o trato gastrointestinal.</segment>
    <segment id="45">Ele continuou recebendo soro e oxigenação para manter a saturação.</segment>
    <segment id="46">No sábado (24)</segment>
    <segment id="47">, véspera de Natal</segment>
    <segment id="48">, com a piora da falta de ar</segment>
    <segment id="49">, a sedação foi aumentada e havia prognóstico de morte iminente.</segment>
    <segment id="50">Cercado pelos filhos</segment>
    <segment id="51">, Pelé morreu nesta quinta (29).</segment>
    <segment id="52">A evolução da doença  Desde que operou o tumor de cólon</segment>
    <segment id="53">, em 2021</segment>
    <segment id="54">, Pelé passou por várias internações no Einstein e foi levado algumas vezes para a UTI (Unidade de Terapia Intensiva)</segment>
    <segment id="55">, por instabilidade respiratória.</segment>
    <segment id="56">Em janeiro de 2022</segment>
    <segment id="57">, ele teve metástases diagnosticadas em uma outra região do intestino</segment>
    <segment id="58">, no pulmão e no fígado.</segment>
    <segment id="59">Em fevereiro</segment>
    <segment id="60">, quando retornou ao hospital para mais sessões de quimioterapia</segment>
    <segment id="61">, precisou prolongar sua estadia após os médicos identificarem uma infecção urinária.</segment>
    <segment id="62">Além do câncer</segment>
    <segment id="63">, o atleta sofria com sequelas de três cirurgias realizadas nos últimos anos.</segment>
    <segment id="64">Uma para colocação de prótese no quadril e outras duas para corrigi-la.</segment>
    <segment id="65">Também sentia dores no joelho</segment>
    <segment id="66">, problemas que dificultavam sua locomoção.</segment>
    <segment id="67">Fatores de risco para o câncerMais    novamente         de   de  de  representando um  Entenda o câncer de cólon</segment>
    <segment id="68">O câncer de cólon é um dos tumores mais comuns na população brasileira.</segment>
    <segment id="69">Estimativa do Inca (Instituto Nacional de Câncer) aponta que</segment>
    <segment id="70">, neste ano</segment>
    <segment id="71">, o Brasil deve registrar 20.520 casos de câncer de cólon e reto em homens e 20.470 em mulheres</segment>
    <segment id="72">, e esses números devem subir em 2023.</segment>
    <segment id="73">No próximo ano</segment>
    <segment id="74">, a projeção do instituto indica que o país terá 45.630 novos casos de câncer.</segment>
    <segment id="75">Segundo o Inca</segment>
    <segment id="76">, esse tipo de tumor quase sempre</segment>
    <segment id="77">sese desenvolve a partir de pólipos</segment>
    <segment id="78">, lesões benignas que crescem na parede do intestino.</segment>
    <segment id="79">Sabe-se</segment>
    <segment id="80">se que ele é mais frequente em pessoas que consomem carne vermelha em excesso</segment>
    <segment id="81">, têm uma alimentação pobre em fibras</segment>
    <segment id="82">, são fumantes ou consomem bebida alcoólica.</segment>
    <segment id="83">Entre 10% e 15% dos casos têm uma origem familiar.</segment>
    <segment id="84">No restante</segment>
    <segment id="85">, a dieta e o estilo de vida podem ser fatores que contribuem para a doença.</segment>
    <segment id="86">LEIA MAIS SOBRE PELÉCâncer de Pelé progrediu</segment>
    <segment id="87">, e tratamento não surtiu efeitoPelé</segment>
    <segment id="88">sese revelou ao mundo aos 17 anos</segment>
    <segment id="89">, na Copa de 1958Preservado pela família</segment>
    <segment id="90">, Edson manteve a fé por saber que Pelé é imortalPelé só foi Pelé</segment>
    <segment id="91">porque</segment>
    <segment id="92">porque antes existiu o menino EdsonPelé fez história com gol 1.001</segment>
    <segment id="93">, não com o 1.000</segment>
    <segment id="94">, descobriu a Folha em 1995Pelé foi de estrela a deus do futebol na Copa de 1970Um acróstico para PeléPelé sempre foi referência para qualquer comparaçãoPelé e Santos dominaram o mundo em 1962 e 1963Pelé ficou mais próximo dos filhos com o passar dos anosEmbaixador da &amp;#</segment>
    <segment id="95">039;marca Brasil&amp;#039</segment>
    <segment id="96">;, Pelé faturou menos do que poderiaPelé foi astro no futebol</segment>
    <segment id="97">, masmas coadjuvante no cinemaAntes de a bola chegar</segment>
    <segment id="98">, pelo olhar</segment>
    <segment id="99">,</segment>
    <segment id="100">Pelé já me dizia o que pretendia fazerPelé faturou com comerciais até o fim da vidaPelé versão</segment>
    <segment id="101">Nostradamus fez previsões furadas que viraram piadaEm &amp;#039</segment>
    <segment id="102">;Pelépolis&amp;#039</segment>
    <segment id="103">;, todo morador tem uma história com o ReiAlckmin diz que Pelé era um atleta completo e lamenta morteTrês Corações e Santos guardam relíquias de PeléPelé foi personagem cercado de mitos e histórias inusitadasMito de que Santos parou guerra na África foi contestado após 50 anosPresidente da CBF promete &amp;#</segment>
