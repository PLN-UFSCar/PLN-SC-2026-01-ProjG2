  <rst>
    <segment id="1">O longa “Marighella”</segment>
    <segment id="2">, dirigido por Wagner Moura</segment>
    <segment id="3">, ganhará uma exibição popular no assentamento do MST (Movimento dos Trabalhadores Rurais Sem Terra)</segment>
    <segment id="4">Jacy Rocha</segment>
    <segment id="5">, em Prado</segment>
    <segment id="6">, na Bahia</segment>
    <segment id="7">, no dia 6 de novembro.</segment>
    <segment id="8">EU VOU</segment>
    <segment id="9">Participarão os atores Bruno Gagliasso</segment>
    <segment id="10">, Henrique Vieira e José de Abreu</segment>
    <segment id="11">, os familiares do líder comunista baiano Maria e Carlinhos Marighella e o dirigente do MST João Pedro Stedile.</segment>
    <segment id="12">A cineasta Tata Amaral e os atores Herson Capri e Pally Siqueira também confirmaram presença no evento.</segment>
    <segment id="13">TERRA</segment>
    <segment id="14">O assentamento Jacy Rocha tem três mil hectares</segment>
    <segment id="15">, e mais de 200 famílias desenvolvem atividades agroecológicas relacionadas a bovinocultura leiteira</segment>
    <segment id="16">, horta</segment>
    <segment id="17">, café</segment>
    <segment id="18">, pimenta do reino</segment>
    <segment id="19">, urucum</segment>
    <segment id="20">, piscicultura</segment>
    <segment id="21">, cacau e pequenos animais.</segment>
    <segment id="22">Bastidores do filme sobre Carlos MarighellaMais    novamente         de   de  de  representando um    FAMOSOS NAS REDES</segment>
    <segment id="23">Famosos nas redesMais</segment>
    <segment id="24">novamente         de   de  de  representando um  com LÍGIA MESQUITA</segment>
    <segment id="25">, VICTORIA AZEVEDO</segment>
    <segment id="26">, BIANKA VIEIRA e MANOELLA SMITH</segment>
  </rst>
