  <rst>
    <segment id="1">Esta é a edição da Maratonar</segment>
    <segment id="2">, a newsletter da Folha que ajuda você a</segment>
    <segment id="3">sese achar no meio de tantas opções de séries e filmes no streaming.</segment>
    <segment id="4">Quer recebê-la todas as sextas no seu email?</segment>
    <segment id="5">Inscreva-</segment>
    <segment id="6">sese abaixo.</segment>
    <segment id="7">MaratonarUm guia com dicas de filmes e séries para assistir no streamingCarregando...</segment>
    <segment id="8">No dia 14 de fevereiro</segment>
    <segment id="9">, as redes sociais</segment>
    <segment id="10">sese enchem de casais comemorando o Valentine’s Day– que não é o "nosso"</segment>
    <segment id="11">Dia dos Namorados</segment>
    <segment id="12">,</segment>
    <segment id="13">aquele inventado pelo pai do João Doria para apimentar o comércio no gélido mês de junho no Brasil.</segment>
    <segment id="14">Para acompanhar o momento celebratório</segment>
    <segment id="15">, a Netflix lança nesta sexta (10) a nova comédia romântica "</segment>
    <segment id="16">Na Sua Casa ou Na Minha"</segment>
    <segment id="17">, estrelada por Reese Witherspoon e Ashton Kutcher.</segment>
    <segment id="18">Tem muita opção de filmes e séries sobre o amor no streaming.</segment>
    <segment id="19">Abaixo</segment>
    <segment id="20">, seleciono algumas dependendo do que você quiser…  Reese Witherspoon e Ashton Kutcher</segment>
    <segment id="21">comocomo Debbie e Peter em &amp;quot</segment>
    <segment id="22">;Na</segment>
    <segment id="23">Sua Casa ou na Minha?&amp;quot</segment>
    <segment id="24">; - Divulgação/NetflixFILMES</segment>
    <segment id="25">Se você quer ver um casal mais velho...</segment>
    <segment id="26">"</segment>
    <segment id="27">À Procura do Amor"  Eva (Julia Louis-Dreyfus</segment>
    <segment id="28">, em uma de suas poucas incursões no cinema)</segment>
    <segment id="29">, divorciada há um bom tempo</segment>
    <segment id="30">, resolve voltar a namorar.</segment>
    <segment id="31">Albert (James Gandolfini)</segment>
    <segment id="32">, candidato à vaga</segment>
    <segment id="33">, causa uma primeira impressão ruim</segment>
    <segment id="34">, masmas logo a desfaz.</segment>
    <segment id="35">O problema surge mesmo é nas impressões da nova amiga de Eva</segment>
    <segment id="36">, Marianne (Catherine Keener)</segment>
    <segment id="37">, que é também ex-mulher de Albert.</segment>
    <segment id="38">Disponível na Star+ (93 min.)</segment>
    <segment id="39">Julia Louis-Dreyfus é uma premiada atriz de comédia</segment>
    <segment id="40">, vencedora do Emmy de melhor atriz nessa categoria pela série &amp;#039</segment>
    <segment id="41">;Veep&amp;#039</segment>
    <segment id="42">;, em 2017 - Lucy Nicholson/Reuters   Se quer morrer de charme...  "</segment>
    <segment id="43">Dormindo com as Outras Pessoas"</segment>
    <segment id="44">Minha sugestão favorita desta lista</segment>
    <segment id="45">, por ser estrelada por um par de atores com mais química que todos os demais.</segment>
    <segment id="46">Laney (Alison Brie) e Jake (Jason Sudeikis) perderam a virgindade juntos na faculdade</segment>
    <segment id="47">, masmas</segment>
    <segment id="48">sese afastaram.</segment>
    <segment id="49">Doze anos depois</segment>
    <segment id="50">, sese reencontram numa reunião para dependentes de amor e sexo</segment>
    <segment id="51">, retomam a amizade e descobrem que talvez sejam a solução um para os problemas do outro.</segment>
    <segment id="52">E tem um dos melhores usos de "Modern Love"</segment>
    <segment id="53">, de David Bowie.</segment>
    <segment id="54">Disponível no PlutoTV</segment>
    <segment id="55">, com comerciais (101 min.</segment>
    <segment id="56">)  Se quer um casal não hétero...  "Fire Island: Orgulho e Sedução"</segment>
    <segment id="57">Como o título sugere</segment>
    <segment id="58">, é uma adaptação de "Orgulho e Preconceito"</segment>
    <segment id="59">, de Jane Austen.</segment>
    <segment id="60">Em vez das cinco irmãs</segment>
    <segment id="61">Bennet</segment>
    <segment id="62">, temos cinco melhores amigos —liderados por Noah (Joel Kim Booster)</segment>
    <segment id="63">, a "Jane"</segment>
    <segment id="64">, e Howie (Bowen Yang)</segment>
    <segment id="65">, a "Elizabeth".</segment>
    <segment id="66">No lugar das verdejantes propriedades do interior inglês</segment>
    <segment id="67">, temos a bombante Fire Island</segment>
    <segment id="68">, uma ilha na costa do nordeste americano onde a comunidade LGBTQIA+</segment>
    <segment id="69">sese reúne no verão para curtir baladas</segment>
    <segment id="70">, drogas</segment>
    <segment id="71">, festas na praia</segment>
    <segment id="72">, e, no</segment>
    <segment id="73">casocaso dos nossos heróis</segment>
    <segment id="74">, para encontrar o seu senhor Darcy.</segment>
    <segment id="75">Disponível na Star+ (105 min.)</segment>
    <segment id="76">Imagens do filme Fire IslandMais    novamente         de   de  de  representando um  Se quer amor de amigo...  "</segment>
    <segment id="77">Juntos</segment>
    <segment id="78">, Mas Separados"</segment>
    <segment id="79">Matt (Ed Helms) está cansado de esperar: depois do fim de seu casamento</segment>
    <segment id="80">, decide ter um filho sozinho.</segment>
    <segment id="81">Por meio de uma agência</segment>
    <segment id="82">, escolhe uma barriga de aluguel</segment>
    <segment id="83">, Anna (Patti Harrison)</segment>
    <segment id="84">, com quem desenvolve uma relação enquanto espera a chegada do bebê Abajur (não</segment>
    <segment id="85">sese preocupe</segment>
    <segment id="86">, é só um apelidinho neutro até a hora do nascimento).</segment>
    <segment id="87">No meio tempo</segment>
    <segment id="88">, Anna tenta pôr a vida em ordem e Matt</segment>
    <segment id="89">sese prepara para encarar a paternidade.</segment>
    <segment id="90">Somos todos treinados para esperar que algo aconteça entre os dois</segment>
    <segment id="91">, masmas esta não é uma comédia romântica típica: a amizade é o romance.  Disponível na HBO Max (90 min.)</segment>
    <segment id="92">Se quer uma pitadinha de sci-fi...  "</segment>
    <segment id="93">O Homem Ideal"</segment>
    <segment id="94">Em troca de financiamento para seu projeto de pesquisa</segment>
    <segment id="95">, Alma (Maren Eggert) aceita participar da avaliação ética de um novo produto: um androide feito sob medida para ser o par perfeito de quem o adquire —Tom (Dan Stevens</segment>
    <segment id="96">, elevando o primo Matthew de "Downton Abbey" à enésima potência)</segment>
    <segment id="97">, no caso</segment>
    <segment id="98">caso.</segment>
    <segment id="99">Serão os dilemas éticos maiores que a atração entre os dois?</segment>
    <segment id="100">Será possível um robô amar?</segment>
    <segment id="101">Será que ele sonha com ovelhas elétricas?</segment>
    <segment id="102">Disponível no Prime Video (108 min.)  Se quer a receita clássica...</segment>
    <segment id="103">"</segment>
    <segment id="104">Será Que?</segment>
    <segment id="105">"</segment>
    <segment id="106">O primeiro desenho animado que invade a tela pode suscitar do espectador um "oh</segment>
    <segment id="107">, não"</segment>
    <segment id="108">, masmas o filme sossega</segment>
    <segment id="109">, eu juro.</segment>
    <segment id="110">O longa mais pró-Toronto que</segment>
    <segment id="111">sese pode achar no streaming no Brasil (infelizmente</segment>
    <segment id="112">, no momento</segment>
    <segment id="113">, "</segment>
    <segment id="114">Entre o Amor e a Paixão"</segment>
    <segment id="115">, de Sarah Polley</segment>
    <segment id="116">, não está disponível aqui)</segment>
    <segment id="117">, "</segment>
    <segment id="118">Será Que?</segment>
    <segment id="119">" conta a história de Wallace (Daniel Radcliffe) e Chantry (Zoe Kazan).</segment>
    <segment id="120">Ele é um ex-estudante de medicina de coração partido</segment>
    <segment id="121">, ela, uma animadora em um relacionamento estável com um cara chato.</segment>
    <segment id="122">A existência do namorado faz com que os dois prometam que a amizade é apenas amizade</segment>
    <segment id="123">, masmas...</segment>
    <segment id="124">O filme tem dois pontos fortes: o casal de amigos</segment>
    <segment id="125">, interpretados por Adam Driver e Mackenzie Davis em começo de carreira</segment>
    <segment id="126">, e a clareza de que os grandes gestos românticos dos filmes são</segment>
    <segment id="127">, na vida real</segment>
    <segment id="128">, coisa de louco.</segment>
    <segment id="129">Disponível na HBO Max (97 min.)  SÉRIES  Se quer algo mais "Fleabag": "Extraordinária"  Não é bem um romance</segment>
    <segment id="130">, de cara</segment>
    <segment id="131">, masmas ele está lá (e eu assisti à série inteira em uma sentada e queria uma desculpa para escrever sobre ela).</segment>
    <segment id="132">Jenny, 25</segment>
    <segment id="133">, (Máiréad Tyers) está entre as poucas pessoas no mundo que</segment>
    <segment id="134">, ao completarem 18 anos</segment>
    <segment id="135">, não descobriram de uma hora para outra serem capazes de voar</segment>
    <segment id="136">, atravessar sólidos</segment>
    <segment id="137">, convocar peixes ou transformar qualquer coisa em PDF.</segment>
    <segment id="138">Sem rumo na vida</segment>
    <segment id="139">, ela tenta arranjar dinheiro e coragem para contratar uma clínica que promete ajudar a "despertar" seu poder</segment>
    <segment id="140">, ao lado da melhor amiga</segment>
    <segment id="141">, Carrie (Sofia Oxenham)</segment>
    <segment id="142">, do namorado dela</segment>
    <segment id="143">, Kash (Bilal Hasna)</segment>
    <segment id="144">, e do recém-adquirido gato Leitoso (Luke Rollason).</segment>
    <segment id="145">Criada por Emma Moran e dirigida</segment>
    <segment id="146">comocomo um filme do Edgar Wright dos bons tempos</segment>
    <segment id="147">, a série já garantiu segunda temporada.</segment>
    <segment id="148">Disponível na Star+</segment>
    <segment id="149">, uma temporada (oito episódios)  Se quer ver altos e baixos...</segment>
    <segment id="150">"</segment>
    <segment id="151">Feel</segment>
    <segment id="152">Good</segment>
    <segment id="153">"</segment>
    <segment id="154">Mae (Mae Martin)</segment>
    <segment id="155">, jovem comediante canadense tentando fazer carreira na Inglaterra</segment>
    <segment id="156">, mal pode acreditar quando George (Charlotte Ritchie) demonstra interesse nela ("ela é uma Mary Poppins rebelde</segment>
    <segment id="157">, eu sou o Bart Simpson").</segment>
    <segment id="158">O romance avança rapidamente</segment>
    <segment id="159">, com dois obstáculos: Mae está em recuperação de um vício em cocaína</segment>
    <segment id="160">, e George está no armário.</segment>
    <segment id="161">Com toques mais dramáticos —é inspirada na vida de Martin</segment>
    <segment id="162">, que a cocriou com Joe Hampson—</segment>
    <segment id="163">, "Feel Good" pode não ser uma série fácil</segment>
    <segment id="164">, masmas está entre as minhas mais revistas (abrir o primeiro episódio para escrever este parágrafo pode me fazer começar a ver série de novo).  Disponível na Netflix</segment>
    <segment id="165">, duas temporadas (12 episódios)  Imagens da atriz Mae MartinMais    novamente         de   de  de  representando um  Se quer algo mais "</segment>
    <segment id="166">Um Lugar Chamado Notting Hill"...</segment>
    <segment id="167">"</segment>
    <segment id="168">Starstruck"</segment>
    <segment id="169">Jessie (Rose Matafeo</segment>
    <segment id="170">, também criadora da série) conhece Tom (Nikesh Patel) numa balada na noite de Ano-Novo.</segment>
    <segment id="171">Na manhã seguinte</segment>
    <segment id="172">, descobre que ele é</segment>
    <segment id="173">, na verdade</segment>
    <segment id="174">, Tom Kapoor</segment>
    <segment id="175">, estrela de cinema —ou seja</segment>
    <segment id="176">, é praticamente "</segment>
    <segment id="177">Um Lugar Chamado Notting</segment>
    <segment id="178">Hill</segment>
    <segment id="179">"</segment>
    <segment id="180">com jovens millennials.</segment>
    <segment id="181">Cada temporada de seis episódios de 20 e poucos minutos cada um tem o tamanho perfeito de uma rom-com.</segment>
    <segment id="182">Uma terceira já está em produção.  Disponível na HBO Max</segment>
    <segment id="183">, duas temporadas (12 episódios)  Se quer protagonistas que precisam de um chacoalhão...  "</segment>
    <segment id="184">You’re</segment>
    <segment id="185">the Worst"</segment>
    <segment id="186">Jimmy (Chris Geere) e Gretchen (Aya Cash) são egoístas</segment>
    <segment id="187">, vaidosos e inseguros e</segment>
    <segment id="188">, portanto</segment>
    <segment id="189">, perfeitos um para o outro.</segment>
    <segment id="190">É como</segment>
    <segment id="191">como um romance entre dois anti-heróis</segment>
    <segment id="192">, que cresce quanto mais o espectador</segment>
    <segment id="193">sese diverte vendo o embate do casal contra o mundo.</segment>
    <segment id="194">Por ter durado mais que as outras sugestões aqui</segment>
    <segment id="195">, teve também mais percalços: a linda guinada da segunda temporada para abordar a depressão de Gretchen deu lugar</segment>
    <segment id="196">, na quarta</segment>
    <segment id="197">, a uma versão da personagem talvez idiota demais para viver em sociedade.</segment>
    <segment id="198">Por sorte</segment>
    <segment id="199">, a quinta temporada corrige o rumo e termina no ápice do romance.</segment>
    <segment id="200">Disponível na Star+</segment>
    <segment id="201">, cinco temporadas (62 episódios)</segment>
    <segment id="202">O que está chegando  "</segment>
    <segment id="203">Tudo o que Respira"</segment>
    <segment id="204">Documentário indicado ao Oscar deste ano</segment>
    <segment id="205">, acompanha a história de dois irmãos indianos que criam um santuário para tratar da saúde de pássaros</segment>
    <segment id="206">, cada vez mais afetados pela crise climática e a poluição</segment>
    <segment id="207">, em Nova Déli.</segment>
    <segment id="208">Chegou à HBO Max na quarta (8).</segment>
    <segment id="209">(97 min)  Atenção!</segment>
    <segment id="210">"The Last of Us"</segment>
    <segment id="211">Devido ao Super Bowl</segment>
    <segment id="212">, que acontece no domingo (12)</segment>
    <segment id="213">, o quinto episódio de "The Last of Us" chega à HBO Max</segment>
    <segment id="214">hoje mesmo (sexta</segment>
    <segment id="215">, 10),</segment>
    <segment id="216">às 23h.</segment>
    <segment id="217">O episódio será exibido no canal linear da HBO normalmente</segment>
    <segment id="218">, no domingo</segment>
    <segment id="219">, às 23h.</segment>
    <segment id="220">Pedro Pascal em cena da série &amp;#039</segment>
    <segment id="221">;The Last of Us&amp;#039</segment>
    <segment id="222">;, da HBO Max - DivulgaçãoO que está saindo  "</segment>
    <segment id="223">A Origem"</segment>
    <segment id="224">A HBO Max avisa que você só tem mais este mês para tentar entender o que raios acontece em "</segment>
    <segment id="225">A Origem"</segment>
    <segment id="226">, de Christopher Nolan.</segment>
    <segment id="227">Saindo da HBO Max em 28 de fevereiro (158 min.)</segment>
