  <rst>
    <segment id="1">Madonna</segment>
    <segment id="2">sese apresentou no Madison Square Garden na noite da última segunda</segment>
    <segment id="3">comocomo parte de sua turnê "Celebration"</segment>
    <segment id="4">, um espetáculo extravagante dedicado ao seu catálogo de sucessos</segment>
    <segment id="5">comocomo a rainha do pop.  Madonna</segment>
    <segment id="6">sese apresenta na O2 Arena</segment>
    <segment id="7">, em Londres</segment>
    <segment id="8">, durante a sua turnê &amp;#039</segment>
    <segment id="9">;The Celebration Tour&amp;#039</segment>
    <segment id="10">;   -Kevin Mazur/WireImage/Reuters</segment>
    <segment id="11">Durante "</segment>
    <segment id="12">Like a Prayer"</segment>
    <segment id="13">, ela cantou de um carrossel giratório cheio de crucifixos gigantes e homens sem camisa.</segment>
    <segment id="14">Quando cantou "Vogue"</segment>
    <segment id="15">, ela convidou Kelly Ripa para</segment>
    <segment id="16">sese juntar a ela no palco e avaliar os movimentos de seus dançarinos com placares de pontuação.</segment>
    <segment id="17">"</segment>
    <segment id="18">Eu não sei quando vou voltar aqui para tocar novamente</segment>
    <segment id="19">, masmas estou fazendo esse show</segment>
    <segment id="20">comocomo</segment>
    <segment id="21">sese fosse meu último show"</segment>
    <segment id="22">, disse Madonna</segment>
    <segment id="23">, de 65 anos</segment>
    <segment id="24">, para a multidão.</segment>
    <segment id="25">"E estou fazendo esse show</segment>
    <segment id="26">comocomo</segment>
    <segment id="27">sese fosse meu primeiro show.</segment>
    <segment id="28">"  Nina Lebron</segment>
    <segment id="29">, professora</segment>
    <segment id="30">, no Madison Square Garden em Nova York</segment>
    <segment id="31">, antes do show de Madonna - Amir Hamja/The New York TimesAntes do show</segment>
    <segment id="32">, a cena do lado de fora da arena</segment>
    <segment id="33">sese assemelhava a uma passarela de moda</segment>
    <segment id="34">, já que os fãs de Madonna chegavam para prestar homenagens estilísticas a ela.</segment>
    <segment id="35">Homens saíam do metrô usando botas de motociclista pretas e jaquetas de couro.</segment>
    <segment id="36">Algumas mulheres desenharam pintas falsas nos lábios superiores.</segment>
    <segment id="37">Num bar subterrâneo antes do show na Penn Station</segment>
    <segment id="38">, enquanto sucessos</segment>
    <segment id="39">comocomo "Holiday" e "</segment>
    <segment id="40">Papa Don't Preach" tocavam em um alto-falante</segment>
    <segment id="41">, Sophy LeMay</segment>
    <segment id="42">, uma contadora corporativa</segment>
    <segment id="43">, usava luvas de renda sem dedos enquanto tomava uma bebida.</segment>
    <segment id="44">Os fãs compartilharam suas opiniões sobre o processo movido por dois espectadores contra Madonna</segment>
    <segment id="45">, que se</segment>
    <segment id="46">se tornou conhecida</segment>
    <segment id="47">comocomo uma artista de palco nada pontual</segment>
    <segment id="48">, acusando a artista de publicidade enganosa e representação negligente por</segment>
    <segment id="49">sese apresentar tarde no Barclays Center</segment>
    <segment id="50">, no distrito nova-iorquino do Brooklyn</segment>
    <segment id="51">, em dezembro.</segment>
    <segment id="52">Seus representantes disseram que "pretendem defender vigorosamente esse</segment>
    <segment id="53">casocaso".</segment>
    <segment id="54">Veja os fãs de Madonna que foram no show da &amp;#039</segment>
    <segment id="55">;Celebration&amp;#039</segment>
    <segment id="56">; no Madison Square GardenMais    novamente         de   de  de  representando um  "</segment>
    <segment id="57">É o que é"</segment>
    <segment id="58">, disse Julio Alvarez</segment>
    <segment id="59">, que usava um chapéu coco.</segment>
    <segment id="60">"</segment>
    <segment id="61">Ela é Madonna.</segment>
    <segment id="62">"  "</segment>
    <segment id="63">Eu viajei de Oklahoma só para a ver"</segment>
    <segment id="64">, acrescentou Kevin Smith</segment>
    <segment id="65">, que empunhava um chicote preto.</segment>
    <segment id="66">"Eu vou ficar acordado até a 1h da manhã para a ver</segment>
    <segment id="67">, sese for preciso.</segment>
    <segment id="68">"  Nas entrevistas editadas abaixo</segment>
    <segment id="69">, os fãs refletiram sobre a relevância cultural duradoura de Madonna.</segment>
    <segment id="70">Francisco Ramirez  Por que ela é importante para você?</segment>
    <segment id="71">Todos os caminhos levam a Madonna.</segment>
    <segment id="72">Olha, eu amo a Beyoncé</segment>
    <segment id="73">, masmas ninguém nunca vai tirar a coroa dela.</segment>
    <segment id="74">Ninguém pode tirar o que ela nos deu.</segment>
    <segment id="75">E o que eu quero dizer com isso é jovens queer que antes não sabiam melhor.</segment>
    <segment id="76">Ela nos guiou pelo deserto.</segment>
    <segment id="77">Você se</segment>
    <segment id="78">se importa com uma diva que não é pontual?</segment>
    <segment id="79">Eu me certifiquei de estar preparado para isso</segment>
    <segment id="80">, caso</segment>
    <segment id="81">caso aconteça.</segment>
    <segment id="82">Tomei chá para dormir</segment>
    <segment id="83">, tirei uma soneca mais cedo.</segment>
    <segment id="84">Estou hidratado.</segment>
    <segment id="85">Mike SmileZ  Por que ela é importante para você?</segment>
    <segment id="86">Madonna foi especificamente responsável pelo meu despertar sexual.</segment>
    <segment id="87">Ela me ajudou a me encontrar.</segment>
    <segment id="88">Se você pudesse passar um dia com Madonna</segment>
    <segment id="89">, o que você faria?</segment>
    <segment id="90">Minha resposta PG-13 [apropriada para menores] seria 'adoraria conversar com ela sobre os dias do Danceteria enquanto faço uma massagem nos pés dela'.</segment>
    <segment id="91">Você se</segment>
    <segment id="92">se importa com uma diva atrasada?</segment>
    <segment id="93">Um mago nunca</segment>
    <segment id="94">sese atrasa</segment>
    <segment id="95">, nem chega cedo.</segment>
    <segment id="96">Ele chega precisamente quando quer.</segment>
    <segment id="97">Relembre o show da Madonna em 1993 no BrasilMais    novamente         de   de  de  representando um   Vera Alexander</segment>
    <segment id="98">Você diz que já conheceu Madonna?</segment>
    <segment id="99">Sim, a conheci quando ela chegou pela primeira vez em Nova York</segment>
    <segment id="100">, quando ela não era ninguém.</segment>
    <segment id="101">Ela era apenas uma garota de Michigan.</segment>
    <segment id="102">Então ela começou a sair com todos os caras gays no East Village e eles a transformaram.</segment>
    <segment id="103">Ela se</segment>
    <segment id="104">se tornou audaciosa de uma maneira sexy.</segment>
    <segment id="105">Kevin Smith  Por que você a ama?</segment>
    <segment id="106">Porque estamos entrando na quinta década dela</segment>
    <segment id="107">, e ela ainda está forte.</segment>
    <segment id="108">As pessoas continuam dizendo que essa será a última turnê dela</segment>
    <segment id="109">, masmas eu não acredito.</segment>
    <segment id="110">Esta não será a última turnê dela.</segment>
    <segment id="111">Ninguém diz para Mick Jagger ou Paul McCartney que eles precisam parar de fazer turnês.</segment>
    <segment id="112">Eu me pergunto por quê.</segment>
    <segment id="113">Se você pudesse passar um dia com Madonna</segment>
    <segment id="114">, o que você faria?</segment>
    <segment id="115">Seria divertido fazer uma viagem de compras de moda juntos</segment>
    <segment id="116">, em que ela está pagando a conta.</segment>
    <segment id="117">Veja fotos mais recentes de MadonnaMais    novamente         de   de  de  representando um   Peter Maslow</segment>
    <segment id="118">Por que ela é importante para você?</segment>
    <segment id="119">Por causa de seu apoio incansável ao movimento queer.</segment>
    <segment id="120">E como</segment>
    <segment id="121">como um ícone cultural</segment>
    <segment id="122">, ela é imortal.</segment>
    <segment id="123">Se você pudesse conhecer Madonna</segment>
    <segment id="124">, o que você faria?</segment>
    <segment id="125">Eu perguntaria a ela sobre seus amigos gays durante a crise da Aids.</segment>
    <segment id="126">Como ela</segment>
    <segment id="127">sese sentiu naquela época em Nova York e</segment>
    <segment id="128">comocomo ela lidou com isso.</segment>
    <segment id="129">Nina Lebron  Por que Madonna é importante para você?</segment>
    <segment id="130">Ela sempre foi um ícone de estilo.</segment>
    <segment id="131">Ela ajudou a apoiar artistas e designers</segment>
    <segment id="132">comocomo Keith Haring e Vivienne Westwood.</segment>
    <segment id="133">E todo mundo conhece o sutiã de cone de Jean Paul Gaultier da turnê</segment>
    <segment id="134">"Blond Ambition".</segment>
    <segment id="135">Julio Alvarez  Por que você a ama?</segment>
    <segment id="136">Porque o poder de permanência de Madonna não pode ser questionado.</segment>
    <segment id="137">Ela é uma camaleoa.</segment>
    <segment id="138">Sempre mudando.</segment>
    <segment id="139">Sempre apertando os botões.</segment>
    <segment id="140">E ela nunca vai parar.</segment>
    <segment id="141">Relembre todos os discos de MadonnaMais    novamente         de   de  de  representando um   Milena Guedes</segment>
    <segment id="142">Se você pudesse passar um dia com Madonna</segment>
    <segment id="143">, o que você faria?</segment>
    <segment id="144">Eu preferiria passar uma noite fora com Madonna.</segment>
    <segment id="145">Ir a um clube de strip juntas</segment>
    <segment id="146">, tomar muitas bebidas e festejar até de manhã.</segment>
    <segment id="147">Você se</segment>
    <segment id="148">se importa com uma diva atrasada?</segment>
    <segment id="149">Ela é a rainha.</segment>
    <segment id="150">Ela pode subir ao palco tão tarde quanto quiser.</segment>
    <segment id="151">Kevin Biedrzycki  Se você pudesse conhecer Madonna</segment>
    <segment id="152">, o que você faria?</segment>
    <segment id="153">Eu perguntaria</segment>
    <segment id="154">comocomo ela supera suas ansiedades e inseguranças.</segment>
    <segment id="155">Como ela consegue transformar toda a escrutinação que a sociedade põe sobre ela em combustível e motor</segment>
    <segment id="156">comocomo artista.</segment>
    <segment id="157">Como ela deixa isso a impulsionar para a frente.</segment>
    <segment id="158">Por que você a ama?</segment>
    <segment id="159">Ela mantém suas convicções e entende profundamente seu público.</segment>
    <segment id="160">Sophy LeMay  Por que ela é importante para você?</segment>
    <segment id="161">Porque quando a vi</segment>
    <segment id="162">sese apresentar uma noite antes durante essa turnê</segment>
    <segment id="163">, ela me fez sentir</segment>
    <segment id="164">comocomo um adolescente novamente.</segment>
    <segment id="165">Espero que ela nunca pare de fazer turnês.</segment>
  </rst>
</analysis>