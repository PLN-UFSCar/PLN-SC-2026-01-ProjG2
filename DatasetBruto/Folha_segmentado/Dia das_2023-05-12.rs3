  <rst>
    <segment id="1">Além de estar à frente de sete estabelecimentos</segment>
    <segment id="2">, a chef Renata Vanzetto é mãe de três crianças.</segment>
    <segment id="3">Ela, que é dona de casas</segment>
    <segment id="4">comocomo o Mico e o MeGusta</segment>
    <segment id="5">, compartilha em sua conta no Instagram</segment>
    <segment id="6">, o preparo de pratos doces ou salgados</segment>
    <segment id="7">, que ela chama de "rê-ceitas".</segment>
    <segment id="8">Veja uma receita de pavê da chef renata vanzetto para o Dia das Mães - Gustavo steffen/DivulgaçãoUma das receitas compartilhadas é perfeita para fazer no Dia das Mães: pavê criado pela chef</segment>
    <segment id="9">, que intercala camadas de massa de bolo esfarelado e chantili com doce de leite.</segment>
    <segment id="10">A sobremesa leva algum tempo entre assar o bolo</segment>
    <segment id="11">, esperar que ele esfrie e depois resfriar o pavê</segment>
    <segment id="12">, masmas o processo não exige muita familiaridade com a cozinha —e pode ser feito para surpreender as mães neste domingo (14).</segment>
    <segment id="13">&amp;gt;</segment>
    <segment id="14">Leia tudo sobre Dia das Mães: dicas de presentes</segment>
    <segment id="15">, onde ir e quem criou a data.</segment>
    <segment id="16">PAVÊ DE NOZES</segment>
    <segment id="17">COM CREME DE DOCE DE LEITE  Ingredientes:   250g de nozes picadas 6 colheres de sopa de farinha de rosca 6 colheres de sopa de açúcar 6 ovos 1 colher de sopa de fermento 400 g de doce de leite 500 ml de creme de leite</segment>
    <segment id="18">Modo de fazer:</segment>
    <segment id="19">Bata os ovos com o açúcar até ficar esbranquiçado e dobrar de tamanho</segment>
    <segment id="20">Acrescente a farinha de rosca</segment>
    <segment id="21">, as nozes e</segment>
    <segment id="22">, por último</segment>
    <segment id="23">, o fermento</segment>
    <segment id="24">; misture com uma espátula Assar em uma forma untada com óleo e farinha de rosca por 30 minutos a 180ºC graus</segment>
    <segment id="25">Bata o creme de leite até o ponto de chantili</segment>
    <segment id="26">Incorpore o doce de leite ao chantili</segment>
    <segment id="27">Após deixar o bolo esfriar</segment>
    <segment id="28">, esfarele a massa com as mãos</segment>
    <segment id="29">Coloque uma camada do bolo esfarelado em uma travessa</segment>
    <segment id="30">, seguida de uma camada do chantili com doce de leite.</segment>
    <segment id="31">Faça mais uma camada de bolo e outra de recheio Leve para gelar por cerca de duas horas e polvilhe canela ao servir</segment>
  </rst>
</analysis>