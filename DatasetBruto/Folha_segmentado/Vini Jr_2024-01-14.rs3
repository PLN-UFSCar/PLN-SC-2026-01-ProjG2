  <rst>
    <segment id="1">Após dois meses sem marcar pelo Real Madrid</segment>
    <segment id="2">, Vinicius Junior acabou com o jejum em grande estilo.</segment>
    <segment id="3">Marcou três gols neste domingo (14) na vitória de seu time sobre o rival Barcelona</segment>
    <segment id="4">, no confronto conhecido</segment>
    <segment id="5">comocomo El Clásico.</segment>
    <segment id="6">O último gol de Vini Jr. fora contra o Valencia</segment>
    <segment id="7">, em novembro passado.</segment>
    <segment id="8">Pouco depois ele sofreu uma lesão e ficou de fora de algumas partidas pelo Real.</segment>
    <segment id="9">A partida deste domingo</segment>
    <segment id="10">, no estádio Al-Awwal Park</segment>
    <segment id="11">, em Riad (Arábia Saudita)</segment>
    <segment id="12">, valia o título da Supercopa da Espanha.</segment>
    <segment id="13">Vini Jr. é o terceiro brasileiro a marcar três gols no El Clásico.</segment>
    <segment id="14">Antes dele</segment>
    <segment id="15">, apenas Evaristo de Macedo e Romário</segment>
    <segment id="16">, ambos atuando pelo Barcelona</segment>
    <segment id="17">, haviam atingido tal feito.</segment>
    <segment id="18">Vinicius Junior no jogo em Riad</segment>
    <segment id="19">, Arábia Saudita - Juan Medina/ReutersOs três gols foram feitos pelo atacante no primeiro tempo: aos 7 minutos</segment>
    <segment id="20">, aos 10 minutos e aos 38 minutos</segment>
    <segment id="21">, de pênalti</segment>
    <segment id="22">, cometido sobre ele mesmo.</segment>
    <segment id="23">Foi o trio de gols mais rápido marcado por um jogador do Real Madrid em um El Clásico desde 1951.</segment>
    <segment id="24">Na partida deste domingo</segment>
    <segment id="25">, houve confusão entre Vinicius e jogadores do Barcelona logo após a expulsão de Araújo.</segment>
    <segment id="26">O jogador do Barcelona</segment>
    <segment id="27">, que já havia recebido cartão amarelo pela falta em Vini Jr que gerou o pênalti</segment>
    <segment id="28">, recebeu outro amarelo após outra falta no atacante brasileiro.</segment>
    <segment id="29">Os reservas do Barcelona acharam que Vini Jr simulou a falta e aí começou a confusão.</segment>
    <segment id="30">Houve empurra-empurra e Vini chegou a fazer "4 a 1" com os dedos das mãos para o banco de reserva do Barcelona e para a torcida adversária</segment>
    <segment id="31">, mostrando o placar do jogo.</segment>
    <segment id="32">Na entrevista após a partida</segment>
    <segment id="33">, ele disse:</segment>
    <segment id="34">"</segment>
    <segment id="35">Eu quero me tornar uma pessoa melhor.</segment>
    <segment id="36">Fazer tudo para vencer.</segment>
    <segment id="37">Às vezes eu acabo irritando os outros</segment>
    <segment id="38">, a mim mesmo e aos meus colegas.</segment>
    <segment id="39">Preciso melhorar</segment>
    <segment id="40">, masmas tenho que continuar nessa trajetória.</segment>
    <segment id="41">Fico muito triste.</segment>
    <segment id="42">Todos querem brigar comigo</segment>
    <segment id="43">porque</segment>
    <segment id="44">porque todos sabem que vai sair na imprensa.</segment>
    <segment id="45">'Vinicius fez isso</segment>
    <segment id="46">, fez aquilo'.</segment>
    <segment id="47">Eu tento ficar calmo e focado no jogo para poder fazer o melhor pelos meus colegas.</segment>
    <segment id="48">Eu não sou um santo.</segment>
    <segment id="49">Falo demais e faço dribles que não deveria fazer.</segment>
    <segment id="50">Mas estou aqui para melhorar e dar exemplo às crianças.</segment>
    <segment id="51">O treinador e meus colegas estão me ensinando o que devo fazer".  Vinicius Junior com o troféu da Supercopa da Espanha - Juan Medina/ReutersNa noite de 8 de janeiro de 1994</segment>
    <segment id="52">, Romário marcou os seus três gols pelo Barcelona na vitória por 5 a 0 sobre o Real Madrid</segment>
    <segment id="53">O hat-trick de Vini Jr é o 28º na história do El Clásico.</segment>
    <segment id="54">Já alcançaram o feito 25 jogadores.</segment>
    <segment id="55">O craque do Real na década de 1910</segment>
    <segment id="56">, Santiago Bernabéu</segment>
    <segment id="57">, o húngaro Ferenc Puskas e Lionel Messi têm dois hat-tricks</segment>
    <segment id="58">cada um.</segment>
    <segment id="59">Em uma só partida</segment>
    <segment id="60">, em 1916</segment>
    <segment id="61">, o empate em 6-6 pela Copa do Rei</segment>
    <segment id="62">, três jogadores</segment>
    <segment id="63">, incluindo Bernabéu</segment>
    <segment id="64">, marcaram hat-tricks.</segment>
  </rst>
</analysis>