  <rst>
    <segment id="1">Morreu</segment>
    <segment id="2">, neste sábado</segment>
    <segment id="3">, dia 20</segment>
    <segment id="4">, a cantora Mary Weiss</segment>
    <segment id="5">, principal vocalista do grupo americano The Shangri-Las</segment>
    <segment id="6">, aos 75 anos.</segment>
    <segment id="7">A informação foi confirmada pelo marido da artista</segment>
    <segment id="8">, que não especificou a causa da morte.</segment>
    <segment id="9">A vocalista Mary Weiss</segment>
    <segment id="10">, do The Shangri-Las- BBCThe Shangri-Las estourou na década de 1960</segment>
    <segment id="11">, com as duplas de irmãs Mary e Betty Weiss e Marge e Mary Ann Ganser.</segment>
    <segment id="12">As canções "</segment>
    <segment id="13">Remember" e "</segment>
    <segment id="14">Leader of the Pack" foram incluídas na lista das 500 melhores músicas de todos os tempos</segment>
    <segment id="15">, segundo a revista Rolling Stone.</segment>
    <segment id="16">Mary Weiss era a principal estrela do grupo</segment>
    <segment id="17">, que fazia muito sucesso entre os jovens</segment>
    <segment id="18">, com letras que versavam sobre amores desastrados e dramas adolescentes.</segment>
    <segment id="19">O quarteto terminou em 1968</segment>
    <segment id="20">, masmas ganhou espaço no Rock and Roll Hall of Fame.</segment>
    <segment id="21">Rush no Hall da FamaMais    novamente         de   de  de  representando um  Em 2007</segment>
    <segment id="22">, Mary chegou a voltar a gravar.</segment>
    <segment id="23">Desse período</segment>
    <segment id="24">, surgiu o disco intitulado "Dangerous Game"</segment>
    <segment id="25">, que não teve o mesmo sucesso.</segment>
    <segment id="26">Miriam Linna</segment>
    <segment id="27">, da gravadora Norton Records</segment>
    <segment id="28">, responsável por lançar "Dangerous Game" homenageou a artista em uma postagem no Facebook.</segment>
    <segment id="29">"Mary foi um ícone</segment>
    <segment id="30">, uma heroína</segment>
    <segment id="31">, tanto para homens e mulheres jovens da minha geração quanto de todas as gerações"</segment>
    <segment id="32">, ela escreveu.</segment>
  </rst>
