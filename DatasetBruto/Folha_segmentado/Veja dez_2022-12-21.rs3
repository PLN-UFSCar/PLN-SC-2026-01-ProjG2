  <rst>
    <segment id="1">O verão</segment>
    <segment id="2">, que começou nesta quarta-feira (21)</segment>
    <segment id="3">, é um convite a passeios e brincadeiras ao ar livre.</segment>
    <segment id="4">Mas o pet merece atenção.</segment>
    <segment id="5">O calor provoca incômodos e pode causar hipertermia</segment>
    <segment id="6">, temperatura do corpo mais elevada do que o normal —a dos pets normalmente vai de 38</segment>
    <segment id="7">,5ºC a 39</segment>
    <segment id="8">,2ºC. Por isso</segment>
    <segment id="9">, manter a hidratação do animal é fundamental.</segment>
    <segment id="10">Cachorro brinca em dia ensolarado em Biarritz</segment>
    <segment id="11">, França - Gaizka Iroz-18.out.22/AFPComo saber</segment>
    <segment id="12">sese o pet está com calor?</segment>
    <segment id="13">Segundo a veterinária Carla Berl</segment>
    <segment id="14">, fundadora da rede de hospitais</segment>
    <segment id="15">Pet Care</segment>
    <segment id="16">, ele fica ofegante e procura superfícies mais geladas</segment>
    <segment id="17">, como</segment>
    <segment id="18">como o piso da cozinha ou o box do banheiro</segment>
    <segment id="19">, para esparramar o corpo e</segment>
    <segment id="20">sese refrescar.</segment>
    <segment id="21">Diferentemente dos humanos</segment>
    <segment id="22">, cães não transpiram por todo o corpo</segment>
    <segment id="23">, masmas pela respiração.</segment>
    <segment id="24">Quanto mais ofegante o animal estiver</segment>
    <segment id="25">, maior é o calor que ele sente</segment>
    <segment id="26">, afirma Carla.</segment>
    <segment id="27">Ela explica que o pet está inspirando o ar fresco e expirando o ar quente para perder esse calor.</segment>
    <segment id="28">Porém, em dias de temperaturas acima de 28ºC</segment>
    <segment id="29">, essa perda é mínima.</segment>
    <segment id="30">A veterinária lista dez cuidados para dar mais conforto aos peludos nesta época do ano</segment>
    <segment id="31">:  Saúde do pet no verãoMais    novamente         de   de  de  representando um</segment>
    <segment id="32">Aumente a quantidade disponível de água fresca e</segment>
    <segment id="33">, sese estiver muito quente</segment>
    <segment id="34">, ajude a refrescar o pet oferecendo água gelada.</segment>
    <segment id="35">Pode até colocar cubos de gelo no pote com água</segment>
    <segment id="36">Se o animal estiver muito ofegante</segment>
    <segment id="37">, coloque-o na sombra e</segment>
    <segment id="38">, sese for necessário</segment>
    <segment id="39">, refresque-o com um banho de água fria</segment>
    <segment id="40">Faça os passeios diários nas horas mais amenas do dia</segment>
    <segment id="41">, como</segment>
    <segment id="42">como no começo da manhã e no comecinho da noite.</segment>
    <segment id="43">A temperatura elevada esquenta o asfalto e pode machucar as almofadinhas da pata</segment>
    <segment id="44">, criando um desconforto a mais Leve sempre uma garrafinha de água durante os passeios</segment>
    <segment id="45">Ofereça</segment>
    <segment id="46">as refeições também nas horas mais frescas do dia Animais com pelos muito longos podem fazer tosa.</segment>
    <segment id="47">Algumas raças</segment>
    <segment id="48">, como</segment>
    <segment id="49">como spitz</segment>
    <segment id="50">, devem fazer a tosa somente na tesoura</segment>
    <segment id="51">O tutor pode preparar sorvete caseiro de caldo de carne ou frango Invista em um tapete gelado</segment>
    <segment id="52">, que pode ser encontrado em pet shops!</segment>
    <segment id="53">Ligue o ventilador ou ar-condicionado</segment>
    <segment id="54">sese o ambiente em que o pet fica a maior parte do tempo não for bem ventilado Brinque com água no quintal de casa</segment>
    <segment id="55">Com o lazer em áreas abertas e até aquela soneca sob o sol</segment>
    <segment id="56">, é imprescindível o uso de protetor solar em animais de pelo curto ou branco.</segment>
    <segment id="57">Para garantir a saúde do animal</segment>
    <segment id="58">, é recomendável o uso de medicamentos preventivos contra pulgas e mosquitos</segment>
    <segment id="59">, sempre sob orientação médica.</segment>
    <segment id="60">As vacinas devem sempre estar em dia</segment>
    <segment id="61">, nesta época especialmente a que previne a leptospirose e especialmente</segment>
    <segment id="62">sese o pet vive em área sujeita a alagamentos.</segment>
    <segment id="63">Pets no verãoMais</segment>
    <segment id="64">novamente         de   de  de  representando um  +</segment>
    <segment id="65">Bom</segment>
    <segment id="66">Pra CachorroCaramelo invade evento internacional de cães de raça</segment>
    <segment id="67">, mobiliza grupo e acaba adotadoProjeto leva ação de Natal a grupos vulneráveis e seus pets em 7 estadosComo cuidar do cachorro em todas as fases da vida</segment>
    <segment id="68">; veja perguntas e respostasComo seu pet</segment>
    <segment id="69">sese comunica com você?Siga o Bom Pra Cachorro no Twitter</segment>
    <segment id="70">, Instagram e Facebook</segment>
  </rst>
