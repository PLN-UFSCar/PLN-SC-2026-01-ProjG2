  <rst>
    <segment id="1">Simpatia.</segment>
    <segment id="2">Simplicidade.</segment>
    <segment id="3">Despretensão.</segment>
    <segment id="4">Quem está no poder sente falta de hábitos mais informais.</segment>
    <segment id="5">Tempos de short e chinelão.</segment>
    <segment id="6">Em Nova York</segment>
    <segment id="7">, o presidente Bolsonaro deu o exemplo.</segment>
    <segment id="8">Pizza na calçada.</segment>
    <segment id="9">A famosa socialite Bibi Abdala apoiava a iniciativa.</segment>
    <segment id="10">—</segment>
    <segment id="11">Isso mesmo.</segment>
    <segment id="12">Restaurante é tão chato…</segment>
    <segment id="13">não é, Tiffany?</segment>
    <segment id="14">A cachorrinha poodle abanou o rabinho de pompom.</segment>
    <segment id="15">—</segment>
    <segment id="16">Wák.</segment>
    <segment id="17">—</segment>
    <segment id="18">Adoro a vida simples.</segment>
    <segment id="19">—Wák...</segment>
    <segment id="20">Era a hora do passeio.</segment>
    <segment id="21">O motorista Ademar foi mobilizado. —</segment>
    <segment id="22">Leva a gente para os Jardins.</segment>
    <segment id="23">O Audi prata estacionou numa esquina movimentada.</segment>
    <segment id="24">—Olha só.</segment>
    <segment id="25">Um botecozinho bem simples.</segment>
    <segment id="26">Pálidas fatias de pizza morriam lentamente na estufa de vidro.</segment>
    <segment id="27">—Quero só metade dessa aí.</segment>
    <segment id="28">Era preciso manter a linha.</segment>
    <segment id="29">—Wak.</segment>
    <segment id="30">—Ah, me dá inteira.</segment>
    <segment id="31">Que eu dou metade para a Tiffany.</segment>
    <segment id="32">A consciência social é importante na vida do empresariado.</segment>
    <segment id="33">—Dá mais duas fatias.</segment>
    <segment id="34">Para o meu motorista.</segment>
    <segment id="35">Foi quando Bibi levou um tranco.</segment>
    <segment id="36">O morador de rua Férgusson apropriou-</segment>
    <segment id="37">sese dos cobiçados quitutes.</segment>
    <segment id="38">—Valeu</segment>
    <segment id="39">, dona.</segment>
    <segment id="40">Bibi suspira.</segment>
    <segment id="41">—Não adianta… isso aqui nunca vai ser igual a Nova York.</segment>
    <segment id="42">Calçadas são para todos.</segment>
    <segment id="43">Mas nem sempre as pessoas têm os pés no chão.</segment>
    <segment id="44">A pizza é uma das iguarias mais consumidas pelos paulistanos   - Ronny Santos - 23.jan.20/Folhapress</segment>
  </rst>
