  <rst>
    <segment id="1">Três secretários e um diretor de empresa municipal da gestão Ricardo Nunes (MDB) devem deixar a Prefeitura de São Paulo em abril para tentarem vagas de vereadores na Câmara Municipal.  Aline Torres</segment>
    <segment id="2">, da Cultura</segment>
    <segment id="3">, Carlos Bezerra Júnior</segment>
    <segment id="4">, da Assistência e Desenvolvimento Social</segment>
    <segment id="5">, Elza Paulina</segment>
    <segment id="6">, da Segurança Urbana</segment>
    <segment id="7">, e Cesar Azevedo</segment>
    <segment id="8">, da SP Urbanismo</segment>
    <segment id="9">, são apostas do prefeito para tentar ampliar sua bancada no Legislativo paulistano</segment>
    <segment id="10">, caso</segment>
    <segment id="11">caso seja reeleito.</segment>
    <segment id="12">O coronel aposentado da Polícia Militar Ricardo Mello Araújo</segment>
    <segment id="13">, ex-Ceagesp</segment>
    <segment id="14">, pode assumir a Segurança Pública.</segment>
    <segment id="15">Ele é aliado do ex-presidente Jair Bolsonaro (PL)</segment>
    <segment id="16">, cujo apoio tem sido pleiteado pelo prefeito.</segment>
    <segment id="17">Ricardo Nunes (MDB)</segment>
    <segment id="18">, prefeito de São Paulo</segment>
    <segment id="19">, durante entrevista à Folha - Marlene Bergamo-15.set.2023/Folhapress</segment>
  </rst>
