  <rst>
    <segment id="1">Titular da seleção brasileira na Copa do Mundo de 2018</segment>
    <segment id="2">, na Rússia</segment>
    <segment id="3">, e convocado para a de 2022</segment>
    <segment id="4">, no Qatar</segment>
    <segment id="5">, Gabriel Jesus disse após a derrota da semana passada para a Argentina por 1 a 0</segment>
    <segment id="6">, no Maracanã</segment>
    <segment id="7">, acreditar que o gol "não seja o meu ponto forte".</segment>
    <segment id="8">Vindo de um atacante</segment>
    <segment id="9">, que atualmente joga em seu clube</segment>
    <segment id="10">, o inglês Arsenal</segment>
    <segment id="11">, como</segment>
    <segment id="12">como centroavante</segment>
    <segment id="13">, a declaração trouxe uma alta dose de incompreensão.</segment>
    <segment id="14">Afinal</segment>
    <segment id="15">, todo atacante que</segment>
    <segment id="16">sese preze</segment>
    <segment id="17">, especialmente o que joga centralizado</segment>
    <segment id="18">, deveria considerar fazer gol a sua grande qualidade.</segment>
    <segment id="19">Gabriel Jesus toma a frente de Romero em Brasil x Argentina</segment>
    <segment id="20">, no Rio de Janeiro</segment>
    <segment id="21">, pelas Eliminatórias da Copa do Mundo de 2026 - Sergio Moraes - 21.nov.2023/ReutersSe alguém não vê assim</segment>
    <segment id="22">, talvez seja o</segment>
    <segment id="23">casocaso de repensar a posição em que joga e dar espaço na equipe para outro alguém –que esteja certo de que seu ponto mais forte é balançar a rede adversária.</segment>
    <segment id="24">Afinal</segment>
    <segment id="25">, o Brasil</segment>
    <segment id="26">, que vai mal nas Eliminatórias sob a batuta do treinador interino Fernando Diniz</segment>
    <segment id="27">, está precisando muito de gols.</segment>
    <segment id="28">Nos cinco jogos mais recentes</segment>
    <segment id="29">, marcou apenas três</segment>
    <segment id="30">, uma péssima média de 0</segment>
    <segment id="31">,6 por partida.</segment>
    <segment id="32">Diniz chamou para as duas últimas apresentações da seleção nada menos do que nove atacantes.</segment>
    <segment id="33">Atualmente</segment>
    <segment id="34">, algum deles tem o gol</segment>
    <segment id="35">comocomo ponto forte?</segment>
    <segment id="36">A resposta depende muito da exigência de quem acompanha futebol.</segment>
    <segment id="37">O que é suficiente?</segment>
    <segment id="38">Um gol por partida (cujo tempo regulamentar é de 90 minutos)?  Talvez seja exigir demais</segment>
    <segment id="39">, pois</segment>
    <segment id="40">pois é incomum um atacante ter esse desempenho.</segment>
    <segment id="41">Tem que estar em uma fase estupenda ou ser um craque da estirpe do norueguês Erling Haaland</segment>
    <segment id="42">, 23, do Manchester City</segment>
    <segment id="43">, que nesta temporada (2023/24) registra média de um gol a cada 85 minutos (clube mais seleção).</segment>
    <segment id="44">Colunas e BlogsReceba no seu email uma seleção de colunas e blogs da FolhaCarregando...</segment>
    <segment id="45">Gabriel Jesus</segment>
    <segment id="46">, na atual temporada</segment>
    <segment id="47">, marcou quatro gols em 929 minutos –perdeu alguns jogos devido a lesões no joelho e na coxa.</segment>
    <segment id="48">Ou seja</segment>
    <segment id="49">, demorou 232 minutos</segment>
    <segment id="50">, ou perto de dois jogos e meio</segment>
    <segment id="51">, para conseguir superar o goleiro adversário.</segment>
    <segment id="52">Isso o deixa em posição de vantagem em relação a três dos convocados recentemente por Diniz (Pepê</segment>
    <segment id="53">, Raphinha e Martinelli) e em desvantagem na comparação com cinco (João Pedro</segment>
    <segment id="54">, Paulinho</segment>
    <segment id="55">, Rodrygo</segment>
    <segment id="56">, Endrick e Vini Jr).</segment>
    <segment id="57">A seguir</segment>
    <segment id="58">, os números de cada um</segment>
    <segment id="59">, em gols por minuto</segment>
    <segment id="60">, considerando a temporada de 2023 no Brasil e de 2023/24 na Europa</segment>
    <segment id="61">, em jogos por competição disputados pelo clube e pela seleção.</segment>
    <segment id="62">João Pedro (Brighton</segment>
    <segment id="63">, 22 anos):</segment>
    <segment id="64">1 gol a cada 134 minutos (1.071 minutos</segment>
    <segment id="65">, 8 gols)</segment>
    <segment id="66">Paulinho (Atlético-MG</segment>
    <segment id="67">, 23 anos):</segment>
    <segment id="68">1 gol a cada 162 minutos (4.531 minutos</segment>
    <segment id="69">, 28 gols)</segment>
    <segment id="70">Vinicius Junior (Real Madrid</segment>
    <segment id="71">, 23 anos):</segment>
    <segment id="72">1 gol a cada 194 minutos (1.165 minutos</segment>
    <segment id="73">, 6 gols)</segment>
    <segment id="74">Rodrygo (Real Madrid</segment>
    <segment id="75">, 22 anos):</segment>
    <segment id="76">1 gol a cada 200 minutos (1.799 minutos</segment>
    <segment id="77">, 9 gols)</segment>
    <segment id="78">Endrick (Palmeiras</segment>
    <segment id="79">, 17 anos):</segment>
    <segment id="80">1 gol a cada 210 minutos (2.515 minutos</segment>
    <segment id="81">, 12 gols)</segment>
    <segment id="82">Gabriel Jesus (Arsenal</segment>
    <segment id="83">, 26 anos):</segment>
    <segment id="84">1 gol a cada 232 minutos (929 minutos</segment>
    <segment id="85">, 4 gols)</segment>
    <segment id="86">Raphinha (Barcelona</segment>
    <segment id="87">, 26 anos):</segment>
    <segment id="88">1 gol a cada 278 minutos (835 minutos</segment>
    <segment id="89">, 3 gols)</segment>
    <segment id="90">Gabriel Martinelli (Arsenal</segment>
    <segment id="91">, 22 anos):</segment>
    <segment id="92">1 gol a cada 334 minutos (1.002 minutos</segment>
    <segment id="93">, 3 gols)</segment>
    <segment id="94">Pepê (Porto</segment>
    <segment id="95">, 26 anos):</segment>
    <segment id="96">1 gol a cada 1.376 minutos (1.376 minutos</segment>
    <segment id="97">, 1 gol)</segment>
    <segment id="98">Na metade de baixo da lista</segment>
    <segment id="99">, Jesus não deveria</segment>
    <segment id="100">, em teoria</segment>
    <segment id="101">, ter sido titular diante da Argentina</segment>
    <segment id="102">, como</segment>
    <segment id="103">como foi (jogou a partida inteira)</segment>
    <segment id="104">, e sim João Pedro ou Paulinho (o atual artilheiro do Campeonato Brasileiro)</segment>
    <segment id="105">, que só esquentaram o banco.</segment>
    <segment id="106">João Pedro (9) avança com a bola em sua estreia pela seleção brasileira principal</segment>
    <segment id="107">, diante da Colômbia</segment>
    <segment id="108">, em Barranquilla - Juan Barreto - 16.nov.2023/AFPApesar da boa performance (1 gol a cada jogo e meio)</segment>
    <segment id="109">, João Pedro</segment>
    <segment id="110">, que está na Europa desde 2019 (antes defendeu o Fluminense)</segment>
    <segment id="111">, não é titular absoluto do modesto (</segment>
    <segment id="112">porémporém competitivo) clube inglês pelo qual atua</segment>
    <segment id="113">, tendo iniciado só 4 dos 13 jogos do Brighton na Premier League.</segment>
    <segment id="114">Já Pepê (ex-Grêmio)</segment>
    <segment id="115">, na rabeira na relação dos nove atacantes comparados</segment>
    <segment id="116">, começou 9 das 11 partidas de seu time no Campeonato Português</segment>
    <segment id="117">, fazendo... zero gol.</segment>
    <segment id="118">A única vez que ele marcou na temporada foi na Champions League</segment>
    <segment id="119">, na derrota do Porto por 2 a 1 para o Barcelona nesta terça (28).</segment>
  </rst>
</analysis>