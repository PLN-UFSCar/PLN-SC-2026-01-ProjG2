  <rst>
    <segment id="1">Evangélicos Sou evangélico e fico envergonhado de ver esses comportamentos</segment>
    <segment id="2">, não passam de adoradores de homens ("</segment>
    <segment id="3">Pastores bolsonaristas falam de apocalipse e oração após a derrota"</segment>
    <segment id="4">, Eliane Trindade</segment>
    <segment id="5">, 31/10).</segment>
    <segment id="6">Elias Marinho (Brasília</segment>
    <segment id="7">, DF)    Eu teria imensa vergonha de tê-lo</segment>
    <segment id="8">comocomo pastor.</segment>
    <segment id="9">Você é uma fraude.</segment>
    <segment id="10">De cristão não tem nada ("‘</segment>
    <segment id="11">Meu papel é orar por Lula’</segment>
    <segment id="12">, diz Silas Malafaia"</segment>
    <segment id="13">, Política</segment>
    <segment id="14">, 1º/11).</segment>
    <segment id="15">Marli Miranda Vieira (São Paulo</segment>
    <segment id="16">, SP)    "Evangélicos podem ser fiel de balança que pesará contra esquerda no futuro" (Política</segment>
    <segment id="17">, 31/10).</segment>
    <segment id="18">Do ponto de vista de um jovem de periferia</segment>
    <segment id="19">, o único espaço cultural de convivência saudável na sua vizinhança é a igreja evangélica mais próxima.</segment>
    <segment id="20">Não podemos deixar a juventude à mercê da doutrinação ideológica que</segment>
    <segment id="21">, infelizmente</segment>
    <segment id="22">, esses lugares</segment>
    <segment id="23">sese tornaram</segment>
    <segment id="24">, sem oferecer uma alternativa secular</segment>
    <segment id="25">, cultural e saudável.</segment>
    <segment id="26">Gino Passos (Rio de Janeiro</segment>
    <segment id="27">, RJ)    Gostaria muito e oro a nosso Deus que haja também uma renovação nas lideranças religiosas do nosso país.</segment>
    <segment id="28">Muitos que aí estão já provaram estar mais ligados aos prazeres da terra que aos desígnios de Deus!</segment>
    <segment id="29">Luciano Silva (São Vicente</segment>
    <segment id="30">, SP)  Evento profético para um Brasil com CristoMais    novamente         de   de  de  representando um  Raquel Lyra "‘Principal desafio de Lula é unir o Brasil’</segment>
    <segment id="31">, diz 1ª governadora eleita de Pernambuco" (Política</segment>
    <segment id="32">, 31/10).</segment>
    <segment id="33">Alguém da elite pernambucana</segment>
    <segment id="34">, masmas que construiu sua própria trajetória.</segment>
    <segment id="35">Parece ter fibra e um projeto de desenvolvimento.</segment>
    <segment id="36">Que as sementes floresçam em favor dos que mais precisam da intercessão do poder do Estado.</segment>
    <segment id="37">Daisy Santos (Aracaju</segment>
    <segment id="38">, SE)    Esqueceu de dizer que leva consigo para o governo o que há de pior na política de Pernambuco.</segment>
    <segment id="39">A começar pela sua vice</segment>
    <segment id="40">, Priscila Krause</segment>
    <segment id="41">, elitista e bolsonarista de carteirinha.</segment>
    <segment id="42">Fez alianças também com as piores figuras do mundo evangélico e com ela estão todos os bolsonaristas de Pernambuco.</segment>
    <segment id="43">Tomara que consiga fazer um bom governo.</segment>
    <segment id="44">Iraia Galindo (Recife</segment>
    <segment id="45">, PE)  Raquel Lyra e Priscila Krause em campanha para o Governo de Pernambuco- Janaína Pepeu/Divulgação  Fisiculturista</segment>
    <segment id="46">Isso sim parece bastante mais a PM sendo a PM</segment>
    <segment id="47">, exceto</segment>
    <segment id="48">porque</segment>
    <segment id="49">porque o rapaz não era favelado</segment>
    <segment id="50">; já nos protestos golpistas</segment>
    <segment id="51">, é uma delicadeza que parece que estamos na Nova Zelândia ("</segment>
    <segment id="52">Fisiculturista morre após ação em que PM colocou joelho sobre seu pescoço"</segment>
    <segment id="53">, Cotidiano</segment>
    <segment id="54">, 31/10).</segment>
    <segment id="55">Marta Vainchenker (Florianópolis</segment>
    <segment id="56">, SC)  </segment>
    <segment id="57">E as abordagens da Polícia Militar de São Paulo vão "melhorar" mais ainda</segment>
    <segment id="58">sese as câmeras dos uniformes forem retiradas</segment>
    <segment id="59">, conforme promessa do candidato e agora governador eleito</segment>
    <segment id="60">, o carioca Tarcísio.</segment>
    <segment id="61">Não há nada tão ruim</segment>
    <segment id="62">, que não possa ficar pior.</segment>
    <segment id="63">"</segment>
    <segment id="64">Parabéns" SP</segment>
    <segment id="65">, "bela" escolha!</segment>
    <segment id="66">Ezequias de Lima (São Carlos</segment>
    <segment id="67">, SP)</segment>
    <segment id="68">Noruega "</segment>
    <segment id="69">Noruega diz que vai retomar ajuda ao Brasil contra o desmatamento após vitória de Lula" (Ambiente</segment>
    <segment id="70">, 31/10).</segment>
    <segment id="71">Que maravilha!</segment>
    <segment id="72">Esperemos que também parem de matar baleias e detonar o Mar do Norte.</segment>
    <segment id="73">Marisa Coan (São Caetano do Sul</segment>
    <segment id="74">, SP)</segment>
    <segment id="75">Fim do silêncio</segment>
    <segment id="76">A aparição desse sujeito serviu para reavivar a minha alegria com o desfecho das eleições ("</segment>
    <segment id="77">Bolsonaro quebra silêncio</segment>
    <segment id="78">, condena bloqueios e fala em indignação com ‘injustiças’ na eleição"</segment>
    <segment id="79">, Política</segment>
    <segment id="80">, 1º/11).</segment>
    <segment id="81">Leila de Oliveira (Campinas</segment>
    <segment id="82">, SP)  </segment>
    <segment id="83">A condenação só existe quando</segment>
    <segment id="84">sese refuta algo com veemência</segment>
    <segment id="85">, o que Bolsonaro claramente não fez.</segment>
    <segment id="86">Ele no máximo criticou o método</segment>
    <segment id="87">, masmas nunca o conteúdo.</segment>
    <segment id="88">Inclusive buscou justificar as ações</segment>
    <segment id="89">comocomo</segment>
    <segment id="90">sese fossem fruto de uma indignação legítima.</segment>
    <segment id="91">Bruna Carvalho (Santos</segment>
    <segment id="92">, SP)    Segregação.</segment>
    <segment id="93">Essa foi a palavra de início e do final do mandato de Bolsonaro.</segment>
    <segment id="94">Sempre governou</segment>
    <segment id="95">, sese é que o fez</segment>
    <segment id="96">, em nome de alguns.</segment>
    <segment id="97">Denise Braga Moura (Belo Horizonte</segment>
    <segment id="98">, MG)  Presidente Jair Bolsonaro faz pronunciamento após derrota nas urnas dentro do Palácio da Alvorada - Gabriela Biló/Folhapress  ‘</segment>
    <segment id="99">Nosso Brasil’  "</segment>
    <segment id="100">Não vamos desistir do nosso Brasil</segment>
    <segment id="101">, diz Flávio Bolsonaro" (Política</segment>
    <segment id="102">, 31/10).</segment>
    <segment id="103">Que nosso Brasil é esse?</segment>
    <segment id="104">Estão pensando que aqui temos uma monarquia e os Bolsonaro são a família real?</segment>
    <segment id="105">Que audácia!</segment>
    <segment id="106">Ana Marques (Jundiaí</segment>
    <segment id="107">, SP)   Diplomacia "</segment>
    <segment id="108">Biden e europeus correm para reconhecer vitória de Lula" (Mundo</segment>
    <segment id="109">, 30/10).</segment>
    <segment id="110">Muito boas as reações rápidas</segment>
    <segment id="111">, além de diplomaticamente necessárias</segment>
    <segment id="112">, são pessoalmente gestos de rejeição ao estilo antidiplomático de Bolsonaro.</segment>
    <segment id="113">Leonilda Pereira Simões (São Paulo</segment>
    <segment id="114">, SP)  Lula é eleito presidente pela 3ª vez Mais    novamente         de   de  de  representando um    Ministérios de Lula "</segment>
    <segment id="115">Lula deve aumentar em ao menos 10 ministérios o tamanho da Esplanada" (Política</segment>
    <segment id="116">, 31/10).</segment>
    <segment id="117">Acho importante a segregação de algumas pastas.</segment>
    <segment id="118">Economia e Planejamento nunca deveriam ter sido fundidas.</segment>
    <segment id="119">Ao invés da criação de uma pasta de Povos Originários</segment>
    <segment id="120">, acredito que poderia ser uma pasta vinculada à volta do ministério da Integração Nacional.</segment>
    <segment id="121">Alberto Kiess (Rio de Janeiro</segment>
    <segment id="122">, RJ)    Para mim</segment>
    <segment id="123">, umas das maiores falhas do PT foi justamente o número absurdo de ministérios (e uma das raras coisas que achei positivo no futuro ex-presidente</segment>
    <segment id="124">; o enxugamento desse número).</segment>
    <segment id="125">Deve custar uma graninha para o nosso bolso.</segment>
    <segment id="126">Gabriel Dias (São Paulo</segment>
    <segment id="127">, SP)</segment>
  </rst>
</analysis>