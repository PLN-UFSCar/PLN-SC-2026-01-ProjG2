  <rst>
    <segment id="1">Choque.</segment>
    <segment id="2">Polêmica.</segment>
    <segment id="3">Discussão.</segment>
    <segment id="4">Acontece no Qatar.</segment>
    <segment id="5">Jogadores brasileiros vão a churrascaria e comem carne folheada a ouro.</segment>
    <segment id="6">É como</segment>
    <segment id="7">como dizem.</segment>
    <segment id="8">Trata-</segment>
    <segment id="9">sese do velho esquadrão de ouro.</segment>
    <segment id="10">Bom no samba e bom no couro.</segment>
    <segment id="11">Mais uma vez</segment>
    <segment id="12">, eles chegam com fome de caneco.</segment>
    <segment id="13">A famosa socialite Bibi Abdalla acompanhava os acontecimentos.  —</segment>
    <segment id="14">Ué... nunca soube que tinha essa churrascaria.</segment>
    <segment id="15">Ela tinha sido convidada para assistir aos jogos da Copa no país muçulmano.</segment>
    <segment id="16">O milionário J. P. do Prado era maníaco de futebol.  —Mas</segment>
    <segment id="17">, J. P.</segment>
    <segment id="18">, eu sou mulher...</segment>
    <segment id="19">e lá no Qatar tem muita perseguição.  —</segment>
    <segment id="20">Esquece isso</segment>
    <segment id="21">, Bibi.</segment>
    <segment id="22">A gente vai ficar no meu iate.</segment>
    <segment id="23">Bebida.</segment>
    <segment id="24">Cocaína.</segment>
    <segment id="25">Sexo prafrentex.  —Não tem proibição a bordo.</segment>
    <segment id="26">Faltava resolver uma dúvida.  —</segment>
    <segment id="27">Será que a Tiffany não enjoa no barco?</segment>
    <segment id="28">Tratava-</segment>
    <segment id="29">sese de sua encantadora poodle de estimação.  —Wák</segment>
    <segment id="30">, wák... wooorgh.  —</segment>
    <segment id="31">A gente tem ambulatório pet no iate</segment>
    <segment id="32">, Bibi.</segment>
    <segment id="33">Não se</segment>
    <segment id="34">se preocupe.  —</segment>
    <segment id="35">E cachorro pode andar na rua lá no Qatar?</segment>
    <segment id="36">—É macho ou fêmea?  —Fêmea.  —</segment>
    <segment id="37">Bom... quem sabe um veuzinho pode evitar problema.</segment>
    <segment id="38">Bibi não</segment>
    <segment id="39">sese interessava demais por futebol.</segment>
    <segment id="40">Mas um passeio para compras ninguém recusa.</segment>
    <segment id="41">J. P. andava a seu lado.  —</segment>
    <segment id="42">Melhor eles pensarem que a gente é um casal.  —</segment>
    <segment id="43">Wák.</segment>
    <segment id="44">Wák.  —Olha</segment>
    <segment id="45">, Bibi.</segment>
    <segment id="46">A churrascaria da Seleção.  —Onde eles comeram carne com ouro?  —</segment>
    <segment id="47">Isso mesmo.</segment>
    <segment id="48">Quer entrar?</segment>
    <segment id="49">Bibi fez cara de nojo.  —</segment>
    <segment id="50">Virei vegana</segment>
    <segment id="51">, J. P.</segment>
    <segment id="52">, não percebeu?  —</segment>
    <segment id="53">Ah... então é isso...</segment>
    <segment id="54">você não quis salmão no café da manhã.  —</segment>
    <segment id="55">De modo que</segment>
    <segment id="56">, esse tipo de churrascaria</segment>
    <segment id="57">, francamente...  --Wók.</segment>
    <segment id="58">Wók.</segment>
    <segment id="59">Wók.</segment>
    <segment id="60">Aíính, aííính...</segment>
    <segment id="61">J. P. estranhou.  —</segment>
    <segment id="62">O que é que essa cachorrinha tem</segment>
    <segment id="63">?</segment>
    <segment id="64">Bibi sorriu com inteligência.  —</segment>
    <segment id="65">A Tiffany quer experimentar.  —A carne com ouro?  —</segment>
    <segment id="66">Será que eles fazem mal passada?  —</segment>
    <segment id="67">Wák, wák.</segment>
    <segment id="68">Nhawk.</segment>
    <segment id="69">Tiffany foi tratada com respeito pelo chef Albeybi Hibif.  --Khashôr tendiry heitusuman.</segment>
    <segment id="70">As preferências gastronômicas do nosso selecionado receberam muitas críticas.</segment>
    <segment id="71">Mas craques são os pets de uma nação.</segment>
    <segment id="72">Merecem todo o nosso carinho.</segment>
    <segment id="73">Conheça o mercado de ouro Gold Souq</segment>
    <segment id="74">, em DohaMais    novamente         de   de  de  representando</segment>
