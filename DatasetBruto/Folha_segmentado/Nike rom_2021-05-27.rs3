  <rst>
    <segment id="1">O rompimento entre Nike e Neymar</segment>
    <segment id="2">, em agosto do ano passado</segment>
    <segment id="3">, deu-</segment>
    <segment id="4">sese em meio a uma investigação sobre um suposto ataque sexual do jogador</segment>
    <segment id="5">, publicou The Wall Street Journal e confirmou a Folha.</segment>
    <segment id="6">Uma funcionária da empresa acusa o atleta de ter tentado forçá-la a praticar sexo oral</segment>
    <segment id="7">, o que é negado por ele.</segment>
    <segment id="8">A mulher diz ter relatado o suposto incidente a amigos e colegas em 2016.</segment>
    <segment id="9">De acordo com documentos obtidos pelo jornal norte-americano</segment>
    <segment id="10">, ela protocolou em 2018 uma reclamação formal</segment>
    <segment id="11">, que passou a ser investigada pela empresa de material esportivo.</segment>
    <segment id="12">A Nike explicou</segment>
    <segment id="13">, segundo o diário</segment>
    <segment id="14">, que Neymar não cooperou com essa apuração e por isso teve o contrato encerrado.</segment>
    <segment id="15">Fontes próximas ao jogador disseram à Folha que a acusação já era conhecida por ele e seu pai.</segment>
    <segment id="16">Foi por orientação de advogados contratados pelo atleta que ele decidiu</segment>
    <segment id="17">sese recusar a colaborar com a investigação.</segment>
    <segment id="18">A trajetória de Neymar no PSGMais    novamente         de   de  de  representando um</segment>
    <segment id="19">A funcionária</segment>
    <segment id="20">, que não teve a identidade revelada</segment>
    <segment id="21">, afirma que o</segment>
    <segment id="22">casocaso</segment>
    <segment id="23">sese deu em junho de 2016</segment>
    <segment id="24">, quando o atacante esteve em Nova York para uma campanha publicitária com a participação de Michael Jordan.</segment>
    <segment id="25">Segundo ela</segment>
    <segment id="26">, foi no hotel em que estava hospedado o jogador que ocorreu o ataque sexual.</segment>
    <segment id="27">Naquela ocasião</segment>
    <segment id="28">, a mulher trabalhou na logística do encontro entre o craque do futebol e o do basquete.</segment>
    <segment id="29">Até hoje empregada pela Nike</segment>
    <segment id="30">, ela disse ter decidido apresentar sua queixa em 2018 quando outras trabalhadoras da empresa decidiram</segment>
    <segment id="31">sese manifestar</segment>
    <segment id="32">, apontando casos de abuso e discriminação.</segment>
    <segment id="33">De acordo com os documentos obtidos por The Wall Street Journal</segment>
    <segment id="34">, a Nike contratou advogados da firma Cooley LLP para conduzir uma investigação a partir de 2019 e deixou de usar a imagem do brasileiro em novas campanhas.</segment>
    <segment id="35">Como não teria havido cooperação do jogador</segment>
    <segment id="36">, a empresa finalizou o contrato e suspendeu a investigação.</segment>
    <segment id="37">Neymar nega as acusações - Franck Fife - 23.mai.21/AFP“A Nike encerrou seu relacionamento com o atleta</segment>
    <segment id="38">porque</segment>
    <segment id="39">porque ele</segment>
    <segment id="40">sese recusou a cooperar de boa-fé na investigação a respeito das alegações feitas pela funcionária”</segment>
    <segment id="41">, afirmou ao jornal Hilary Crane</segment>
    <segment id="42">, conselheira geral da Nike.</segment>
    <segment id="43">Neymar</segment>
    <segment id="44">, 29, foi ligado à Nike dos 13 aos 28 anos.</segment>
    <segment id="45">Na ocasião do rompimento</segment>
    <segment id="46">, a empresa norte-americana não apresentou justificativas para o término do contrato</segment>
    <segment id="47">, que tinha previsão de duração por mais oito anos.</segment>
    <segment id="48">Hoje, o atleta tem acordo de patrocínio com a Puma</segment>
    <segment id="49">, que preferiu não</segment>
    <segment id="50">sese manifestar sobre o</segment>
    <segment id="51">casocaso.</segment>
    <segment id="52">A Folha entrou em contato também com os representantes do atacante</segment>
    <segment id="53">, que reiteraram sua inocência.</segment>
    <segment id="54">Seu pai</segment>
    <segment id="55">, Neymar da Silva Santos</segment>
    <segment id="56">, disse que a acusação apareceu por este motivo: “</segment>
    <segment id="57">Simplesmente</segment>
    <segment id="58">porque</segment>
    <segment id="59">porque saímos da Nike”.</segment>
    <segment id="60">“</segment>
    <segment id="61">Neymar não tem nem ideia de quem é a moça”</segment>
    <segment id="62">, afirmou</segment>
    <segment id="63">, aos berros</segment>
    <segment id="64">, exaltado.</segment>
    <segment id="65">“Como pode sair uma notícia dessas?</segment>
    <segment id="66">Fomos surpreendidos por algo que teria acontecido em 2016.</segment>
    <segment id="67">É muito estranho tudo isso agora.</segment>
    <segment id="68">Claro que isso partiu da Nike depois da nossa saída”</segment>
    <segment id="69">, acrescentou Santos.</segment>
    <segment id="70">“</segment>
    <segment id="71">Todos os que saem da Nike são acusados assim.</segment>
    <segment id="72">É muito estranho.</segment>
    <segment id="73">Se a Nike quer chantagem</segment>
    <segment id="74">, armação</segment>
    <segment id="75">, vamos para cima da Nike</segment>
    <segment id="76">, então.</segment>
    <segment id="77">Se aconteceu em 2016</segment>
    <segment id="78">, por que só agora?</segment>
    <segment id="79">O Neymar nem sabe quem é a moça.</segment>
    <segment id="80">Estamos tranquilos”</segment>
    <segment id="81">, concluiu o pai do jogador.</segment>
    <segment id="82">No momento da ruptura do contrato</segment>
    <segment id="83">, havia o entendimento de que o</segment>
    <segment id="84">casocaso estava encerrado ali e não ganharia publicidade.</segment>
    <segment id="85">A divulgação da investigação pegou o atacante de surpresa e causou irritação.</segment>
    <segment id="86">O assunto incomoda também</segment>
    <segment id="87">porque</segment>
    <segment id="88">porque a imagem do craque já havia sido arranhada por uma acusação de estupro</segment>
    <segment id="89">, em 2019.</segment>
    <segment id="90">Naquele ano</segment>
    <segment id="91">, portanto antes da rescisão do contrato com o Nike</segment>
    <segment id="92">, a brasileira Najila Trindade disse ter sido estuprada pelo atleta.</segment>
    <segment id="93">Na ocasião</segment>
    <segment id="94">, Neymar também negou a acusação</segment>
    <segment id="95">, e a Polícia Civil de São Paulo acabou arquivando o inquérito.</segment>
    <segment id="96">NEWSLETTER JURÍDICAReceba no seu email boletins com notícias exclusivas</segment>
    <segment id="97">, análise e opinião sobre assuntos jurídicos</segment>
    <segment id="98">;</segment>
    <segment id="99">inscreva-seAssine aqui as newsletters</segment>
    <segment id="100">Folhajus (exclusiva para assinantes) e Folhajus dia (aberta a não assinantes)</segment>
    <segment id="101">A Folha procurou a empresa norte-americana.</segment>
    <segment id="102">Em nota</segment>
    <segment id="103">, a companhia confirma a acusação de sua funcionária e afirma que a investigação foi inconclusiva.</segment>
    <segment id="104">"</segment>
    <segment id="105">A Nike encerrou seu vínculo com o atleta</segment>
    <segment id="106">porque</segment>
    <segment id="107">porque ele</segment>
    <segment id="108">sese recusou a cooperar com a investigação.</segment>
    <segment id="109">"</segment>
    <segment id="110">A empresa ainda acrescentou que a funcionária só abordou o episódio em 2018 e que teria pedido a investigação apenas no ano seguinte.</segment>
    <segment id="111">"</segment>
    <segment id="112">Os fatos que surgiram não permitiram que nós nos pronunciássemos substancialmente sobre o assunto.</segment>
    <segment id="113">Seria inapropriado para a Nike fazer uma acusação sem substância em fatos.</segment>
    <segment id="114">"  "</segment>
    <segment id="115">Continuamos a respeitar a confidencialidade da funcionária e reconhecemos que tem sido uma experiência longa e difícil para ela"</segment>
    <segment id="116">, completa.</segment>
  </rst>
</analysis>