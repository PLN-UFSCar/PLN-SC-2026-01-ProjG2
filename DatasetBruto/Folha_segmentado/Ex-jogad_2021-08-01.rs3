  <rst>
    <segment id="1">A ginasta Rebeca Andrade</segment>
    <segment id="2">, 22, conquistou a segunda medalha de ouro do Brasil nos Jogos Olímpicos de Tóquio-2020.</segment>
    <segment id="3">A prata ficou com a norte-americana Mykayla Skinner</segment>
    <segment id="4">, e o bronze foi para a coreana Seojeong Yeo.</segment>
    <segment id="5">A atleta já havia ganhado uma medalha de prata no individual geral</segment>
    <segment id="6">, o que lhe rendeu elogios da multicampeã romena Nadia Comaneci.</segment>
    <segment id="7">O histórico desempenho da brasileira vem após três cirurgias no joelho e uma longa e difícil recuperação.</segment>
    <segment id="8">Além de sua competência</segment>
    <segment id="9">, o caminho para o ouro contou com a desistência da grande estrela olímpica Simone Biles</segment>
    <segment id="10">, que resolveu não disputar as finais para cuidar de sua saúde mental.</segment>
    <segment id="11">Rebeca Andrade posa com medalha de ouro do salto na ginástica artística feminina - Loic VENANCE/AFPNas redes sociais</segment>
    <segment id="12">, atletas e famosos celebraram o triunfo de Rebeca.</segment>
    <segment id="13">O craque Neymar</segment>
    <segment id="14">, do Paris Saint-Germain</segment>
    <segment id="15">, mostrou que tem acompanhado de perto as Olimpíadas</segment>
    <segment id="16">, mesmo sem fazer parte da equipe de André Jardine.</segment>
    <segment id="17">Ele, que já havia comentado as outras medalhas conquistadas pelo Brasil</segment>
    <segment id="18">, também aplaudiu o ouro de Rebeca.</segment>
    <segment id="19">O jogador Richarlison</segment>
    <segment id="20">, 24, que joga pela seleção masculina de futebol</segment>
    <segment id="21">, brincou com o fato de possuir o mesmo sobrenome da ginasta.</segment>
    <segment id="22">Ainda entre os futebolistas</segment>
    <segment id="23">, o jogador Igor Julião</segment>
    <segment id="24">, que trocou recentemente o Fluminense pelo Vizela</segment>
    <segment id="25">, de Portugal</segment>
    <segment id="26">, pediu que a estátua de Borba Gato</segment>
    <segment id="27">, recentemente queimada em São Paulo</segment>
    <segment id="28">, fosse substituída por uma de Rebeca Andrade.</segment>
    <segment id="29">Clube de Rebeca</segment>
    <segment id="30">, o Flamengo também comemorou a medalha de ouro.</segment>
    <segment id="31">"É simplesmente impossível ver esse sorriso aberto e não</segment>
    <segment id="32">sese emocionar"</segment>
    <segment id="33">, publicou a conta oficial da agremiação rubro-negra.</segment>
    <segment id="34">A modelo Pathy Dejesus chamou Rebeca de "rainha da ginástica olímpica" e avisou: "calma</segment>
    <segment id="35">, que amanhã tem mais".</segment>
    <segment id="36">Nesta segunda (2)</segment>
    <segment id="37">, a ginasta vai disputar a final do solo e tem chances de conquistar a sua terceira medalha em Tóquio.</segment>
    <segment id="38">Prefeito do Rio de Janeiro</segment>
    <segment id="39">, Eduardo Paes também publicou sobre o triunfo.</segment>
    <segment id="40">O ator e comediante Marcelo Adnet comemorou a conquista no Twitter.</segment>
    <segment id="41">As cantoras MC Rebecca e Gabily também demonstraram orgulho pela vitória da atleta de Guarulhos nas redes sociais.</segment>
    <segment id="42">A tradicional escola de samba Portela</segment>
    <segment id="43">, do Rio de Janeiro</segment>
    <segment id="44">, deu parabéns à campeã.</segment>
    <segment id="45">Rebeca Andrade conquista medalha de ouro no salto   novamente         de   de  de  representando um</segment>
  </rst>
</analysis>