  <rst>
    <segment id="1">Em busca de material sobre o futebol de outros tempos</segment>
    <segment id="2">, descubro números de 1958 da revista Manchete Esportiva</segment>
    <segment id="3">, sobre a preparação da seleção brasileira para a Copa do Mundo daquele ano</segment>
    <segment id="4">, na Suécia.</segment>
    <segment id="5">E vejo as reportagens sobre os exames dentários dos jogadores</segment>
    <segment id="6">, ordenados pela CBF</segment>
    <segment id="7">, então CBD.</segment>
    <segment id="8">Aquilo era uma novidade.</segment>
    <segment id="9">Formou-</segment>
    <segment id="10">sese uma legião de dentistas</segment>
    <segment id="11">, e os 33 convocados iniciais</segment>
    <segment id="12">, um a um</segment>
    <segment id="13">, com ou sem medo</segment>
    <segment id="14">, sentaram-</segment>
    <segment id="15">sese na cadeira e abriram a boca.</segment>
    <segment id="16">Foi um terror: em duas semanas</segment>
    <segment id="17">, os dentistas tiveram de meter a broca em 470 dentes</segment>
    <segment id="18">, quase 15 por jogador</segment>
    <segment id="19">, e fazer 32 extrações —Oreco</segment>
    <segment id="20">, lateral do Corinthians</segment>
    <segment id="21">, o recordista</segment>
    <segment id="22">, com sete.</segment>
    <segment id="23">Era este o estado dentário médio dos jogadores no Brasil.</segment>
    <segment id="24">Craques da seleção</segment>
    <segment id="25">, ídolos de seus times e a maioria com menos de 25 anos</segment>
    <segment id="26">, saíam em close nas capas de revista com espetaculares falhas dentárias —</segment>
    <segment id="27">comocomo Vavá</segment>
    <segment id="28">, artilheiro do Vasco</segment>
    <segment id="29">, Telê</segment>
    <segment id="30">, motor do Fluminense</segment>
    <segment id="31">, e Garrincha</segment>
    <segment id="32">, que você sabe quem foi—</segment>
    <segment id="33">, e ninguém via nada demais nisso .</segment>
    <segment id="34">Era um reflexo do estado dentário médio da população</segment>
    <segment id="35">, assim</segment>
    <segment id="36">comocomo do salário médio dessa mesma população.</segment>
    <segment id="37">Estávamos longe das grandes fortunas no futebol</segment>
    <segment id="38">, e muitos jogadores</segment>
    <segment id="39">, mesmo os bem pagos</segment>
    <segment id="40">, tinham de fazer bicos por fora.</segment>
    <segment id="41">Pinheiro</segment>
    <segment id="42">, capitão do Fluminense</segment>
    <segment id="43">, era corretor de imóveis</segment>
    <segment id="44">, passava o dia ralando no asfalto</segment>
    <segment id="45">;</segment>
    <segment id="46">Oswaldo Baliza</segment>
    <segment id="47">, goleiro do Botafogo</segment>
    <segment id="48">, era caixeiro de armazém</segment>
    <segment id="49">; Bellini</segment>
    <segment id="50">, senhor da grande área do Vasco e da seleção</segment>
    <segment id="51">, vendia sapatos em Copacabana</segment>
    <segment id="52">, em sociedade com Fernando</segment>
    <segment id="53">, goleiro do Flamengo.</segment>
    <segment id="54">As coisas mudaram.</segment>
    <segment id="55">Os jogadores de hoje</segment>
    <segment id="56">, mesmo da Série B</segment>
    <segment id="57">, ostentam teclados esculpidos em alabastro.</segment>
    <segment id="58">E a razão é simples: por maior que ainda seja a desigualdade no futebol</segment>
    <segment id="59">, sua média salarial ficou muito maior que a do brasileiro.</segment>
    <segment id="60">E isso</segment>
    <segment id="61">sese reflete nos dentes.</segment>
    <segment id="62">Os cracões agora podem</segment>
    <segment id="63">sese orgulhar de suas bocas de cristal</segment>
    <segment id="64">, masmas o grosso dos brasileiros</segment>
    <segment id="65">, que não vê a cor da bola</segment>
    <segment id="66">, continua desdentado.</segment>
    <segment id="67">Capas da revista Manchete Esportiva dos anos 50 com fotos de Vavá</segment>
    <segment id="68">, Telê e Garrincha- Heloisa Seixas</segment>
  </rst>
</analysis>