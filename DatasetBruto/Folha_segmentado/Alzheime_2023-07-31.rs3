  <rst>
    <segment id="1">Primeiro</segment>
    <segment id="2">, pare de rolar a tela.</segment>
    <segment id="3">Agora, inspire lentamente.</segment>
    <segment id="4">Concentre-</segment>
    <segment id="5">sese nos seus pulmões</segment>
    <segment id="6">sese enchendo de ar e conte até cinco.</segment>
    <segment id="7">Agora, expire</segment>
    <segment id="8">, da mesma forma lenta e controlada</segment>
    <segment id="9">, contando até cinco novamente.</segment>
    <segment id="10">Em apenas 10 segundos</segment>
    <segment id="11">, você pode ter ficado um pouco mais relaxado ou concentrado.</segment>
    <segment id="12">Siga esta prática por 20 minutos algumas vezes por semana e você pode colher não só o benefício de</segment>
    <segment id="13">sese sentir mais calmo.</segment>
    <segment id="14">Você também pode</segment>
    <segment id="15">sese proteger contra diversas doenças - e</segment>
    <segment id="16">, segundo um estudo recente</segment>
    <segment id="17">, até mesmo contra o Alzheimer.</segment>
    <segment id="18">Exercícios respiratórios podem trazer uma série de benefícios - Getty Images via BBC</segment>
    <segment id="19">Os benefícios dos exercícios de respiração são reconhecidos há milênios.</segment>
    <segment id="20">Nas últimas décadas</segment>
    <segment id="21">, estudos científicos parecem confirmar o que muitas culturas</segment>
    <segment id="22">, principalmente na Ásia</segment>
    <segment id="23">, vêm recomendando há muito tempo: a respiração consciente pode ajudar a combater uma série de condições de saúde</segment>
    <segment id="24">, incluindo hipertensão</segment>
    <segment id="25">, estresse</segment>
    <segment id="26">, ansiedade e até dores crônicas.</segment>
    <segment id="27">No estudo mais recente</segment>
    <segment id="28">, pesquisadores analisaram os biomarcadores do plasma sanguíneo associados ao aumento do risco de desenvolvimento de Alzheimer</segment>
    <segment id="29">, particularmente a beta-amiloide 40 e 42.</segment>
    <segment id="30">Eles instruíram metade dos 108 participantes do estudo a tentar imaginar-</segment>
    <segment id="31">sese em um lugar calmo</segment>
    <segment id="32">, mentalizando uma cena tranquila</segment>
    <segment id="33">, ouvindo sons relaxantes e fechando os olhos - basicamente</segment>
    <segment id="34">, praticando meditação mindfulness (atenção plena).</segment>
    <segment id="35">O objetivo era reduzir as oscilações dos seus batimentos cardíacos</segment>
    <segment id="36">, incentivando batimentos mais estáveis e consistentes.</segment>
    <segment id="37">Pranayamas: Quatro exercícios de respiração para acalmar rapidamenteMais    novamente         de   de  de  representando um</segment>
    <segment id="38">O outro grupo acompanhou um exercício de respiração na tela do computador.</segment>
    <segment id="39">Quando um quadrado subia ao longo de cinco segundos</segment>
    <segment id="40">, eles inspiravam</segment>
    <segment id="41">;</segment>
    <segment id="42">quando ele caía por cinco segundos</segment>
    <segment id="43">, eles expiravam.</segment>
    <segment id="44">Estudos indicam que este tipo de respiração lenta e profunda aumenta as oscilações dos batimentos cardíacos</segment>
    <segment id="45">, fazendo com que os intervalos entre os batimentos sejam mais variáveis (ou seja</segment>
    <segment id="46">, causando maior "variabilidade da frequência cardíaca").</segment>
    <segment id="47">Os dois grupos praticaram a técnica solicitada duas vezes por dia</segment>
    <segment id="48">, por 20 a 40 minutos cada vez</segment>
    <segment id="49">, durante cinco semanas.</segment>
    <segment id="50">Quando os pesquisadores analisaram as amostras de sangue dos participantes após quatro semanas de prática</segment>
    <segment id="51">, os resultados foram uma "surpresa"</segment>
    <segment id="52">, segundo Mara Mather</segment>
    <segment id="53">, professora de gerontologia</segment>
    <segment id="54">, psicologia e engenharia biomédica da Universidade do Sul da Califórnia</segment>
    <segment id="55">, nos Estados Unidos</segment>
    <segment id="56">, uma das autoras do estudo.</segment>
    <segment id="57">Os exercícios respiratórios</segment>
    <segment id="58">, destinados a aumentar a variabilidade da frequência cardíaca</segment>
    <segment id="59">, reduziram os níveis de beta-amiloide</segment>
    <segment id="60">, enquanto os exercícios de mindfulness</segment>
    <segment id="61">, que reduziam a variabilidade da frequência cardíaca</segment>
    <segment id="62">, aumentaram os níveis da proteína.</segment>
    <segment id="63">Embora nenhum fator isolado tenha sido identificado</segment>
    <segment id="64">comocomo causador do Alzheimer</segment>
    <segment id="65">, sabe-</segment>
    <segment id="66">sese que aglomerados de proteína beta-amiloide</segment>
    <segment id="67">, conhecidos</segment>
    <segment id="68">comocomo "placas"</segment>
    <segment id="69">, são uma das principais características da doença.</segment>
    <segment id="70">Certos tipos desta proteína podem ser particularmente tóxicos quando</segment>
    <segment id="71">sese acumulam no interior das células cerebrais</segment>
    <segment id="72">, gerando danos que afetam suas funções normais e levando à sua morte.</segment>
    <segment id="73">Mather e sua equipe não esperavam que os níveis de beta-amiloide fossem "afetados com tanta intensidade".</segment>
    <segment id="74">E não só em adultos mais idosos</segment>
    <segment id="75">, que talvez já fossem mais suscetíveis a apresentar níveis mais altos de beta-amiloide.</segment>
    <segment id="76">"</segment>
    <segment id="77">Os efeitos foram significativos em adultos mais jovens e mais idosos"</segment>
    <segment id="78">, diz ela.</segment>
    <segment id="79">"</segment>
    <segment id="80">Esta é uma descoberta fascinante</segment>
    <segment id="81">porque</segment>
    <segment id="82">porque</segment>
    <segment id="83">, em adultos saudáveis</segment>
    <segment id="84">, níveis mais baixos de beta-amiloide no plasma são associados ao menor risco de desenvolver Alzheimer com mais idade.</segment>
    <segment id="85">"  "</segment>
    <segment id="86">A respiração lenta pode trazer benefícios não apenas para o bem-estar emocional</segment>
    <segment id="87">, masmas também para melhorar os biomarcadores associados ao Alzheimer"</segment>
    <segment id="88">, acrescenta.</segment>
    <segment id="89">Pessoas ao redor do mundo praticam exercícios respiratórios</segment>
    <segment id="90">, buscando obter uma série de benefícios - Getty Images via BBCPor quê?</segment>
    <segment id="91">Os pesquisadores não têm certeza de qual seria a razão exata por trás destes resultados.</segment>
    <segment id="92">Mas uma hipótese é que a respiração lenta e consciente pode simular alguns dos benefícios do sono profundo que</segment>
    <segment id="93">, segundo pesquisas</segment>
    <segment id="94">, pode eliminar resíduos neurotóxicos do cérebro e do sistema nervoso com mais rapidez.</segment>
    <segment id="95">E o acúmulo destes resíduos</segment>
    <segment id="96">, aparentemente</segment>
    <segment id="97">, influencia o desenvolvimento do Alzheimer.</segment>
    <segment id="98">O principal fator parece ser</segment>
    <segment id="99">comocomo cada exercício afetou a variabilidade da frequência cardíaca</segment>
    <segment id="100">, que reflete o nível de flutuação existente entre os batimentos.</segment>
    <segment id="101">Pesquisas indicaram que a variabilidade da frequência cardíaca é uma boa medida do funcionamento do sistema nervoso e</segment>
    <segment id="102">, portanto</segment>
    <segment id="103">, é um bom indicador da saúde em geral e de diversas condições específicas</segment>
    <segment id="104">, que variam desde a depressão e o estresse crônico até infecções virais e sepse.</segment>
    <segment id="105">Curiosamente</segment>
    <segment id="106">, o aumento da variabilidade (ou seja</segment>
    <segment id="107">, um padrão menos consistente) parece ser muito mais saudável</segment>
    <segment id="108">, talvez</segment>
    <segment id="109">porque</segment>
    <segment id="110">porque demonstre a capacidade do corpo de</segment>
    <segment id="111">sese adaptar aos fatores de estresse.</segment>
    <segment id="112">Independentemente de qual seja o mecanismo exato</segment>
    <segment id="113">, Mather afirma que a prática regular da respiração lenta e consciente aparentemente pode beneficiar a maioria das pessoas.</segment>
    <segment id="114">"</segment>
    <segment id="115">Não sabemos ainda qual é a dose ideal"</segment>
    <segment id="116">, ela explica.  "</segment>
    <segment id="117">Mas provavelmente não precisa ser todos os dias.</segment>
    <segment id="118">Meu palpite no momento é que 20 minutos</segment>
    <segment id="119">, 4-5 vezes por semana</segment>
    <segment id="120">, trariam benefícios.</segment>
    <segment id="121">"</segment>
    <segment id="122">O estudo não comparou as diferentes técnicas de respiração</segment>
    <segment id="123">porque</segment>
    <segment id="124">porque os pesquisadores ainda não sabem qual tipo de padrão de respiração pode ser mais eficaz.</segment>
    <segment id="125">"</segment>
    <segment id="126">O que sabemos é que respirar em qualquer velocidade entre 9 e 14 segundos por respiração</segment>
    <segment id="127">, aumentando ao máximo as oscilações dos batimentos cardíacos do indivíduo</segment>
    <segment id="128">, reduziu os níveis de beta-amiloide no plasma de forma eficaz"</segment>
    <segment id="129">, afirma Mather.</segment>
    <segment id="130">A pesquisa ainda precisa ser repetida com um número maior de pacientes para confirmar</segment>
    <segment id="131">sese pode ser observado um efeito de longo prazo significativo.</segment>
    <segment id="132">Alguns cientistas também manifestaram dúvidas sobre quão confiáveis e eficazes as técnicas de respiração podem ser em comparação a tratamentos medicamentosos.</segment>
    <segment id="133">Mas este estudo está longe de ser o único a constatar os benefícios dos exercícios respiratórios para a saúde.</segment>
    <segment id="134">Pesquisas mostram</segment>
    <segment id="135">, por exemplo</segment>
    <segment id="136">, que os exercícios respiratórios podem reduzir a pressão arterial de pessoas com hipertensão</segment>
    <segment id="137">, ajudam a aliviar os sintomas da ansiedade e depressão e combatem a insônia.</segment>
    <segment id="138">E uma recente meta-análise concluiu que os exercícios de respiração podem diminuir o estresse e melhorar a saúde mental.</segment>
    <segment id="139">Com isso</segment>
    <segment id="140">, os exercícios respiratórios estão começando a ir além das aulas de ioga e meditação</segment>
    <segment id="141">, invadindo retiros corporativos e até escolas.</segment>
    <segment id="142">O prefeito de Nova York</segment>
    <segment id="143">, Eric Adams</segment>
    <segment id="144">, anunciou recentemente que todas as escolas públicas da cidade vão ter que oferecer sessões diárias de respiração consciente aos alunos.</segment>
    <segment id="145">Para o prefeito</segment>
    <segment id="146">, "uma existe ciência por trás da respiração" -</segment>
    <segment id="147">e muitos pesquisadores estão começando a concordar com ele.</segment>
    <segment id="148">Esperança no combate à beta-amiloide</segment>
    <segment id="149">Recentemente</segment>
    <segment id="150">, um teste global apresentou um novo medicamento promissor</segment>
    <segment id="151">, chamado donanemabe</segment>
    <segment id="152">, para ajudar a eliminar o acúmulo de proteína beta-amiloide</segment>
    <segment id="153">, associada ao Alzheimer.</segment>
    <segment id="154">A droga foi descrita</segment>
    <segment id="155">comocomo um "marco" na luta contra o Alzheimer</segment>
    <segment id="156">, por aparentemente retardar em cerca de um terço o avanço da doença.</segment>
    <segment id="157">Os resultados dos estudos indicam que a remoção das placas de beta-amiloide do cérebro pode alterar o curso da doença e ajudar os pacientes a preservar grande parte da sua rotina diária.</segment>
  </rst>
</analysis>