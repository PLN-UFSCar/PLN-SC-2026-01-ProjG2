  <rst>
    <segment id="1">De volta à rua do Ouvidor</segment>
    <segment id="2">, palco mais elegante daquela que fora a sua cidade</segment>
    <segment id="3">, o fantasma de Machado de Assis horrorizou-</segment>
    <segment id="4">sese com "postes sem luz e montanhas de lixo</segment>
    <segment id="5">, entre vitrines quebradas e bueiros sem tampa de onde brotavam ratazanas do tamanho de cães".</segment>
    <segment id="6">Além da miséria</segment>
    <segment id="7">, com pessoas vagando</segment>
    <segment id="8">comocomo zumbis e dormindo amontoadas nas calçadas</segment>
    <segment id="9">, o escritor presenciou assassinatos e estupros.</segment>
    <segment id="10">Tudo no Centro do Rio</segment>
    <segment id="11">, "o lugar onde —assim</segment>
    <segment id="12">comocomo não</segment>
    <segment id="13">sese pode acender uma vela no vácuo— os seres humanos não conseguem conceber a ideia de Deus".</segment>
    <segment id="14">A ação de "</segment>
    <segment id="15">A Vida Futura"</segment>
    <segment id="16">, de Sérgio Rodrigues —um romance raro</segment>
    <segment id="17">, que consegue divertir mesmo tratando de "cousas" duras—</segment>
    <segment id="18">, sese desenrola em 2020</segment>
    <segment id="19">, com a Covid em alta.</segment>
    <segment id="20">Se fosse hoje não haveria diferença no panorama nem na desgraça.</segment>
    <segment id="21">O Centro</segment>
    <segment id="22">, região que mais sofreu com a pandemia</segment>
    <segment id="23">, parece condenado a não recuperar a vida de antes.</segment>
    <segment id="24">Para se</segment>
    <segment id="25">se ter uma ideia</segment>
    <segment id="26">, não há mais engarrafamentos na avenida Antônio Carlos</segment>
    <segment id="27">, onde</segment>
    <segment id="28">sese levava até meia hora para atravessar o trecho em frente ao Fórum.</segment>
    <segment id="29">É como</segment>
    <segment id="30">como se</segment>
    <segment id="31">se estivéssemos no meio de um cenário abandonado</segment>
    <segment id="32">, com lojas fechadas e quase ninguém nos becos silenciosos.</segment>
    <segment id="33">À noite e nos fins de semana</segment>
    <segment id="34">, sem policiamento</segment>
    <segment id="35">, andar por ali é um desafio de morte.</segment>
    <segment id="36">Colunas e BlogsReceba no seu email uma seleção de colunas e blogs da Folha</segment>
    <segment id="37">; exclusiva para assinantes.</segment>
    <segment id="38">Carregando...</segment>
    <segment id="39">Idealizado pelo urbanista Washington Fajardo —que</segment>
    <segment id="40">sese desentendeu com Eduardo Paes e deixou a prefeitura—</segment>
    <segment id="41">, o programa Reviver Centro completou um ano em julho e ninguém notou.</segment>
    <segment id="42">Não há bulício de novos moradores ou barulho de trabalhadores</segment>
    <segment id="43">;</segment>
    <segment id="44">o supermercado que abriu na rua Sete de Setembro está às moscas.</segment>
    <segment id="45">Os poucos camelôs</segment>
    <segment id="46">, antes numerosos e em toda parte</segment>
    <segment id="47">, concentram-</segment>
    <segment id="48">sese nas saídas do metrô</segment>
    <segment id="49">, oferecendo mariolas e paçoquinhas.</segment>
    <segment id="50">Até a parada militar do Dia da Independência</segment>
    <segment id="51">, que se</segment>
    <segment id="52">se realiza há décadas na avenida Presidente Vargas</segment>
    <segment id="53">, foi desmoralizada por Bolsonaro</segment>
    <segment id="54">, que quer levar os tanques fumacentos para a orla de Copacabana.</segment>
    <segment id="55">Nem os golpistas querem o Centro.</segment>
    <segment id="56">A travessa do Comércio</segment>
    <segment id="57">, que acaba na rua do Ouvidor</segment>
    <segment id="58">, no centro do Rio de Janeiro - Alvaro Costa e Silva/Folhapress</segment>
  </rst>
</analysis>