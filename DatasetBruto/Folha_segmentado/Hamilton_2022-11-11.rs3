  <rst>
    <segment id="1">O piloto Lewis Hamilton</segment>
    <segment id="2">, 37, declarou seu amor ao Brasil e afirmou que</segment>
    <segment id="3">, de alguma forma</segment>
    <segment id="4">, sente que também representa muitos brasileiros.</segment>
    <segment id="5">O inglês está no país para a disputa do GP São Paulo de F1 e recebeu o título de cidadão honorário.</segment>
    <segment id="6">Em entrevista à Folha</segment>
    <segment id="7">, o piloto disse que há uma "real falta de representatividade" em diversos setores da sociedade.</segment>
    <segment id="8">"</segment>
    <segment id="9">Para mim</segment>
    <segment id="10">, quando criança</segment>
    <segment id="11">, não havia super-heróis com a nossa cor.</segment>
    <segment id="12">Não havia muitas grandes figuras reais na TV.</segment>
    <segment id="13">Claro que você tem pessoas</segment>
    <segment id="14">comocomo Muhammad Ali</segment>
    <segment id="15">, masmas eles estavam tão longe.</segment>
    <segment id="16">"</segment>
    <segment id="17">Clique aqui e leia a entrevista na íntegra   Hamilton afirmou acreditar que muitos brasileiros</segment>
    <segment id="18">sese enxergam nele.</segment>
    <segment id="19">"</segment>
    <segment id="20">Acho, então</segment>
    <segment id="21">, que o brasileiro vê em mim alguém parecido</segment>
    <segment id="22">, talvez com valores parecidos</segment>
    <segment id="23">, que gosta de pensar em ser uma boa pessoa</segment>
    <segment id="24">, de se</segment>
    <segment id="25">se importar com mais do que apenas correr.</segment>
    <segment id="26">E acho que é a paixão que tenho pelo que faço.</segment>
    <segment id="27">Talvez isso</segment>
    <segment id="28">sese conecte com eles.</segment>
    <segment id="29">Eu viajo o mundo todo e tanta gente me pergunta o tempo todo: 'você é brasileiro?</segment>
    <segment id="30">' (risos).</segment>
    <segment id="31">"</segment>
    <segment id="32">Lewis Hamilton recebe o título de cidadão brasileiro no Congresso</segment>
    <segment id="33">, em Brasília - Evaristo Sá - 7.nov.22/AFPEra</segment>
    <segment id="34">um desejo antigo do inglês conhecer mais a fundo as comunidades brasileiras.</segment>
    <segment id="35">"</segment>
    <segment id="36">Eu venho aqui há 15 anos.</segment>
    <segment id="37">Passo pelas favelas</segment>
    <segment id="38">, masmas nunca tinha entrado até hoje.</segment>
    <segment id="39">Eu não sabia</segment>
    <segment id="40">comocomo elas eram por dentro.</segment>
    <segment id="41">Agora eu vejo o trabalho que eles estão fazendo ajudando as crianças"</segment>
    <segment id="42">, afirmou o piloto.</segment>
    <segment id="43">Lewis Hamilton vence GP de São Paulo em InterlagosMais    novamente         de   de  de  representando um</segment>
  </rst>
