  <rst>
    <segment id="1">Eis aqui um tema que toca muitas de nós —literalmente</segment>
    <segment id="2">, inclusive.</segment>
    <segment id="3">A mim surgiu por obra e graça do mais fanfarrão dos algoritmos</segment>
    <segment id="4">, que criou uma playlist contendo canções inspiradas em amigas minhas.</segment>
    <segment id="5">Verdade seja dita</segment>
