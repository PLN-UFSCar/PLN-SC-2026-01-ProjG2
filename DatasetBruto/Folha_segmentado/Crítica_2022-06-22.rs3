  <rst>
    <segment id="1">Tudo em Todo Lugar ao Mesmo TempoQuando Estreia nesta quinta (23)Onde</segment>
    <segment id="2">Nos cinemasClassificação 14 anosElenco Michelle Yeoh</segment>
    <segment id="3">, Ke Huy Quan</segment>
    <segment id="4">, Jamie Lee CurtisProdução EUA</segment>
    <segment id="5">, 2022Direção Daniel Scheinert e Daniel KwanDesde "Matrix"</segment>
    <segment id="6">, o original</segment>
    <segment id="7">, de 1999</segment>
    <segment id="8">, muitos outros filmes</segment>
    <segment id="9">, séries</segment>
    <segment id="10">, livros e videogames</segment>
    <segment id="11">, fizeram uso do recurso do universo paralelo para contar suas histórias</segment>
    <segment id="12">, 99% das vezes com resultados ridículos.</segment>
    <segment id="13">"</segment>
    <segment id="14">Matrix</segment>
    <segment id="15">"</segment>
    <segment id="16">não foi o primeiro produto de cultura a apresentar esse conceito</segment>
    <segment id="17">, masmas o fez de maneira tão inovadora e atraente que praticamente inaugurou o multiverso</segment>
    <segment id="18">comocomo gênero.</segment>
    <segment id="19">Depois de duas sequências desastrosas lançadas em 2003</segment>
    <segment id="20">, no ano passado uma das diretoras originais</segment>
    <segment id="21">, Lana Wachowski</segment>
    <segment id="22">, lançou "Matrix</segment>
    <segment id="23">Resurrections</segment>
    <segment id="24">"</segment>
    <segment id="25">, muito superior aos dois filmes do começo deste século</segment>
    <segment id="26">, masmas ainda muito longe do impacto do primeiro longa.</segment>
    <segment id="27">Michelle Yeoh em cena do filme &amp;#</segment>
    <segment id="28">039;Tudo em Todo o Lugar ao Mesmo Tempo&amp;#039</segment>
    <segment id="29">; - Divulgação"Tudo em Todo Lugar ao Mesmo Tempo" é infinitamente menos pretensioso que a franquia capitaneada por Keanu Reeves</segment>
    <segment id="30">, e essa despretensão é o ingrediente mágico deste filme.</segment>
    <segment id="31">Além dela</segment>
    <segment id="32">, o humor palhaço do roteiro e a total falta de compromisso com a verossimilhança fazem deste um produto de entretenimento puro.</segment>
    <segment id="33">Não precisa entender tudo que acontece para</segment>
    <segment id="34">sese divertir com "</segment>
    <segment id="35">Tudo em Todo Lugar..." —ao contrário</segment>
    <segment id="36">, a bagunça é intencional.</segment>
    <segment id="37">Criado</segment>
    <segment id="38">, roteirizado e dirigido pela dupla que</segment>
    <segment id="39">sese apresenta</segment>
    <segment id="40">comocomo "The Daniels"</segment>
    <segment id="41">, formada por Daniel Kwan e Daniel Scheinert</segment>
    <segment id="42">, dois americanos de 30 e poucos anos</segment>
    <segment id="43">, responsáveis pela maravilha que é o filme "</segment>
    <segment id="44">Um Cadáver para Sobreviver"</segment>
    <segment id="45">, de 2016</segment>
    <segment id="46">, esse também é um longa original.</segment>
    <segment id="47">Não tem personagem conhecido</segment>
    <segment id="48">, não é baseado em história real</segment>
    <segment id="49">, nem em podcast blockbuster.</segment>
    <segment id="50">Como "</segment>
    <segment id="51">Um Cadáver"</segment>
    <segment id="52">, vencedor do prêmio de melhor direção no Festival Sundance no ano de seu lançamento —sobre um homem perdido numa ilha deserta</segment>
    <segment id="53">, vivido por Paul Dano</segment>
    <segment id="54">, que faz amizade com um morto que solta puns</segment>
    <segment id="55">, papel de Daniel Radcliffe—</segment>
    <segment id="56">, "</segment>
    <segment id="57">Tudo em Todo Lugar" tem nomes conhecidos no elenco fazendo papéis completamente diferentes de tudo que já fizeram.</segment>
    <segment id="58">Veja cenas de &amp;#</segment>
    <segment id="59">039;Tudo em Todo Lugar ao Mesmo Tempo&amp;#039</segment>
    <segment id="60">;, filme que mergulha no multiversoMais    novamente         de   de  de  representando um  Sim</segment>
    <segment id="61">, Michelle Yeoh luta várias vezes</segment>
    <segment id="62">, como</segment>
    <segment id="63">como fez no filme que a transformou numa estrela internacional em 2000</segment>
    <segment id="64">, "</segment>
    <segment id="65">O Tigre e o Dragão"</segment>
    <segment id="66">, de Ang Lee.</segment>
    <segment id="67">Mas a personagem dela nesta trama</segment>
    <segment id="68">, Evelyn Wang</segment>
    <segment id="69">, é o oposto disso —uma imigrante chinesa nos Estados Unidos amargurada com as obrigações que cumpre sem nenhum prazer.  Está entediada com o marido que</segment>
    <segment id="70">sese acha engraçado e que está pedindo o divórcio</segment>
    <segment id="71">, masmas nem nisso ela presta atenção.</segment>
    <segment id="72">Envergonhada com a filha lésbica</segment>
    <segment id="73">, estressada com tudo e com todos e tentando manter as aparências de que tudo vai bem para seu pai</segment>
    <segment id="74">, um velho mandão e ranzinza.</segment>
    <segment id="75">Evelyn chega ao ponto de ebulição na hora em que percebe que corre o risco de cair na malha fina</segment>
    <segment id="76">, quando entrega suas contas a Deirdre</segment>
    <segment id="77">, uma funcionária maléfica e insensível interpretada com óbvio deleite por Jamie Lee Curtis.</segment>
    <segment id="78">A atriz de 63 anos disse em entrevistas que</segment>
    <segment id="79">, durante as filmagens</segment>
    <segment id="80">, foi a primeira vez na vida que deixou sua barriga solta</segment>
    <segment id="81">, desde que tinha 11 anos de idade</segment>
    <segment id="82">, e percebeu que o abdômen plano era considerado vantajoso na estranha hierarquia da humanidade.</segment>
    <segment id="83">Em pleno embate entre Evelyn e Deirdre</segment>
    <segment id="84">, Waymond</segment>
    <segment id="85">, o marido bobalhão</segment>
    <segment id="86">, interpretado pelo ator vietnamita Ke Huy Quan</segment>
    <segment id="87">, de "</segment>
    <segment id="88">Os Goonies"</segment>
    <segment id="89">, faz a primeira de uma série de lutas inacreditáveis.</segment>
    <segment id="90">Usando sua pochete</segment>
    <segment id="91">comocomo arma</segment>
    <segment id="92">, aniquila todos os policiais que aparecem para levar Evelyn presa e explica para a mulher atônita que ela precisa ser treinada para</segment>
    <segment id="93">sese catapultar para universos paralelos e combater um demônio chamado Jobu Tupaki</segment>
    <segment id="94">, que só ela poderá eliminar</segment>
    <segment id="95">, restaurando</segment>
    <segment id="96">, assim</segment>
    <segment id="97">, a estabilidade do multiverso.</segment>
    <segment id="98">Pois é</segment>
    <segment id="99">, complexo.</segment>
    <segment id="100">Mas não deixe que essa explicação estapafúrdia desanime você.</segment>
    <segment id="101">Assim como</segment>
    <segment id="102">como outros filmes com premissas complicadas</segment>
    <segment id="103">, como</segment>
    <segment id="104">como "Brilho Eterno de uma Mente sem Lembranças"</segment>
    <segment id="105">, de 2004</segment>
    <segment id="106">, "Adaptação"</segment>
    <segment id="107">, de 2002</segment>
    <segment id="108">, ou mesmo a animação "Divertida Mente"</segment>
    <segment id="109">, de 2015</segment>
    <segment id="110">, esta é uma trama mais doce do que o seu resumo faz parecer.</segment>
    <segment id="111">MaratonarUm guia com dicas de filmes e séries para assistir no streamingCarregando...</segment>
    <segment id="112">E, no que realmente importa</segment>
    <segment id="113">, é uma história sobre uma família em conflito.</segment>
    <segment id="114">Um casal que</segment>
    <segment id="115">sese desinteressou um pelo outro</segment>
    <segment id="116">, uma mãe e uma filha que não</segment>
    <segment id="117">sese entendem mais</segment>
    <segment id="118">, um patriarca que ficou sem papel</segment>
    <segment id="119">masmas não sabe desempenhar nenhum outro</segment>
    <segment id="120">, imigrantes que</segment>
    <segment id="121">sese esforçam para vencer as barreiras do preconceito.</segment>
    <segment id="122">Agora também ficou parecendo que "</segment>
    <segment id="123">Tudo em Todo Lugar ao Mesmo Tempo" é um filme suave demais.</segment>
    <segment id="124">Não é.</segment>
    <segment id="125">Tem barulho o tempo todo</segment>
    <segment id="126">, cenas estroboscópicas e</segment>
    <segment id="127">, talvez</segment>
    <segment id="128">, uns 30 minutos a mais do que deveria.</segment>
  </rst>
</analysis>