  <rst>
    <segment id="1">A alta temporada em Santos</segment>
    <segment id="2">, no litoral paulista</segment>
    <segment id="3">, ganhará novos atrativos durante o verão.</segment>
    <segment id="4">Nesta sexta-feira (27)</segment>
    <segment id="5">, a prefeitura entrega a primeira fase das obras no bairro Ponta da Praia</segment>
    <segment id="6">, localizado na orla na cidade.</segment>
    <segment id="7">Desde o início do ano</segment>
    <segment id="8">, o trecho passa por amplo processo de reformas e modernização.</segment>
    <segment id="9">O investimento de pouco mais de R$ 130 milhões é custeado pela iniciativa privada por meio de compensação ao município exigida por lei e tem conclusão prevista para julho de 2020.</segment>
    <segment id="10">“</segment>
    <segment id="11">Podemos dizer que chegamos a 55% das obras hoje [sexta].</segment>
    <segment id="12">Entregamos a primeira etapa</segment>
    <segment id="13">, que é uma revitalização completa de um trecho muito importante.</segment>
    <segment id="14">Temos nova iluminação</segment>
    <segment id="15">, fonte interativa para as crianças</segment>
    <segment id="16">, bancos com espaço para conectar equipamentos USB e quiosques em funcionamento”</segment>
    <segment id="17">, disse à o prefeito Paulo Alexandre Barbosa (PSDB).</segment>
    <segment id="18">Verão em Santos terá novo trecho da orla da praia custeada por R$ 130 mil</segment>
    <segment id="19">; vista aérea (drone) das obras</segment>
    <segment id="20">-Credito Doug Fernandes/</segment>
    <segment id="21">Divulgação Prefeitura de Santos</segment>
    <segment id="22">O projeto visa transformar o lugar em uma referência para o turismo na cidade com a construção do novo Mercado do Peixe</segment>
    <segment id="23">, já em obras e com previsão de entrega para março</segment>
    <segment id="24">, e do CAT (Centro de Atividades Turísticas)</segment>
    <segment id="25">, espaço que será utilizado para feiras</segment>
    <segment id="26">, exposições</segment>
    <segment id="27">, convenções e shows.</segment>
    <segment id="28">O local terá heliponto e 367 vagas de estacionamento.</segment>
    <segment id="29">O projeto inclui</segment>
    <segment id="30">, também</segment>
    <segment id="31">, a criação de uma praça com espelho d’água</segment>
    <segment id="32">, rampas náuticas e um mirante com vista para o mar.</segment>
    <segment id="33">A ponte Edgard Perdigão</segment>
    <segment id="34">, utilizada por pequenas embarcações</segment>
    <segment id="35">, e o Deck do Pescador</segment>
    <segment id="36">, atingido por constantes ressacas</segment>
    <segment id="37">, passam por reformas e ampliação.</segment>
    <segment id="38">“Há muitos benefícios que estimamos antes e depois.</segment>
    <segment id="39">Ao todo</segment>
    <segment id="40">, são mais de 600 pessoas trabalhando.</segment>
    <segment id="41">Depois</segment>
    <segment id="42">, acreditamos que Santos pode entrar em outro patamar pelo turismo”</segment>
    <segment id="43">, afirmou Barbosa.</segment>
    <segment id="44">Para a inauguração</segment>
    <segment id="45">, a principal atração será o show do grupo Demônios da Garoa.</segment>
    <segment id="46">Artistas locais também</segment>
    <segment id="47">sese apresentarão ao longo do trecho.</segment>
    <segment id="48">Para as crianças</segment>
    <segment id="49">, personagens conhecidos de desenhos promoverão brincadeiras e distribuição gratuita de pipoca e algodão doce.</segment>
    <segment id="50">Haverá</segment>
    <segment id="51">, também</segment>
    <segment id="52">, playground montado.</segment>
    <segment id="53">As obras incluíram a pavimentação de cinco quilômetros de pistas</segment>
    <segment id="54">, o redimensionamento de dois quilômetros de calçadão</segment>
    <segment id="55">, extensão da ciclovia</segment>
    <segment id="56">, plantio de 200 árvores</segment>
    <segment id="57">, além de instalação de postes de luz</segment>
    <segment id="58">, bancos e lixeiras.</segment>
    <segment id="59">Revitalização da Ponta da Praia</segment>
    <segment id="60">, em Santos</segment>
    <segment id="61">, incluiu novo calçamento</segment>
    <segment id="62">, iluminação</segment>
    <segment id="63">, bancos e quiosques- Anderson Bianchi/Divulgação Prefeitura de Santos</segment>
    <segment id="64">Entre as atrações</segment>
    <segment id="65">, há dois quiosques</segment>
    <segment id="66">, que começarão a funcionar já em janeiro</segment>
    <segment id="67">, dois mirantes para o mar</segment>
    <segment id="68">, uma fonte de piso interativa para as crianças</segment>
    <segment id="69">, espaço para exercícios físicos e pistas de skate.</segment>
    <segment id="70">A Ponta da Praia é o principal ponto de acesso para a temporada de cruzeiros</segment>
    <segment id="71">, além de ser o local do Aquário Municipal</segment>
    <segment id="72">, equipamento mais visitado da cidade.</segment>
    <segment id="73">No último ano</segment>
    <segment id="74">, pouco mais de 431 mil pessoas passaram pelo aquário.</segment>
    <segment id="75">Neste ano</segment>
    <segment id="76">, com dados até outubro</segment>
    <segment id="77">, o número chegou a 379 mil pessoas.</segment>
    <segment id="78">O projeto passou em março por uma audiência para esclarecimentos na cidade.</segment>
    <segment id="79">O prefeito já disse que a prefeitura tem a intenção de estender as linhas do VLT (Veículo Leve sobre Trilhos) até o local.</segment>
    <segment id="80">Trecho da orla da praia reformado</segment>
    <segment id="81">, em Santos - Anderson Bianch/Divulgação Prefeitura de SantosA remodelação viária da "Nova Ponta da Praia"</segment>
    <segment id="82">, como</segment>
    <segment id="83">como é chamado o projeto</segment>
    <segment id="84">, ainda inclui o acesso as balsas.</segment>
    <segment id="85">O trecho continua em obras e teve o bolsão de acesso ampliado para melhorar o fluxo no período.</segment>
    <segment id="86">Nesta sexta (27)</segment>
    <segment id="87">, no entanto</segment>
    <segment id="88">, o tempo de espera na travessia entre Santos e Guarujá chegou a 120 minutos pela manhã</segment>
    <segment id="89">, do lado de Santos.</segment>
    <segment id="90">Em nota</segment>
    <segment id="91">, a Dersa informou que a travessia opera com toda a sua frota disponível e registrou excesso de veículos no período.</segment>
    <segment id="92">Durante a tarde</segment>
    <segment id="93">, o tempo estimado pela empresa era de 70 minutos.</segment>
    <segment id="94">Folha VerãoLeias outras reportagens sobre a estação preferida para as fériasVeja quais praias estão próprias para banho</segment>
    <segment id="95">pelo BrasilPrincipais cidades turísticas do Brasil</segment>
    <segment id="96">têm 42% das praias poluídasPraias paulistas</segment>
    <segment id="97">comocomo Ilhabela e São Sebastião têm piora na qualidade da águaCada vez mais badalada</segment>
    <segment id="98">, Jurerê</segment>
    <segment id="99">, em SC</segment>
    <segment id="100">, ganha mais um atributo: fica limpa o ano todoÉ hora de os &amp;#039</segment>
    <segment id="101">;atletas de verão&amp;#039</segment>
    <segment id="102">;</segment>
    <segment id="103">saírem às ruas</segment>
    <segment id="104">, masmas prática traz riscos</segment>
    <segment id="105">, alertam médicosCom óleo e esgoto</segment>
    <segment id="106">, parte do litoral do Nordeste enfrenta dupla poluiçãoParaíso das selfies</segment>
    <segment id="107">, Capitólio atrai milhares ao &amp;#</segment>
    <segment id="108">039;mar de MG&amp;#039</segment>
    <segment id="109">;Bucólico e charmoso</segment>
    <segment id="110">, vilarejo do Piauí atrai turistas em busca da &amp;#</segment>
    <segment id="111">039;nova Jeri&amp;#039</segment>
    <segment id="112">;</segment>
  </rst>
</analysis>