  <rst>
    <segment id="1">CarnageOnde Disponível</segment>
    <segment id="2">nas plataformas de streamingAutor Nick Cave e Warren EllisGravadora</segment>
    <segment id="3">Goliath</segment>
    <segment id="4">Records</segment>
    <segment id="5">“Deixai</segment>
    <segment id="6">toda a esperança</segment>
    <segment id="7">, vós que entrais”</segment>
    <segment id="8">, nos avisa o poeta italiano Dante Alighieri no portão do inferno.</segment>
    <segment id="9">Bem, essa sempre foi mais ou menos a vibração de</segment>
    <segment id="10">sese pôr um álbum de Nick Cave para rodar</segment>
    <segment id="11">, e “Carnage”</segment>
    <segment id="12">, lançado há duas semanas nas plataformas de streaming</segment>
    <segment id="13">, mais uma vez toca nessa paleta sombria.</segment>
    <segment id="14">É de se</segment>
    <segment id="15">se perguntar quem</segment>
    <segment id="16">, no atual momento pandêmico mundial</segment>
    <segment id="17">, gostaria de ficar mais deprimido</segment>
    <segment id="18">, mais desgostoso</segment>
    <segment id="19">, mais infeliz?</segment>
    <segment id="20">A resposta é: aqueles capazes de enfrentar qualquer coisa por boa música.</segment>
    <segment id="21">Nick Cave   novamente         de   de  de  representando um</segment>
    <segment id="22">O álbum é uma parceria com Warren Ellis</segment>
    <segment id="23">, violinista que entrou na banda de Cave</segment>
    <segment id="24">, a Bad Seeds</segment>
    <segment id="25">, em 1993.</segment>
    <segment id="26">Apesar de ser o primeiro álbum puro</segment>
    <segment id="27">, digamos</segment>
    <segment id="28">, assinado pelos dois</segment>
    <segment id="29">, a dupla já trabalhou em 13 trilhas-sonoras de cinema e duas de teatro desde 2005.</segment>
    <segment id="30">Vale lembrar que os dois últimos discos lançados por Cave</segment>
    <segment id="31">, “Skeleton Tree”</segment>
    <segment id="32">, de 2016</segment>
    <segment id="33">, e “Gostheen”</segment>
    <segment id="34">, de 2019</segment>
    <segment id="35">, falavam da morte de um de seus filhos gêmeos.</segment>
    <segment id="36">Em 2015</segment>
    <segment id="37">, Arthur morreu após cair de um penhasco no sudeste da Inglaterra</segment>
    <segment id="38">, aos 15 anos.</segment>
    <segment id="39">Assim chegamos à nova floresta negra de Cave</segment>
    <segment id="40">, com “Hand of God”.</segment>
    <segment id="41">É uma música experimental</segment>
    <segment id="42">, que pode assustar</segment>
    <segment id="43">, nos dois sentidos</segment>
    <segment id="44">, quem esperava apenas uma balada amarga.</segment>
    <segment id="45">Traz notas dissonantes e gritos</segment>
    <segment id="46">, que passam de uma pessoa para um coral.</segment>
    <segment id="47">Em “Old Time”</segment>
    <segment id="48">, Cave passeia de carro e dá vazão a seus pesadelos:</segment>
    <segment id="49">“Peguei uma saída errada em algum lugar/ Direto para o passado/ Direto para o passado</segment>
    <segment id="50">, com certeza/</segment>
    <segment id="51">As árvores são negras e antigas/</segment>
    <segment id="52">Nos põem de joelhos num tempo</segment>
    <segment id="53">frio/</segment>
    <segment id="54">Ah, os sonhos de todo mundo estão mortos/ Onde quer que você esteja</segment>
    <segment id="55">, querido</segment>
    <segment id="56">, eu não estou muito atrás”.</segment>
    <segment id="57">Com letras nesse naipe e a famosa voz cavernosa de Cave</segment>
    <segment id="58">, o multi-instrumentista Ellis vai construindo um fantasmagórico emaranhado sonoro.</segment>
    <segment id="59">Mais reminiscências surgem na canção que dá nome ao disco</segment>
    <segment id="60">, “Carnage” —carnificina ou massacre</segment>
    <segment id="61">, em inglês—</segment>
    <segment id="62">, com o lamento do vocal acompanhado por um dedilhado</segment>
    <segment id="63">, cordas e mais corais.</segment>
    <segment id="64">Aqui há pela primeira vez um esboço de refrão</segment>
    <segment id="65">, em “</segment>
    <segment id="66">E é só amor/</segment>
    <segment id="67">Com um pouquinho de chuva/ E eu espero te ver de novo”.</segment>
    <segment id="68">De batida hipnótica</segment>
    <segment id="69">, “White Elephant” é quase uma música.</segment>
    <segment id="70">Dá até para balançar a cabeça com o ritmo</segment>
    <segment id="71">, no entanto a letra é falada</segment>
    <segment id="72">, não cantada.</segment>
    <segment id="73">E o que o artista tem a nos dizer?</segment>
    <segment id="74">“Vou atirar na porra da sua cara/</segment>
    <segment id="75">Caso você pense em vir aqui”.</segment>
    <segment id="76">A segunda metade do disco</segment>
    <segment id="77">, sese pensarmos no formato LP</segment>
    <segment id="78">, mídia formadora de Cave e em que “Carnage” também está sendo lançado</segment>
    <segment id="79">, é nitidamente mais leve.</segment>
    <segment id="80">São quatro baladas delicadas e mais convencionais</segment>
    <segment id="81">, sese é que</segment>
    <segment id="82">sese pode dizer isso de qualquer música deste trabalho.</segment>
    <segment id="83">O que não</segment>
    <segment id="84">sese pode dizer é que o autor esteja vendo a luz do sol.</segment>
    <segment id="85">“Albuquerque”</segment>
    <segment id="86">, assim</segment>
    <segment id="87">comocomo todo o álbum</segment>
    <segment id="88">, foi escrito em 2020</segment>
    <segment id="89">, durante a quarentena.</segment>
    <segment id="90">“</segment>
    <segment id="91">Nós não iremos para Amsterdã/ Nem para aquele lago na África</segment>
    <segment id="92">, amor/</segment>
    <segment id="93">Nós não iremos para lugar</segment>
    <segment id="94">nenhum/</segment>
    <segment id="95">Em nenhum momento deste ano”.</segment>
    <segment id="96">“Lavender Fields” retoma a ideia da existência de um reino dos céus</segment>
    <segment id="97">, já citada em “Hand of God” e “White Elephant”.</segment>
    <segment id="98">Em um disco conceitual</segment>
    <segment id="99">comocomo esse</segment>
    <segment id="100">, em que todas as canções estão amarradas por uma tristeza comum</segment>
    <segment id="101">, “Balcony Man” encerra servindo</segment>
    <segment id="102">comocomo uma redenção.</segment>
    <segment id="103">Cave repete seis vezes que “Esta manhã é incrível/</segment>
    <segment id="104">Assim como</segment>
    <segment id="105">como você”.</segment>
    <segment id="106">Mas a conclusão que vem a seguir é menos palatável</segment>
    <segment id="107">, mudando o ditado de que o que não te mata te faz mais forte.</segment>
    <segment id="108">Para o artista</segment>
    <segment id="109">, não é bem assim:</segment>
    <segment id="110">“</segment>
    <segment id="111">O que não te mata te deixa mais louco”.</segment>
    <segment id="112">Deve ser difícil ser Nick Cave nesses tempos atuais.</segment>
  </rst>
</analysis>