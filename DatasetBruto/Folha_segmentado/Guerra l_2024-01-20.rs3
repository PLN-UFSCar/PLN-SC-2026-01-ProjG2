  <rst>
    <segment id="1">No mês passado</segment>
    <segment id="2">, na primeira noite do Hanukkah</segment>
    <segment id="3">, mais de 200 pessoas lotaram um antigo salão no terceiro andar de uma sinagoga restaurada na cidade de Nova York.</segment>
    <segment id="4">Alguns vieram diretamente do metrô de um protesto organizado por grupos judaicos de esquerda que pediam um cessar-fogo na guerra entre Israel e Hamas.</segment>
    <segment id="5">Eles foram ouvir Shaul Magid</segment>
    <segment id="6">, 65.</segment>
    <segment id="7">Professor de estudos judaicos na Universidade Dartmouth e rabino</segment>
    <segment id="8">, Magid estava lá para disseminar a mensagem de um novo livro</segment>
    <segment id="9">, "The Necessity of Exile:</segment>
    <segment id="10">Essays from a Distance" (A necessidade do exílio</segment>
    <segment id="11">, ensaios à distância):</segment>
    <segment id="12">a de que os judeus hoje fora de Israel —75% dos quais vivem nos Estados Unidos— devem abraçar a diáspora</segment>
    <segment id="13">, o estado de viver fora de uma pátria</segment>
    <segment id="14">, como</segment>
    <segment id="15">como uma condição permanente e valiosa.</segment>
    <segment id="16">"</segment>
    <segment id="17">Se há uma realidade diaspórica onde os judeus conseguiram viver</segment>
    <segment id="18">comocomo judeus</segment>
    <segment id="19">; florescer</segment>
    <segment id="20">comocomo judeus</segment>
    <segment id="21">; não ser oprimidos e perseguidos —não importa</segment>
    <segment id="22">sese escolheram ser ortodoxos ou não—</segment>
    <segment id="23">;</segment>
    <segment id="24">sese lhes é permitido viver o judaísmo que desejam viver</segment>
    <segment id="25">, por que isso seria uma tragédia?</segment>
    <segment id="26">", questionou Magid.</segment>
    <segment id="27">Famílias de reféns do Hamas acendem uma menorá em Tel Aviv</segment>
    <segment id="28">, em Dezembro - Ahmad Gharabli - 14.dez.2023/AFPA perspectiva de Magid é uma das várias visões emergentes para o futuro da vida judaica que</segment>
    <segment id="29">sese enquadram no âmbito do "diasporismo".</segment>
    <segment id="30">A ideia tem sido reconsiderada desde o ataque do Hamas a Israel há três meses e a campanha de bombardeio e invasão de Israel na Faixa de Gaza.</segment>
    <segment id="31">Esses eventos forçaram os judeus em todos os lugares a repensar o que sentem sobre Israel e o papel central que o Estado desempenha na vida judaica.</segment>
    <segment id="32">Algumas versões do diasporismo são seculares</segment>
    <segment id="33">, muitas vezes remetendo ao Bund Judaico Trabalhista</segment>
    <segment id="34">, partido não religioso e antissionista</segment>
    <segment id="35">, que surgiu no final do século 19 na Europa Oriental —a mesma época e lugar onde o sionismo político nasceu— para lutar pelos direitos judaicos nos impérios europeus da época.</segment>
    <segment id="36">O slogan da organização</segment>
    <segment id="37">, "doikayt"</segment>
    <segment id="38">, uma palavra em iídiche que significa algo próximo de "estar aqui"</segment>
    <segment id="39">, foi adotado por jovens judeus de esquerda.</segment>
    <segment id="40">"</segment>
    <segment id="41">Essa filosofia socialista</segment>
    <segment id="42">, secular e libertadora"</segment>
    <segment id="43">, diz Molly Crabapple</segment>
    <segment id="44">, uma artista e escritora que está escrevendo uma história do partido</segment>
    <segment id="45">, "seja do Bund ou do mundo socialismo iídiche mais amplo</segment>
    <segment id="46">, está profundamente entrelaçada em nossa herança" e "pode fornecer uma bússola moral e ajudar as pessoas a rejeitar ideologias excludentes e violentas".</segment>
    <segment id="47">Outras vertentes do diasporismo são religiosas.</segment>
    <segment id="48">O professor emérito da Universidade da Califórnia em Berkeley</segment>
    <segment id="49">, Daniel Boyarin</segment>
    <segment id="50">, chamou o Talmude Babilônico —um dos livros centrais do judaísmo</segment>
    <segment id="51">, composto no exílio— de verdadeira pátria judaica.</segment>
    <segment id="52">Lá foraReceba no seu email uma seleção semanal com o que de mais importante aconteceu no mundoCarregando...</segment>
    <segment id="53">O oposto dessa ideia</segment>
    <segment id="54">, o sionismo</segment>
    <segment id="55">, pelo menos em sua forma mais doutrinária</segment>
    <segment id="56">, insiste que um judeu só pode alcançar a realização total</segment>
    <segment id="57">comocomo judeu vivendo em Israel.</segment>
    <segment id="58">Shlilat ha-golah</segment>
    <segment id="59">, hebraico para "negação do exílio"</segment>
    <segment id="60">, foi um slogan sionista.</segment>
    <segment id="61">O diasporismo sustenta o inverso: que os judeus devem abraçar a marginalidade e um certo afastamento de Israel</segment>
    <segment id="62">, o Estado</segment>
    <segment id="63">, e talvez até mesmo de Israel</segment>
    <segment id="64">, o lugar.</segment>
    <segment id="65">"</segment>
    <segment id="66">Qualquer pessoa que</segment>
    <segment id="67">sese preocupe seriamente em ser judeu está no Exílio e estaria no Exílio mesmo que essa pessoa estivesse em Jerusalém"</segment>
    <segment id="68">, diz uma epígrafe do livro de Magid escrita pelo teólogo americano Eugene Borowitz</segment>
    <segment id="69">, morto em 2016.</segment>
    <segment id="70">Em 2024</segment>
    <segment id="71">, o antissionismo é a coisa mais próxima de heresia para o judaísmo organizado.</segment>
    <segment id="72">A terra de Israel é central para a religião</segment>
    <segment id="73">, a narrativa fundamental sobre o retorno à terra prometida após a escravidão.</segment>
    <segment id="74">Ao longo de séculos de exílio</segment>
    <segment id="75">, os judeus prometeram "no próximo ano em Jerusalém" e rezaram voltados para aquela cidade.</segment>
    <segment id="76">Sinagogas em todos os lugares prestam homenagem aos templos originais destruídos em Jerusalém.</segment>
    <segment id="77">O diasporismo é uma posição distintamente minoritária e facilmente visto</segment>
    <segment id="78">comocomo desdenhoso em relação aos mais de 7 milhões de judeus em Israel —pode parecer uma cegueira voluntária aos séculos de perseguição e pogroms</segment>
    <segment id="79">, culminando no Holocausto</segment>
    <segment id="80">, que convenceram a maioria dos judeus e a comunidade internacional de que Israel precisava existir.</segment>
    <segment id="81">Israelenses bloqueiam rodovias e fazem greve em &amp;#039</segment>
    <segment id="82">;dia de resistência&amp;#039</segment>
    <segment id="83">; contra reforma judicialMais    novamente         de   de  de  representando um  E</segment>
    <segment id="84">, para a maioria dos judeus</segment>
    <segment id="85">, o dia em que o Hamas matou ou sequestrou quase 1.500 israelenses provocou solidariedade e lembrou visceralmente a razão de ser de Israel.</segment>
    <segment id="86">Alguns judeus</segment>
    <segment id="87">, no entanto</segment>
    <segment id="88">, têm sido repelidos pela resposta militar de Tel Aviv</segment>
    <segment id="89">, que matou aproximadamente 23.000 pessoas</segment>
    <segment id="90">, segundo autoridades em Gaza.</segment>
    <segment id="91">Para Magid</segment>
    <segment id="92">, um judaísmo próspero do século 21 sem Israel no centro deve incluir um retorno à religião.</segment>
    <segment id="93">"</segment>
    <segment id="94">É sempre o que vai nos manter juntos"</segment>
    <segment id="95">, diz ele.</segment>
    <segment id="96">Essa religião é baseada no exílio</segment>
    <segment id="97">, surgindo principalmente após a destruição do Segundo Templo pelos romanos no ano 70.</segment>
    <segment id="98">Rabinos criaram substitutos para os requisitos sagrados que não podiam mais ser cumpridos: orações em vez de sacrifícios de animais</segment>
    <segment id="99">, arca para rolos da Torá em vez do santuário interno do templo.  "</segment>
    <segment id="100">Uma das coisas cruciais que a diáspora faz é moldar essa ideia de judaísmo</segment>
    <segment id="101">comocomo uma identidade portátil</segment>
    <segment id="102">, não ligada à terra.</segment>
    <segment id="103">Você pode manter uma cultura e religião judaica vibrante</segment>
    <segment id="104">, permanecer um judeu fiel e observante"</segment>
    <segment id="105">, disse Daniel Schwartz</segment>
    <segment id="106">, professor de história judaica na Universidade George Washington.</segment>
    <segment id="107">Mesmo que esse judaísmo "incorporasse um anseio por Sião em sua liturgia e lei"</segment>
    <segment id="108">, acrescentou Schwartz</segment>
    <segment id="109">, "quão messiânico era o judeu médio na Idade Média?</segment>
    <segment id="110">Provavelmente não muito".</segment>
    <segment id="111">Ato reúne dezenas em apoio à Israel na PaulistaMais    novamente         de   de  de  representando</segment>
    <segment id="112">um  Jovens judeus americanos têm suas próprias ideias sobre o conceito.</segment>
    <segment id="113">Ao relançar o jornal de esquerda Jewish Currents (Tendências judaicas) em 2018</segment>
    <segment id="114">, o então editor Jacob Plitman descreveu "</segment>
    <segment id="115">um diasporismo emergente" que equilibrava "uma consciência crítica de Israel" com "um compromisso de lutar principalmente nas comunidades em que vivemos".</segment>
    <segment id="116">A revista tem sido francamente de esquerda</segment>
    <segment id="117">, tão propensa a debater a perspectiva palestina quanto a judaica.  Simon Schama</segment>
    <segment id="118">, professor universitário de história da arte e história na Universidade Columbia</segment>
    <segment id="119">, que publicou dois volumes de "</segment>
    <segment id="120">A História dos Judeus"</segment>
    <segment id="121">, rejeita o diasporismo</segment>
    <segment id="122">, argumentando que o anseio pela terra de Israel é um aspecto inevitável dos textos judaicos</segment>
    <segment id="123">, desde a poesia da Espanha medieval até a liturgia religiosa cotidiana cantada em 2024.</segment>
    <segment id="124">As limitações do diasporismo surgem claramente quando</segment>
    <segment id="125">sese aplica o conceito a outro povo: os palestinos.</segment>
    <segment id="126">A falta de Estado do passado judeu</segment>
    <segment id="127">, afinal</segment>
    <segment id="128">, ainda descreve o presente palestino.</segment>
    <segment id="129">A noção de que os palestinos devem aceitar sua situação em nome de uma ideologia nobre seria considerada nociva pelos diaspóricos judeus</segment>
    <segment id="130">, que tendem a favorecer a autodeterminação palestina.</segment>
    <segment id="131">"</segment>
    <segment id="132">Os refugiados judeus da Europa</segment>
    <segment id="133">, penso neles</segment>
    <segment id="134">comocomo apátridas</segment>
    <segment id="135">, indefesos"</segment>
    <segment id="136">, diz Sayed Kashua</segment>
    <segment id="137">, um escritor palestino-israelense que vive nos Estados Unidos.</segment>
    <segment id="138">"</segment>
    <segment id="139">Esse plano de ter um Estado</segment>
    <segment id="140">, o Estado nacional moderno do qual não sou um grande fã</segment>
    <segment id="141">, era a única proteção.</segment>
    <segment id="142">Agora é a maioria dos palestinos que substituiu os judeus apátridas e indefesos.</segment>
    <segment id="143">"</segment>
    <segment id="144">Alan Wolfe</segment>
    <segment id="145">, professor emérito de história da Universidade de Boston afirma que</segment>
    <segment id="146">, no ano passado</segment>
    <segment id="147">, enquanto o governo mais à direita da história de Israel buscava diminuir a independência do judiciário</segment>
    <segment id="148">, judeus em outros lugares do mundo serviram</segment>
    <segment id="149">comocomo valiosos críticos.</segment>
    <segment id="150">"</segment>
    <segment id="151">A diáspora pode fornecer o que [o premiê Binyamin] Netanyahu e seus ministros de extrema direita não podem"</segment>
    <segment id="152">, diz.</segment>
    <segment id="153">"</segment>
    <segment id="154">Existe uma grande consciência judaica</segment>
    <segment id="155">, que tem mantido os judeus sobrevivendo por tanto tempo</segment>
    <segment id="156">, sendo arriscada pelas tendências políticas atuais em Israel.</segment>
    <segment id="157">"</segment>
    <segment id="158">Mas Wolfe também critica judeus não israelenses que não entendem que a diáspora é "tanto um conceito mental quanto geográfico"</segment>
    <segment id="159">, um status que une pessoas díspares</segment>
    <segment id="160">, e, por isso</segment>
    <segment id="161">, não perceberam o ataque do Hamas</segment>
    <segment id="162">comocomo um ataque aos judeus de todo o mundo.</segment>
    <segment id="163">"</segment>
    <segment id="164">Se eu pudesse criar o mundo ideal</segment>
    <segment id="165">, seria um em que metade dos judeus vivesse em Israel e metade dos judeus não vivesse</segment>
    <segment id="166">, e é mais ou menos isso que temos"</segment>
    <segment id="167">, diz Wolfe.</segment>
    <segment id="168">"</segment>
    <segment id="169">Eles precisam um do outro —especialmente agora.</segment>
    <segment id="170">"</segment>
  </rst>
</analysis>