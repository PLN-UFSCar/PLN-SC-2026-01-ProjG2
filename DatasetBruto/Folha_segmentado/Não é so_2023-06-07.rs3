  <rst>
    <segment id="1">Ao nomear seu amigo e advogado pessoal para o mais alto cargo jurídico do país</segment>
    <segment id="2">, Lula foi coerente na forma pela qual</segment>
    <segment id="3">sese ascende no direito e na política:</segment>
    <segment id="4">o compadrio.</segment>
    <segment id="5">Confunde-</segment>
    <segment id="6">sese discricionariedade com pessoalidade</segment>
    <segment id="7">, essa "coisa tão minha que não quero repartir com ninguém"</segment>
    <segment id="8">, como</segment>
    <segment id="9">como disse a respeito da nomeação.</segment>
    <segment id="10">No mesmo mês</segment>
    <segment id="11">, o presidente escolheu</segment>
    <segment id="12">, entre uma lista de quatro candidatos igualmente qualificados para o Tribunal Superior Eleitoral</segment>
    <segment id="13">, onde havia duas mulheres e dois homens</segment>
    <segment id="14">, os dois últimos.</segment>
    <segment id="15">Quem diz que raça</segment>
    <segment id="16">, gênero e classe não importam para a boa magistratura precisa dizer por que raios escolher o 165º homem branco a ocupar uma cadeira no STF nos 132 anos da corte sinalizaria algo diferente do que</segment>
    <segment id="17">sese faz há séculos neste país.</segment>
    <segment id="18">Incomoda a muitos questionar as credenciais de Cristiano Zanin para o cargo</segment>
    <segment id="19">porque</segment>
    <segment id="20">porque para homens brancos competência é pressuposto</segment>
    <segment id="21">, não algo a ser provado.</segment>
    <segment id="22">Pode-se</segment>
    <segment id="23">se fingir que raça</segment>
    <segment id="24">, gênero e classe não importam</segment>
    <segment id="25">, masmas é difícil fazê-lo quando as cores da fotografia de quem</segment>
    <segment id="26">sese prende e de quem prende são tão distintas.</segment>
    <segment id="27">O advogado Cristiano Zanin</segment>
    <segment id="28">, indicado pelo presidente Lula a uma vaga no STF - Mathilde Missioneiro/Folhapress - FolhapressA nomeação do STF e o compadrio que ela encerra são mais importantes pelo que</segment>
    <segment id="29">, ocultamente</segment>
    <segment id="30">, evidenciam:</segment>
    <segment id="31">trata-</segment>
    <segment id="32">sese da ponta do iceberg do Judiciário brasileiro</segment>
    <segment id="33">, de elite (prisões por furto de xampu</segment>
    <segment id="34">, botijão</segment>
    <segment id="35">, chocolate e miojo inundam cortes superiores)</segment>
    <segment id="36">, masculino (há mais desembargadores chamados Luís e Luiz do que mulheres no Tribunal de Justiça paulista) e branco (apenas em 2044 estima-</segment>
    <segment id="37">sese que haverá 22% de juízes negros no país).</segment>
    <segment id="38">O debate não é sobre Zanin</segment>
    <segment id="39">, que provavelmente será um ministro adequado</segment>
    <segment id="40">, sese confirmado.</segment>
    <segment id="41">O debate precisa ser menos comezinho</segment>
    <segment id="42">;</segment>
    <segment id="43">é sobre</segment>
    <segment id="44">sese estamos no time que pensa que o Judiciário precisa</segment>
    <segment id="45">sese democratizar ou</segment>
    <segment id="46">sese continuar a parecer uma corte real é suficiente.</segment>
    <segment id="47">Estou no primeiro time</segment>
    <segment id="48">, como</segment>
    <segment id="49">como a esquerda deveria estar.</segment>
    <segment id="50">Lula ganhou as eleições com votos cruciais de mulheres</segment>
    <segment id="51">, negros e mais pobres.</segment>
    <segment id="52">Esses grupos gostam de ganhar eleições e</segment>
    <segment id="53">, espante-</segment>
    <segment id="54">sese, de vestir a toga também.</segment>
  </rst>
