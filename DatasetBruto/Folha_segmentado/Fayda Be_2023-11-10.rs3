  <rst>
    <segment id="1">Para a advogada</segment>
    <segment id="2">Fayda Belo</segment>
    <segment id="3">, a estrutura patriarcal sobre a qual o Brasil foi construído faz com que mulheres</segment>
    <segment id="4">, sejam elas negras</segment>
    <segment id="5">, brancas</segment>
    <segment id="6">, ricas</segment>
    <segment id="7">, pobres</segment>
    <segment id="8">, cis ou trans</segment>
    <segment id="9">, não sejam capazes de identificar quando são vítimas de um crime.</segment>
    <segment id="10">"</segment>
    <segment id="11">Não é questão de status</segment>
    <segment id="12">, masmas sobre uma herança histórica violenta</segment>
    <segment id="13">, que oprime e mata as mulheres"</segment>
    <segment id="14">, diz ela em entrevista à Folha.</segment>
    <segment id="15">A advogada e escritora Fayda Belo</segment>
    <segment id="16">, autora do livro &amp;#039</segment>
    <segment id="17">;Justiça para Todas&amp;#039</segment>
    <segment id="18">; - DivulgaçãoAutora do livro "Justiça para Todas"</segment>
    <segment id="19">, ela considera que a sociedade brasileira foi criada com base na dominação masculina.</segment>
    <segment id="20">Legitimada ao longo de séculos por instituições</segment>
    <segment id="21">comocomo a Igreja Católica</segment>
    <segment id="22">, a polícia e a Justiça</segment>
    <segment id="23">, ela coloca a mulher</segment>
    <segment id="24">comocomo inferior e indigna dos mesmo direitos que o homem.</segment>
    <segment id="25">Especializada em crimes de gênero</segment>
    <segment id="26">, direito antidiscriminatório e feminicídio</segment>
    <segment id="27">, a advogada de 41 anos teve seu trabalho popularizado na internet durante a pandemia.  "</segment>
    <segment id="28">Com o fórum fechado</segment>
    <segment id="29">, eu comecei a ver mais vídeos online.</segment>
    <segment id="30">Um dia</segment>
    <segment id="31">, num ato de impulso</segment>
    <segment id="32">, eu vi uma moça que falou algo errado</segment>
    <segment id="33">, abri a câmera e falei:</segment>
    <segment id="34">Epa!</segment>
    <segment id="35">Não pode</segment>
    <segment id="36">, não!</segment>
    <segment id="37">Aí é crime!</segment>
    <segment id="38">", conta</segment>
    <segment id="39">, aos risos.</segment>
    <segment id="40">O vídeo viralizou e a frase</segment>
    <segment id="41">sese tornou jargão.</segment>
    <segment id="42">Foi quando a advogada percebeu o interesse do público no direito</segment>
    <segment id="43">, cuja linguagem é pouco acessível.</segment>
    <segment id="44">Ela passou a traduzir seu conhecimento técnico para o cotidiano</segment>
    <segment id="45">, e isso a levou a aparecer em rede nacional</segment>
    <segment id="46">, explicando crimes em telejornais.</segment>
    <segment id="47">Como denunciar casos de violência contra a mulherMais    novamente         de   de  de  representando um</segment>
    <segment id="48">A mesma premissa é seguida em seu livro</segment>
    <segment id="49">, lançado agora pela editora Planeta.</segment>
    <segment id="50">É uma espécie de manual ou guia</segment>
    <segment id="51">, que reúne o contexto das leis no Brasil</segment>
    <segment id="52">, explica por que mulheres não sabem identificar quando são vítimas de um crime e aponta o papel do Estado nessa construção.</segment>
    <segment id="53">Os capítulos também apresentam violências das quais mulheres são vítimas cotidianamente.</segment>
    <segment id="54">Não são raros os casos de mulheres apelidadas de forma depreciativa por seus cônjuges</segment>
    <segment id="55">, que recebem avisos sobre o risco de apanhar</segment>
    <segment id="56">casocaso desagradem um homem</segment>
    <segment id="57">, ou que são elogiadas de forma desrespeitosa por um suposto admirador.</segment>
    <segment id="58">FolhaJusA newsletter sobre o mundo jurídico exclusiva para assinantes da FolhaCarregando...</segment>
    <segment id="59">Muitas vezes banalizadas</segment>
    <segment id="60">, essas violências são crimes contra a honra</segment>
    <segment id="61">, a liberdade e a saúde</segment>
    <segment id="62">, por exemplo.</segment>
    <segment id="63">"</segment>
    <segment id="64">Escrevi</segment>
    <segment id="65">para que</segment>
    <segment id="66">para que as mulheres que não têm nenhuma relação com o direito pudessem compreender as leis e os crimes cometidos contra elas.</segment>
    <segment id="67">Eu não falo para uma mulher pobre ou uma mulher rica</segment>
    <segment id="68">, para uma branca ou negra</segment>
    <segment id="69">, eu falo para todas as mulheres que não entendem a lei e precisam de ajuda"</segment>
    <segment id="70">, afirma Belo.</segment>
    <segment id="71">Para cada forma de violência apresentada no livro</segment>
    <segment id="72">, a escritora cita o que diz a lei e identifica o artigo em que ele</segment>
    <segment id="73">sese insere</segment>
    <segment id="74">, com apoio de ilustrações.</segment>
    <segment id="75">Capa do livro &amp;#039</segment>
    <segment id="76">;Justiça para Todas - o que toda mulher deve saber para garantir seus direitos&amp;#039</segment>
    <segment id="77">;, de Fayda Belo - Reprodução"Eu cresci vendo mulheres sendo violentadas"</segment>
    <segment id="78">, diz a autora.</segment>
    <segment id="79">"</segment>
    <segment id="80">Minha mãe foi</segment>
    <segment id="81">, eu fui</segment>
    <segment id="82">, mulheres do meu entorno foram</segment>
    <segment id="83">, e isso fez com que eu sonhasse em ser uma advogada que defende mulheres.</segment>
    <segment id="84">Só que</segment>
    <segment id="85">, quando eu entrei para esse mundo da advocacia</segment>
    <segment id="86">, vi que a gente fala inglês para o Brasil.</segment>
    <segment id="87">"</segment>
    <segment id="88">Belo conta ter amigas que vivem relações abusivas e sofrem violências</segment>
    <segment id="89">comocomo socos</segment>
    <segment id="90">, tapas ou estupro</segment>
    <segment id="91">, masmas relevam ou têm medo de denunciar.</segment>
    <segment id="92">"</segment>
    <segment id="93">Elas foram educadas a dizer que o homem às vezes explode</segment>
    <segment id="94">, masmas amanhã passa.</segment>
    <segment id="95">Que a prioridade tem que ser a família e é feio ser uma mulher largada pelo marido.</segment>
    <segment id="96">"</segment>
    <segment id="97">Isso se</segment>
    <segment id="98">se deve a uma cultura enraizada desde o período imperial</segment>
    <segment id="99">, quando</segment>
    <segment id="100">, para o Código Penal</segment>
    <segment id="101">, um homem que estuprasse uma mulher só seria culpado de um crime</segment>
    <segment id="102">sese ela fosse virgem.</segment>
    <segment id="103">Nesse caso</segment>
    <segment id="104">caso, ele seria expulso de sua cidade</segment>
    <segment id="105">, masmas</segment>
    <segment id="106">, sese optasse por</segment>
    <segment id="107">sese caso</segment>
    <segment id="108">caso se</segment>
    <segment id="109">se casar com ela</segment>
    <segment id="110">, não sofreria nenhuma consequência.</segment>
    <segment id="111">"Ou seja</segment>
    <segment id="112">, a mulher recebia a pena de ter que viver pelo resto da vida com o algoz que invadiu seu corpo.</segment>
    <segment id="113">"</segment>
    <segment id="114">Entenda os termos usados para classificar a violência contra mulherMais    novamente         de   de  de  representando um  Na publicação</segment>
    <segment id="115">, Belo conversa com as leitoras e rebate pensamentos frequentes que impedem a denúncia de agressões.</segment>
    <segment id="116">A autora brinca que destacou partes do livro</segment>
    <segment id="117">para que</segment>
    <segment id="118">para que uma de suas amigas lesse</segment>
    <segment id="119">, já que ela não a escutava.</segment>
    <segment id="120">Para a escritora</segment>
    <segment id="121">, uma mulher que denuncia o companheiro não coloca em risco sua família</segment>
    <segment id="122">, masmas a protege.</segment>
    <segment id="123">"</segment>
    <segment id="124">Quando uma menina cresce em um lar onde a mãe é violentada</segment>
    <segment id="125">, cresce achando que aquilo é o normal.</segment>
    <segment id="126">E o menino acha que aquilo que o pai faz é normal dentro da relação.</segment>
    <segment id="127">Ao denunciar</segment>
    <segment id="128">, de alguma forma</segment>
    <segment id="129">, a mãe vai estar ajudando seus filhos.</segment>
    <segment id="130">"</segment>
    <segment id="131">Por outro lado</segment>
    <segment id="132">, completa a escritora</segment>
    <segment id="133">, essa mulher cuidará de si mesma e garantirá a saúde emocional e financeira da família ao prevenir que as violências das quais é vítima prejudiquem seu desenvolvimento profissional.</segment>
    <segment id="134">Justiça para TodasPreço R$ 54</segment>
    <segment id="135">,90 (176 págs.)Autoria Fayda BeloEditora Planeta</segment>
  </rst>
</analysis>