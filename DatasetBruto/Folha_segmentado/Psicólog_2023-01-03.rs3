  <rst>
    <segment id="1">Quando um novo ano começa</segment>
    <segment id="2">, é comum estabelecermos metas do que queremos realizar nos próximos meses.</segment>
    <segment id="3">Mas é importante refletirmos sobre o que é viável para não gerar autocobrança</segment>
    <segment id="4">, frustração e ansiedade.</segment>
    <segment id="5">Para Monica Machado</segment>
    <segment id="6">, psicóloga e fundadora da Clínica</segment>
    <segment id="7">Ame.</segment>
    <segment id="8">C,</segment>
    <segment id="9">a autocobrança é a constante busca pela perfeição e</segment>
    <segment id="10">, consequentemente</segment>
    <segment id="11">, cria expectativas irreais</segment>
    <segment id="12">, tornando-</segment>
    <segment id="13">sese uma das principais causas das nossas maiores frustrações.</segment>
    <segment id="14">"Autocobrança é sobre tudo o que queremos esconder: imperfeição</segment>
    <segment id="15">, vulnerabilidade</segment>
    <segment id="16">, sensação de impotência e incapacidade.</segment>
    <segment id="17">Afinal</segment>
    <segment id="18">, ninguém quer</segment>
    <segment id="19">sese sentir</segment>
    <segment id="20">, ou ser visto</segment>
    <segment id="21">, dessa forma.</segment>
    <segment id="22">Daí a necessidade de</segment>
    <segment id="23">sese cobrar sempre</segment>
    <segment id="24">, e cada vez mais"</segment>
    <segment id="25">, diz.</segment>
    <segment id="26">Estabelecer metas muito difíceis de alcançar pode gerar ansiedade e frustração - Getty imagesA psicóloga reforça que é preciso ter em mente que você pode fazer e dar o seu melhor</segment>
    <segment id="27">, masmas sem ultrapassar seus limites físicos e emocionais.</segment>
    <segment id="28">Essa forma de pensar neutraliza as emoções negativas e faz com que seja possível</segment>
    <segment id="29">sese relacionar ou atuar em determinadas situações com menos pressão interna e mais equilíbrio emocional.</segment>
    <segment id="30">Veja dicas da profissional para fugir da autocobrança.</segment>
    <segment id="31">Não tema o julgamento alheio</segment>
    <segment id="32">A autenticidade requer coragem</segment>
    <segment id="33">, pois</segment>
    <segment id="34">pois exige de nós aceitar nossa personalidade</segment>
    <segment id="35">, nossas falhas e vulnerabilidades.</segment>
    <segment id="36">É ter a força para abraçar quem realmente somos</segment>
    <segment id="37">, desapegar das comparações e dos paradigmas de quem achamos que devemos ser.</segment>
    <segment id="38">"</segment>
    <segment id="39">Nada vale mais a pena do que trazer ao mundo o que realmente temos para dar.</segment>
    <segment id="40">Ser coerente com nossa verdade nos proporciona liberdade</segment>
    <segment id="41">, verdade e plenitude"</segment>
    <segment id="42">, afirma Machado.</segment>
    <segment id="43">Permita-</segment>
    <segment id="44">sese fazer menos e</segment>
    <segment id="45">sese cuidar mais</segment>
    <segment id="46">No estilo de vida atual</segment>
    <segment id="47">, a quantidade de coisas que nós mesmos exigimos vai além do que</segment>
    <segment id="48">sese pode aguentar.</segment>
    <segment id="49">E quando não damos conta de tudo</segment>
    <segment id="50">, nos sentimos frustrados.</segment>
    <segment id="51">Muitas vezes evitamos até fazer pausas e tirar folgas.</segment>
    <segment id="52">"</segment>
    <segment id="53">Como seria</segment>
    <segment id="54">sese você</segment>
    <segment id="55">sese permitisse fazer menos e incluir momentos de descanso em sua jornada?</segment>
    <segment id="56">", questiona a psicóloga.</segment>
    <segment id="57">"</segment>
    <segment id="58">Períodos de desconexão são essenciais para o bem-estar.</segment>
    <segment id="59">Esquecer um pouco o check-list</segment>
    <segment id="60">, olhar para si mesmo e fazer algo que não esteja vinculado a responsabilidades</segment>
    <segment id="61">, masmas sim ao prazer</segment>
    <segment id="62">, ao conforto que tanto lhe falta.</segment>
    <segment id="63">Sua mente ficará mais descansada e até mais produtiva"</segment>
    <segment id="64">, diz.</segment>
    <segment id="65">Transtorno de ansiedade é caracterizado por preocupação excessiva e medoMais    novamente         de   de  de  representando um  Seja resiliente</segment>
    <segment id="66">Resiliência é a capacidade de nos adaptarmos às mudanças.</segment>
    <segment id="67">Essa habilidade depende de fortalecer nossas qualidades pessoais e agir diante das adversidades com foco no nosso poder de atuação.</segment>
    <segment id="68">Segundo Machado</segment>
    <segment id="69">, para ser resiliente é preciso cultivar um modelo mental com espaço para uma visão positiva da vida</segment>
    <segment id="70">, entrar em contato com as emoções e avaliar</segment>
    <segment id="71">sese suas escolhas alimentam os problemas ou agem de forma coerente à solução do que</segment>
    <segment id="72">sese busca.</segment>
    <segment id="73">Tenha autocompaixão</segment>
    <segment id="74">O perfeccionismo e a autocrítica geram um círculo vicioso.</segment>
    <segment id="75">Passamos a viver na ansiedade de uma vida e atos perfeitos</segment>
    <segment id="76">, tentando nos proteger das situações capazes de expor nossos defeitos ao mundo.</segment>
    <segment id="77">Quando entendemos que a perfeição não existe e nos acolhemos exatamente</segment>
    <segment id="78">comocomo somos</segment>
    <segment id="79">, conseguimos nos perdoar</segment>
    <segment id="80">, atuar com autocompaixão e pedir ajuda quando precisamos.</segment>
    <segment id="81">"</segment>
    <segment id="82">Vale lembrar que a autocobrança exagerada pode desencadear crises de ansiedade e até desenvolver transtornos graves.</segment>
    <segment id="83">Daí a importância de</segment>
    <segment id="84">sese policiar.</segment>
    <segment id="85">Caso perceba que o sentimento fugiu de controle</segment>
    <segment id="86">, o ideal é buscar ajuda médica"</segment>
    <segment id="87">, afirma Machado.  +</segment>
    <segment id="88">Saúde MentalLeia mais sobre o temaSíndrome do pânico: psiquiatra explica</segment>
    <segment id="89">comocomo são as crises e o tratamentoHigiene do sono: aprenda a criar uma rotina ao longo do dia para dormir bemPessoas que tiveram burnout contam</segment>
    <segment id="90">comocomo superaram o esgotamento profissionalSiga o blog Saúde Mental no Twitter</segment>
    <segment id="91">, no Instagram e no Facebook.</segment>
  </rst>
