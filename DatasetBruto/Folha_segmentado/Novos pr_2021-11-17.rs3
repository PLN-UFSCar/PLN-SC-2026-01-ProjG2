  <rst>
    <segment id="1">Ao menos 15 pessoas morreram e dezenas ficaram feridas</segment>
    <segment id="2">, nesta quarta-feira (17)</segment>
    <segment id="3">, durante manifestações no Sudão contra a cúpula militar que liderou um golpe no final do mês passado.</segment>
    <segment id="4">Segundo a agência de notícias Reuters</segment>
    <segment id="5">, que cita médicos</segment>
    <segment id="6">comocomo fontes</segment>
    <segment id="7">, as mortes foram decorrentes de ações das forças de segurança nas proximidades de Cartum</segment>
    <segment id="8">, capital do país.</segment>
    <segment id="9">Os atos</segment>
    <segment id="10">, em diversas cidades</segment>
    <segment id="11">, tiveram a participação de milhares de sudaneses</segment>
    <segment id="12">, que exigiam a libertação de todas as autoridades civis presas pelos militares e o julgamento dos responsáveis pelo golpe.</segment>
    <segment id="13">De acordo com testemunhas ouvidas pela Reuters</segment>
    <segment id="14">, as forças de segurança atiraram contra os manifestantes e usaram gás lacrimogêneo para dispersar as multidões.</segment>
    <segment id="15">Das 15 mortes</segment>
    <segment id="16">, ao menos 7 teriam ocorrido em Bahri</segment>
    <segment id="17">, cidade vizinha a Cartum.</segment>
    <segment id="18">Sudaneses contrários ao golpe militar de 25 de outubro tomam as ruas da capital</segment>
    <segment id="19">, em Cartum - 17.nov.21/AFP "</segment>
    <segment id="20">As forças golpistas usaram pesadamente balas de verdade em diferentes áreas da capital</segment>
    <segment id="21">, e há dezenas de feridos por arma de fogo</segment>
    <segment id="22">, alguns dos quais em estado grave"</segment>
    <segment id="23">, informou o Comitê Central de Médicos Sudaneses</segment>
    <segment id="24">, grupo de profissionais alinhado a manifestantes.</segment>
    <segment id="25">O Partido do Congresso Sudanês</segment>
    <segment id="26">, que integrava a coalizão militar e civil que sustentava o premiê deposto</segment>
    <segment id="27">, Abdallah Hamdok</segment>
    <segment id="28">, disse que um de seus líderes foi preso depois de policiais irem a sua casa.</segment>
    <segment id="29">Lá foraReceba no seu email uma seleção semanal com o que de mais importante aconteceu no mundo</segment>
    <segment id="30">; aberta para não assinantes.</segment>
    <segment id="31">Carregando...</segment>
    <segment id="32">Nas ruas</segment>
    <segment id="33">, os sudaneses carregavam fotos de pessoas mortas em protestos anteriores</segment>
    <segment id="34">, além de imagens de Hamdok.</segment>
    <segment id="35">O primeiro-ministro civil chegou a ser detido na tomada de poder e foi liberado e posto em prisão domiciliar um dia depois.</segment>
    <segment id="36">"</segment>
    <segment id="37">A legitimidade vem da rua</segment>
    <segment id="38">, não dos canhões"</segment>
    <segment id="39">, dizia uma faixa.</segment>
    <segment id="40">Antes mesmo de darem início aos protestos desta quarta</segment>
    <segment id="41">, os manifestantes encontraram grande contingente de policiais</segment>
    <segment id="42">, que bloquearam estradas e cruzamentos.</segment>
    <segment id="43">Pontes sobre o rio Nilo também foram fechadas.</segment>
    <segment id="44">Golpe militar no Sudão</segment>
    <segment id="45">, dois anos após início de transição para a democraciaMais    novamente         de   de  de  representando um</segment>
    <segment id="46">Apesar das mortes</segment>
    <segment id="47">, as forças de segurança inicialmente não fizeram comentários sobre os atos</segment>
    <segment id="48">; mais tarde</segment>
    <segment id="49">, a televisão estatal</segment>
    <segment id="50">, porém</segment>
    <segment id="51">porém,anunciou feridos entre os manifestantes e a polícia.</segment>
    <segment id="52">Antes disso</segment>
    <segment id="53">, o chefe do Exército e líder do país desde o golpe</segment>
    <segment id="54">, o general Abdel Fattah al-Burhan</segment>
    <segment id="55">, disse que protestos pacíficos são permitidos e que os militares não matam manifestantes.</segment>
    <segment id="56">O regime é acusado</segment>
    <segment id="57">, pela organização sudanesa de médicos</segment>
    <segment id="58">, de ser responsável pela morte de ao menos sete pessoas durante atos no último sábado (13).</segment>
    <segment id="59">Ao todo</segment>
    <segment id="60">, desde o golpe de 25 de outubro</segment>
    <segment id="61">, 39 pessoas</segment>
    <segment id="62">, incluindo três adolescentes</segment>
    <segment id="63">, morreram</segment>
    <segment id="64">, e centenas ficaram feridas.  Somam-</segment>
    <segment id="65">sese à brutalidade das forças de segurança na repressão os recentes bloqueios de internet por parte dos militares</segment>
    <segment id="66">, o que tem dificultado a organização dos opositores.</segment>
    <segment id="67">Com a suspensão total ou parcial dos serviços de internet móvel no Sudão desde o golpe</segment>
    <segment id="68">, manifestantes têm marcado a concentração para atos via SMS —nesta quarta</segment>
    <segment id="69">, porém</segment>
    <segment id="70">porém, o regime também bloqueou as comunicações telefônicas.</segment>
    <segment id="71">Na quinta-feira passada (11)</segment>
    <segment id="72">, em meio à pressão internacional</segment>
    <segment id="73">, Burhan anunciou um novo conselho de transição para comandar o país.</segment>
    <segment id="74">O grupo é liderado pelo próprio general</segment>
    <segment id="75">, que também manteve</segment>
    <segment id="76">comocomo vice Mohamed Hamdan Dagalo</segment>
    <segment id="77">, comandante das poderosas Forças de Apoio Rápido paramilitares.</segment>
    <segment id="78">Forças Armadas do Sudão destituem o ditador Omar al-Bashir em abril de 2019Mais    novamente         de   de  de  representando um  Antes do golpe</segment>
    <segment id="79">, os dois já exerciam essas funções</segment>
    <segment id="80">, masmas compartilhavam o poder com Hamdok</segment>
    <segment id="81">, o premiê civil.</segment>
    <segment id="82">A composição seria mantida até 2023</segment>
    <segment id="83">, quando estavam previstas eleições no país.</segment>
    <segment id="84">A nomeação do novo conselho de transição gerou repúdio entre sudaneses e a comunidade internacional</segment>
    <segment id="85">, que vê cada vez mais distante a possibilidade de um acordo pacífico para o imbróglio.</segment>
    <segment id="86">A ONU classificou o movimento de Burhan</segment>
    <segment id="87">comocomo "muito preocupante".</segment>
    <segment id="88">Nesta quarta</segment>
    <segment id="89">, o secretário de Estado americano</segment>
    <segment id="90">, Antony Blinken</segment>
    <segment id="91">, disse</segment>
    <segment id="92">, durante viagem ao Quênia</segment>
    <segment id="93">, que o governo americano apoia a restauração da "transição democrática do Sudão"</segment>
    <segment id="94">, acrescentando que ele está "intensamente envolvido" no assunto.</segment>
    <segment id="95">Um dia antes</segment>
    <segment id="96">, a diplomata americana enviada ao país</segment>
    <segment id="97">, Molly Phee</segment>
    <segment id="98">, encontrou-</segment>
    <segment id="99">sese com Hamdok para discutir formas de retomar o poder.</segment>
    <segment id="100">Ela já havia</segment>
    <segment id="101">sese reunido com Burhan</segment>
    <segment id="102">, que prometeu a libertação de presos políticos em até dois dias.</segment>
  </rst>
</analysis>