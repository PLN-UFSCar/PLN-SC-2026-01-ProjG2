  <rst>
    <segment id="1">A Justi&amp;ccedil</segment>
    <segment id="2">;a acatou pedido do MP-SP (Minist&amp;eacute</segment>
    <segment id="3">;rio P&amp;uacute</segment>
    <segment id="4">;blico de S&amp;atilde</segment>
    <segment id="5">;o Paulo) e reclassificou o atropelamento seguido de morte da ciclista Marina Kholer Harkot</segment>
    <segment id="6">, 28 anos</segment>
    <segment id="7">, como</segment>
    <segment id="8">como homic&amp;iacute</segment>
    <segment id="9">;dio doloso</segment>
    <segment id="10">, quando</segment>
    <segment id="11">sese assume o risco de matar.</segment>
    <segment id="12">O microempres&amp;aacute</segment>
    <segment id="13">;rio Jos&amp;eacute</segment>
    <segment id="14">; Maria da Costa J&amp;uacute</segment>
    <segment id="15">;nior, 33 anos</segment>
    <segment id="16">, &amp;eacute</segment>
    <segment id="17">; suspeito de atropelar e matar a cicloativista no &amp;uacute</segment>
    <segment id="18">;ltimo dia 8</segment>
    <segment id="19">, na avenida Paulo 6</segment>
    <segment id="20">, zona oeste da capital paulista.</segment>
    <segment id="21">Ele n&amp;atilde</segment>
    <segment id="22">;o prestou socorro &amp;agrave</segment>
    <segment id="23">; v&amp;iacute</segment>
    <segment id="24">;tima.</segment>
    <segment id="25">Uma mulher que estava com ele no Hyundai Tucson tamb&amp;eacute</segment>
    <segment id="26">;m foi indiciada</segment>
    <segment id="27">, por omiss&amp;atilde</segment>
    <segment id="28">;o de socorro.</segment>
    <segment id="29">A Pol&amp;iacute</segment>
    <segment id="30">;cia Civil havia considerado o</segment>
    <segment id="31">casocaso</segment>
    <segment id="32">comocomo homic&amp;iacute</segment>
    <segment id="33">;dio culposo</segment>
    <segment id="34">, quando n&amp;atilde</segment>
    <segment id="35">;o h&amp;aacute</segment>
    <segment id="36">;</segment>
    <segment id="37">inten&amp;ccedil</segment>
    <segment id="38">;&amp;atilde</segment>
    <segment id="39">;o de matar.</segment>
    <segment id="40">Segundo a ju&amp;iacute</segment>
    <segment id="41">;za Tatiana Saes Valverde Ormeleze</segment>
    <segment id="42">, h&amp;aacute</segment>
    <segment id="43">; ind&amp;iacute</segment>
    <segment id="44">;cios de que J&amp;uacute</segment>
    <segment id="45">;nior &amp;ldquo</segment>
    <segment id="46">;encontrava-</segment>
    <segment id="47">sese sob efeito de &amp;aacute</segment>
    <segment id="48">;lcool&amp;rdquo</segment>
    <segment id="49">;, quando conduzia o carro que atropelou e matou Marina.</segment>
    <segment id="50">&amp;ldquo</segment>
    <segment id="51">;H&amp;aacute</segment>
    <segment id="52">; novos elementos investigativos que corroboram tanto a embriaguez quanto o excesso de velocidade e</segment>
    <segment id="53">, como</segment>
    <segment id="54">como bem afirmado pelo promotor de Justi&amp;ccedil</segment>
    <segment id="55">;a, h&amp;aacute</segment>
    <segment id="56">;, portanto</segment>
    <segment id="57">, dolo eventual [inten&amp;ccedil</segment>
    <segment id="58">;&amp;atilde</segment>
    <segment id="59">;o], de modo que o investigado</segment>
    <segment id="60">, nestas condi&amp;ccedil</segment>
    <segment id="61">;&amp;otilde</segment>
    <segment id="62">;es, assumiu o risco de produzir o resultado morte&amp;rdquo</segment>
    <segment id="63">;, diz trecho do parecer da magistrada</segment>
    <segment id="64">, assinado na quinta-feira (26).</segment>
    <segment id="65">Miguel da Silva J&amp;uacute</segment>
    <segment id="66">;nior, defensor do microempres&amp;aacute</segment>
    <segment id="67">;rio, afirmou que ir&amp;aacute</segment>
    <segment id="68">; tomar as &amp;ldquo</segment>
    <segment id="69">;medidas cab&amp;iacute</segment>
    <segment id="70">;veis&amp;rdquo</segment>
    <segment id="71">; sobre a decis&amp;atilde</segment>
    <segment id="72">;o judicial.</segment>
    <segment id="73">&amp;ldquo</segment>
    <segment id="74">;A decis&amp;atilde</segment>
    <segment id="75">;o que remeteu os autos ao tribunal do j&amp;uacute</segment>
    <segment id="76">;ri &amp;eacute</segment>
    <segment id="77">; carente de fundamenta&amp;ccedil</segment>
    <segment id="78">;&amp;atilde</segment>
    <segment id="79">;o&amp;rdquo</segment>
    <segment id="80">;, disse o advogado ao Agora neste domingo (29).  Marina Kohler Harkot</segment>
    <segment id="81">, 28 anos</segment>
    <segment id="82">, morreu após ser atropelada em Pinheiros (zona oeste da capital paulista)-</segment>
    <segment id="83">Arquivo pessoal&amp;quot</segment>
    <segment id="84">;Embora</segment>
    <segment id="85">a autoridade judici&amp;aacute</segment>
    <segment id="86">;ria possa discordar da tipifica&amp;ccedil</segment>
    <segment id="87">;&amp;atilde</segment>
    <segment id="88">;o do delegado</segment>
    <segment id="89">, o mesmo entendeu pelo homic&amp;iacute</segment>
    <segment id="90">;dio culposo [sem inten&amp;ccedil</segment>
    <segment id="91">;&amp;atilde</segment>
    <segment id="92">;o].</segment>
    <segment id="93">Portanto</segment>
    <segment id="94">, vamos aguardar o momento oportuno para tomar as medidas jur&amp;iacute</segment>
    <segment id="95">;dicas pertinentes ao</segment>
    <segment id="96">casocaso</segment>
    <segment id="97">, al&amp;eacute</segment>
    <segment id="98">;m disso</segment>
    <segment id="99">, as provas testemunhais que ele ingeriu bebidas alco&amp;oacute</segment>
    <segment id="100">;licas s&amp;atilde</segment>
    <segment id="101">;o capengas</segment>
    <segment id="102">, de sorte que n&amp;atilde</segment>
    <segment id="103">;o podem ser substitu&amp;iacute</segment>
    <segment id="104">;das por uma prova t&amp;eacute</segment>
    <segment id="105">;cnica.</segment>
    <segment id="106">Prova t&amp;eacute</segment>
    <segment id="107">;cnica que n&amp;atilde</segment>
    <segment id="108">;o existe nos autos&amp;rdquo</segment>
    <segment id="109">;, acrescentou o defensor.</segment>
    <segment id="110">O microempres&amp;aacute</segment>
    <segment id="111">;rio j&amp;aacute</segment>
    <segment id="112">; havia sido indiciado por omiss&amp;atilde</segment>
    <segment id="113">;o de socorro e por homic&amp;iacute</segment>
    <segment id="114">;dio culposo.</segment>
    <segment id="115">A qualifica&amp;ccedil</segment>
    <segment id="116">;&amp;atilde</segment>
    <segment id="117">;o de que teria consumido bebida alco&amp;oacute</segment>
    <segment id="118">;lica, endossada pela Justi&amp;ccedil</segment>
    <segment id="119">;a, foi atribu&amp;iacute</segment>
    <segment id="120">;da ao suspeito pela pol&amp;iacute</segment>
    <segment id="121">;cia no &amp;uacute</segment>
    <segment id="122">;ltimo dia 18.</segment>
    <segment id="123">Antes do atropelamento</segment>
    <segment id="124">, ele foi a um bar</segment>
    <segment id="125">, segundo registrado por c&amp;acirc</segment>
    <segment id="126">;meras de monitoramento.</segment>
    <segment id="127">Na comanda do suspeito</segment>
    <segment id="128">, que est&amp;aacute</segment>
    <segment id="129">; com a pol&amp;iacute</segment>
    <segment id="130">;cia, consta que ele pagou a conta &amp;agrave</segment>
    <segment id="131">;s 23h06 do dia 7</segment>
    <segment id="132">, pouco antes do acidente.</segment>
    <segment id="133">Em seguida</segment>
    <segment id="134">, Costa J&amp;uacute</segment>
    <segment id="135">;nior saiu do bar em um Hyundai Tucson</segment>
    <segment id="136">, ocupado tamb&amp;eacute</segment>
    <segment id="137">;m pela amiga e outro homem</segment>
    <segment id="138">, j&amp;aacute</segment>
    <segment id="139">; identificado.</segment>
    <segment id="140">O Hyundai foi multado ap&amp;oacute</segment>
    <segment id="141">;s um radar flagrar o ve&amp;iacute</segment>
    <segment id="142">;culo trafegando a mais de 90 km/h na avenida onde ocorreu o acidente</segment>
    <segment id="143">, segundo a pol&amp;iacute</segment>
    <segment id="144">;cia.</segment>
    <segment id="145">O limite de velocidade da via &amp;eacute</segment>
    <segment id="146">; de 50 km/h.  Ap&amp;oacute</segment>
    <segment id="147">;s isso</segment>
    <segment id="148">, segundo outras c&amp;acirc</segment>
    <segment id="149">;meras de monitoramento</segment>
    <segment id="150">, o suspeito deixou o carro em um estacionamento</segment>
    <segment id="151">, ao lado do pr&amp;eacute</segment>
    <segment id="152">;dio onde mora</segment>
    <segment id="153">, na Consola&amp;ccedil</segment>
    <segment id="154">;&amp;atilde</segment>
    <segment id="155">;o (centro).</segment>
    <segment id="156">Em seguida</segment>
    <segment id="157">, ele vai at&amp;eacute</segment>
    <segment id="158">;</segment>
    <segment id="159">seu apartamento</segment>
    <segment id="160">, acompanhado pela amiga tamb&amp;eacute</segment>
    <segment id="161">;m indiciada pelo crime.</segment>
    <segment id="162">Junior sorri para a acompanhante</segment>
    <segment id="163">, segundo as imagens do elevador.</segment>
    <segment id="164">Microempresário de 33 anos suspeito de matar a ciclista Marina Kohler</segment>
    <segment id="165">, na madrugada do último dia 8 em Pinheiros (zona oeste da capital paulista)</segment>
    <segment id="166">, aparece sorrindo</segment>
    <segment id="167">, acompanhado de uma mulher</segment>
    <segment id="168">, minutos após o acidente.   - Reprodução   ​Cerca de dez minutos depois</segment>
    <segment id="169">, ambos retornam ao estacionamento</segment>
    <segment id="170">, onde uma pessoa coberta por um pano pega algum objeto no carro de Costa J&amp;uacute</segment>
    <segment id="171">;nior.</segment>
    <segment id="172">O microempres&amp;aacute</segment>
    <segment id="173">;rio teve o pedido de pris&amp;atilde</segment>
    <segment id="174">;o preventiva negado pela Justi&amp;ccedil</segment>
    <segment id="175">;a, no &amp;uacute</segment>
    <segment id="176">;ltimo dia 13.</segment>
    <segment id="177">A decis&amp;atilde</segment>
    <segment id="178">;o seguiu a manifesta&amp;ccedil</segment>
    <segment id="179">;&amp;atilde</segment>
    <segment id="180">;o do Minist&amp;eacute</segment>
    <segment id="181">;rio P&amp;uacute</segment>
    <segment id="182">;blico pelo indeferimento da solicita&amp;ccedil</segment>
    <segment id="183">;&amp;atilde</segment>
    <segment id="184">;o, feita pela Pol&amp;iacute</segment>
    <segment id="185">;cia Civil.</segment>
    <segment id="186">Ele se</segment>
    <segment id="187">se apresentou no 14&amp;ordm</segment>
    <segment id="188">; DP, no &amp;uacute</segment>
    <segment id="189">;ltimo dia 10</segment>
    <segment id="190">, e se</segment>
    <segment id="191">se negou a prestar depoimento sobre o</segment>
    <segment id="192">casocaso</segment>
    <segment id="193">, sendo liberado em seguida.</segment>
    <segment id="194">O advogado Jos&amp;eacute</segment>
    <segment id="195">; Miguel da Silva J&amp;uacute</segment>
    <segment id="196">;nior, defensor do microempres&amp;aacute</segment>
    <segment id="197">;rio, afirmou na ocasi&amp;atilde</segment>
    <segment id="198">;o que seu cliente jamais negou ter ido ao bar antes do atropelamento.</segment>
    <segment id="199">Por&amp;eacute</segment>
    <segment id="200">;m, reiterou que ele n&amp;atilde</segment>
    <segment id="201">;o bebeu.</segment>
    <segment id="202">&amp;</segment>
    <segment id="203">quot;Na pior das hip&amp;oacute</segment>
    <segment id="204">;teses</segment>
    <segment id="205">, sese ele tivesse bebido [uma dose de u&amp;iacute</segment>
    <segment id="206">;sque]</segment>
    <segment id="207">n&amp;atilde</segment>
    <segment id="208">;o ficaria embriagado.</segment>
    <segment id="209">Mas n&amp;atilde</segment>
    <segment id="210">;o estou falando que ele bebeu&amp;quot</segment>
    <segment id="211">;, disse.</segment>
    <segment id="212">Sobre o fato de constar a compra de u&amp;iacute</segment>
    <segment id="213">;sque na comanda do microempres&amp;aacute</segment>
    <segment id="214">;rio, o advogado afirmou que o cliente pagou a bebida para pessoas que estavam com ele</segment>
    <segment id="215">, sem especificar quem.</segment>
    <segment id="216">Informado sobre o depoimento da amiga</segment>
    <segment id="217">, no qual ela afirma ter visto o microempres&amp;aacute</segment>
    <segment id="218">;rio consumir &amp;aacute</segment>
    <segment id="219">;lcool</segment>
    <segment id="220">,</segment>
    <segment id="221">o defensor disse que a jovem teria afirmado isso pelo fato de &amp;ldquo</segment>
    <segment id="222">;ter sido indiciada por omiss&amp;atilde</segment>
    <segment id="223">;o de socorro&amp;rdquo</segment>
    <segment id="224">;.</segment>
    <segment id="225">Em entrevista ao Agora</segment>
    <segment id="226">, a bi&amp;oacute</segment>
    <segment id="227">;loga Maria Claudia Mibielli Kohler</segment>
    <segment id="228">, 56, m&amp;atilde</segment>
    <segment id="229">;e da cicloativista</segment>
    <segment id="230">, afirmou que a fam&amp;iacute</segment>
    <segment id="231">;lia vai brigar na Justi&amp;ccedil</segment>
    <segment id="232">;a para que</segment>
    <segment id="233">para que J&amp;uacute</segment>
    <segment id="234">;nior seja responsabilizado.</segment>
  </rst>
</analysis>