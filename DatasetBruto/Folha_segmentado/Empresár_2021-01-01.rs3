  <rst>
    <segment id="1">Grandes empresários contaram à Folha quais livros que estão em suas cabeceiras.</segment>
    <segment id="2">A história da Odebrecht</segment>
    <segment id="3">, clássicos da literatura</segment>
    <segment id="4">, obras de economia e ficção fazem parte das indicações para o ano que</segment>
    <segment id="5">sese inicia.</segment>
    <segment id="6">Flávio Rocha</segment>
    <segment id="7">, Riachuelo  Retrato do empresário Flavio Rocha</segment>
    <segment id="8">, proprietário da Riachuelo - Eduardo Knapp/Folhapress​​“Invent and Wander: The Collected Writings of Jeff Bezos” (Crie e divague: coletânea de textos de Jeff Bezos)  Introdução de Walter Isaacson</segment>
    <segment id="9">, 274 págs.</segment>
    <segment id="10">R$ 49,90 (ebook)</segment>
    <segment id="11">“</segment>
    <segment id="12">Estou lendo o livro mais recente de Jeff Bezos.</segment>
    <segment id="13">É uma leitura muito interessante e inspiradora.</segment>
    <segment id="14">São lições para todos os empreendedores.</segment>
    <segment id="15">O mundo precisa de mais Jeff Bezos.</segment>
    <segment id="16">"</segment>
    <segment id="17">Jorge Paulo Lemann</segment>
    <segment id="18">, 3G Capital   Retrato de Jorge Paulo Lemann</segment>
    <segment id="19">, fundador do 3G Capital e da Fundação Estudar - Bruno Santos/ Folhapress“A Organização - A Odebrecht e o esquema de corrupção que chocou o mundo”  Malu Gaspar</segment>
    <segment id="20">, ed. Companhia das Letras</segment>
    <segment id="21">, 640 págs.</segment>
    <segment id="22">, R$ 99</segment>
    <segment id="23">,90  “</segment>
    <segment id="24">Apesar de termos acompanhado o noticiário na época</segment>
    <segment id="25">, você fica impressionado com a riqueza dos detalhes.</segment>
    <segment id="26">Exigiu certamente um enorme trabalho de apuração.</segment>
    <segment id="27">"</segment>
    <segment id="28">Sergio All</segment>
    <segment id="29">, Conta Black  Retrato de Sergio All</segment>
    <segment id="30">, fundador da Conta Black</segment>
    <segment id="31">, primeira conta digital criada por negros no Brasil - Monica Silva/Divulgação“O Jogo Infinito” Simon Sinek</segment>
    <segment id="32">, ed. Sextante</segment>
    <segment id="33">, 256 págs.</segment>
    <segment id="34">, R$ 24</segment>
    <segment id="35">,99</segment>
    <segment id="36">“</segment>
    <segment id="37">Ler esse livro foi fundamental para entender sobre o propósito de um negócio.</segment>
    <segment id="38">E reconhecer a importância de cada um dos participantes dos processos para o desenvolvimento do legado.</segment>
    <segment id="39">"</segment>
    <segment id="40">Horácio Lafer Piva</segment>
    <segment id="41">, Klabin  Horácio Lafer Piva</segment>
    <segment id="42">, da Klabin - Mastrangelo Reino/Folhapress“A Estrada” Cormac McCarthy</segment>
    <segment id="43">, ed. Alfaguara</segment>
    <segment id="44">, 240 págs.</segment>
    <segment id="45">, R$ 52</segment>
    <segment id="46">,90  “É uma historia que</segment>
    <segment id="47">sese passa num mundo futuro destruído e desesperançado</segment>
    <segment id="48">, no qual pai e o filho caminham em busca de sobrevivência e nada alem disto.</segment>
    <segment id="49">Uma pérola de texto e impacto.</segment>
    <segment id="50">"</segment>
    <segment id="51">Ricardo Lacerda</segment>
    <segment id="52">, BR Partners  Ricardo Lacerda</segment>
    <segment id="53">, sócio-fundador do BR Partners Banco de Investimento - Danilo Verpa/Folhapress“Desta Vez é Diferente:</segment>
    <segment id="54">Oito Séculos de Loucura Financeira” Carmen Reinhart e Kenneth Rogoff</segment>
    <segment id="55">, Actual Editora</segment>
    <segment id="56">, 774 págs.</segment>
    <segment id="57">, US$ 13</segment>
    <segment id="58">,83 (ebook)</segment>
    <segment id="59">“É uma obra disciplinada e rica em detalhes sobre</segment>
    <segment id="60">comocomo bolhas e crises afetam decisões de empresários e investidores.</segment>
    <segment id="61">"  Waldir Beira Junior</segment>
    <segment id="62">, Ypê  Waldir Beira Júnior</segment>
    <segment id="63">, presidente executivo da Ypê - Marco Flávio/Divulgação“A</segment>
    <segment id="64">Revolução dos Bichos” (obra foi rebatizada</segment>
    <segment id="65">comocomo “</segment>
    <segment id="66">A Fazenda dos Animais”</segment>
    <segment id="67">, em nova edição)</segment>
    <segment id="68">George Orwell</segment>
    <segment id="69">, ed. Companhia das Letras</segment>
    <segment id="70">, 248 págs.</segment>
    <segment id="71">, R$ 89</segment>
    <segment id="72">,89  “</segment>
    <segment id="73">Explora</segment>
    <segment id="74">temas atuais dos dias conturbados que vivemos.</segment>
    <segment id="75">Tem especial utilidade em relação à polarização nas posições ideológicas e políticas</segment>
    <segment id="76">, com direito a fake news.</segment>
    <segment id="77">"</segment>
  </rst>
