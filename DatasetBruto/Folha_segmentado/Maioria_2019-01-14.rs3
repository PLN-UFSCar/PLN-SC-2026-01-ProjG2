  <rst>
    <segment id="1">Baixa a pesquisa completa</segment>
    <segment id="2">Deputados e senadores que estão no Congresso atualmente têm seu desempenho aprovado por 13% dos brasileiros</segment>
    <segment id="3">, enquanto 48% os reprovam.</segment>
    <segment id="4">Há ainda 36% que consideram regular o trabalho dos congressistas.</segment>
    <segment id="5">A reprovação ao desempenho do Congresso atual caiu na comparação com novembro do ano passado</segment>
    <segment id="6">, quando havia atingido o nível recorde de 60%.</segment>
    <segment id="7">Entre os mais jovens</segment>
    <segment id="8">, a taxa dos que avaliam negativamente os parlamentares fica abaixo da média</segment>
    <segment id="9">, em 34%</segment>
    <segment id="10">, e sobe para 50% a avaliação regular.</segment>
    <segment id="11">Na parcela dos mais escolarizados</segment>
    <segment id="12">, por outro lado</segment>
    <segment id="13">, a reprovação fica acima da média (62%).</segment>
    <segment id="14">A expectativa em relação aos deputados e senadores que tomarão posse em 2019</segment>
    <segment id="15">, contudo</segment>
    <segment id="16">contudo</segment>
    <segment id="17">, é mais otimista: 56% acreditam que terão um desempenho ótimo ou bom</segment>
    <segment id="18">, 28%, que o desempenho será regular</segment>
    <segment id="19">, e apenas 8% preveem um trabalho ruim ou péssimo.</segment>
    <segment id="20">Há ainda 8% que não opinaram sobre o tema.</segment>
    <segment id="21">Uma comparação com levantamentos anteriores mostra confirma um nível mais alto de otimismo no momento atual: em 2014</segment>
    <segment id="22">, 40% esperavam um desempenho positivo dos parlamentares recém-eleitos para o Congresso</segment>
    <segment id="23">;</segment>
    <segment id="24">em 2010</segment>
    <segment id="25">, o índice era de 49%.</segment>
    <segment id="26">Entre eleitores que também estão otimistas com o governo Bolsonaro</segment>
    <segment id="27">, 71% preveem um desempenho ótimo ou bom do próximo Congresso.</segment>
    <segment id="28">Na parcela que espera um desempenho regular do futuro presidente</segment>
    <segment id="29">, o índice cai pela metade</segment>
    <segment id="30">, para 34%</segment>
    <segment id="31">, e entre quem avalia que o governo do político do PSL será ruim ou péssimo</segment>
    <segment id="32">, apenas 17% preveem que deputados e senadores façam um trabalho ótimo ou bom.</segment>
    <segment id="33">Fachada do Congresso Nacional</segment>
    <segment id="34">, a sede das duas Casas do Poder Legislativo brasileiro - Roque de Sá/Agência Senado</segment>
  </rst>
</analysis>