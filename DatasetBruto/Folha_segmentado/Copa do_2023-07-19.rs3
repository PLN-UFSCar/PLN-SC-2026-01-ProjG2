  <rst>
    <segment id="1">Os principais dirigentes da Fifa previram</segment>
    <segment id="2">, nesta quarta-feira (19)</segment>
    <segment id="3">, que a Copa do Mundo feminina na Nova Zelândia e na Austrália quebrará recordes de espectadores e de público em estádios</segment>
    <segment id="4">, em um sinal do crescimento do futebol feminino.  "</segment>
    <segment id="5">Os olhos do mundo estarão aqui.</segment>
    <segment id="6">Esperamos atingir um quarto da população mundial</segment>
    <segment id="7">, 2 bilhões de pessoas</segment>
    <segment id="8">, que assistirão a pelo menos uma partida"</segment>
    <segment id="9">, disse a secretária-geral da Fifa</segment>
    <segment id="10">, Fatma Samoura</segment>
    <segment id="11">, em entrevista em Auckland.</segment>
    <segment id="12">"</segment>
    <segment id="13">Este torneio será o primeiro Mundial feminino organizado por duas confederações</segment>
    <segment id="14">, a primeira do hemisfério sul</segment>
    <segment id="15">, a primeira com 32 seleções</segment>
    <segment id="16">, oito delas estreantes"</segment>
    <segment id="17">, acrescentou Samoura.</segment>
    <segment id="18">A secretária-geral da Fifa</segment>
    <segment id="19">, Fatma Samoura</segment>
    <segment id="20">, e o presidente da entidade</segment>
    <segment id="21">, Gianni Infantino</segment>
    <segment id="22">, durante entrevista antes da abertura da Copa do Mundo feminina - Saeed Khan/AFPA dirigente assegurou que os bilhetes vendidos para o torneio deste ano já superam os da Copa há quatro anos</segment>
    <segment id="23">, na França</segment>
    <segment id="24">, com 1.375.000 já vendidos e muitos mais disponíveis.</segment>
    <segment id="25">"</segment>
    <segment id="26">Vai ser o Mundial Feminino com maior público"</segment>
    <segment id="27">, comentou Samoura.</segment>
    <segment id="28">A mídia da Nova Zelândia</segment>
    <segment id="29">, porém</segment>
    <segment id="30">porém, relatou baixas vendas de partidas em seu território</segment>
    <segment id="31">, masmas não na Austrália</segment>
    <segment id="32">, o outro país-sede.</segment>
    <segment id="33">Por exemplo</segment>
    <segment id="34">, 80 mil ingressos já estão esgotados para o primeiro jogo da Austrália contra a Irlanda em Sydney</segment>
    <segment id="35">, na quinta-feira (20)</segment>
    <segment id="36">, enquanto a partida de abertura entre Nova Zelândia e Noruega</segment>
    <segment id="37">, no mesmo dia</segment>
    <segment id="38">, no Eden Park de Auckland (com capacidade para 50 mil espectadores)</segment>
    <segment id="39">, os ingressos ainda estão disponíveis.</segment>
    <segment id="40">E segundo dados da organização</segment>
    <segment id="41">, dos mais de 1</segment>
    <segment id="42">,3 milhão de ingressos vendidos até quarta-feira</segment>
    <segment id="43">, apenas 320 mil correspondem às partidas que serão disputadas na Nova Zelândia</segment>
    <segment id="44">, incluindo todas as da primeira fase dos Estados Unidos</segment>
    <segment id="45">, atual campeão e grande favorito para a classificação.</segment>
    <segment id="46">Dinheiro</segment>
    <segment id="47">, 'uma questão delicada'</segment>
    <segment id="48">O presidente da Fifa</segment>
    <segment id="49">, Gianni Infantino</segment>
    <segment id="50">, também foi repetidamente questionado sobre</segment>
    <segment id="51">comocomo garantir que os prêmios atribuídos às jogadoras</segment>
    <segment id="52">, de US$ 30 mil (R$ 144 mil) cada</segment>
    <segment id="53">, cheguem até elas</segment>
    <segment id="54">, masmas evitou responder</segment>
    <segment id="55">, argumentando que "o dinheiro é sempre um assunto delicado".</segment>
    <segment id="56">No entanto</segment>
    <segment id="57">, o cartola garantiu que a entidade criou pela primeira vez um programa comercial "que nos gerou cifras interessantes"</segment>
    <segment id="58">, de US$ 500 milhões (R$ 2</segment>
    <segment id="59">,4 bilhões)</segment>
    <segment id="60">, que nos permitiu cobrir os custos do torneio.</segment>
    <segment id="61">"Será um show realmente único.</segment>
    <segment id="62">Muitas pessoas ainda acreditam que o futebol feminino não é um grande jogo</segment>
    <segment id="63">, que é uma cópia ruim do futebol masculino</segment>
    <segment id="64">, masmas quando o veem percebem que é fantástico"</segment>
    <segment id="65">, disse Infantino.  "</segment>
    <segment id="66">O nível aumentou nos últimos 10 anos e os melhores jogadores estão aqui"</segment>
    <segment id="67">, afirmou.</segment>
  </rst>
</analysis>