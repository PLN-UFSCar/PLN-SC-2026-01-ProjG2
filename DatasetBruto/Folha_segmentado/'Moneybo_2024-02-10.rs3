  <rst>
    <segment id="1">MoneyboysQuando</segment>
    <segment id="2">Em cartaz nos cinemasClassificação 16 anosElenco Kai Ko Chen-Tung</segment>
    <segment id="3">, Chloe Maayan</segment>
    <segment id="4">, Yufan BaiProdução Áustria e França</segment>
    <segment id="5">, 2021Direção C.B.</segment>
    <segment id="6">YiUm jovem garoto de programa chinês.</segment>
    <segment id="7">Fei, o protagonista</segment>
    <segment id="8">, deixou sua aldeia no campo para ganhar a vida na cidade grande —e vende o corpo para enviar dinheiro à família que deixou para trás.</segment>
    <segment id="9">Em "Moneyboys"</segment>
    <segment id="10">, encontramos esse protagonista desenraizado</segment>
    <segment id="11">, um fruto que foi cair longe da árvore.</segment>
    <segment id="12">A dimensão desse rompimento de laços logo vai ficar clara.</segment>
    <segment id="13">Ao tentar voltar à sua aldeia para visitar o avô</segment>
    <segment id="14">, Fei é vítima da homofobia raivosa dos parentes.</segment>
    <segment id="15">Cena do filme &amp;#039</segment>
    <segment id="16">;Moneyboys&amp;#039</segment>
    <segment id="17">;, de C.B. Yi - DivulgaçãoEm resumo</segment>
    <segment id="18">, a família que aceitava seu dinheiro não pode aceitar a forma</segment>
    <segment id="19">comocomo ele ganha a vida</segment>
    <segment id="20">, menos ainda a sua homossexualidade.</segment>
    <segment id="21">Proibido de retornar</segment>
    <segment id="22">, ele tem diante de si um drama de formação</segment>
    <segment id="23">, o de construir uma identidade e uma vida que sejam só suas</segment>
    <segment id="24">, acima do que cobra a tradição familiar.</segment>
    <segment id="25">E precisa encontrar tal identidade em um meio de caminho.</segment>
    <segment id="26">Afinal</segment>
    <segment id="27">, Fei já é urbano demais para sua velha aldeia</segment>
    <segment id="28">, masmas quem o rapaz da aldeia pode ser na cidade grande?</segment>
    <segment id="29">Cenas do filme &amp;#039</segment>
    <segment id="30">;Moneyboys&amp;#039</segment>
    <segment id="31">;Mais    novamente         de   de  de  representando um  Exibido na mostra</segment>
    <segment id="32">Um Certo Olhar</segment>
    <segment id="33">, do Festival de Cannes</segment>
    <segment id="34">, "Moneyboys" é o longa-metragem de estreia de C.B. Yi</segment>
    <segment id="35">, que busca na história a dimensão emocional de uma realidade social.</segment>
    <segment id="36">Ao longo das décadas</segment>
    <segment id="37">, centenas de milhões de chineses deixaram a vida no campo para tentar a sorte nas cidades.</segment>
    <segment id="38">O público internacional que entende chinês</segment>
    <segment id="39">, aliás</segment>
    <segment id="40">, sese incomodou com o filme.</segment>
    <segment id="41">A história</segment>
    <segment id="42">sese passa na China</segment>
    <segment id="43">, masmas foi filmada em Taiwan —o que não seria um problema</segment>
    <segment id="44">sese, segundo os entendidos</segment>
    <segment id="45">, os personagens não falassem uma mistura de sotaque mandarim mal-ajambrado e o sotaque taiwanês.</segment>
    <segment id="46">Mas, no Brasil</segment>
    <segment id="47">, isso não será problema para ninguém (ou quase ninguém).</segment>
    <segment id="48">O que resta para quem não pode entender os problemas de verossimilhança idiomática é um filme comovente</segment>
    <segment id="49">, com um protagonista cheio de longos silêncios</segment>
    <segment id="50">, tanto de palavras quanto de gestos —por vezes</segment>
    <segment id="51">, o espectador</segment>
    <segment id="52">sese vê intrigado ao tentar decifrar o rapaz em cena.</segment>
    <segment id="53">Ponto para a interpretação econômica de Kai Ko Chen-Tung.</segment>
    <segment id="54">Aqui, a cidade não é só um espaço de relativa liberdade sexual</segment>
    <segment id="55">, masmas também um ambiente que pode ser sufocante.</segment>
    <segment id="56">Primeiro</segment>
    <segment id="57">, porque</segment>
    <segment id="58">porque a tal liberdade é relativa</segment>
    <segment id="59">, e a polícia está de olho para armar arapucas contra a prostituição.</segment>
    <segment id="60">Segundo</segment>
    <segment id="61">, porque</segment>
    <segment id="62">porque o trabalho com os programas é degradante e cria um estigma</segment>
    <segment id="63">, como</segment>
    <segment id="64">como mostra a relação de Fei com sua família.</segment>
    <segment id="65">O sexo por dinheiro é retratado no filme</segment>
    <segment id="66">comocomo uma reles burocracia</segment>
    <segment id="67">, um ato mecânico reduzido a uma transação comercial.</segment>
    <segment id="68">Mas, fora da prostituição</segment>
    <segment id="69">, o cenário não é muito melhor.</segment>
    <segment id="70">Um amigo do protagonista que também vai para cidade e quer</segment>
    <segment id="71">sese prostituir é quem lança o argumento —trabalhar em postos precários para ganhar nada também não é vender o corpo?</segment>
    <segment id="72">Esse amigo</segment>
    <segment id="73">, Long</segment>
    <segment id="74">, é quem traz a doçura para o filme e desarranja a trajetória de melancolia do personagem principal.</segment>
    <segment id="75">Alegre</segment>
    <segment id="76">, apaixonado</segment>
    <segment id="77">, intenso e otimista</segment>
    <segment id="78">, ele convoca Fei a encontrarem juntos alguma alegria</segment>
    <segment id="79">, sem estarem aprisionados à rejeição da aldeia.</segment>
    <segment id="80">O conflito está posto diante do protagonista.</segment>
    <segment id="81">Ferido por tantas humilhações</segment>
    <segment id="82">, ele ainda sabe dizer sim?</segment>
  </rst>
</analysis>