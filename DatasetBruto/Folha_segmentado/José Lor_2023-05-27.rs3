  <rst>
    <segment id="1">O ator José Loreto causou furor na São Paulo Fashion Week</segment>
    <segment id="2">, na noite de sexta-feira (26)</segment>
    <segment id="3">, ao desfilar usando uma sunga fio dental que deixou o seu bumbum de fora.</segment>
    <segment id="4">Os atores Luis Lobianco e José Loreto desfilam na São Paulo Fashion Week  - Reprodução /SPFW no Youtube</segment>
    <segment id="5">O artista participou da apresentação da grife</segment>
    <segment id="6">The Paradise</segment>
    <segment id="7">, que fez sua estreia na semana de moda paulistana.</segment>
    <segment id="8">Loreto publicou neste sábado (27)</segment>
    <segment id="9">, dia em que faz aniversário</segment>
    <segment id="10">, um vídeo em que aparece em sua performance para a marca.</segment>
    <segment id="11">"</segment>
    <segment id="12">Cheguei aos meus 39 anos desfilando alegria</segment>
    <segment id="13">, ousadia</segment>
    <segment id="14">, arte</segment>
    <segment id="15">, verdade</segment>
    <segment id="16">, saúde</segment>
    <segment id="17">, gratidão e um montão de coisas que a vida tem me ensinado!!!</segment>
    <segment id="18">Evoé, axé e avante José!!</segment>
    <segment id="19">Obrigado</segment>
    <segment id="20">, meus amores!</segment>
    <segment id="21">", escreveu na legenda.</segment>
    <segment id="22">Além da sunga</segment>
    <segment id="23">, ele usou uma camisa aberta e tênis.</segment>
    <segment id="24">Em sua segunda aparição na passarela</segment>
    <segment id="25">, o ator vestiu bermuda e camisa de poás coloridos e fez uma dancinha semelhante a do personagem Lui Lorenzo</segment>
    <segment id="26">, que interpreta na novela "Vai na Fé"</segment>
    <segment id="27">, da Globo.</segment>
    <segment id="28">Imagens do ator</segment>
    <segment id="29">José LoretoMais    novamente         de   de  de  representando</segment>
