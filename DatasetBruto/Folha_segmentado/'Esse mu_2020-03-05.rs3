  <rst>
    <segment id="1">O médico Drauzio Varella</segment>
    <segment id="2">, 76, que ganhou as redes sociais após dar um abraço em uma presidiária transexual que não recebia visitas havia oito anos durante uma entrevista</segment>
    <segment id="3">, explica o gesto:</segment>
    <segment id="4">“Eu fiquei muito emocionado.</segment>
    <segment id="5">Teve toda essa repercussão</segment>
    <segment id="6">porque</segment>
    <segment id="7">porque as pessoas sentiram essa tristeza que eu senti.</segment>
    <segment id="8">Não tem realidade mais dura”.</segment>
    <segment id="9">O médico cancerologista Drauzio Varella - Bruno Santos - 22.jul.2019/FolhapressLONGE DE MIM</segment>
    <segment id="10">Os internautas passaram também a sugerir que ele ocupe o Ministério da Saúde ou até mesmo que concorra à Presidência.</segment>
    <segment id="11">“Esse mundo tá louco”</segment>
    <segment id="12">, diz Drauzio.</segment>
    <segment id="13">“Nós vivemos procurando por um salvador da pátria.</segment>
    <segment id="14">Esse é o drama do país.</segment>
    <segment id="15">A gente</segment>
    <segment id="16">sese decepciona com um e corre atrás de outro que seja o oposto.</segment>
    <segment id="17">Vamos ficar assim até quando?</segment>
    <segment id="18">”</segment>
    <segment id="19">LEIA</segment>
    <segment id="20">TODOS OS TEMAS ABORDADOS PELA COLUNA</segment>
    <segment id="21">NESTA QUINTA (5)  ​Regina Duarte é bomba perto de explodir</segment>
    <segment id="22">, avalia núcleo de Bolsonaro  Tutuca vai fazer media training para sabatina no Senado   Bebianno diz que general Heleno não liga 'nome à pessoa' no</segment>
    <segment id="23">casocaso de Abin paralela   Viúva de Gugu vai à Justiça para receber mensalidades atrasadas   Arthur 'Mamãe Falei' cria site para recrutar candidatos a vereador   Escritório de advocacia promove debate sobre avanços e desafios femininos</segment>
    <segment id="24">O rapper Emicida posa para a revista GQ Brasil - Caroline LimaHUMANIDADE</segment>
    <segment id="25">“Se tenho a oportunidade de ter a vida que tenho</segment>
    <segment id="26">, é óbvio que vou alcançar o máximo do meu potencial”</segment>
    <segment id="27">, diz o rapper Emicida à revista GQ Brasil deste mês</segment>
    <segment id="28">; na entrevista</segment>
    <segment id="29">, ele diz que começou a cultivar uma horta e que está à procura de serenidade:</segment>
    <segment id="30">“Nossa vitória não é ser bilionário</segment>
    <segment id="31">, é ser humano”.</segment>
    <segment id="32">Estreia do filme &amp;#039</segment>
    <segment id="33">;Fim de Festa&amp;#039</segment>
    <segment id="34">;   novamente         de   de  de  representando um  SALA CHEIA</segment>
    <segment id="35">O ator Silvero Pereira e o diretor Kiko Goifman foram à estreia do filme “Fim de Festa”</segment>
    <segment id="36">, no Reserva Cultural</segment>
    <segment id="37">, em SP</segment>
    <segment id="38">, na terça-feira (3).</segment>
    <segment id="39">A produtora Paula Cosenza e a cantora Assucena Assucena também estiveram lá.   CURTO-CIRCUITO</segment>
    <segment id="40">O Auditório Ibirapuera recebe a 7ª Mostra Internacional de Teatro de SP.</segment>
    <segment id="41">Na quinta (5)</segment>
    <segment id="42">, às 20h.</segment>
    <segment id="43">O Pavilhão da Bienal de SP recebe</segment>
    <segment id="44">, a partir de sexta (6)</segment>
    <segment id="45">, o Festival Sesi de Robótica.</segment>
    <segment id="46">A estilista Fernanda Yamamoto expõe peças desfiladas na SPFW.</segment>
    <segment id="47">No Senac Santo Amaro</segment>
    <segment id="48">, até 30 de junho.  com BRUNO B. SORAGGI</segment>
    <segment id="49">, BIANKA VIEIRA e VICTORIA AZEVEDO</segment>
