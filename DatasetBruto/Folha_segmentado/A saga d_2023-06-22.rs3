  <rst>
    <segment id="1">Quando o inverno chegar</segment>
    <segment id="2">, eu quero estar junto a ti.</segment>
    <segment id="3">Chegou.</segment>
    <segment id="4">Se não houver "ti" e o vozeirão do Tim não for suficiente</segment>
    <segment id="5">, vá de irish coffee —é garantia para esquentar a alma</segment>
    <segment id="6">, nem que seja um pouco.</segment>
    <segment id="7">Colunas e BlogsReceba no seu email uma seleção de colunas e blogs da Folha</segment>
    <segment id="8">; exclusiva para assinantes.</segment>
    <segment id="9">Carregando...</segment>
    <segment id="10">O caife gaelach</segment>
    <segment id="11">, em bom irlandês</segment>
    <segment id="12">, foi inventado em 1942</segment>
    <segment id="13">, no antigo aeroporto de Foynes</segment>
    <segment id="14">, na Irlanda</segment>
    <segment id="15">, para animar turistas depois que o hidroavião em que estavam teve de pousar na baía novamente</segment>
    <segment id="16">, acossado por uma tempestade.</segment>
    <segment id="17">O chef do aeroporto decidiu acrescentar uísque ao café.</segment>
    <segment id="18">Assim, com o hidroavião estacionado</segment>
    <segment id="19">, foram os turistas que decolaram.</segment>
    <segment id="20">Dez anos depois</segment>
    <segment id="21">, a receita acabou nas mãos de um dono de bar em San Francisco</segment>
    <segment id="22">, o Buena Vista</segment>
    <segment id="23">, que chamou o chef de Foynes para garantir a textura certa do creme no topo.</segment>
    <segment id="24">A bebida virou mania nos EUA e no mundo</segment>
    <segment id="25">, alavancando as vendas do uísque irlandês</segment>
    <segment id="26">, que andava esquecido desde que a guerra civil dividiu o país</segment>
    <segment id="27">, em 1922</segment>
    <segment id="28">, dificultando a produção nos alambiques.</segment>
    <segment id="29">Antes muito popular</segment>
    <segment id="30">, é anterior ao escocês</segment>
    <segment id="31">, sendo um dos primeiros destilados da história.</segment>
    <segment id="32">Monges do Eire trouxeram a técnica de destilação de viagens ao Mediterrâneo no século 14.</segment>
    <segment id="33">Um consolo para os horrores da Peste Negra.</segment>
    <segment id="34">Irish coffee do Viggar Bar</segment>
    <segment id="35">;</segment>
    <segment id="36">drinque leva uísque irlandês</segment>
    <segment id="37">, café</segment>
    <segment id="38">, açúcar demerara e creme de leite batido - Luiz Vigga/DivulgaçãoEm termos gerais</segment>
    <segment id="39">, a diferença entre ambos uísques é simples:</segment>
    <segment id="40">enquanto os escoceses destilam o malte duas vezes</segment>
    <segment id="41">, os irlandeses o fazem três vezes —e com outros grãos.</segment>
    <segment id="42">O resultado é uma bebida mais suave.</segment>
    <segment id="43">Nos áureos tempos</segment>
    <segment id="44">, o pai de Joyce teve uma destilaria.</segment>
    <segment id="45">A experiência vazou para dentro do "Ulisses".</segment>
    <segment id="46">Kingsley Amis</segment>
    <segment id="47">, devoto do irish coffee</segment>
    <segment id="48">, assim</segment>
    <segment id="49">comocomo de outras trezentas misturas</segment>
    <segment id="50">, explica</segment>
    <segment id="51">, no seu "Everyday Drinking"</segment>
    <segment id="52">, que é um drinque difícil de preparar</segment>
    <segment id="53">, tanto por conta da quantidade de açúcar quanto pelo equilíbrio do creme —o toque final.</segment>
    <segment id="54">Citando um amigo</segment>
    <segment id="55">, recomenda que</segment>
    <segment id="56">, sese o creme</segment>
    <segment id="57">sese misturar à bebida</segment>
    <segment id="58">, é melhor não servir —beba o drinque errado de um gole e prepare outro.  Faz todo sentido.</segment>
    <segment id="59">Afinal</segment>
    <segment id="60">, a exata camada de creme é a fronteira que separa a realidade fria do afago quente aos sentidos.</segment>
    <segment id="61">Uma fantasia realizada</segment>
    <segment id="62">, diriam os fãs fervorosos.</segment>
    <segment id="63">Dentre eles</segment>
    <segment id="64">, John Cheever.</segment>
    <segment id="65">Consta que</segment>
    <segment id="66">, numa viagem à Irlanda</segment>
    <segment id="67">, bateu o carro.</segment>
    <segment id="68">Enquanto esperava socorro</segment>
    <segment id="69">, bebeu vários irish coffees num bar na estrada.</segment>
    <segment id="70">Animado</segment>
    <segment id="71">, compôs uma cantiga para o uísque irlandês</segment>
    <segment id="72">, poção mágica de um certo cavaleiro errante.</segment>
    <segment id="73">É algo que parece</segment>
    <segment id="74">sese repetir com escritores.</segment>
    <segment id="75">Balzac tomava cerca de 40 xícaras de café por dia.</segment>
    <segment id="76">Era seu combustível para dar conta de toda a "Comédia Humana".</segment>
    <segment id="77">Dizem que morreu disso.</segment>
    <segment id="78">Em "</segment>
    <segment id="79">Pai Goriot"</segment>
    <segment id="80">, faz menção à glória</segment>
    <segment id="81">, não aquela perseguida por vaidosos</segment>
    <segment id="82">, sonhadores e celerados</segment>
    <segment id="83">, masmas um amálgama semelhante</segment>
    <segment id="84">, com café e conhaque ou rum.</segment>
    <segment id="85">Flaubert faria o mesmo.</segment>
    <segment id="86">Em "Madame Bovary"</segment>
    <segment id="87">, lê-se</segment>
    <segment id="88">se: "gostava de boa sidra</segment>
    <segment id="89">, pernil de cordeiro mal passado e glórias bem batidas.</segment>
    <segment id="90">"</segment>
    <segment id="91">Como se</segment>
    <segment id="92">se vê, o pai da desditosa Emma curtia os prazeres da mesa</segment>
    <segment id="93">, incluindo o irish coffe à francesa.</segment>
    <segment id="94">Na Viena de Egon Schiele e Robert Musil</segment>
    <segment id="95">, essa glória também era comum</segment>
    <segment id="96">, sob o nome pharisäer.</segment>
    <segment id="97">Eternamente insatisfeita</segment>
    <segment id="98">, Emma Bovary teve fim inglório.</segment>
    <segment id="99">Em outro tempo</segment>
    <segment id="100">, sese aceitasse a rosa trazida por Monsieur Maia</segment>
    <segment id="101">, talvez visse a próxima primavera.</segment>
    <segment id="102">E bebesse bons irish coffees.</segment>
    <segment id="103">IRISH COFFEE  45 ml de uísque irlandês (não serve outro)  90 ml de café  10 ml de xarope de açúcar mascavo  20 ml de creme de leite</segment>
    <segment id="104">Esquente a taça com água fervente e descarte.</segment>
    <segment id="105">Ponha os três primeiros ingredientes e mexa.</segment>
    <segment id="106">Bata o creme de leite num pote até o volume aumentar em cerca de ⅓. Despeje-o lentamente em uma colher</segment>
    <segment id="107">, de forma a manter a camada de creme sobre a bebida.</segment>
  </rst>
</analysis>