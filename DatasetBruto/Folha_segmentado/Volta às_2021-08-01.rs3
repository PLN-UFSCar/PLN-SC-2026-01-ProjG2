    <segment id="221">50% Escola Brigadeiro Gavião Peixoto (Perus):</segment>
    <segment id="222">50% Escola Charles de Gaulle (Jardim Ina):</segment>
    <segment id="223">50% Escola General Humberto de Souza Mello (Parada de Taipas):</segment>
    <segment id="224">50% Padre Tiago Alberione (Cidade Julia):</segment>
    <segment id="225">50% João Solimeo (Jardim Maristela):</segment>
    <segment id="226">50% Prof.</segment>
    <segment id="227">Marcos Antonio Costa (Jardim Santo André):</segment>
    <segment id="228">sem informação</segment>
  </rst>
</analysis>