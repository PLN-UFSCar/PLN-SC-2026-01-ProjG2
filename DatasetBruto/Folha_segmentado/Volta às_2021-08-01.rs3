    <segment id="217">Aroldo de Azevedo (Jardim Planalto):</segment>
    <segment id="218">50% Escola Reverendo Erodice Pontes de Queiroz (Jardim Casa Grande):</segment>
    <segment id="219">indefinido Escola Prof.</segment>
