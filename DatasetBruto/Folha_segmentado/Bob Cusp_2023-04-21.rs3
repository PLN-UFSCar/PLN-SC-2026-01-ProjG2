  <rst>
    <segment id="1">Este domingo</segment>
    <segment id="2">, dia 23</segment>
    <segment id="3">, marca quatro décadas desde que Bob Cuspe começou a atirar saliva por onde e por quem passasse em tirinhas publicadas nas páginas da Folha.</segment>
    <segment id="4">Cena da animação &amp;#</segment>
    <segment id="5">039;Bob Cuspe - Nós Não Gostamos de Gente&amp;#039</segment>
    <segment id="6">;, dirigida por Cesar Cabral e selecionada para o Festival de Annecy - DivulgaçãoCriado por Angeli</segment>
    <segment id="7">, Bob virou um ícone punk dos anos 1980 e 1990.</segment>
    <segment id="8">De moicano verde</segment>
    <segment id="9">, óculos escuros</segment>
    <segment id="10">, jaqueta e com piercings pendurados pelo corpo</segment>
    <segment id="11">, o personagem retratava a geração contestadora.</segment>
    <segment id="12">Prova disso é sua primeira tirinha</segment>
    <segment id="13">, em que o personagem</segment>
    <segment id="14">, mal-humorado</segment>
    <segment id="15">, leva um tombo causado por ele mesmo em frente a uma metrópole.</segment>
    <segment id="16">Agora, Bob vai além das páginas para estampar um tênis.</segment>
    <segment id="17">Idealizado pela marca Öus e pela Fresh People</segment>
    <segment id="18">, um setor da agência Press Pass</segment>
    <segment id="19">, o calçado é pintado nas cores do personagem —preto</segment>
    <segment id="20">, branco e verde.</segment>
    <segment id="21">Ao preço de R$ 589</segment>
    <segment id="22">, o tênis será lançado em maio.</segment>
    <segment id="23">Tênis de Bob Cuspe</segment>
    <segment id="24">, personagem de Angeli</segment>
    <segment id="25">, feito pela marca Öus-</segment>
    <segment id="26">DviulgaçãoNão é a primeira vez que Bob ultrapassa os limites dos quadrinhos.</segment>
    <segment id="27">A criação de Angeli foi tema também do filme "</segment>
    <segment id="28">Bob Cuspe –</segment>
    <segment id="29">Nós Não Gostamos de Gente"</segment>
    <segment id="30">, lançado em 2021.</segment>
    <segment id="31">Produzida em stopmotion</segment>
    <segment id="32">, a animação foi premiada nos festivais de Annecy e Ottawa</segment>
    <segment id="33">, que estão entre os mais importantes do setor</segment>
    <segment id="34">, e também disputou uma vaga para ser indicada ao Oscar.</segment>
    <segment id="35">Relembre os principais personagens do cartunista AngeliMais    novamente         de   de  de  representando um</segment>
    <segment id="36">O filme não angariou uma indicação</segment>
    <segment id="37">, masmas Angeli estava satisfeito só com a possibilidade de ver seu personagem participar da premiação.</segment>
    <segment id="38">O cartunista</segment>
    <segment id="39">, de 66 anos</segment>
    <segment id="40">, recebeu no ano passado um diagnóstico de afasia</segment>
    <segment id="41">, condição neurodegenerativa que prejudica a comunicação</segment>
    <segment id="42">, verbal ou escrita.</segment>
    <segment id="43">Então, precisou</segment>
    <segment id="44">sese aposentar</segment>
    <segment id="45">, encerrando uma carreira que revolucionou a arte que</segment>
    <segment id="46">sese podia fazer em jornais.</segment>
    <segment id="47">A primeira tira de Bob Cuspe na Folha</segment>
    <segment id="48">, publicada em 23 de abril de 1983 - Reprodução</segment>
  </rst>
</analysis>