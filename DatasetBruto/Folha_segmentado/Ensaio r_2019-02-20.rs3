  <rst>
    <segment id="1">Os cenários dos contos dos irmãos Grimm</segment>
    <segment id="2">, na Alemanha</segment>
    <segment id="3">, foram inspiração para um ensaio do fotógrafo alemão Kilian Schönberger.</segment>
    <segment id="4">“Cresci lendo contos de fada e europeus e fiquei fascinado</segment>
    <segment id="5">, as pessoas inventavam histórias para explicar coisas que não entendiam”</segment>
    <segment id="6">, diz.</segment>
    <segment id="7">Locais das histórias dos irmãos GrimmMais    novamente         de   de  de  representando um</segment>
    <segment id="8">O castelo de Eltz</segment>
    <segment id="9">, a ponte do Diabo de Rakotzbrücke e a floresta Fantasma</segment>
    <segment id="10">, no município de Nienhagen</segment>
    <segment id="11">, são alguns dos lugares onde foram feitas as imagens.</segment>
    <segment id="12">Há contos que não</segment>
    <segment id="13">sese passam em localidades específicas.</segment>
    <segment id="14">“Por isso decidi capturar lugares que emulam a atmosfera das histórias”</segment>
    <segment id="15">, diz o fotógrafo.</segment>
    <segment id="16">Seu conto favorito dos irmãos Grimm é “</segment>
    <segment id="17">O Menino que Saiu de Casa para Saber o que Era o Medo”.</segment>
    <segment id="18">O projeto consumiu 18 meses de trabalho.</segment>
  </rst>
</analysis>