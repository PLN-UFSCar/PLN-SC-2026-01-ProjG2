  <rst>
    <segment id="1">Pouco depois de o autismo ter</segment>
    <segment id="2">sese instalado</segment>
    <segment id="3">comocomo um tópico do meu cotidiano</segment>
    <segment id="4">, quando eu tinha muitas dúvidas e nenhuma resposta (nem mesmo um diagnóstico)</segment>
    <segment id="5">, ganhei de presente da minha mãe o livro "</segment>
    <segment id="6">Autismo - Compreender e Agir em Família"</segment>
    <segment id="7">, escrito por Sally Rogers</segment>
    <segment id="8">, Geraldine Dawson (criadoras do modelo Denver) e Laurie A. Vismara.</segment>
    <segment id="9">Usando estratégias simples e o contexto cotidiano das famílias (ou naturalístico)</segment>
    <segment id="10">, o livro ensina</segment>
    <segment id="11">comocomo potencializar relações prazerosas e ajudar a desenvolver habilidades</segment>
    <segment id="12">comocomo a atenção compartilhada</segment>
    <segment id="13">, a troca de turnos</segment>
    <segment id="14">, a imitação</segment>
    <segment id="15">, a flexibilidade e o jogo simbólico (o faz de contas).Livro ensina técnicas para crianças trabalharem habilidades com crianças autistas - DivulgaçãoAs dicas são bem práticas.</segment>
    <segment id="16">"</segment>
    <segment id="17">Quando está a brincar ou a cuidar do seu filho</segment>
    <segment id="18">, comece por posicionar-</segment>
    <segment id="19">sese de modo a que ele tenha uma visão nítida do seu rosto e olhos.</segment>
    <segment id="20">Tanto quanto possível</segment>
    <segment id="21">, procure estar perto dele</segment>
    <segment id="22">, ao mesmo nível e frente a frente</segment>
    <segment id="23">, tanto durante as brincadeiras</segment>
    <segment id="24">comocomo durante os cuidados.</segment>
    <segment id="25">Nunca é demais realçar a importância do posicionamento para aumentar a atenção da criança"</segment>
    <segment id="26">, diz um trecho do livro.</segment>
    <segment id="27">Em seguida</segment>
    <segment id="28">, as autoras dão exemplos de</segment>
    <segment id="29">comocomo colocar aquela sugestão específica em prática:</segment>
    <segment id="30">colocar a criança deitada enquanto o adulto</segment>
    <segment id="31">, de pé</segment>
    <segment id="32">, sese inclina sobre a criança para cantar ou fazer brincadeiras</segment>
    <segment id="33">;</segment>
    <segment id="34">jogos físicos na cama ou no sofá</segment>
    <segment id="35">, com a criança deitada ou de pé</segment>
    <segment id="36">; brincar e cantar com a criança sentada no colo</segment>
    <segment id="37">, de frente para você.</segment>
    <segment id="38">Ao mesmo tempo em que oferece um passo-a-passo para trabalhar cada habilidade</segment>
    <segment id="39">, o livro explica por que elas são importantes para o desenvolvimento e oferece hipóteses de por que muitas pessoas no espectro autista têm dificuldades relacionadas a essas habilidades.</segment>
    <segment id="40">Para mim</segment>
    <segment id="41">, o livro foi um bom ponto de partida para entender habilidades que precisariam ser trabalhadas e</segment>
    <segment id="42">comocomo eu poderia incluí-las no nosso dia-a-dia de maneira lúdica e contínua -- ainda que</segment>
    <segment id="43">, muitas vezes</segment>
    <segment id="44">, conseguir aqueles objetivos fosse mais complicado do que parecia durante a leitura do livro.</segment>
  </rst>
</analysis>