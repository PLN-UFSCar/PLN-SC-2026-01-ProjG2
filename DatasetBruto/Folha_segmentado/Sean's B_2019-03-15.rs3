  <rst>
    <segment id="1">Em um dia de semana comum na cidade de Athloneno</segment>
    <segment id="2">, no Condado de Westmeath</segment>
    <segment id="3">, Irlanda</segment>
    <segment id="4">, o silêncio cai sobre as ruas e</segment>
    <segment id="5">, longe de agências bancárias</segment>
    <segment id="6">, hotéis e centros comerciais</segment>
    <segment id="7">, os ônibus estão vazios.</segment>
    <segment id="8">Barcos e lanchas ancorados no rio Shannon estão parados enquanto a água escura passa.</segment>
    <segment id="9">Mas além da ponte de pedra arqueada que</segment>
    <segment id="10">sese vê ali</segment>
    <segment id="11">, há um prédio modesto na margem oeste do rio e</segment>
    <segment id="12">, dentro dele</segment>
    <segment id="13">, um barman de 50 anos chamado Timmy Donovan já está preparando a primeira dose do dia —a agitação no lugar está começando.</segment>
    <segment id="14">O local</segment>
    <segment id="15">, o Sean's Bar</segment>
    <segment id="16">, é um pub.</segment>
    <segment id="17">Quando encerrar o expediente</segment>
    <segment id="18">, depois da meia-noite</segment>
    <segment id="19">, sua lareira terá ardido o dia quase inteiro e vários copos de cerveja com espuma cremosa —e muitas doses de uísque e xícaras de irish coffee— terão sido servidos.</segment>
    <segment id="20">Do mesmo jeito que os funcionários do pub mal iluminado faziam com tipos mais rudimentares de bebidas</segment>
    <segment id="21">, como</segment>
    <segment id="22">como o hidromel</segment>
    <segment id="23">, 1.100 anos atrás.</segment>
    <segment id="24">O Sean&amp;#039</segment>
    <segment id="25">;s Bar em Athlone</segment>
    <segment id="26">, na Irlanda</segment>
    <segment id="27">, serve bebidas há 1.100 anos - Mike Maceacheran/BBC News BrasilCom seu piso revestido de madeira e paredes feitas de taipa e varas entrelaçadas com pelos de cavalo e argila</segment>
    <segment id="28">, o Sean's Bar está em atividade desde a Idade Média.</segment>
    <segment id="29">Localizado perto das ruínas de um castelo normando do século 12</segment>
    <segment id="30">, ele é o pub mais antigo na Irlanda</segment>
    <segment id="31">, título oficialmente registrado pelo livro dos recordes em 2004.</segment>
    <segment id="32">Mas muitos</segment>
    <segment id="33">, incluindo os atuais proprietários</segment>
    <segment id="34">, vários frequentadores e respeitados historiadores irlandeses</segment>
    <segment id="35">, também acreditam que ele seja o mais antigo do mundo.  'Arqueologia' dos bares</segment>
    <segment id="36">"Imagine quanta história esse lugar já viu"</segment>
    <segment id="37">, diz Donovan</segment>
    <segment id="38">, admirando o bar de teto baixo para além do movimento matinal</segment>
    <segment id="39">, ainda tímido de clientes.</segment>
    <segment id="40">"Eu tenho pesquisado nossa história há 30 e tantos anos e nenhum outro pub chega perto.</segment>
    <segment id="41">"</segment>
    <segment id="42">Outros pubs famosos da Europa —o The Bingley Arms</segment>
    <segment id="43">, de Leeds</segment>
    <segment id="44">, na Inglaterra (fundado em 953)</segment>
    <segment id="45">, o Ye Olde Trip to Jerusalém</segment>
    <segment id="46">, de Nottingham</segment>
    <segment id="47">, também na Inglaterra (de cerca de 1189)</segment>
    <segment id="48">, o The Skirrid Mountain Inn</segment>
    <segment id="49">, de Abergavenny</segment>
    <segment id="50">, no País de Gales (1110)</segment>
    <segment id="51">, e o Brazen Head</segment>
    <segment id="52">, de Dublin</segment>
    <segment id="53">, na Irlanda (1198)— reivindicam o título de pub mais antigo do mundo ainda em funcionamento.</segment>
    <segment id="54">Alguns preservam histórias nebulosas</segment>
    <segment id="55">, ou tão obscuras quanto qualquer copo de Guinness —a cerveja escura mais famosa da Irlanda.</segment>
    <segment id="56">Uma pesquisa arqueológica conduzida e verificada pelo Museu Nacional da Irlanda mostrou</segment>
    <segment id="57">, entretanto</segment>
    <segment id="58">, que o Sean's</segment>
    <segment id="59">Bar existe há mais tempo que todos eles: ele data do ano 900.</segment>
    <segment id="60">Isso quer dizer que surgiu antes da derrota e declínio dos vikings na Irlanda.</segment>
    <segment id="61">E da conquista anglo-normanda da Irlanda.</segment>
    <segment id="62">E da criação do whisky e da cerveja preta</segment>
    <segment id="63">, dos quais os pubs irlandeses viraram sinônimos.</segment>
    <segment id="64">Considerando a idade do material orgânico presente no local —em pedaços de argila</segment>
    <segment id="65">, madeira e taipa— e a presença de "tokens de taverna"</segment>
    <segment id="66">, ou seja</segment>
    <segment id="67">, de "fichas</segment>
    <segment id="68">" encontradas no bar e agora expostas no Museu Nacional da Irlanda</segment>
    <segment id="69">, o sentimento no país é de que o Sean's Bar é muito merecedor da fama.  "</segment>
    <segment id="70">Quando você entra no estabelecimento</segment>
    <segment id="71">, consegue sentir a história e o clima imediatamente"</segment>
    <segment id="72">, diz Declan Delaney</segment>
    <segment id="73">, gerente do bar</segment>
    <segment id="74">, enchendo de cerveja os copos de um grupo de sedentos recém-chegados.</segment>
    <segment id="75">"</segment>
    <segment id="76">Houve muitos donos e inquilinos temporários ao longo dos anos</segment>
    <segment id="77">, masmas o fundamental não mudou: tem música irlandesa</segment>
    <segment id="78">, gente conversando e</segment>
    <segment id="79">sese divertindo com os amigos.</segment>
    <segment id="80">"</segment>
    <segment id="81">O autor irlandês James Joyce ecreveu que seria difícil</segment>
    <segment id="82">&amp;#</segment>
    <segment id="83">039;atravessar Dublin sem passar por um pub&amp;#039</segment>
    <segment id="84">; - Getty Images/BBC News Brasil 'Espécie em extinção'</segment>
    <segment id="85">Em seu clássico romance "Ulysses"</segment>
    <segment id="86">, o autor irlandês James Joyce escreveu que seria difícil</segment>
    <segment id="87">"atravessar Dublin sem passar por um pub"</segment>
    <segment id="88">, e hoje a geografia de sua terra natal é exatamente desse jeito.</segment>
    <segment id="89">A cidade é caracterizada por famosos salões de bebidas</segment>
    <segment id="90">, onde os sons do fogo crepitante</segment>
    <segment id="91">, de violões afinados e do tilintar de copos são panos de fundo para o burburinho das conversas.</segment>
    <segment id="92">O Sean's</segment>
    <segment id="93">Bar não é exceção.</segment>
    <segment id="94">Há o cheiro inconfundível de lúpulo e cevada —ingredientes básicos da cerveja.</segment>
    <segment id="95">A iluminação não é muito forte</segment>
    <segment id="96">, masmas aconchegante o bastante.</segment>
    <segment id="97">Há a luz do fogo.</segment>
    <segment id="98">Os cantos e recantos com assentos confortáveis.</segment>
    <segment id="99">As paredes e vigas de madeira cobertas de recordações</segment>
    <segment id="100">, mapas</segment>
    <segment id="101">, cartas</segment>
    <segment id="102">, poemas e cartas náuticas.</segment>
    <segment id="103">Em um lugar</segment>
    <segment id="104">comocomo esses</segment>
    <segment id="105">, a narrativa da história é inseparável da hospitalidade.</segment>
    <segment id="106">Mas os pubs com histórias nem enraizadas são uma espécie em extinção.</segment>
    <segment id="107">As estatísticas mais recentes do Drinks Industry Group of Ireland</segment>
    <segment id="108">, entidade que representa a indústria nacional de bebidas</segment>
    <segment id="109">, mostram que o número de pubs fechando no país chega a uma média de mais de dois por semana há mais de uma década</segment>
    <segment id="110">, por causa da recessão duradoura</segment>
    <segment id="111">, do aumento do imposto sobre o consumo de álcool e da crescente conscientização envolvendo questões de saúde.</segment>
    <segment id="112">Desde 2005</segment>
    <segment id="113">, aproximadamente 1.500 pubs anotaram seus últimos pedidos.</segment>
    <segment id="114">"</segment>
    <segment id="115">Há muitas imitações por aí</segment>
    <segment id="116">, sem 'a história'</segment>
    <segment id="117">, masmas a Irlanda é cheia de ótimos pubs</segment>
    <segment id="118">, sese você souber onde procurar"</segment>
    <segment id="119">, diz Kevin Martin</segment>
    <segment id="120">, autor do livro "Have Ye</segment>
    <segment id="121">No Homes To Go To?</segment>
    <segment id="122">:</segment>
    <segment id="123">The History of the Irish Pub"</segment>
    <segment id="124">, fruto de sua tese de mestrado sobre a história dos pubs irlandeses.</segment>
    <segment id="125">"</segment>
    <segment id="126">O que é fundamental [nesses lugares] é o convívio —e a garantia de hospitalidade</segment>
    <segment id="127">, uma daquelas combinações simplesmente perfeitas.</segment>
    <segment id="128">Convivência e hospitalidade estão profundamente enraizadas na cultura irlandesa e encontraram sua melhor expressão nesses 'bares'"</segment>
    <segment id="129">, acrescenta ele</segment>
    <segment id="130">, ressaltando que "infelizmente</segment>
    <segment id="131">, pubs irlandeses são só mais uma commodity agora".</segment>
    <segment id="132">"</segment>
    <segment id="133">Mas você pode sentir a história no Sean's Bar.</segment>
    <segment id="134">A cuidadosa manutenção da tradição do lugar tem sido o seu trunfo.</segment>
    <segment id="135">"</segment>
    <segment id="136">O Sean&amp;#039</segment>
    <segment id="137">;s Bar está intrinsecamente associado a lendas sobre o famoso rio Shannon da Irlanda - Mike Maceacheran/BBC News BrasilQuanto ao requerimento do Sean's</segment>
    <segment id="138">Bar para ser reconhecido</segment>
    <segment id="139">comocomo o pub mais antigo do mundo</segment>
    <segment id="140">,</segment>
    <segment id="141">Martin não vê razão para o pedido não ser válido</segment>
    <segment id="142">, tomando por base o que é conhecido.</segment>
    <segment id="143">"Mas como</segment>
    <segment id="144">como você pode imaginar</segment>
    <segment id="145">, esse é um território e uma ciência altamente contestáveis</segment>
    <segment id="146">, e ninguém vai jurar sobre isso"</segment>
    <segment id="147">, diz Martin</segment>
    <segment id="148">, que tem um livro sobre a história e o folclore dos pubs irlandeses pronto para ser publicado.</segment>
    <segment id="149">"</segment>
    <segment id="150">Além disso</segment>
    <segment id="151">, não havia leis de licenciamento na época.</segment>
    <segment id="152">"</segment>
    <segment id="153">Ninguém sabe exatamente quando a primeira pedra foi assentada no Sean's Bar</segment>
    <segment id="154">, masmas sabe-</segment>
    <segment id="155">sese que o histórico salão de Athlone está intrinsecamente ligado à lenda sobre um lugar em especial: o famoso rio Shannon.</segment>
    <segment id="156">Ponto de apoio</segment>
    <segment id="157">O local da Taberna de Luain (</segment>
    <segment id="158">comocomo foi chamado inicialmente) foi escolhido por um ex-dono de estalagem identificado</segment>
    <segment id="159">comocomo Luain Mac Luighdeach</segment>
    <segment id="160">, que usou uma curva do rio para guiar pessoas pela água</segment>
    <segment id="161">, servindo jarras de hidromel.</segment>
    <segment id="162">Um eixo central da vida irlandesa medieval</segment>
    <segment id="163">, o rio era um ponto estratégico não apenas</segment>
    <segment id="164">comocomo importante via de navegação para o comércio monástico</segment>
    <segment id="165">, masmas</segment>
    <segment id="166">porque</segment>
    <segment id="167">porque também ajudou a espalhar a influência viking pelo país e atuou</segment>
    <segment id="168">comocomo um limite geográfico entre o leste e o oeste durante campanhas militares posteriores.</segment>
    <segment id="169">Mesmo quando o Shannon estava cheio e com as águas agitadas</segment>
    <segment id="170">, peregrinos podiam ser vistos na porta dos fundos do Luain</segment>
    <segment id="171">, tentando atravessar a corredeira.</segment>
    <segment id="172">Na verdade</segment>
    <segment id="173">, havia poucas outras alternativas.</segment>
    <segment id="174">Para o norte</segment>
    <segment id="175">, a paisagem</segment>
    <segment id="176">sese torna cada vez mais mais desafiadora</segment>
    <segment id="177">, com as águas do Lough Ree ('o Lago dos Reis') jorrando por uma enorme bacia hidrográfica com 29 km de comprimento e 12 km de largura.</segment>
    <segment id="178">Ao sul</segment>
    <segment id="179">, o Shannon</segment>
    <segment id="180">sese alarga e</segment>
    <segment id="181">sese aprofunda</segment>
    <segment id="182">, criando uma jornada ainda mais traiçoeira.</segment>
    <segment id="183">Em reconhecimento a isso</segment>
    <segment id="184">, o local da pousada ficou conhecido pelo nome do dono do bar —Athlone</segment>
    <segment id="185">, ou 'Ath Luain'</segment>
    <segment id="186">, o Ford de Luain— e hoje o pub é uma das poucas instalações na Irlanda com uma ordem de preservação em vigor tanto para o interior quanto para a área externa.</segment>
    <segment id="187">Kevin Martin: &amp;#039</segment>
    <segment id="188">;Você pode sentir a história no Sean&amp;#039</segment>
    <segment id="189">;s Bar&amp;#039</segment>
    <segment id="190">; - Mike Maceacheran/BBC News BrasilQuando Donovan chegou pela primeira vez ao bar</segment>
    <segment id="191">, ainda um menino com os pais</segment>
    <segment id="192">, há 32 anos</segment>
    <segment id="193">, a primeira coisa que o impressionou foi essa relação do lugar com o rio e o piso xadrez inclinado.</segment>
    <segment id="194">Muito visivelmente</segment>
    <segment id="195">, ele se</segment>
    <segment id="196">se inclina em direção ao rio</segment>
    <segment id="197">, já que a gravidade era o único jeito de escoar a água quando havia inundações nos tempos áureos da estalagem.</segment>
    <segment id="198">Aparas de madeira colocadas no chão</segment>
    <segment id="199">, que já foram usadas para absorver o excesso d'água</segment>
    <segment id="200">, hoje absorvem cerveja derramada.</segment>
    <segment id="201">Pouca coisa mudou no bar nas últimas três décadas.</segment>
    <segment id="202">Para Donavan</segment>
    <segment id="203">, entretanto</segment>
    <segment id="204">, a diferença é grande.</segment>
    <segment id="205">Ele passou de barman a dono do estabelecimento</segment>
    <segment id="206">, junto com um parceiro</segment>
    <segment id="207">, e ainda</segment>
    <segment id="208">sese sente atraído pela história do pub.</segment>
    <segment id="209">Ele diz que quando</segment>
    <segment id="210">sese aposentar vai pegar um banco e passar o tempo no bar com Delaney.</segment>
    <segment id="211">"</segment>
    <segment id="212">Todo mundo traz um pouco de felicidade a esse lugar"</segment>
    <segment id="213">, brinca ele</segment>
    <segment id="214">, um pouco emocionado.</segment>
    <segment id="215">"</segment>
    <segment id="216">Alguns quando entram</segment>
    <segment id="217">, outros quando saem.</segment>
    <segment id="218">"</segment>
    <segment id="219">A pesquisa está em andamento no Sean's</segment>
    <segment id="220">Bar para reivindicar o título oficial de pub mais antigo do mundo</segment>
    <segment id="221">, masmas</segment>
    <segment id="222">, enquanto isso</segment>
    <segment id="223">, há várias outras discussões por vir.</segment>
    <segment id="224">Estações e gostos mudam</segment>
    <segment id="225">, masmas para a população que vive às margens do Shannon</segment>
    <segment id="226">, no local onde Luain fez um dia sua grande passagem para travessia do rio</segment>
    <segment id="227">, a bebida vai continuar rodando</segment>
    <segment id="228">, e sempre haverá uma recepção calorosa.</segment>
  </rst>
</analysis>