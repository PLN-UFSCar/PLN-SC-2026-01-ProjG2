  <rst>
    <segment id="1">O clima tenso entre os Poderes depois da rea&amp;ccedil</segment>
    <segment id="2">;&amp;atilde</segment>
    <segment id="3">;o do Legislativo e do Judici&amp;aacute</segment>
    <segment id="4">;rio &amp;agrave</segment>
    <segment id="5">;s declara&amp;ccedil</segment>
    <segment id="6">;&amp;otilde</segment>
    <segment id="7">;es golpistas do presidente Jair Bolsonaro (sem partido) na semana passada n&amp;atilde</segment>
    <segment id="8">;o arrefeceu durante o fim de semana e tende a permanecer pelos pr&amp;oacute</segment>
    <segment id="9">;ximos dias j&amp;aacute</segment>
    <segment id="10">; que, ao menos at&amp;eacute</segment>
    <segment id="11">;</segment>
    <segment id="12">o in&amp;iacute</segment>
    <segment id="13">;cio da noite deste domingo (11)</segment>
    <segment id="14">, n&amp;atilde</segment>
    <segment id="15">;o havia inten&amp;ccedil</segment>
    <segment id="16">;&amp;atilde</segment>
    <segment id="17">;o dos envolvidos em baixar o tom.</segment>
    <segment id="18">No fim de semana</segment>
    <segment id="19">, emiss&amp;aacute</segment>
    <segment id="20">;rios do Pal&amp;aacute</segment>
    <segment id="21">;cio do Planalto fizeram chegar ao presidente do Senado</segment>
    <segment id="22">, Rodrigo Pacheco (DEM-MG)</segment>
    <segment id="23">, a irrita&amp;ccedil</segment>
    <segment id="24">;&amp;atilde</segment>
    <segment id="25">;o de Bolsonaro com as declara&amp;ccedil</segment>
    <segment id="26">;&amp;otilde</segment>
    <segment id="27">;es do senador.</segment>
    <segment id="28">Pacheco disse na sexta-feira (9) que n&amp;atilde</segment>
    <segment id="29">;o aceitar&amp;aacute</segment>
    <segment id="30">; retrocessos &amp;agrave</segment>
    <segment id="31">; democracia do pa&amp;iacute</segment>
    <segment id="32">;s e que quem agir nessa dire&amp;ccedil</segment>
    <segment id="33">;&amp;atilde</segment>
    <segment id="34">;o ser&amp;aacute</segment>
    <segment id="35">; considerado inimigo da na&amp;ccedil</segment>
    <segment id="36">;&amp;atilde</segment>
    <segment id="37">;o.</segment>
    <segment id="38">Ele sinalizou a interlocutores que n&amp;atilde</segment>
    <segment id="39">;o pretende recuar da posi&amp;ccedil</segment>
    <segment id="40">;&amp;atilde</segment>
    <segment id="41">;o que tomou.</segment>
    <segment id="42">Relembre dias de fúria de BolsonaroMais    novamente         de   de  de  representando</segment>
    <segment id="43">um  Tamb&amp;eacute</segment>
    <segment id="44">;m na sexta</segment>
    <segment id="45">, o ministro do STF (Supremo Tribunal Federal) e presidente do TSE (Tribunal Superior Eleitoral)</segment>
    <segment id="46">, Lu&amp;iacute</segment>
    <segment id="47">;s Roberto Barroso</segment>
    <segment id="48">, disse que qualquer tentativa de impedir a realiza&amp;ccedil</segment>
    <segment id="49">;&amp;atilde</segment>
    <segment id="50">;o de elei&amp;ccedil</segment>
    <segment id="51">;&amp;otilde</segment>
    <segment id="52">;es em 2022 &amp;ldquo</segment>
    <segment id="53">;configura crime de responsabilidade&amp;rdquo</segment>
    <segment id="54">;.</segment>
    <segment id="55">Somente no s&amp;aacute</segment>
    <segment id="56">;bado (10)</segment>
    <segment id="57">, o presidente da C&amp;acirc</segment>
    <segment id="58">;mara, Arthur Lira (PP-AL)</segment>
    <segment id="59">, rompeu o sil&amp;ecirc</segment>
    <segment id="60">;ncio sobre as declara&amp;ccedil</segment>
    <segment id="61">;&amp;otilde</segment>
    <segment id="62">;es de Bolsonaro.</segment>
    <segment id="63">Em um primeiro momento</segment>
    <segment id="64">, divulgou nota nas redes sociais em que evitou criticar o aliado e afirmou que &amp;quot</segment>
    <segment id="65">;nossas institui&amp;ccedil</segment>
    <segment id="66">;&amp;otilde</segment>
    <segment id="67">;es s&amp;atilde</segment>
    <segment id="68">;o fortalezas que n&amp;atilde</segment>
    <segment id="69">;o sese abalar&amp;atilde</segment>
    <segment id="70">;o com declara&amp;ccedil</segment>
    <segment id="71">;&amp;otilde</segment>
    <segment id="72">;es p&amp;uacute</segment>
    <segment id="73">;blicas e oportunismo&amp;quot</segment>
    <segment id="74">;.</segment>
    <segment id="75">Em seguida</segment>
    <segment id="76">, em entrevista &amp;agrave</segment>
    <segment id="77">; CNN Brasil</segment>
    <segment id="78">, afirmou n&amp;atilde</segment>
    <segment id="79">;o ter compromisso com intentos antidemocr&amp;aacute</segment>
    <segment id="80">;ticos e criticou manifesta&amp;ccedil</segment>
    <segment id="81">;&amp;otilde</segment>
    <segment id="82">;es pol&amp;iacute</segment>
    <segment id="83">;ticas de comandantes militares.</segment>
    <segment id="84">A sequ&amp;ecirc</segment>
    <segment id="85">;ncia de posicionamentos de autoridades veio na esteira de declara&amp;ccedil</segment>
    <segment id="86">;&amp;otilde</segment>
    <segment id="87">;es de Bolsonaro</segment>
    <segment id="88">, que afirma que as elei&amp;ccedil</segment>
    <segment id="89">;&amp;otilde</segment>
    <segment id="90">;es podem simplesmente n&amp;atilde</segment>
    <segment id="91">;o ocorrer</segment>
    <segment id="92">casocaso n&amp;atilde</segment>
    <segment id="93">;o exista um sistema confi&amp;aacute</segment>
    <segment id="94">;vel &amp;mdash</segment>
    <segment id="95">;segundo ele</segment>
    <segment id="96">, o voto impresso.​</segment>
    <segment id="97">A escalada golpista acontece em um contexto de pesquisas de opini&amp;atilde</segment>
    <segment id="98">;o que apontam picos de rejei&amp;ccedil</segment>
    <segment id="99">;&amp;atilde</segment>
    <segment id="100">;o e amplo favoritismo do ex-presidente Luiz In&amp;aacute</segment>
    <segment id="101">;cio Lula da Silva (PT) em 2022.</segment>
    <segment id="102">Bolsonaro subiu o tom de suas amea&amp;ccedil</segment>
    <segment id="103">;as golpistas e</segment>
    <segment id="104">, sem apresentar provas</segment>
    <segment id="105">, insiste que haver&amp;aacute</segment>
    <segment id="106">; fraude no ano que vem e que o resultado j&amp;aacute</segment>
    <segment id="107">;</segment>
    <segment id="108">estaria definido.</segment>
    <segment id="109">Ele tamb&amp;eacute</segment>
    <segment id="110">;m afirmou que h&amp;aacute</segment>
    <segment id="111">; risco de n&amp;atilde</segment>
    <segment id="112">;o haver elei&amp;ccedil</segment>
    <segment id="113">;&amp;otilde</segment>
    <segment id="114">;es no ano que vem no pa&amp;iacute</segment>
    <segment id="115">;s.</segment>
    <segment id="116">Al&amp;eacute</segment>
    <segment id="117">;m de Bolsonaro</segment>
    <segment id="118">, o ministro da Defesa</segment>
    <segment id="119">, Braga Netto</segment>
    <segment id="120">, e os comandantes das For&amp;ccedil</segment>
    <segment id="121">;as Armadas ajudaram a elevar a temperatura ao divulgarem uma nota na qual repudiavam declara&amp;ccedil</segment>
    <segment id="122">;&amp;otilde</segment>
    <segment id="123">;es feitas pelo presidente da CPI da Covid</segment>
    <segment id="124">, senador Omar Aziz (PSD-AM)</segment>
    <segment id="125">, sobre os militares sob investiga&amp;ccedil</segment>
    <segment id="126">;&amp;atilde</segment>
    <segment id="127">;o e na mira da comiss&amp;atilde</segment>
    <segment id="128">;o.</segment>
    <segment id="129">Para completar o cen&amp;aacute</segment>
    <segment id="130">;rio de escalada de tens&amp;atilde</segment>
    <segment id="131">;o, na sexta</segment>
    <segment id="132">, o comandante da Aeron&amp;aacute</segment>
    <segment id="133">;utica</segment>
    <segment id="134">, tenente-brigadeiro do ar Carlos de Almeida Baptista Junior</segment>
    <segment id="135">, reafirmou os termos da nota em entrevista ao jornal</segment>
    <segment id="136">O Globo e disse que as For&amp;ccedil</segment>
    <segment id="137">;as Armadas t&amp;ecirc</segment>
    <segment id="138">;m &amp;quot</segment>
    <segment id="139">;base legal&amp;quot</segment>
    <segment id="140">; para agir</segment>
    <segment id="141">, sem deixar claro qual seria a a&amp;ccedil</segment>
    <segment id="142">;&amp;atilde</segment>
    <segment id="143">;o e contra quem.</segment>
    <segment id="144">Como mostrou a coluna</segment>
    <segment id="145">Painel</segment>
    <segment id="146">, da Folha</segment>
    <segment id="147">, neste domingo</segment>
    <segment id="148">, a fala de Baptista Junior provocou rea&amp;ccedil</segment>
    <segment id="149">;&amp;atilde</segment>
    <segment id="150">;o un&amp;acirc</segment>
    <segment id="151">;nime de reprova&amp;ccedil</segment>
    <segment id="152">;&amp;atilde</segment>
    <segment id="153">;o absoluta entre os grupos pol&amp;iacute</segment>
    <segment id="154">;ticos.</segment>
    <segment id="155">Integrantes da CPI</segment>
    <segment id="156">, tanto os de oposi&amp;ccedil</segment>
    <segment id="157">;&amp;atilde</segment>
    <segment id="158">;o como</segment>
    <segment id="159">como os bolsonaristas</segment>
    <segment id="160">, viram</segment>
    <segment id="161">comocomo inoportunas e desnecess&amp;aacute</segment>
    <segment id="162">;rias as falas do tenente-brigadeiro do ar.</segment>
    <segment id="163">J&amp;aacute</segment>
    <segment id="164">; o procurador-geral da Rep&amp;uacute</segment>
    <segment id="165">;blica</segment>
    <segment id="166">, Augusto Aras</segment>
    <segment id="167">, n&amp;atilde</segment>
    <segment id="168">;o quis</segment>
    <segment id="169">sese manifestar sobre as declara&amp;ccedil</segment>
    <segment id="170">;&amp;otilde</segment>
    <segment id="171">;es golpistas de Bolsonaro sobre as elei&amp;ccedil</segment>
    <segment id="172">;&amp;otilde</segment>
    <segment id="173">;es.</segment>
    <segment id="174">Questionado pela Folha</segment>
    <segment id="175">, Aras tamb&amp;eacute</segment>
    <segment id="176">;m n&amp;atilde</segment>
    <segment id="177">;o quis</segment>
    <segment id="178">sese pronunciar sobre as afirma&amp;ccedil</segment>
    <segment id="179">;&amp;otilde</segment>
    <segment id="180">;es do chefe do Executivo de que o TSE fraudou as duas &amp;</segment>
    <segment id="181">uacute</segment>
    <segment id="182">;ltimas disputas presidenciais.</segment>
    <segment id="183">No s&amp;aacute</segment>
    <segment id="184">;bado, Bolsonaro participou de um passeio de moto com apoiadores em Porto Alegre.</segment>
    <segment id="185">J&amp;aacute</segment>
    <segment id="186">; no domingo</segment>
    <segment id="187">, reuniu alguns de seus ministros e secret&amp;aacute</segment>
    <segment id="188">;rios para um churrasco no Pal&amp;aacute</segment>
    <segment id="189">;cio da Alvorada.</segment>
    <segment id="190">Este é Rodrigo PachecoMais    novamente         de   de  de  representando um</segment>
    <segment id="191">A auxiliares o presidente admitiu sua irrita&amp;ccedil</segment>
    <segment id="192">;&amp;atilde</segment>
    <segment id="193">;o com as manifesta&amp;ccedil</segment>
    <segment id="194">;&amp;otilde</segment>
    <segment id="195">;es dos demais Poderes e</segment>
    <segment id="196">, assim</segment>
    <segment id="197">comocomo Pacheco</segment>
    <segment id="198">, tamb&amp;eacute</segment>
    <segment id="199">;m afirmou que n&amp;atilde</segment>
    <segment id="200">;o pretende baixar o tom</segment>
    <segment id="201">, masmas pontuou que vai</segment>
    <segment id="202">sese esfor&amp;ccedil</segment>
    <segment id="203">;ar para n&amp;atilde</segment>
    <segment id="204">;o atacar institui&amp;ccedil</segment>
    <segment id="205">;&amp;otilde</segment>
    <segment id="206">;es, direcionando seus rompantes a pessoas espec&amp;iacute</segment>
    <segment id="207">;ficas.</segment>
    <segment id="208">No fim da tarde de domingo</segment>
    <segment id="209">, o mandat&amp;aacute</segment>
    <segment id="210">;rio foi a uma rede social e mencionou &amp;quot</segment>
    <segment id="211">;tr&amp;ecirc</segment>
    <segment id="212">;s ministros do Supremo&amp;quot</segment>
    <segment id="213">;, sem mencionar nomes.     &amp;quot</segment>
    <segment id="214">;A pergunta que fica:</segment>
    <segment id="215">por que tr&amp;ecirc</segment>
    <segment id="216">;s ministros do Supremo rejeitam</segment>
    <segment id="217">, com veem&amp;ecirc</segment>
    <segment id="218">;ncia, a possibilidade de termos elei&amp;ccedil</segment>
    <segment id="219">;&amp;otilde</segment>
    <segment id="220">;es com auditoria nos votos?&amp;quot</segment>
    <segment id="221">;, escreveu o presidente.</segment>
    <segment id="222">Pelo lado do Judici&amp;aacute</segment>
    <segment id="223">;rio, Barroso relatou a pessoas pr&amp;oacute</segment>
    <segment id="224">;ximas sua indigna&amp;ccedil</segment>
    <segment id="225">;&amp;atilde</segment>
    <segment id="226">;o com o que tem acontecido.</segment>
    <segment id="227">Para o ministro</segment>
    <segment id="228">, como</segment>
    <segment id="229">como ele tem sido atacado</segment>
    <segment id="230">, n&amp;atilde</segment>
    <segment id="231">;o &amp;eacute</segment>
    <segment id="232">; dele que deve partir a bandeira branca.  J&amp;aacute</segment>
    <segment id="233">;</segment>
    <segment id="234">o presidente do Supremo</segment>
    <segment id="235">, ministro Luiz Fux</segment>
    <segment id="236">, indicou que pretende buscar di&amp;aacute</segment>
    <segment id="237">;logo institucional com os demais Poderes.</segment>
    <segment id="238">​</segment>
    <segment id="239">A tens&amp;atilde</segment>
    <segment id="240">;o pol&amp;iacute</segment>
    <segment id="241">;tica entre os Poderes vai dividir as aten&amp;ccedil</segment>
    <segment id="242">;&amp;otilde</segment>
    <segment id="243">;es com a expectativa de indica&amp;ccedil</segment>
    <segment id="244">;&amp;atilde</segment>
    <segment id="245">;o do ministro da AGU (Advocacia-Geral da Uni&amp;atilde</segment>
    <segment id="246">;o), Andr&amp;eacute</segment>
    <segment id="247">; Mendon&amp;ccedil</segment>
    <segment id="248">;a, para a vaga de ministro do STF que surge nesta segunda-feira (12) com a aposentadoria do ministro Marco Aur&amp;eacute</segment>
    <segment id="249">;lio Mello e com o avan&amp;ccedil</segment>
    <segment id="250">;o da CPI da Covid.</segment>
    <segment id="251">Apesar das manobras para estancar o desgaste e depor o quanto antes na comiss&amp;atilde</segment>
    <segment id="252">;o, o l&amp;iacute</segment>
    <segment id="253">;der do governo na C&amp;acirc</segment>
    <segment id="254">;mara, Ricardo Barros (PP-PR)</segment>
    <segment id="255">, deve ser ouvido apenas em 20 de julho.</segment>
    <segment id="256">Senadores independentes e da oposi&amp;ccedil</segment>
    <segment id="257">;&amp;atilde</segment>
    <segment id="258">;o querem aprofundar as investiga&amp;ccedil</segment>
    <segment id="259">;&amp;otilde</segment>
    <segment id="260">;es sobre as negocia&amp;ccedil</segment>
    <segment id="261">;&amp;otilde</segment>
    <segment id="262">;es para a compra da vacina Covaxin e reunir dados suficientes antes de interrogar o deputado.</segment>
    <segment id="263">Neste domingo</segment>
    <segment id="264">, Barros chamou de covardia o fato de n&amp;atilde</segment>
    <segment id="265">;o marcarem o depoimento dele para esta semana.</segment>
    <segment id="266">&amp;ldquo</segment>
    <segment id="267">;Reafirmo que n&amp;atilde</segment>
    <segment id="268">;o participei das negocia&amp;ccedil</segment>
    <segment id="269">;&amp;otilde</segment>
    <segment id="270">;es da Covaxin.</segment>
    <segment id="271">Por que a CPI s&amp;oacute</segment>
    <segment id="272">; me ataca e n&amp;atilde</segment>
    <segment id="273">;o me d&amp;aacute</segment>
    <segment id="274">; direito &amp;agrave</segment>
    <segment id="275">; defesa?!</segment>
    <segment id="276">Isso tem nome:</segment>
    <segment id="277">covardia&amp;rdquo</segment>
    <segment id="278">;, escreveu em uma rede social.</segment>
    <segment id="279">Inicialmente</segment>
    <segment id="280">, ele seria ouvido na &amp;uacute</segment>
    <segment id="281">;ltima quinta-feira (8)</segment>
    <segment id="282">, masmas a data foi alterada</segment>
    <segment id="283">, o que levou o deputado a ingressar com um mandado de seguran&amp;ccedil</segment>
    <segment id="284">;a no STF</segment>
    <segment id="285">para que</segment>
    <segment id="286">para que o depoimento fosse mantido.</segment>
    <segment id="287">O depoimento do l&amp;iacute</segment>
    <segment id="288">;der do governo pode ficar para agosto</segment>
    <segment id="289">, caso</segment>
    <segment id="290">caso o Congresso vote a LDO (Lei de Diretrizes Or&amp;ccedil</segment>
    <segment id="291">;ament&amp;aacute</segment>
    <segment id="292">;rias) e entre em recesso.</segment>
    <segment id="293">Pacheco j&amp;aacute</segment>
    <segment id="294">; afirmou que as oitivas na comiss&amp;atilde</segment>
    <segment id="295">;o n&amp;atilde</segment>
    <segment id="296">;o poder&amp;atilde</segment>
    <segment id="297">;o ocorrer</segment>
    <segment id="298">sese os trabalhos no Senado estiverem suspensos.</segment>
    <segment id="299">Outro rev&amp;eacute</segment>
    <segment id="300">;s para o governo nesta semana pode ser a aprova&amp;ccedil</segment>
    <segment id="301">;&amp;atilde</segment>
    <segment id="302">;o de um requerimento de convoca&amp;ccedil</segment>
    <segment id="303">;&amp;atilde</segment>
    <segment id="304">;o para ouvir o ministro da Secretaria-Geral da Presid&amp;ecirc</segment>
    <segment id="305">;ncia, Onyx Lorenzoni.</segment>
    <segment id="306">Na semana passada</segment>
    <segment id="307">, o relator da CPI</segment>
    <segment id="308">, Renan Calheiros (MDB-AL)</segment>
    <segment id="309">, disse que iria apresentar o pedido</segment>
    <segment id="310">para que</segment>
    <segment id="311">para que Onyx comparecesse &amp;agrave</segment>
    <segment id="312">; comiss&amp;atilde</segment>
    <segment id="313">;o.</segment>
    <segment id="314">Para Calheiros</segment>
    <segment id="315">, Onyx mentiu em uma coletiva de imprensa ao dizer que as invoices (nota fiscal internacional) da Covaxin apresentadas nas acusa&amp;ccedil</segment>
    <segment id="316">;&amp;otilde</segment>
    <segment id="317">;es feitas pelo deputado Luis Miranda (DEM-DF) seriam falsas.</segment>
    <segment id="318">Em depoimento na sexta-feira (9)</segment>
    <segment id="319">, o consultor do Minist&amp;eacute</segment>
    <segment id="320">;rio da Sa&amp;uacute</segment>
    <segment id="321">;de William Amorim Santana afirmou que os documentos s&amp;atilde</segment>
    <segment id="322">;o verdadeiros.  CPI ouve envolvidos em suspeitas de irregularidades   Ter&amp;ccedil</segment>
    <segment id="323">;a (13):</segment>
    <segment id="324">Emanuela Medrades</segment>
    <segment id="325">, representante da Precisa Medicamentos</segment>
    <segment id="326">, envolvida na negocia&amp;ccedil</segment>
    <segment id="327">;&amp;atilde</segment>
    <segment id="328">;o da Covaxin</segment>
    <segment id="329">; Quarta (14):</segment>
    <segment id="330">Amilton Gomes</segment>
    <segment id="331">, reverendo e presidente da Senah</segment>
    <segment id="332">, supostamente</segment>
    <segment id="333">, envolvido no</segment>
    <segment id="334">casocaso Davati</segment>
    <segment id="335">; Quinta (15):</segment>
    <segment id="336">Coronel Marcelo Blanco</segment>
    <segment id="337">, ex-assessor do Minist&amp;eacute</segment>
    <segment id="338">;rio da Sa&amp;uacute</segment>
    <segment id="339">;de, que participou de jantar onde teria ocorrido o pedido de propina</segment>
    <segment id="340">;</segment>
    <segment id="341">Sexta (16):</segment>
    <segment id="342">Cristiano Carvalho</segment>
    <segment id="343">, representante da Davati Medical Supply</segment>
    <segment id="344">Quem é quem nas suspeitas de compra de vacinasMais    novamente         de   de  de  representando</segment>
    <segment id="345">um</segment>
  </rst>
</analysis>