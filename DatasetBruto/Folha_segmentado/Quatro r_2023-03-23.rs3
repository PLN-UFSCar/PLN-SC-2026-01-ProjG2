  <rst>
    <segment id="1">Até mesmo para quem segue aproveitando o home office</segment>
    <segment id="2">, o jantar pode ser uma refeição complicada.</segment>
    <segment id="3">Dificilmente</segment>
    <segment id="4">sese quer comer a mesma coisa do almoço</segment>
    <segment id="5">, masmas também são poucas as forças para ir à cozinha e preparar algo novo.</segment>
    <segment id="6">Nessa, o delivery</segment>
    <segment id="7">, geralmente caro e gorduroso</segment>
    <segment id="8">, acaba sempre sendo a solução.</segment>
    <segment id="9">Para te ajudar a romper com esse padrão</segment>
    <segment id="10">, selecionamos quatro receitas que ficam prontas em menos de uma hora e que vão salvar o seu jantar a semana toda</segment>
    <segment id="11">, provando que a última refeição do dia pode ser</segment>
    <segment id="12">, ao mesmo tempo</segment>
    <segment id="13">, saudável</segment>
    <segment id="14">, gostosa e rápida de preparar.</segment>
    <segment id="15">Macarrão à carbonara - Adobe StockPara tudo ficar ainda mais fácil</segment>
    <segment id="16">, uma pequena dose de planejamento é sempre bem-vinda para otimizar o tempo na cozinha.</segment>
    <segment id="17">Se você tem poucos ingredientes na despensa</segment>
    <segment id="18">, planeje uma passadinha no supermercado</segment>
    <segment id="19">, compre o que precisa e deixe tudo no jeito —os feijões sempre precisam ficar de molho</segment>
    <segment id="20">, por exemplo.  Se não tiver ou esquecer de algum ingrediente</segment>
    <segment id="21">, como</segment>
    <segment id="22">como a carne seca ou o atum fresco</segment>
    <segment id="23">, por exemplo</segment>
    <segment id="24">, basta substituí-los por equivalentes</segment>
    <segment id="25">, como</segment>
    <segment id="26">como a carne moída comum e o atum em lata.</segment>
    <segment id="27">O importante é construir os próprios sabores e comer bem!</segment>
    <segment id="28">Confira abaixo quatro receitas para cozinhar quando</segment>
    <segment id="29">sese está cansado:    ALMÔNDEGAS NORDESTINAS</segment>
    <segment id="30">Jurados avaliam almôndegas congeladasMais    novamente         de   de  de  representando um  Estas almôndegas vão bem com molho</segment>
    <segment id="31">, acompanhando arroz</segment>
    <segment id="32">, no macarrão ou consumidos</segment>
    <segment id="33">comocomo aperitivo</segment>
    <segment id="34">, sem o molho.</segment>
    <segment id="35">Para deixar mais leve</segment>
    <segment id="36">, em vez de usar bacon</segment>
    <segment id="37">, faça o refogadinho em uma colher de sopa de azeite e</segment>
    <segment id="38">, no lugar de fritar</segment>
    <segment id="39">, asse as almôndegas em uma assadeira antiaderente.</segment>
    <segment id="40">Tempo: até 1 hora</segment>
    <segment id="41">Rendimento: 16 unidades  Ingredientes:   1kg de carne seca 100g de bacon moído 2 cebolas grandes 2 tomates (sem pele) picados 1 pimentão vermelho (sem pele) picado 1 maço de salsa 1 xícara (chá) de miolo de pão 4 colheres (sopa) de farinha de trigo 1 ovo 1 lata de molho de tomate   Preparo:   Coloque de molho na água</segment>
    <segment id="42">, de véspera</segment>
    <segment id="43">, a carne seca.</segment>
    <segment id="44">Cozinhe por uma hora ou até que amacie e pique bem miudinho.</segment>
    <segment id="45">Faça um refogado com o bacon</segment>
    <segment id="46">, a cebola</segment>
    <segment id="47">, o tomate</segment>
    <segment id="48">, o pimentão e a salsa.</segment>
    <segment id="49">Junte a carne seca a esse refogado e deixe cozinhar até que fique bem macia.</segment>
    <segment id="50">Retire do fogo</segment>
    <segment id="51">, deixe esfriar um pouco e incorpore o miolo de pão molhado no leite e o ovo.</segment>
    <segment id="52">Faça as almôndegas</segment>
    <segment id="53">, passe-as na farinha de trigo e frite-as em bastante óleo.</segment>
    <segment id="54">Depois de prontas</segment>
    <segment id="55">, regue-as com molho de tomate já aquecido.     CALDINHO DE FEIJÃO  Caldinho de feijão: tão nutritivo quanto rápido de preparar - Patricia Stavis/FolhapressTempo: até 1 hora</segment>
    <segment id="56">Rendimento: 8 porções  Ingredientes:   1/2kg de feijão preto 150g de linguiça paio cortada em rodelas 2 dentes de alho picados 2 colheres (sopa) de azeite</segment>
    <segment id="57">1/2kg de costelinhas de porco 2 colheres (sopa) de cebola picadinha 1/2 xícara de óleo sal e pimenta a gosto 4 xícaras de torresmos 4 unidades pãezinhos cortados em fatias</segment>
    <segment id="58">Preparo:   Cozinhe o feijão com o paio e o alho já dourado no azeite.</segment>
    <segment id="59">Depois de cozido</segment>
    <segment id="60">, bata no liquidificador o feijão com o paio e a água do cozimento</segment>
    <segment id="61">, verifique o sal e reserve.</segment>
    <segment id="62">Tempere as costelinhas de porco com a cebola</segment>
    <segment id="63">, pimenta e sal a gosto.</segment>
    <segment id="64">Frite no óleo bem quente até ficarem tostadas.</segment>
    <segment id="65">Sirva o caldinho bem quente em canecas</segment>
    <segment id="66">, acrescentando para cada porção uma costelinha.</segment>
    <segment id="67">Acompanhe com torresmos e fatias de pão francês.     ENSALATA DE ATUM</segment>
    <segment id="68">Receita do restaurante espanhol Don Curro</segment>
    <segment id="69">, publicada na seção "Avental" da coluna que Joyce Pascowitch manteve na Folha de S. Paulo por mais de uma década.</segment>
    <segment id="70">Uma taça de vinho branco Marquês de Riscal e uma dose extra de azeite de oliva</segment>
    <segment id="71">, ambos espanhóis</segment>
    <segment id="72">, são os acompanhamentos perfeitos para essa salada.  Tempo: 20 minutos</segment>
    <segment id="73">Rendimento: 1 porção  Ingredientes:    150g de atum fresco</segment>
    <segment id="74">, cozido em cubos um tomate partido em quatro três folhas de alface lisa três folhas de alface frisée três de endívias quatro rodelas de cebola três tiras de pimentão verde três de amarelo quatro azeitonas pretas ervilhas frescas a gosto   Preparo:</segment>
    <segment id="75">Em uma tigela média</segment>
    <segment id="76">, colocar as folhas inteiras</segment>
    <segment id="77">, antes dos outros ingredientes</segment>
    <segment id="78">, que vêm em seguida Temperar com sal</segment>
    <segment id="79">, pimenta</segment>
    <segment id="80">, limão</segment>
    <segment id="81">, vinagre e azeite</segment>
    <segment id="82">, tudo a gosto do freguês.     MACARRÃO À CARBONARA</segment>
    <segment id="83">Aprenda a preparar espaguete à carbonaraMais    novamente         de   de  de  representando um  Receita do chef e apresentador Carlos Bertolazzi  Tempo: até meia hora</segment>
    <segment id="84">Rendimento: 4 porções  Ingredientes:   3 unidades gemas 1 unidade ovo inteiro 3 colheres (de sobremesa) pecorino pimenta preta a gosto 320g espaguete 1 xícara (chá) bacon cortado em cubos   Preparo:</segment>
    <segment id="85">Misture o ovo</segment>
    <segment id="86">, o queijo e a pimenta.</segment>
    <segment id="87">Toste os cubos de bacon.</segment>
    <segment id="88">Misture o espaguete cozido à mistura de ovos e ao bacon tostado.</segment>
  </rst>
</analysis>