  <rst>
    <segment id="1">Seja nas lentes do americano Robert Mapplethorpe ou nas tintas de Portinari</segment>
    <segment id="2">, pessoas negras quase sempre foram retratadas pela perspectiva de pessoas brancas</segment>
    <segment id="3">, bem ou mal intencionadas</segment>
    <segment id="4">, com resultados diversos.</segment>
    <segment id="5">Qualquer coisa diferente disso costumava ser exceção.</segment>
    <segment id="6">Hoje, no entanto</segment>
    <segment id="7">, especialmente desde a chegada das redes sociais</segment>
    <segment id="8">, a situação é diferente.</segment>
    <segment id="9">Artistas de todas as áreas olham para a própria negritude através de suas obras e têm mais autonomia para compartilhar os resultados.</segment>
    <segment id="10">Catarina Silva Ferreira</segment>
    <segment id="11">, jornalista da Folha de S.Paulo - Gabriel Cabral/FolhapressO novo blog Pretos Olhares surge para mostrar ao leitor o trabalho de pessoas negras que retratam a negritude e a diversidade através da fotografia e de outras manifestações visuais.</segment>
    <segment id="12">"</segment>
    <segment id="13">A ideia é falar sobre</segment>
    <segment id="14">comocomo as pessoas pretas hoje estão olhando para si</segment>
    <segment id="15">, suas comunidades</segment>
    <segment id="16">, suas manifestações culturais agora que elas também estão por trás das câmeras"</segment>
    <segment id="17">, afirma Catarina Ferreira</segment>
    <segment id="18">, que cuidará do espaço.</segment>
    <segment id="19">O texto de estreia vai apresentar o trabalho de Helen Salomão</segment>
    <segment id="20">, fotógrafa baiana que decidiu clicar cenas do cotidiano ao sentir falta de registros mais antigos da sua família —sua avó</segment>
    <segment id="21">, por exemplo</segment>
    <segment id="22">, não tem nenhum registro de</segment>
    <segment id="23">comocomo era quando jovem.  "</segment>
    <segment id="24">Na faculdade</segment>
    <segment id="25">, as referências que vi</segment>
    <segment id="26">, de fotógrafos mais antigos</segment>
    <segment id="27">, tinham a perspectiva das pessoas negras</segment>
    <segment id="28">comocomo exóticas e da religião de matriz africana</segment>
    <segment id="29">comocomo algo diferente</segment>
    <segment id="30">, místico"</segment>
    <segment id="31">, diz Ferreira.</segment>
    <segment id="32">"Era sempre uma pessoa branca que olhava para as comunidades negras e suas manifestações culturais.</segment>
    <segment id="33">"</segment>
    <segment id="34">Ferreira é formada em jornalismo na Universidade de São Paulo</segment>
    <segment id="35">, a USP</segment>
    <segment id="36">, e desde lá demonstrava interesse pela fotografia.</segment>
    <segment id="37">Participou do primeiro treinamento voltado para profissionais negros da Folha.</segment>
    <segment id="38">A jornalista foi repórter na editoria de Especiais</segment>
    <segment id="39">, Seminários e Treinamento</segment>
    <segment id="40">, onde participou do especial "</segment>
    <segment id="41">Afrofuturismo".</segment>
    <segment id="42">Já, desde 2021</segment>
    <segment id="43">, participou de reportagens sobre temáticas sensíveis à população negra</segment>
    <segment id="44">, como</segment>
    <segment id="45">como política de cotas</segment>
    <segment id="46">, violência policial</segment>
    <segment id="47">, autoestima</segment>
    <segment id="48">, representatividade</segment>
    <segment id="49">, luta e ancestralidade.</segment>
    <segment id="50">No novo espaço</segment>
    <segment id="51">, une seu interesse pela pauta racial ao gosto pelas artes visuais</segment>
    <segment id="52">, especialmente pela fotografia</segment>
    <segment id="53">, para apresentar artistas e eventos ao público.</segment>
    <segment id="54">Para enriquecer o blog</segment>
    <segment id="55">, deve juntar seus próprios registros às obras dos artistas.</segment>
  </rst>
</analysis>