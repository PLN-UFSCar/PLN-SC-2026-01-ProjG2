  <rst>
    <segment id="1">O Brasil desconhece sua própria história.</segment>
    <segment id="2">Não sabe nada sobre os diferentes 305 povos originários do país.</segment>
    <segment id="3">Escolhi utilizar a palavra "originários</segment>
    <segment id="4">" para lembrá-los que esse país já era habitado quando os colonizadores chegaram nesse território.</segment>
    <segment id="5">Hoje continuam tentando apagar nossa identidade dizendo que muitos dos que vivem na cidade são menos indígenas por isso</segment>
    <segment id="6">, masmas esquecem que não são os povos indígenas que estão na cidade</segment>
    <segment id="7">, é a cidade que está na aldeia.</segment>
    <segment id="8">Inúmeros municípios foram construídos em cima de aldeias indígenas</segment>
    <segment id="9">, massacrando</segment>
    <segment id="10">, violentando e expulsando comunidades inteiras.</segment>
    <segment id="11">Muitos deles</segment>
    <segment id="12">, inclusive</segment>
    <segment id="13">, têm seus nomes inspirados nos povos que viviam ali.</segment>
    <segment id="14">As indígenas Célia Xakriabá</segment>
    <segment id="15">, Cacique Shirley Krenak</segment>
    <segment id="16">, Cacica Ângoho</segment>
    <segment id="17">, também noninada Célia Hã Hã Hãe no evento &amp;quot</segment>
    <segment id="18">;Sem Demarcação</segment>
    <segment id="19">não tem Jogo&amp;quot</segment>
    <segment id="20">;, na aldeia Katurãma</segment>
    <segment id="21">, em São Joaquim de Bicas (MG) - Divulgação</segment>
    <segment id="22">Quando afirmamos que o Brasil é terra indígena</segment>
    <segment id="23">, nos referimos a nossa presença física</segment>
    <segment id="24">, territorial e espiritual em todo o território que foi demarcado</segment>
    <segment id="25">comocomo Brasil.</segment>
    <segment id="26">Passado</segment>
    <segment id="27">, presente e futuro de resistência indígena.</segment>
    <segment id="28">Antes da chegada dos portugueses estima-</segment>
    <segment id="29">sese que havia mais de 5 milhões de habitantes que falavam aproximadamente mais de mil línguas.</segment>
    <segment id="30">A população indígena em nosso país está crescendo</segment>
    <segment id="31">, éramos mais de 800 mil em 2010 e agora somos mais de 1 milhão</segment>
    <segment id="32">, de acordo com o balanço parcial do IBGE.</segment>
    <segment id="33">Dados como</segment>
    <segment id="34">como esses são essenciais na construção e implementação de políticas públicas voltadas para nossos povos</segment>
    <segment id="35">, independente de onde estejam.</segment>
    <segment id="36">No entanto</segment>
    <segment id="37">, a nossa existência continua sendo apagada pelo governo e</segment>
    <segment id="38">, por exemplo</segment>
    <segment id="39">, 50% da população yanomami corre o risco de não ser recenseada por falta de disponibilidade de transporte pelo governo federal.</segment>
    <segment id="40">Esse apagamento acontece nas cidades também</segment>
    <segment id="41">porque</segment>
    <segment id="42">porque a maioria da população ainda acredita que povos indígenas só estão no imaginário de 1500 ou dentro das comunidades.</segment>
    <segment id="43">Conflitos entre indígenas ganham força em terras não demarcadasMais    novamente         de   de  de  representando um</segment>
    <segment id="44">Os povos indígenas estão presentes em todos os estados do Brasil e em diferentes contextos: temos povos em isolamento voluntário</segment>
    <segment id="45">, nas aldeias</segment>
    <segment id="46">, nas comunidades</segment>
    <segment id="47">, nas cidades</segment>
    <segment id="48">, principalmente nas periferias</segment>
    <segment id="49">, território para onde somos levados e acolhidos quando precisamos ir para a cidade por inúmeros motivos</segment>
    <segment id="50">, como</segment>
    <segment id="51">como estudar</segment>
    <segment id="52">, buscar melhorias para nossas famílias e comunidades</segment>
    <segment id="53">, ou quando continuamos a ser expulsos dessas nossas terras.</segment>
    <segment id="54">São mais de 170 línguas nativas</segment>
    <segment id="55">, e pelo menos 40 estão em iminente perigo de desaparecerem</segment>
    <segment id="56">, povos que têm português</segment>
    <segment id="57">comocomo língua materna por terem tido suas línguas extintas pelo processo de colonização</segment>
    <segment id="58">, movimentos de retomada</segment>
    <segment id="59">, alguns parentes que nem tem consciência de que são indígenas</segment>
    <segment id="60">, imigrantes que chegaram ao Brasil e diversidade de fenótipos e visões de mundo.</segment>
  </rst>
</analysis>