  <rst>
    <segment id="1">Em termos diplomáticos</segment>
    <segment id="2">, Taiwan</segment>
    <segment id="3">sese tornou um bichinho solitário.</segment>
    <segment id="4">Foi recentemente abandonada por Honduras</segment>
    <segment id="5">, que fechou sua embaixada em Taipé para abri-la em Pequim.</segment>
    <segment id="6">O governo da ilha hoje mantém relações com apenas 13 dos 193 países-membros da ONU.</segment>
    <segment id="7">O assunto foi levantado em podcast da Universidade Johns Hopkins</segment>
    <segment id="8">, dos Estados Unidos.</segment>
    <segment id="9">Detalhe interessante veio à tona:</segment>
    <segment id="10">sete dos países que mantêm relações com Taiwan são da América Latina.</segment>
    <segment id="11">E são nações menores ou de pequena expressão</segment>
    <segment id="12">, como</segment>
    <segment id="13">como Belize e Haiti.</segment>
    <segment id="14">Em termos de extensão geográfica</segment>
    <segment id="15">, o maior interlocutor regional é o Paraguai.</segment>
    <segment id="16">A presidente de Taiwan</segment>
    <segment id="17">, Tsai Ing-wen</segment>
    <segment id="18">, durante cerimônia de graduação de estudantes na Universidade de Defesa Nacional</segment>
    <segment id="19">, academia militar na capital da ilha</segment>
    <segment id="20">, Taipé- Ann Wang - 21.jun.23/ReutersNos últimos anos</segment>
    <segment id="21">Taiwan foi abandonada por 27 de seus antigos parceiros diplomáticos</segment>
    <segment id="22">, disse Margaret Myers</segment>
    <segment id="23">, diretora de Ásia e América Latina no think tank Inter-American Dialogue.</segment>
    <segment id="24">Mas há também um curioso contraste.</segment>
    <segment id="25">A ilha —oficialmente República da China</segment>
    <segment id="26">, em oposição à China continental</segment>
    <segment id="27">, a República Popular da China— diminuiu em importância diplomática na mesma proporção em que cresceu em importância tecnológica e econômica.  China</segment>
    <segment id="28">, terra do meioReceba no seu email os grandes temas da China explicados e contextualizados</segment>
    <segment id="29">; exclusiva para assinantes.</segment>
    <segment id="30">Carregando...</segment>
    <segment id="31">É, por exemplo</segment>
    <segment id="32">, um dos grandes produtores mundiais de chips para computadores e componentes de veículos.</segment>
    <segment id="33">Esse dinamismo industrial</segment>
    <segment id="34">sese traduz no volume de dinheiro que o sistema financeiro local é capaz de gerir</segment>
    <segment id="35">, com influência na Ásia e alhures.</segment>
    <segment id="36">Um pouco de história cai bem:</segment>
    <segment id="37">Taiwan pertencia ao Japão até cair sob controle chinês quando o país é derrotado na Segunda Guerra Mundial.</segment>
    <segment id="38">Anos depois</segment>
    <segment id="39">, em 1949</segment>
    <segment id="40">, em meio à guerra civil chinesa</segment>
    <segment id="41">, os comunistas de Mao Tse-tung</segment>
    <segment id="42">sese apoderam de Pequim</segment>
    <segment id="43">, marcam controle sobre o imenso território chinês e empurram os nacionalistas de Chiang Kai-shek para a ilha de Taiwan</segment>
    <segment id="44">, também conhecida por Formosa.</segment>
    <segment id="45">Taiwan</segment>
    <segment id="46">, a ilha que é independente</segment>
    <segment id="47">, masmas a China considera uma província rebeldeMais    novamente         de   de  de  representando um  Começa então um longo período da guerra fria local</segment>
    <segment id="48">, opondo a China continental —com seus problemas derivados da superpopulação e das besteiras econômicas cometidas pelo Partido Comunista— e a pequena Taiwan</segment>
    <segment id="49">, ditadura que</segment>
    <segment id="50">sese considerava "um porta-aviões ancorado" para a defesa do chamado mundo livre.</segment>
    <segment id="51">Nos anos 1970</segment>
    <segment id="52">, a China entra em período acelerado de modernização</segment>
    <segment id="53">, com o surgimento de uma burguesia dinâmica e paradoxalmente disciplinada às imposições do Partido Comunista.</segment>
    <segment id="54">Enquanto isso</segment>
    <segment id="55">, Taiwan</segment>
    <segment id="56">sese democratiza e deixa de lado seu ímpeto militarista.</segment>
    <segment id="57">Lá foraReceba no seu email uma seleção semanal com o que de mais importante aconteceu no mundo</segment>
    <segment id="58">; aberta para não assinantes.</segment>
    <segment id="59">Carregando...</segment>
    <segment id="60">Um único detalhe permaneceu imutável: a concepção da China de que o país é uma coisa só e que</segment>
    <segment id="61">, mais cedo ou mais tarde</segment>
    <segment id="62">, Taiwan precisaria</segment>
    <segment id="63">sese juntar à China continental</segment>
    <segment id="64">, conforme a receita adotada em Hong Kong</segment>
    <segment id="65">, ex-protetorado britânico onde a democracia em grande parte desapareceu neutralizada pelo autoritarismo dos comunistas.</segment>
    <segment id="66">Em 1971</segment>
    <segment id="67">, a China conseguiu que a ONU adotasse a Resolução 2758</segment>
    <segment id="68">, pela qual Taiwan foi expulsa do espaço das delegações da Assembleia-Geral e do Conselho de Segurança</segment>
    <segment id="69">, sendo substituída pelos diplomatas de Pequim também em instituições</segment>
    <segment id="70">comocomo a OMS e a Unesco.</segment>
    <segment id="71">O mesmo ocorreu numa sequência em cascata de outras capitais</segment>
    <segment id="72">, de Washington a Brasília.</segment>
    <segment id="73">Nem por isso</segment>
    <segment id="74">, no entanto</segment>
    <segment id="75">, a ilha deixou de ser tratada</segment>
    <segment id="76">comocomo um aliado pelo governo dos EUA</segment>
    <segment id="77">, que fornece a Taiwan boa parte de seu poder bélico e impede que seja engolida por seu grande e poderoso vizinho.</segment>
    <segment id="78">Desde 1993</segment>
    <segment id="79">, Taiwan tem inutilmente batido às portas da ONU para solicitar seu ingresso.</segment>
    <segment id="80">Taiwan realiza tradicional exercício militar anualMais    novamente         de   de  de  representando um</segment>
    <segment id="81">Mas voltemos a Margaret Myers e ao podcast.</segment>
    <segment id="82">Na falta de embaixadas e consulados</segment>
    <segment id="83">, ela cita os escritórios de representação</segment>
    <segment id="84">comocomo o instrumento pelo qual Taiwan exerce sua política externa.</segment>
    <segment id="85">No caso</segment>
    <segment id="86">caso do Brasil</segment>
    <segment id="87">, diz ela</segment>
    <segment id="88">, mesmo sem uma embaixada</segment>
    <segment id="89">, há fortes vínculos no campo tecnológico.</segment>
    <segment id="90">A pesquisadora nega que Taiwan pratique a chamada "diplomacia do dólar"</segment>
    <segment id="91">, que consiste em comprar o apoio de pequenos países.</segment>
    <segment id="92">Não haveria dinheiro</segment>
    <segment id="93">, diz, para financiar esse mecanismo</segment>
    <segment id="94">, cuja existência Pequim afirma existir.</segment>
    <segment id="95">O fato é que Taiwan</segment>
    <segment id="96">sese comporta</segment>
    <segment id="97">comocomo um parceiro leal com aqueles com quem mantém relações.</segment>
    <segment id="98">Durante a pandemia</segment>
    <segment id="99">, forneceu vacinas para o Paraguai e influiu</segment>
    <segment id="100">para que</segment>
    <segment id="101">para que os EUA fizessem o mesmo.</segment>
    <segment id="102">Myers cita</segment>
    <segment id="103">, por fim</segment>
    <segment id="104">, a visita feita no início do ano pela presidente da ilha</segment>
    <segment id="105">, Tsai Ing-wen</segment>
    <segment id="106">, a Guatemala e Belize.</segment>
    <segment id="107">E aproveitou para visitar os EUA</segment>
    <segment id="108">, sob protestos da China continental.</segment>
    <segment id="109">Taiwan Loses Its FriendsAutoria Universidade Johns HopkinsLink: https://hopkinspofa.com/2023/04/24/taiwan-loses-its-friends/</segment>
    <segment id="110">Duração 24 mins.</segment>
    <segment id="111">(em inglês)</segment>
  </rst>
</analysis>