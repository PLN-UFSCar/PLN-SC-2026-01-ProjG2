  <rst>
    <segment id="1">Estes cookies picantes</segment>
    <segment id="2">, cheios de chocolate e com marshmallow</segment>
    <segment id="3">, são ótimos para surpreender.</segment>
    <segment id="4">A massa leva canela e um toque de pimenta-caiena em pó</segment>
    <segment id="5">, combinação típica do chocolate quente mexicano.</segment>
    <segment id="6">O recheio</segment>
    <segment id="7">, com marshmallow</segment>
    <segment id="8">, tem textura macia e fofa</segment>
    <segment id="9">, e pode ser armazenado em um pote hermético durante alguns dias.</segment>
    <segment id="10">Não esqueça de congelar completamente os marshmallows antes de fazer a receita.</segment>
    <segment id="11">Biscoitos de chocolate quente mexicano.</segment>
    <segment id="12">Comida estilizada por Samantha Seneviratne - Johnny Miller/The New York Times  Rendimento: 20 a 24 biscoitos</segment>
    <segment id="13">Tempo total: 1 hora e meia</segment>
    <segment id="14">, mais 2 horas de resfriamento</segment>
    <segment id="15">Ingredientes   1 ½ xícaras (chá) de farinha de trigo comum ½ xícara (chá) de cacau em pó 1 colher (chá) de bicarbonato de sódio 1 colher (chá) de sal ½ colher (chá) de pimenta-caiena em pó 3 colheres (chá) de canela em pó ½ xícara (chá) de manteiga sem sal</segment>
    <segment id="16">, em temperatura ambiente 1 ½ xícaras (chá) de açúcar mascavo claro 1 ovo grande</segment>
    <segment id="17">, em temperatura ambiente 2 colheres (chá) de extrato de baunilha</segment>
    <segment id="18">Mini marshmallows</segment>
    <segment id="19">, congelados ¼ xícara (chá) de açúcar granulado</segment>
    <segment id="20">Modo de preparo</segment>
    <segment id="21">Em uma tigela média</segment>
    <segment id="22">, misture a farinha</segment>
    <segment id="23">, o cacau em pó</segment>
    <segment id="24">, o bicarbonato de sódio</segment>
    <segment id="25">, o sal</segment>
    <segment id="26">, a pimenta-caiena e 2 colheres de chá de canela em pó.</segment>
    <segment id="27">Reserve.</segment>
    <segment id="28">Coloque os marshmallows para congelar</segment>
    <segment id="29">Usando uma batedeira com pá</segment>
    <segment id="30">, bata a manteiga e o açúcar mascavo em velocidade média-alta até ficar claro e fofo</segment>
    <segment id="31">, por cerca de 2 minutos.</segment>
    <segment id="32">Adicione o ovo e a baunilha.</segment>
    <segment id="33">Bata até ficar cremoso</segment>
    <segment id="34">, por mais 2 minutos.</segment>
    <segment id="35">Adicione a mistura de farinha reservada.</segment>
    <segment id="36">Bata em velocidade baixa até que não haja pontos secos</segment>
    <segment id="37">, cerca de 1 minuto.</segment>
    <segment id="38">Use uma colher de sorvete para porcionar a massa de cookie</segment>
    <segment id="39">, colocando em uma assadeira.</segment>
    <segment id="40">Cubra e leve à geladeira por pelo menos 2 horas</segment>
    <segment id="41">, ou até durante a noite.</segment>
    <segment id="42">Quando estiver pronto para assar</segment>
    <segment id="43">, aqueça o forno a 180ºC e forre 2 assadeiras com papel-manteiga.</segment>
    <segment id="44">Adicione o açúcar granulado e a colher de chá restante de canela a uma tigela pequena.</segment>
    <segment id="45">Retire metade da massa da geladeira e deixe-a à temperatura ambiente por 5 minutos</segment>
    <segment id="46">sese a massa estiver muito rígida.</segment>
    <segment id="47">Pegue uma unidade da massa e achate ligeiramente na palma da mão.</segment>
    <segment id="48">Empilhe 5 mini marshmallows congelados em cima da massa achatada</segment>
    <segment id="49">, em seguida</segment>
    <segment id="50">, traga as bordas externas sobre os marshmallows para envolvê-los</segment>
    <segment id="51">, fazendo uma bola.</segment>
    <segment id="52">Depois passe pelo açúcar de canela para cobrir.</segment>
    <segment id="53">Coloque na assadeira</segment>
    <segment id="54">, com 15 cm de distância um do outro.</segment>
    <segment id="55">Asse por 10 a 12 minutos</segment>
    <segment id="56">, girando na metade do tempo</segment>
    <segment id="57">, até que os cookies cresçam ligeiramente e pedaços de marshmallow derretido apareçam na superfície.</segment>
    <segment id="58">Deixe esfriar na assadeira por cerca de 5 minutos</segment>
    <segment id="59">, depois transfira para uma grade para esfriar completamente.</segment>
    <segment id="60">Os biscoitos</segment>
    <segment id="61">sese manterão por cerca de 3 dias em um recipiente hermético à temperatura ambiente.</segment>
    <segment id="62">Dicas: Antes de assar</segment>
    <segment id="63">, a massa porcionada (antes de ser revestida com açúcar de canela) pode ser congelada por até 3 meses em um recipiente hermético.</segment>
    <segment id="64">Para assar</segment>
    <segment id="65">, descongele por 5 minutos à temperatura ambiente</segment>
    <segment id="66">, enrole no açúcar de canela e asse por 13 a 15 minutos.</segment>
  </rst>
</analysis>