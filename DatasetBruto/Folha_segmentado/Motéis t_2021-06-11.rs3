  <rst>
    <segment id="1">Com o avanço da vacinação contra Covid-19 no estado de São Paulo</segment>
    <segment id="2">, os proprietários de motéis esperam faturar mais neste Dia dos Namorados.</segment>
    <segment id="3">A data é</segment>
    <segment id="4">, na avaliação dos empresários da área</segment>
    <segment id="5">, o equivalente ao Natal.</segment>
    <segment id="6">O setor moteleiro aposta nas promoções</segment>
    <segment id="7">, até o domingo (13) para espantar a fase ruim do início da pandemia.</segment>
    <segment id="8">Para isso</segment>
    <segment id="9">, os motéis voltaram a oferecer promoções na Love Week</segment>
    <segment id="10">, que começou no dia 7 e vai até dia 13</segment>
    <segment id="11">, para quem fizer a reserva pelo site da campanha.</segment>
    <segment id="12">Os valores do pernoite custam a partir de R$ 129</segment>
    <segment id="13">,15, incluindo brindes</segment>
    <segment id="14">comocomo espumantes e horário estendido para check-in e check-out.</segment>
    <segment id="15">Móteis fazem promoção na capital paulista para o Dia dos Namorados de 2021 - DivulgaçãoNa Cidade Universitária (zona oeste)</segment>
    <segment id="16">, o L’Essence</segment>
    <segment id="17">, tem suítes a partir de R$ 129</segment>
    <segment id="18">,15.</segment>
    <segment id="19">No Motel Ouse</segment>
    <segment id="20">, em Itaquera (zona leste)</segment>
    <segment id="21">, o pernoite dentro da promoção custa a partir de R$ 267</segment>
    <segment id="22">,75.  ​No Jardim Jaraguá (zona oeste)</segment>
    <segment id="23">, o preço no Destiny Motel é a partir de R$ 283</segment>
    <segment id="24">,50.</segment>
    <segment id="25">Há ainda valores promocionais na Grande SP e no ABC.</segment>
    <segment id="26">Em Poá (Grande SP)</segment>
    <segment id="27">, a Love Week tem</segment>
    <segment id="28">comocomo opção de pernoite com preço especial no Venus</segment>
    <segment id="29">Inn a partir de R$ 295</segment>
    <segment id="30">,05.</segment>
    <segment id="31">Em Santo André</segment>
    <segment id="32">, no ABC</segment>
    <segment id="33">, o motel Enigma tem pernoite a partir de R$ 313</segment>
    <segment id="34">,95.</segment>
    <segment id="35">Muitos dos motéis que participam da semana promocional do Dia dos Namorados oferecem no valor do pernoite o jantar e o café da manhã.</segment>
    <segment id="36">Além do site</segment>
    <segment id="37">, também é possível fazer reservas pelo aplicativo "Guia de Motéis Go".</segment>
    <segment id="38">É possível também parcelar a conta dos pacotes oferecidos na campanha em até 12 vezes.</segment>
    <segment id="39">"</segment>
    <segment id="40">Os motéis são opções de entretenimento totalmente privativas.</segment>
    <segment id="41">Neles, o casal não tem contato com outros hóspedes nem com a equipe que trabalha no local”</segment>
    <segment id="42">, afirma Felipe Martinez</segment>
    <segment id="43">, presidente da ABMotéis (Associação Brasileira de Motéis).</segment>
    <segment id="44">Segundo Martinez</segment>
    <segment id="45">, a diferença entre o cenário de 2020 e o de 2021</segment>
    <segment id="46">, é que os clientes estão mais conscientes sobre a forma de contágio e as condições de segurança.</segment>
    <segment id="47">Neste quesito</segment>
    <segment id="48">, os protocolos rígidos de limpeza e higienização</segment>
    <segment id="49">, tradicionais nos motéis</segment>
    <segment id="50">, são uma vantagem.</segment>
    <segment id="51">Outro ponto de destaque é que</segment>
    <segment id="52">, neste ano</segment>
    <segment id="53">, a ida ao motel pode ser uma opção para os paulistanos que não querem</segment>
    <segment id="54">sese arriscar em uma viagem</segment>
    <segment id="55">, por exemplo.</segment>
    <segment id="56">“</segment>
    <segment id="57">Os casais estão também interessados na gastronomia</segment>
    <segment id="58">, com um jantar romântico a dois na suíte</segment>
    <segment id="59">, mais privativo e num ambiente seguro”</segment>
    <segment id="60">, diz Martinez.  Lush Motel   novamente         de   de  de  representando um  A Abrasel-SP (Associação Brasileira de Bares e Restaurantes) também estima que as comemorações do Dia dos Namorados serão mais reservadas e o setor pode faturar até 100% a mais com os pedidos de delivery</segment>
    <segment id="61">, comparando com um sábado comum na pandemia do coronavírus.</segment>
    <segment id="62">“</segment>
    <segment id="63">O setor adquiriu experiência e estabeleceu parcerias que facilitam o delivery</segment>
    <segment id="64">, possibilitando ampliar o número de entregas com qualidade”</segment>
    <segment id="65">, afirma Joaquim Saraiva de Almeida</segment>
    <segment id="66">, presidente da Abrasel SP.</segment>
    <segment id="67">Os empresários do setor tentaram convencer o governo do estado para flexibilizar as medidas de contenção da pandemia</segment>
    <segment id="68">, permitindo que no sábado</segment>
    <segment id="69">, dia 12</segment>
    <segment id="70">, os estabelecimentos possam ficar abertos até 23h e com mesas na calçada.</segment>
    <segment id="71">A solicitação foi feita no dia 4 e junho</segment>
    <segment id="72">, porém</segment>
    <segment id="73">porém, segunda a Abrasel-SP</segment>
    <segment id="74">, não houve retorno.</segment>
    <segment id="75">Nesta semana</segment>
    <segment id="76">, o governo anunciou a manutenção da atual fase de restrições por conta da pandemia de Covid até o dia 30 de junho.</segment>
  </rst>
</analysis>