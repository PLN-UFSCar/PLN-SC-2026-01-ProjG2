    <segment id="243">99198-0944</segment>
    <segment id="244">; pousada4estacoesdepinhal.com.br  Pousada Candeias</segment>
    <segment id="245">, Cunha Você nem precisa sair dessa pousada para tomar um banho de cachoeira: basta fazer</segment>
    <segment id="246">, ali mesmo</segment>
    <segment id="247">, uma trilha de 1.700 metros cercada por árvores</segment>
    <segment id="248">comocomo araucárias e pereiras.</segment>
    <segment id="249">Os dez chalés têm varanda ou deque com rede e são rodeados de verde.</segment>
    <segment id="250">Situada em Cunha</segment>
    <segment id="251">, a pousada é cercada por atrações</segment>
    <segment id="252">comocomo as trilhas do Parque Estadual Serra do Mar</segment>
    <segment id="253">, a Cachoeira do Pimenta e campos de lavanda.</segment>
    <segment id="254">A cidade de Paraty está situada a apenas 35 de distância.</segment>
    <segment id="255">Estrada do Campo Alegre</segment>
    <segment id="256">, km 1</segment>
    <segment id="257">,1, Cunha.</segment>
    <segment id="258">Pacotes de quatro diárias a partir de R$ 3.120 por casal.</segment>
