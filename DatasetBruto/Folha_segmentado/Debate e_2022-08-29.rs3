  <rst>
    <segment id="1">Polêmica.</segment>
    <segment id="2">Confronto.</segment>
    <segment id="3">Discussão.</segment>
    <segment id="4">É a campanha eleitoral.</segment>
    <segment id="5">Torna-</segment>
    <segment id="6">sese importante</segment>
    <segment id="7">, neste momento</segment>
    <segment id="8">, a participação de todas as camadas sociais.</segment>
    <segment id="9">Alcyr concordava.  —</segment>
    <segment id="10">Não perco esse debate por nada.</segment>
    <segment id="11">A noite ia chegando de mansinho no Jardim Valo Verde.  —Bolsonaro</segment>
    <segment id="12">, Lula</segment>
    <segment id="13">, Ciro...</segment>
    <segment id="14">encontro de gigantes.</segment>
    <segment id="15">O jovem motoqueiro lançou um olhar de desprezo para os barracos à sua volta.  —</segment>
    <segment id="16">E aqui no bairro ninguém</segment>
    <segment id="17">sese interessa.</segment>
    <segment id="18">O horário do debate eleitoral talvez atrapalhasse um pouco.  —</segment>
    <segment id="19">Nada disso.</segment>
    <segment id="20">Todo esse povo está desempregado.</segment>
    <segment id="21">Ele respirou fundo.  —</segment>
    <segment id="22">É burrice mesmo.</segment>
    <segment id="23">A mãe dele</segment>
    <segment id="24">sese chamava Sidália.  —</segment>
    <segment id="25">Esse menino precisava ter mais humildade...  —</segment>
    <segment id="26">Olha.</segment>
    <segment id="27">Olha.</segment>
    <segment id="28">Vai começar o debate.</segment>
    <segment id="29">--Eu, hein?</segment>
    <segment id="30">Ficar ouvindo falação.  —</segment>
    <segment id="31">Ah.</segment>
    <segment id="32">Prefere a conversa dos bispos</segment>
    <segment id="33">, né.</segment>
    <segment id="34">O pastor Avarildo Campelo tinha forte presença na área.  —Ele ajudou muito a gente quando seu pai ficou doente.  —Pena que faltou vacina.</segment>
    <segment id="35">O Covid fizera do sr.</segment>
    <segment id="36">Cesário uma de suas primeiras vítimas.</segment>
    <segment id="37">Alcyr verificava o estado da televisão.  —</segment>
    <segment id="38">O que está acontecendo?  —</segment>
    <segment id="39">E agora</segment>
    <segment id="40">, vamos passar às regras do deb...</segment>
    <segment id="41">deb... creec.</segment>
    <segment id="42">Som e imagem fugiram do antigo aparelho Sanyo Circuito Integrado.  —Só pode ser a parabólica.</segment>
    <segment id="43">Alcyr subiu na laje da residência.  —Entortou tudo na última chuva de pedra.</segment>
    <segment id="44">Ele ia tentando consertar.  —Mãe.</segment>
    <segment id="45">Vê aí se</segment>
    <segment id="46">se a imagem voltou.  —</segment>
    <segment id="47">Hein?</segment>
    <segment id="48">Fala mais alto</segment>
    <segment id="49">, filho.</segment>
    <segment id="50">Alcyr já não era capaz de responder.</segment>
    <segment id="51">A bala perdida cortara suas conexões com o mundo dos vivos.</segment>
    <segment id="52">Intenso conflito entre traficantes na vizinhança.</segment>
    <segment id="53">O debate deve ser estimulado.</segment>
    <segment id="54">O problema</segment>
    <segment id="55">, por vezes</segment>
    <segment id="56">, é a hora em que começa o tiroteio.</segment>
    <segment id="57">Veja fotos do debate histórico de Lula e CollorMais    novamente         de   de  de  representando um</segment>
  </rst>
</analysis>