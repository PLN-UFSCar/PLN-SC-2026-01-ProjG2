  <rst>
    <segment id="1">Carlos Minc</segment>
    <segment id="2">, vice-presidente do PSB-RJ</segment>
    <segment id="3">, defende que Cesar Maia (PSDB) seja o vice de Marcelo Freixo (PSB) na disputa pelo Governo do Rio de Janeiro.</segment>
    <segment id="4">Ele acredita que o ex-prefeito seria um escudo para rejeição no segundo turno.</segment>
    <segment id="5">"</segment>
    <segment id="6">Acho que o Freixo está mirando no segundo turno.</segment>
    <segment id="7">Ele tem uma rejeição maior.</segment>
    <segment id="8">Os principais argumentos contra Freixo são os de que ele é inexperiente e muito radical.</segment>
    <segment id="9">O Maia não é nada radical e tem muita experiência.</segment>
    <segment id="10">É um escudo para reduzir a rejeição e garantir uma vitória.</segment>
    <segment id="11">O Cesar Maia é o Geraldo Alckmin do Freixo"</segment>
    <segment id="12">, afirma o ex-ministro</segment>
    <segment id="13">, que é membro da coordenação de campanha.</segment>
    <segment id="14">O deputado federal Marcelo Freixo (PSB-RJ) e o vereador César Maia (PSDB-RJ) em encontro para discutir aliança para o governo do RJ - @marcelofreixo no Instagram  "</segment>
    <segment id="15">O movimento do Freixo</segment>
    <segment id="16">, ao contrário de outros anos</segment>
    <segment id="17">, é o de ter diálogo com o centro.</segment>
    <segment id="18">Foi essa a razão de trocar o PSOL pelo PSB"</segment>
    <segment id="19">, completa Minc.</segment>
    <segment id="20">O PSDB indicou Maia para a vice de Freixo nesta sexta-feira (15).</segment>
    <segment id="21">No entanto</segment>
    <segment id="22">, a aliança enfrenta resistência do Cidadania</segment>
    <segment id="23">, que está mais inclinado a apoiar o pedetista Rodrigo Neves na disputa pelo Palácio das Laranjeiras.</segment>
    <segment id="24">Minc acredita que a questão está praticamente resolvida.</segment>
    <segment id="25">"</segment>
    <segment id="26">Acho que o Cidadania acaba</segment>
    <segment id="27">sese convencendo</segment>
    <segment id="28">, porque</segment>
    <segment id="29">porque</segment>
    <segment id="30">sese não chegar a um acordo entre Cidadania e PSDB [no Rio]</segment>
    <segment id="31">, isso vai para o [diretório] nacional</segment>
    <segment id="32">, e no nacional o PSDB é majoritário na federação com o Cidadania.</segment>
    <segment id="33">Se não chegar a um acordo regional</segment>
    <segment id="34">, o nacional vai referendar o Cesar Maia</segment>
    <segment id="35">comocomo vice do Freixo"</segment>
    <segment id="36">, conclui.</segment>
  </rst>
</analysis>