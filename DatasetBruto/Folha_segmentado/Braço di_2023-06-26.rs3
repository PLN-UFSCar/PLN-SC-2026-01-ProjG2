  <rst>
    <segment id="1">O diretor de televisão Homero Salles</segment>
    <segment id="2">, que se</segment>
    <segment id="3">se diz o melhor amigo de Gugu Liberato</segment>
    <segment id="4">, com quem trabalhou no SBT e na Record</segment>
    <segment id="5">, disse que o apresentador e Rose Miriam nunca tiveram relações sexuais ou</segment>
    <segment id="6">sese relacionaram</segment>
    <segment id="7">comocomo namorados ou marido e mulher.</segment>
    <segment id="8">As informações foram divulgadas pelo colunista Erlan Bastos</segment>
    <segment id="9">, do site Em Off.</segment>
    <segment id="10">Rose Miriam</segment>
    <segment id="11">, viúva de Gugu - @rosemiriamoficial no InstagramSalles disse que Rose Miriam foi escolhida para ser mãe dos filhos do apresentador</segment>
    <segment id="12">porque</segment>
    <segment id="13">porque era considerada confiável e que ela recebia dinheiro de Gugu</segment>
    <segment id="14">, que teria pago sua faculdade.</segment>
    <segment id="15">Os dois</segment>
    <segment id="16">sese conheciam há muito tempo</segment>
    <segment id="17">, segundo Salles</segment>
    <segment id="18">, e eram amigos.</segment>
    <segment id="19">Gugu e Rose Miriam dormiam separados na casa que dividiam e só viajavam juntos em viagens de família</segment>
    <segment id="20">, com os filhos.</segment>
    <segment id="21">Ainda de acordo com o braço direito de Gugu</segment>
    <segment id="22">, o apresentador teria deixado a herança aos filhos e sobrinhos confiante de que a geração mais nova cuidaria da mais velha.  Gugu Liberato: quem está na disputa da herançaMais    novamente         de   de  de  representando um    "Disse a Rose que</segment>
    <segment id="23">, sese ela entrasse com um processo</segment>
    <segment id="24">, estaria tirando os bens dos filhos.</segment>
    <segment id="25">Ela me disse que a irmã morava de aluguel e eu eu disse que cederíamos um imóvel.</segment>
    <segment id="26">Ela disse que queria um valor mensal</segment>
    <segment id="27">, eu disse que ela teria uma mesada igual à mãe do Gugu"</segment>
    <segment id="28">, afirmou Salles.</segment>
    <segment id="29">"</segment>
    <segment id="30">Não tenho raiva e nem mágoa da Rose e das crianças</segment>
    <segment id="31">, masmas nunca vou perdoar por entrarem na Justiça.</segment>
    <segment id="32">Jogaram o nome do Gugu na lama com toda essa exposição.</segment>
    <segment id="33">"  Imagens de Gugu Liberato com a famíliaMais    novamente         de   de  de  representando</segment>
    <segment id="34">um</segment>
