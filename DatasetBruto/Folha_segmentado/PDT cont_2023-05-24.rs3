  <rst>
    <segment id="1">Um dos partidos que deram 100% dos votos favoráveis ao arcabouço fiscal</segment>
    <segment id="2">, o PDT contrariou posição crítica à nova regra externada por uma de suas principais lideranças</segment>
    <segment id="3">, o ex-candidato a presidente Ciro Gomes.</segment>
    <segment id="4">O ex-candidato a presidente Ciro Gomes durante a campanha eleitoral do ano passado - Ciro Gomes 12 no Twitter  Foram 18 votos pela aprovação da regra</segment>
    <segment id="5">, incluindo o do deputado Mauro Benevides Filho (CE)</segment>
    <segment id="6">, principal assessor econômico das campanhas de Ciro.</segment>
    <segment id="7">"</segment>
    <segment id="8">Houve uma melhora significativa do texto nos últimos dias</segment>
    <segment id="9">, que preservou investimentos e manteve e manteve em níveis elevados os gastos com saúde e educação</segment>
    <segment id="10">, que são nossas maiores preocupações"</segment>
    <segment id="11">, afirmou.</segment>
    <segment id="12">No último dia 12 de maio</segment>
    <segment id="13">, em palestra a investidores em Lisboa</segment>
    <segment id="14">, Ciro criticou o arcabouço</segment>
    <segment id="15">, chamando-o de "</segment>
    <segment id="16">arrocho absoluto na taxa de investimentos".</segment>
    <segment id="17">Benevides diz que a bancada decidiu apoiar a nova regra</segment>
    <segment id="18">, e que uma das razões foi o fato de o partido ter seu presidente</segment>
    <segment id="19">, Carlos Lupi</segment>
    <segment id="20">, como</segment>
    <segment id="21">como ministro da Previdência.</segment>
    <segment id="22">Não houve contato com Ciro</segment>
    <segment id="23">, diz o deputado.</segment>
    <segment id="24">"</segment>
    <segment id="25">Ele está fora do país.</segment>
    <segment id="26">Mas a gente já sabe mais ou menos o posicionamento dele"</segment>
    <segment id="27">, afirmou.</segment>
  </rst>
