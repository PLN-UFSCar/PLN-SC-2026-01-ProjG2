  <rst>
    <segment id="1">Antes da revolução industrial</segment>
    <segment id="2">, que alterou completamente as relações de homens e mulheres com o espaço público</segment>
    <segment id="3">, não havia distinções de gênero no convívio regado a álcool.</segment>
    <segment id="4">Ficava tudo em casa</segment>
    <segment id="5">, na comunidade</segment>
    <segment id="6">, nas feiras.</segment>
    <segment id="7">Trabalho e socialização</segment>
    <segment id="8">sese misturavam e todos bebiam juntos</segment>
    <segment id="9">, até crianças</segment>
    <segment id="10">, quando a água ainda não era confiável.</segment>
    <segment id="11">Com a invasão das máquinas</segment>
    <segment id="12">, entre meados do século 18 e início do 19</segment>
    <segment id="13">, os homens</segment>
    <segment id="14">, novos operários</segment>
    <segment id="15">, passavam o dia puxando alavancas e girando manivelas e de noite afogavam o cansaço num bar</segment>
    <segment id="16">, taverna</segment>
    <segment id="17">, pub ou saloon.</segment>
    <segment id="18">As mulheres de classe média e alta continuaram sendo "do lar"</segment>
    <segment id="19">, ao passo que as das classes mais pobres trocaram o trabalho no campo por uma jornada por vezes tripla</segment>
    <segment id="20">, imersas na fuligem que movia a economia e nos cuidados com os filhos e a casa.</segment>
    <segment id="21">A poeta Sylvia Plath - Reprodução/New York TimesA estas era garantido um lugar nos bares</segment>
    <segment id="22">, desde que entrassem por uma porta lateral e</segment>
    <segment id="23">sese mantivessem separadas dos varões.</segment>
    <segment id="24">Isso para "protegê-las"de cusparadas</segment>
    <segment id="25">, mijos e atitudes inconvenientes</segment>
    <segment id="26">, masmas também</segment>
    <segment id="27">porque</segment>
    <segment id="28">porque os homens preferiam</segment>
    <segment id="29">sese fechar em seu círculo de bravatas e viam com péssimos olhos as trabalhadoras que erguiam um caneco.</segment>
    <segment id="30">Na violenta miopia patriarcal</segment>
    <segment id="31">, deveriam estar ocupadas em ser esposas</segment>
    <segment id="32">, mães e filhas.  Mesmo antes da revolução industrial</segment>
    <segment id="33">, havia confusão.</segment>
    <segment id="34">Aceitava-</segment>
    <segment id="35">sese que mulheres administrassem tavernas e preparassem bebidas caseiras —contanto que não fossem bruxas.</segment>
    <segment id="36">Algumas das vítimas das fogueiras em Salém eram meras fabricantes de cervejas e destilados</segment>
    <segment id="37">, confundidos</segment>
    <segment id="38">, por ignorância ou conveniência</segment>
    <segment id="39">, com poções de feitiçaria.</segment>
    <segment id="40">Colunas e BlogsReceba no seu email uma seleção de colunas e blogs da Folha</segment>
    <segment id="41">; exclusiva para assinantes.</segment>
    <segment id="42">Carregando...</segment>
    <segment id="43">Nos EUA</segment>
    <segment id="44">, demorou muito</segment>
    <segment id="45">para que</segment>
    <segment id="46">para que as mulheres fossem aceitas</segment>
    <segment id="47">comocomo profissionais do balcão e não apenas garçonetes.</segment>
    <segment id="48">Foi só no final dos anos 1970 que a situação começou a melhorar</segment>
    <segment id="49">, quando as ações pela igualdade de gênero foram dobrando o machismo dos sindicatos.</segment>
    <segment id="50">Hoje as bartenders ocupam 60% do setor.</segment>
    <segment id="51">Já como</segment>
    <segment id="52">como consumidoras</segment>
    <segment id="53">, foi preciso que proibissem o álcool recreativo.</segment>
    <segment id="54">Na era dos speakeasies</segment>
    <segment id="55">, entre 1920 e 1933</segment>
    <segment id="56">, o prazer de brindar e a necessidade de manter um negócio ameaçado fez com que as mulheres tivessem acesso às banquetas e mesas subterrâneas</segment>
    <segment id="57">, assim</segment>
    <segment id="58">comocomo os clientes negros.</segment>
    <segment id="59">Não à toa</segment>
    <segment id="60">, uma das maiores apoiadoras da Lei Seca era a Ku Klux Klan.  Sylvia PlathMais    novamente         de   de  de  representando um  Em 1959</segment>
    <segment id="61">, as poetas Anne Sexton e Sylvia Plath</segment>
    <segment id="62">sese conheceram no curso de Robert Lowell</segment>
    <segment id="63">, na Universidade de Boston.</segment>
    <segment id="64">Melhores amigas e maiores rivais</segment>
    <segment id="65">, eram talentosas</segment>
    <segment id="66">, bonitas e autodestrutivas.</segment>
    <segment id="67">Expunham a intimidade em poemas confessionais de alta voltagem literária.</segment>
    <segment id="68">Falavam de menstruação</segment>
    <segment id="69">, aborto e masturbação sem eufemismos</segment>
    <segment id="70">, na cadência moderna do verso livre.</segment>
    <segment id="71">A influência que exercem até hoje é incalculável.</segment>
    <segment id="72">Madonna</segment>
    <segment id="73">, por exemplo</segment>
    <segment id="74">, bebeu muito da fonte Sexton.</segment>
    <segment id="75">Depois das aulas</segment>
    <segment id="76">, elas costumavam ir ao Ritz</segment>
    <segment id="77">, onde empilhavam taças de dry martinis e vodca stingers e conversavam alegremente sobre sexo</segment>
    <segment id="78">, suicídio</segment>
    <segment id="79">, a estupidez dos homens</segment>
    <segment id="80">, e, nas poucas brechas</segment>
    <segment id="81">, também poesia.</segment>
    <segment id="82">Certamente adorariam ir ao Pegu Club de Nova York</segment>
    <segment id="83">, aberto em 2005 por Audrey Saunders</segment>
    <segment id="84">, pioneira da nova onda dos coquetéis e da atuação feminina atrás do balcão.  Sexton: "</segment>
    <segment id="85">Para celebrar a mulher que sou/e a alma da mulher que sou/e a criatura central e seu prazer/canto para ti.</segment>
    <segment id="86">Me atrevo a viver./Olá</segment>
    <segment id="87">, espírito.</segment>
    <segment id="88">Olá, taça.</segment>
    <segment id="89">"</segment>
    <segment id="90">A poeta Anne Sexton - Reprodução  PEGU CLUB COCKTAIL  Ingredientes   60 ml de gim 25 ml de licor de laranja 15 ml de suco de limão</segment>
    <segment id="91">Uma espirrada de Angostura e uma de bitter de laranja</segment>
    <segment id="92">Passo a passo</segment>
    <segment id="93">Bata os ingredientes numa coqueteleira com gelo e coe para uma taça coupe gelada.</segment>
    <segment id="94">Enfeite com uma casca de limão</segment>
  </rst>
</analysis>