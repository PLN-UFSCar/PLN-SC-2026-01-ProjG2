  <rst>
    <segment id="1">A saída de Lionel Messi do Paris Saint-Germain ao final de seu contrato</segment>
    <segment id="2">, em junho</segment>
    <segment id="3">, é considerada muito mais provável</segment>
    <segment id="4">, masmas não certa</segment>
    <segment id="5">, disse uma fonte próxima ao clube nesta terça-feira (4).</segment>
    <segment id="6">Segundo a agência AFP</segment>
    <segment id="7">, essa fonte afirmou que nenhum acordo foi assinado e que a dinâmica mudou completamente no PSG</segment>
    <segment id="8">, que pressiona menos pela renovação.</segment>
    <segment id="9">Messi, que completa 36 anos em junho</segment>
    <segment id="10">, chegou à França em 2021.</segment>
    <segment id="11">Lionel Messi durante a partida do PSG contra o Bayern de Munique</segment>
    <segment id="12">, pelas oitavas de final da Champions League - Franck Fife-4.abr.23/AFPA atitude dos torcedores</segment>
    <segment id="13">, que vaiaram o craque argentino no domingo (2)</segment>
    <segment id="14">, na derrota em casa para o Lyon</segment>
    <segment id="15">, mudou completamente o jogo</segment>
    <segment id="16">, segundo esta fonte.</segment>
    <segment id="17">Após Messi voltar da Copa do Mundo do Qatar campeão</segment>
    <segment id="18">, tudo parecia estar orientado para um prolongamento do contrato.</segment>
    <segment id="19">Desde o título mundial</segment>
    <segment id="20">, porém</segment>
    <segment id="21">porém, conquistado com uma vitória na final justamente contra a seleção francesa de Mbappé</segment>
    <segment id="22">, Messi tem sido menos brilhante no PSG.</segment>
    <segment id="23">O argentino</segment>
    <segment id="24">, por exemplo</segment>
    <segment id="25">, não se</segment>
    <segment id="26">se destacou</segment>
    <segment id="27">, como</segment>
    <segment id="28">como outros dos seus companheiros</segment>
    <segment id="29">, na eliminação da equipe da Champions League</segment>
    <segment id="30">, diante do Bayern de Munique.</segment>
    <segment id="31">Veja a trajetória do Messi na copa do QatarMais    novamente         de   de  de  representando um</segment>
    <segment id="32">Em 67 jogos com a camisa do PSG</segment>
    <segment id="33">, o atacante marcou 29 gols e deu 32 assistências.</segment>
    <segment id="34">Depois de uma primeira temporada de aclimatação</segment>
    <segment id="35">, Messi conseguiu realizar um excelente início de temporada</segment>
    <segment id="36">2022-2023 até a Copa do Mundo no Catar.</segment>
    <segment id="37">Caso deixasse o PSG</segment>
    <segment id="38">, entre as hipóteses mais comentadas nas últimas semanas</segment>
    <segment id="39">, Messi poderia retornar ao Barcelona ou ir para o rico campeonato saudita</segment>
    <segment id="40">, onde joga seu grande rival Cristiano Ronaldo</segment>
    <segment id="41">, ou ainda ser tentado pela norte-americana MLS</segment>
    <segment id="42">, onde o Inter Miami gostaria de tê-lo.</segment>
  </rst>
