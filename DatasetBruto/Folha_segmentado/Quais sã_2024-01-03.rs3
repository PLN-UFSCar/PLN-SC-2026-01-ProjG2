  <rst>
    <segment id="1">Novo ano</segment>
    <segment id="2">, novo eu.</segment>
    <segment id="3">Ou melhor</segment>
    <segment id="4">, novo ano</segment>
    <segment id="5">, novas metas.</segment>
    <segment id="6">Quem nunca ouviu ou leu isso?</segment>
    <segment id="7">Na virada do dia 31 de dezembro para o 1º de janeiro</segment>
    <segment id="8">, muitas promessas são feitas</segment>
    <segment id="9">, novas metas são estabelecidas e grandes expectativas são criadas para o novo ano que</segment>
    <segment id="10">sese inicia.</segment>
    <segment id="11">Começar a frequentar a academia</segment>
    <segment id="12">, sese inscrever para um curso</segment>
    <segment id="13">, começar a namorar</segment>
    <segment id="14">, ler mais livros: a lista vai longe.</segment>
    <segment id="15">Estabelecer novas metas</segment>
    <segment id="16">, porém</segment>
    <segment id="17">porém, não significa que as antigas foram cumpridas.</segment>
    <segment id="18">Por isso</segment>
    <segment id="19">, algumas pessoas optam por reafirmar os votos feitos em anos anteriores</segment>
    <segment id="20">, já que cumprir uma meta nem sempre é tão simples.</segment>
    <segment id="21">Outros acabam levando o "novo ano</segment>
    <segment id="22">, papel em branco" a sério e decidem recomeçar.</segment>
    <segment id="23">Então novos desejos e objetivos são adicionados à lista.</segment>
    <segment id="24">O Ano-Novo pelo mundoMais    novamente         de   de  de  representando um</segment>
    <segment id="25">Se você é daqueles que vê o início do ano</segment>
    <segment id="26">comocomo uma chance de recomeçar e sempre tem em mente o que quer mudar</segment>
    <segment id="27">, a Folha quer saber:</segment>
    <segment id="28">quais são suas resoluções para o ano de 2024?</segment>
    <segment id="29">Como planeja atingir suas metas?</segment>
    <segment id="30">Quais suas expectativas para esse novo ano?</segment>
    <segment id="31">Além disso</segment>
    <segment id="32">, leitor</segment>
    <segment id="33">, você prefere manter as expectativas baixas (e assim tudo o que vier é lucro) ou prefere pensar grande?</segment>
    <segment id="34">Conte para a Folha neste formulário.</segment>
    <segment id="35">Algumas respostas podem ser publicadas no Painel do Leitor e divulgadas nas redes sociais da Folha.</segment>
  </rst>
