  <rst>
    <segment id="1">Dúvida.</segment>
    <segment id="2">Remorso.</segment>
    <segment id="3">Decepção.</segment>
    <segment id="4">Pastores</segment>
    <segment id="5">sese envolvem em roubalheira pesada no governo Bolsonaro.</segment>
    <segment id="6">Alguns membros da comunidade evangélica sentem o impacto.</segment>
    <segment id="7">–Que vergonha</segment>
    <segment id="8">, irmão.</segment>
    <segment id="9">Dona Gladíola tentava entender.</segment>
    <segment id="10">–Dinheiro?</segment>
    <segment id="11">Comissão?</segment>
    <segment id="12">Prefeituras?</segment>
    <segment id="13">O marido não</segment>
    <segment id="14">sese interessava muito.</segment>
    <segment id="15">–</segment>
    <segment id="16">Ué.</segment>
    <segment id="17">Qual a novidade?  –</segment>
    <segment id="18">Aquele ministro da Educação… tinha um jeito tão distinto.</segment>
    <segment id="19">–</segment>
    <segment id="20">Pois é.</segment>
    <segment id="21">Mas todos acabam é na cadeia.</segment>
    <segment id="22">–</segment>
    <segment id="23">Tudo bem que eles querem enriquecer…</segment>
    <segment id="24">A boa evangélica suspirou.</segment>
    <segment id="25">–É legítimo.</segment>
    <segment id="26">Afinal</segment>
    <segment id="27">, quem não quer?</segment>
    <segment id="28">–</segment>
    <segment id="29">Então do quê você está reclamando?</segment>
    <segment id="30">–Essa coisa de kit de robótica</segment>
    <segment id="31">…</segment>
    <segment id="32">acho que não é muito cristão.</segment>
    <segment id="33">O marido concordava.</segment>
    <segment id="34">–Educação</segment>
    <segment id="35">, para mim</segment>
    <segment id="36">, tem de ser na linha tradicional.</segment>
    <segment id="37">–Cartilha e tabuada.</segment>
    <segment id="38">–E oração</segment>
    <segment id="39">, Jurandir.</segment>
    <segment id="40">Oração.  –Pastor andando de jatinho…  –Jesus Cristo andava a pé.</segment>
    <segment id="41">–No máximo</segment>
    <segment id="42">, em cima de um jumento.</segment>
    <segment id="43">Foi amarga a exclamação de dona Gladíola.</segment>
    <segment id="44">–Quer saber</segment>
    <segment id="45">, Jurandir?</segment>
    <segment id="46">Jumento é você.</segment>
    <segment id="47">Ela logo completou.</segment>
    <segment id="48">–</segment>
    <segment id="49">Você, eu</segment>
    <segment id="50">, todos nós.</segment>
    <segment id="51">Raios prateados de sol atravessavam o céu nublado do Jardim Contorno.</segment>
    <segment id="52">Gladíola</segment>
    <segment id="53">sese lembrou das velhas missas da infância.</segment>
    <segment id="54">–</segment>
    <segment id="55">Fui criada</segment>
    <segment id="56">comocomo católica.</segment>
    <segment id="57">Veio a vontade de reencontrar-</segment>
    <segment id="58">sese com as antigas bases da fé.</segment>
    <segment id="59">Na Igreja Santa Ismália</segment>
    <segment id="60">, ela foi recebida de braços abertos pelo Padre Pelozzi.</segment>
    <segment id="61">–</segment>
    <segment id="62">La oveglia disgarrata ritorna para la antica pastagge.</segment>
    <segment id="63">Dona Gladíola olhou desconfiada para as escadarias do edifício.  –Mas</segment>
    <segment id="64">, padre…</segment>
    <segment id="65">–Pode falare</segment>
    <segment id="66">, minha figlia.  –</segment>
    <segment id="67">Na minha igreja todo mundo aparece arrumado… com roupa bonita…</segment>
    <segment id="68">Ela fez um gesto vago na direção da porta.</segment>
    <segment id="69">–Aqui só tem mendigo</segment>
    <segment id="70">…  De fato.</segment>
    <segment id="71">Um grande contingente de pedintes e dependentes químicos</segment>
    <segment id="72">sese espalhava no entorno.</segment>
    <segment id="73">Padre Pellozzi sorriu com resignação.</segment>
    <segment id="74">–</segment>
    <segment id="75">Ma minha figlia… non té otro djeito.</segment>
    <segment id="76">Ele explicou.</segment>
    <segment id="77">–Non exidgimo</segment>
    <segment id="78">il pagamento del dizzimo.</segment>
    <segment id="79">–</segment>
    <segment id="80">Ah não?  –</segment>
    <segment id="81">Tutto di grazza.</segment>
    <segment id="82">Sem un tostó.</segment>
    <segment id="83">Padre Pelozzi limpava o pavimento com um pano molhado.</segment>
    <segment id="84">–</segment>
    <segment id="85">Daí que djunta tutta essa mendigatta.</segment>
    <segment id="86">Havia nojo no olhar da evangélica.</segment>
    <segment id="87">–Jesus.</segment>
    <segment id="88">Só tem vagabundo aqui.</segment>
    <segment id="89">Essa igreja não deixa ninguém rico.</segment>
    <segment id="90">Padre Pelozzi fez cara séria.</segment>
    <segment id="91">–La signora escoglie.</segment>
    <segment id="92">É la vagabondaggia ou la corruzione.</segment>
    <segment id="93">La pobrezza o il jatigno.</segment>
    <segment id="94">Dona Gladíola voltou para casa sem saber o que fazer.</segment>
    <segment id="95">A alma</segment>
    <segment id="96">, por vezes</segment>
    <segment id="97">, é como</segment>
    <segment id="98">como uma ordem de prisão.</segment>
    <segment id="99">Fica suspensa até segunda ordem.</segment>
    <segment id="100">Culto na igreja do novo ministro da educaçãoMais    novamente         de   de  de  representando um</segment>
  </rst>
</analysis>