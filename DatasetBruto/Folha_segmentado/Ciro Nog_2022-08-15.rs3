    <segment id="10">, que promove encontros entre representantes dos setores público e privado.</segment>
    <segment id="11">O evento</segment>
    <segment id="12">, que vai acontecer em São Paulo</segment>
    <segment id="13">, também terá a presença de nomes</segment>
