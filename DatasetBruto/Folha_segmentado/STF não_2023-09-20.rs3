  <rst>
    <segment id="1">Defensores do julgamento virtual dos réus dos ataques de 8 de Janeiro usam</segment>
    <segment id="2">comocomo argumento o fato de o Supremo Tribunal Federal (STF) ter recebido 1.345 denúncias relacionadas ao</segment>
    <segment id="3">casocaso em dois inquéritos</segment>
    <segment id="4">, ao longo de nove sessões virtuais extraordinárias.</segment>
    <segment id="5">Ministro Alexandre de Moraes</segment>
    <segment id="6">, do STF</segment>
    <segment id="7">, antes de sessão que julgou réus do 8 de Janeiro - Pedro Ladeira/FolhapressDestas</segment>
    <segment id="8">, 1.113 denúncias recebidas estão com ação penal suspensa por 120 dias por decisão do ministro Alexandre de Moraes</segment>
    <segment id="9">, para que</segment>
    <segment id="10">para que a Procuradoria Geral da República analise</segment>
    <segment id="11">sese propõe</segment>
    <segment id="12">, ou não</segment>
    <segment id="13">, acordos de não persecução penal.</segment>
    <segment id="14">Na semana passada</segment>
    <segment id="15">, os três primeiros réus dos ataques foram condenados em julgamento presencial pelo STF.</segment>
    <segment id="16">Os próximos</segment>
    <segment id="17">, no entanto</segment>
    <segment id="18">, tendem a ser virtuais</segment>
    <segment id="19">, o que gerou protesto da OAB (Ordem dos Advogados do Brasil).</segment>
    <segment id="20">Segundo o criminalista Sergio Rosenthal</segment>
    <segment id="21">, as duras penas aplicadas até aqui a alguns dos autores dos atos revelam que o STF não os tratará</segment>
    <segment id="22">comocomo "simples baderneiros".  "</segment>
    <segment id="23">A depredação de prédios públicos era meio e não fim.</segment>
    <segment id="24">O que se</segment>
    <segment id="25">se buscou foi atentar contra o Estado Democrático de Direito"</segment>
    <segment id="26">, afirma.</segment>
  </rst>
</analysis>