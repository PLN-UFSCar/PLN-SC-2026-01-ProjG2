  <rst>
    <segment id="1">Atuando</segment>
    <segment id="2">, produzindo ou dirigindo</segment>
    <segment id="3">, pais e filhos compartilham o amor e a dedicação ao cinema.</segment>
    <segment id="4">Confira onde ver esses encontros (os preços e a disponibilidade nos serviços de streaming foram pesquisados no dia 5 de julho).</segment>
    <segment id="5">Jane e Henry Fonda em cena do filme &amp;quot</segment>
    <segment id="6">;Num Lago Dourado&amp;quot</segment>
    <segment id="7">; (1981) - DivulgaçãoPETER E JANE FONDA</segment>
    <segment id="8">O único encontro de pai e filha tão famosos no cinema aconteceu em “Num Lago Dourado” (1981)</segment>
    <segment id="9">, um filme sobre a velhice e as relações familiares.</segment>
    <segment id="10">Jane comprou os direitos da peça de mesmo nome que havia estreado na Broadway em 1979 com muito sucesso e prêmios.</segment>
    <segment id="11">Além de Henry e Jane</segment>
    <segment id="12">, o longa ainda tem Katharine Hepburn no elenco.</segment>
    <segment id="13">Assim como</segment>
    <segment id="14">como “Num Lago” foi o primeiro e único encontro de pai e filha atores em um filme</segment>
    <segment id="15">, este trabalho também foi o único em que Henry e Katharine</segment>
    <segment id="16">, dois dos grandes nomes de Hollywood</segment>
    <segment id="17">, atuaram juntos</segment>
    <segment id="18">, e ambos foram premiados com o Oscar pelo filme em 1982.</segment>
    <segment id="19">Na cerimônia</segment>
    <segment id="20">, Jane</segment>
    <segment id="21">, que havia sido indicada a melhor atriz coadjuvante</segment>
    <segment id="22">, recebeu a estatueta em nome do pai</segment>
    <segment id="23">, que estava doente e morreria meses depois.</segment>
    <segment id="24">No longa</segment>
    <segment id="25">, Henry e Katharine são dois idosos que recebem em sua casa no lago a filha e o novo namorado dela.</segment>
    <segment id="26">A filha não tem uma boa relação com o pai</segment>
    <segment id="27">, econômico nas demonstrações de afeto por ela.</segment>
    <segment id="28">Jane disse que</segment>
    <segment id="29">, durante uma tomada em que segurou inesperadamente a mão do pai</segment>
    <segment id="30">, Henry começou a chorar e afastou a cabeça da câmera</segment>
    <segment id="31">, envergonhado.</segment>
    <segment id="32">A cena entrou no corte final do filme.</segment>
    <segment id="33">ONDE VER  NUM LAGO DOURADO (1981)</segment>
    <segment id="34">Old Flix: grátis para assinantes  Jack Nicholson</segment>
    <segment id="35">, Kathleen Turner</segment>
    <segment id="36">, Angelica Huston e o diretor John Huston (à frente)</segment>
    <segment id="37">, no set de &amp;quot</segment>
    <segment id="38">;A Honra do Poderoso Prizzi&amp;quot</segment>
    <segment id="39">; - DivulgaçãoJOHN E ANJELICA HUSTON</segment>
    <segment id="40">O primeiro encontro no cinema entre o pai</segment>
    <segment id="41">, o diretor John Huston</segment>
    <segment id="42">, autor de clássicos</segment>
    <segment id="43">comocomo “O Tesouro de Sierra Madre” e “Os Desajustados”</segment>
    <segment id="44">, e a filha Anjelica aconteceu em 1969</segment>
    <segment id="45">, em “Caminhando com o Amor e a Morte”.</segment>
    <segment id="46">Foi a estreia dela</segment>
    <segment id="47">, então com 18 anos.</segment>
    <segment id="48">Nos anos seguintes</segment>
    <segment id="49">, Anjelica seguiu a carreira de modelo até que</segment>
    <segment id="50">, na década de 1980 decidiu-</segment>
    <segment id="51">sese pela atuação.</segment>
    <segment id="52">Pai e filha reencontraram-</segment>
    <segment id="53">sese, então</segment>
    <segment id="54">, em “A Honra do Poderoso Prizzi” (1985)</segment>
    <segment id="55">, comédia sobre mafiosos com Jack Nicholson e Kathleen Turner nos papéis principais.</segment>
    <segment id="56">Anjelica interpreta Maerose</segment>
    <segment id="57">, filha de um gângster.</segment>
    <segment id="58">Pela personagem</segment>
    <segment id="59">, recebeu o Oscar de melhor atriz coadjuvante em 1986.</segment>
    <segment id="60">Ela também fez parte do elenco do último filme de Huston</segment>
    <segment id="61">, “Os Vivos e os Mortos” (1987).</segment>
    <segment id="62">Essas experiências não foram as primeiras de Huston com familiares.</segment>
    <segment id="63">Ele havia dirigido o pai</segment>
    <segment id="64">, o ator Walter Huston</segment>
    <segment id="65">, em “O Tesouro”.</segment>
    <segment id="66">ONDE VER</segment>
    <segment id="67">A HONRA DO PODEROSO PRIZZI (1985)</segment>
    <segment id="68">Old Flix: grátis para assinantes</segment>
    <segment id="69">A atriz Fernanda Torres em cena do filme &amp;quot</segment>
    <segment id="70">;Inocência&amp;quot</segment>
    <segment id="71">; (1983)</segment>
    <segment id="72">, de Walter Lima Jr. - ReproduçãoFERNANDO E FERNANDA TORRES Pai e filha de uma das mais talentosas famílias do país estiveram juntos em dois filmes.</segment>
    <segment id="73">No clássico “Inocência”(1983)</segment>
    <segment id="74">, de Walter Lima Jr.</segment>
    <segment id="75">, não chegaram a dividir a cena.</segment>
    <segment id="76">Em sua estreia no cinema</segment>
    <segment id="77">, aos 18 anos</segment>
    <segment id="78">, Fernanda é a personagem título</segment>
    <segment id="79">, uma jovem que vive uma história de amor com um médico</segment>
    <segment id="80">, interpretado por Edson Celulari</segment>
    <segment id="81">, no Brasil do século 19.</segment>
    <segment id="82">Fernando é o padrinho da garota.</segment>
    <segment id="83">Em 2004</segment>
    <segment id="84">, foram dirigidos por Cláudio Torres</segment>
    <segment id="85">, filho de Fernando e irmão de Fernanda</segment>
    <segment id="86">, em “Redentor”.</segment>
    <segment id="87">A participação da família não parou por aí.</segment>
    <segment id="88">No elenco também estava Fernanda Montenegro.</segment>
    <segment id="89">ONDE VER  INOCÊNCIA (1983)</segment>
    <segment id="90">Globoplay</segment>
    <segment id="91">, Prime Video e Looke: grátis para assinantes.</segment>
    <segment id="92">NOW: grátis para assinantes do Looke e R$ 6</segment>
    <segment id="93">,90 (aluguel)  REDENTOR (2004)</segment>
    <segment id="94">Globoplay: grátis para assinantes</segment>
    <segment id="95">O ator Antonio Pitanga em cena de &amp;quot</segment>
    <segment id="96">;Pitanga&amp;quot</segment>
    <segment id="97">;, documentário codirigido por sua filha</segment>
    <segment id="98">, a atriz Camila Pitanga - Divulgação/TVGloboANTONIO E CAMILA PITANGA</segment>
    <segment id="99">Em 2017</segment>
    <segment id="100">, Camila Pitanga e o diretor Beto Brant lançaram “Pitanga”</segment>
    <segment id="101">, documentário sobre o pai da atriz</segment>
    <segment id="102">, Antonio Pitanga</segment>
    <segment id="103">, um dos principais atores do cinema brasileiro.</segment>
    <segment id="104">Ele surgiu nas telas em “Bahia de Todos os Santos” (1960)</segment>
    <segment id="105">, ainda</segment>
    <segment id="106">comocomo Antonio Luis Sampaio.</segment>
    <segment id="107">O Pitanga do sobrenome veio do personagem que interpretava no filme.</segment>
    <segment id="108">Em sua carreira estão filmes</segment>
    <segment id="109">comocomo “</segment>
    <segment id="110">O Pagador de Promessas”</segment>
    <segment id="111">, “</segment>
    <segment id="112">Os Fuzis” e obras do Cinema Novo.</segment>
    <segment id="113">Camila herdou o sobrenome e o talento.</segment>
    <segment id="114">Estiveram juntos nos filmes “Quilombo” (1984)</segment>
    <segment id="115">, de Cacá Diegues</segment>
    <segment id="116">, quando Camila ainda era criança</segment>
    <segment id="117">, e “Eu Receberia as Piores Notícias dos seus Lindos Lábios” (2011)</segment>
    <segment id="118">, de Brant.</segment>
    <segment id="119">ONDE VER  PITANGA (2017)</segment>
    <segment id="120">Globoplay: grátis para assinantes​  EU RECEBERIA</segment>
    <segment id="121">AS PIORES</segment>
    <segment id="122">NOTÍCIAS DOS SEUS</segment>
    <segment id="123">LINDOS LÁBIOS (2011)</segment>
    <segment id="124">Google Play: R$ 19</segment>
    <segment id="125">,90 (compra)</segment>
    <segment id="126">Apple TV: R$ 24</segment>
    <segment id="127">,90 (compra)</segment>
    <segment id="128">Looke: R$ 42</segment>
    <segment id="129">,90 (compra)  Chaplin</segment>
    <segment id="130">, Marlon Brando e Geraldine no set de filmagem de &amp;quot</segment>
    <segment id="131">;A Condessa de Hong Kong&amp;quot</segment>
    <segment id="132">; - DivulgaçãoCHARLES E GERALDINE CHAPLIN</segment>
    <segment id="133">A atriz Geraldine Chaplin queria ser bailarina profissional.</segment>
    <segment id="134">Filha do ator e diretor Charles Chaplin</segment>
    <segment id="135">, fez pequenas participações em filmes do pai</segment>
    <segment id="136">, e só decidiu ser atriz anos depois</segment>
    <segment id="137">, abraçando uma carreira que mantém até hoje</segment>
    <segment id="138">, aos 77 anos.</segment>
    <segment id="139">A primeira “colaboração” entre pai e filha aconteceu no clássico “Luzes da Ribalta” (1952)</segment>
    <segment id="140">, em que ela e seus irmãos contracenam com Chaplin no início do filme.</segment>
    <segment id="141">O segundo e último encontro deles nas telas foi em “A Condessa de Hong Kong” (1967)</segment>
    <segment id="142">, o filme final de Chaplin.</segment>
    <segment id="143">A esta altura</segment>
    <segment id="144">, Geraldine havia estrelado</segment>
    <segment id="145">“Doutor</segment>
    <segment id="146">Jivago” (1965)</segment>
    <segment id="147">.</segment>
    <segment id="148">Em “A Condessa”</segment>
    <segment id="149">, ela faz uma ponta</segment>
    <segment id="150">, como</segment>
    <segment id="151">como uma jovem em um baile.</segment>
    <segment id="152">ONDE VER Mubi: grátis para assinantes</segment>
    <segment id="153">Os atores Glória Pires</segment>
    <segment id="154">, Alexandre Paternost</segment>
    <segment id="155">, Bruno Campos e Patricia Pillar em cena do filme &amp;quot</segment>
    <segment id="156">;O Quatrilho&amp;quot</segment>
    <segment id="157">;, de Fábio Barreto</segment>
    <segment id="158">, produzido por Luiz Carlos Barreto - DivulgaçãoLUIZ CARLOS</segment>
    <segment id="159">, BRUNO E FÁBIO BARRETO</segment>
    <segment id="160">O produtor Luiz Carlos Barreto</segment>
    <segment id="161">, o Barretão</segment>
    <segment id="162">, um dos principais do país</segment>
    <segment id="163">, com certeza transmitiu a dedicação ao cinema aos filhos Bruno e Fábio</segment>
    <segment id="164">, que morreu em 2019.</segment>
    <segment id="165">Diretores</segment>
    <segment id="166">, eles tiveram muitos de seus longas produzidos pelo pai.</segment>
    <segment id="167">Entre eles estão “Dona Flor e Seus Dois Maridos” (1976) e “</segment>
    <segment id="168">O Que é Isso</segment>
    <segment id="169">, Companheiro?</segment>
    <segment id="170">” (1997)</segment>
    <segment id="171">, indicado ao Oscar de melhor filme estrangeiro</segment>
    <segment id="172">, ambos dirigidos por Bruno.</segment>
    <segment id="173">De Fábio</segment>
    <segment id="174">, Barretão produziu “</segment>
    <segment id="175">O Quatrilho” (1995)</segment>
    <segment id="176">, que também teve uma indicação ao Oscar</segment>
    <segment id="177">, e “</segment>
    <segment id="178">O Rei do Rio” (1985)</segment>
    <segment id="179">, por exemplo.</segment>
    <segment id="180">A última colaboração entre pai e filhos</segment>
    <segment id="181">, no caso</segment>
    <segment id="182">caso Fábio</segment>
    <segment id="183">, aconteceu em 2003</segment>
    <segment id="184">, na produção do filme “</segment>
    <segment id="185">A Paixão de Jacobina”.</segment>
    <segment id="186">ONDE VER  DONA</segment>
    <segment id="187">FLOR E SEUS DOIS</segment>
    <segment id="188">MARIDOS (1976)</segment>
    <segment id="189">Looke, Mubi e Globoplay: grátis para assinantes.</segment>
    <segment id="190">NOW: R$ 6</segment>
    <segment id="191">,90 (aluguel)</segment>
    <segment id="192">O QUATRILHO (1995) Looke e Globoplay: grátis para assinantes.</segment>
    <segment id="193">NOW: grátis para assinantes do Looke</segment>
    <segment id="194">O QUE É ISSO COMPANHEIRO (1997)</segment>
    <segment id="195">Looke e Globoplay: grátis para assinantes.</segment>
    <segment id="196">NOW: R$ 6</segment>
    <segment id="197">,90 (aluguel)</segment>
    <segment id="198">Os atores Louis Garrel e Clémentine Poidatz em cena do filme &amp;quot</segment>
    <segment id="199">;A Fronteira da Alvorada&amp;quot</segment>
    <segment id="200">;,de Philippe Garrel - DivulgaçãoPHILIPPE</segment>
    <segment id="201">, ESTHER E LOUIS GARREL</segment>
    <segment id="202">A família</segment>
    <segment id="203">Garrel faz parte do cinema francês.</segment>
    <segment id="204">Primeiro</segment>
    <segment id="205">, com o ator Maurice Garrel</segment>
    <segment id="206">, morto em 2011.</segment>
    <segment id="207">Depois com Phillipe</segment>
    <segment id="208">, seu filho</segment>
    <segment id="209">, diretor e roteirista de cinema.</segment>
    <segment id="210">E, por fim</segment>
    <segment id="211">, com os filhos de Philippe: os atores Esther e Louis</segment>
    <segment id="212">, que despontou em “</segment>
    <segment id="213">Os Sonhadores”</segment>
    <segment id="214">, de Bernardo Bertolucci (2003).</segment>
    <segment id="215">Avô e netos atuaram</segment>
    <segment id="216">, juntos ou não</segment>
    <segment id="217">, em filmes de Philippe</segment>
    <segment id="218">, como</segment>
    <segment id="219">como “Um Verão Escaldante” (2011)</segment>
    <segment id="220">, “Ciúme” (2013) e “Amantes Constantes”(2005).</segment>
    <segment id="221">A parceria mais frequente acontece entre Philippe e Louis.</segment>
    <segment id="222">Juntos</segment>
    <segment id="223">, eles já realizaram seis longas.</segment>
    <segment id="224">O filho</segment>
    <segment id="225">, por sinal</segment>
    <segment id="226">, já segue os passos de Philippe atrás das câmeras.</segment>
    <segment id="227">Além de atuar</segment>
    <segment id="228">, esteve na direção de seis longas.</segment>
    <segment id="229">ONDE VER  UM VERÃO ESCALDANTE (2011)</segment>
    <segment id="230">Globoplay: grátis para assinantes</segment>
    <segment id="231">O CIÚME (2013) Belas</segment>
    <segment id="232">Artes à La Carte: grátis a assinantes</segment>
  </rst>
</analysis>