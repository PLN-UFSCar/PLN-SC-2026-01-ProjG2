  <rst>
    <segment id="1">Cinco dias depois de a OMS (Organização Mundial da Saúde) ter declarado que existe uma pandemia do novo coronavírus</segment>
    <segment id="2">, o presidente Jair Bolsonaro (sem partido) criou</segment>
    <segment id="3">, nesta segunda-feira (16)</segment>
    <segment id="4">, um comitê de crise para coordenar e monitorar o combate à doença no Brasil.</segment>
    <segment id="5">O decreto com a instituição do comitê foi publicado em edição extra do Diário Oficial da União.</segment>
    <segment id="6">De acordo com o decreto</segment>
    <segment id="7">, o comitê de crise visa a "articulação da ação governamental e de assessoramento ao presidente da República".</segment>
    <segment id="8">Ele será coordenado pelo ministro Walter Braga Netto (Casa Civil).</segment>
    <segment id="9">O coronavírus no Brasil    novamente         de   de  de  representando um    Também farão parte do órgão os seguintes ministérios: Justiça</segment>
    <segment id="10">, Defesa</segment>
    <segment id="11">, Relações Exteriores</segment>
    <segment id="12">, Economia</segment>
    <segment id="13">, Infraestrutura</segment>
    <segment id="14">, Educação</segment>
    <segment id="15">, Cidadania</segment>
    <segment id="16">, Saúde</segment>
    <segment id="17">, Ciência e Tecnologia</segment>
    <segment id="18">, CGU (Controladoria-Geral da União)</segment>
    <segment id="19">, Mulher</segment>
    <segment id="20">, da Família e dos Direitos Humanos</segment>
    <segment id="21">, Secretaria-Geral</segment>
    <segment id="22">, Secretaria de Governo</segment>
    <segment id="23">, Segurança Institucional e Advocacia-Geral da União.</segment>
    <segment id="24">Os presidentes do Banco Central</segment>
    <segment id="25">, do Banco do Brasil</segment>
    <segment id="26">, da Caixa e do BNDES também vão compor o comitê</segment>
    <segment id="27">, assim</segment>
    <segment id="28">comocomo o chefe da Anvisa (Agência Nacional de Vigilância Sanitária) e o coordenador do Centro de Operação Emergenciais em Saúde Pública da Secretaria de Vigilância em Saúde do Ministério da Saúde.</segment>
    <segment id="29">As reuniões ocorrerão de acordo com convocação de Braga Netto.</segment>
    <segment id="30">A OMS classificou o coronavírus</segment>
    <segment id="31">comocomo pandemia no dia 11 de março.</segment>
    <segment id="32">Globalmente</segment>
    <segment id="33">, há 167.511 casos confirmados do novo vírus</segment>
    <segment id="34">, segundo a organização.</segment>
    <segment id="35">No Brasil há 234 casos confirmados e 2.064 suspeitos.</segment>
    <segment id="36">O presidente Bolsonaro minimizou em diversas declarações a pandemia.</segment>
    <segment id="37">Ele também foi criticado por governadores e parlamentares por ter estimulado e participado de manifestações pró-governo que ocorreram no domingo (15).</segment>
    <segment id="38">A presença de Bolsonaro nos protestos contrariou recomendação de seu próprio ministro da Saúde</segment>
    <segment id="39">, Luiz Henrique Mandetta</segment>
    <segment id="40">, que alertou para o maior risco de contaminação pelo vírus em ambientes com aglomerações.</segment>
    <segment id="41">Tudo sobre a covid-19Cura de coronavírus é</segment>
    <segment id="42">comocomo a de uma gripe em casos simples</segment>
    <segment id="43">;</segment>
    <segment id="44">entendaNovo coronavírus pode ser transmitido pelo sexo?Quais são os sintomas do novo coronavírus?Saiba</segment>
    <segment id="45">comocomo</segment>
    <segment id="46">sese proteger contra o coronavírus e o que fazer em</segment>
    <segment id="47">casocaso de suspeitaComo falar sobre o coronavírus com crianças e adolescentesNovo coronavírus pode não ser tão letal</segment>
    <segment id="48">masmas</segment>
