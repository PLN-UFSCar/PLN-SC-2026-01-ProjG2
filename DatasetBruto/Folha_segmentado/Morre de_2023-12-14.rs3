  <rst>
    <segment id="1">O deputado da Turquia Hasan Bitmez morreu na manhã desta quinta-feira (14)</segment>
    <segment id="2">, dois dias após desmaiar em meio a uma sessão no Parlamento no momento em que criticava as ações do governo de Recep Tayyip Erdogan no que diz respeito à guerra Israel-Hamas.</segment>
    <segment id="3">"</segment>
    <segment id="4">Que Deus tenha piedade do nosso deputado.</segment>
    <segment id="5">Presto minhas condolências à sua família e a todos os seus entes queridos.</segment>
    <segment id="6">(...)</segment>
    <segment id="7">Descanse em paz"</segment>
    <segment id="8">, afirmou o ministro da Saúde turco</segment>
    <segment id="9">, Fahrettin Koca</segment>
    <segment id="10">, ao informar sobre a sua morte.</segment>
    <segment id="11">O deputado turcio Hasan Bitmez discursa pouco antes de desmaiar - Adem Altan - 12.dez.2023/AFPBitmez estava internado no Hospital da Cidade de Ancara em estado grave após sofrer um ataque cardíaco na tribuna e ser socorrido por outros parlamentares.</segment>
    <segment id="12">Ao desmaiar</segment>
    <segment id="13">, o político de 54 anos bateu a cabeça no chão</segment>
    <segment id="14">, e um dos presentes na sala começou a fazer massagem cardíaca nele no local.</segment>
    <segment id="15">No discurso de terça</segment>
    <segment id="16">, o parlamentar criticava a manutenção das relações comerciais da Turquia com Israel</segment>
    <segment id="17">, apesar das críticas do partido governista</segment>
    <segment id="18">, o AKP</segment>
    <segment id="19">, aos ataques em Gaza.</segment>
    <segment id="20">"</segment>
    <segment id="21">Vocês permitem que navios</segment>
    <segment id="22">sese dirijam a Israel e descaradamente chamam isso de comércio.</segment>
    <segment id="23">Vocês são cúmplices de Israel"</segment>
    <segment id="24">, disse Bitmez atrás de um cartaz em que</segment>
    <segment id="25">sese lia: "</segment>
    <segment id="26">Israel assassino</segment>
    <segment id="27">; colaborador do AKP".</segment>
    <segment id="28">"</segment>
    <segment id="29">Mesmo que a história</segment>
    <segment id="30">sese cale</segment>
    <segment id="31">, a verdade não ficará em silêncio"</segment>
    <segment id="32">, dizia ele antes de desmaiar.</segment>
    <segment id="33">"</segment>
    <segment id="34">Eles [Israel] pensam que</segment>
    <segment id="35">, caso</segment>
    <segment id="36">caso se</segment>
    <segment id="37">se livrem de nós</segment>
    <segment id="38">, o problema estará resolvido.</segment>
    <segment id="39">Mesmo que</segment>
    <segment id="40">sese livrem de nós</segment>
    <segment id="41">, não se</segment>
    <segment id="42">se livrarão da culpa.</segment>
    <segment id="43">Se sese livrarem do castigo da história</segment>
    <segment id="44">, não se</segment>
    <segment id="45">se livrarão do castigo de Alá.</segment>
    <segment id="46">"</segment>
    <segment id="47">O deputado foi socorrido em uma ambulância</segment>
    <segment id="48">, e, horas depois</segment>
    <segment id="49">, o Ministério da Saúde da Turquia informou</segment>
    <segment id="50">, em nota</segment>
    <segment id="51">, que seu estado de saúde era extremamente grave.</segment>
    <segment id="52">Na ocasião</segment>
    <segment id="53">, a pasta detalhou que um exame de angiografia foi realizado e constatou que duas artérias estavam completamente bloqueadas.</segment>
    <segment id="54">Bitmez então ficou conectado a um respirador pulmonar.</segment>
    <segment id="55">De acordo com a emissora britânica BBC</segment>
    <segment id="56">, Bitmez era diabético e tinha dois stents cardíacos.</segment>
    <segment id="57">Guerra transforma Gaza em cemitério para criançasMais    novamente         de   de  de  representando um  Formado pela Universidade de Al-Azhar</segment>
    <segment id="58">, na capital do Egito</segment>
    <segment id="59">, Bitmez era presidente do Centro de Pesquisa da União Islâmica e havia trabalhado anteriormente em organizações não governamentais islâmicas</segment>
    <segment id="60">, segundo sua biografia parlamentar.</segment>
    <segment id="61">Ele deixa a mulher e um filho.</segment>
    <segment id="62">O Felicity</segment>
    <segment id="63">, partido do deputado</segment>
    <segment id="64">, com frequência critica a atuação do governista AKP pelo que descreve</segment>
    <segment id="65">comocomo uma posição "moderada" frente aos acontecimentos que</segment>
    <segment id="66">sese desenrolam em Gaza.</segment>
    <segment id="67">O deputado</segment>
    <segment id="68">, por exemplo</segment>
    <segment id="69">, criticou Erdogan em seu discurso</segment>
    <segment id="70">, dizendo que o líder era "diretamente responsável por cada bomba de Israel lançada sobre Gaza".</segment>
    <segment id="71">Em falas públicas</segment>
    <segment id="72">, o presidente turco tem criticado o governo de Binyamin Netanyahu.</segment>
    <segment id="73">Mais recentemente</segment>
    <segment id="74">, afirmou em um grande ato em defesa dos palestinos que Israel era um "peão do Ocidente".</segment>
    <segment id="75">Nas eleições de maio</segment>
    <segment id="76">, a pequena sigla a qual Bitmez pertencia</segment>
    <segment id="77">sese juntou ao principal bloco de oposição para apoiar o candidato que fazia frente a Erdogan</segment>
    <segment id="78">, Kemal Kilicdaroglu.</segment>
    <segment id="79">O acordo da aliança não garantiu a vitória</segment>
    <segment id="80">, masmas permitiu que deputados do Felicity</segment>
    <segment id="81">, como</segment>
    <segment id="82">como Bitmez</segment>
    <segment id="83">, ganhassem assentos no parlamento.</segment>
  </rst>
</analysis>