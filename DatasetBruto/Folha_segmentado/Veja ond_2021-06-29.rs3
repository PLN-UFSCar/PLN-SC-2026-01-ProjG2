  <rst>
    <segment id="1">As quartas de final da Copa América começam nesta sexta-feira (2)</segment>
    <segment id="2">, já com a seleção brasileira em campo.</segment>
    <segment id="3">O time de Tite</segment>
    <segment id="4">, que avançou em primeiro lugar do Grupo B</segment>
    <segment id="5">, encara o Chile (4º do Grupo A) no Rio de Janeiro</segment>
    <segment id="6">, às 21h (horário de Brasília).</segment>
    <segment id="7">A partida será transmitida pelo SBT</segment>
    <segment id="8">, na TV aberta</segment>
    <segment id="9">, e pela ESPN Brasil</segment>
    <segment id="10">, na TV fechada.</segment>
    <segment id="11">Mais cedo</segment>
    <segment id="12">, às 18h</segment>
    <segment id="13">, em Goiânia</segment>
    <segment id="14">,</segment>
    <segment id="15">o Peru (classificado em 2º da chave brasileira) enfrenta o Paraguai (3º do outro agrupamento).</segment>
    <segment id="16">Neymar antes de partida contra o Peru</segment>
    <segment id="17">, pela Copa América - Rahel Patrasso - 18.jun.2021/XinhuaÀs 18h do sábado (3)</segment>
    <segment id="18">, Uruguai e Colômbia –respectivamente vice-líder do Grupo A e terceiro do Grupo B–</segment>
    <segment id="19">sese enfrentam em Brasília.</segment>
    <segment id="20">Depois</segment>
    <segment id="21">, a Argentina</segment>
    <segment id="22">, que terminou a primeira fase</segment>
    <segment id="23">comocomo líder da chave A</segment>
    <segment id="24">, encara o Equador (4º da B) em Goiânia</segment>
    <segment id="25">, às 22h.</segment>
    <segment id="26">Nas semifinais</segment>
    <segment id="27">, os vencedores dos jogos de sexta</segment>
    <segment id="28">sese enfrentam no próximo dia 5</segment>
    <segment id="29">, e quem triunfar no sábado</segment>
    <segment id="30">, joga dia 6.</segment>
    <segment id="31">A final está marcada para o dia 10</segment>
    <segment id="32">, no Maracanã.</segment>
    <segment id="33">Onde assistir aos confrontos das quartas de final  Sexta (2)   18h:</segment>
    <segment id="34">Peru x Paraguai</segment>
    <segment id="35">, FOX Sports 21h: Brasil x Chile</segment>
    <segment id="36">, SBT e ESPN Brasil   Sábado (3)   19h: Uruguai x Colômbia</segment>
    <segment id="37">, FOX Sports 22h: Argentina x Equador</segment>
    <segment id="38">, SBT e ESPN Brasil</segment>
  </rst>
