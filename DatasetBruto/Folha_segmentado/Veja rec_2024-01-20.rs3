  <rst>
    <segment id="1">Sorvete gelado</segment>
    <segment id="2">, calda quente de chocolate</segment>
    <segment id="3">, amendoim e manteiga de amendoim mais chantili cremoso tornam esta receita de sundae deliciosa o suficiente para uma ocasião especial —</segment>
    <segment id="4">masmas fácil o bastante para fazer durante a semana.</segment>
    <segment id="5">Para conseguir uma calda de chocolate mais interessante</segment>
    <segment id="6">, use chocolate amargo com cerca de 70% de cacau e manteiga de amendoim cremosa com adição de sal.</segment>
    <segment id="7">Você pode preparar a calda alguns dias antes para facilitar ainda mais.</segment>
    <segment id="8">Para servir</segment>
    <segment id="9">, cubra seu sorvete favorito com a calda quente</segment>
    <segment id="10">, chantili</segment>
    <segment id="11">, amendoins picados com sal e cerejas ao maraschino.</segment>
    <segment id="12">Se quiser torná-la ainda mais especial</segment>
    <segment id="13">, pode transformá-la em uma banana split ou adicionar alguns biscoitos crocantes.</segment>
    <segment id="14">Veja abaixo o passo a passo:  Sundaes com calda quente de manteiga de amendoim em Nova York.</segment>
    <segment id="15">A calda quente de manteiga de amendoim pode ser feita com alguns dias de antecedência e aquecida no micro-ondas antes de servir.</segment>
    <segment id="16">Comida estilizada por Yossy Arefi.- Mark Weinberg/The New York Times  Sundae com calda de manteiga de amendoim</segment>
    <segment id="17">Rendimento:</segment>
    <segment id="18">Cerca de duas xícaras de calda de chocolate quente (suficiente para oito porções)</segment>
    <segment id="19">Tempo total: 10 minutos</segment>
    <segment id="20">Ingredientes  ⅔ de xícara de chá (133 g) de açúcar mascavo claro</segment>
    <segment id="21">¼ de xícara de chá(20 g) de cacau em pó de processo holandês  ¼ de colher de chá de sal fino  1 ½ xícaras de chá (360 ml) de creme de leite  ⅓ de xícara de chá (50 g) de chocolate amargo picado (não em gotas</segment>
    <segment id="22">; veja a dica)  ½ xícara de chá(135 g) de manteiga de amendoim cremosa (não natural)</segment>
    <segment id="23">Seu sorvete favorito de baunilha ou chocolate</segment>
    <segment id="24">, ou ambos</segment>
    <segment id="25">, para servir  Chantili</segment>
    <segment id="26">, amendoins picados com sal e cerejas ao maraschino</segment>
    <segment id="27">, para servir  Modo de preparo</segment>
    <segment id="28">Em uma panela média</segment>
    <segment id="29">, misture o açúcar mascavo</segment>
    <segment id="30">, o cacau em pó e o sal até que não haja grumos.</segment>
    <segment id="31">Devagar</segment>
    <segment id="32">, despeje o creme de leite enquanto mexe constantemente.</segment>
    <segment id="33">Leve para ferver em fogo médio</segment>
    <segment id="34">, mexendo quando necessário</segment>
    <segment id="35">, até que a mistura comece a ferver e o açúcar esteja derretido (cerca de 3 minutos).</segment>
    <segment id="36">Retire do fogo e misture o chocolate picado até ficar homogêneo.</segment>
    <segment id="37">Adicione a manteiga de amendoim e mexa até ficar cremoso.</segment>
    <segment id="38">Deixe esfriar um pouco antes de colocar no topo do seu sundae.</segment>
    <segment id="39">A calda de chocolate com sabor de amendoim pode ser armazenada na geladeira por até uma semana em um recipiente hermético.</segment>
    <segment id="40">Para servir</segment>
    <segment id="41">, reaqueça suavemente no micro-ondas ou em uma panela em fogo baixo.</segment>
    <segment id="42">Quando estiver pronto para montar a sobremesa</segment>
    <segment id="43">, coloque um pouco da calda no fundo de uma tigela ou copo.</segment>
    <segment id="44">Então, cubra com sorvete</segment>
    <segment id="45">, mais calda quente</segment>
    <segment id="46">, chantili</segment>
    <segment id="47">, amendoins picados e uma cereja.</segment>
    <segment id="48">Dica: Opte por chocolate em barra picado em vez de gotas para esta receita</segment>
    <segment id="49">, pois</segment>
    <segment id="50">pois as gotas contêm estabilizadores que podem deixar a calda granulada.</segment>
  </rst>
</analysis>