  <rst>
    <segment id="1">Esta é a edição da newsletter Folha</segment>
    <segment id="2">Carreiras desta segunda-feira (20).</segment>
    <segment id="3">Quer recebê-la às segundas-feiras no seu email?</segment>
    <segment id="4">Inscreva-</segment>
    <segment id="5">sese abaixo.</segment>
    <segment id="6">Folha CarreirasReceba no seu email conteúdo para profissionais em início de carreira</segment>
    <segment id="7">, dicas e indicações de estágio e traineeCarregando...</segment>
    <segment id="8">Para quem passa o dia fora</segment>
    <segment id="9">, ter uma alimentação equilibrada pode ser um verdadeiro desafio.</segment>
    <segment id="10">Afinal</segment>
    <segment id="11">, é muito mais fácil comprar uma coxinha na padaria do que preparar um sanduíche natural na noite anterior</segment>
    <segment id="12">, não é?</segment>
    <segment id="13">Comer bem dá disposição e energia para enfrentar um dia cheio</segment>
    <segment id="14">, diz especialista</segment>
    <segment id="15">-Foto:Space_Cat/adobe stockMas a correria da rotina não pode impedir você de ter uma alimentação nutritiva</segment>
    <segment id="16">, gostosa e que cabe no seu bolso.</segment>
    <segment id="17">"</segment>
    <segment id="18">Além de ser uma questão de saúde</segment>
    <segment id="19">, comer bem te dá disposição e energia para enfrentar o dia"</segment>
    <segment id="20">, afirma Daniela Cierro</segment>
    <segment id="21">, nutricionista e vice-presidente da ASBRAN (Associação Brasileira de Nutrição).</segment>
    <segment id="22">Pensando nisso</segment>
    <segment id="23">, reuni dicas de especialistas em nutrição para quem precisa de ajuda para</segment>
    <segment id="24">sese alimentar melhor.</segment>
    <segment id="25">Dá uma olhada no</segment>
    <segment id="26">casocaso a</segment>
    <segment id="27">casocaso aqui embaixo.</segment>
    <segment id="28">O que fazer</segment>
    <segment id="29">sese…  … o seu problema é não ter tempo para preparar refeições</segment>
    <segment id="30">Se falta espaço na sua agenda durante a semana</segment>
    <segment id="31">, ou se</segment>
    <segment id="32">se, ao chegar em casa</segment>
    <segment id="33">, a última coisa que você quer fazer é cozinhar</segment>
    <segment id="34">, o congelador vai ser seu novo melhor amigo.</segment>
    <segment id="35">A dica de Alisson Machado</segment>
    <segment id="36">, nutricionista e professor da USP (Universidade de São Paulo)</segment>
    <segment id="37">, é dedicar algumas horas do final de semana para cozinhar tudo o que você vai comer nos dias seguintes.</segment>
    <segment id="38">Para isso:</segment>
    <segment id="39">Varie o preparo.</segment>
    <segment id="40">Se você não quer comer o mesmo arroz todo dia</segment>
    <segment id="41">, experimente adicionar legumes e temperos a algumas porções.</segment>
    <segment id="42">Otimize o tempo.</segment>
    <segment id="43">"</segment>
    <segment id="44">Enquanto você faz o arroz</segment>
    <segment id="45">, coloque proteínas e legumes no forno.</segment>
    <segment id="46">Nas outras bocas do fogão</segment>
    <segment id="47">, cozinhe feijão</segment>
    <segment id="48">, macarrão…</segment>
    <segment id="49">",</segment>
    <segment id="50">indica ele.</segment>
    <segment id="51">Sabe aqueles vidros de conserva que você lavou e nunca mais usou?</segment>
    <segment id="52">Guarde saladas.</segment>
    <segment id="53">Coloque molhos diferentes em cada porção para não enjoar e varie as combinações.</segment>
    <segment id="54">Se separar um tempo no final de semana for inviável para você</segment>
    <segment id="55">, existem outras opções.</segment>
    <segment id="56">Conte com uma rede de apoio.</segment>
    <segment id="57">Pode ser um vizinho</segment>
    <segment id="58">, um familiar</segment>
    <segment id="59">, um amigo que goste de cozinhar para a galera.</segment>
    <segment id="60">Se ofereça para ajudar com os custos dos alimentos e guarde sobras no congelador.</segment>
    <segment id="61">Compre kits de marmitas prontas.</segment>
    <segment id="62">"</segment>
    <segment id="63">Existem empresas que prestam esse tipo de serviço</segment>
    <segment id="64">, e alguns inclusive aceitam vale-refeição"</segment>
    <segment id="65">, afirma Machado.</segment>
    <segment id="66">… você sai de casa de manhã e volta só à noite</segment>
    <segment id="67">Essa é a rotina de muitos jovens que vão do escritório para a faculdade</segment>
    <segment id="68">, e vice-versa.</segment>
    <segment id="69">Cierro dá a letra: "</segment>
    <segment id="70">Leve refeições congeladas em uma bolsa térmica e adicione lanches que vão durar fora da geladeira.</segment>
    <segment id="71">"</segment>
    <segment id="72">Sugestões de lanches saudáveis e duráveis: mix de nozes</segment>
    <segment id="73">, castanhas e frutas secas (é mais barato</segment>
    <segment id="74">sese comprar a granel)</segment>
    <segment id="75">, sanduíches naturais e frutas não picadas.</segment>
    <segment id="76">Se for optar por industrializados</segment>
    <segment id="77">, leia os rótulos.</segment>
    <segment id="78">"</segment>
    <segment id="79">O primeiro ingrediente que aparece é sempre o que tem em maior quantidade"</segment>
    <segment id="80">, diz Cierro.</segment>
    <segment id="81">Isso vale especialmente para barrinhas de cereal e outras opções fit.</segment>
    <segment id="82">Olhe a descrição para não cair no conto do vigário.</segment>
    <segment id="83">Deixe também alguns snacks não-perecíveis na sua gaveta de trabalho para sempre ter um lanchinho por perto e não pesar na mochila.</segment>
    <segment id="84">Veja onde comer sanduíches em SPMais    novamente         de   de  de  representando um   …</segment>
    <segment id="85">você prefere usar o Vale Refeição em vez de levar marmitas</segment>
    <segment id="86">Nesse caso</segment>
    <segment id="87">caso, prefira restaurantes self-service para ter mais controle</segment>
    <segment id="88">, variedade e liberdade com as refeições.</segment>
    <segment id="89">Cuidado com a composição do prato.</segment>
    <segment id="90">Sabe aquela vontade de tirar uma soneca depois do almoço?</segment>
    <segment id="91">Pode ser sinal de que sua refeição teve carboidratos e gorduras demais.</segment>
    <segment id="92">De acordo com Giuliana Modenezi</segment>
    <segment id="93">, nutricionista do Espaço Einstein</segment>
    <segment id="94">, do Hospital Albert Einstein</segment>
    <segment id="95">, um prato saudável precisa de carboidratos</segment>
    <segment id="96">, verduras</segment>
    <segment id="97">, legumes</segment>
    <segment id="98">, cereais</segment>
    <segment id="99">, tubérculos e proteína animal ou vegetal.</segment>
    <segment id="100">A proporção é: metade do prato para legumes e verduras</segment>
    <segment id="101">, 25% para carboidratos</segment>
    <segment id="102">, cereais e/ou tubérculos e 25% para proteínas.</segment>
    <segment id="103">… a empresa não tem copa</segment>
    <segment id="104">, geladeira ou micro-ondas   Se comer fora não é uma opção</segment>
    <segment id="105">, leve uma marmita ainda congelada em uma bolsa térmica e</segment>
    <segment id="106">, enquanto ela desgela</segment>
    <segment id="107">, procure estabelecimentos nos arredores que te deixem usar o micro-ondas.</segment>
    <segment id="108">Avalie alternativas de refeições frias</segment>
    <segment id="109">, como</segment>
    <segment id="110">como saladas caprichadas</segment>
    <segment id="111">, sanduíches completos (e saudáveis</segment>
    <segment id="112">, claro)</segment>
    <segment id="113">, wraps</segment>
    <segment id="114">, legumes recheados…</segment>
    <segment id="115">Para lanches intermediários</segment>
    <segment id="116">, opte por alimentos que não precisam de refrigeração ou aquecimento.</segment>
    <segment id="117">Anote aí  Dicas e recomendações de especialistas consultados para o Tema da Semana   - Divulgação</segment>
    <segment id="118">O que evitar na marmita e</segment>
    <segment id="119">comocomo embalar os alimentos  Evite levar:</segment>
    <segment id="120">Ovos, creme de leite</segment>
    <segment id="121">, maionese</segment>
    <segment id="122">, iogurte</segment>
    <segment id="123">, carnes mal passadas e peixes.</segment>
    <segment id="124">São alimentos que azedam rápido e</segment>
    <segment id="125">, além de estragar sua refeição</segment>
    <segment id="126">, podem te dar intoxicação alimentar.</segment>
    <segment id="127">Macarrão junto com molho.</segment>
    <segment id="128">A massa absorve o molho e</segment>
    <segment id="129">, até você comer</segment>
    <segment id="130">, o macarrão ficou quebradiço e seco.</segment>
    <segment id="131">Leve em potes separados e misture na hora.</segment>
    <segment id="132">Frituras.</segment>
    <segment id="133">Elas murcham e ficam borrachudas</segment>
    <segment id="134">, que nem batata frita no delivery.</segment>
    <segment id="135">Para armazenar no congelador:    Escolha bem os recipientes.</segment>
    <segment id="136">Embalagens de vidro e plástico polipropileno são as mais adequadas para micro-ondas.</segment>
    <segment id="137">Coloque etiquetas.</segment>
    <segment id="138">Escreva do que é a marmita e a data de quando você congelou para</segment>
    <segment id="139">sese organizar melhor.</segment>
    <segment id="140">Porções para uma pessoa.</segment>
    <segment id="141">Elas facilitam na hora de descongelar (e evitam confundir sorvete com feijão).</segment>
    <segment id="142">Para transportar na bolsa:   Potes com fechamento nas quatro laterais e borracha de vedação.</segment>
    <segment id="143">Eles tornam vazamentos muito menos prováveis.</segment>
    <segment id="144">Não coloque na mochila.</segment>
    <segment id="145">Se não tiver uma térmica</segment>
    <segment id="146">, opte por pequenas bolsas.</segment>
    <segment id="147">Imagina descobrir que o molho bolonhesa do macarrão vazou em todos os seus pertences?</segment>
  </rst>
</analysis>