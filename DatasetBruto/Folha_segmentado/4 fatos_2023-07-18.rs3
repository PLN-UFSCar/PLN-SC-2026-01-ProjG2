  <rst>
    <segment id="1">O mundo sofre cada vez mais com os efeitos das ondas de calor extremo —algo que já era alertado por cientistas há alguns anos.</segment>
    <segment id="2">Especialistas dizem que os recordes de temperatura quebrados nas últimas semanas durante o verão no Hemisfério Norte</segment>
    <segment id="3">, embora</segment>
    <segment id="4">embora tenham sido projetados</segment>
    <segment id="5">, chegam mais rápido do que o esperado</segment>
    <segment id="6">, e mantêm os governos da região em alerta.</segment>
    <segment id="7">"</segment>
    <segment id="8">Estamos entrando em um terreno desconhecido"</segment>
    <segment id="9">, divulgou na semana passada a Organização Meteorológica Internacional</segment>
    <segment id="10">, dias após as observações das maiores temperaturas da história</segment>
    <segment id="11">, no mês de junho mais quente desde que os registros foram iniciados.</segment>
    <segment id="12">Calor na Itália pode quebrar recordes continentais</segment>
    <segment id="13">, segundo especialistas   - Getty ImagesSegundo Hannah Cloke</segment>
    <segment id="14">, pesquisadora de mudanças climáticas da Universidade de Reading</segment>
    <segment id="15">, no Reino Unido</segment>
    <segment id="16">, o cenário "é muito assustador".</segment>
    <segment id="17">Segundo ela</segment>
    <segment id="18">, o calor extremo não dá trégua no Hemisfério Norte e pode ter consequências fatais</segment>
    <segment id="19">sese a população não tomar as devidas medidas de proteção.</segment>
    <segment id="20">Só na Europa</segment>
    <segment id="21">, cerca de 61 mil pessoas morreram com a onda de calor que ocorreu no ano passado</segment>
    <segment id="22">, disse a especialista em entrevista à BBC.</segment>
    <segment id="23">Atualmente</segment>
    <segment id="24">, existem alertas de calor em toda a Europa</segment>
    <segment id="25">, Ásia e Estados Unidos para dezenas de milhões de pessoas.</segment>
    <segment id="26">A situação atual</segment>
    <segment id="27">, observa Cloke</segment>
    <segment id="28">, parece estar "saindo do controle".</segment>
    <segment id="29">As ondas de calor</segment>
    <segment id="30">, atribuídas às mudanças climáticas e ao ao fenômeno El Niño</segment>
    <segment id="31">, que se</segment>
    <segment id="32">se desenvolve no Pacífico</segment>
    <segment id="33">, provavelmente continuarão a piorar.</segment>
    <segment id="34">Nesta reportagem</segment>
    <segment id="35">, você confere quatro fatos extremos relacionados às ondas de calor que atingem boa parte do planeta atualmente.</segment>
    <segment id="36">Uma região da China que lutava contra o frio extremo agora enfrenta uma onda de calor    - Getty Images1.</segment>
    <segment id="37">China registra temperatura mais alta</segment>
    <segment id="38">Apenas alguns meses atrás</segment>
    <segment id="39">, várias regiões no norte da China estavam lutando contra o frio extremo</segment>
    <segment id="40">, com temperaturas abaixo de -50 °C.</segment>
    <segment id="41">No domingo (16/7)</segment>
    <segment id="42">, o quadro foi totalmente diferente.</segment>
    <segment id="43">Em Xinjiang</segment>
    <segment id="44">, no remoto e árido nordeste do gigante asiático</segment>
    <segment id="45">, foram registradas temperaturas de 52 °C</segment>
    <segment id="46">, que, segundo a mídia estatal</segment>
    <segment id="47">, é a temperatura mais alta já registrada no local.</segment>
    <segment id="48">Espera-</segment>
    <segment id="49">sese que o calor extremo</segment>
    <segment id="50">sese estenda por pelo menos mais cinco dias nesta região.</segment>
    <segment id="51">O recorde anterior na China</segment>
    <segment id="52">, de 2015</segment>
    <segment id="53">, era de 50</segment>
    <segment id="54">,3 °C.  2.</segment>
    <segment id="55">O escaldante sul dos EUA</segment>
    <segment id="56">Quase um quarto da população dos Estados Unidos está sob alerta de calor extremo.</segment>
    <segment id="57">Em El Paso</segment>
    <segment id="58">, no Texas</segment>
    <segment id="59">, as temperaturas ficaram acima de 38 °C por 32 dias consecutivos</segment>
    <segment id="60">, superando o recorde anterior</segment>
    <segment id="61">, de 26 dias.</segment>
    <segment id="62">Além disso</segment>
    <segment id="63">, os cientistas estão preocupados que as temperaturas no Arizona nem cheguem a cair durante a noite.</segment>
    <segment id="64">No Estado</segment>
    <segment id="65">, a previsão é que o termômetro não fique abaixo de 32 °C quando o sol</segment>
    <segment id="66">sese põe.</segment>
    <segment id="67">A temperatura média de julho do último século no Arizona à noite foi de 18</segment>
    <segment id="68">,5 °C.</segment>
    <segment id="69">No Vale da Morte</segment>
    <segment id="70">, na Califórnia</segment>
    <segment id="71">, o recorde de calor já registrado na Terra pode ser quebrado.</segment>
    <segment id="72">No domingo (16/7)</segment>
    <segment id="73">, a temperatura no local atingiu 53 °C.</segment>
    <segment id="74">Isso gerou um enorme fluxo de turistas ao local</segment>
    <segment id="75">, que esperavam a quebra da marca de 56 °C</segment>
    <segment id="76">, registrada em 1913.</segment>
    <segment id="77">O Serviço Nacional de Meteorologia dos EUA também está prevendo surtos de "clima instável" no início desta semana</segment>
    <segment id="78">, incluindo chuvas excessivas que podem levar a inundações repentinas em partes do sul da Louisiana e do Arizona</segment>
    <segment id="79">, no vale de Ohio e em estados do nordeste americano.  3.</segment>
    <segment id="80">Calor na Itália pode quebrar recordes continentais  Espanha</segment>
    <segment id="81">, Itália e Grécia sofrem com temperaturas extremas há vários dias.</segment>
    <segment id="82">Mas nesta semana é esperada uma nova onda de calor —batizada por agências meteorológicas de Caronte</segment>
    <segment id="83">, em homenagem ao monstro da mitologia grega que era o barqueiro dos mortos no Hades.</segment>
    <segment id="84">A onda de calor</segment>
    <segment id="85">sese desloca para o país a partir do Norte de África.</segment>
    <segment id="86">Nas ilhas da Sardenha e da Sicília</segment>
    <segment id="87">, por exemplo</segment>
    <segment id="88">, são projetadas temperaturas em torno de 46 °C</segment>
    <segment id="89">, segundo as agências meteorológicas.</segment>
    <segment id="90">A temperatura mais alta registrada na Europa foi de 48</segment>
    <segment id="91">,8 °C, justamente na Sicília</segment>
    <segment id="92">, em agosto de 2021.</segment>
    <segment id="93">Prevê-</segment>
    <segment id="94">sese que a onda de calor que afeta o Mediterrâneo</segment>
    <segment id="95">sese intensifique no meio desta semana e provavelmente continue no próximo mês em partes da Europa.</segment>
    <segment id="96">O norte da África também está experimentando altas temperaturas</segment>
    <segment id="97">, com previsão de até 49 °C no Marrocos.</segment>
    <segment id="98">Calor extremo atinge países ao redor do mundoMais    novamente         de   de  de  representando um  4.</segment>
    <segment id="99">Milhares são deslocados na Grécia</segment>
    <segment id="100">Cerca de 1</segment>
    <segment id="101">,2 mil crianças foram retiradas de um acampamento de verão na cidade costeira grega de Loutraki</segment>
    <segment id="102">, na Grécia</segment>
    <segment id="103">, depois que um incêndio florestal começou devido ao tempo seco.</segment>
    <segment id="104">Enquanto isso</segment>
    <segment id="105">, a polícia prendeu um homem suspeito de iniciar outro incêndio em Kouvaras</segment>
    <segment id="106">, a sudeste de Atenas.</segment>
    <segment id="107">O serviço meteorológico grego alertou que o risco de novos incêndios continua alto.</segment>
    <segment id="108">Dezenas de pessoas tiveram de abandonar as próprias casas</segment>
    <segment id="109">, assistidas pelas equipes dos serviços de emergência.</segment>
    <segment id="110">O governo grego declarou que aqueles cujas casas foram afetadas pelos incêndios podem</segment>
    <segment id="111">sese hospedar em hotéis locais.</segment>
    <segment id="112">Anna Vlachou</segment>
    <segment id="113">, dona de uma casa em Kouvaras</segment>
    <segment id="114">, disse à agência de notícias Reuters que</segment>
    <segment id="115">, embora</segment>
    <segment id="116">embora seu lar ainda não estivesse em chamas</segment>
    <segment id="117">, havia "muitas frentes" de incêndios e nenhum sinal dos bombeiros.</segment>
    <segment id="118">Os incêndios florestais foram alimentados por ventos fortes</segment>
    <segment id="119">, com centenas de bombeiros lutando para conter a propagação das chamas.</segment>
    <segment id="120">Este texto foi publicado originalmente aqui.</segment>
  </rst>
</analysis>