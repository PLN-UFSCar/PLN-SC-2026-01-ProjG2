  <rst>
    <segment id="1">O Ministério Público de São Paulo (MP-SP) abriu uma investigação nesta segunda-feira (15) para apurar um</segment>
    <segment id="2">casocaso de homofobia durante o clássico entre Corinthians e São Paulo</segment>
    <segment id="3">, pelo Campeonato Brasileiro.</segment>
    <segment id="4">O Gecradi (Grupo Especial de Combate aos Crimes Raciais e de Intolerância) conduzirá a investigação sobre o episódio.</segment>
    <segment id="5">O órgão atua na identificação</segment>
    <segment id="6">, na prevenção e na repressão de delitos de intolerância</segment>
    <segment id="7">, preconceito e discriminação contra pessoas ou grupos</segment>
    <segment id="8">, incluindo a homofobia.</segment>
    <segment id="9">O árbitro Bruno Arleu de Araújo interrompeu o clássico na Neo Química Arena devido aos cânticos preconceituosos entoados pela torcida do Corinthians.</segment>
    <segment id="10">Esse incidente no segundo tempo foi registrado na súmula do jogo</segment>
    <segment id="11">, que deve ser enviada ao STJD (Superior Tribunal de Justiça Desportiva) pela CBF.</segment>
    <segment id="12">Jogadores do São Paulo ouviram cantos homofóbicos - Carla Carniel - 14.mai.23/ReutersAntes mesmo do início do jogo</segment>
    <segment id="13">, cânticos com teor discriminatório foram entoados em momentos distintos da partida.</segment>
    <segment id="14">Aos 17 minutos do segundo tempo</segment>
    <segment id="15">, o jogo foi interrompido por esse motivo e retomado cerca de quatro minutos depois.</segment>
    <segment id="16">O caso</segment>
    <segment id="17">caso deve ser enquadrado no artigo 243-G do CBJD (Código Brasileiro de Justiça Desportiva)</segment>
    <segment id="18">, que versa sobre atos discriminatórios relacionados a preconceito em razão de origem étnica</segment>
    <segment id="19">, raça</segment>
    <segment id="20">, sexo</segment>
    <segment id="21">, cor, idade</segment>
    <segment id="22">, condição de pessoa idosa ou portadora de deficiência.</segment>
    <segment id="23">A sanção prevista para essa infração consiste na perda do número de pontos atribuídos a uma vitória no regulamento da competição</segment>
    <segment id="24">, independentemente do resultado da partida</segment>
    <segment id="25">, prova ou equivalente</segment>
    <segment id="26">, e, em</segment>
    <segment id="27">casocaso de reincidência</segment>
    <segment id="28">, na perda do dobro do número de pontos atribuídos a uma vitória no regulamento da competição.</segment>
    <segment id="29">O procurador-geral do STJD</segment>
    <segment id="30">, Ronaldo Piacente</segment>
    <segment id="31">, já disse que pretende denunciar o Corinthians.</segment>
    <segment id="32">O que escreveu o árbitro Bruno Arleu na súmula  "</segment>
    <segment id="33">Informo que aos 18 minutos do segundo tempo paralisei a partida por dois minutos devido gritos homofóbicos da torcida:</segment>
    <segment id="34">‘Vamos</segment>
    <segment id="35">, Corinthians</segment>
    <segment id="36">, dessas bichas teremos que ganhar’.</segment>
    <segment id="37">Sendo informado no som e no telão do estádio</segment>
    <segment id="38">para que</segment>
    <segment id="39">para que os gritos cessassem</segment>
    <segment id="40">, mesmo assim</segment>
    <segment id="41">, a torcida continuou gritando efusivamente</segment>
    <segment id="42">, e, após os gritos cessarem</segment>
    <segment id="43">, a partida foi reiniciada.</segment>
    <segment id="44">Fato esse comunicado ao delegado da partida e ao chefe do policiamento.</segment>
    <segment id="45">"</segment>
  </rst>
</analysis>