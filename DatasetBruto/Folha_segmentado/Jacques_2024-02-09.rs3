  <rst>
    <segment id="1">O diretor Jacques Doillon foi acusado de abuso sexual pela atriz Judith Godrèche.</segment>
    <segment id="2">O caso</segment>
    <segment id="3">caso teria ocorrido em 1987 durante uma produção.</segment>
    <segment id="4">O diretor Jacques Doillon</segment>
    <segment id="5">, à esquerda</segment>
    <segment id="6">, e a atriz Judith Godrèche - Yohan Bonnet e Lou Benoist/AFPLogo após a acusação de Godrèche</segment>
    <segment id="7">sese tornar pública</segment>
    <segment id="8">, as atrizes Anna Mouglalis e Isild le Besco também acusaram o diretor de assédio.</segment>
    <segment id="9">No caso</segment>
    <segment id="10">caso de Mouglalis</segment>
    <segment id="11">, ele teria a beijado à força</segment>
    <segment id="12">, em 2011.</segment>
    <segment id="13">Já Le Besco disse que ele prometera a ela um papel em 2001</segment>
    <segment id="14">, sob a condição de fazer sexo com ele.</segment>
    <segment id="15">Godrèche também acusa o diretor Benoît Jacquot de ter cometido o mesmo crime em 1986.</segment>
    <segment id="16">O episódio teria acontecido quando ele namorava a atriz Jane Birkin.</segment>
    <segment id="17">Os processos foram submetidos à Justiça na quinta-feira.</segment>
    <segment id="18">Jacquot negou as acusações ao jornal Le Monde.</segment>
    <segment id="19">Doillon não respondeu à imprensa.</segment>
    <segment id="20">Jane Birkin: Relembre papéis da atriz no cinemaMais    novamente         de   de  de  representando um</segment>
