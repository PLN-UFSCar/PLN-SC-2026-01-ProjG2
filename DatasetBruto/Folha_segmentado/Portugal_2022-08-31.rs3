  <rst>
    <segment id="1">Em Portugal</segment>
    <segment id="2">, apoiadores confessos e sonoros de Jair Bolsonaro e Luiz Inácio Lula da Silva</segment>
    <segment id="3">sese sentam à mesma mesa e bebem do mesmo vinho.</segment>
    <segment id="4">Entre eles</segment>
    <segment id="5">, a política não é tabu.</segment>
    <segment id="6">O país luso parece ter um surpreendente efeito apaziguador.</segment>
    <segment id="7">Os ares da "terrinha" deviam ser importados.</segment>
    <segment id="8">Com um oceano pelo meio a tensão diminui e</segment>
    <segment id="9">, entre amigos</segment>
    <segment id="10">, os brasileiros preferem não falar de política</segment>
    <segment id="11">, masmas</segment>
    <segment id="12">sese algum português mais incauto traz o assunto para cima da mesa</segment>
    <segment id="13">, mesmo que o ambiente esfrie</segment>
    <segment id="14">, ninguém perde a compostura.</segment>
    <segment id="15">Os extremos que no Brasil</segment>
    <segment id="16">sese odeiam</segment>
    <segment id="17">, em Portugal partilham lugares</segment>
    <segment id="18">, conversas</segment>
    <segment id="19">, amigos —sobretudo portugueses—</segment>
    <segment id="20">, masmas não só.</segment>
    <segment id="21">Como se</segment>
    <segment id="22">se o país luso e os lusitanos fossem um antídoto para os ódios nacionais.</segment>
    <segment id="23">Uma espécie de cápsula protetora</segment>
    <segment id="24">, confortável casulo onde vigora um permanente pacto de não agressão.</segment>
    <segment id="25">Apoiadores de Jair Bolsonaro pisam em toalha com o rosto do ex-presidente Luiz Inácio Lula da Silva em evento do candidato à reeleição em Juiz de Fora - Mauro Pimentel - 16.ago.22/AFPEssa história aconteceu em Lisboa</segment>
    <segment id="26">, num restaurante-galeria que um brasileiro elegante e com bom gosto abriu no bairro afrancesado e chique de Campo de Ourique</segment>
    <segment id="27">, masmas poderia acontecer em qualquer outro lugar.</segment>
    <segment id="28">Vale a pena contá-la</segment>
    <segment id="29">porque</segment>
    <segment id="30">porque os protagonistas são bons tipos e o Cícero</segment>
    <segment id="31">, nome de batismo do boteco homônimo do famoso pintor modernista brasileiro Cícero Dias</segment>
    <segment id="32">, compõe o quadro com qualidade.</segment>
    <segment id="33">Foi um jantar com todos os condimentos.</segment>
    <segment id="34">Vinho do bom.</segment>
    <segment id="35">Açoriano por sinal</segment>
    <segment id="36">, Terras de Lava</segment>
    <segment id="37">, feito na Ilha do Pico</segment>
    <segment id="38">, lugar da montanha mais alta de Portugal</segment>
    <segment id="39">, masmas que fica bem no meio do oceano Atlântico</segment>
    <segment id="40">, praticamente a meio caminho com o Canadá.</segment>
    <segment id="41">Lembro-me bem desse vinho</segment>
    <segment id="42">porque</segment>
    <segment id="43">porque só o havia bebido uma vez há muito tempo</segment>
    <segment id="44">, lá no arquipélago atlântico</segment>
    <segment id="45">, e estava longe de o voltar a provar —muito menos numa mesa francesa no coração de Lisboa debaixo do olhar moderno</segment>
    <segment id="46">, colorido e cintilante do mestre Cícero.</segment>
    <segment id="47">China, terra do meioReceba no seu email os grandes temas da China explicados e contextualizados</segment>
    <segment id="48">; exclusiva para assinantes.</segment>
    <segment id="49">Carregando...</segment>
    <segment id="50">É nota de rodapé</segment>
    <segment id="51">, masmas vai aqui mesmo.</segment>
    <segment id="52">É preciso dizer que o cardápio da "elegância à mesa" na capital lusa não pode mais ser dissociado da presença permanente de intelectuais</segment>
    <segment id="53">, artistas</segment>
    <segment id="54">, investidores</segment>
    <segment id="55">, jornalistas famosos e muitos outros seres humanos</segment>
    <segment id="56">, agradáveis e sofisticados</segment>
    <segment id="57">, apóstolos de uma certa elite brasileira no exterior.</segment>
    <segment id="58">Outro condimento do jantar foram os livros.</segment>
    <segment id="59">O patrão do Cícero tem uma vocação tardia</segment>
    <segment id="60">masmas imparável de patrono das artes literárias</segment>
    <segment id="61">, e foi para conversar dessa maravilhosa lista dos 200 livros que a Folha apresentou no último Dia Mundial da Língua Portuguesa (5 de maio) que os amigos</segment>
    <segment id="62">sese reuniram.</segment>
    <segment id="63">Vinho, livros.</segment>
    <segment id="64">Arte.</segment>
    <segment id="65">Pintura.</segment>
    <segment id="66">Luz e cor.</segment>
    <segment id="67">Modernismo e história.</segment>
    <segment id="68">Sorrisos e ideias</segment>
    <segment id="69">sese acompanhando em perfeita sintonia</segment>
    <segment id="70">, na pauta da amizade luso-brasileira.</segment>
    <segment id="71">Candidatos à Presidência participam de debateMais    novamente         de   de  de  representando um</segment>
    <segment id="72">Eis senão quando</segment>
    <segment id="73">, um dos convivas</segment>
    <segment id="74">, português menos treinado nas tragicomédias do luso-brasileirismo no exílio</segment>
    <segment id="75">, joga Bolsonaro no lagostim suado e Lula no atum braseado.</segment>
    <segment id="76">Logo pensei —modinha de aforismo: "</segment>
    <segment id="77">Afonso</segment>
    <segment id="78">, querido Afonso</segment>
    <segment id="79">, não vá entornar o caldo</segment>
    <segment id="80">, não perca tempo</segment>
    <segment id="81">, não perca</segment>
    <segment id="82">, fique de bico calado".</segment>
    <segment id="83">Mas era exagero meu.</segment>
    <segment id="84">Um dos convivas suspirou sorvendo um Madeira Bual muito seco e o outro nem comentou</segment>
    <segment id="85">, logo elogiando uma paçoca de amêndoa.</segment>
    <segment id="86">Distraidamente</segment>
    <segment id="87">, todos seguiram a conversa</segment>
    <segment id="88">, elogiando a lista</segment>
    <segment id="89">, a Carolina de Jesus</segment>
    <segment id="90">, o Guimarães Rosa e o Davi Kopenawa</segment>
    <segment id="91">, como</segment>
    <segment id="92">como se</segment>
    <segment id="93">se estivessem vendo o mundo...</segment>
    <segment id="94">E ele começasse em Lisboa.</segment>
  </rst>
</analysis>