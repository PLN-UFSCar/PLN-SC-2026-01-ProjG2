    <segment id="326">&amp;#039;A senhora deu positivo e deve</segment>
    <segment id="327">sese isolar imediatamente&amp;#039</segment>
    <segment id="328">;Dia 85:</segment>
    <segment id="329">&amp;#</segment>
    <segment id="330">039;A verdade é que é uma incerteza para todos&amp;#039</segment>
    <segment id="331">;Dia 86:&amp;#039</segment>
    <segment id="332">;A cultura de bar na Espanha é expressiva&amp;#039</segment>
    <segment id="333">;Dia 87: &amp;</segment>
    <segment id="334">#039;Todo cuidado é pouco e</segment>
    <segment id="335">, inclusive</segment>
    <segment id="336">, pode não ser suficiente&amp;#039</segment>
    <segment id="337">;Dia 88:</segment>
    <segment id="338">&amp;#</segment>
    <segment id="339">039;O vírus segue sendo uma ameaça&amp;#039</segment>
    <segment id="340">;Dia 89:</segment>
    <segment id="341">&amp;#</segment>
    <segment id="342">039;O fogo que nunca</segment>
    <segment id="343">sese apaga&amp;#039</segment>
    <segment id="344">;Dia 90:</segment>
    <segment id="345">&amp;#</segment>
    <segment id="346">039;Uma bolha</segment>
    <segment id="347">, uma família&amp;#039</segment>
    <segment id="348">;Dia 91:</segment>
    <segment id="349">&amp;#039;Músicos do mundinho</segment>
    <segment id="350">, uni-vos&amp;#039</segment>
    <segment id="351">;</segment>
    <segment id="352">Dia 92:</segment>
    <segment id="353">&amp;#</segment>
    <segment id="354">039;Como um clube de jazz dos anos</segment>
    <segment id="355">1930&amp;#039</segment>
    <segment id="356">;Dia 93:</segment>
    <segment id="357">&amp;#</segment>
    <segment id="358">039;Dinheiro</segment>
