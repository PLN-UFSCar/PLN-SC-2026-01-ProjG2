    <segment id="4">Superação.</segment>
    <segment id="5">Neste ano</segment>
    <segment id="6">, em março</segment>
    <segment id="7">, eu descobri um câncer no intestino.</segment>
    <segment id="8">Isso mudou a vida de toda a minha família.</segment>
