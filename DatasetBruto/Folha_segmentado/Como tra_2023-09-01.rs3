  <rst>
    <segment id="1">Fiquei fisicamente destruído na primeira vez que voltei do supermercado para casa de bicicleta</segment>
    <segment id="2">, carregando um reboque cheio de mantimentos.</segment>
    <segment id="3">A viagem de 18 km de ida e volta me deixou com as pernas mortas</segment>
    <segment id="4">, dor nas costas e uma leve suspeita de que tinha cometido um erro.</segment>
    <segment id="5">Um mês antes</segment>
    <segment id="6">, minha minivan de 23 anos quebrou pela última vez.</segment>
    <segment id="7">Em vez de substituí-la</segment>
    <segment id="8">, decidi que uma nova realidade "sem carros" promoveria um estilo de vida mais saudável.</segment>
    <segment id="9">Meus músculos doloridos questionaram a viabilidade desse plano.</segment>
    <segment id="10">Deixar o carro de lado e ir ao mercado de bicicleta pode ser uma boa maneira de</segment>
    <segment id="11">sese exercitar- Ana Galvan/</segment>
    <segment id="12">The New York Times</segment>
    <segment id="13">Agora, três anos depois</segment>
    <segment id="14">, sei que desistir do meu carro foi o primeiro passo para resolver uma luta que durava a vida toda: manter uma atividade física constante.</segment>
    <segment id="15">O que começou</segment>
    <segment id="16">comocomo uma necessidade –eu não tinha carro</segment>
    <segment id="17">, então precisava me locomover de bicicleta–</segment>
    <segment id="18">sese tornou uma estratégia: as tarefas são uma oportunidade para fazer exercícios.</segment>
    <segment id="19">Essa reformulação acabou sendo uma bonança motivacional.</segment>
    <segment id="20">Comecei a procurar novos afazeres pelo simples exercício que eles proporcionariam.</segment>
    <segment id="21">A necessidade de meias novas</segment>
    <segment id="22">sese tornou uma oportunidade de caminhar até a loja Target.</segment>
    <segment id="23">A falta de grãos de pimenta de Sichuan me estimulou a pedalar os 7 km até o mercado chinês e voltar.</segment>
    <segment id="24">Este ano</segment>
    <segment id="25">, descobri que a biblioteca pública tinha um livro sobre uma tumba antiga que eu estava pesquisando</segment>
    <segment id="26">, e meu primeiro pensamento foi: "</segment>
    <segment id="27">Excelente</segment>
    <segment id="28">, são 4.000 passos de ida e volta!</segment>
    <segment id="29">"</segment>
    <segment id="30">Faça chuva ou faça sol</segment>
    <segment id="31">, tornei-me uma máquina de realizar tarefas.</segment>
    <segment id="32">Meu humor melhorou</segment>
    <segment id="33">, minhas idas ao supermercado ficaram mais fáceis e tive que comprar um cinto novo para minha cintura cada vez menor.</segment>
    <segment id="34">Durante a maior parte da minha vida adulta</segment>
    <segment id="35">, tentei</segment>
    <segment id="36">, sem sucesso</segment>
    <segment id="37">, fazer exercícios físicos de forma consistente.</segment>
    <segment id="38">Só agora</segment>
    <segment id="39">, ao completar 60 anos</segment>
    <segment id="40">, eu senti que tinha decifrado o código.</segment>
    <segment id="41">Especialistas que estudam psicologia do exercício dizem que não foi por acaso que meu novo regime baseado em tarefas teve resultados duradouros.</segment>
    <segment id="42">Melhor ainda</segment>
    <segment id="43">, o que funcionou para mim pode funcionar para outros.</segment>
    <segment id="44">Como transformar sua caminhada em um treino completoMais    novamente         de   de  de  representando um  Encontre a motivação certa  Não sou estranho a truques motivacionais.</segment>
    <segment id="45">Depois que meu casamento acabou</segment>
    <segment id="46">, no início dos anos 2000</segment>
    <segment id="47">, disse a mim mesmo que perder peso me tornaria mais atraente.</segment>
    <segment id="48">Ouvindo o conselho do meu médico sobre o colesterol</segment>
    <segment id="49">, decidi que só poderia comer batatas fritas no jantar</segment>
    <segment id="50">sese fosse de bicicleta até o morro mais próximo.</segment>
    <segment id="51">Mas nada</segment>
    <segment id="52">sese mantinha.</segment>
    <segment id="53">Michelle Fortier</segment>
    <segment id="54">, psicóloga de atividade física da Universidade de Ottawa</segment>
    <segment id="55">, em Ontário (Canadá)</segment>
    <segment id="56">, diz que motivações externas</segment>
    <segment id="57">, como</segment>
    <segment id="58">como avisos médicos e insegurança em relação ao peso</segment>
    <segment id="59">, não resultam em mudanças duradouras de comportamento.</segment>
    <segment id="60">"</segment>
    <segment id="61">Isso pode ajudar as pessoas a começar"</segment>
    <segment id="62">, afirma Fortier</segment>
    <segment id="63">, "mas</segment>
    <segment id="64">mas não manterá sua atividade física.</segment>
    <segment id="65">Não leva a consequências positivas ou emoções positivas.</segment>
    <segment id="66">"</segment>
    <segment id="67">A motivação gerada internamente</segment>
    <segment id="68">, que é impulsionada por uma sensação de realização ou satisfação</segment>
    <segment id="69">, é muito mais poderosa</segment>
    <segment id="70">, pontua.</segment>
    <segment id="71">"</segment>
    <segment id="72">Você faz aquilo</segment>
    <segment id="73">porque</segment>
    <segment id="74">porque é divertido"</segment>
    <segment id="75">, diz, "e a pesquisa mostra que esse tipo de motivação é bom" para a manutenção do exercício.</segment>
    <segment id="76">Minha mudança de comportamento</segment>
    <segment id="77">, indica Fortier</segment>
    <segment id="78">, provavelmente foi o resultado da combinação de duas motivações geradas internamente que nada tinham a ver com medos de imagem corporal ou pressões externas: adoro andar de bicicleta e adoro a satisfação de fazer as coisas.</segment>
    <segment id="79">Faça uma mudança mental  Mas isso não quer dizer que minha estratégia sem carro funcionará para todos.</segment>
    <segment id="80">As pessoas usam mais a bicicleta em cidades com infraestrutura para ciclistas</segment>
    <segment id="81">, e caminham mais em comunidades onde</segment>
    <segment id="82">sese pode caminhar.</segment>
    <segment id="83">Tenho sorte: moro na área da baía de San Francisco</segment>
    <segment id="84">, que possui uma extensa rede de ciclovias</segment>
    <segment id="85">, incluindo uma trilha linda em curvas seguindo a beira-mar</segment>
    <segment id="86">, que uso para comprar mantimentos.</segment>
    <segment id="87">Mas o que acontece</segment>
    <segment id="88">sese você mora numa comunidade rural a 50 km do shopping mais próximo?</segment>
    <segment id="89">Ou sese o seu escritório não permite mais trabalhar em casa</segment>
    <segment id="90">, onde você pode escapar ao meio-dia para uma caminhada?</segment>
    <segment id="91">O truque pode ser tão simples quanto mudar o modo de pensar no exercício</segment>
    <segment id="92">, diz Benjamin Gardner</segment>
    <segment id="93">, pesquisador de psicologia do comportamento habitual na Universidade de Surrey</segment>
    <segment id="94">, na Grã-Bretanha.</segment>
    <segment id="95">O excesso de foco na palavra "exercício"</segment>
    <segment id="96">, afirma Gardner</segment>
    <segment id="97">, "lembra ir à academia</segment>
    <segment id="98">, levantar pesos</segment>
    <segment id="99">, correr em esteiras e assim por diante".</segment>
    <segment id="100">Reconhecer que as tarefas do dia a dia muitas vezes envolvem movimento é uma oportunidade para "incorporar hábitos de atividade física na nossa vida cotidiana"</segment>
    <segment id="101">, acrescenta.</segment>
    <segment id="102">Todos os dias da semana</segment>
    <segment id="103">, depois de levar seus filhos até a escola por 3 km</segment>
    <segment id="104">, diz Gardner</segment>
    <segment id="105">, ele estaciona o carro e caminha para casa</segment>
    <segment id="106">, às vezes marcando reuniões durante o percurso.</segment>
    <segment id="107">Depois</segment>
    <segment id="108">, à tarde</segment>
    <segment id="109">, ele volta até a escola para pegar as crianças e o carro.</segment>
    <segment id="110">"Adquiri o hábito de me perguntar"</segment>
    <segment id="111">, afirma</segment>
    <segment id="112">, "com todas as tarefas que faço todos os dias</segment>
    <segment id="113">, sese existe uma maneira de realizá-las de uma forma mais ativa fisicamente.</segment>
    <segment id="114">"  Você pode decidir caminhar um quilômetro para comprar um sanduíche para o almoço</segment>
    <segment id="115">, em vez de comprar um na lanchonete da esquina.</segment>
    <segment id="116">Se você mora numa área rural e não pode ir de bicicleta fazer compras</segment>
    <segment id="117">, experimente passar 20 minutos por dia removendo ervas daninhas ou reorganizando a garagem.</segment>
    <segment id="118">Qualquer coisa que você esteja adiando</segment>
    <segment id="119">, como</segment>
    <segment id="120">como desenterrar um toco velho ou transportar resíduos do quintal</segment>
    <segment id="121">, torna-</segment>
    <segment id="122">sese uma perspectiva mais convidativa quando você pensa nisso</segment>
    <segment id="123">comocomo um treino.</segment>
    <segment id="124">Comece fácil  "</segment>
    <segment id="125">O mais importante"</segment>
    <segment id="126">, diz Fortier</segment>
    <segment id="127">, "é que as pessoas encontrem maneiras de tornar sua sessão de exercícios –seja passear com o cachorro ou andar de bicicleta até o mercado– o mais agradável possível.</segment>
    <segment id="128">"</segment>
    <segment id="129">Em seu trabalho com mulheres clinicamente deprimidas e inativas</segment>
    <segment id="130">, Fortier diz a suas pacientes para começarem escolhendo um dia agradável para dar uma caminhada e</segment>
    <segment id="131">, em seguida</segment>
    <segment id="132">, ajustar um cronômetro para 10 minutos.</segment>
    <segment id="133">Se elas estiverem</segment>
    <segment id="134">sese sentindo bem quando o alarme disparar</segment>
    <segment id="135">, talvez caminhem mais um pouco.</segment>
    <segment id="136">Se não</segment>
    <segment id="137">, encerram o dia.</segment>
    <segment id="138">Ao ouvir Fortier</segment>
    <segment id="139">, percebi que</segment>
    <segment id="140">, ao iniciar meu novo regime de exercícios com uma árdua corrida ao supermercado</segment>
    <segment id="141">, corria o risco de reprimir meu entusiasmo antes mesmo de começar.</segment>
    <segment id="142">É melhor prestar atenção no princípio do prazer</segment>
    <segment id="143">, começar com desafios mais fáceis e aos poucos entrar em forma.</segment>
    <segment id="144">Portanto</segment>
    <segment id="145">, faça seu primeiro exercício numa tarde ensolarada:</segment>
    <segment id="146">dê um passeio até a agência dos correios mais próxima para enviar um pacote.</segment>
    <segment id="147">Aumente o ritmo por alguns meses e sua lista de tarefas começará a</segment>
    <segment id="148">sese encher de missões mais árduas.</segment>
    <segment id="149">Você pode até comprar um reboque de bicicleta usado na internet</segment>
    <segment id="150">, rir de uma chuvarada imprevista e adorar cada minuto.</segment>
    <segment id="151">Tradução Luiz Roberto M. Gonçalves</segment>
  </rst>
</analysis>