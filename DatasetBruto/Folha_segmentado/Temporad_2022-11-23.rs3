  <rst>
    <segment id="1">De volta à rota das companhias marítimas após a desaceleração de casos de Covid-19</segment>
    <segment id="2">, o Brasil inicia sua temporada de cruzeiros</segment>
    <segment id="3">, que se</segment>
    <segment id="4">se estende até abril de 2023.</segment>
    <segment id="5">A expectativa é de que essa seja a maior dos últimos dez anos</segment>
    <segment id="6">, com 780 mil leitos ofertados e 176 dias de duração.</segment>
    <segment id="7">Os dados são da Associação Brasileira de Cruzeiros Marítimos (Clia)</segment>
    <segment id="8">, que prevê a movimentação de R$ 3</segment>
    <segment id="9">,8 bilhões e a geração de 48 mil empregos com a procura pelas embarcações da alta temporada.  Deque da piscina do Costa Favolosa - Davide Scappini/Divulgação"Devemos vender mais de 850 mil passagens.</segment>
    <segment id="10">Essa é uma estimativa muito boa</segment>
    <segment id="11">, e o mês de novembro já tem demonstrado a positividade dessas vendas"</segment>
    <segment id="12">, diz Marco Ferraz</segment>
    <segment id="13">, presidente da Clia.</segment>
    <segment id="14">Durante o aumento de casos na primeira onda de Covid-19</segment>
    <segment id="15">, os cruzeiros enfrentaram a doença em alto-mar.</segment>
    <segment id="16">As embarcações isolaram os contaminados e prorrogaram as datas de desembarque.</segment>
    <segment id="17">A Clia realizou um estudo para medir a confiança dos passageiros em fazer uma nova viagem de navio.</segment>
    <segment id="18">Segundo Ferraz</segment>
    <segment id="19">, 84% pretendem voltar a viajar no próximo ano.</segment>
    <segment id="20">Entre os que nunca fizeram cruzeiros</segment>
    <segment id="21">, 69% têm a mesma intenção.</segment>
    <segment id="22">"</segment>
    <segment id="23">Esse é um número melhor que pré-pandemia</segment>
    <segment id="24">, e nos leva a crer que as pessoas estão</segment>
    <segment id="25">sese sentindo seguras"</segment>
    <segment id="26">, avalia.</segment>
    <segment id="27">A vacina não é mais obrigatória para os embarques.</segment>
    <segment id="28">Entretanto</segment>
    <segment id="29">, a Anvisa determinou outras medidas de segurança contra o vírus.</segment>
    <segment id="30">Se a viagem for de cinco noites ou menos</segment>
    <segment id="31">, é necessário apresentar comprovante de vacinação ou teste recente.</segment>
    <segment id="32">Já para aqueles que forem viajar por seis noites ou mais</segment>
    <segment id="33">, só será válido o teste.</segment>
    <segment id="34">Não são aceitos autotestes.</segment>
    <segment id="35">Nesta temporada</segment>
    <segment id="36">, 14 embarcações passam pelo Brasil e outros países da América do Sul.</segment>
    <segment id="37">Veja detalhes dos cruzeiros.</segment>
    <segment id="38">Cruzeiros Costa  Costa Firenze</segment>
    <segment id="39">O navio</segment>
    <segment id="40">, com capacidade para 5.620 passageiros</segment>
    <segment id="41">, faz estreia na América do Sul neste ano.</segment>
    <segment id="42">Inspirada na região italiana de Florença</segment>
    <segment id="43">, a embarcação oferece gastronomia regional aos hóspedes com pizzas</segment>
    <segment id="44">, vinhos e sorvetes da Pizzeria Pummid'Óro e da Gelateria Amarillo.</segment>
    <segment id="45">O transatlântico tem quatro piscinas</segment>
    <segment id="46">, hidromassagens</segment>
    <segment id="47">, três toboáguas</segment>
    <segment id="48">, outros 11 restaurantes</segment>
    <segment id="49">, sete bares</segment>
    <segment id="50">, spa com vista para o mar</segment>
    <segment id="51">, academia</segment>
    <segment id="52">, minigolfe</segment>
    <segment id="53">, cassino e dois espaços infantis.</segment>
    <segment id="54">Roteiro Bahia (Santos</segment>
    <segment id="55">, Salvador</segment>
    <segment id="56">, Ilhéus e Rio de Janeiro).</segment>
    <segment id="57">Embarque: Santos</segment>
    <segment id="58">, Salvador e Rio de Janeiro.</segment>
    <segment id="59">A partir de R$ 1.739 por pessoa em cabine interna dupla.</segment>
    <segment id="60">Roteiro especial de Réveillon</segment>
    <segment id="61">, de 26 de dezembro a 2 de janeiro de 2023.</segment>
