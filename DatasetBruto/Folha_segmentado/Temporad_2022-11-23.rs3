    <segment id="65">A embarcação</segment>
    <segment id="66">, que foi cenário do filme "</segment>
    <segment id="67">Meu Passado</segment>
    <segment id="68">Me Condena"</segment>
    <segment id="69">, é decorada com 6.000 obras de arte.</segment>
    <segment id="70">Comporta até 3.780 passageiros e é equipada com seis restaurantes com menus assinados por chefs</segment>
    <segment id="71">comocomo o italiano Bruno Barbieri.</segment>
    <segment id="72">Além das opções gastronômicas</segment>
    <segment id="73">, o navio possui spa</segment>
