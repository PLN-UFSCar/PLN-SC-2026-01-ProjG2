    <segment id="359">Royal Caribbean  Celebrity Infinity</segment>
    <segment id="360">A embarcação de luxo da Celebrity Cruises</segment>
    <segment id="361">, companhia adquirida pela Royal Caribbean</segment>
    <segment id="362">, comporta até 2.604 passageiros.</segment>
    <segment id="363">Renovado em 2021</segment>
    <segment id="364">, o navio tem dois restaurantes com comida à vontade.</segment>
    <segment id="365">Outros restaurantes</segment>
