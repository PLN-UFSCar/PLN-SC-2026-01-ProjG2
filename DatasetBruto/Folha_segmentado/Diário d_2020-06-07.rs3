    <segment id="354">;Dia 81: &amp;#039</segment>
    <segment id="355">;Botellones</segment>
    <segment id="356">, a nova discoteca pós-Covid&amp;#039</segment>
    <segment id="357">;Dia 82:</segment>
    <segment id="358">&amp;#039;Pandemia</segment>
