  <rst>
    <segment id="1">Marketing é essencial para o sucesso.</segment>
    <segment id="2">Há quem discorde</segment>
    <segment id="3">, masmas é essa a premissa por trás de "João Mata-Sete"</segment>
    <segment id="4">, o novo livro da Coleção Folha Folclore Brasileiro para Crianças.</segment>
    <segment id="5">O 13º volume</segment>
    <segment id="6">, que conta as aventuras de um jovem rapaz e sua campanha de autopromoção</segment>
    <segment id="7">, estará disponível a partir deste final de semana e pode ser encontrado nas bancas</segment>
    <segment id="8">, livrarias e no site do jornal.</segment>
    <segment id="9">&amp;#039;João Mata-Sete&amp;#039</segment>
    <segment id="10">;, volume da Coleção Folha Folclore Brasileiro para Crianças- DivulgaçãoNesta edição</segment>
    <segment id="11">, a escritora Silvia Oberg narra a história do sapateiro João</segment>
    <segment id="12">, que inicia suas peripécias após uma grande epifania.</segment>
    <segment id="13">Já no início da trama</segment>
    <segment id="14">, depois de matar sete moscas com um só golpe</segment>
    <segment id="15">, ele para</segment>
    <segment id="16">, pensa a respeito e decide confeccionar um cinto para propagandear seu feito.</segment>
    <segment id="17">O acessório tinha os dizeres "</segment>
    <segment id="18">João Gurumete de uma vez só matou sete".</segment>
    <segment id="19">A frase não era mentira e condizia com a realidade dos fatos</segment>
    <segment id="20">, já que o rapaz realmente matou sete moscas.</segment>
    <segment id="21">Entretanto</segment>
    <segment id="22">, a interpretação dada por quem lia a mensagem fez com que o esperto personagem ganhasse fama e fosse exposto a toda sorte de desafios.</segment>
    <segment id="23">Veja todos os volumes da Coleção Folha Folclore Brasileiro para CriançasMais    novamente         de   de  de  representando um</segment>
    <segment id="24">O livro</segment>
    <segment id="25">, que traz ilustrações de Weberson Santiago</segment>
    <segment id="26">, ainda vem acompanhado de diversas brincadeiras e cantigas tradicionais</segment>
    <segment id="27">, fazendo com que os pequenos leitores também aprendam mais um pouco sobre o folclore nacional.</segment>
    <segment id="28">COMO COMPRAR</segment>
    <segment id="29">Site da coleção</segment>
    <segment id="30">Telefone: (11)</segment>
    <segment id="31">3224-3090 (Grande São Paulo) e 0800 775 8080 (outras localidades)</segment>
    <segment id="32">Frete grátis: SP</segment>
    <segment id="33">, RJ, MG e PR (na compra da coleção completa)</segment>
    <segment id="34">Nas bancas por R$ 22</segment>
    <segment id="35">,90 o volume</segment>
    <segment id="36">Coleção completa: R$ 549</segment>
    <segment id="37">,60; lote avulso: R$ 109</segment>
    <segment id="38">,92</segment>
  </rst>
