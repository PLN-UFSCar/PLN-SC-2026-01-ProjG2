  <rst>
    <segment id="1">m dias quentes</segment>
    <segment id="2">comocomo os que estamos passando</segment>
    <segment id="3">, é comum ter vontade de fazer refeições mais leves.</segment>
    <segment id="4">Adoro saladas</segment>
    <segment id="5">, masmas sempre fiquei com um pé atrás em optar por elas</segment>
    <segment id="6">comocomo prato principal ao comer fora – principalmente</segment>
    <segment id="7">porque</segment>
    <segment id="8">porque costumam ser caras e nem sempre sustentam.  Tive</segment>
    <segment id="9">, porém</segment>
    <segment id="10">porém, três boas experiências com delivery nos últimos dias.</segment>
    <segment id="11">Foram saladas caprichadas e muito saborosas que recebi em casa.</segment>
    <segment id="12">E não fiquei com fome pouco tempo depois de almoçar!</segment>
    <segment id="13">Compartilho com vocês abaixo e deixo a dica para experimentar.</segment>
    <segment id="14">La Ensalada Ligera</segment>
    <segment id="15">O delivery saudável entrega em São Paulo e tem preços bem justos –os bowls custam R$ 25</segment>
    <segment id="16">,99.</segment>
    <segment id="17">São bem servidos e valem por uma ótima refeição!</segment>
    <segment id="18">Ou, se</segment>
    <segment id="19">se quiser pedir para servir</segment>
    <segment id="20">comocomo entrada</segment>
    <segment id="21">, um bowl dá conta de duas pessoas.</segment>
    <segment id="22">Salada Mediterrânea do La Ensalada Legera</segment>
    <segment id="23">, que leva penne integral</segment>
    <segment id="24">, abobrinha e crispy de bacon - Reprodução/Instagram</segment>
    <segment id="25">Uma das minhas opções prediletas é a Mediterrânea</segment>
    <segment id="26">, com penne integral</segment>
    <segment id="27">, mix de folhas</segment>
    <segment id="28">, queijo mozarela</segment>
    <segment id="29">, tomate</segment>
    <segment id="30">, cebola roxa</segment>
    <segment id="31">, azeitonas pretas</segment>
    <segment id="32">, abobrinha assada e crispy de bacon (que pode ser retirado</segment>
    <segment id="33">, para quem não gosta ou não come carne).</segment>
    <segment id="34">Vale provar também a salada Barcelona</segment>
    <segment id="35">, que leva abóbora cabotiã assada</segment>
    <segment id="36">, quinoa e brócolis.</segment>
    <segment id="37">Os molhos acompanham e há opções</segment>
    <segment id="38">comocomo oriental (shoyo</segment>
    <segment id="39">, azeite</segment>
    <segment id="40">, limão e pimenta) e mostarda e mel.</segment>
    <segment id="41">&amp;gt; Delivery aqui.</segment>
    <segment id="42">Olga Ri</segment>
    <segment id="43">O restaurante saudável possui unidades na Vila Olímpia</segment>
    <segment id="44">, Jardins</segment>
    <segment id="45">, Lapa</segment>
    <segment id="46">, Mooca e Santana –todas em São Paulo– e entrega em casa.</segment>
    <segment id="47">Os preços são um pouco mais altos (variam entre R$ 30 e R$ 50)</segment>
    <segment id="48">, masmas as saladas também são muito bem servidas.</segment>
    <segment id="49">Salada de camarão com guacamole do restaurante Olga Ri - Reprodução/Instagram  Provei recentemente e gostei muito da Camarão Guac (R$ 47</segment>
    <segment id="50">,90), que leva camarão marinado</segment>
    <segment id="51">, guacamole</segment>
    <segment id="52">, chips de batata doce e bifum (macarrão de arroz)</segment>
    <segment id="53">, além da base de alface americana.</segment>
    <segment id="54">Dica para casal: vale montar a própria salada em tamanho grande e dividir.</segment>
    <segment id="55">Sai mais em conta e dá bem para os dois!</segment>
    <segment id="56">Os molhos acompanham e há opções</segment>
    <segment id="57">comocomo azeite e balsâmico e pesto de manjericão.</segment>
    <segment id="58">&amp;gt; Delivery aqui.</segment>
    <segment id="59">Boali</segment>
    <segment id="60">A franquia de alimentação saudável é uma das mais conhecidas na capital paulista e continua sendo uma das melhores opções também no delivery</segment>
    <segment id="61">, com pratos coloridos e que matam a fome.</segment>
    <segment id="62">No cardápio de saladas</segment>
    <segment id="63">, boa sugestão é a Foco na Meta</segment>
    <segment id="64">, que leva carpaccio de salmão</segment>
    <segment id="65">, brócolis</segment>
    <segment id="66">, pepino e mandioquinha palha (R$ 39).</segment>
    <segment id="67">Salada com carpaccio de salmão defumado do restaurante Boali - Reprodução/Instagram</segment>
    <segment id="68">Para quem quer diversificar</segment>
    <segment id="69">, a salada Oriental é bem gostosa</segment>
    <segment id="70">–leva, entre outros ingredientes</segment>
    <segment id="71">, bifum</segment>
    <segment id="72">, atum</segment>
    <segment id="73">, amendoim</segment>
    <segment id="74">, cebola crocante e semente de linhaça.</segment>
    <segment id="75">Há também a opção de montar a própria salada (folha</segment>
    <segment id="76">, ingredientes frescos e secos e a proteína</segment>
    <segment id="77">, masmas esta deve ser paga à parte).</segment>
    <segment id="78">Os molhos acompanham e há opções</segment>
    <segment id="79">comocomo chipotle (tomate</segment>
    <segment id="80">, pimenta jalapeño e páprica) e caeser.</segment>
    <segment id="81">&amp;gt; Delivery aqui.</segment>
  </rst>
