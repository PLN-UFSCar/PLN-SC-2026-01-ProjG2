  <rst>
    <segment id="1">Frango fica bom na churrasqueira</segment>
    <segment id="2">, sim!</segment>
    <segment id="3">O importante é escolher cortes mais gordurosos</segment>
    <segment id="4">, como</segment>
    <segment id="5">como uma sobrecoxa de frango ou a coxinha da asa</segment>
    <segment id="6">; e, se</segment>
    <segment id="7">se for usar o peito</segment>
    <segment id="8">, mantenha a pele.</segment>
    <segment id="9">Para trazer mais sabor e suculência</segment>
    <segment id="10">, uma marinada faz toda a diferença —além de amaciar a carne</segment>
    <segment id="11">, por causa dos sucos ácidos com limão</segment>
    <segment id="12">, laranja ou vinagre.</segment>
    <segment id="13">Sobrecoxa de frango na grelha - Larissa Morales</segment>
    <segment id="14">Quanto mais tempo marinando</segment>
    <segment id="15">, mais saborosa a carne ficará.</segment>
    <segment id="16">O ideal é deixar por 48 horas ou</segment>
    <segment id="17">, no mínimo</segment>
    <segment id="18">, por 2 horas.</segment>
    <segment id="19">Além disso</segment>
    <segment id="20">, há um grande custo-benefício da carne de frango em relação à carne bovina</segment>
    <segment id="21">, já que a sobrecoxa custa</segment>
    <segment id="22">, no máximo</segment>
    <segment id="23">, R$ 20 no mercado.</segment>
    <segment id="24">Anote os ingredientes e bom proveito!  SOBRECOXA DESOSSADA MARINADA  Ingredientes:   1kg de sobrecoxa de frango desossada 3 dentes de alho Raspas de 1 limão Suco de 1 limão 1 xícara de manjericão ½ colher de sopa de sal 1 colher de chá de açúcar 1 colher de chá de gengibre ralado Pimenta do reino à gosto 3 colheres de sopa de shoyu 3 colheres de sopa de azeite</segment>
    <segment id="25">Modo de preparo:</segment>
    <segment id="26">Abra a sobrecoxa de frango fazendo talhos com a faca ou com a ajuda de um martelo culinário</segment>
    <segment id="27">, de forma que fique um filé com 1 dedo de espessura</segment>
    <segment id="28">, tomando cuidado para manter a pele.</segment>
    <segment id="29">Em um pilão junte o manjericão</segment>
    <segment id="30">, o alho o gengibre</segment>
    <segment id="31">, o sal e bata até formar uma pasta.</segment>
    <segment id="32">Adicione as raspas de limão</segment>
    <segment id="33">, o suco de limão</segment>
    <segment id="34">, o shoyu</segment>
    <segment id="35">, o azeite e a pimenta do reino e as sobrecoxas.</segment>
    <segment id="36">Tampe e deixe na geladeira por 48 horas ou no mínimo por 2 horas.</segment>
    <segment id="37">Leve para grelhar em fogo médio por 6 minutos cada lado.</segment>
    <segment id="38">Deixe descansar por 2 minutos e sirva</segment>
  </rst>
</analysis>