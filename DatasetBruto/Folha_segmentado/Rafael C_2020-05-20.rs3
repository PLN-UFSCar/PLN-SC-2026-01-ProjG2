  <rst>
    <segment id="1">Diariamente</segment>
    <segment id="2">, durante a crise do coronavírus</segment>
    <segment id="3">, um colunista ou um blogueiro da Folha indica sugestões para o período de quarentena</segment>
    <segment id="4">, como</segment>
    <segment id="5">como livros</segment>
    <segment id="6">, filmes</segment>
    <segment id="7">, séries</segment>
    <segment id="8">, entre outras opções.</segment>
    <segment id="9">Confira as sugestões de Rafael Capanema</segment>
    <segment id="10">, colunista de humor do site da Folha.</segment>
    <segment id="11">Acompanhe todas as dicas dos colunistas aqui.</segment>
    <segment id="12">Para ver  Nathan For You Série.</segment>
    <segment id="13">Comedy Central</segment>
    <segment id="14">, 2013</segment>
    <segment id="15">Em "Nathan For You"</segment>
    <segment id="16">, o comediante canadense Nathan Fielder tenta ajudar pequenos negócios propondo ideias estapafúrdias</segment>
    <segment id="17">, antiéticas ou de execução desnecessariamente complexa (nos melhores episódios</segment>
    <segment id="18">, tudo isso ao mesmo tempo).</segment>
    <segment id="19">É de "pausar para ficar rindo"</segment>
    <segment id="20">, como</segment>
    <segment id="21">como disse um conhecido meu.</segment>
    <segment id="22">Comece pelos trechos disponíveis no YouTube para saber</segment>
    <segment id="23">sese é a sua praia.</segment>
    <segment id="24">Para ler  Pizzarias que Contam a História de São Paulo  Panda Books</segment>
    <segment id="25">, 2018.</segment>
    <segment id="26">R$ 28,42 (96 págs.)</segment>
    <segment id="27">Ebook R$ 25</segment>
    <segment id="28">,90  Bráz</segment>
    <segment id="29">, 1900 e Veridiana são as melhores pizzarias na opinião de paulistanos    novamente         de   de  de  representando um  Passo 75% do meu dia pensando em pizza e fiquei muito feliz quando soube da existência deste livro de Gabriela Erbetta</segment>
    <segment id="30">, que conta a história de dez das pizzarias mais tradicionais de São Paulo.</segment>
    <segment id="31">Comprei principalmente por causa da Castelões</segment>
    <segment id="32">, a pizzaria em atividade mais antiga do Brasil</segment>
    <segment id="33">, fundada em 1924</segment>
    <segment id="34">, pela qual sou obcecado.</segment>
    <segment id="35">Agora tenho pelo menos mais cinco lugares para conhecer quando isso tudo passar.</segment>
  </rst>
