    <segment id="18">A hashtag Protect Taylor Swift</segment>
    <segment id="19">, ou proteja Taylor Swift</segment>
    <segment id="20">, está entre os assuntos mais comentados do X nesta quinta-feira (25).</segment>
    <segment id="21">No Brasil</segment>
    <segment id="22">, no mês passado</segment>
