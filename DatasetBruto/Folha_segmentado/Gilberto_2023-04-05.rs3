  <rst>
    <segment id="1">Foi com a Lua 99</segment>
    <segment id="2">,15% visível</segment>
    <segment id="3">, e crescendo</segment>
    <segment id="4">, na noite da última terça-feira (4)</segment>
    <segment id="5">, que o cantor e compositor baiano Gilberto Gil</segment>
    <segment id="6">, 80, fez um pocket show para cerca de cem pessoas</segment>
    <segment id="7">, no Espaço Priceless</segment>
    <segment id="8">, complexo gastronômico da Mastercard</segment>
    <segment id="9">, no rooftop do shopping Light</segment>
    <segment id="10">, no centro histórico de São Paulo.</segment>
    <segment id="11">O evento</segment>
    <segment id="12">, exclusivo para convidados</segment>
    <segment id="13">, serviu para marcar a chegada em São Paulo do Noites Cariocas</segment>
    <segment id="14">, um dos festivais icônicos da música brasileira.</segment>
    <segment id="15">O cantor e compositor Gilberto Gil em pocket show realizado na última terça-feira</segment>
    <segment id="16">, em São Paulo - Carlos Bozzo Junior/FolhapressTocando violão</segment>
    <segment id="17">, cantando e acompanhado por dois de seus filhos</segment>
    <segment id="18">, o compositor e multi-instrumentista Bem Gil e o baterista José Gil</segment>
    <segment id="19">, Gilberto Gil mostrou ter sua filha maior</segment>
    <segment id="20">, a música</segment>
    <segment id="21">, no bolso.</segment>
    <segment id="22">Dele tirou seus maiores sucessos</segment>
    <segment id="23">, sendo acompanhado também pelas vozes e palmas de quem teve a sorte de assistir de perto ao talento incomensurável do artista.</segment>
    <segment id="24">Durante uma hora e dez minutos de show</segment>
    <segment id="25">, público e artista</segment>
    <segment id="26">sese deliciaram cantando</segment>
    <segment id="27">, entre outras</segment>
    <segment id="28">, "Expresso 2222"</segment>
    <segment id="29">, "Estrela"</segment>
    <segment id="30">, "Tempo Rei"</segment>
    <segment id="31">, "Esotérico"</segment>
    <segment id="32">, "Refazenda"</segment>
    <segment id="33">, "Vamos Fugir"</segment>
    <segment id="34">, "Palco"</segment>
    <segment id="35">, "</segment>
    <segment id="36">Andar</segment>
    <segment id="37">Com Fé"</segment>
    <segment id="38">, "Toda Menina Baiana"</segment>
    <segment id="39">, além da positivista "</segment>
    <segment id="40">Three Little Birds" (Everything's Gonna Be Alright)</segment>
    <segment id="41">, lançada em 1977</segment>
    <segment id="42">, no álbum "Exodus"</segment>
    <segment id="43">, de Bob Marley &amp;amp</segment>
    <segment id="44">;</segment>
    <segment id="45">The Wailers.  "</segment>
    <segment id="46">O samba</segment>
    <segment id="47">, das músicas populares</segment>
    <segment id="48">, é a expressão mais genuína</segment>
    <segment id="49">, mais profunda</segment>
    <segment id="50">, mais integral do Brasil</segment>
    <segment id="51">, da música brasileira.</segment>
    <segment id="52">O Brasil é muito grande e os africanos</segment>
    <segment id="53">, especialmente eles</segment>
    <segment id="54">, foram fundamentais na formação</segment>
    <segment id="55">, na forja do samba</segment>
    <segment id="56">, e se</segment>
    <segment id="57">se espalharam também por vários lugares do Brasil</segment>
    <segment id="58">, começando lá pela minha Bahia</segment>
    <segment id="59">, depois andando por aí por tudo que é canto.</segment>
    <segment id="60">Forjaram portanto uma variedade muito grande de samba"</segment>
    <segment id="61">, disse o artista tirando do bolso "Chiclete com Banana"</segment>
    <segment id="62">, um samba jazz</segment>
    <segment id="63">, gênero difundido pelo Rei do Ritmo</segment>
    <segment id="64">, o paraibano Jackson do Pandeiro (1919-1982).</segment>
    <segment id="65">O compositor Tom Zé e a atriz Adriana Lessa na entrada do pocket show de Gilberto Gil</segment>
    <segment id="66">, em São Paulo - Carlos Bozzo Junior/FolhapressNa plateia</segment>
    <segment id="67">, várias celebridades.</segment>
    <segment id="68">Entre elas</segment>
    <segment id="69">, o compositor Tom Zé e seu guitarrista e diretor artístico Daniel Maia</segment>
    <segment id="70">; o trombonista Joabe Reis e sua produtora Julia Andreatta</segment>
    <segment id="71">; o ator Leopoldo Pacheco e sua mulher</segment>
    <segment id="72">, a produtora cultural Bel Gomes</segment>
    <segment id="73">; as atrizes Adriana Lessa e Débora Falabella</segment>
    <segment id="74">; os chefs de cozinha Alex Atala e Edu Guedes</segment>
    <segment id="75">; o ator Flávio Tolezani e sua filha</segment>
    <segment id="76">, a atriz Ana Clara</segment>
    <segment id="77">; além do life coach Edson Moraes.</segment>
    <segment id="78">Ao sentir a calorosa recepção do público cantando com ele suas músicas</segment>
    <segment id="79">, antes de mandar "</segment>
    <segment id="80">Aquele Abraço"</segment>
    <segment id="81">, Gilberto Gil disse:</segment>
    <segment id="82">"</segment>
    <segment id="83">É São Paulo cantando.</segment>
    <segment id="84">Dizem que São Paulo só trabalha</segment>
    <segment id="85">, que nada.</segment>
    <segment id="86">Canta e canta muito.</segment>
    <segment id="87">Canta o Brasil inteiro</segment>
    <segment id="88">, porque</segment>
    <segment id="89">porque reúne aquela coisa que eu estava falando do samba no começo [do show].</segment>
    <segment id="90">São Paulo reúne tudo</segment>
    <segment id="91">, o Brasil inteiro.</segment>
    <segment id="92">Procedências várias</segment>
    <segment id="93">, de todos os lugares</segment>
    <segment id="94">, por exemplo</segment>
    <segment id="95">, do Rio de Janeiro".</segment>
    <segment id="96">Colunas e BlogsReceba no seu email uma seleção de colunas e blogs da Folha</segment>
    <segment id="97">; exclusiva para assinantes.</segment>
    <segment id="98">Carregando...</segment>
    <segment id="99">A conquista da Lua foi anunciada pela Folha de S.Paulo</segment>
    <segment id="100">, no dia 21 de julho de 1969</segment>
    <segment id="101">, com a manchete: "</segment>
    <segment id="102">A Lua no Bolso".</segment>
    <segment id="103">Nesta quarta-feira</segment>
    <segment id="104">, 5 de abril de 2023</segment>
    <segment id="105">, este repórter anuncia: "</segment>
    <segment id="106">Gilberto Gil Tem a Música no Bolso".</segment>
    <segment id="107">Assista</segment>
    <segment id="108">, a seguir</segment>
    <segment id="109">, trechos do pocket show de Gilberto Gil</segment>
    <segment id="110">, gravados com exclusividade pelo Música em Letras.</segment>
  </rst>
</analysis>