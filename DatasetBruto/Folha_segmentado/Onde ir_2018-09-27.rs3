  <rst>
    <segment id="1">O destaque da cidade de Salvador</segment>
    <segment id="2">, mais populosa do Nordeste</segment>
    <segment id="3">, é a mistura de religiões e tradições populares.</segment>
    <segment id="4">O que fazer:</segment>
    <segment id="5">Quem visita Salvador não pode deixar de conhecer o Pelourinho.</segment>
    <segment id="6">Dá para passar uma tarde toda passeando pelas ruas</segment>
    <segment id="7">, visitando as igrejas do centro histórico</segment>
    <segment id="8">, os museus e ateliês da região.</segment>
    <segment id="9">De lá, o turista pode descer pelo Elevador Lacerda e conhecer o Mercado Modelo.</segment>
    <segment id="10">O pôr do sol é uma das atrações de Salvador</segment>
    <segment id="11">, e um bom lugar para vê-lo é das praias do Farol da Barra ou do Porto da Barra —boas opções para aproveitar o mar na zona urbana.</segment>
    <segment id="12">Outro ponto interessante para ver o sol ir</segment>
    <segment id="13">embora</segment>
    <segment id="14">embora é a Ponta de Humaitá</segment>
    <segment id="15">, no bairro de Mont Serrat.</segment>
    <segment id="16">A Casa do Rio Vermelho</segment>
    <segment id="17">, museu no local onde morava Jorge Amado e Zélia Gattai</segment>
    <segment id="18">, é outro ponto imperdível</segment>
    <segment id="19">, aberto para visitação em 2014.</segment>
    <segment id="20">A culinária baiana</segment>
    <segment id="21">, de temperos fortes</segment>
    <segment id="22">, é destaque da visita a Salvador.</segment>
    <segment id="23">O turista precisa ao menos provar o acarajé</segment>
    <segment id="24">, o abará e a moqueca baiana.</segment>
    <segment id="25">Quando ir:</segment>
    <segment id="26">Se quiser o agito dos trios elétricos</segment>
    <segment id="27">, visite durante o Carnaval.</segment>
    <segment id="28">Para mais tranquilidade</segment>
    <segment id="29">, fuja dessa época.</segment>
    <segment id="30">O Ano Novo na cidade é animado e menos caro do que em outros destinos de litoral.</segment>
    <segment id="31">Para vivenciar o sincretismo religioso</segment>
    <segment id="32">, aproveite a Lavagem do Senhor do Bonfim</segment>
    <segment id="33">, que em 2019 acontece em 10 de janeiro.</segment>
    <segment id="34">​Sinta-</segment>
    <segment id="35">sese lá:</segment>
    <segment id="36">O filme "Capitães da Areia" (2011)</segment>
    <segment id="37">, adaptação da obra de Jorge Amado dirigida por sua neta</segment>
    <segment id="38">, Cecília Amado</segment>
    <segment id="39">, conta uma das histórias mais famosas que tem Salvador</segment>
    <segment id="40">comocomo cenário.</segment>
    <segment id="41">Para ouvir e</segment>
    <segment id="42">sese sentir na cidade</segment>
    <segment id="43">, escolha uma das canções de Dorival Caymmi</segment>
    <segment id="44">, como</segment>
    <segment id="45">como São Salvador</segment>
    <segment id="46">, ou se</segment>
    <segment id="47">se jogue no axé</segment>
    <segment id="48">, ritmo que nasceu na cidade nos anos 1990.</segment>
    <segment id="49">O Canto da Cidade é um clássico de Daniela Mercury</segment>
    <segment id="50">, de 1992.</segment>
    <segment id="51">Confira o que fazer nos 50 destinos eleitos pelo júri de Turismo</segment>
  </rst>
</analysis>