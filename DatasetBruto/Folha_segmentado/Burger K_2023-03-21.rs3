  <rst>
    <segment id="1">Quando eu era pivete</segment>
    <segment id="2">, meus pais me levavam a uma pizzaria de bairro que ostentava a seguinte placa na parece: "</segment>
    <segment id="3">A melhor pizza da região".</segment>
    <segment id="4">De alguma forma</segment>
    <segment id="5">, eu já entendia a síndrome de impostor que levava os donos do restaurante a serem tão modestos na pretensão.</segment>
    <segment id="6">Eu adorava aquela honestidade meio acabrunhada</segment>
    <segment id="7">, só faltava um "talvez</segment>
    <segment id="8">" no letreiro.</segment>
    <segment id="9">A maioria das pessoas não tem o menor pudor de</segment>
    <segment id="10">sese declarar melhor do mundo nisso ou naquilo</segment>
    <segment id="11">, rei da cocada preta</segment>
    <segment id="12">, top dos topzeras.</segment>
    <segment id="13">O Bacon Super</segment>
    <segment id="14">, do Madero</segment>
    <segment id="15">, leva dez fatias de bacon.</segment>
    <segment id="16">Nem por isso é bom - Nilo Biazetto/DivulgaçãoEssa presunção faz parte das estratégias de venda desde que o mundo é mundo.</segment>
    <segment id="17">Não morreu e não morrerá por uma simples razão: é um pavoneio que não tem</segment>
    <segment id="18">comocomo ser verificado.</segment>
    <segment id="19">Agora, fico sabendo que há anos o Burger King move uma ação judicial contra o Madero</segment>
    <segment id="20">, a fim de obrigar a rede concorrente a provar que faz o melhor hambúrguer do mundo.</segment>
    <segment id="21">Esse é o slogan do Madero</segment>
    <segment id="22">, totalmente disparatado para quem faz o pior hambúrguer do mundo.</segment>
    <segment id="23">Mas e aí?</segment>
    <segment id="24">Como provar uma coisa dessas?</segment>
    <segment id="25">Colunas e BlogsReceba no seu email uma seleção de colunas e blogs da Folha</segment>
    <segment id="26">; exclusiva para assinantes.</segment>
    <segment id="27">Carregando...</segment>
    <segment id="28">Segundo reportagem do jornal</segment>
    <segment id="29">O Globo</segment>
    <segment id="30">, o Burguer King "queria que fosse realizada uma prova pericial".</segment>
    <segment id="31">Perdão?</segment>
    <segment id="32">Iam chamar uns blogueiros de hambúrguer para uma degustação técnica?</segment>
    <segment id="33">Ainda segundo o texto</segment>
    <segment id="34">, o BK alega que o Madero não comprovou "liderança de mercado em âmbito mundial".</segment>
    <segment id="35">Ah, beleza</segment>
    <segment id="36">, por esse critério só eles e o sanduba do palhaço Ronaldo McDonaldo estão no páreo.</segment>
    <segment id="37">A era das celebridades no fast foodMais    novamente         de   de  de  representando um</segment>
    <segment id="38">Desde quando liderança de mercado é qualidade?</segment>
    <segment id="39">Não tá escrito que tem de jumento disposto a dar dinheiro por comida ruim.</segment>
    <segment id="40">As pessoas adoram rankings.</segment>
    <segment id="41">A imprensa também</segment>
    <segment id="42">, porque</segment>
    <segment id="43">porque dá leitura.</segment>
    <segment id="44">O problema com eles é que todos são furados</segment>
    <segment id="45">, não valem nada.</segment>
    <segment id="46">Não existe melhor hambúrguer do mundo nem melhor restaurante.</segment>
    <segment id="47">Tripadvisor</segment>
    <segment id="48">, Taste Atlas</segment>
    <segment id="49">, 50 Best Restaurants</segment>
    <segment id="50">, nada disso vale uma pamonha.</segment>
    <segment id="51">Cada um diz o que quer.</segment>
    <segment id="52">Depois de idas e vindas</segment>
    <segment id="53">, baixou a sensatez no tribunal: o STJ negou na terça-feira (21) o pedido do Burger King.</segment>
    <segment id="54">E aqui bateu uma pitada de alívio.</segment>
    <segment id="55">Eu também não tenho prova objetiva</segment>
    <segment id="56">, impressa e auditável de que o Madero faz o pior hambúrguer do mundo</segment>
    <segment id="57">, como</segment>
    <segment id="58">como já andei escrevendo.</segment>
  </rst>
</analysis>