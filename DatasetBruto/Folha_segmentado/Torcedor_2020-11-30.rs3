  <rst>
    <segment id="1">Roberto Cejas</segment>
    <segment id="2">, 64, se</segment>
    <segment id="3">se encontrou com Diego</segment>
    <segment id="4">Maradona duas vezes na vida.</segment>
    <segment id="5">A última foi em 2014</segment>
    <segment id="6">, durante a Copa do Mundo no Brasil.</segment>
    <segment id="7">A primeira o tornou famoso na Argentina e fez com que seu telefone não parasse de tocar nos útimos dias.</segment>
    <segment id="8">Muita gente quer conversar com o homem que carregou o camisa 10 nos ombros</segment>
    <segment id="9">, no estádio Azteca</segment>
    <segment id="10">, no México</segment>
    <segment id="11">, durante a festa de comemoração pelo título Mundial de 1986.</segment>
    <segment id="12">Cejas afirma que</segment>
    <segment id="13">, ao saber da morte de Maradona</segment>
    <segment id="14">, na última quarta-feira (25)</segment>
    <segment id="15">, teve uma crise de choro incontrolável.</segment>
    <segment id="16">"</segment>
    <segment id="17">Eu não podia acreditar.</segment>
    <segment id="18">Não podia ser.</segment>
    <segment id="19">Como Diego poderia estar morto?</segment>
    <segment id="20">Estou destroçado"</segment>
    <segment id="21">, disse ele à Folha.</segment>
    <segment id="22">Maradona é carregado por Cejas com a taça da Copa de 1986 - Gary Hershorn - 29.jun.86/Reuters</segment>
    <segment id="23">A foto em que aparece</segment>
    <segment id="24">, 34 anos mais jovem</segment>
    <segment id="25">, com Maradona sobre seus ombros e segurando a taça da Copa do Mundo</segment>
    <segment id="26">, está enquadrada na sala de sua casa.</segment>
    <segment id="27">"</segment>
    <segment id="28">Em 2014</segment>
    <segment id="29">, uma emissora de TV entrou em contato comigo para perguntar</segment>
    <segment id="30">sese eu queria me encontrar com Diego.</segment>
    <segment id="31">Claro que queria.</segment>
    <segment id="32">Me disseram que ele desejava me ver.</segment>
    <segment id="33">Fui ao Brasil durante a Copa do Mundo e</segment>
    <segment id="34">, quando nos vimos</segment>
    <segment id="35">, demos um longo abraço.</segment>
    <segment id="36">Foi um momento incrível.</segment>
    <segment id="37">Eu me lembro que era Dia dos Pais [na Argentina]"</segment>
    <segment id="38">, recorda Cejas.</segment>
    <segment id="39">Abelardo Acceta relembra</segment>
    <segment id="40">comocomo foi carregar Pelé na Copa de 1970</segment>
    <segment id="41">A data era 15 de junho de 2014</segment>
    <segment id="42">, quando a seleção estreou no Mundial do Brasil diante da Bósnia</segment>
    <segment id="43">, no Maracanã.</segment>
    <segment id="44">Maradona participava todas as noites do programa "</segment>
    <segment id="45">De Zurda"</segment>
    <segment id="46">, transmitido pela multiestatal da América Latina TeleSur.</segment>
    <segment id="47">Hoje Cejas lamenta não ter tido uma nova oportunidade</segment>
    <segment id="48">, nos seis anos que</segment>
    <segment id="49">sese seguiram</segment>
    <segment id="50">, de ter sua terceira conversa com Diego.</segment>
    <segment id="51">"</segment>
    <segment id="52">Mas eu sabia que seria difícil.</segment>
    <segment id="53">Ele era uma pessoa muito ocupada.</segment>
    <segment id="54">"</segment>
    <segment id="55">Diego</segment>
    <segment id="56">Maradona é velado na Casa Rosada</segment>
    <segment id="57">, em Buenos Aires   novamente         de   de  de  representando um</segment>
    <segment id="58">O torcedor invadiu o gramado do estádio Azteca com outros argentinos assim que o árbitro brasileiro Romualdo Arppi Filho apitou o fim da partida contra a Alemanha e começou a saltar em frente a câmeras de TV e fotógrafos</segment>
    <segment id="59">, com a esperança de registrar para a posteridade que estava ali naquele momento histórico.</segment>
    <segment id="60">Ele correu de um lado para o outro e</segment>
    <segment id="61">sese aproximou do local onde os jogadores receberiam o troféu.</segment>
    <segment id="62">Quando a cerimônia terminou</segment>
    <segment id="63">, teve início a volta olímpica.</segment>
    <segment id="64">Um dos seus amigos colocou o atacante Pedro Pasculli nos ombros.</segment>
    <segment id="65">Cejas diz ter</segment>
    <segment id="66">sese aproximado para ajudá-lo.</segment>
    <segment id="67">Foi quando viu Maradona próximo</segment>
    <segment id="68">, a observar a cena</segment>
    <segment id="69">, como</segment>
    <segment id="70">como que esperando que alguém fizesse o mesmo por ele.</segment>
    <segment id="71">"</segment>
    <segment id="72">Eu apenas me abaixei</segment>
    <segment id="73">, ele apoiou as pernas em torno do meu pescoço e o levantei.</segment>
    <segment id="74">Começamos a dar a volta no gramado e Diego ia me dizendo para qual direção ir.</segment>
    <segment id="75">Foi algo lindo.</segment>
    <segment id="76">Gosto de dizer que estava naquele local e naquele momento por causa da mão de Deus"</segment>
    <segment id="77">, afirma</segment>
    <segment id="78">, usando a expressão criada por Maradona para definir seu primeiro gol contra a Inglaterra</segment>
    <segment id="79">, nas quartas de final</segment>
    <segment id="80">, marcado com a mão.</segment>
    <segment id="81">A trajetória de Maradona   novamente         de   de  de  representando um  Cejas passou o trajeto inteiro pedindo coisas para Maradona.</segment>
    <segment id="82">A camisa</segment>
    <segment id="83">, depois os calções</segment>
    <segment id="84">, as meias</segment>
    <segment id="85">, as chuteiras.</segment>
    <segment id="86">Não conseguiu nada.</segment>
    <segment id="87">"</segment>
    <segment id="88">Ele já tinha prometido tudo para outras pessoas.</segment>
    <segment id="89">Depois ganhei o calção de Oscar Garré [lateral esquerdo].</segment>
    <segment id="90">Coloquei em uma caixa quando cheguei em casa e nunca mais encontrei.</segment>
    <segment id="91">"</segment>
    <segment id="92">Entrar no campo e carregar Maradona aconteceu de improviso</segment>
    <segment id="93">, como</segment>
    <segment id="94">como toda a viagem do torcedor ao México.</segment>
    <segment id="95">Antes da semifinal contra a Bélgica</segment>
    <segment id="96">, ele havia decidido que</segment>
    <segment id="97">, sese a Argentina passasse</segment>
    <segment id="98">, viajaria para ver a decisão.</segment>
    <segment id="99">Pediu dinheiro emprestado para o pai</segment>
    <segment id="100">, pegou alguns dias de folga no trabalho e embarcou</segment>
    <segment id="101">, sem ingresso.</segment>
    <segment id="102">Ele se</segment>
    <segment id="103">se encontrou com seis amigos na Cidade do México.</segment>
    <segment id="104">Haviam lhe dito ser possível comprar o bilhete por US$ 80</segment>
    <segment id="105">, masmas naquela altura nenhum cambista os tinha.</segment>
    <segment id="106">"</segment>
    <segment id="107">Nós estávamos em sete e tínhamos quatro entradas.</segment>
    <segment id="108">Fomos até a porta do Azteca e</segment>
    <segment id="109">, na hora de passar pelo portão</segment>
    <segment id="110">, as entregamos aos fiscais com pesos mexicanos enfiados entre elas.</segment>
    <segment id="111">Deixaram todos nós entrarmos.</segment>
    <segment id="112">Era tudo muito diferente naquela época.</segment>
    <segment id="113">Imagine viajar para a final da Copa sem ingresso e conseguir entrar...</segment>
    <segment id="114">", sese espanta ainda hoje.</segment>
    <segment id="115">Ele é grato pelo suborno que o permitiu ver a Argentina campeã e ter contato com Maradona.</segment>
    <segment id="116">Em 2014</segment>
    <segment id="117">, chegou a dizer ao ídolo que poderiam</segment>
    <segment id="118">sese encontrar em Corrientes (a 800 km de Buenos Aires)</segment>
    <segment id="119">, para uma pescaria.</segment>
    <segment id="120">O camisa 10 disse que claro</segment>
    <segment id="121">, iriam marcar.</segment>
    <segment id="122">Mas Cejas sabia ser impossível.</segment>
    <segment id="123">"Se estou arrasado pela morte de Diego</segment>
    <segment id="124">, sou grato por esses momentos com ele.</segment>
    <segment id="125">"</segment>
  </rst>
</analysis>