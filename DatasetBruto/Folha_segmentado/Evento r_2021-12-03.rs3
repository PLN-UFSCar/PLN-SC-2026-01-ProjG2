  <rst>
    <segment id="1">A Praia Grande (litoral paulista) serviu nesta quinta-feira (2) de cenário</segment>
    <segment id="2">para que</segment>
    <segment id="3">para que 132 pessoas com deficiência pudessem ter o primeiro contato com esportes aquáticos</segment>
    <segment id="4">, como</segment>
    <segment id="5">como surfe</segment>
    <segment id="6">, standup paddle e caiaque</segment>
    <segment id="7">, com o acompanhamento de profissionais.</segment>
    <segment id="8">Apesar de não ser um campeonato</segment>
    <segment id="9">, todos receberam medalhas de participação</segment>
    <segment id="10">, segundo os organizadores.</segment>
    <segment id="11">Nesta sexta-feira (3)</segment>
    <segment id="12">, é comemorado o Dia Internacional da Pessoa com Deficiência.</segment>
    <segment id="13">Além de voluntários</segment>
    <segment id="14">, instituições</segment>
    <segment id="15">comocomo a Apae da Praia Grande e a ONG Adote um Cidadão</segment>
    <segment id="16">sese uniram para realizar o evento Surf Eficiente</segment>
    <segment id="17">, com o objetivo de proporcionar momentos de inclusão aos atendidos em diferentes projetos sociais.</segment>
    <segment id="18">A Escola Radical de Surfe</segment>
    <segment id="19">, de Santos</segment>
    <segment id="20">, a primeira escola pública do esporte</segment>
    <segment id="21">, coordenada por Cisco Araña</segment>
    <segment id="22">, fez a doação de uma prancha de surfe adaptada.</segment>
    <segment id="23">Adriano Pereira</segment>
    <segment id="24">, 35, veio de São Bernardo do Campo</segment>
    <segment id="25">, na Grande São Paulo</segment>
    <segment id="26">, para entrar no mar com a cadeira anfíbia - modelo de cadeira de rodas que tem a finalidade de permitir o acesso de um cadeirante à praia- algo que</segment>
    <segment id="27">, segundo ele</segment>
    <segment id="28">, foi pura diversão.</segment>
    <segment id="29">Adriano Pereira</segment>
    <segment id="30">, 35 anos</segment>
    <segment id="31">, de São Bernardo do Campo (ABC)</segment>
    <segment id="32">, entra no mar com cadeira anfíbia - Ronny Santos/Folhapress"A ideia é desenvolver autonomia e que eles façam parte de todos os espaços</segment>
    <segment id="33">, superando limites corporais.</segment>
    <segment id="34">Na verdade</segment>
    <segment id="35">, as limitações são nossas.</segment>
    <segment id="36">Eles se</segment>
    <segment id="37">se jogaram na água sem medo"</segment>
    <segment id="38">, diz Patrícia Caetano Borelli</segment>
    <segment id="39">, coordenadora da Residência Inclusiva da Praia Grande</segment>
    <segment id="40">, espaço que oferece acompanhamento para jovens</segment>
    <segment id="41">comocomo Alan Roger Torres</segment>
    <segment id="42">, 19, que tem deficiência intelectual.</segment>
    <segment id="43">"</segment>
    <segment id="44">Peguei três ondas</segment>
    <segment id="45">, quero ir de novo.</segment>
    <segment id="46">Quero a minha medalha"</segment>
    <segment id="47">, diz ele.</segment>
    <segment id="48">A alegria contagiou também voluntários e familiares presentes.</segment>
    <segment id="49">"</segment>
    <segment id="50">Ver meu sobrinho feliz dessa maneira não tem preço.</segment>
    <segment id="51">Eles têm as mesmas vontades e o mesmo direito de participar de tudo que as pessoas ditas 'normais' participam.</segment>
    <segment id="52">Por isso</segment>
    <segment id="53">, ações</segment>
    <segment id="54">comocomo essa são essenciais e nós</segment>
    <segment id="55">, como</segment>
    <segment id="56">como família</segment>
    <segment id="57">, abraçamos a causa"</segment>
    <segment id="58">, diz Shirlei Aparecida Rodio</segment>
    <segment id="59">, tia de Felipe Penarbel</segment>
    <segment id="60">, 24, jovem com síndrome de Down e que surfou pela primeira vez durante o evento.</segment>
    <segment id="61">Evento de esportes aquáticos promovido pela Apae Praia Grande</segment>
    <segment id="62">, ONG Adote um Cidadão</segment>
    <segment id="63">, em parceria com outras instituições.</segment>
    <segment id="64">O foco é que pessoas com deficiência tenham contato com esportes</segment>
    <segment id="65">, como</segment>
    <segment id="66">como surfe</segment>
    <segment id="67">, caiaque e cadeiras anfíbias - Ronny Santos/Folhapress"Só agradeço a Deus por existir pessoas que pensem em nós e nos proporcionem momentos</segment>
    <segment id="68">comocomo esses.</segment>
    <segment id="69">A sensação de liberdade que senti ao ficar em cima da prancha e poder sentir o vento no meu rosto é sensacional"</segment>
    <segment id="70">, afirma Júlia Dias Anjos</segment>
    <segment id="71">, 19, de Mauá</segment>
    <segment id="72">, na Grande São Paulo</segment>
    <segment id="73">, que tem baixa visão.</segment>
    <segment id="74">Evento ensina surfe para pessoas com deficiênciaMais    novamente         de   de  de  representando um  "</segment>
    <segment id="75">Para fazer esse projeto falo com as escolas de surfe de cada cidade.</segment>
    <segment id="76">A ideia é mostrar ao empreendedor que ele pode ajudar e fazer a diferença"</segment>
    <segment id="77">, afirma Antonio Carlos Veiga</segment>
    <segment id="78">, da ONG Adote um Cidadão e idealizador do projeto.</segment>
    <segment id="79">Ele conta que a instituição levou 59 pessoas com deficiência</segment>
    <segment id="80">, moradoras da capital e da Grande São Paulo</segment>
    <segment id="81">, para participar do evento na Praia Grande.</segment>
    <segment id="82">"</segment>
    <segment id="83">É emocionante ver a empolgação de todos eles.</segment>
    <segment id="84">Não só hoje</segment>
    <segment id="85">, masmas em todos os outros dias deveriam</segment>
    <segment id="86">sese sentir incluídos.</segment>
    <segment id="87">As instituições e as famílias lutam por isso</segment>
    <segment id="88">, masmas também precisamos de ações consistentes do poder público"</segment>
    <segment id="89">, afirma Sílvio Ursini</segment>
    <segment id="90">, superintendente da Apae da Praia Grande.</segment>
    <segment id="91">Gabriel Toledo</segment>
    <segment id="92">, 39, um dos organizadores do evento na cidade ressalta a falta de ajuda governamental.</segment>
    <segment id="93">"</segment>
    <segment id="94">Mas conversamos com diferentes parceiros e é gratificante ver o resultado.</segment>
    <segment id="95">Foram mais de 130 inscritos e não parava de chegar gente que ficou sabendo do evento por alguma mídia.</segment>
    <segment id="96">Isso nos motiva a continuar trabalhando pelo próximo.</segment>
    <segment id="97">"</segment>
  </rst>
</analysis>