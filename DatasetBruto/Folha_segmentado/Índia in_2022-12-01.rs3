  <rst>
    <segment id="1">As 17 presidências anteriores do G20 apresentaram resultados significativos para garantir a estabilidade macroeconômica</segment>
    <segment id="2">, racionalizar a tributação internacional</segment>
    <segment id="3">, aliviar a carga da dívida dos países</segment>
    <segment id="4">, entre muitos outros resultados.</segment>
    <segment id="5">Nós nos beneficiaremos dessas conquistas e continuaremos a desenvolvê-las.</segment>
    <segment id="6">Entretanto</segment>
    <segment id="7">, como</segment>
    <segment id="8">como a Índia assume este importante manto</segment>
    <segment id="9">, eu me pergunto: o G20 pode ir ainda mais longe?</segment>
    <segment id="10">Podemos catalisar uma mudança de mentalidade fundamental para beneficiar a humanidade</segment>
    <segment id="11">comocomo um todo?</segment>
    <segment id="12">Acredito que podemos.</segment>
    <segment id="13">O primeiro-ministro da Índia</segment>
    <segment id="14">, Narendra Modi</segment>
    <segment id="15">, chega à cúpula do G20 em Bali</segment>
    <segment id="16">, na Indonésia - Mast Irham - 15.nov.22/Pool/ReutersNossas mentalidades são moldadas por nossas circunstâncias.</segment>
    <segment id="17">Ao longo de toda a história</segment>
    <segment id="18">, a humanidade viveu na escassez.</segment>
    <segment id="19">Lutamos por recursos limitados</segment>
    <segment id="20">, porque</segment>
    <segment id="21">porque nossa sobrevivência dependia de negá-los aos outros.</segment>
    <segment id="22">O confronto e a competição –entre ideias</segment>
    <segment id="23">, ideologias e identidades– tornaram-</segment>
    <segment id="24">sese a norma.</segment>
    <segment id="25">Infelizmente</segment>
    <segment id="26">, ainda hoje continuamos presos à mesma mentalidade de soma zero.</segment>
    <segment id="27">Vemos isso quando os países lutam por território ou recursos.</segment>
    <segment id="28">Vemos isso quando suprimentos de bens essenciais viram armas.</segment>
    <segment id="29">Vemos isso quando vacinas são acumuladas por poucos</segment>
    <segment id="30">, mesmo quando bilhões seguem vulneráveis.</segment>
    <segment id="31">Alguns podem argumentar que o confronto e a ganância são apenas a natureza humana.</segment>
    <segment id="32">Discordo.</segment>
    <segment id="33">Se os seres humanos fossem inerentemente egoístas</segment>
    <segment id="34">, o que explicaria o apelo duradouro de tantas tradições espirituais que defendem a unicidade fundamental de todos nós?</segment>
    <segment id="35">Uma dessas tradições</segment>
    <segment id="36">, popular na Índia</segment>
    <segment id="37">, vê todos os seres vivos</segment>
    <segment id="38">, e até mesmo coisas inanimadas</segment>
    <segment id="39">, compostos pelos mesmos cinco elementos básicos: panch tatva de terra</segment>
    <segment id="40">, água</segment>
    <segment id="41">, fogo</segment>
    <segment id="42">, ar e espaço.</segment>
    <segment id="43">A harmonia entre esses elementos –dentro de nós e entre nós– é essencial para nosso bem-estar físico</segment>
    <segment id="44">, social e ambiental.</segment>
    <segment id="45">Lá foraReceba no seu email uma seleção semanal com o que de mais importante aconteceu no mundo</segment>
    <segment id="46">; aberta para não assinantes.</segment>
    <segment id="47">Carregando...</segment>
    <segment id="48">A presidência do G20 da Índia trabalhará para promover esse sentido universal de unicidade.</segment>
    <segment id="49">Daí nosso tema "</segment>
    <segment id="50">Uma Terra</segment>
    <segment id="51">, Uma Família</segment>
    <segment id="52">, Um Futuro".</segment>
    <segment id="53">Esse não é apenas um slogan.</segment>
    <segment id="54">Ele leva em conta as recentes mudanças nas circunstâncias humanas</segment>
    <segment id="55">, as quais não apreciamos coletivamente.</segment>
    <segment id="56">Hoje temos os meios para produzir o suficiente para atender às necessidades básicas de todas as pessoas no mundo.</segment>
    <segment id="57">Hoje não precisamos lutar por nossa sobrevivência</segment>
    <segment id="58">, então nossa era não precisa ser uma era de guerra.</segment>
    <segment id="59">De fato</segment>
    <segment id="60">, não deve ser uma!</segment>
    <segment id="61">Veja imagens da cúpula do G20Mais    novamente         de   de  de  representando um</segment>
    <segment id="62">Hoje os maiores desafios que enfrentamos –mudança climática</segment>
    <segment id="63">, terrorismo e pandemias– podem ser resolvidos não lutando uns contra os outros</segment>
    <segment id="64">, masmas somente agindo em conjunto.</segment>
    <segment id="65">Felizmente</segment>
    <segment id="66">, a tecnologia de hoje também nos dá os meios para enfrentar os problemas em escala humana.</segment>
    <segment id="67">Os enormes mundos virtuais que habitamos demonstram a escalabilidade das tecnologias digitais.</segment>
    <segment id="68">Habitando um sexto da humanidade e com sua imensa diversidade de línguas</segment>
    <segment id="69">, religiões</segment>
    <segment id="70">, costumes e crenças</segment>
    <segment id="71">, a Índia é um microcosmo do mundo.</segment>
    <segment id="72">Com as tradições mais antigas de tomada de decisão coletiva</segment>
    <segment id="73">, contribui para o DNA fundacional da democracia.</segment>
    <segment id="74">Como mãe da democracia</segment>
    <segment id="75">, o consenso nacional é forjado não pelo diktat</segment>
    <segment id="76">, masmas pela mistura de milhões de vozes livres em uma melodia harmoniosa.</segment>
    <segment id="77">Hoje, a Índia é a grande economia que mais cresce.</segment>
    <segment id="78">Nosso modelo de governança centrado no cidadão cuida até mesmo de nossos cidadãos mais marginalizados</segment>
    <segment id="79">, enquanto nutre o gênio criativo de nossa talentosa juventude.</segment>
    <segment id="80">Tentamos fazer do desenvolvimento nacional não um exercício de governança de cima para baixo</segment>
    <segment id="81">, masmas sim</segment>
    <segment id="82">um "movimento popular" liderado pelo cidadão.</segment>
    <segment id="83">Aproveitamos a tecnologia para criar bens públicos digitais que sejam abertos</segment>
    <segment id="84">, inclusivos e interoperáveis.</segment>
    <segment id="85">Estes têm proporcionado progressos revolucionários em campos tão variados</segment>
    <segment id="86">comocomo a proteção social</segment>
    <segment id="87">, a inclusão financeira e os pagamentos eletrônicos.</segment>
    <segment id="88">Por todas essas razões</segment>
    <segment id="89">, as experiências da Índia podem fornecer insights para possíveis soluções globais.</segment>
    <segment id="90">Reunião do Brics em BrasíliaMais    novamente         de   de  de  representando um</segment>
    <segment id="91">Durante nossa presidência do G20</segment>
    <segment id="92">, apresentaremos as experiências</segment>
    <segment id="93">, aprendizagens e modelos da Índia</segment>
    <segment id="94">comocomo possíveis modelos para outros</segment>
    <segment id="95">, particularmente para o mundo em desenvolvimento.</segment>
    <segment id="96">Nossas prioridades do G20 serão moldadas em consulta não apenas com nossos parceiros do G20</segment>
    <segment id="97">, masmas também com nossos companheiros de viagem no Sul Global</segment>
    <segment id="98">, cuja voz muitas vezes não é ouvida.</segment>
    <segment id="99">Nossas prioridades</segment>
    <segment id="100">sese concentrarão na cura de nossa "</segment>
    <segment id="101">Uma Terra"</segment>
    <segment id="102">, criando harmonia dentro de nossa "</segment>
    <segment id="103">Uma Família" e dando esperança para o nosso "</segment>
    <segment id="104">Um Futuro".</segment>
    <segment id="105">Para curar nosso planeta</segment>
    <segment id="106">, incentivaremos estilos de vida sustentáveis e ecológicos</segment>
    <segment id="107">, com base na tradição indiana de confiança em relação à natureza.</segment>
    <segment id="108">Para promover a harmonia dentro da família humana</segment>
    <segment id="109">, procuraremos despolitizar o fornecimento global de alimentos</segment>
    <segment id="110">, fertilizantes e produtos médicos</segment>
    <segment id="111">, para que</segment>
    <segment id="112">para que as tensões geopolíticas não levem a crises humanitárias.</segment>
    <segment id="113">Como em nossas próprias famílias</segment>
    <segment id="114">, aqueles cujas necessidades são as maiores devem ser sempre nossa primeira preocupação.</segment>
    <segment id="115">Para imbuir esperança em nossas futuras gerações</segment>
    <segment id="116">, incentivaremos uma conversa honesta entre os países mais poderosos sobre a mitigação dos riscos representados pelas armas de destruição em massa e o aumento da segurança global.</segment>
    <segment id="117">A agenda do G20 da Índia será inclusiva</segment>
    <segment id="118">, ambiciosa</segment>
    <segment id="119">, decisiva e orientada para a ação.</segment>
    <segment id="120">Juntemo-nos para fazer da Presidência indiana do G20 uma Presidência de cura</segment>
    <segment id="121">, harmonia e esperança.</segment>
    <segment id="122">Vamos trabalhar juntos para moldar um novo paradigma: o da globalização centrada no ser humano.</segment>
  </rst>
</analysis>