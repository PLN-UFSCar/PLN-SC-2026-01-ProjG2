  <rst>
    <segment id="1">Com uma programação que aposta na música negra —com clima dançante e indo do underground ao mainstream— o MBora Fest surge com o objetivo de valorizar a diversidade da música contemporânea brasileira.</segment>
    <segment id="2">O evento que tem sua primeira edição acontece nesta sexta-feira</segment>
    <segment id="3">, dia 3 de junho</segment>
    <segment id="4">, a partir das 22h</segment>
    <segment id="5">, no Carioca Club.</segment>
    <segment id="6">Veja as atrações do MBora FestMais    novamente         de   de  de  representando um</segment>
    <segment id="7">Entre os principais nomes do line-up aparece o rapper FBC</segment>
    <segment id="8">, dono do hit "</segment>
    <segment id="9">Se Tá Solteira"</segment>
    <segment id="10">, Heavy Baile</segment>
    <segment id="11">, responsável por animar a pista com músicas cheias de suingue e o funkeiro Nego Bala</segment>
    <segment id="12">, cantor que traz em seus versos a visão de quem saiu da Cracolândia.</segment>
    <segment id="13">Evehive</segment>
    <segment id="14">, Mari Mats e Odara Kadiegi também estão entre os artistas convidados.</segment>
    <segment id="15">Naiá Camargo</segment>
    <segment id="16">, sócia e idealizadora do evento</segment>
    <segment id="17">, lembra que o funk por mais que ainda sofra preconceito</segment>
    <segment id="18">, tem ocupado as pistas mais badaladas de São Paulo.</segment>
    <segment id="19">"</segment>
    <segment id="20">Queremos ocupar os palcos da cidade com variedade de nomes já consagrados no ritmo.</segment>
    <segment id="21">A ideia do MBora Fest é destacar aqueles músicos que muitas vezes não ganham espaço nos grandes eventos do país"</segment>
    <segment id="22">, afirma Camargo.</segment>
    <segment id="23">Quem for curtir o evento vai precisar desembolsar entre R$ 40 a R$ 240.</segment>
    <segment id="24">Existe também a entrada social</segment>
    <segment id="25">, para participar</segment>
    <segment id="26">, basta doar um quilo de alimento e o valor cobrado será o da meia-entrada do lote vigente.</segment>
    <segment id="27">Para a próximo edição</segment>
    <segment id="28">, a promessa é de movimentar outros ritmos negros</segment>
    <segment id="29">comocomo trap</segment>
    <segment id="30">, grime e soul.</segment>
    <segment id="31">MBora FestQuando Sexta-feira</segment>
    <segment id="32">, dia 3 de junho</segment>
    <segment id="33">, a partir das 22hOnde Carioca Club:</segment>
    <segment id="34">R. Cardeal Arcoverde</segment>
    <segment id="35">, 2899</segment>
    <segment id="36">, Pinheiros</segment>
    <segment id="37">, região oestePreço</segment>
    <segment id="38">De R$40 à R$240.</segment>
    <segment id="39">Na doação de um quilo de alimento</segment>
    <segment id="40">, paga-</segment>
    <segment id="41">sese o valor da meia-entrada do lote vigenteClassificação 18 anosLink: https://www.instagram.com/mborafest/</segment>
