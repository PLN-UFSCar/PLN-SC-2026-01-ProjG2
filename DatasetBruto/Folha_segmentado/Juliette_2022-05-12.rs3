  <rst>
    <segment id="1">Pouco antes de entrar no Big Brother Brasil 2021</segment>
    <segment id="2">, reality do qual sairia campeã</segment>
    <segment id="3">, Juliette Freire</segment>
    <segment id="4">sese dividia entre estudar para passar em concursos</segment>
    <segment id="5">, fazer trabalhos</segment>
    <segment id="6">comocomo advogada ou</segment>
    <segment id="7">sese dedicar a um salão de beleza.</segment>
    <segment id="8">Pouco mais de um ano depois de levar o prêmio de R$ 1</segment>
    <segment id="9">,5 milhão</segment>
    <segment id="10">, ela diz que trabalha ainda mais agora</segment>
    <segment id="11">, que tem a agenda cheia —produz conteúdo para as redes sociais</segment>
    <segment id="12">, faz peças publicitárias</segment>
    <segment id="13">, tem o dia lotado de compromissos e</segment>
    <segment id="14">, agora</segment>
    <segment id="15">, cuida da voz e ensaia para sua primeira turnê.</segment>
    <segment id="16">A cantora Juliette Freire</segment>
    <segment id="17">, vencedora do BBB 21 - Igor Melo/Divulgação"Eu ficava pensando ‘meu Deus</segment>
    <segment id="18">, quando eu conseguir chegar aonde quero</segment>
    <segment id="19">, ter dinheiro e tudo mais</segment>
    <segment id="20">, vou viajar</segment>
    <segment id="21">, passear</segment>
    <segment id="22">, fazer festa</segment>
    <segment id="23">, curtir a vida'.</segment>
    <segment id="24">E não é assim.</segment>
    <segment id="25">Quanto mais famosa</segment>
    <segment id="26">, mais trabalho.</segment>
    <segment id="27">E quanto mais dinheiro</segment>
    <segment id="28">, mais trabalho.</segment>
    <segment id="29">E assim vai.</segment>
    <segment id="30">Isso é diferente do que eu imaginava.</segment>
    <segment id="31">"  Vencedora de uma das edições de maior audiência do programa</segment>
    <segment id="32">, Juliette reuniu uma legião de fãs fervorosos em sua passagem pelo BBB</segment>
    <segment id="33">, onde costumava soltar a voz nas festas.</segment>
    <segment id="34">As cantorias viralizaram nas redes sociais e</segment>
    <segment id="35">, quando ela saiu da casa mais vigiada do Brasil</segment>
    <segment id="36">, transformou a brincadeira em carreira —sua turnê de estreia chega a São Paulo nesta sexta-feira.</segment>
    <segment id="37">"</segment>
    <segment id="38">Nunca foi um plano ter uma carreira de cantora"</segment>
    <segment id="39">, ela diz.</segment>
    <segment id="40">"</segment>
    <segment id="41">Nunca me imaginei sendo cantora.</segment>
    <segment id="42">Eu cantava com os meus amigos</segment>
    <segment id="43">, brincando.</segment>
    <segment id="44">Mas, quando saí do programa e vi que as pessoas me reconheceram</segment>
    <segment id="45">comocomo cantora</segment>
    <segment id="46">, fiquei lisonjeada e muito surpresa.</segment>
    <segment id="47">"</segment>
    <segment id="48">Logo que saiu do BBB</segment>
    <segment id="49">, ela soube que tinha um EP inteiro pronto</segment>
    <segment id="50">, feito com a ajuda de Anitta</segment>
    <segment id="51">, só faltando pôr a sua voz.</segment>
    <segment id="52">"</segment>
    <segment id="53">Meus produtores e sócios são meus amigos</segment>
    <segment id="54">, era com eles que eu ficava cantando violão e tomando uma cervejinha.</segment>
    <segment id="55">Eles sabiam do que eu gostava.</segment>
    <segment id="56">Apresentaram esse projeto à Anitta</segment>
    <segment id="57">, que aprovou e construiu junto com eles.</segment>
    <segment id="58">"  Imagens da maquiadora Juliette FreireMais    novamente         de   de  de  representando um  Juliette escolheu as músicas de que mais gostou das que foram apresentadas</segment>
    <segment id="59">, fez ajustes nas letras</segment>
    <segment id="60">, trocou instrumentos e arranjos e</segment>
    <segment id="61">, enfim</segment>
    <segment id="62">, acrescentou sua voz às faixas.</segment>
    <segment id="63">Mas ela teve de botar um freio nos planos de virar cantora.</segment>
    <segment id="64">"</segment>
    <segment id="65">Puxei o freio de mão.</segment>
    <segment id="66">Não saí tão bem psicologicamente.</segment>
    <segment id="67">Não estava preparada.</segment>
    <segment id="68">Mudamos o ritmo</segment>
    <segment id="69">, foi mais lento</segment>
    <segment id="70">, para eu fazer as coisas com mais calma"</segment>
    <segment id="71">, diz.</segment>
    <segment id="72">"</segment>
    <segment id="73">Quando você sai</segment>
    <segment id="74">, especialmente na proporção que eu estava</segment>
    <segment id="75">, é assustador.</segment>
    <segment id="76">Você fica</segment>
    <segment id="77">, ‘caramba</segment>
    <segment id="78">, o que as pessoas esperam de mim</segment>
    <segment id="79">, como</segment>
    <segment id="80">como posso acrescentar?</segment>
    <segment id="81">'.</segment>
    <segment id="82">Estava nesse processo psicológico de recuperar o que eu tinha perdido de juízo no programa.</segment>
    <segment id="83">"  Batizado 'Juliette'</segment>
    <segment id="84">, o EP foi lançado depois que a ex-BBB já tinha cantado em lives de gente</segment>
    <segment id="85">comocomo Gilberto Gil</segment>
    <segment id="86">, Elba Ramalho e Wesley Safadão.</segment>
    <segment id="87">As músicas são baseadas no forró</segment>
    <segment id="88">, masmas passeiam também pela MPB e pelo sertanejo</segment>
    <segment id="89">, incluindo várias baladas</segment>
    <segment id="90">, algo que reflete o momento de introspecção pelo qual ela estava passando depois de sair do programa.  "</segment>
    <segment id="91">Tanto é que minhas músicas são mais calmas.</segment>
    <segment id="92">Estou mais retraída.</segment>
    <segment id="93">Se você pegar eu cantando as músicas no EP e me ver cantando hoje no meu show</segment>
    <segment id="94">, você vai ver outra música.</segment>
    <segment id="95">Hoje, canto de peito aberto</segment>
    <segment id="96">, canto cada palavra com o sentido que ela realmente merece.</segment>
    <segment id="97">Antes eu estava fechadinha</segment>
    <segment id="98">, vulnerável e calma</segment>
    <segment id="99">, digamos assim</segment>
    <segment id="100">, quietinha.</segment>
    <segment id="101">"  Depois de sair do BBB</segment>
    <segment id="102">, Juliette estava frágil psicologicamente</segment>
    <segment id="103">, vivendo uma avalanche de trabalho</segment>
    <segment id="104">, com medo da pandemia e muita insônia.</segment>
    <segment id="105">Ela diz que esse período durou cerca de seis meses</segment>
    <segment id="106">, masmas a experiência que teve vai deixar marcas para sempre.</segment>
    <segment id="107">"</segment>
    <segment id="108">Depois eu fui me reconectando</segment>
    <segment id="109">, masmas nada é 100%.</segment>
    <segment id="110">Acho que uma pessoa que participa de um reality nunca mais fica normal.</segment>
    <segment id="111">Mas estou bem mais segura e confortável nessa vida agora.</segment>
    <segment id="112">"  No show</segment>
    <segment id="113">, ela faz homenagens a artistas nordestinos mais clássicos</segment>
    <segment id="114">, como</segment>
    <segment id="115">como Luiz Gonzaga e Dominguinhos</segment>
    <segment id="116">, canta Chico César e também Duda Beat e Marina Sena</segment>
    <segment id="117">, entre outros.</segment>
    <segment id="118">Seu estilo</segment>
    <segment id="119">, ela diz</segment>
    <segment id="120">, é uma mistura do que escuta</segment>
    <segment id="121">, algo entre a MPB</segment>
    <segment id="122">, o forró e o pop.</segment>
    <segment id="123">"</segment>
    <segment id="124">Se eu tivesse um potinho</segment>
    <segment id="125">, colocaria um pedacinho de Caetano</segment>
    <segment id="126">, um pedaço de Gil</segment>
    <segment id="127">, de Anitta</segment>
    <segment id="128">, de Ivete</segment>
    <segment id="129">, de Maria Gadú</segment>
    <segment id="130">, de Chico César</segment>
    <segment id="131">, de Paralamas do Sucesso.</segment>
    <segment id="132">Minha identidade é formada dessa mistura.</segment>
    <segment id="133">Não preciso ser só a cantora que senta no banquinho e canta Gil e Caetano.</segment>
    <segment id="134">Também posso descer a bunda até o chão.</segment>
    <segment id="135">"  Se depender do afã dos cactos</segment>
    <segment id="136">, como</segment>
    <segment id="137">como são conhecidos seus seguidores</segment>
    <segment id="138">, para multiplicar os plays no streaming e comprar ingressos</segment>
    <segment id="139">, a carreira musical de Juliette não deve ter problemas para decolar.</segment>
    <segment id="140">Ela, porém</segment>
    <segment id="141">porém, conta que esses fãs muitas vezes</segment>
    <segment id="142">sese excedem em sua defesa e diz que muitas vezes age</segment>
    <segment id="143">comocomo mãe deles.</segment>
    <segment id="144">"</segment>
    <segment id="145">Quando eu acho que passa do limite</segment>
    <segment id="146">, que passa do saudável</segment>
    <segment id="147">, eu intervenho rapidamente.</segment>
    <segment id="148">Vejo meus fãs buscando valores positivos</segment>
    <segment id="149">, masmas há uma pequena parcela que existe e precisa ser instruída</segment>
    <segment id="150">, acolhida e repreendida.</segment>
    <segment id="151">Quando eles têm boas atitudes</segment>
    <segment id="152">, eu exalto e apoio.</segment>
    <segment id="153">É como</segment>
    <segment id="154">como uma mãe faz com os filhos.</segment>
    <segment id="155">Nem sempre os filhos vão ter boas atitudes.</segment>
    <segment id="156">A gente tem que educar e repreender.</segment>
    <segment id="157">"</segment>
    <segment id="158">Hoje com um a visibilidade gigante —só no Instagram</segment>
    <segment id="159">, ela é seguida por mais de 30 milhões de pessoas—</segment>
    <segment id="160">, Juliette diz que entende a responsabilidade que carrega e toma cuidados ao</segment>
    <segment id="161">sese comunicar.</segment>
    <segment id="162">Nas próximas eleições</segment>
    <segment id="163">, acredita que pode usar essa voz para</segment>
    <segment id="164">sese posicionar "em prol da sociedade".</segment>
    <segment id="165">Sobre seu voto</segment>
    <segment id="166">, diz que está "analisando o cenário".</segment>
    <segment id="167">"</segment>
    <segment id="168">A minha posição é contra Bolsonaro sempre.</segment>
    <segment id="169">Já falei isso explicitamente</segment>
    <segment id="170">, falo inclusive nas minhas músicas.</segment>
    <segment id="171">Não apoio a postura dele.</segment>
    <segment id="172">Então, por enquanto</segment>
    <segment id="173">, esse é meu único posicionamento.</segment>
    <segment id="174">"  Juliette em São PauloQuando 13 de maio (sexta)Onde Espaço Unimed - r. Tagipuru</segment>
    <segment id="175">, 795, Barra Funda</segment>
    <segment id="176">, zona oestePreço ingressos disponíveis a partir de R$ 140</segment>
  </rst>
</analysis>