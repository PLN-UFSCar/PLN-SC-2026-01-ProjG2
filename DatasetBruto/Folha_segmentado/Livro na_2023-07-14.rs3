  <rst>
    <segment id="1">Faz pelo menos três décadas que o professor e pesquisador João Roberto Faria</segment>
    <segment id="2">, mergulhado em pesquisas sobre a produção teatral do século 19</segment>
    <segment id="3">, sese depara com o tema da escravidão refletido em obras</segment>
    <segment id="4">, declarações e manifestos pró-abolição de uma série de autores</segment>
    <segment id="5">, como</segment>
    <segment id="6">como Ruy Barbosa e Machado de Assis.</segment>
    <segment id="7">Presente de forma lateral em todas as pesquisas e</segment>
    <segment id="8">, por consequência</segment>
    <segment id="9">, em alguns de seus livros</segment>
    <segment id="10">, como</segment>
    <segment id="11">como "</segment>
    <segment id="12">O Teatro Realista no Brasil" e "Ideias</segment>
    <segment id="13">Teatrais:</segment>
    <segment id="14">O Século XIX no Brasil"</segment>
    <segment id="15">, de 1993 e de 2001</segment>
    <segment id="16">, respectivamente</segment>
    <segment id="17">, o tema ganha um estudo para chamar de seu com a publicação de "Teatro e Escravidão no Brasil"</segment>
    <segment id="18">, posto nas prateleiras pela editora Perspectiva.</segment>
    <segment id="19">Capa do livro &amp;#039</segment>
    <segment id="20">;Teatro e Escravidão no Brasil&amp;#039</segment>
    <segment id="21">;, de João Roberto Faria - DivulgaçãoNa obra</segment>
    <segment id="22">, Faria não apenas aprofunda o tema dentro da seara teatral</segment>
    <segment id="23">, masmas expande sua área de pesquisa</segment>
    <segment id="24">, limitada em obras anteriores apenas ao Rio de Janeiro</segment>
    <segment id="25">, e, neste livro</segment>
    <segment id="26">, chegando às regiões sul</segment>
    <segment id="27">, norte e nordeste do Brasil</segment>
    <segment id="28">, onde</segment>
    <segment id="29">sese produzia um teatro sem a mesma visibilidade histórica que eram dadas às encenações na então capital do país</segment>
    <segment id="30">, masmas igualmente importantes na visão do autor.</segment>
    <segment id="31">"</segment>
    <segment id="32">Cerca de cem peças abordaram essa questão e</segment>
    <segment id="33">, sem falsa modéstia</segment>
    <segment id="34">, até então ninguém tinha feito esse levantamento"</segment>
    <segment id="35">, diz o autor</segment>
    <segment id="36">, que se</segment>
    <segment id="37">se debruçou não apenas sobre a análise das obras</segment>
    <segment id="38">, masmas sobre sua repercussão na imprensa e em publicações de articuladores e intelectuais de uma época em que o teatro era o centro do entretenimento brasileiro.</segment>
    <segment id="39">Faria recupera dados de um órgão responsável por censurar textos que não estivessem de acordo com a moral e com as regras da época</segment>
    <segment id="40">, impedindo que ganhassem montagem.</segment>
    <segment id="41">Nomeado Conservatório Dramático Brasileiro</segment>
    <segment id="42">, era formado por nomes</segment>
    <segment id="43">comocomo Gonçalves de Magalhães</segment>
    <segment id="44">, Martins Pena</segment>
    <segment id="45">, Araújo Porto Alegre</segment>
    <segment id="46">, José de Alencar e um jovem Machado de Assis</segment>
    <segment id="47">, entre outros.</segment>
    <segment id="48">Relatos de americanos escravizadosMais    novamente         de   de  de  representando um  "Não é preciso dizer que a escravidão era um assunto delicado para ser colocado no palco.</segment>
    <segment id="49">Martins Pena</segment>
    <segment id="50">, que teve várias comédias representadas de 1844 a 1864</segment>
    <segment id="51">, não foi censurado provavelmente</segment>
    <segment id="52">porque</segment>
    <segment id="53">porque suas críticas relativas ao tráfico ilícito</segment>
    <segment id="54">, à dureza do trabalho no campo</segment>
    <segment id="55">, a um ou outro castigo físico</segment>
    <segment id="56">, aos vigaristas que enganavam os negros de ganho e aos vendedores de escravos sequestrados de seus donos não foram percebidas pelos seus contemporâneos</segment>
    <segment id="57">comocomo denúncia vigorosa</segment>
    <segment id="58">, capaz de mexer com a sensibilidade do espectador"</segment>
    <segment id="59">, escreve o autor.</segment>
    <segment id="60">Entre os cem textos resgatados para o livro</segment>
    <segment id="61">, Faria acredita ter tido a chance de</segment>
    <segment id="62">sese debruçar em material senão inédito</segment>
    <segment id="63">, ao menos muito raro</segment>
    <segment id="64">, que ainda não havia recebido análise ou atenção de colegas</segment>
    <segment id="65">, num processo que durou cinco anos e envolveu desde pesquisas em acervos de jornais e bibliotecas</segment>
    <segment id="66">, até a entrada em leilões online para adquirir obras até então indisponíveis.</segment>
    <segment id="67">"</segment>
    <segment id="68">E durante as pesquisas descobri que muita coisa sequer foi publicada</segment>
    <segment id="69">, ou que os textos das encenações que não aconteceram não eram sempre guardados.</segment>
    <segment id="70">O livro dá um panorama do papel do teatro</segment>
    <segment id="71">comocomo um agente crítico da escravidão</segment>
    <segment id="72">, da lei do ventre livre e até mesmo do processo de abolição em certa medida"</segment>
    <segment id="73">, diz.</segment>
    <segment id="74">Veja imagens de Machado de AssisMais    novamente         de   de  de  representando um  Faria</segment>
    <segment id="75">, contudo</segment>
    <segment id="76">contudo</segment>
    <segment id="77">, deixa claro que há uma diferença entre o fato de os espetáculos serem uma forma de protesto e crítica à escravidão e o processo que culminaria</segment>
    <segment id="78">, no século seguinte</segment>
    <segment id="79">, nas lutas antirracistas.</segment>
    <segment id="80">Não havia atores negros em cena.</segment>
    <segment id="81">"</segment>
    <segment id="82">O que havia na verdade eram atrizes</segment>
    <segment id="83">, algumas europeias</segment>
    <segment id="84">, fazendo uso da blackface"</segment>
    <segment id="85">, diz, referindo-</segment>
    <segment id="86">sese à prática de um ator branco pintar o corpo de preto para interpretar uma personagem negra</segment>
    <segment id="87">, muitas vezes de forma caricata.</segment>
    <segment id="88">O máximo que a pesquisa pôde apontar sobre a participação de pessoas pretas nas produções foi durante a encenação de "</segment>
    <segment id="89">comocomo</segment>
    <segment id="90">sese Fazia um Deputado"</segment>
    <segment id="91">, de França Júnior</segment>
    <segment id="92">, onde foram chamadas pessoas negras para compor o coro para dançar durante uma cena de festa para dar mais realismo à montagem</segment>
    <segment id="93">, masmas nenhuma delas profissional.</segment>
    <segment id="94">"</segment>
    <segment id="95">Guardadas as devidas proporções</segment>
    <segment id="96">, é possível enxergar indiretamente uma relação entre aquele momento antiescravista com as lutas sociais hoje.</segment>
    <segment id="97">São todos movimentos em busca de um país menos desigual</segment>
    <segment id="98">, masmas não acho possível comparar esses dois momentos buscando ecos de um movimento ou outro.</segment>
    <segment id="99">"  Teatro e Escravidão no BrasilPreço R$ 104</segment>
    <segment id="100">,90 (416 págs.)</segment>
    <segment id="101">; R$ 74</segment>
    <segment id="102">,90 (ebook)Autoria José Roberto FariaEditora Perspectiva</segment>
  </rst>
</analysis>