  <rst>
    <segment id="1">A Academia de Artes e Ciências Televisivas dos Estados Unidos anunciou na noite desta segunda-feira (12) os vencedores da 74ª edição do Primetime Emmy Awards</segment>
    <segment id="2">, o principal prêmio da indústria americana de televisão e streaming.</segment>
    <segment id="3">Quem saiu na frente não foi uma série de drama ou de comédia</segment>
    <segment id="4">, masmas uma minissérie.</segment>
    <segment id="5">"</segment>
    <segment id="6">The White Lotus" confirmou seu favoritismo e não só embolsou a estatueta principal da seção</segment>
    <segment id="7">, como</segment>
    <segment id="8">como também as de direção</segment>
    <segment id="9">, roteiro</segment>
    <segment id="10">, ator coadjuvante e atriz coadjuvante —para Murray Bartlett e Jennifer Coolidge.</segment>
    <segment id="11">Detalhe do cartaz da terceira temporada da série &amp;quot</segment>
    <segment id="12">;Succession&amp;quot</segment>
    <segment id="13">; - DivulgaçãoNa disputa de drama</segment>
    <segment id="14">, "</segment>
    <segment id="15">Round 6" venceu mais prêmios que "Succession"</segment>
    <segment id="16">, masmas foi passada para trás na categoria de melhor série do gênero.</segment>
    <segment id="17">A sul-coreana</segment>
    <segment id="18">, no entanto</segment>
    <segment id="19">, fez história só por ser indicada e novamente ao receber o prêmio de ator</segment>
    <segment id="20">, para Lee Jung-jae.</segment>
    <segment id="21">Ele é o primeiro de uma série em língua não inglesa a triunfar na categoria.</segment>
    <segment id="22">"</segment>
    <segment id="23">Round 6" também levou direção</segment>
    <segment id="24">, direção de arte</segment>
    <segment id="25">, performance de dublês</segment>
    <segment id="26">, efeitos especiais e atriz convidada</segment>
    <segment id="27">, para Lee You-mi.</segment>
    <segment id="28">"</segment>
    <segment id="29">Succession" ficou com melhor drama</segment>
    <segment id="30">, ator coadjuvante</segment>
    <segment id="31">, para Matthew Macfadyen</segment>
    <segment id="32">, e roteiro.</segment>
    <segment id="33">Os melhores e os piores looks do Emmy 2022Mais    novamente         de   de  de  representando um  Leia maisEmmy</segment>
    <segment id="34">Awards 2022 recusa onda sul-coreana e premia &amp;#039</segment>
    <segment id="35">;Succession&amp;#039</segment>
    <segment id="36">;Emmy Awards 2022 atira a todos os lados</segment>
    <segment id="37">, com falta de catarse coletivaVeja fotos dos melhores e piores looks do Oscar da televisãoSaiba onde ver os indicados e premiados do Emmy 2022</segment>
    <segment id="38">Em comédia</segment>
    <segment id="39">, "</segment>
    <segment id="40">Ted Lasso" confirmou o favoritismo com vitórias em melhor série do gênero</segment>
    <segment id="41">, ator para Jason Sudeikis</segment>
    <segment id="42">, ator coadjuvante para Brett Goldstein e direção.</segment>
    <segment id="43">Também vale mencionar a vitória de Zendaya</segment>
    <segment id="44">comocomo atriz em série dramática</segment>
    <segment id="45">, por "Euphoria".</segment>
    <segment id="46">Este é seu segundo troféu na categoria</segment>
    <segment id="47">, pela mesma série</segment>
    <segment id="48">, e a tornou a atriz mais jovem a ser premiada duas vezes com o Emmy.  Imagens da atrizZendayaMais    novamente         de   de  de  representando um  Confira abaixo a lista de premiados na cerimônia nesta segunda e</segment>
    <segment id="49">, no site do Emmy</segment>
    <segment id="50">, a relação completa de troféus entregues no Creative Arts Emmy.    Série dramática</segment>
    <segment id="51">"</segment>
