  <rst>
    <segment id="1">Beneficiários do Auxílio Brasil reclamam de descontos indevidos ou antecipados no extrato de pagamento do benefício de novembro</segment>
    <segment id="2">, que será depositado entre os dias 17 e 30 deste mês.</segment>
    <segment id="3">Há queixas de pessoas que não solicitaram o empréstimo</segment>
    <segment id="4">, masmas estão com descontos programados.</segment>
    <segment id="5">Também há relatos de beneficiários que pediram o crédito</segment>
    <segment id="6">, masmas contavam que a primeira parcela só seria debitada em dezembro</segment>
    <segment id="7">, como</segment>
    <segment id="8">como estava detalhado no contrato.</segment>
    <segment id="9">Paola de Carvalho</segment>
    <segment id="10">, diretora da Rede Brasileira de Renda Básica</segment>
    <segment id="11">, diz estar recebendo diversas reclamações.</segment>
    <segment id="12">Segundo ela</segment>
    <segment id="13">, em muitos casos</segment>
    <segment id="14">, os extratos de pagamento indicam um desconto de R$ 160 já neste mês</segment>
    <segment id="15">, o que surpreendeu muitas pessoas.</segment>
    <segment id="16">Thais Salino</segment>
    <segment id="17">, 29, é uma delas.</segment>
    <segment id="18">Atualmente desempregada</segment>
    <segment id="19">, ela afirma que não pediu o empréstimo consignado vinculado ao Auxílio Brasil</segment>
    <segment id="20">, masmas o aplicativo da Caixa mostra um débito no valor a ser pago em novembro.</segment>
    <segment id="21">"</segment>
    <segment id="22">Vi no aplicativo</segment>
    <segment id="23">Caixa Tem</segment>
    <segment id="24">, na opção de contratos</segment>
    <segment id="25">, que consta um contrato que eu desconheço e está em processamento"</segment>
    <segment id="26">,</segment>
    <segment id="27">diz.</segment>
    <segment id="28">Fila em agência da Caixa Econômica Federal na zona leste de São Paulo</segment>
    <segment id="29">, em dia de pagamento do Auxílio Brasil - Rivaldo Gomes - 11.out.2022/FolhapressAo tentar cancelar</segment>
    <segment id="30">, ela diz que aparece a mensagem de que é preciso esperar sete dias após a contratação para fazer a suspensão.</segment>
    <segment id="31">A captura de tela feita por Salino mostra os detalhes do contrato e</segment>
    <segment id="32">, mesmo que ela tivesse solicitado o crédito</segment>
    <segment id="33">, consta que a primeira parcela deveria ser feita em dezembro.</segment>
    <segment id="34">Salino afirma que não conseguiu resolver o problema pelo SAC da Caixa. "</segment>
    <segment id="35">Se eu não conseguir [cancelar o contrato em sete dias] vou até a Caixa Econômica"</segment>
    <segment id="36">, diz.</segment>
    <segment id="37">Captura de tela feita por Thais Salino mostra mensagem de erro ao tentar cancelar contrato de empréstimo que ela diz não ter solicitado</segment>
    <segment id="38">; dados mostram que a primeira parcela deveria acontecer apenas em dezembro - ReproduçãoGoverno e Caixa dizem que não há carência para início dos descontos</segment>
    <segment id="39">Sobre o início dos débitos</segment>
    <segment id="40">, o Ministério da Cidadania informou que</segment>
    <segment id="41">, na folha de pagamento do auxílio referente a novembro</segment>
    <segment id="42">, serão descontados os empréstimos contratados entre 10 de outubro e 1º de novembro e que todos os beneficiários que tiverem desconto serão avisados por mensagem no extrato.</segment>
    <segment id="43">A Caixa informou que é o agente operador do Auxílio Brasil e que os descontos obedecem a averbação feita pelos bancos junto à Dataprev.</segment>
    <segment id="44">Segundo a Cidadania e a Caixa</segment>
    <segment id="45">, o primeiro desconto ocorre no primeiro mês subsequente ao do envio das informações pelas instituições financeiras</segment>
    <segment id="46">, conforme regulamentação.</segment>
    <segment id="47">Os beneficiários podem entrar em contato diretamente na instituição onde o empréstimo foi contratado ou registrar uma contestação no site consumidor.gov.br</segment>
    <segment id="48">, informou a Cidadania.</segment>
    <segment id="49">A Caixa afirmou que</segment>
    <segment id="50">, em cumprimento ao sigilo bancário</segment>
    <segment id="51">, as informações sobre os casos específicos relatados pela reportagem serão fornecidas diretamente aos clientes.</segment>
    <segment id="52">Caso o beneficiário não reconheça o empréstimo consignado em seu benefício</segment>
    <segment id="53">, a Caixa orienta que seja procurado o banco em que o contrato foi feito para verificação.</segment>
    <segment id="54">A informação do banco pode ser obtida junto ao Ministério da Cidadania</segment>
    <segment id="55">, por meio do telefone 121.</segment>
    <segment id="56">Se o contrato foi feito com a Caixa</segment>
    <segment id="57">, o cliente pode ir a uma agência com o CPF e um documento de identificação com foto.</segment>
    <segment id="58">Recepcionista teve pedido cancelado e diz que não recebeu dinheiro  Thais Viana</segment>
    <segment id="59">, 28, também diz ter sido surpreendida ao olhar o extrato deste mês.</segment>
    <segment id="60">"</segment>
    <segment id="61">Geralmente o aplicativo mostra os R$ 400</segment>
    <segment id="62">, além dos R$ 200 [complementares].</segment>
    <segment id="63">Neste mês</segment>
    <segment id="64">, estava só R$ 254</segment>
    <segment id="65">, sendo que eu não fiz empréstimo.</segment>
    <segment id="66">Eu até tentei</segment>
    <segment id="67">, masmas foi cancelado.</segment>
    <segment id="68">Não recebi dinheiro nenhum"</segment>
    <segment id="69">, reclama.  Recepcionista no Rio de Janeiro</segment>
    <segment id="70">, Viana diz que tentou contato pelos números fornecidos pela Caixa</segment>
    <segment id="71">, masmas não consegue passar da etapa de atendimento eletrônico.</segment>
    <segment id="72">"</segment>
    <segment id="73">Trabalho das 8h às 18h</segment>
    <segment id="74">, ir na agência é complicado"</segment>
    <segment id="75">, diz.</segment>
    <segment id="76">Captura de tela mostra valor programado para novembro com desconto de R$ 160 - ReproduçãoQuem também reclama de cobrança indevida é a auxiliar administrativa Rosilene Silva</segment>
    <segment id="77">, 28.</segment>
    <segment id="78">Ela diz ter solicitado o empréstimo no último dia 25</segment>
    <segment id="79">, o qual foi aprovado.</segment>
    <segment id="80">No entanto</segment>
    <segment id="81">, na última sexta-feira (4)</segment>
    <segment id="82">, o contrato desapareceu da seção onde deveria constar —</segment>
    <segment id="83">embora</segment>
    <segment id="84">embora a primeira parcela já esteja programada.</segment>
    <segment id="85">"</segment>
    <segment id="86">No aplicativo do Auxílio veio o desconto do empréstimo</segment>
    <segment id="87">, sendo que eu nem peguei [o dinheiro].</segment>
    <segment id="88">Descontou R$ 160 no valor que eu recebo dia 21 [de novembro]".</segment>
    <segment id="89">Segundo Silva</segment>
    <segment id="90">, o crédito do consignado também não caiu na conta.</segment>
    <segment id="91">"</segment>
    <segment id="92">Olhei no Caixa Tem</segment>
    <segment id="93">, puxei extrato</segment>
    <segment id="94">, olhei na Caixa Poupança.</segment>
    <segment id="95">Nada.</segment>
    <segment id="96">"</segment>
    <segment id="97">Na agência</segment>
    <segment id="98">, ela diz ter sido informada de que era preciso esperar até dia 14 de novembro</segment>
    <segment id="99">, porque</segment>
    <segment id="100">porque havia um problema no aplicativo.</segment>
    <segment id="101">"</segment>
    <segment id="102">Olharam meu CPF e disseram que não tinha nenhum pedido de empréstimo</segment>
    <segment id="103">, não consta no sistema.</segment>
    <segment id="104">Mas eu tirei print do contrato</segment>
    <segment id="105">, da mensagem que chegou"</segment>
    <segment id="106">, afirma.</segment>
    <segment id="107">O que dizem benefíciários sobre o empréstimo do Auxílio Brasil Mais    novamente         de   de  de  representando um  Liberação do crédito foi marcada por falhas e suspensão</segment>
    <segment id="108">O início da liberação do consignado do Auxílio Brasil foi marcado por reclamações de crédito cancelado</segment>
    <segment id="109">, demora na liberação do dinheiro</segment>
    <segment id="110">, cobrança de taxa extra e sobrecarga nos sistemas da Caixa.</segment>
    <segment id="111">A linha de crédito já foi suspensa pelo banco duas vezes (a liberação de novos empréstimos está bloqueada até o dia 14 de novembro).</segment>
    <segment id="112">Às vésperas da eleição</segment>
    <segment id="113">, o TCU (Tribunal de Contas da União) também recomendou que o empréstimo fosse suspenso.</segment>
    <segment id="114">Após uma sobrecarga no sistema devido à explosão de acessos</segment>
    <segment id="115">, pedidos foram cancelados ou ficaram em processamento.</segment>
    <segment id="116">O banco estimou que havia cerca de 200 mil pessoas com o contrato em análise ou pendente até o dia 21 de outubro e que precisariam fazer nova solicitação.</segment>
    <segment id="117">Paola de Carvalho</segment>
    <segment id="118">, da Rede Brasileira de Renda Básica</segment>
    <segment id="119">, diz estar preocupada com a quantidade de famílias relatando que não receberam o dinheiro do empréstimo</segment>
    <segment id="120">, masmas que estão com o desconto previsto em seus extratos.</segment>
    <segment id="121">A diretora diz estar coletando os relatos para decidir o que fazer.</segment>
    <segment id="122">Uma das opções é acionar a Defensoria Pública.</segment>
    <segment id="123">"Mas vai demorar um ano</segment>
    <segment id="124">, um ano e meio</segment>
    <segment id="125">, para as pessoas serem ressarcidas.</segment>
    <segment id="126">O que me preocupa é isso.</segment>
    <segment id="127">"</segment>
    <segment id="128">A recomendação oficial é que o beneficiário use o canal de atendimento do Ministério da Cidadania (telefone 121) para registrar sua reclamação.</segment>
    <segment id="129">No entanto</segment>
    <segment id="130">, Carvalho diz que as pessoas não têm conseguido obter retorno.</segment>
    <segment id="131">Ir à agência</segment>
    <segment id="132">, ela diz</segment>
    <segment id="133">, também tem sido infrutífero.</segment>
    <segment id="134">"</segment>
    <segment id="135">Eles mandam olhar no aplicativo ou procurar o Cras [Centro de Referência da Assistência Social]</segment>
    <segment id="136">, o que é um absurdo</segment>
    <segment id="137">porque</segment>
    <segment id="138">porque não são eles que organizam o pagamento do consignado"</segment>
    <segment id="139">, diz.</segment>
    <segment id="140">Além disso</segment>
    <segment id="141">, a regulamentação do consignado previa que o banco deixasse bem claro para os clientes quais eram as condições ao contratar o crédito</segment>
    <segment id="142">, masmas Carvalho afirma que a realidade é outra.</segment>
    <segment id="143">"Está sendo bem confuso"</segment>
    <segment id="144">, diz.</segment>
    <segment id="145">"</segment>
    <segment id="146">Deveria estar escrito que a partir de tal dia vai ser debitado o crédito do benefício</segment>
    <segment id="147">, e nada disso foi feito</segment>
    <segment id="148">", acrescenta.</segment>
  </rst>
</analysis>