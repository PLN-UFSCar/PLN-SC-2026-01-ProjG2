  <rst>
    <segment id="1">Depois de 12 temporadas</segment>
    <segment id="2">, vai ao ar nesta quinta o último episódio da competição musical The Voice Brasil.</segment>
    <segment id="3">A audiência e a repercussão caíram</segment>
    <segment id="4">; ao contrário do que aconteceu em outros países</segment>
    <segment id="5">, nenhum dos vencedores</segment>
    <segment id="6">sese tornou um grande astro.</segment>
    <segment id="7">Toni Garrido</segment>
    <segment id="8">, Lulu Santos</segment>
    <segment id="9">, Iza, Carlinhos Brown</segment>
    <segment id="10">, Michel Teló</segment>
    <segment id="11">, Fatima Bernades e Gaby Amarantos no &amp;#</segment>
    <segment id="12">039;The Voice Brasil&amp;#039</segment>
    <segment id="13">; - Léo Rosario/GloboTransmitida ao vivo</segment>
    <segment id="14">, a grande final tem duas etapas.</segment>
    <segment id="15">Na primeira</segment>
    <segment id="16">, os técnicos Carlinhos Brown</segment>
    <segment id="17">, Iza, Lulu Santos e Michel Teló escolhem os finalistas.</segment>
    <segment id="18">Na segunda</segment>
    <segment id="19">, o público vota pela internet no campeão desta edição.</segment>
    <segment id="20">Apresentação de Fátima Bernardes.  Globo</segment>
    <segment id="21">, 22h25</segment>
    <segment id="22">, livre</segment>
    <segment id="23">A Criatura de GyeongSeong</segment>
    <segment id="24">Na primavera de 1945</segment>
    <segment id="25">, a 2ª Guerra Mundial</segment>
    <segment id="26">sese aproximava do fim</segment>
    <segment id="27">, masmas a Coreia continuava sob o domínio japonês.</segment>
    <segment id="28">Num hospital de GyeongSeong</segment>
    <segment id="29">, o antigo nome de Seul</segment>
    <segment id="30">, um homem e uma mulher enfrentam uma criatura forjada pela ganância humana.</segment>
    <segment id="31">Os sete primeiros episódios desta minissérie sul-coreana já estão disponíveis</segment>
    <segment id="32">;</segment>
    <segment id="33">os três últimos chegam em 5 de janeiro.</segment>
    <segment id="34">Netflix</segment>
    <segment id="35">, 16 anos</segment>
    <segment id="36">Pérola</segment>
    <segment id="37">Um jovem escritor volta à sua cidade natal depois da morte da mãe</segment>
    <segment id="38">, e é inundado pelas lembranças dela.</segment>
    <segment id="39">A adaptação de Murilo Benício para a peça semiautobiográfica de Mauro Rasi é um dos melhores filmes nacionais de 2023</segment>
    <segment id="40">, e traz Drica Moraes numa grande atuação no papel-título.</segment>
    <segment id="41">Telecine Premium</segment>
    <segment id="42">, 14h05</segment>
    <segment id="43">, 14 anos   Retrospectiva 2023</segment>
    <segment id="44">Roberto Cabrini apresenta uma compilação dos principais acontecimentos que marcaram o Brasil e o mundo durante o ano que está terminando.  Record</segment>
    <segment id="45">, 22h45</segment>
    <segment id="46">, livre  Imagens do jornalista Roberto CabriniMais    novamente         de   de  de  representando um  Evel</segment>
    <segment id="47">, Hazin – Dias de Luto</segment>
    <segment id="48">O documentário inédito de Gabriel Chaim registra os impactos da guerra em Israel na Cisjordânia</segment>
    <segment id="49">, mostrando o sofrimento de palestinos e israelenses que tiveram parentes mortos.</segment>
    <segment id="50">GloboNews</segment>
    <segment id="51">, 23h, livre  Veja linha do tempo de conflito entre Israel e HamasMais    novamente         de   de  de  representando um  Liceu 50 Anos –</segment>
    <segment id="52">Entre a Arte e o Ofício</segment>
    <segment id="53">Criado em 1873</segment>
    <segment id="54">, o Liceu de Artes e Ofícios de São Paulo teve papel fundamental na história da cidade.</segment>
    <segment id="55">O documentário de Ricardo Elias conta a história da instituição que já foi dirigida pelo arquiteto Ramos de Azevedo.</segment>
