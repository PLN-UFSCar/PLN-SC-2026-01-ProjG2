  <rst>
    <segment id="1">Vou começar com a imodesta presunção de que talvez alguém leia este texto daqui 30 ou 40 anos.</segment>
    <segment id="2">Ao improvável leitor do futuro dedico algumas palavras.</segment>
    <segment id="3">Colunas e BlogsReceba no seu email uma seleção de colunas e blogs da FolhaCarregando...</segment>
    <segment id="4">Em novembro de 2023</segment>
    <segment id="5">, calor de 40ºC em São Paulo era algo totalmente fora do normal.</segment>
    <segment id="6">Não estávamos habituados e não sabíamos lidar com a situação.</segment>
    <segment id="7">Escrevi esta coluna em pleno desespero térmico.</segment>
    <segment id="8">De volta ao presente</segment>
    <segment id="9">, a canícula dos dias recentes requer mais do que comida fresca.</segment>
    <segment id="10">Exige algo gelado.</segment>
    <segment id="11">Não sou muito dos sorvetes</segment>
    <segment id="12">, então vasculhei a memória em busca de uma comida salgada que</segment>
    <segment id="13">sese encaixasse.</segment>
    <segment id="14">Termômetro no bairro da Liberdade</segment>
    <segment id="15">, em São Paulo</segment>
    <segment id="16">, no dia 12.nov.23 - Rubens Cavallari/FolhapressEncontrei</segment>
    <segment id="17">um prato servido no restaurante Komah</segment>
    <segment id="18">, o coreano mais caprichado de São Paulo.</segment>
    <segment id="19">É uma espécie de steak tartare</segment>
    <segment id="20">, uma receita de carne crua que chega à mesa ainda meio congelada.</segment>
    <segment id="21">Fuçando na internet</segment>
    <segment id="22">, achei o nome do bicho: yukhoe.</segment>
    <segment id="23">Além da carne crua</segment>
    <segment id="24">, leva pera asiática (especialmente crocante</segment>
    <segment id="25">, masmas você pode trocar por outra variedade)</segment>
    <segment id="26">, alho</segment>
    <segment id="27">, shoyu</segment>
    <segment id="28">, óleo de gergelim e uma gema curada por cima.</segment>
    <segment id="29">Antes de prosseguir</segment>
    <segment id="30">, um pequeno alerta.</segment>
    <segment id="31">O yukhoe é feito de carne e ovo crus</segment>
    <segment id="32">, alimentos que sempre oferecem algum risco sanitário.</segment>
    <segment id="33">Cerque-</segment>
    <segment id="34">sese destes três cuidados: higiene impecável</segment>
    <segment id="35">, ingredientes frescos e rapidez no preparo e no serviço.</segment>
    <segment id="36">Yukhoe</segment>
    <segment id="37">, carne congelada à coreana</segment>
    <segment id="38">, receita do Marcos Nogueira</segment>
    <segment id="39">, o Marcão - Marcos Nogueira/FolhapressAs medidas da receita são para uma porção individual pequena</segment>
    <segment id="40">,.</segment>
    <segment id="41">O yukhoe é uma comida muito forte</segment>
    <segment id="42">, melhor não ser o prato principal.</segment>
    <segment id="43">Desse jeito</segment>
    <segment id="44">, você consegue cortar</segment>
    <segment id="45">, marinar e servir a carne em cinco minutos ou até menos.</segment>
    <segment id="46">Quanto à carne</segment>
    <segment id="47">, pegue um corte magro e macio</segment>
    <segment id="48">, como</segment>
    <segment id="49">como filé mignon.</segment>
    <segment id="50">Eu usei coração de alcatra.</segment>
    <segment id="51">Compre bifes bem fininhos e congele-os isoladamente</segment>
    <segment id="52">, assim fica mais fácil cortar a carne em bastões bem finos –na culinária clássica francesa</segment>
    <segment id="53">, à juliana.</segment>
    <segment id="54">A pera também vai à juliana</segment>
    <segment id="55">, no mesmo tamanho dos palitos de carne.</segment>
    <segment id="56">A gema crua deve ficar duas horas curando numa mistura de shoyu e saquê –dentro da geladeira</segment>
    <segment id="57">, por favor.</segment>
    <segment id="58">Aliás, sempre guarde os ovos na geladeira.</segment>
    <segment id="59">A receita do molho eu peguei do maangchi.com</segment>
    <segment id="60">, um excelente site de comida coreana em inglês.</segment>
    <segment id="61">É bem puxado no alho</segment>
    <segment id="62">, que eu amo.</segment>
    <segment id="63">Você pode reduzir ou omitir o alho.</segment>
    <segment id="64">Para suavizar o fator bafo</segment>
    <segment id="65">, cozinhe os dentes de alho por 30 segundos no micro-ondas.</segment>
    <segment id="66">Por fim</segment>
    <segment id="67">, harmonize o yukhoe com um copão de água gelada com muito gelo.</segment>
    <segment id="68">O Yukhoe</segment>
    <segment id="69">, espécie de steak tartare coreano feito com carne congelada - Marcos Nogueira/Folhaprees CARNE CRUA</segment>
    <segment id="70">À COREANA</segment>
    <segment id="71">Rendimento: 1 porção  Dificuldade: fácil</segment>
    <segment id="72">Ingredientes  2 colheres (sopa de shoyu)</segment>
    <segment id="73">1 colher (sopa) de saquê culinário  1 gema  ¼ de pera asiática  2 colheres (chá) de açúcar  2 dentes de alho triturados  1 colher (chá) de óleo de gergelim  80 g de filé mignon ou alcatra congelada  Guarnição: cebolinha picada e gergelim preto</segment>
    <segment id="74">Modo de fazer</segment>
    <segment id="75">Misture uma colher (sopa) de shoyu e o saquê.</segment>
    <segment id="76">Coloque a gema nessa mistura</segment>
    <segment id="77">, cubra com papel-toalha (para envolver o topo da gema com líquido) e deixe na geladeira por duas horas.</segment>
    <segment id="78">Numa tigela</segment>
    <segment id="79">, dissolva metade do açúcar em água gelada.</segment>
    <segment id="80">Descasque a pera</segment>
    <segment id="81">, corte-a em palitos bem finos e deixe-a reservada na água com açúcar.</segment>
    <segment id="82">Prepare o molho em outra tigela</segment>
    <segment id="83">, misturando o alho</segment>
    <segment id="84">, o óleo de gergelim</segment>
    <segment id="85">, o shoyu e o açúcar restantes.</segment>
    <segment id="86">Corte a carne congelada em palitos bem finos.</segment>
    <segment id="87">Misture-a rapidamente ao molho.</segment>
    <segment id="88">Escorra e misture a pera.</segment>
    <segment id="89">Cubra com a gema curada</segment>
    <segment id="90">, guarneça com cebolinha e gergelim e coma imediatamente.</segment>
  </rst>
</analysis>