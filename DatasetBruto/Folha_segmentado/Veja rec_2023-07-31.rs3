  <rst>
    <segment id="1">A febre cor-de-rosa do filme "Barbie" me despertou interesse em explorar comidas de cores intensas —além do acarajé pink que gerou controvérsia em Salvador.</segment>
    <segment id="2">Colunas e BlogsReceba no seu email uma seleção de colunas e blogs da Folha</segment>
    <segment id="3">; exclusiva para assinantes.</segment>
    <segment id="4">Carregando...</segment>
    <segment id="5">A cor tem apelo visual inegável</segment>
    <segment id="6">, e resolvi brincar com isso.</segment>
    <segment id="7">Mas não queria recorrer a corantes</segment>
    <segment id="8">, mesmo que naturais.</segment>
    <segment id="9">Muitos alimentos emprestam cor —ou mancham</segment>
    <segment id="10">, depende do ponto de vista— a outras comidas.</segment>
    <segment id="11">O açafrão</segment>
    <segment id="12">, de amarelo-ouro.</segment>
    <segment id="13">A couve e o espinafre</segment>
    <segment id="14">, de verde profundo.</segment>
    <segment id="15">A tinta de lula e seu negro absoluto</segment>
    <segment id="16">, que não parece pertencer ao reino das coisas comestíveis</segment>
    <segment id="17">, masmas pertence.</segment>
    <segment id="18">Pitaia</segment>
    <segment id="19">, beterraba e amoras vão do rosa-choque ao vermelho sanguíneo.</segment>
    <segment id="20">E tem a batata roxa.</segment>
    <segment id="21">Sopa de batata roxa ao curry - Receitas do Marcão - FolhapressEu sempre gostei de batata-doce roxa</segment>
    <segment id="22">, mais do que das outras variedades.</segment>
    <segment id="23">Ela tem um sabor um pouco defumado</segment>
    <segment id="24">, obviamente terroso e não tão doce quanto seu nome leva a pensar.</segment>
    <segment id="25">Um pouquinho de sal e temos uma comida quase neutra.</segment>
    <segment id="26">Anos atrás</segment>
    <segment id="27">, eu fiz uma experiência interessante:</segment>
    <segment id="28">extraí o sumo da batata-doce roxa crua e o deixei fermentar</segment>
    <segment id="29">, como</segment>
    <segment id="30">como o tucupi da Amazônia.</segment>
    <segment id="31">Obtive um caldo ácido</segment>
    <segment id="32">, escuro e delicioso.</segment>
    <segment id="33">Sucesso total.</segment>
    <segment id="34">Mas pode sossegar</segment>
    <segment id="35">, a receita aqui não tem nenhuma porra-louquice.</segment>
    <segment id="36">É uma simples sopa.</segment>
    <segment id="37">Uma sopa roxona.</segment>
    <segment id="38">Uma receita muito convencional</segment>
    <segment id="39">, a despeito da cor alienígena.</segment>
    <segment id="40">Basta bater as batatas com caldo e alguns temperos.</segment>
    <segment id="41">Eu usei caldo de frango.</segment>
    <segment id="42">Caldo comprado.</segment>
    <segment id="43">Hoje há duas ou três marcas de caldo feito sem subprodutos industriais nem aditivos químicos.</segment>
    <segment id="44">Confira os pratos inspirados no filme &amp;#039</segment>
    <segment id="45">;Barbie&amp;#039</segment>
    <segment id="46">; da doceria Pikurrucha&amp;#039</segment>
    <segment id="47">;sMais    novamente         de   de  de  representando um  Ele vem congelado ou em embalagem tetrapak</segment>
    <segment id="48">, como</segment>
    <segment id="49">como a de leite.</segment>
    <segment id="50">Tem gosto de caldo caseiro.</segment>
    <segment id="51">Você pode</segment>
    <segment id="52">–ouso dizer que deve– fazer o próprio caldo</segment>
    <segment id="53">, sese tiver a disposição que não tive.</segment>
    <segment id="54">Evite caldo em cubo ou em pó.</segment>
    <segment id="55">E, claro</segment>
    <segment id="56">, pode substituir o frango por legumes ou carne.</segment>
    <segment id="57">Assei a batata no micro-ondas</segment>
    <segment id="58">, dentro de um saco de pão.</segment>
    <segment id="59">Se preferir</segment>
    <segment id="60">, asse no forno ou cozinhe no próprio caldo</segment>
    <segment id="61">, juntando mais água depois.</segment>
    <segment id="62">Quanto ao tempero</segment>
    <segment id="63">, fiz um refogado de cebola</segment>
    <segment id="64">, alho e salsão.</segment>
    <segment id="65">Essa é a base</segment>
    <segment id="66">, que dá para temperar de várias maneiras.</segment>
    <segment id="67">Eu usei curry</segment>
    <segment id="68">, para dar um ar vagamente oriental à sopa.</segment>
    <segment id="69">Finalizei com castanhas-de-caju e folhas de salsão.</segment>
    <segment id="70">Fique à vontade para mudar</segment>
    <segment id="71">comocomo quiser... só não vai usar batata normal</segment>
    <segment id="72">, né?</segment>
    <segment id="73">SOPA DE BATATA</segment>
    <segment id="74">ROXA AO CURRY  Dificuldade</segment>
    <segment id="75">: fácil  Rendimento: 4 porções  Ingredientes   1 kg de batata-doce roxa 1 l de caldo de frango 1 colher (sopa) de manteiga 1 cebola picada 2 dentes de alho picados 1 talo de salsão picado 1 colher (sopa) de curry Sal e pimenta-do-reino a gosto Castanha-de-caju torrada e folhas de salsão para guarnecer   Modo de fazer  1.</segment>
    <segment id="76">Coloque a batata num saco de papel pardo e asse no micro-ondas</segment>
    <segment id="77">, em potência máxima</segment>
    <segment id="78">, por 8 minutos (ou até ficar macia).</segment>
    <segment id="79">Espere esfriar</segment>
    <segment id="80">, descasque e parta em pedaços menores.  2.</segment>
    <segment id="81">Aqueça a manteiga e refogue a cebola</segment>
    <segment id="82">, o alho e o salsão.</segment>
    <segment id="83">Acrescente o caldo e a batata e ferva por 10 minutos.  3.</segment>
    <segment id="84">Bata a sopa com um mixer ou no liquidificador.</segment>
    <segment id="85">Aqueça até obter um creme pouco espesso (acrescente água</segment>
    <segment id="86">sese preciso).  4.</segment>
    <segment id="87">Junte o curry</segment>
    <segment id="88">, o sal e a pimenta.</segment>
    <segment id="89">Sirva com as guarnições.</segment>
  </rst>
</analysis>