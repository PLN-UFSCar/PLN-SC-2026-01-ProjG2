  <rst>
    <segment id="1">O bairro da Luz</segment>
    <segment id="2">, região central de São Paulo</segment>
    <segment id="3">, passou a contar</segment>
    <segment id="4">, desde o último dia 8 de dezembro</segment>
    <segment id="5">, com o primeiro Bom Prato Refeitório da rede de restaurantes populares.</segment>
    <segment id="6">Trata-</segment>
    <segment id="7">sese de uma nova modelagem do programa Bom Prato</segment>
    <segment id="8">, mais rápida de ser implantada e até 50% mais barata que as unidades fixas tradicionais.</segment>
    <segment id="9">A reforma da unidade Luz foi planejada e financiada pela Prefeitura de São Paulo e será gerida pela Secretaria de Desenvolvimento Social do Governo de São Paulo.</segment>
    <segment id="10">O total de investimento feito pela Prefeitura e pelo governo estadual na unidade foi de R$ 1</segment>
    <segment id="11">,2 milhão.</segment>
    <segment id="12">Com capacidade para 110 pessoas</segment>
    <segment id="13">, a unidade passou a ter mesas</segment>
    <segment id="14">, banheiros e lavatórios com objetivo de oferecer três refeições diárias à população vulnerável da região central.</segment>
    <segment id="15">São 250 cafés da manhã</segment>
    <segment id="16">, 700 almoços e 300 jantares.</segment>
    <segment id="17">Bom Prato Refeitório Luz que</segment>
    <segment id="18">, desde o último dia 8 de dezembro</segment>
    <segment id="19">, serve refeições à população vulnerável da região central da cidade- Paulo Guereta/SECOMO</segment>
    <segment id="20">Bom</segment>
    <segment id="21">Prato</segment>
    <segment id="22">Refeitório da Luz está localizado na rua Mauá</segment>
    <segment id="23">, nº 66</segment>
    <segment id="24">, em terreno cedido pela Prefeitura</segment>
    <segment id="25">, e está aberto todos os dias</segment>
    <segment id="26">, inclusive fins de semana.</segment>
    <segment id="27">O café da manhã é oferecido a partir das 7h com o valor de R$ 0</segment>
    <segment id="28">,50.</segment>
    <segment id="29">O almoço é servido às 10h30</segment>
    <segment id="30">, preferencialmente para idosos</segment>
    <segment id="31">, e às 11h para o público em geral</segment>
    <segment id="32">, e o jantar tem início às 17h.</segment>
    <segment id="33">Ambos custam R$ 1.</segment>
    <segment id="34">Serão concedidos pela Secretaria Municipal de Assistência e Desenvolvimento Social (SMADS) cartões de gratuidade</segment>
    <segment id="35">para que</segment>
    <segment id="36">para que pessoas em situação de alta vulnerabilidade possam</segment>
    <segment id="37">sese alimentar sem nenhum custo.</segment>
    <segment id="38">A reforma da unidade Bom Prato Refeitório Luz faz parte do eixo "cuidado" do Programa Reencontro</segment>
    <segment id="39">, para promover segurança alimentar e nutricional às pessoas que vivem nas ruas da cidade de São Paulo.</segment>
    <segment id="40">Para conhecer todos os serviços que são oferecidos pela Prefeitura de SP à população em situação de rua</segment>
    <segment id="41">, acesse: www.prefeitura.sp.gov.br/poprua.  *</segment>
    <segment id="42">Conteúdo patrocinado produzido pelo Estúdio Folha</segment>
  </rst>
</analysis>