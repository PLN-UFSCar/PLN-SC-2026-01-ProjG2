  <rst>
    <segment id="1">Jesse Armstrong nem sempre soube</segment>
    <segment id="2">comocomo "</segment>
    <segment id="3">Succession</segment>
    <segment id="4">"</segment>
    <segment id="5">terminaria.</segment>
    <segment id="6">Mas ele sabia</segment>
    <segment id="7">comocomo esse final seria sentido.</segment>
    <segment id="8">"</segment>
    <segment id="9">Sempre foi um pouco sobre a mortalidade humana e a mortalidade desse tipo de operação midiática"</segment>
    <segment id="10">, disse ele.</segment>
    <segment id="11">Já no piloto</segment>
    <segment id="12">, acrescentou:</segment>
    <segment id="13">"Eu sabia qual seria o tom do final".  "Succession"</segment>
    <segment id="14">, que teve quatro temporadas na HBO</segment>
    <segment id="15">, exibiu seu episódio final em 28 de maio.</segment>
    <segment id="16">A última temporada recebeu impressionantes 27 indicações ao Emmy —o maior número de qualquer programa este ano— incluindo uma para melhor série dramática</segment>
    <segment id="17">, que já venceu duas vezes antes.</segment>
    <segment id="18">Ao longo da série</segment>
    <segment id="19">, o foco foi em Logan Roy (Brian Cox)</segment>
    <segment id="20">, o autoproclamado senhor de um império conservador de mídia e parques temáticos</segment>
    <segment id="21">, e seus filhos e seguidores.</segment>
    <segment id="22">Jesse Armstrong</segment>
    <segment id="23">, o criador da série &amp;#</segment>
    <segment id="24">039;Succession&amp;#039</segment>
    <segment id="25">;- Lila Barth/The New York TimesSarcástica</segment>
    <segment id="26">, invernal</segment>
    <segment id="27">, profana</segment>
    <segment id="28">,</segment>
    <segment id="29">a série era uma mistura desconcertante de sátira e tragédia</segment>
    <segment id="30">, intriga corporativa e drama profundamente humano.</segment>
    <segment id="31">Cada episódio inspirava uma enxurrada de memes e análises.</segment>
    <segment id="32">E, embora</segment>
    <segment id="33">embora nenhum dos personagens parecesse desfrutar de sua riqueza obscena</segment>
    <segment id="34">, o estilo de alta contagem de fios da série</segment>
    <segment id="35">, chamado de "luxo discreto" ou "riqueza silenciosa"</segment>
    <segment id="36">, gerou inúmeras imitações.</segment>
    <segment id="37">Em uma manhã recente</segment>
    <segment id="38">, em um hotel do Brooklyn um pouco plebeu demais para os Roys</segment>
    <segment id="39">, Armstrong sentou-</segment>
    <segment id="40">sese em uma mesa de café com uma camisa azul-marinho amassada e calças quase combinando.</segment>
    <segment id="41">Ele estava na cidade para receber um Prêmio Fundadores do Emmy Internacional.</segment>
    <segment id="42">"</segment>
    <segment id="43">Acho que é um daqueles prêmios honorários para pessoas no final de suas carreiras que estão sendo afastadas"</segment>
    <segment id="44">, disse ele</segment>
    <segment id="45">, com a típica autodepreciação inglesa.</segment>
    <segment id="46">A greve dos roteiristas impediu Armstrong de participar de muitas discussões sobre o final de "Succession"</segment>
    <segment id="47">quando o episódio final foi ao ar há seis meses</segment>
    <segment id="48">.</segment>
    <segment id="49">Ele passou a greve em Londres</segment>
    <segment id="50">, sese recuperando.</segment>
    <segment id="51">No entanto</segment>
    <segment id="52">, o brilho bege de "Succession" mal</segment>
    <segment id="53">sese desgastou.</segment>
    <segment id="54">Em janeiro</segment>
    <segment id="55">, provavelmente dominará o Emmy Awards —todo o elenco principal recebeu indicações e Armstrong recebeu duas</segment>
    <segment id="56">, por roteiro e</segment>
    <segment id="57">comocomo produtor executivo— e nenhum outro programa o substituiu na consciência cultural.</segment>
    <segment id="58">Modas vêm e vão</segment>
    <segment id="59">, masmas o interesse pelos ultrarricos e suas disputas?</segment>
    <segment id="60">Atemporal.</segment>
    <segment id="61">Enquanto tomava um café com leite</segment>
    <segment id="62">, não o primeiro do dia</segment>
    <segment id="63">, e com pausas ocasionais para cuidar de cãibras nas pernas —ele havia jogado futebol no McCarren Park de manhã cedo—</segment>
    <segment id="64">, Armstrong discutiu marxismo</segment>
    <segment id="65">, riqueza extrema e</segment>
    <segment id="66">sese algum desses personagens era remotamente simpático.</segment>
    <segment id="67">Estes são trechos editados da conversa.</segment>
    <segment id="68">&amp;#039;Succession&amp;#039</segment>
    <segment id="69">;</segment>
    <segment id="70">:</segment>
    <segment id="71">Veja looks da 4ª temporada da série da HBOMais    novamente         de   de  de  representando um  </segment>
    <segment id="72">A pergunta principal da série era quem sucederia Logan Roy.</segment>
    <segment id="73">Seria possível o programa ter terminado sem respondê-la?</segment>
    <segment id="74">A maioria dos espectadores assiste por prazeres além da corrida de cavalos.</segment>
    <segment id="75">Mas não é ilegítimo assistir à corrida de cavalos e</segment>
    <segment id="76">sese perguntar quem vai ganhar.</segment>
    <segment id="77">Essa seria uma pergunta que eu poderia trazer para a sala de roteiristas</segment>
    <segment id="78">, tipo</segment>
    <segment id="79">, "Como seria</segment>
    <segment id="80">sese não déssemos um sucessor?</segment>
    <segment id="81">Isso poderia ser interessante?</segment>
    <segment id="82">"</segment>
    <segment id="83">Através de um processo de discussão com pessoas inteligentes</segment>
    <segment id="84">, chegamos à conclusão de que seria irritante.</segment>
    <segment id="85">Uma das razões para encerrar o programa é que ele começa a</segment>
    <segment id="86">sese tornar ridículo ou irritante</segment>
    <segment id="87">sese você adiar continuamente essa decisão.</segment>
    <segment id="88">Gosto de pensar em mim mesmo</segment>
    <segment id="89">comocomo alguém com uma quantidade razoável de empatia.</segment>
    <segment id="90">Eu continuava querendo sentir empatia por esses personagens</segment>
    <segment id="91">, masmas desisti.</segment>
    <segment id="92">Era para eu simpatizar com eles?</segment>
    <segment id="93">Isso nunca foi realmente considerado.</segment>
    <segment id="94">Talvez seja um defeito em nosso processo de trabalho.</segment>
    <segment id="95">Talvez eu pudesse tentar despertar a simpatia do público por alguém</segment>
    <segment id="96">, masmas não gostaria de fazer isso com esse programa.</segment>
    <segment id="97">Seria tão falso.</segment>
    <segment id="98">É um programa com essas dinâmicas familiares específicas e com essa relação com poder e dinheiro.</segment>
    <segment id="99">Tudo fluiu a partir disso.</segment>
    <segment id="100">Não foi</segment>
    <segment id="101">comocomo</segment>
    <segment id="102">, 'Ah, vamos tentar afastar as pessoas ou atraí-las.</segment>
    <segment id="103">' Foi apenas</segment>
    <segment id="104">, 'Vamos mostrar essas pessoas e ver o que acontece.</segment>
    <segment id="105">' Não seria impossível para nós dizer</segment>
    <segment id="106">, isso é uma coisa horrível de</segment>
    <segment id="107">sese fazer?</segment>
    <segment id="108">Mas se</segment>
    <segment id="109">se isso pudesse acontecer ou aconteceria</segment>
    <segment id="110">, sempre diríamos</segment>
    <segment id="111">, vamos fazer.</segment>
    <segment id="112">Qual é a sua atitude em relação à grande riqueza?</segment>
    <segment id="113">Tenho uma visão europeia de que uma sociedade mais igualitária tornará todos mais felizes.</segment>
    <segment id="114">Essa é uma formulação bastante básica.</segment>
    <segment id="115">Mas me sinto um pouco ridículo dizendo isso.</segment>
    <segment id="116">Não é muito saudável</segment>
    <segment id="117">, não é</segment>
    <segment id="118">, essa enorme acumulação de riqueza?</segment>
    <segment id="119">Veja os indicados ao Emmy 2023</segment>
    <segment id="120">, principal prêmio da televisão e do streaming americanosMais    novamente         de   de  de  representando um  É possível que ela não seja deformadora?</segment>
    <segment id="121">É uma pergunta</segment>
    <segment id="122">, não é?</segment>
    <segment id="123">Acho que tudo é possível para os seres humanos.</segment>
    <segment id="124">Existem pessoas muito ricas que têm uma relação empática com o mundo.</segment>
    <segment id="125">Algumas pessoas usam seu poder para o bem maior.</segment>
    <segment id="126">Em um nível psicológico</segment>
    <segment id="127">, não necessariamente precisa te deixar louco.</segment>
    <segment id="128">Mas muitas vezes acontece.</segment>
    <segment id="129">O programa adota mais uma visão psicológica do que marxista.</segment>
    <segment id="130">É nesse nível que eu tenho muita simpatia pelos personagens e espero que o público também tenha.</segment>
    <segment id="131">Eles são bem ruins.</segment>
    <segment id="132">Eles fazem coisas ruins.</segment>
    <segment id="133">Mas você entende de onde eles vêm psicologicamente.</segment>
    <segment id="134">Essa é uma das tragédias da vida dessas crianças.</segment>
    <segment id="135">Você não vê muitos amigos.</segment>
    <segment id="136">Eles vivem essas vidas internacionais desenraizadas.</segment>
    <segment id="137">Eles estão profundamente desorientados.</segment>
    <segment id="138">Uma das poucas coisas que eles têm é a família e ela tem um magnetismo incrível para eles.</segment>
    <segment id="139">É como</segment>
    <segment id="140">como se</segment>
    <segment id="141">se eles estivessem constantemente conectados a um gotejamento intravenoso e não percebessem que há uma porcentagem de veneno na IV.</segment>
    <segment id="142">Isso não os está tornando melhores.</segment>
    <segment id="143">Isso os está deixando mais doentes.</segment>
    <segment id="144">A paixão dos espectadores pelo programa te surpreendeu?</segment>
    <segment id="145">Nós investimos muito nele.</segment>
    <segment id="146">E sim, há muito para discutir.</segment>
    <segment id="147">Agora eu voltei e olhei coisas interessantes e li coisas sobre o programa.</segment>
    <segment id="148">Na época</segment>
    <segment id="149">, eu mantive distância da maioria das reações</segment>
    <segment id="150">, porque</segment>
    <segment id="151">porque não era útil saber o que as pessoas estavam pensando sobre o programa.</segment>
    <segment id="152">Você pode ficar um pouco abalado.</segment>
    <segment id="153">Eu gosto de críticos.</segment>
    <segment id="154">Eu acredito na crítica</segment>
    <segment id="155">comocomo uma parte importante para manter o mundo cultural em movimento.</segment>
    <segment id="156">Mas eu não li muitas coisas antes do fim do programa.</segment>
    <segment id="157">Você leu o artigo que escrevi dizendo que o programa me tornou uma pessoa pior?</segment>
    <segment id="158">Não.</segment>
    <segment id="159">Oh, querida.</segment>
    <segment id="160">Desculpe.</segment>
    <segment id="161">É um mundo muito particular</segment>
    <segment id="162">, certo?</segment>
    <segment id="163">É uma representação do que é possível dentro do universo moral criado por um negócio e uma família.</segment>
    <segment id="164">As possibilidades são realmente limitadas.</segment>
    <segment id="165">Mas elas existem.</segment>
    <segment id="166">A intenção é mostrar esse mundo o mais verdadeiramente possível.</segment>
    <segment id="167">Mas, sim. Desculpe.</segment>
  </rst>
</analysis>