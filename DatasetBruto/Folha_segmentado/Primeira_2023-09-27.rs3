  <rst>
    <segment id="1">A ministra substituta do TSE (Tribunal Superior Eleitoral) Edilene Lôbo</segment>
    <segment id="2">, primeira mulher negra a integrar a corte</segment>
    <segment id="3">, vai participar de seu primeiro julgamento nesta quinta-feira (28).</segment>
    <segment id="4">A magistrada tomou posse em agosto</segment>
    <segment id="5">, masmas só é convocada a participar quando algum titular não pode comparecer.</segment>
    <segment id="6">A ministra do TSE Edilene Lôbo - Antonio Augusto/TSE</segment>
    <segment id="7">Em sua sessão de estreia no TSE</segment>
    <segment id="8">, ela deve votar sobre dois recursos que discutem supostas fraudes à cota de gênero cometidas nas eleições de 2020 em candidaturas ao cargo de vereador em Belém e em Goiânia.   CASA NOVA  Ludhmila Hajjar reúne políticos</segment>
    <segment id="9">, ministros do STF e artistas em sua posse</segment>
    <segment id="10">comocomo professora titular da USP</segment>
    <segment id="11">Mais    novamente         de   de  de  representando um</segment>
    <segment id="12">A médica cardiologista Ludhmila Hajjar recebeu convidados</segment>
    <segment id="13">comocomo a cantora Marisa Monte em sua cerimônia de posse</segment>
    <segment id="14">comocomo professora titular da Disciplina de Emergências Clínicas da Faculdade de Medicina da Universidade de São Paulo (FMUSP)</segment>
    <segment id="15">, na terça-feira</segment>
    <segment id="16">, na capital paulista.</segment>
    <segment id="17">O médico Roberto Kalil Filho</segment>
    <segment id="18">, presidente do conselho diretor do InCor</segment>
    <segment id="19">, prestigiou a ocasião.</segment>
    <segment id="20">Os ministros do Supremo Tribunal Federal (STF) Kassio Nunes Marques e Cristiano Zanin compareceram.  com BIANKA VIEIRA</segment>
    <segment id="21">, KARINA MATIAS e MANOELLA SMITH</segment>
  </rst>
