  <rst>
    <segment id="1">Ao menos quatro turistas morreram e outros 16 ficaram feridos ao retornar de um passeio à cidadela inca de Machu Picchu</segment>
    <segment id="2">, quando o micro-ônibus em que estavam caiu em um penhasco na rodovia</segment>
    <segment id="3">, informaram autoridades do Peru nesta segunda-feira (22).</segment>
    <segment id="4">Entre os feridos há quatro cidadãos franceses</segment>
    <segment id="5">, dois gregos</segment>
    <segment id="6">, dois israelenses</segment>
    <segment id="7">, dois canadenses</segment>
    <segment id="8">, dois argentinos</segment>
    <segment id="9">, dois peruanos</segment>
    <segment id="10">, um holandês e um espanhol</segment>
    <segment id="11">, segundo balanço oficial divulgado em Cusco.</segment>
    <segment id="12">Os mortos são três colombianos e um peruano.</segment>
    <segment id="13">O ministro de Comércio Exterior e Turismo</segment>
    <segment id="14">, Roberto Sánchez</segment>
    <segment id="15">, disse em entrevista coletiva na cidade</segment>
    <segment id="16">, ao lado de autoridades regionais</segment>
    <segment id="17">, que a queda</segment>
    <segment id="18">sese deu em uma escarpa de pouco mais de 100 metros.</segment>
    <segment id="19">Van que caiu com turistas em Machu Picchu</segment>
    <segment id="20">, na região de Abra Málaga - Divulgação Polícia Nacional do Peru/AFPOs 16 feridos foram levados a dois hospitais de Cusco.</segment>
    <segment id="21">Entre eles está o motorista</segment>
    <segment id="22">, de nacionalidade peruana.</segment>
    <segment id="23">O acidente ocorreu ainda na noite de domingo (21)</segment>
    <segment id="24">, na região de Abra Málaga</segment>
    <segment id="25">, a 105 km da cidade de Cusco.</segment>
    <segment id="26">"</segment>
    <segment id="27">Havia neblina no local do acidente.</segment>
    <segment id="28">Nós lamentamos esse evento tão trágico"</segment>
    <segment id="29">, disse Sánchez.</segment>
    <segment id="30">Em entrevista</segment>
    <segment id="31">, o chefe da polícia local destacou a dificuldade nas buscas.</segment>
    <segment id="32">China, terra do meioReceba no seu email os grandes temas da China explicados e contextualizados</segment>
    <segment id="33">; exclusiva para assinantes.</segment>
    <segment id="34">Carregando...</segment>
    <segment id="35">"Expressamos nossas condolências aos familiares e aos governos dos turistas estrangeiros</segment>
    <segment id="36">, lamentavelmente falecidos"</segment>
    <segment id="37">, expressou a chancelaria peruana no Twitter.</segment>
    <segment id="38">O presidente Pedro Castillo também lamentou o</segment>
    <segment id="39">casocaso</segment>
    <segment id="40">, acrescentando que determinou às pastas do Turismo e das Relações Exteriores que prestem assistência aos feridos</segment>
    <segment id="41">, entrem em contato com os familiares das vítimas e as respectivas embaixadas para providenciar a repatriação dos corpos.</segment>
    <segment id="42">O sítio arqueológico de Machu Picchu</segment>
    <segment id="43">, em Cusco - Ernesto Benavides - 27.jul.22/AFPUm avião da Força Aérea do Peru pousou no aeroporto de Cusco por volta das 13h locais (15h de Brasília) para levar alguns feridos a Lima</segment>
    <segment id="44">, segundo veículos locais.</segment>
    <segment id="45">Acidentes rodoviários são frequentes no Peru</segment>
    <segment id="46">, devido mau estado das rodovias</segment>
    <segment id="47">, à falta de sinalização e ao escasso controle das autoridades.</segment>
    <segment id="48">Em 31 de julho</segment>
    <segment id="49">, a queda de uma caminhonete em um abismo de 200 metros deixou 16 mortos</segment>
    <segment id="50">, entre eles crianças</segment>
    <segment id="51">, em uma remota via rural da região central de Junín.</segment>
    <segment id="52">Em fevereiro</segment>
    <segment id="53">, um ônibus caiu em um despenhadeiro de 100 metros em uma estrada rural na região de La Libertad</segment>
    <segment id="54">, perto dos Andes</segment>
    <segment id="55">, deixando pelo menos 20 pessoas mortas e 33 feridas.</segment>
    <segment id="56">Cerca de 5.000 turistas peruanos e estrangeiros visitam diariamente</segment>
    <segment id="57">Machu Picchu</segment>
    <segment id="58">, construída no século 15 pelo imperador inca Pachacútec e considerada a joia do turismo peruano.</segment>
  </rst>
</analysis>