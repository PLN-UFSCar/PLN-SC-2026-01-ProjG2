    <segment id="198">Gravataí (RS) Guarapuava (PR) Guaratinguetá (SP)</segment>
    <segment id="199">Itacoatiara (AM)</segment>
    <segment id="200">Jaú (SP) Ji-Paraná (RO) Juiz De Fora (MG) Londrina (PR) Manaus (AM) Marília (SP)</segment>
    <segment id="201">Maringá (PR) Mauá (SP)</segment>
    <segment id="202">Niterói (RJ)</segment>
