    <segment id="191">Cascavel (PR)</segment>
    <segment id="192">Catalão (GO)]</segment>
    <segment id="193">Caxias Do Sul (RS) Chapecó (SC)</segment>
    <segment id="194">Criciúma (SC)</segment>
    <segment id="195">Curitiba (PR) Divinópolis (MG)</segment>
    <segment id="196">Erechim (RS)</segment>
