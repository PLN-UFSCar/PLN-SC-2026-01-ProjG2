  <rst>
    <segment id="1">A Prefeitura de S&amp;atilde</segment>
    <segment id="2">;o Paulo anunciou que a cidade ter&amp;aacute</segment>
    <segment id="3">; &amp;</segment>
    <segment id="4">ocirc;nibus gratuitos aos domingos</segment>
    <segment id="5">, da 0h &amp;agrave</segment>
    <segment id="6">;s 23h59.</segment>
    <segment id="7">A medida come&amp;ccedil</segment>
    <segment id="8">;a a valer no dia 17 em todas as linhas do munic&amp;iacute</segment>
    <segment id="9">;pio.</segment>
    <segment id="10">A gratuidade tamb&amp;eacute</segment>
    <segment id="11">;m ser&amp;aacute</segment>
    <segment id="12">; aplicada nos dias de Natal (25/12)</segment>
    <segment id="13">, Ano Novo (1&amp;ordm</segment>
    <segment id="14">;/1/24) e anivers&amp;aacute</segment>
    <segment id="15">;rio de S&amp;atilde</segment>
    <segment id="16">;o Paulo (25/1/24).</segment>
    <segment id="17">Anunciada com o slogan &amp;quot</segment>
    <segment id="18">;Doming&amp;atilde</segment>
    <segment id="19">;o Tarifa Zero &amp;ndash</segment>
    <segment id="20">; explore</segment>
    <segment id="21">, descubra</segment>
    <segment id="22">, viva S&amp;atilde</segment>
    <segment id="23">;o Paulo&amp;quot</segment>
    <segment id="24">;, a medida tem</segment>
    <segment id="25">comocomo objetivos incentivar o uso do transporte p&amp;uacute</segment>
    <segment id="26">;blico</segment>
    <segment id="27">, ampliar o acesso ao lazer</segment>
    <segment id="28">, parques</segment>
    <segment id="29">, centros esportivos</segment>
    <segment id="30">, eventos culturais</segment>
    <segment id="31">, melhorar a economia e a oferta de empregos.</segment>
    <segment id="32">Aos domingos</segment>
    <segment id="33">, a Prefeitura mant&amp;eacute</segment>
    <segment id="34">;m abertos 78 espa&amp;ccedil</segment>
    <segment id="35">;os culturais</segment>
    <segment id="36">, 45 espa&amp;ccedil</segment>
    <segment id="37">;os esportivos e 112 parques.</segment>
    <segment id="38">Ônibus passa pela avenida Dom Pedro 1º</segment>
    <segment id="39">, no Ipiranga</segment>
    <segment id="40">; aos domingos</segment>
    <segment id="41">, todas as linhas de ônibus da cidade terão tarifa zero - DivulgaçãoAos domingos</segment>
    <segment id="42">, atualmente</segment>
    <segment id="43">, 2,2 milh&amp;otilde</segment>
    <segment id="44">;es de passageiros utilizam 1.175 linhas de &amp;ocirc</segment>
    <segment id="45">;nibus municipais.</segment>
    <segment id="46">Inicialmente</segment>
    <segment id="47">, o atendimento ser&amp;aacute</segment>
    <segment id="48">; feito com a frota atual operacional de 4</segment>
    <segment id="49">,8 mil &amp;ocirc</segment>
    <segment id="50">;nibus</segment>
    <segment id="51">, j&amp;aacute</segment>
    <segment id="52">; que estudos da SPTrans demonstram que</segment>
    <segment id="53">, aos domingos</segment>
    <segment id="54">, h&amp;aacute</segment>
    <segment id="55">; 60% de capacidade ociosa nos &amp;ocirc</segment>
    <segment id="56">;nibus em alguns per&amp;iacute</segment>
    <segment id="57">;odos, o que permite absorver uma demanda maior.</segment>
    <segment id="58">Tamb&amp;eacute</segment>
    <segment id="59">;m n&amp;atilde</segment>
    <segment id="60">;o h&amp;aacute</segment>
    <segment id="61">; necessidade de integra&amp;ccedil</segment>
    <segment id="62">;&amp;atilde</segment>
    <segment id="63">;o com o sistema de metr&amp;ocirc</segment>
    <segment id="64">; e trens</segment>
    <segment id="65">, j&amp;aacute</segment>
    <segment id="66">; que as linhas de &amp;ocirc</segment>
    <segment id="67">;nibus atendem toda a cidade.</segment>
    <segment id="68">Os passageiros ter&amp;atilde</segment>
    <segment id="69">;o que usar o Bilhete &amp;Uacute</segment>
    <segment id="70">;nico: a tarifa n&amp;atilde</segment>
    <segment id="71">;o ser&amp;aacute</segment>
    <segment id="72">; cobrada no validador.</segment>
    <segment id="73">O cobrador ou o motorista ir&amp;aacute</segment>
    <segment id="74">; liberar a passagem pela catraca para aqueles que n&amp;atilde</segment>
    <segment id="75">;o o tiverem (saiba</segment>
    <segment id="76">comocomo solicitar o Bilhete &amp;Uacute</segment>
    <segment id="77">;nico no site da SPTrans).</segment>
    <segment id="78">*Conte&amp;uacute</segment>
    <segment id="79">;do patrocinado produzido pelo Est&amp;uacute</segment>
    <segment id="80">;dio Folha</segment>
  </rst>
