  <rst>
    <segment id="1">Rogério Caboclo tem passado os dias ao telefone</segment>
    <segment id="2">, segundo o próprio.</segment>
    <segment id="3">De seu apartamento em São Paulo</segment>
    <segment id="4">, tem feito contatos com dirigentes (que ele não diz quais são) e conversado com seus advogados.</segment>
    <segment id="5">"Eu estou totalmente consciente do que não fiz"</segment>
    <segment id="6">, disse à Folha o presidente afastado por 30 dias pelo Comitê de Ética da CBF (Confederação Brasileira de Futebol).</segment>
    <segment id="7">Isto é Rogério Caboclo   novamente         de   de  de  representando um  Caboclo é acusado por uma funcionária da confederação de assédio moral e sexual.</segment>
    <segment id="8">Contratada em 2012</segment>
    <segment id="9">, foi cerimonialista</segment>
    <segment id="10">, secretária e foi promovida a assessora especial da presidência.</segment>
    <segment id="11">Ela gravou diálogos com o dirigente em que ele questionava</segment>
    <segment id="12">, entre outras coisas</segment>
    <segment id="13">, sese a assessora "</segment>
    <segment id="14">sese masturbava".</segment>
    <segment id="15">O cartola pede para não comentar mais o assunto.</segment>
    <segment id="16">"</segment>
    <segment id="17">Em conversa com meus advogados</segment>
    <segment id="18">, concluímos que o melhor é não nos manifestarmos.</segment>
    <segment id="19">Espero que você compreenda"</segment>
    <segment id="20">, disse ele</segment>
    <segment id="21">, pedindo para encerrar a ligação.</segment>
    <segment id="22">A defesa de Caboclo</segment>
    <segment id="23">, segundo o próprio</segment>
    <segment id="24">, será feita por Fernanda Tórtima</segment>
    <segment id="25">, especialista em direito penal.</segment>
    <segment id="26">Em contato com a reportagem nesta segunda (7)</segment>
    <segment id="27">, a advogada afirmou que ainda não cuida do</segment>
    <segment id="28">casocaso do presidente afastado da CBF e que apenas o fará</segment>
    <segment id="29">sese chegar à esfera criminal.</segment>
    <segment id="30">"</segment>
    <segment id="31">Nós estamos acertando isso"</segment>
    <segment id="32">, disse o dirigente.</segment>
    <segment id="33">A alguns cartolas com os quais conversou desde segunda (7)</segment>
    <segment id="34">, Caboclo afirmou estar tranquilo e que conseguirá provar que não cometeu o assédio</segment>
    <segment id="35">, embora</segment>
    <segment id="36">embora admita ter tido um comportamento indesejado</segment>
    <segment id="37">, que qualificou</segment>
    <segment id="38">comocomo "brincadeiras".</segment>
    <segment id="39">Caboclo foi afastado no domingo (6) à tarde</segment>
    <segment id="40">, por decisão do Comitê de Ética da CBF.</segment>
    <segment id="41">Isso apenas aconteceu</segment>
    <segment id="42">porque</segment>
    <segment id="43">porque ele resistia a todos os pedidos e conselhos para renunciar ou</segment>
    <segment id="44">sese afastar voluntariamente do cargo para o qual assumiu em 2019 –com duração até 2023.</segment>
    <segment id="45">A saída foi recebida com alívio pela Conmebol e cartolas brasileiros preocupados com a repercussão do</segment>
    <segment id="46">casocaso e possível boicote dos jogadores à Copa América.</segment>
    <segment id="47">À ESPN</segment>
    <segment id="48">, Caboclo havia dito que não demitiria Tite do comando</segment>
    <segment id="49">, masmas outros cartolas têm certeza que isso aconteceria e consideram que teria repercussões péssimas dentro do elenco da seleção.</segment>
    <segment id="50">Uruguai x Brasil   novamente         de   de  de  representando um</segment>
    <segment id="51">Os jogadores questionaram</segment>
    <segment id="52">, em reunião com Caboclo</segment>
    <segment id="53">, a realização da Copa América no país após a desistência de Argentina e Colômbia.</segment>
    <segment id="54">Reclamaram também que não houve diálogo com o elenco sobre a mudança de país.</segment>
    <segment id="55">Aproveitaram para</segment>
    <segment id="56">sese queixar de terem de disputar o torneio um ano antes da Copa do Mundo</segment>
    <segment id="57">, após uma temporada exaustiva e colada em partidas das Eliminatórias.</segment>
    <segment id="58">Jogos que eles consideram muito mais importantes do que a Copa América.</segment>
    <segment id="59">O código da CBF determina</segment>
    <segment id="60">, em seu artigo 22</segment>
    <segment id="61">, que a duração de qualquer sanção é de alçada da comissão de ética da entidade e também diz que o comitê "poderá recomendar ao órgão apropriado da CBF que proceda notificação às autoridades policiais e judiciais competentes".</segment>
    <segment id="62">O Ministério Público do Trabalho do Rio de Janeiro vai investigar o</segment>
    <segment id="63">casocaso.</segment>
    <segment id="64">O código também determina que a aplicação de sanções de dirigentes eleitos (</segment>
    <segment id="65">comocomo o impedimento definitivo do presidente</segment>
    <segment id="66">, por exemplo)</segment>
    <segment id="67">, "ficará sujeita à confirmação das Assembleias Gerais Administrativas das respectivas entidades</segment>
    <segment id="68">, exigindo-</segment>
    <segment id="69">sese aprovação de 3/4 (três quartos) da totalidade de seus membros".</segment>
  </rst>
</analysis>