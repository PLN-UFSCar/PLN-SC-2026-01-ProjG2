  <rst>
    <segment id="1">O seu gato é basicamente uma chita pequena e flexível</segment>
    <segment id="2">, com potencial para correr 50 km/h</segment>
    <segment id="3">, conta Bruce Kornriech</segment>
    <segment id="4">, diretor do centro de saúde felina de Cornell</segment>
    <segment id="5">, nos primeiros minutos do documentário "</segment>
    <segment id="6">Dentro da Mente de um Gato"</segment>
    <segment id="7">, lançamento da Netflix.</segment>
    <segment id="8">Ele é um dos especialistas entrevistados no filme que tem pouco mais de uma hora de duração</segment>
    <segment id="9">, masmas traz tantas informações interessantes que mesmo o gateiro mais aficionado vai</segment>
    <segment id="10">sese surpreender com algumas curiosidades.</segment>
    <segment id="11">Sem seguir uma narrativa muito linear</segment>
    <segment id="12">, o diretor Andy Mitchell aborda desde questões sobre saúde e comportamento animal até fatos históricos</segment>
    <segment id="13">, como</segment>
    <segment id="14">como quando os gatos quase foram dizimados na Europa durante a Idade Média e as primeiras evidências da relação entre humanos e Felis catus</segment>
    <segment id="15">, nome científico do nosso bichano doméstico</segment>
    <segment id="16">, há cerca de 10 mil anos</segment>
    <segment id="17">, no Chipre.</segment>
    <segment id="18">&amp;#039;Dentro da Mente de um</segment>
    <segment id="19">Gato&amp;#039</segment>
    <segment id="20">; entretém e informaMais    novamente         de   de  de  representando</segment>
    <segment id="21">um  Aliás</segment>
    <segment id="22">, conhecer os ancestrais selvagens e caçadores deles ajuda a entender alguns comportamentos do pet</segment>
    <segment id="23">, como</segment>
    <segment id="24">como atacar os nossos tornozelos</segment>
    <segment id="25">, subir em móveis altos e amar</segment>
    <segment id="26">sese esconder em caixas.</segment>
    <segment id="27">Afinal</segment>
    <segment id="28">, o DNA dos gatos não mudou tanto assim nos últimos milhares de anos</segment>
    <segment id="29">, o que significa que temos pequenos predadores dentro de casa.</segment>
    <segment id="30">Sabe aquele ratinho ou barata que ele já caçou e trouxe na boca para você?</segment>
    <segment id="31">Pois é.</segment>
    <segment id="32">Mas apesar dessas atitudes primitivas que acontecem de vez em quando</segment>
    <segment id="33">, nossos peludos são amáveis e podem aprendes vários truques</segment>
    <segment id="34">, como</segment>
    <segment id="35">como mostram as irmãs ucranianas Maryna e Svitlana Savitsky</segment>
    <segment id="36">, que formaram a trupe de gatinhos treinados The Savitsky Cats.</segment>
    <segment id="37">Dúvidas comuns a muitos tutores</segment>
    <segment id="38">, como</segment>
    <segment id="39">como "será que meu gato sabe o nome dele?</segment>
    <segment id="40">", ou, a mais perturbadora</segment>
    <segment id="41">, "será que ele me ama ou só</segment>
    <segment id="42">sese aproveita de mim"</segment>
    <segment id="43">, são respondidas pelas especialistas Kristyn Vitalo</segment>
    <segment id="44">, professora da Unity College</segment>
    <segment id="45">, e Saho Takagi</segment>
    <segment id="46">, pesquisadora da Universidade Azabu.</segment>
    <segment id="47">Muitos dos mistérios sobre a mente dos gatos</segment>
    <segment id="48">, explicam elas</segment>
    <segment id="49">, ainda existem</segment>
    <segment id="50">porque</segment>
    <segment id="51">porque os estudos sobre esses animais foram negligenciados por muito tempo e estão cerca de 15 anos atrasados em comparação às pesquisas sobre cães.</segment>
    <segment id="52">+</segment>
    <segment id="53">GaticesLeia</segment>
    <segment id="54">mais sobre gatos‘Cat People’</segment>
    <segment id="55">, na Netflix</segment>
    <segment id="56">, não é apenas sobre pessoas excêntricas e loucas por gatosGatos precisam de cuidados especiais nos dias friosGato</segment>
    <segment id="57">Lelo volta para biblioteca de Guaxupé após mobilização de moradoresPor meio dos miados</segment>
    <segment id="58">, dos ronrons</segment>
    <segment id="59">, e até da posição do rabo</segment>
    <segment id="60">,</segment>
    <segment id="61">é possível identificar os sentimentos dos bichanos.</segment>
    <segment id="62">Um dos pontos mais interessantes do trabalho de Kristyn e Saho</segment>
    <segment id="63">, mostrado do documentário</segment>
    <segment id="64">, é que a nossa cultura também influencia no comportamento dos felinos.</segment>
    <segment id="65">Repetindo as mesmas experiências nos Estados Unidos e no Japão</segment>
    <segment id="66">, elas descobriram que as atitudes dos gatos são distintas</segment>
    <segment id="67">, e boa parte dessas diferenças pode ser explicada pelos costumes dos tutores</segment>
    <segment id="68">, como</segment>
    <segment id="69">como receber visitas em casa.</segment>
    <segment id="70">Além de entreter</segment>
    <segment id="71">, "Dentro da Mente de um Gato" é um guia para compreender e viver melhor com seu bigodudo.</segment>
    <segment id="72">Dê uma piscadinha bem devagar para o seu gato</segment>
    <segment id="73">, faça um carinho e aproveite a companhia dele para assistir ao filme.</segment>
    <segment id="74">Siga o blog Gatices no Twitter</segment>
    <segment id="75">, Instagram e Facebook.</segment>
  </rst>
</analysis>