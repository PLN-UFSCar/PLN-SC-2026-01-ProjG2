  <rst>
    <segment id="1">A seleção brasileira estreia na Copa do Mundo em 24 de novembro</segment>
    <segment id="2">, 25 dias após a realização do segundo turno das eleições gerais no Brasil.</segment>
    <segment id="3">O técnico Tite</segment>
    <segment id="4">, 61, porém</segment>
    <segment id="5">porém, preocupa-</segment>
    <segment id="6">sese em separar o futebol da política.</segment>
    <segment id="7">Para ele</segment>
    <segment id="8">, o esporte é um agente educativo</segment>
    <segment id="9">, além de patrimônio cultural</segment>
    <segment id="10">, não a solução dos problemas do país.  "</segment>
    <segment id="11">O futebol não pode carregar a solução do prazer</segment>
    <segment id="12">, da satisfação.</segment>
    <segment id="13">Ele não bota comida na boca de ninguém</segment>
    <segment id="14">, nem emprego na boca de ninguém</segment>
    <segment id="15">, nem educação na boca de ninguém"</segment>
    <segment id="16">, afirma o treinador à Folha.</segment>
    <segment id="17">Em entrevista na sede da CBF (Confederação Brasileira de Futebol)</segment>
    <segment id="18">, no Rio</segment>
    <segment id="19">, o comandante que sonha em dar ao Brasil o seu sexto título mundial diz que "não tem</segment>
    <segment id="20">comocomo não ficar ligado" nas principais questões sociais do Brasil</segment>
    <segment id="21">, masmas prioriza seu trabalho.</segment>
    <segment id="22">"</segment>
    <segment id="23">Nossa prioridade é a seleção.</segment>
    <segment id="24">"</segment>
    <segment id="25">No Qatar</segment>
    <segment id="26">, Tite também vai encontrar um cenário que o desagrada.</segment>
    <segment id="27">Por disputar o torneio em um país com histórico de violação dos direitos humanos</segment>
    <segment id="28">, inclusive durante a construção dos estádios da Copa</segment>
    <segment id="29">, ele diz que não estará na "plenitude de sua satisfação".</segment>
    <segment id="30">Já em relação à seleção brasileira</segment>
    <segment id="31">, ele acredita que a equipe chegará ao torneio mais bem-preparada do que no último Mundial</segment>
    <segment id="32">, na Rússia</segment>
    <segment id="33">, em 2018</segment>
    <segment id="34">, quando o time foi eliminado nas quartas de final pela Bélgica.</segment>
    <segment id="35">"Temos mais opções.</segment>
    <segment id="36">"  </segment>
    <segment id="37">Há quanto tempo você tem a lista de jogadores que levará para o Qatar?</segment>
    <segment id="38">Ela [a lista] é recente</segment>
    <segment id="39">porque</segment>
    <segment id="40">porque é construída a cada jogo</segment>
    <segment id="41">, a cada treino.</segment>
    <segment id="42">Ela é construída a cada performance do atleta no seu clube</segment>
    <segment id="43">, a cada acompanhamento nosso em tempo integral do atleta no jogo</segment>
    <segment id="44">, e não assistindo aos melhores momentos.</segment>
    <segment id="45">Mas quando você chegou ao mais próximo dessa lista final?</segment>
    <segment id="46">Quando terminou esses dois jogos.</segment>
    <segment id="47">Agora, ela fica à mercê desse produto final.</segment>
    <segment id="48">Quantas dúvidas ainda restam para fechar o elenco?</segment>
    <segment id="49">Seis, sete disputas [estão abertas].</segment>
    <segment id="50">Como você lida com a pressão por determinadas convocações?</segment>
    <segment id="51">Primeiro</segment>
    <segment id="52">, com respeito</segment>
    <segment id="53">, desde que seja respeitosa.</segment>
    <segment id="54">Segundo</segment>
    <segment id="55">, olhar e fazer o nosso julgamento.</segment>
    <segment id="56">Senão, não vou conseguir.</segment>
    <segment id="57">Consegue ficar alheio às cobranças mais fortes?</segment>
    <segment id="58">Não, mas</segment>
    <segment id="59">mas dá para filtrar.</segment>
    <segment id="60">Deixar os ruídos do lado de fora é normal.</segment>
    <segment id="61">É a função de vocês [da imprensa] elogiar ou criticar.</segment>
    <segment id="62">É a função do cronista</segment>
    <segment id="63">, do comentarista e do jornalista.</segment>
    <segment id="64">Eu tenho que entender isso.</segment>
    <segment id="65">Se eu falo dos processos do técnico</segment>
    <segment id="66">, o técnico tem que entender os processos do jornalista.</segment>
    <segment id="67">Então, vocês não vão emitir opinião?</segment>
    <segment id="68">Que jornalismo é esse?</segment>
    <segment id="69">Agora, há diferenças básicas: a opinião</segment>
    <segment id="70">, e aí ela é de qualificação</segment>
    <segment id="71">, baseada em informações verdadeiras</segment>
    <segment id="72">, essa é uma opinião.</segment>
    <segment id="73">E tem a opinião rasa.</segment>
    <segment id="74">O que me deixa muito chateado é quando ela é com má-informação.</segment>
    <segment id="75">Qual a diferença prática no trabalho de um técnico que consegue ficar tanto tempo na seleção</segment>
    <segment id="76">, como</segment>
    <segment id="77">como é o seu</segment>
    <segment id="78">casocaso?</segment>
    <segment id="79">Relações pessoais de confiança com o grupo todo.</segment>
    <segment id="80">Eles já sabem</segment>
    <segment id="81">comocomo o técnico reage no bom ou no mau</segment>
    <segment id="82">, no médio e na exposição.</segment>
    <segment id="83">Que tipo de liderança</segment>
    <segment id="84">, qual a qualificação profissional da comissão</segment>
    <segment id="85">, o nível de conhecimento.</segment>
    <segment id="86">Eles [atletas] comparam com os técnicos de alto nível que eles têm.</segment>
    <segment id="87">É inevitável</segment>
    <segment id="88">, é humano.</segment>
    <segment id="89">Tite pretende deixar a seleção brasileira após a Copa do Mundo  - Eduardo Anizelli/FolhapressO que foi determinante para você conseguir esse tempo na seleção?</segment>
    <segment id="90">Primeiro</segment>
    <segment id="91">, o meu histórico todo</segment>
    <segment id="92">, o meu histórico passado de construtor de equipe.</segment>
    <segment id="93">Segundo</segment>
    <segment id="94">, os resultados dentro da seleção</segment>
    <segment id="95">, que batem todos os recordes de qualquer técnico ao longo das trajetórias deles.</segment>
    <segment id="96">Nas Eliminatórias</segment>
    <segment id="97">, batemos todos os recordes de gols feitos</segment>
    <segment id="98">, gols tomados</segment>
    <segment id="99">, saldo de gols</segment>
    <segment id="100">, número de vitórias</segment>
    <segment id="101">, vitórias em casa.</segment>
    <segment id="102">Temos 13 gols a mais que a Argentina</segment>
    <segment id="103">, em número de gols feitos.</segment>
    <segment id="104">A quantos jogos de Sérvia</segment>
    <segment id="105">, Suíça e Camarões</segment>
    <segment id="106">, rivais do Brasil no Qatar</segment>
    <segment id="107">, você já assistiu?</segment>
    <segment id="108">Integralmente</segment>
    <segment id="109">, não.</segment>
    <segment id="110">Melhores momentos</segment>
    <segment id="111">, sim, e o relato deles [dos membros da comissão].</segment>
    <segment id="112">Continuo aprofundando o nosso modelo e os atletas.</segment>
    <segment id="113">Um jogo eu vi separadamente</segment>
    <segment id="114">, masmas não com a devida profundidade que darei a partir de agora.</segment>
    <segment id="115">Quantas vezes reviu o jogo com a Bélgica?</segment>
    <segment id="116">Depois da Copa</segment>
    <segment id="117">, eu devo ter revisto umas cinco vezes.</segment>
    <segment id="118">Depois eu pego</segment>
    <segment id="119">, levanto e digo: chega.</segment>
    <segment id="120">Em suas análises</segment>
    <segment id="121">, identificou o momento ou o fator que considera determinante para aquela derrota?</segment>
    <segment id="122">Não.  E no conjunto do jogo</segment>
    <segment id="123">, quais os fatores que você faria diferente hoje?</segment>
    <segment id="124">Não [faria diferente]</segment>
    <segment id="125">porque</segment>
    <segment id="126">porque eu não tinha conhecimento e</segment>
    <segment id="127">, para mim</segment>
    <segment id="128">, quem ganhou foi a Bélgica</segment>
    <segment id="129">, pela grande qualidade que ela tem.</segment>
    <segment id="130">Não fiz diferente</segment>
    <segment id="131">porque</segment>
    <segment id="132">porque eu não tinha ou conhecimento ou maturidade para fazer diferente.</segment>
    <segment id="133">Foi nosso melhor jogo na Copa em termos de desempenho para mim.</segment>
    <segment id="134">Jogamos contra a melhor equipe da Copa e finalizamos 20 vezes</segment>
    <segment id="135">, sendo 11 no gol.</segment>
    <segment id="136">O De Bruyne falou assim: o Brasil jogou melhor</segment>
    <segment id="137">, masmas nós fomos efetivos.</segment>
    <segment id="138">O Brasil chegará no Qatar mais favorito do que chegou na Rússia?</segment>
    <segment id="139">Boa pergunta.</segment>
    <segment id="140">[Temos mais opções de] nomes e jogo.</segment>
    <segment id="141">Aquilo que aconteceu</segment>
    <segment id="142">, machucando o Dani [Alves]</segment>
    <segment id="143">, machucando</segment>
    <segment id="144">, principalmente</segment>
    <segment id="145">, o Renato [Augusto] em 2018</segment>
    <segment id="146">, hoje a gente tem modelos diferentes</segment>
    <segment id="147">, ajustes diferentes</segment>
    <segment id="148">, preparo de atletas diferentes.</segment>
    <segment id="149">Essa é uma diferença significativa.  Acredita que esta será a última Copa do Neymar</segment>
    <segment id="150">, como</segment>
    <segment id="151">como ele mesmo já disse?</segment>
    <segment id="152">Respeito muito a opinião do Neymar e veementemente discordo.</segment>
    <segment id="153">Ele vai jogar outra Copa</segment>
    <segment id="154">, eu afirmo que ele vai jogar.</segment>
    <segment id="155">Eu tenho dúvida</segment>
    <segment id="156">sese ele joga uma segunda</segment>
    <segment id="157">, masmas eu afirmo que ele vai jogar [outra depois do Qatar].</segment>
    <segment id="158">Um jogador com a qualidade técnica excepcional que ele tem</segment>
    <segment id="159">, associado a virtudes físicas de jogador leve</segment>
    <segment id="160">, flutua</segment>
    <segment id="161">, ágil</segment>
    <segment id="162">, móvel</segment>
    <segment id="163">, ele seguindo nessa condição física</segment>
    <segment id="164">, nesses cuidados físicos que está tendo agora</segment>
    <segment id="165">, o Neymar vai jogar tranquilamente outra Copa.</segment>
    <segment id="166">TiteTécnico da seleção brasileiraA saúde mental dos atletas é uma preocupação da comissão técnica da seleção?</segment>
    <segment id="167">Não diretamente com a CBF</segment>
    <segment id="168">, masmas ela tem.</segment>
    <segment id="169">Só por uma questão nossa</segment>
    <segment id="170">, intimista</segment>
    <segment id="171">, ela é pessoal comigo</segment>
    <segment id="172">, ela é de comissão técnica.</segment>
    <segment id="173">Inclusive</segment>
    <segment id="174">, os próprios atletas sabem</segment>
    <segment id="175">, porque</segment>
    <segment id="176">porque eu disse numa palestra de temas comportamentais que eu tenho uma profissional que orienta</segment>
    <segment id="177">para que</segment>
    <segment id="178">para que a gente possa nos direcionar</segment>
    <segment id="179">, masmas que vocês tenham essa capacidade de saber que é importante.</segment>
    <segment id="180">Quando tomou a decisão de que não vai seguir na seleção após a Copa?</segment>
    <segment id="181">Um ano e meio</segment>
    <segment id="182">, dois anos atrás.</segment>
    <segment id="183">Eu chamei a comissão técnica toda e coloquei a eles.</segment>
    <segment id="184">Depois de encerrar o ciclo</segment>
    <segment id="185">, novas lideranças têm que surgir e um novo processo tem que acontecer.</segment>
    <segment id="186">É assim que</segment>
    <segment id="187">sese oxigena</segment>
    <segment id="188">, que revigora e evolui.</segment>
    <segment id="189">Eu, em termos de maturidade</segment>
    <segment id="190">, terei a grande oportunidade de fazer um ciclo inteiro na seleção brasileira</segment>
    <segment id="191">, que é extraordinário.</segment>
    <segment id="192">A busca por esses novos objetivos tem a ver também com um cansaço seu em relação à rotina na CBF?</segment>
    <segment id="193">Você cansou de trabalhar na CBF?</segment>
    <segment id="194">Não.</segment>
    <segment id="195">Se fosse só por vontade própria eu teria continuado.</segment>
    <segment id="196">Mas é o contexto todo.</segment>
    <segment id="197">São etapas e a maturidade.</segment>
    <segment id="198">Quando houve o escândalo envolvendo o ex-presidente da CBF</segment>
    <segment id="199">, Rogério Caboclo</segment>
    <segment id="200">, acusado de assédio sexual e moral</segment>
    <segment id="201">, alguns veículos noticiaram que você cogitou deixar a seleção brasileira e</segment>
    <segment id="202">sese afastar do que estava acontecendo.</segment>
    <segment id="203">Isso ocorreu?</segment>
    <segment id="204">Cogitação mentirosa.</segment>
    <segment id="205">Em nenhum momento passou pela sua cabeça deixar a seleção?</segment>
    <segment id="206">Cogitação mentirosa</segment>
    <segment id="207">, com ponto de exclamação.</segment>
    <segment id="208">Não teve nenhuma conversa paralela.</segment>
    <segment id="209">Teve [conversa] logo depois da Bélgica e</segment>
    <segment id="210">, assim</segment>
    <segment id="211">, eu pensei 950 mil vezes.</segment>
    <segment id="212">Depois da seleção</segment>
    <segment id="213">, o objetivo é trabalhar na Europa?</segment>
    <segment id="214">Claro que eu penso "pô</segment>
    <segment id="215">, como</segment>
    <segment id="216">como vai ser o meu futuro?</segment>
    <segment id="217">".</segment>
    <segment id="218">Mas, se</segment>
    <segment id="219">se tu quer saber alguma coisa</segment>
    <segment id="220">, eu estou nem aí para o que vier depois.</segment>
    <segment id="221">Eu quero é a seleção.</segment>
    <segment id="222">Isso me fascina.</segment>
    <segment id="223">É o maior orgulho que um profissional pode ter.</segment>
    <segment id="224">Depois vai ser um percurso.</segment>
    <segment id="225">O que eu não vou é trabalhar no Brasil no ano depois da Copa.</segment>
    <segment id="226">Se voltar a trabalhar no Brasil logo após a Copa</segment>
    <segment id="227">, acredita que pode perder a força do impulso que a seleção pode dar?</segment>
    <segment id="228">Isso pesou na sua decisão?</segment>
    <segment id="229">[A decisão] passa por uma uma palavra da minha esposa de dizer assim</segment>
    <segment id="230">, ó: o que eles fazem com os técnicos brasileiros não existe.</segment>
    <segment id="231">Eu não quero que tu treine no Brasil um ano depois que tu sair da Copa.</segment>
    <segment id="232">Essa exposição</segment>
    <segment id="233">, de cortar carne o tempo todo</segment>
    <segment id="234">, é desumana.</segment>
    <segment id="235">Você está estudando idiomas?</segment>
    <segment id="236">Tem em mente trabalhar em um país em que</segment>
    <segment id="237">sese sinta confortável com a língua?</segment>
    <segment id="238">Sabe por que eu não estudo agora e eu teria até vontade?</segment>
    <segment id="239">É que isso gera especulação para um país que eu possa ir.</segment>
    <segment id="240">Se eu for estudar agora</segment>
    <segment id="241">, também vou ficar projetando.</segment>
    <segment id="242">Como eu não quero</segment>
    <segment id="243">, eu isolo as variáveis.</segment>
    <segment id="244">Agora,</segment>
    <segment id="245">sese você fala Itália</segment>
    <segment id="246">, o italiano eu sei</segment>
    <segment id="247">, vou compreender.</segment>
    <segment id="248">O espanhol também entendo.</segment>
    <segment id="249">Então, faltaria o inglês?</segment>
    <segment id="250">É [risos].</segment>
    <segment id="251">Sim.</segment>
    <segment id="252">Qual sua opinião sobre técnicos estrangeiros na seleção?</segment>
    <segment id="253">Prefiro os brasileiros e respeito os estrangeiros.</segment>
    <segment id="254">Por ser uma Copa depois de uma eleição que tem dividido o país</segment>
    <segment id="255">, você acredita que o torneio pode unir os brasileiros?</segment>
    <segment id="256">O futebol e o esporte unem-</segment>
    <segment id="257">sese por si só.</segment>
    <segment id="258">Não vejo esses outros...</segment>
    <segment id="259">Essas situações paralelas</segment>
    <segment id="260">, importantes</segment>
    <segment id="261">, masmas paralelas</segment>
    <segment id="262">, masmas cada um carrega suas responsabilidades.</segment>
    <segment id="263">Responsabilidades sociais são suas e o futebol não pode carregar a solução do prazer</segment>
    <segment id="264">, da satisfação.</segment>
    <segment id="265">Ele não bota comida na boca de ninguém</segment>
    <segment id="266">, nem emprego na boca de ninguém</segment>
    <segment id="267">, nem educação na boca de ninguém.</segment>
    <segment id="268">Ele é um agente educativo esportivo</segment>
    <segment id="269">, patrimônio cultural e ele deve seguir dessa forma.</segment>
    <segment id="270">Qual sua opinião sobre a realização da Copa no Qatar</segment>
    <segment id="271">, um país com longo histórico de violação de direitos humanos?</segment>
    <segment id="272">Procuro igualdade social e justiça em qualquer que seja o país.</segment>
    <segment id="273">Em termos legais</segment>
    <segment id="274">, gostaria que tivesse cada vez mais dois aspectos: educação e punição.</segment>
    <segment id="275">Quaisquer que sejam os fatores preconceituosos ou</segment>
    <segment id="276">, no caso</segment>
    <segment id="277">caso, de mão de obra de exploração.</segment>
    <segment id="278">Justiça.</segment>
    <segment id="279">Seleção goleia a Tunísia no último amistoso antes da Copa do QatarMais    novamente         de   de  de  representando um</segment>
    <segment id="280">O incomoda disputar uma Copa em um país com esse histórico?</segment>
    <segment id="281">Ela [Copa no Qatar] não me deixa na plenitude da minha satisfação.</segment>
    <segment id="282">Gostaria que fosse em um país que não tivesse esses problemas?</segment>
    <segment id="283">Sim, gostaria que fosse sem esses problemas.</segment>
    <segment id="284">Você consegue separar o momento de preparação para uma Copa do Mundo com o fato de todos os dias abrir os jornais e tomar consciência dos problemas do país?</segment>
    <segment id="285">De que forma isso o afeta?</segment>
    <segment id="286">Não tem</segment>
    <segment id="287">comocomo não ficar ligado</segment>
    <segment id="288">, porque</segment>
    <segment id="289">porque nós somos seres humanos</segment>
    <segment id="290">, masmas tem a possibilidade de priorizar.</segment>
    <segment id="291">Isso é uma escolha.</segment>
    <segment id="292">A nossa prioridade é a seleção brasileira</segment>
    <segment id="293">, masmas que está associado a esses fatores</segment>
    <segment id="294">, inevitavelmente</segment>
    <segment id="295">, sim,</segment>
    <segment id="296">comocomo ser humano.</segment>
    <segment id="297">Tem um acordo entre os jogadores da seleção brasileira para não</segment>
    <segment id="298">sese manifestarem sobre política enquanto estiverem a serviço da seleção?</segment>
    <segment id="299">Nunca teve determinação</segment>
    <segment id="300">, nem por parte da direção para a comissão técnica</segment>
    <segment id="301">, nem por parte da comissão técnica com os atletas.</segment>
    <segment id="302">Absolutamente não.</segment>
    <segment id="303">Alguns veículos noticiaram que Neymar teria quebrado esse suposto acordo manifestando apoio ao candidato à reeleição</segment>
    <segment id="304">, Jair Bolsonaro.</segment>
    <segment id="305">O acordo</segment>
    <segment id="306">, então</segment>
    <segment id="307">, não existe?</segment>
    <segment id="308">Não existe.</segment>
    <segment id="309">Nós vivemos o país democrático.</segment>
    <segment id="310">Ou senão a gente fica sem democracia</segment>
    <segment id="311">, só quando concorda comigo.</segment>
    <segment id="312">Você se</segment>
    <segment id="313">se incomoda com a imagem de antibolsonarista que tem sido disseminada a seu respeito?</segment>
    <segment id="314">As pessoas que pensam isso que carreguem com elas</segment>
    <segment id="315">, porque</segment>
    <segment id="316">porque essa batalha eu não vou carregar</segment>
    <segment id="317">, isso é um problema delas.</segment>
    <segment id="318">O meu é a minha paz de espírito.</segment>
    <segment id="319">No segundo turno das eleições presidenciais</segment>
    <segment id="320">, em quem vai votar?</segment>
    <segment id="321">Eu vou votar de forma secreta e tenho bem claras as minhas ideias.</segment>
    <segment id="322">Vou fazer em termos pessoais e particularmente.</segment>
    <segment id="323">RAIO-X  Tite</segment>
    <segment id="324">, 61 Treinador de futebol</segment>
    <segment id="325">, comanda a seleção brasileira desde 2016.</segment>
    <segment id="326">À frente da equipe canarinho</segment>
    <segment id="327">, foi campeão da Copa América em 2019.</segment>
  </rst>
</analysis>