  <rst>
    <segment id="1">A Justi&amp;ccedil</segment>
    <segment id="2">;a argentina ordenou uma busca na casa do m&amp;eacute</segment>
    <segment id="3">;dico de Diego Maradona</segment>
    <segment id="4">, Leopoldo Luque</segment>
    <segment id="5">, que est&amp;aacute</segment>
    <segment id="6">; sendo investigado sob suspeita de homic&amp;iacute</segment>
    <segment id="7">;dio culposo na morte do craque.</segment>
    <segment id="8">Os promotores Laura Capra</segment>
    <segment id="9">, Patricio Ferrari e Cosme Irribaren disseram que a busca foi para &amp;quot</segment>
    <segment id="10">;procurar documenta&amp;ccedil</segment>
    <segment id="11">;&amp;atilde</segment>
    <segment id="12">;o para determinar</segment>
    <segment id="13">sese, durante a interna&amp;ccedil</segment>
    <segment id="14">;&amp;atilde</segment>
    <segment id="15">;o domicili&amp;aacute</segment>
    <segment id="16">;ria de Maradona</segment>
    <segment id="17">, houve irregularidades&amp;quot</segment>
    <segment id="18">;.</segment>
    <segment id="19">Diego Maradona é velado na Casa Rosada</segment>
    <segment id="20">, em Buenos Aires   novamente         de   de  de  representando um  Maradona teve alta da cl&amp;iacute</segment>
    <segment id="21">;nica</segment>
    <segment id="22">Olivos no &amp;uacute</segment>
    <segment id="23">;ltimo dia 11</segment>
    <segment id="24">, ap&amp;oacute</segment>
    <segment id="25">;s cirurgia para retirar um hematoma na cabe&amp;ccedil</segment>
    <segment id="26">;a, contra a vontade dos m&amp;eacute</segment>
    <segment id="27">;dicos da institui&amp;ccedil</segment>
    <segment id="28">;&amp;atilde</segment>
    <segment id="29">;o, que declararam &amp;agrave</segment>
    <segment id="30">; Justi&amp;ccedil</segment>
    <segment id="31">;a que recomendaram a Luque que Maradona continuasse internado mais um tempo.</segment>
    <segment id="32">Foi Luque quem ligou para o servi&amp;ccedil</segment>
    <segment id="33">;o de ambul&amp;acirc</segment>
    <segment id="34">;ncias 911 &amp;agrave</segment>
    <segment id="35">;s 12h16 da &amp;uacute</segment>
    <segment id="36">;ltima quarta-feira (25).</segment>
    <segment id="37">O m&amp;eacute</segment>
    <segment id="38">;dico, por&amp;eacute</segment>
    <segment id="39">;m, n&amp;atilde</segment>
    <segment id="40">;o estava na casa do ex-jogador e havia sido informado pelos que o acompanhavam &amp;ndash</segment>
    <segment id="41">;a psiquiatra</segment>
    <segment id="42">, um enfermeiro e o sobrinho do &amp;iacute</segment>
    <segment id="43">;dolo, que estavam com Maradona&amp;ndash</segment>
    <segment id="44">; que ele n&amp;atilde</segment>
    <segment id="45">;o sese sentia bem.</segment>
    <segment id="46">Paralelamente</segment>
    <segment id="47">, eles tamb&amp;eacute</segment>
    <segment id="48">;m chamaram uma ambul&amp;acirc</segment>
    <segment id="49">;ncia do plano de sa&amp;uacute</segment>
    <segment id="50">;de do ex-jogador.</segment>
    <segment id="51">Ap&amp;oacute</segment>
    <segment id="52">;s a busca em sua casa</segment>
    <segment id="53">, o m&amp;eacute</segment>
    <segment id="54">;dico disse que est&amp;aacute</segment>
    <segment id="55">; &amp;agrave</segment>
    <segment id="56">;</segment>
    <segment id="57">disposi&amp;ccedil</segment>
    <segment id="58">;&amp;atilde</segment>
    <segment id="59">;o da Justi&amp;ccedil</segment>
    <segment id="60">;a para prestar esclarecimentos.</segment>
    <segment id="61">&amp;quot;Eu sei o que fiz com Diego e sei</segment>
    <segment id="62">comocomo fiz.</segment>
    <segment id="63">Tenho tudo para mostrar.</segment>
    <segment id="64">Tenho absoluta certeza de que fiz o melhor que pude com Diego&amp;rdquo</segment>
    <segment id="65">;, afirmou Luque aos jornalistas que estavam em frente de sua casa no bairro de Adrogu&amp;eacute</segment>
    <segment id="66">;.</segment>
    <segment id="67">&amp;quot;Estou muito mal</segment>
    <segment id="68">porque</segment>
    <segment id="69">porque o meu amigo morreu&amp;quot</segment>
    <segment id="70">;, acrescentou.</segment>
    <segment id="71">O médico Leopoldo Luque ao lado de Maradona pouco depois da operação na cabeça do ex-jogador - Fede Bueno no TwitterA Justi&amp;ccedil</segment>
    <segment id="72">;a investiga a atua&amp;ccedil</segment>
    <segment id="73">;&amp;atilde</segment>
    <segment id="74">;o dos enfermeiros.</segment>
    <segment id="75">Especificamente</segment>
    <segment id="76">, uma contradi&amp;ccedil</segment>
    <segment id="77">;&amp;atilde</segment>
    <segment id="78">;o da enfermeira que cuidou dele durante a noite e que afirma n&amp;atilde</segment>
    <segment id="79">;o ter entrado no quarto durante a manh&amp;atilde</segment>
    <segment id="80">;.</segment>
    <segment id="81">Depois</segment>
    <segment id="82">, por&amp;eacute</segment>
    <segment id="83">;m, em sua declara&amp;ccedil</segment>
    <segment id="84">;&amp;atilde</segment>
    <segment id="85">;o oficial &amp;agrave</segment>
    <segment id="86">; pol&amp;iacute</segment>
    <segment id="87">;cia, ela disse outra coisa</segment>
    <segment id="88">, que havia entrado e que Maradona havia</segment>
    <segment id="89">sese recusado a ter seus sinais vitais registrados.</segment>
    <segment id="90">As filhas de Maradona</segment>
    <segment id="91">, Dalma e Gianinna</segment>
    <segment id="92">, e sua ex-mulher</segment>
    <segment id="93">, Claudia Villafa&amp;ntilde</segment>
    <segment id="94">;e, disseram &amp;agrave</segment>
    <segment id="95">;</segment>
    <segment id="96">pol&amp;iacute</segment>
    <segment id="97">;cia que Luque lhes havia garantido que a casa em que Maradona ia estar depois da alta da cl&amp;iacute</segment>
    <segment id="98">;nica Olivos teria &amp;quot</segment>
    <segment id="99">;condi&amp;ccedil</segment>
    <segment id="100">;&amp;otilde</segment>
    <segment id="101">;es parecidas &amp;agrave</segment>
    <segment id="102">;s do hospital&amp;quot</segment>
    <segment id="103">;.</segment>
    <segment id="104">A trajetória de Maradona   novamente         de   de  de  representando um  Agora</segment>
    <segment id="105">, elas pedem a investiga&amp;ccedil</segment>
    <segment id="106">;&amp;atilde</segment>
    <segment id="107">;o sobre o comportamento do m&amp;eacute</segment>
    <segment id="108">;dico porque</segment>
    <segment id="109">porque a resid&amp;ecirc</segment>
    <segment id="110">;ncia, tamb&amp;eacute</segment>
    <segment id="111">;m investigada</segment>
    <segment id="112">, n&amp;atilde</segment>
    <segment id="113">;o tinha nem sequer um desfibrilador ou equipamento necess&amp;aacute</segment>
    <segment id="114">;rio para atend&amp;ecirc</segment>
    <segment id="115">;-lo no</segment>
    <segment id="116">casocaso de uma emerg&amp;ecirc</segment>
    <segment id="117">;ncia.</segment>
    <segment id="118">A procuradoria-geral do departamento de San Isidro</segment>
    <segment id="119">, que ordenou as buscas</segment>
    <segment id="120">, afirmou que elas eram necess&amp;aacute</segment>
    <segment id="121">;rias por conta &amp;quot</segment>
    <segment id="122">;das provas que foram sendo recolhidas por meio dos depoimentos que investigam as condi&amp;ccedil</segment>
    <segment id="123">;&amp;otilde</segment>
    <segment id="124">;es de Diego</segment>
    <segment id="125">Armando Maradona&amp;quot</segment>
    <segment id="126">;, segundo comunicado.</segment>
    <segment id="127">Adeus de Maradona Diego Maradona</segment>
    <segment id="128">, herói de Copa e mito argentino</segment>
    <segment id="129">, morre aos 60Maradona sintetiza Argentina e morre</segment>
    <segment id="130">comocomo maior mito do paísApós velório caótico na Casa Rosada</segment>
    <segment id="131">, Maradona é enterradoEx-mulher e filhas de Maradona afastam estafe do craque após sua morteVilla Fiorito viu Maradona nascer</segment>
    <segment id="132">, cair em fezes e começar a ser um gênio</segment>
  </rst>
