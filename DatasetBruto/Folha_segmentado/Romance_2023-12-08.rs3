  <rst>
    <segment id="1">Em vários momentos do livro "Casa de Alvenaria"</segment>
    <segment id="2">, Carolina Maria de Jesus manifesta seu desejo de ser reconhecida</segment>
    <segment id="3">comocomo escritora de ficção e discorre sobre projetos que está desenvolvendo.</segment>
    <segment id="4">O primeiro passo para aquilo que ela almejava naquela época acontece só agora</segment>
    <segment id="5">, propriamente</segment>
    <segment id="6">, com o lançamento do romance inédito "</segment>
    <segment id="7">O Escravo" pela Companhia das Letras.</segment>
    <segment id="8">A escritora brasileira Carolina Maria de Jesus durante noite de autógrafos do lançamento de seu livro &amp;#039</segment>
    <segment id="9">;Quarto de Despejo&amp;#039</segment>
    <segment id="10">;, em uma livraria em São Paulo- Acervo UH/FolhapressA face mais lembrada de Carolina é a de memorialista.</segment>
    <segment id="11">Foi com "Quarto de Despejo"</segment>
    <segment id="12">, de 1960</segment>
    <segment id="13">, que ela ganhou notoriedade e</segment>
    <segment id="14">sese projetou</segment>
    <segment id="15">comocomo um dos maiores nomes da literatura brasileira</segment>
    <segment id="16">, tendo sido traduzida para 16 idiomas.</segment>
    <segment id="17">Mas só esse lado da autora foi valorizado pelos editores de então.</segment>
    <segment id="18">Ela se</segment>
    <segment id="19">se aventurou</segment>
    <segment id="20">comocomo poeta</segment>
    <segment id="21">, contista</segment>
    <segment id="22">, dramaturga</segment>
    <segment id="23">, cronista e romancista</segment>
    <segment id="24">, masmas foi desincentivada a escrever qualquer coisa que não fosse diário.</segment>
    <segment id="25">"</segment>
    <segment id="26">Esse projeto de Carolina foi deturpado pelos primeiros editores</segment>
    <segment id="27">, que só</segment>
    <segment id="28">sese interessavam pelos diários"</segment>
    <segment id="29">, afirma Amanda Crispim</segment>
    <segment id="30">, pesquisadora que compõe o conselho responsável por publicar os inéditos da autora</segment>
    <segment id="31">, formado em grande parte por mulheres negras.</segment>
    <segment id="32">A coordenação é da escritora Conceição Evaristo e de Vera Eunice de Jesus</segment>
    <segment id="33">, filha de Carolina.</segment>
    <segment id="34">A primeira parte desse projeto</segment>
    <segment id="35">, que tem seus direitos confiados à editora Companhia das Letras</segment>
    <segment id="36">, foi o relançamento de originais de "Casa de Alvenaria"</segment>
    <segment id="37">, com trechos até então desconhecidos que mostravam a relação complexa de Carolina com Audálio Dantas</segment>
    <segment id="38">, jornalista que a revelou.</segment>
    <segment id="39">Os dois</segment>
    <segment id="40">sese conheceram em 1958</segment>
    <segment id="41">, quando ele fazia uma reportagem sobre a favela do Canindé</segment>
    <segment id="42">, em São Paulo</segment>
    <segment id="43">, e ela catava papel nas ruas da cidade para sustentar a família.</segment>
    <segment id="44">Quem foi Carolina Maria de Jesus</segment>
    <segment id="45">, autora de &amp;#039</segment>
    <segment id="46">;Quarto de Despejo&amp;#039</segment>
    <segment id="47">;Mais    novamente         de   de  de  representando um</segment>
    <segment id="48">O segundo passo do projeto é o lançamento deste "</segment>
    <segment id="49">O Escravo".</segment>
    <segment id="50">O livro conta a história dos primos Rosa e Renato</segment>
    <segment id="51">, dois apaixonados que seguem caminhos diferentes por pressões da família e adversidades sociais.</segment>
    <segment id="52">"</segment>
    <segment id="53">Ele fala de um amor impossível e de</segment>
    <segment id="54">comocomo o dinheiro pode influenciar as escolhas e os destinos das pessoas"</segment>
    <segment id="55">, descreve Crispim.</segment>
    <segment id="56">Segundo ela</segment>
    <segment id="57">, o livro aborda assuntos que Carolina já tratava em suas obras não ficcionais</segment>
    <segment id="58">, masmas a partir de um enredo todo inventado.</segment>
    <segment id="59">Na obra</segment>
    <segment id="60">, segundo Vera Eunice de Jesus</segment>
    <segment id="61">, Carolina vai mudando a trama e o contexto de propósito</segment>
    <segment id="62">, de modo que</segment>
    <segment id="63">, quando o leitor entende a história</segment>
    <segment id="64">, ela toma outro rumo.</segment>
    <segment id="65">"</segment>
    <segment id="66">Carolina tem noção do que está fazendo"</segment>
    <segment id="67">, afirma a filha.</segment>
    <segment id="68">É incerta a época exata em que o livro foi escrito.</segment>
    <segment id="69">A pesquisadora afirma que ele passou por reescritas e existiram outras versões —o texto editado agora foi retirado de manuscritos do Museu Histórico Nacional de Sacramento</segment>
    <segment id="70">, onde estão também lembranças de viagens</segment>
    <segment id="71">, fotos</segment>
    <segment id="72">, recortes de jornais</segment>
    <segment id="73">, anotações e cadernos de material inédito da autora.</segment>
    <segment id="74">Quadro sem título</segment>
    <segment id="75">, da série &amp;#039</segment>
    <segment id="76">;Dia de Baile&amp;#039</segment>
    <segment id="77">;, de Allan Weber</segment>
    <segment id="78">, que ilustra capa de &amp;#039</segment>
    <segment id="79">;O Escravo&amp;#039</segment>
    <segment id="80">;, de Carolina Maria de Jesus - Pat Kilgore/Divulgação</segment>
    <segment id="81">Na edição publicada</segment>
    <segment id="82">, não foram feitas correções ortográficas ou adequações à norma padrão da língua portuguesa.</segment>
    <segment id="83">Há erros que foram mantidos deliberadamente</segment>
    <segment id="84">, com a mínima intervenção possível.</segment>
    <segment id="85">Por outro lado</segment>
    <segment id="86">, Carolina explora palavras eruditas na obra</segment>
    <segment id="87">, algumas até de difícil entendimento para o conselho.</segment>
    <segment id="88">"</segment>
    <segment id="89">Não são coisas que ela procurava no dicionário</segment>
    <segment id="90">, ela falava assim dentro de casa"</segment>
    <segment id="91">, afirma a filha</segment>
    <segment id="92">, que se</segment>
    <segment id="93">se lembra da autora chamando a ela e seus irmãos de "famélicos" —palavra que</segment>
    <segment id="94">sese refere a quem está sempre com fome.</segment>
    <segment id="95">Ela afirma ter receio das críticas que o livro pode provocar.</segment>
    <segment id="96">Vera Eunice de Jesus</segment>
    <segment id="97">, que hoje é professora</segment>
    <segment id="98">, começou a ajudar a mãe a corrigir seus textos aos dez anos e conta que</segment>
    <segment id="99">, ao ler "</segment>
    <segment id="100">O Escravo" pela primeira vez</segment>
    <segment id="101">, chorou ao ver</segment>
    <segment id="102">comocomo a mãe lutava para acertar o português.</segment>
    <segment id="103">"Minha mãe tinha ganas de aprender e não escrevia na norma padrão da língua.</segment>
    <segment id="104">Tinha uma cultura para falar</segment>
    <segment id="105">, escrevia palavras distintas</segment>
    <segment id="106">, masmas não escrevia dentro da regra.</segment>
    <segment id="107">"</segment>
    <segment id="108">Estátua em homenagem</segment>
    <segment id="109">a Carolina Maria de Jesus é inaugurada em ParelheirosMais    novamente         de   de  de  representando</segment>
    <segment id="110">um    Conceição Evaristo defende que Carolina escreve em "pretuguês"</segment>
    <segment id="111">, ou seja</segment>
    <segment id="112">, o português influenciado pela cultura negra e africana.</segment>
    <segment id="113">A opção de não mexer na linguagem da autora busca fazer o leitor ter acesso a sua obra na versão mais autêntica possível.  Tom Farias</segment>
    <segment id="114">, autor da biografia mais completa de Carolina e colunista deste jornal</segment>
    <segment id="115">, demonstrou surpresa ao saber que "</segment>
    <segment id="116">O Escravo" seria lançado.</segment>
    <segment id="117">"</segment>
    <segment id="118">As pessoas ainda não têm uma compreensão dela</segment>
    <segment id="119">comocomo romancista.</segment>
    <segment id="120">Não só no âmbito da obra literária</segment>
    <segment id="121">, masmas da sua vida.</segment>
    <segment id="122">"  "</segment>
    <segment id="123">O Escravo"</segment>
    <segment id="124">, segundo as pesquisadoras do conselho editorial</segment>
    <segment id="125">, era o romance que estava mais bem acabado e com texto legível nos arquivos</segment>
    <segment id="126">, ou seja</segment>
    <segment id="127">, mais fácil de ser publicado.</segment>
    <segment id="128">A escritora Conceição EvaristoMais    novamente         de   de  de  representando um  Não é</segment>
    <segment id="129">, contudo</segment>
    <segment id="130">contudo</segment>
    <segment id="131">, a primeira ficção de Carolina a chegar ao público na história.</segment>
    <segment id="132">Em 1963</segment>
    <segment id="133">, foi publicado o romance "Pedaços da Fome"</segment>
    <segment id="134">, uma obra que a autora havia intitulado "</segment>
    <segment id="135">A Felizarda" —a mudança a deixou zangada.</segment>
    <segment id="136">Segundo sua filha</segment>
    <segment id="137">, queriam retratar sua mãe apenas</segment>
    <segment id="138">comocomo "a escritora da favela".</segment>
    <segment id="139">A Companhia das Letras queria relançar o livro com o nome original</segment>
    <segment id="140">, masmas a qualidade e acessibilidade do manuscrito atrasaram a publicação.</segment>
    <segment id="141">Tudo a lerReceba no seu email uma seleção com lançamentos</segment>
    <segment id="142">, clássicos e curiosidades literáriasCarregando...</segment>
    <segment id="143">Farias afirma crer que o livro que Carolina mais gostaria que fosse publicado seria "Dr. Silvio"</segment>
    <segment id="144">, que se</segment>
    <segment id="145">se passa em São Paulo e conta a história de um casal.</segment>
    <segment id="146">Há ainda os romances "Dr. Fausto"</segment>
    <segment id="147">, "Rita" e "</segment>
    <segment id="148">O Diário de Marta" ou "</segment>
    <segment id="149">Mulher</segment>
    <segment id="150">Diabólica".</segment>
    <segment id="151">Seus livros trazem sempre "histórias tristes</segment>
    <segment id="152">, de enganação e de pobreza"</segment>
    <segment id="153">, segundo o biógrafo.</segment>
    <segment id="154">O amor está sempre em um lugar de desilusão.</segment>
    <segment id="155">"</segment>
    <segment id="156">Isso vem de uma origem de não pertencimento</segment>
    <segment id="157">, de só servir para ser mão de obra".  Vera</segment>
    <segment id="158">Eunice</segment>
    <segment id="159">de Jesus</segment>
    <segment id="160">segue tentando atender ao pedido que sua mãe fez</segment>
    <segment id="161">, em uma carta deixada depois de morrer</segment>
    <segment id="162">, para reunir todos os seus inéditos.</segment>
    <segment id="163">Mas leva tempo e dá trabalho</segment>
    <segment id="164">, seja pela falta de data nos documentos</segment>
    <segment id="165">, que passaram por reescritas constantes</segment>
    <segment id="166">, ou a dificuldade de acesso a cadernos que estão em acervos privados</segment>
    <segment id="167">, como</segment>
    <segment id="168">como o de Audálio Dantas.</segment>
    <segment id="169">A filha diz que as letras "eram</segment>
    <segment id="170">comocomo borboletas que flutuavam na cabeça" de Carolina.</segment>
    <segment id="171">Não é à toa que ela vivia com um lápis no bolso</segment>
    <segment id="172">para que</segment>
    <segment id="173">para que</segment>
    <segment id="174">, quando a inspiração viesse</segment>
    <segment id="175">, escrevesse no primeiro pedaço de papel que encontrasse.</segment>
    <segment id="176">Por isso há escritos da autora espalhados por tantos arquivos públicos e privados.</segment>
    <segment id="177">O desejo da filha da autora é criar um centro cultural para guardar a memória da escritora na cidade mineira de Sacramento</segment>
    <segment id="178">, onde ela nasceu.</segment>
    <segment id="179">Diz ter recebido apoio de Margareth Menezes</segment>
    <segment id="180">, ministra da Cultura no governo Lula</segment>
    <segment id="181">, e está elaborando um projeto para captação via Lei Rouanet.  "</segment>
    <segment id="182">O que mais queremos fazer é colocar a obra de Carolina dentro da historiografia literária brasileira que ela merece"</segment>
    <segment id="183">, afirma Crispim</segment>
    <segment id="184">, a pesquisadora.</segment>
    <segment id="185">"</segment>
    <segment id="186">Um lugar de destaque e de respeito.</segment>
    <segment id="187">"</segment>
    <segment id="188">O EscravoQuando Lançamento em 11/12Preço R$ 64</segment>
    <segment id="189">,90 (208 págs.)</segment>
    <segment id="190">; R$ 34</segment>
    <segment id="191">,90 (ebook)Autoria Carolina Maria de JesusEditora Companhia das Letras</segment>
  </rst>
</analysis>