  <rst>
    <segment id="1">Nas redes sociais</segment>
    <segment id="2">, um dos sinais mais claros de que o ano realmente está acabando é quando chega o dia dela: a Retrospectiva 2023 do Spotify</segment>
    <segment id="3">, disponibilizada nesta quarta (29).</segment>
    <segment id="4">No "wrapped" ("apanhado"</segment>
    <segment id="5">, do inglês)</segment>
    <segment id="6">, o popular serviço de streaming mostra ao usuário as músicas</segment>
    <segment id="7">, artistas e podcasts que mais escutou ao longo do ano</segment>
    <segment id="8">, além de outras curiosidades a respeito dos hábitos de cada ouvinte.</segment>
    <segment id="9">Com a divulgação</segment>
    <segment id="10">, as plataformas</segment>
    <segment id="11">comocomo Twitter (atual X) e Instagram estão inundadas por usuários que compartilham este saldo final.</segment>
    <segment id="12">Na rede de Elon Musk</segment>
    <segment id="13">, "Spotify" está no topo dos assuntos do momento</segment>
    <segment id="14">, quase 2 milhões de postagens a respeito.</segment>
    <segment id="15">A retrospectiva também figura em outras hashtags</segment>
    <segment id="16">, sobretudo nomes de artistas</segment>
    <segment id="17">comocomo Lana del Rey</segment>
    <segment id="18">, Billie Eillish e Drake.</segment>
    <segment id="19">Nem tudo é o que parece</segment>
    <segment id="20">, no entanto.</segment>
    <segment id="21">Muitos internautas relatam que os resultados foram adulterados.</segment>
    <segment id="22">E, é, claro</segment>
    <segment id="23">, como</segment>
    <segment id="24">como não poderia deixar de ser</segment>
    <segment id="25">, a retrospectiva virou meme.</segment>
    <segment id="26">Mesmice.  Evidências.  Recados.  Revelações.  Surpresas.  Romances.</segment>
    <segment id="27">Eclético.</segment>
    <segment id="28">Meditação.</segment>
    <segment id="29">Trilha sonora da Coitadolândia.</segment>
    <segment id="30">Se você é usuário do Spotify</segment>
    <segment id="31">, para conferir seus resultados basta abrir o aplicativo e</segment>
    <segment id="32">, no menu superior</segment>
    <segment id="33">, tocar na aba "Retrospectiva".</segment>
    <segment id="34">Na página</segment>
    <segment id="35">, acesse "</segment>
    <segment id="36">Sua Retrospectiva" que</segment>
    <segment id="37">, em formato de stories</segment>
    <segment id="38">, mostrará todas as informações do seu ano em músicas e podcasts.</segment>
  </rst>
</analysis>