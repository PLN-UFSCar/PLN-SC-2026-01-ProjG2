  <rst>
    <segment id="1">A série "Wandinha" é a mais vista na Netflix</segment>
    <segment id="2">, de acordo com a revista americana Variety.</segment>
    <segment id="3">Isso se</segment>
    <segment id="4">se deve à mudança da plataforma na maneira</segment>
    <segment id="5">comocomo analisa as métricas de audiência.</segment>
    <segment id="6">Jenna Ortega em cena da série &amp;quot</segment>
    <segment id="7">;Wandinha&amp;quot</segment>
    <segment id="8">;, da Netflix - DivulgaçãoAgora</segment>
    <segment id="9">, a Netflix relata a audiência de seus produtos por cada "visualização"</segment>
    <segment id="10">, horas assistidas divididas pelo tempo total de execução</segment>
    <segment id="11">, num período que passa a ser de 91 dias em vez de 28.</segment>
    <segment id="12">Nenhum outro serviço havia fornecido antes a audiência de suas produções.</segment>
    <segment id="13">A Netflix tem 232</segment>
    <segment id="14">,5 milhões de assinaturas globais.</segment>
    <segment id="15">Wandinha ganha série derivada de &amp;#039</segment>
    <segment id="16">;A</segment>
    <segment id="17">Família Addams&amp;#039</segment>
    <segment id="18">;Mais    novamente         de   de  de  representando um  Nesse sentido</segment>
    <segment id="19">, "Wandinha</segment>
    <segment id="20">"</segment>
    <segment id="21">supera o quarto ano da produção "Stranger Things".</segment>
    <segment id="22">No topo da lista de filmes em inglês</segment>
    <segment id="23">, ficam "Alerta Vermelho"</segment>
    <segment id="24">, "</segment>
    <segment id="25">Não Olhe para Cima" e "</segment>
    <segment id="26">O Projeto Adam".</segment>
    <segment id="27">No ranking de produções que não são em língua inglesa</segment>
    <segment id="28">, ganham destaque a primeira temporada de "Round 6"</segment>
    <segment id="29">, a quarta temporada de "La Casa de Papel"</segment>
    <segment id="30">, a primeira temporada de "</segment>
    <segment id="31">Lupin" e os filmes "</segment>
    <segment id="32">O Troll da Montanha"</segment>
    <segment id="33">, "</segment>
    <segment id="34">O Poço" e "</segment>
    <segment id="35">Através da Minha Janela".</segment>
