  <rst>
    <segment id="1">Quase todos os dias ainda resgatamos animais.</segment>
    <segment id="2">E todos os dias não são poucos</segment>
    <segment id="3">, abandonados</segment>
    <segment id="4">, perdidos</segment>
    <segment id="5">, sem casa</segment>
    <segment id="6">, sem comida</segment>
    <segment id="7">, sem o calor e o carinho que costumavam receber</segment>
    <segment id="8">, escreveu Alexei Surovtsev em seu Instagram na semana passada.</segment>
    <segment id="9">O ator ucraniano</segment>
    <segment id="10">, que já foi campeão de strip-tease e também participou da versão local do programa Dancing with the Stars (aqui chamado de Dancing Brasil)</segment>
    <segment id="11">, permaneceu na cidade de Irpin mesmo após os bombardeios russos e começou a resgatar gatos perdidos nos escombros.</segment>
    <segment id="12">Com o início da guerra da Ucrânia</segment>
    <segment id="13">, em 24 de fevereiro</segment>
    <segment id="14">, muitas pessoas tiveram que fugir do país e nem todas conseguiram levar seus pets junto com a família.</segment>
    <segment id="15">Ator ucraniano resgata animais em cidades bombardeadas pela guerraMais    novamente         de   de  de  representando um  É sobre esses bichos que Surovtsev</segment>
    <segment id="16">sese refere em seu post.</segment>
    <segment id="17">Em alguns casos</segment>
    <segment id="18">, ele consegue devolver os gatos para os donos que ainda vivem no local.</segment>
    <segment id="19">Em outros</segment>
    <segment id="20">, encaminha os felinos para abrigos e ONGs protetoras que atuam na região.</segment>
    <segment id="21">Por causa do seu trabalho com os animais</segment>
    <segment id="22">, o ator começou a ser chamado de herói nas redes sociais.</segment>
    <segment id="23">Além de gatos</segment>
    <segment id="24">, ele também salva cães perdidos pela cidade.</segment>
    <segment id="25">Antes da guerra</segment>
    <segment id="26">, Surovtsev já tinha pelo menos dois gatos que aparecem com ele e com a esposa</segment>
    <segment id="27">, Hanna Skvortsova</segment>
    <segment id="28">, em fotos no Instagram.</segment>
    <segment id="29">O conflito entre Rússia e Ucrânia também fez com que um famoso gatinho fugisse do país.</segment>
    <segment id="30">Stepan</segment>
    <segment id="31">, que vivia com sua tutora</segment>
    <segment id="32">, Anna</segment>
    <segment id="33">, em Kharkiv</segment>
    <segment id="34">, encontrou abrigo na França.</segment>
    <segment id="35">Famoso nas redes sociais por posar com seu bracinho apoiado numa mesa</segment>
    <segment id="36">, ao lado de um drinque</segment>
    <segment id="37">, o felino concorre ao WIBA (World Influencers and Bloggers Awards)</segment>
    <segment id="38">, prêmio global para os principais líderes de opinião e blogueiros de todo o mundo.</segment>
    <segment id="39">A cerimônia de premiação será no dia 18 de maio em Cannes</segment>
    <segment id="40">, no sul da França</segment>
    <segment id="41">, no tradicional Hotel Martinez.  +</segment>
    <segment id="42">GaticesLeia mais sobre gatosGato ucraniano</segment>
    <segment id="43">Stepan concorre a prêmio de influenciador do anoAnimal comunitário: gato</segment>
    <segment id="44">Frajola conquista na Justiça direito de permanecer em condomínioMaus-tratos contra animais crescem 15</segment>
    <segment id="45">,6% durante a pandemiaSiga o blog Gatices no Twitter</segment>
    <segment id="46">, Instagram e Facebook.</segment>
  </rst>
