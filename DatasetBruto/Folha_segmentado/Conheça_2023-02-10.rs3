  <rst>
    <segment id="1">A Coleção Folha Folclore Brasileiro para Crianças traz neste domingo a lenda indígena que narra o surgimento da mandioca.</segment>
    <segment id="2">Capa de &amp;#039</segment>
    <segment id="3">;A Lenda da Mandioca&amp;#039</segment>
    <segment id="4">;, da Coleção Folha Folclore Brasileiro para Crianças - DivulgaçãoNa edição disponível para compra nas livrarias</segment>
    <segment id="5">, bancas e no site deste jornal</segment>
    <segment id="6">, a escritora Silvia Oberg inicia o enredo contando</segment>
    <segment id="7">comocomo era o cotidiano das crianças de uma tribo indígena no meio da Amazônia.</segment>
    <segment id="8">Segundo o livro</segment>
    <segment id="9">, as crianças dali adoravam correr</segment>
    <segment id="10">, brincar de arco e flecha e fazer bonecas com argila.</segment>
    <segment id="11">E também gostavam de nadar e pescar no rio</segment>
    <segment id="12">, de olhar os bichos que passavam ali perto e de descobrir frutas para comer no mato.</segment>
    <segment id="13">Veja todos os volumes da Coleção Folha Folclore Brasileiro para CriançasMais    novamente         de   de  de  representando um</segment>
    <segment id="14">Com ilustrações de Cris Eich</segment>
    <segment id="15">, a publicação dá forma a essas crianças e à protagonista do livro</segment>
    <segment id="16">, Mani</segment>
    <segment id="17">, uma pequena indígena de pele bem branca e que desde seu nascimento trouxe muita sorte à sua tribo.</segment>
    <segment id="18">A criança vivia em paz com seus pais e os demais habitantes</segment>
    <segment id="19">, masmas</segment>
    <segment id="20">, de maneira abrupta</segment>
    <segment id="21">, morreu inexplicavelmente.</segment>
    <segment id="22">Diante da morte da criança</segment>
    <segment id="23">, seus pais a enterraram na mata e</segment>
    <segment id="24">, pouco tempo depois</segment>
    <segment id="25">, naquele lugar floresceu um arbusto com raízes claras</segment>
    <segment id="26">comocomo a pele de Mani</segment>
    <segment id="27">, um pé de mandioca.</segment>
    <segment id="28">No capítulo final</segment>
    <segment id="29">, o livro ensina o passo a passo para confeccionar uma peteca e ainda dá as diretrizes</segment>
    <segment id="30">para que</segment>
    <segment id="31">para que os leitores brinquem.</segment>
    <segment id="32">COMO COMPRAR</segment>
    <segment id="33">Site da coleção</segment>
    <segment id="34">Telefone: (11)</segment>
    <segment id="35">3224-3090 (Grande São Paulo) e 0800 775 8080 (outras localidades)</segment>
    <segment id="36">Frete grátis: SP</segment>
    <segment id="37">, RJ, MG e PR (na compra da coleção completa)</segment>
    <segment id="38">Nas bancas por R$ 22</segment>
    <segment id="39">,90 o volume</segment>
    <segment id="40">Coleção completa: R$ 549</segment>
    <segment id="41">,60; lote avulso: R$ 109</segment>
    <segment id="42">,92</segment>
  </rst>
