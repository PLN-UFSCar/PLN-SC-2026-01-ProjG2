  <rst>
    <segment id="1">O Tribunal de Justiça do Pará suspendeu o afastamento de Daniela Barbalho do cargo de conselheira no TCE (Tribunal de Contas do Estado)</segment>
    <segment id="2">, com salário de R$ 35 mil.</segment>
    <segment id="3">Ela é casada com o governador Helder Barbalho (MDB).</segment>
    <segment id="4">A decisão argumentou que afastar Daniela traria "grave prejuízo" ao Pará</segment>
    <segment id="5">, porque</segment>
    <segment id="6">porque atrasaria o andamento de processos sob responsabilidade dela e</segment>
    <segment id="7">, assim</segment>
    <segment id="8">, correriam "o risco de serem anulados"</segment>
    <segment id="9">, segundo o desembargador Mairton Marques Carneiro.</segment>
    <segment id="10">A primeira-dama do Pará</segment>
    <segment id="11">, Daniela Barbalho</segment>
    <segment id="12">, com Helder Barbalho</segment>
    <segment id="13">, na cerimônia de posse</segment>
    <segment id="14">, em janeiro - Rodrigo Pinheiro - 1.jan.23/Agência Pará</segment>
    <segment id="15">O desembargador falou ainda em "consequências jurídicas irreparáveis às partes interessadas</segment>
    <segment id="16">, bem como</segment>
    <segment id="17">como o risco de dano grave ao Estado".</segment>
    <segment id="18">Na deliberação anterior</segment>
    <segment id="19">, o juiz havia entendido que o</segment>
    <segment id="20">casocaso configura nepotismo e viola princípios administrativos.  "</segment>
    <segment id="21">Com esse episódio</segment>
    <segment id="22">, foi instituída uma espécie de nepotismo cruzado</segment>
    <segment id="23">, vez que o Governador do Estado não efetuou diretamente a nomeação da sua esposa para um cargo público relevante e vitalício</segment>
    <segment id="24">, porém</segment>
    <segment id="25">porém, indiretamente o fez mediante a conduta comissiva do Presidente da Assembleia Legislativa"</segment>
    <segment id="26">, escreveu Raimundo Santana</segment>
    <segment id="27">, da 5ª Vara da Fazenda Pública.</segment>
    <segment id="28">Daniela tem</segment>
    <segment id="29">comocomo função fiscalizar os gastos do governo do marido.</segment>
    <segment id="30">Ela foi nomeada em março deste ano em ato publicado no Diário Oficial do estado assinado pelo presidente da Alepa</segment>
    <segment id="31">, o deputado Chicão (MDB).</segment>
    <segment id="32">Helder Barbalho posa com cheques simbólicos para prefeitos paraensesMais    novamente         de   de  de  representando um</segment>
  </rst>
</analysis>