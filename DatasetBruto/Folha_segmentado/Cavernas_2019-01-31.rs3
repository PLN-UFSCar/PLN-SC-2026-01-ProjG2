    <segment id="163">, Tehuantepec</segment>
    <segment id="164">, San Cristobal</segment>
    <segment id="165">, Palenque</segment>
    <segment id="166">, Campeche</segment>
    <segment id="167">, Mérida e Riviera Maia</segment>
    <segment id="168">, com café e passeios.</segment>
    <segment id="169">Por pessoa.</segment>
    <segment id="170">Sem aéreo   R$ 19.701  6 noites</segment>
