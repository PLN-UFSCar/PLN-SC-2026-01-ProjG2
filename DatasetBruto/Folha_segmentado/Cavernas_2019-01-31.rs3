    <segment id="157">, na Riviera Maia</segment>
    <segment id="158">, com regime de alimentação all-inclusive.</segment>
    <segment id="159">Preço por pessoa.</segment>
    <segment id="160">Com passagens aéreas  R$ 8.392  14 noites</segment>
    <segment id="161">, na Gold Trip  Entre Cidade do México</segment>
