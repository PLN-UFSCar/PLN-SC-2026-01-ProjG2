  <rst>
    <segment id="1">Negra pioneira no humor brasileiro</segment>
    <segment id="2">, Marina Miranda morreu no Rio</segment>
    <segment id="3">, aos 90 anos</segment>
    <segment id="4">, na segunda-feira (20).</segment>
    <segment id="5">Ela sofria de Alzheimer e tratava uma infecção urinária e doença pulmonar.</segment>
    <segment id="6">A atriz trabalhou no “Balança</segment>
    <segment id="7">, Mas Não Cai”</segment>
    <segment id="8">, foi Dona Charanga na “Escolinha do Professor Raimundo” e fazia uma dupla adorável com Tião Macalé.</segment>
    <segment id="9">Nas redes sociais</segment>
    <segment id="10">, Marina recebeu várias homenagens.</segment>
    <segment id="11">“Para ocupar os espaços que ocupo hoje foi preciso ela vir na frente e abrir as portas!</segment>
    <segment id="12">”, disse Tia Má.</segment>
    <segment id="13">Hélio de La Peña afirmou:</segment>
    <segment id="14">“Foi uma mulher preta pioneira no humor irreverente</segment>
    <segment id="15">, iconoclasta</segment>
    <segment id="16">, abusado.</segment>
    <segment id="17">Marina alegrou muito a minha infância.</segment>
    <segment id="18">”  Imagens da atrizMarina Miranda   novamente         de   de  de  representando um  TUDO AZUL NO HORIZONTE  De biquíni azul</segment>
    <segment id="19">, Larissa Manoela</segment>
    <segment id="20">, 20 anos</segment>
    <segment id="21">, posou para foto nas areias do Rio.</segment>
    <segment id="22">Na legenda</segment>
    <segment id="23">, a bonitinha escreveu “all blue” —</segment>
    <segment id="24">“tudo azul”</segment>
    <segment id="25">, em tradução livre.</segment>
    <segment id="26">Famosos</segment>
    <segment id="27">comocomo Cleo Pires e Paola Antonini comentaram a publicação da atriz</segment>
    <segment id="28">, que recentemente compartilhou com os seguidores seu processo de superação do medo de cavalos.</segment>
    <segment id="29">Há seis anos</segment>
    <segment id="30">, ela caiu de um cavalo durante uma gravação</segment>
    <segment id="31">, o que a traumatizou.</segment>
    <segment id="32">Depois disso</segment>
    <segment id="33">, nunca mais</segment>
    <segment id="34">sese arriscou em montaria.</segment>
    <segment id="35">“</segment>
    <segment id="36">O dia de hoje retoma minha vida próxima a esse animal fantástico e eu não poderia estar mais feliz”</segment>
    <segment id="37">, comemorou.</segment>
    <segment id="38">Quando entrar Setembro</segment>
    <segment id="39">, as gatas aí estão   novamente         de   de  de  representando um  ALIANÇAS</segment>
    <segment id="40">Em comemoração aos 25 anos de casamento com o jornalista Ernesto Paglia</segment>
    <segment id="41">, 62 anos</segment>
    <segment id="42">, Sandra Annenberg</segment>
    <segment id="43">, 53, renovou o pedido.</segment>
    <segment id="44">“</segment>
    <segment id="45">Setembro 1996 - Assinávamos um papel e trocávamos alianças.</segment>
    <segment id="46">21 Setembro 2021 - 25 anos depois essa alegria continua firme e forte!</segment>
    <segment id="47">Te amo hoje e pra sempre!</segment>
    <segment id="48">Casa comigo de novo?</segment>
    <segment id="49">”</segment>
    <segment id="50">, publicou.  Sandra Annenberg e Ernesto Paglia- Marcus Leoni / Folhapress SAO PAULO</segment>
    <segment id="51">, SP, BRASIL</segment>
    <segment id="52">, 12.03.18  FERIDO  Liam Gallagher</segment>
    <segment id="53">, do Oasis</segment>
    <segment id="54">, que chegou aos 49 anos nesta terça (21)</segment>
    <segment id="55">, anunciou o cancelamento de seu show em Belfast</segment>
    <segment id="56">, no Reino Unido</segment>
    <segment id="57">, que aconteceria no final de semana.</segment>
    <segment id="58">“Tive um acidente depois do festival e arrebentei o nariz</segment>
    <segment id="59">, não consigo cantar.</segment>
    <segment id="60">Os médicos me disseram para descansar”</segment>
    <segment id="61">, publicou nas redes sociais.</segment>
    <segment id="62">Ele caiu de um helicóptero na sexta-feira (17)</segment>
    <segment id="63">, depois de um show.</segment>
    <segment id="64">O músico britânico Liam Gallagher mostra machucados no rosto após acidente com helicóptero - Twitter/liamgallagherCORONA</segment>
    <segment id="65">O ator</segment>
    <segment id="66">, produtor e comediante Chris Rock</segment>
    <segment id="67">, 56 anos</segment>
    <segment id="68">, anunciou no Twitter que está com Covid-19.</segment>
    <segment id="69">“Acreditem em mim: vocês não querem isso.</segment>
    <segment id="70">Se vacinem”</segment>
    <segment id="71">, alertou o ator</segment>
    <segment id="72">, que é criador de “Todo Mundo Odeia o Chris”.</segment>
    <segment id="73">Segundo sites internacionais</segment>
    <segment id="74">, o comediante já tinha tomado vacina</segment>
    <segment id="75">, o que amortece o impacto da doença.</segment>
  </rst>
</analysis>