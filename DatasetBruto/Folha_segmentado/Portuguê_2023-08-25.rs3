  <rst>
    <segment id="1">Alguns anos separam as férias em Florianópolis da reunião de negócios em São Paulo para a argentina Catalina Vanoli</segment>
    <segment id="2">, 33.</segment>
    <segment id="3">Se na primeira vez ela foi</segment>
    <segment id="4">, ainda criança</segment>
    <segment id="5">, curtir a praia com os pais</segment>
    <segment id="6">, na segunda usou o português que começou a aprender há quatro meses para</segment>
    <segment id="7">sese comunicar com os clientes brasileiros.</segment>
    <segment id="8">"</segment>
    <segment id="9">A empresa me pedia um nível mais básico</segment>
    <segment id="10">, masmas eu decidi estudar mais"</segment>
    <segment id="11">, diz a engenheira de transportes</segment>
    <segment id="12">, que faz reuniões semanais no idioma brasileiro.</segment>
    <segment id="13">Quem paga as aulas é a multinacional da área de finanças em que trabalha</segment>
    <segment id="14">, que tem escritórios em toda a América Latina e contratos importantes no Brasil.</segment>
    <segment id="15">Argentinos assistem a aula de português na Casa do Brasil</segment>
    <segment id="16">, em Buenos Aires - Divulgação/Casa do BrasilEla conta que oito de seus 11 colegas de classe estão lá pelo mesmo motivo.</segment>
    <segment id="17">"</segment>
    <segment id="18">Muita gente chega 'obrigada' e sai curtindo mais as aulas</segment>
    <segment id="19">, porque</segment>
    <segment id="20">porque não é só aprender o idioma</segment>
    <segment id="21">, masmas também a cultura brasileira.</segment>
    <segment id="22">Agora eu já sei que</segment>
    <segment id="23">, dependendo do estado</segment>
    <segment id="24">, vocês dão um ou dois beijinhos"</segment>
    <segment id="25">, brinca ela.</segment>
    <segment id="26">O caso</segment>
    <segment id="27">caso de Catalina é um exemplo de</segment>
    <segment id="28">comocomo o português ganhou relevância e evoluiu de língua do turismo para língua também dos negócios na Argentina nas últimas décadas.</segment>
    <segment id="29">Mais do que um destino para relaxar</segment>
    <segment id="30">, o Brasil passou a ser visto</segment>
    <segment id="31">comocomo oportunidade de trabalho e estudos</segment>
    <segment id="32">, dizem coordenadores</segment>
    <segment id="33">, professores e alunos.  "</segment>
    <segment id="34">Antigamente os estudantes queriam basicamente ir para Copacabana</segment>
    <segment id="35">, tomar chopinho e ficar 'lagarteando' na praia.</segment>
    <segment id="36">De repente tem gente que quer estudar</segment>
    <segment id="37">, trabalhar</segment>
    <segment id="38">, conhecer o Centro-Oeste</segment>
    <segment id="39">, Nordeste</segment>
    <segment id="40">, Pantanal.</segment>
    <segment id="41">Eles estão descobrindo o Brasil que não é só 'garota de Ipanema'"</segment>
    <segment id="42">, afirma Ivone Tupinambá</segment>
    <segment id="43">, 67, que leciona no país há 26 anos no Instituto Guimarães Rosa (IGR)</segment>
    <segment id="44">, do Itamaraty.</segment>
    <segment id="45">Professores</segment>
    <segment id="46">sese dedicam ao ensino online de língua portuguesa e escritaMais    novamente         de   de  de  representando um  Geraldina Dana</segment>
    <segment id="47">, cientista política da Universidade de Buenos Aires (UBA)</segment>
    <segment id="48">, começou as aulas há quatro anos.</segment>
    <segment id="49">"</segment>
    <segment id="50">Uso o português profissionalmente desde 2020 e também academicamente.</segment>
    <segment id="51">Uma parte da bibliografia de relações internacionais que</segment>
    <segment id="52">sese consome na Argentina é em português</segment>
    <segment id="53">, apesar de a maioria ser em espanhol e inglês"</segment>
    <segment id="54">, diz.</segment>
    <segment id="55">Segundo ela</segment>
    <segment id="56">, o interesse pelo idioma no país cresceu a partir da criação do Mercosul</segment>
    <segment id="57">, em 1991</segment>
    <segment id="58">, que contribuiu</segment>
    <segment id="59">para que</segment>
    <segment id="60">para que o Brasil</segment>
    <segment id="61">sese tornasse o principal sócio comercial da Argentina —novo membro do Brics a partir de 2024.</segment>
    <segment id="62">Em julho</segment>
    <segment id="63">, por exemplo</segment>
    <segment id="64">, o Brasil foi responsável por 25% das importações e 17% das exportações argentinas</segment>
    <segment id="65">, contra 18% e 8% da China</segment>
    <segment id="66">, respectivamente.</segment>
    <segment id="67">A cientista política argentina Geraldina Dana</segment>
    <segment id="68">, que decidiu aprender português ao estudar relações internacionais - Arquivo pessoalSe 15 anos atrás só dois locais em Buenos Aires aplicavam a prova de certificação na língua portuguesa</segment>
    <segment id="69">, chamada de Celpe-Bras</segment>
    <segment id="70">, hoje os postos</segment>
    <segment id="71">sese multiplicaram para oito em diferentes regiões do país</segment>
    <segment id="72">, conta Neucilene Teixeira</segment>
    <segment id="73">, coordenadora pedagógica do instituto IGR</segment>
    <segment id="74">, que tem cerca de 500 alunos.  "</segment>
    <segment id="75">Antes os moradores de outras províncias tinham que vir passar dois ou três dias na capital para fazer o exame.</segment>
    <segment id="76">Agora muitas províncias já têm seus próprios postos"</segment>
    <segment id="77">, afirma ela.</segment>
    <segment id="78">O número de argentinos que</segment>
    <segment id="79">sese inscreveram no exame passou de 399 para 554</segment>
    <segment id="80">, entre 2019 e 2023</segment>
    <segment id="81">, segundo os dados disponibilizados pelo Inep</segment>
    <segment id="82">, do Ministério da Educação.</segment>
    <segment id="83">A coordenadora lembra que a procura por aulas online também aumentou muito a partir da pandemia</segment>
    <segment id="84">, com a facilidade dos cursos à distância.</segment>
    <segment id="85">Para ela</segment>
    <segment id="86">, o crescimento do português entre os argentinos tem muito a ver com o aumento da oferta de bolsas acadêmicas para estrangeiros no Brasil e a inserção da língua no ensino básico.</segment>
    <segment id="87">Desde 2001</segment>
    <segment id="88">, a cidade de Buenos Aires tem o chamado programa de colégios plurilíngue</segment>
    <segment id="89">, onde as crianças aprendem o idioma</segment>
    <segment id="90">comocomo primeira ou segunda língua estrangeira.</segment>
    <segment id="91">O projeto adicionou de 8 a 12 horas semanais à grade curricular de 26 escolas</segment>
    <segment id="92">, incluindo inglês</segment>
    <segment id="93">, português</segment>
    <segment id="94">, italiano e francês.</segment>
    <segment id="95">O mesmo movimento aconteceu nos colégios particulares e no ensino médio</segment>
    <segment id="96">, diz o argentino Fabricio Müller</segment>
    <segment id="97">, diretor-executivo da Casa do Brasil</segment>
    <segment id="98">, instituto privado que leciona a 1.500 alunos e 45 empresas.</segment>
    <segment id="99">"Somos cada vez mais contratados para certificar o nível desses jovens.</segment>
    <segment id="100">Os próprios pais pedem às escolas uma terceira língua além do inglês.</segment>
    <segment id="101">"</segment>
    <segment id="102">Leia maisEntenda a crise econômica e a inflação sem freio na ArgentinaDólar</segment>
    <segment id="103">, peso ou real:</segment>
    <segment id="104">comocomo levar dinheiro para a Argentina?Segundo ele</segment>
    <segment id="105">, isso começou na década de 1990</segment>
    <segment id="106">, na onda das privatizações</segment>
    <segment id="107">, e ganhou força nos anos 2000</segment>
    <segment id="108">, quando houve um diálogo mais fluido entre os dois governos.</segment>
    <segment id="109">"</segment>
    <segment id="110">Com a crise de 2001 [quando um colapso financeiro levou ao congelamento das contas bancárias na Argentina]</segment>
    <segment id="111">, muita gente viu o Brasil</segment>
    <segment id="112">comocomo uma real oportunidade"</segment>
    <segment id="113">, lembra.</segment>
    <segment id="114">Mas a maioria dos profissionais do idioma evita</segment>
    <segment id="115">, por ora</segment>
    <segment id="116">, fazer uma relação com a crise econômica e inflacionária atual.</segment>
    <segment id="117">"</segment>
    <segment id="118">Não tenho dados sobre isso.</segment>
    <segment id="119">O que tenho certeza é que cada vez mais empresas nos procuram para ensinar português aos funcionários</segment>
    <segment id="120">, tanto brasileiras com filiais na Argentina quanto o oposto</segment>
    <segment id="121">, principalmente nas áreas de tecnologia e agronegócio"</segment>
    <segment id="122">, afirma Müller.</segment>
    <segment id="123">O número de argentinos residentes ou temporários no Brasil atingiu seu recorde em 2022</segment>
    <segment id="124">, com mais de 6.000 registros segundo a Polícia Federal</segment>
    <segment id="125">, puxado por uma demanda represada pela pandemia e também pela crise.</segment>
    <segment id="126">Por outro lado</segment>
    <segment id="127">, com o câmbio favorável</segment>
    <segment id="128">, turistas e moradores brasileiros inundam o país vizinho</segment>
    <segment id="129">, aumentando ainda mais o intercâmbio cultural.  "</segment>
    <segment id="130">O interesse cultural foi o pontapé para eu começar a estudar"</segment>
    <segment id="131">, conta o portenho Pedro Rodriguez</segment>
    <segment id="132">, 22, estudante de ciências políticas que conheceu o Brasil de férias</segment>
    <segment id="133">, masmas hoje quer ser diplomata e vê no português um idioma importante para a carreira.</segment>
    <segment id="134">"Não descarto viver no Brasil</segment>
    <segment id="135">, há muitas coisas que nos conectam e nos unem"</segment>
    <segment id="136">, diz.</segment>
  </rst>
</analysis>