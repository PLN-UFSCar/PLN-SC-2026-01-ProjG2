  <rst>
    <segment id="1">A Boitempo aproveita o bicentenário de Friedrich Engels</segment>
    <segment id="2">, em novembro</segment>
    <segment id="3">, para lançar uma biografia inédita do pensador alemão</segment>
    <segment id="4">, junto com mais uma de seu principal parceiro intelectual</segment>
    <segment id="5">, Karl Marx.</segment>
    <segment id="6">Escrita pelo historiador alemão Gustav Mayer na década de 1930 e nunca publicada no Brasil</segment>
    <segment id="7">, “Engels:</segment>
    <segment id="8">Uma Biografia” descreve a vida de um dos criadores do socialismo científico do nascimento em Barmen até a morte em Londres</segment>
    <segment id="9">, passando pelo trabalho na indústria e a escrita do “Manifesto Comunista” ao lado de Marx.</segment>
    <segment id="10">Retrato de Friedrich Engels</segment>
    <segment id="11">, que completa seu bicentenário</segment>
    <segment id="12">, por H. Schey.</segment>
    <segment id="13">- Divulgação</segment>
    <segment id="14">Originalmente publicada em dois grandes tomos</segment>
    <segment id="15">, a obra chega ao país em versão enxuta</segment>
    <segment id="16">, de 256 páginas</segment>
    <segment id="17">, feita pelo próprio autor poucos anos depois da primeira edição.  Marx</segment>
    <segment id="18">, que já foi alvo de inúmeras publicações quando completou seus 200 anos em 2018</segment>
    <segment id="19">, ganha também uma nova e encorpada biografia</segment>
    <segment id="20">, elaborada ao longo de dez anos por José Paulo Netto</segment>
    <segment id="21">, professor emérito da Universidade Federal do Rio de Janeiro e um dos principais especialistas brasileiros em sua obra.</segment>
    <segment id="22">LITERATURA VERDE</segment>
    <segment id="23">O escritor Jonathan Safran Foer é o mais novo autor confirmado na edição virtual da Flip que acontece em dezembro.</segment>
    <segment id="24">Conhecido por obras literárias</segment>
    <segment id="25">comocomo “</segment>
    <segment id="26">Tudo Se Ilumina” e “Extremamente Alto e Incrivelmente Perto”</segment>
    <segment id="27">, ele deve centrar sua palestra na denúncia da mudança climática</segment>
    <segment id="28">, que guia seu livro mais recente</segment>
    <segment id="29">, “Nós Somos o Clima”</segment>
    <segment id="30">, publicado pela Rocco.</segment>
    <segment id="31">ELENCO</segment>
    <segment id="32">A festa literária</segment>
    <segment id="33">, que será gratuita</segment>
    <segment id="34">, anunciou nesta semana a adição da americana Regina Porter e do brasileiro Jeferson Tenório à lista de autores convidados</segment>
    <segment id="35">, que já contava com nomes</segment>
    <segment id="36">comocomo Bernardine Evaristo</segment>
    <segment id="37">, Itamar Vieira Junior e Eileen Myles.  NASCE UMA ESTRELA</segment>
    <segment id="38">A Intrínseca vai lançar a biografia</segment>
    <segment id="39">“Alexander Hamilton”</segment>
    <segment id="40">em dezembro</segment>
    <segment id="41">, dias depois da chegada do serviço de streaming Disney+ ao país —que permitirá aos brasileiros assistirem à arrasadora adaptação musical de Lin-Manuel Miranda</segment>
    <segment id="42">, baseada no livro de Ron Chernow.</segment>
    <segment id="43">Veja imagens do musical &amp;#039</segment>
    <segment id="44">;Hamilton&amp;#039</segment>
    <segment id="45">;   novamente         de   de  de  representando um    ​​ALMA CORSÁRIA</segment>
    <segment id="46">E ainda no extenso campo das biografias</segment>
    <segment id="47">, uma de arte.</segment>
    <segment id="48">A Âyiné acaba de comprar os direitos de “La Corsara”</segment>
    <segment id="49">, que conta a vida da escritora Natalia Ginzburg e traça um bom panorama do universo literário italiano</segment>
    <segment id="50">, já que a autora trabalhou quase toda a vida na prestigiosa editora Einaudi.</segment>
    <segment id="51">Antes da chegada do livro</segment>
    <segment id="52">, em 2022</segment>
    <segment id="53">, a Âyiné deve lançar mais duas coletâneas de artigos de Ginzburg.</segment>
    <segment id="54">PARA QUE SERVE?</segment>
    <segment id="55">A Relicário publica no próximo semestre a nova obra de Carola Saavedra</segment>
    <segment id="56">, um livro de ensaios que discute o papel da literatura em um mundo em colapso político e climático.</segment>
    <segment id="57">Sai pela coleção</segment>
    <segment id="58">Nos.</segment>
    <segment id="59">Otras, dedicada à não ficção produzida por autoras latino-americanas.</segment>
    <segment id="60">DOU-LHE</segment>
    <segment id="61">MAIS UMA</segment>
    <segment id="62">Em leilão disputado na Feira de Frankfurt</segment>
    <segment id="63">, a Sextante arrematou o novo livro do americano Greg McKeown</segment>
    <segment id="64">, autor de “Essencialismo” —que já vendeu 160 mil exemplares pela editora.</segment>
    <segment id="65">“</segment>
    <segment id="66">Sem Esforço”</segment>
    <segment id="67">, a nova obra</segment>
    <segment id="68">, busca ensinar a simplificar problemas e evitar o sentimento de sobrecarga que toma quase todo mundo.</segment>
    <segment id="69">A Sextante prepara um lançamento para junho do ano que vem.</segment>
  </rst>
