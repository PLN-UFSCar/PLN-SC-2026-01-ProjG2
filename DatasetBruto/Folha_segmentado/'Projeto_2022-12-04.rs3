  <rst>
    <segment id="1">O "Projeto Querino"</segment>
    <segment id="2">, do jornalista Tiago Rogero</segment>
    <segment id="3">, vai virar livro.</segment>
    <segment id="4">A obra sairá pela editora Fósforo e apresentará novas informações.</segment>
    <segment id="5">O lançamento está programado para o segundo semestre do ano que vem.</segment>
    <segment id="6">Também em conjunto com a Fósforo</segment>
    <segment id="7">, Rogero prepara uma nova graphic novel de ficção ambientada no mesmo universo do projeto.</segment>
    <segment id="8">A HQ deverá chegar ao público em 2024.</segment>
    <segment id="9">O jornalista Tiago Rogero</segment>
    <segment id="10">, idealizador do podcast &amp;quot</segment>
    <segment id="11">;Projeto Querino&amp;quot</segment>
    <segment id="12">; - Leo Martins/Divulgação  Também em conjunto com a Fósforo</segment>
    <segment id="13">, Rogero prepara uma nova graphic novel de ficção ambientada no mesmo universo do projeto.</segment>
    <segment id="14">A HQ deverá chegar ao público em 2024.</segment>
    <segment id="15">O Projeto Querino foi lançado em agosto deste ano</segment>
    <segment id="16">comocomo um podcast narrativo</segment>
    <segment id="17">, produzido pela Rádio Novelo</segment>
    <segment id="18">, além de reportagens</segment>
    <segment id="19">, ensaios fotográficos e uma história em quadrinhos publicadas pela revista Piauí.</segment>
    <segment id="20">O material revê a história do Brasil sob a perspectiva dos negros brasileiros.   MONÓLOGO</segment>
    <segment id="21">Estreia do espetáculo &amp;#039</segment>
    <segment id="22">;Pagu</segment>
    <segment id="23">- Até Onde Chega a Sonda&amp;#039</segment>
    <segment id="24">;Mais    novamente         de   de  de  representando um</segment>
    <segment id="25">A atriz Martha Nowill estreou o solo "Pagu –</segment>
    <segment id="26">Até Onde Chega a Sonda"</segment>
    <segment id="27">, no Sesc Pompeia</segment>
    <segment id="28">, em São Paulo</segment>
    <segment id="29">, na quinta-feira (1º).</segment>
    <segment id="30">Martha une suas histórias e impressões às da jornalista e ativista Patrícia Galvão</segment>
    <segment id="31">, a Pagu</segment>
    <segment id="32">, para discutir o machismo de hoje.</segment>
    <segment id="33">A peça é dirigida por Elias Andreato.</segment>
    <segment id="34">A dramaturga Denise Stoklos e a atriz Maria Luisa Mendonça compareceram à estreia.  com BIANKA VIEIRA</segment>
    <segment id="35">, KARINA MATIAS e MANOELLA SMITH</segment>
    <segment id="36">; colaborou SUSANA</segment>
    <segment id="37">TERAO</segment>
  </rst>
