  </header>
  <rst>
    <segment id="1">Arm&amp;ecirc</segment>
    <segment id="2">;nia e o Azerbaij&amp;atilde</segment>
    <segment id="3">;o concordaram em iniciar um cessar-fogo no conflito que matou centenas de militares e civis desde o domingo retrasado (27).</segment>
    <segment id="4">A tr&amp;eacute</segment>
    <segment id="5">;gua foi anunciada pelo chanceler russo</segment>
    <segment id="6">, Serguei Lavrov</segment>
    <segment id="7">, ap&amp;oacute</segment>
    <segment id="8">;s dez horas de conversas com seus colegas &amp;Ccedil</segment>
    <segment id="9">;eyhum Baymarov (Azerbaij&amp;atilde</segment>
    <segment id="10">;o) e Zohrab Mnatsakanyan (Arm&amp;ecirc</segment>
    <segment id="11">;nia) em Moscou.</segment>
    <segment id="12">As duas ex-rep&amp;uacute</segment>
    <segment id="13">;blicas sovi&amp;eacute</segment>
    <segment id="14">;ticas</segment>
    <segment id="15">sese enfrentavam ap&amp;oacute</segment>
    <segment id="16">;s for&amp;ccedil</segment>
    <segment id="17">;as azeris atacarem o encrave arm&amp;ecirc</segment>
    <segment id="18">;nio de Nagorno-Karabakh</segment>
    <segment id="19">, regi&amp;atilde</segment>
    <segment id="20">;o com territ&amp;oacute</segment>
    <segment id="21">;rio equivalente a duas vezes o do Distrito Federal</segment>
    <segment id="22">, que disputam desde os anos 1990.</segment>
    <segment id="23">Os pa&amp;iacute</segment>
    <segment id="24">;ses se</segment>
    <segment id="25">se enfrentavam ap&amp;oacute</segment>
    <segment id="26">;s for&amp;ccedil</segment>
    <segment id="27">;as azeris atacarem o encrave arm&amp;ecirc</segment>
    <segment id="28">;nio de Nagorno-Karabakh</segment>
    <segment id="29">, regi&amp;atilde</segment>
    <segment id="30">;o com territ&amp;oacute</segment>
    <segment id="31">;rio equivalente a duas vezes o do Distrito Federal que disputam desde os anos 1990.​  Da esq.</segment>
    <segment id="32">para a dir.</segment>
    <segment id="33">, os chanceleres Bayramov (Azerbaijão)</segment>
    <segment id="34">, Lavrov (Rússia) e Mnatsakanyan (Armênia) durante início do encontro na Casa de Recepções do Ministério das Relações Exteriores em Moscou  - Ministério das Relações Exteriores da Rússia/AFPEm pronunciamento</segment>
    <segment id="35">, o presidente azeri</segment>
    <segment id="36">, Ilham Aliyev</segment>
    <segment id="37">, disse que aceitava os princ&amp;iacute</segment>
    <segment id="38">;pios de negocia&amp;ccedil</segment>
    <segment id="39">;&amp;atilde</segment>
    <segment id="40">;o propostos pelos russos</segment>
    <segment id="41">, franceses e americanos na v&amp;eacute</segment>
    <segment id="42">;spera</segment>
    <segment id="43">, quando Baymarov esteve com enviados do grupo em Genebra.</segment>
    <segment id="44">Mas ele tamb&amp;eacute</segment>
    <segment id="45">;m disse que espera a &amp;quot</segment>
    <segment id="46">;desocupa&amp;ccedil</segment>
    <segment id="47">;&amp;atilde</segment>
    <segment id="48">;o&amp;quot</segment>
    <segment id="49">; de terras azeris por parte dos arm&amp;ecirc</segment>
    <segment id="50">;nios, o cerne da quest&amp;atilde</segment>
    <segment id="51">;o.</segment>
    <segment id="52">O governo da Arm&amp;ecirc</segment>
    <segment id="53">;nia j&amp;aacute</segment>
    <segment id="54">; havia dito aceitar conversar.  R&amp;uacute</segment>
    <segment id="55">;ssia, Fran&amp;ccedil</segment>
    <segment id="56">;a e Estados Unidos integram o chamado Grupo de Minsk</segment>
    <segment id="57">, criado em 1992 para mediar a guerra aberta entre os vizinhos no C&amp;aacute</segment>
    <segment id="58">;ucaso</segment>
    <segment id="59">, ocorrida ap&amp;oacute</segment>
    <segment id="60">;s o fim da Uni&amp;atilde</segment>
    <segment id="61">;o Sovi&amp;eacute</segment>
    <segment id="62">;tica e que foi congelada por um cessar-fogo em 1994.</segment>
    <segment id="63">Moradores passam por prédios atingidos por artilharia armênia em Ganja</segment>
    <segment id="64">, cidade azeri perto da fronteira da região disputada de Nagorno-Karabakh  - Bulent Kilic - 8.out.2020/AFPNa noite de quinta para sexta</segment>
    <segment id="65">, segundo relato do escrit&amp;oacute</segment>
    <segment id="66">;rio de direitos humanos de Stepanarket</segment>
    <segment id="67">, a capital de Nagorno-Karabakh</segment>
    <segment id="68">, houve mais bombardeios azeris.</segment>
    <segment id="69">Baku, por sua vez</segment>
    <segment id="70">, anunciou no Twitter que cidades fronteiri&amp;ccedil</segment>
    <segment id="71">;as azeris foram novamente alvo de ataques arm&amp;ecirc</segment>
    <segment id="72">;nios.</segment>
    <segment id="73">O cessar-fogo</segment>
    <segment id="74">, sese for respeitado</segment>
    <segment id="75">, ser&amp;aacute</segment>
    <segment id="76">; uma vit&amp;oacute</segment>
    <segment id="77">;ria pol&amp;iacute</segment>
    <segment id="78">;tica para o presidente Vladimir Putin.</segment>
    <segment id="79">Pela primeira vez desde que anexou a Crimeia em 2014</segment>
    <segment id="80">, o russo est&amp;aacute</segment>
    <segment id="81">; sendo apoiado numa iniciativa diplom&amp;aacute</segment>
    <segment id="82">;tica clara por pot&amp;ecirc</segment>
    <segment id="83">;ncias ocidentais.</segment>
    <segment id="84">Putin vive hoje uma crise tr&amp;iacute</segment>
    <segment id="85">;plice em suas fronteiras estrat&amp;eacute</segment>
    <segment id="86">;gicas</segment>
    <segment id="87">, com a convuls&amp;atilde</segment>
    <segment id="88">;o pol&amp;iacute</segment>
    <segment id="89">;tica devido a fraudes alegadas em elei&amp;ccedil</segment>
    <segment id="90">;&amp;otilde</segment>
    <segment id="91">;es nos aliados Belarus e Quirguist&amp;atilde</segment>
    <segment id="92">;o, al&amp;eacute</segment>
    <segment id="93">;m da guerra no C&amp;aacute</segment>
    <segment id="94">;ucaso.</segment>
    <segment id="95">O conflito era o mais agudo de seus problemas</segment>
    <segment id="96">, n&amp;atilde</segment>
    <segment id="97">;o s&amp;oacute</segment>
    <segment id="98">;</segment>
    <segment id="99">por desestabilizar a sua importante fronteira sul</segment>
    <segment id="100">comocomo pelo risco de evoluir para uma guerra regional envolvendo diretamente for&amp;ccedil</segment>
    <segment id="101">;as do Kremlin</segment>
    <segment id="102">, que tem uma base militar e um tratado no qual prev&amp;ecirc</segment>
    <segment id="103">; defender Ierevan</segment>
    <segment id="104">, e da Turquia</segment>
    <segment id="105">, que &amp;eacute</segment>
    <segment id="106">; a patrocinadora do regime de Baku.</segment>
    <segment id="107">Tal temor foi expresso abertamente por um ator interessado</segment>
    <segment id="108">, o Ir&amp;atilde</segment>
    <segment id="109">;, que possui 25% da popula&amp;ccedil</segment>
    <segment id="110">;&amp;atilde</segment>
    <segment id="111">;o com origem azeri</segment>
    <segment id="112">, e a Uni&amp;atilde</segment>
    <segment id="113">;o Europeia.</segment>
    <segment id="114">Tensão entre Armênia e Azerbaijão escala com novos conflitos    novamente         de   de  de  representando um</segment>
    <segment id="115">O Grupo de Minsk agiu em conjunto</segment>
    <segment id="116">, num raro momento em que pot&amp;ecirc</segment>
    <segment id="117">;ncias ocidentais franquearam ao presidente russo a prerrogativa de descascar o abacaxi.</segment>
    <segment id="118">Putin agiu pessoalmente</segment>
    <segment id="119">, falando com os l&amp;iacute</segment>
    <segment id="120">;deres de ambas as na&amp;ccedil</segment>
    <segment id="121">;&amp;otilde</segment>
    <segment id="122">;es beligerantes ao longo da crise e na noite de quinta.</segment>
    <segment id="123">A tr&amp;eacute</segment>
    <segment id="124">;gua ocorre com o Azerbaij&amp;atilde</segment>
    <segment id="125">;o em uma posi&amp;ccedil</segment>
    <segment id="126">;&amp;atilde</segment>
    <segment id="127">;o de for&amp;ccedil</segment>
    <segment id="128">;a.</segment>
    <segment id="129">Ap&amp;oacute</segment>
    <segment id="130">;s ter anunciado a tomada de alguns pontos estrat&amp;eacute</segment>
    <segment id="131">;gicos em torno de Nagorno-Karabakh</segment>
    <segment id="132">, o pa&amp;iacute</segment>
    <segment id="133">;s passou a uma campanha ostensiva de press&amp;atilde</segment>
    <segment id="134">;o sobre o governo separatista local.</segment>
    <segment id="135">A regi&amp;atilde</segment>
    <segment id="136">;o, chamada pelos locais de Artsakh</segment>
    <segment id="137">, &amp;eacute</segment>
    <segment id="138">;</segment>
    <segment id="139">territ&amp;oacute</segment>
    <segment id="140">;rio historicamente arm&amp;ecirc</segment>
    <segment id="141">;nio, com 99% da popula&amp;ccedil</segment>
    <segment id="142">;&amp;atilde</segment>
    <segment id="143">;o pertencente ao grupo &amp;eacute</segment>
    <segment id="144">;tnico.</segment>
    <segment id="145">Mas ela ficou perdida dentro do Azerbaij&amp;atilde</segment>
    <segment id="146">;o, assim</segment>
    <segment id="147">comocomo um peda&amp;ccedil</segment>
    <segment id="148">;o azeri existe no sudoeste da Arm&amp;ecirc</segment>
    <segment id="149">;nia, no retalhamento da regi&amp;atilde</segment>
    <segment id="150">;o promovido pelo ent&amp;atilde</segment>
    <segment id="151">;o respons&amp;aacute</segment>
    <segment id="152">;vel pelo C&amp;aacute</segment>
    <segment id="153">;ucaso na Uni&amp;atilde</segment>
    <segment id="154">;o Sovi&amp;eacute</segment>
    <segment id="155">;tica, o futuro ditador Josef St&amp;aacute</segment>
    <segment id="156">;lin, em 1920.</segment>
    <segment id="157">Todo o territ&amp;oacute</segment>
    <segment id="158">;rio foi incorporado ao imp&amp;eacute</segment>
    <segment id="159">;rio comunista</segment>
    <segment id="160">, que ruiu em 1991</segment>
    <segment id="161">, masmas as divis&amp;otilde</segment>
    <segment id="162">;es visavam esvaziar &amp;iacute</segment>
    <segment id="163">;mpetos nacionalistas e tamb&amp;eacute</segment>
    <segment id="164">;m aplacar a nascente Rep&amp;uacute</segment>
    <segment id="165">;blica da Turquia</segment>
    <segment id="166">, que surgiria dos escombros do Imp&amp;eacute</segment>
    <segment id="167">;rio Otomano e tinha acabado de promover o massacre conhecido</segment>
    <segment id="168">comocomo genoc&amp;iacute</segment>
    <segment id="169">;dio arm&amp;ecirc</segment>
    <segment id="170">;nio.</segment>
    <segment id="171">O C&amp;aacute</segment>
    <segment id="172">;ucaso era a fronteira entre os dom&amp;iacute</segment>
    <segment id="173">;nios otomanos e russos</segment>
    <segment id="174">, e assim permaneceu.</segment>
    <segment id="175">Com o ocaso sovi&amp;eacute</segment>
    <segment id="176">;tico, os nacionalismos ressurgiram</segment>
    <segment id="177">, e o conflito desaguou numa guerra cruenta</segment>
    <segment id="178">, que matou entre 17 mil e 30 mil pessoas.</segment>
    <segment id="179">O conflito atual &amp;eacute</segment>
    <segment id="180">; o mais s&amp;eacute</segment>
    <segment id="181">;rio desde ent&amp;atilde</segment>
    <segment id="182">;o.</segment>
    <segment id="183">Segundo o governo da chamada Rep&amp;uacute</segment>
    <segment id="184">;blica de Artsakh</segment>
    <segment id="185">, morreram 376 militares at&amp;eacute</segment>
    <segment id="186">; aqui</segment>
    <segment id="187">, al&amp;eacute</segment>
    <segment id="188">;m de dezenas de civis.</segment>
    <segment id="189">Baku reconhece mais de 30 civis mortos</segment>
    <segment id="190">, masmas n&amp;atilde</segment>
    <segment id="191">;o revela suas baixas fardadas.</segment>
    <segment id="192">Baku quer a volta de Nagorno-Karabakh</segment>
    <segment id="193">, juridicamente seu territ&amp;oacute</segment>
    <segment id="194">;rio, e a desocupa&amp;ccedil</segment>
    <segment id="195">;&amp;atilde</segment>
    <segment id="196">;o militar de sete distritos em torno da &amp;aacute</segment>
    <segment id="197">;rea, que a Arm&amp;ecirc</segment>
    <segment id="198">;nia usa</segment>
    <segment id="199">comocomo tamp&amp;atilde</segment>
    <segment id="200">;o para proteger o encrave.</segment>
    <segment id="201">J&amp;aacute</segment>
    <segment id="202">;</segment>
    <segment id="203">a Arm&amp;ecirc</segment>
    <segment id="204">;nia busca a autonomia da regi&amp;atilde</segment>
    <segment id="205">;o.</segment>
    <segment id="206">Nos &amp;uacute</segment>
    <segment id="207">;ltimos dias</segment>
    <segment id="208">, os arm&amp;ecirc</segment>
    <segment id="209">;nios j&amp;aacute</segment>
    <segment id="210">;</segment>
    <segment id="211">haviam dito a Putin que topavam fazer concess&amp;otilde</segment>
    <segment id="212">;es, o que deve implicar a sa&amp;iacute</segment>
    <segment id="213">;da das regi&amp;otilde</segment>
    <segment id="214">;es azeris ocupadas.</segment>
    <segment id="215">Do ponto de vista militar</segment>
    <segment id="216">, Baku est&amp;aacute</segment>
    <segment id="217">; numa posi&amp;ccedil</segment>
    <segment id="218">;&amp;atilde</segment>
    <segment id="219">;o favor&amp;aacute</segment>
    <segment id="220">;vel, mas</segment>
    <segment id="221">mas a Arm&amp;ecirc</segment>
    <segment id="222">;nia resistiu bem at&amp;eacute</segment>
    <segment id="223">; aqui.</segment>
    <segment id="224">Com o cessar-fogo</segment>
    <segment id="225">, Putin j&amp;aacute</segment>
    <segment id="226">;</segment>
    <segment id="227">poder&amp;aacute</segment>
    <segment id="228">; cantar vit&amp;oacute</segment>
    <segment id="229">;ria sobre o presidente turco Recep Tayyip Erdogan</segment>
    <segment id="230">, masmas tudo ainda depender&amp;aacute</segment>
    <segment id="231">; dos termos da negocia&amp;ccedil</segment>
    <segment id="232">;&amp;atilde</segment>
    <segment id="233">;o futura.</segment>
    <segment id="234">No an&amp;uacute</segment>
    <segment id="235">;ncio feito &amp;agrave</segment>
    <segment id="236">;s 3h de s&amp;aacute</segment>
    <segment id="237">;bado (21h de sexta) em Moscou</segment>
    <segment id="238">, Lavrov afirmou que ambas as partes concordaram em buscar uma solu&amp;ccedil</segment>
    <segment id="239">;&amp;atilde</segment>
    <segment id="240">;o permanente para o conflito.</segment>
    <segment id="241">Por ora</segment>
    <segment id="242">, al&amp;eacute</segment>
    <segment id="243">;m do cessar-fogo</segment>
    <segment id="244">, haver&amp;aacute</segment>
    <segment id="245">; troca de prisioneiros e cad&amp;aacute</segment>
    <segment id="246">;veres no campo de batalha.</segment>
    <segment id="247">Para Ruslan Pukhov</segment>
    <segment id="248">, diretor do Centro de An&amp;aacute</segment>
    <segment id="249">;lises de Estrat&amp;eacute</segment>
    <segment id="250">;gias e Tecnologias</segment>
    <segment id="251">, de Moscou</segment>
    <segment id="252">, o apoio militar da Turquia fez toda a diferen&amp;ccedil</segment>
    <segment id="253">;a em rela&amp;ccedil</segment>
    <segment id="254">;&amp;atilde</segment>
    <segment id="255">;o aos conflitos pontuais que eclodiram em outras ocasi&amp;otilde</segment>
    <segment id="256">;es, como</segment>
    <segment id="257">como em 2014 e 2016.</segment>
    <segment id="258">Ele cr&amp;ecirc</segment>
    <segment id="259">; que as negocia&amp;ccedil</segment>
    <segment id="260">;&amp;otilde</segment>
    <segment id="261">;es no C&amp;aacute</segment>
    <segment id="262">;ucaso n&amp;atilde</segment>
    <segment id="263">;o poder&amp;atilde</segment>
    <segment id="264">;o, ao fim</segment>
    <segment id="265">, alienar Ancara.</segment>
    <segment id="266">Erdogan e Putin</segment>
    <segment id="267">s&amp;atilde</segment>
    <segment id="268">;o aliados reticentes</segment>
    <segment id="269">, com diversas rivalidades em locais</segment>
    <segment id="270">comocomo S&amp;iacute</segment>
    <segment id="271">;ria e L&amp;iacute</segment>
    <segment id="272">;bia, mas</segment>
    <segment id="273">mas tamb&amp;eacute</segment>
    <segment id="274">;m parcerias energ&amp;eacute</segment>
    <segment id="275">;ticas e militares</segment>
    <segment id="276">, apesar de a Turquia ser membro da Otan</segment>
    <segment id="277">, a alian&amp;ccedil</segment>
    <segment id="278">;a liderada pelos Estados Unidos.​</segment>
  </rst>
</analysis>