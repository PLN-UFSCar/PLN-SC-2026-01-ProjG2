  <rst>
    <segment id="1">A música "Flowers"</segment>
    <segment id="2">, de Miley Cyrus</segment>
    <segment id="3">, foi a única estrangeira a aparecer entre as 50 mais tocadas do Brasil no ano passado.</segment>
    <segment id="4">A faixa aparece na 43ª posição.</segment>
    <segment id="5">As primeiras colocações ficaram com "</segment>
    <segment id="6">Leão</segment>
    <segment id="7">"</segment>
    <segment id="8">, de Marília Mendonça</segment>
    <segment id="9">, e "Nosso Quadro"</segment>
    <segment id="10">, de Ana Castela.</segment>
    <segment id="11">A cantora Miley Cyrus em ensaio para o disco &amp;#039</segment>
    <segment id="12">;Endless Summer Vacation&amp;#039</segment>
    <segment id="13">; - DivulgaçãoA conclusão é da entidade Pró-Música</segment>
    <segment id="14">, que representa gravadoras e produtoras brasileiras.</segment>
    <segment id="15">Para montar o ranking</segment>
    <segment id="16">, foram analisadas as plataformas de streaming Spotify</segment>
    <segment id="17">, YouTube</segment>
    <segment id="18">, Deezer</segment>
    <segment id="19">, Apple Music</segment>
    <segment id="20">, Amazon Music e Napster.</segment>
    <segment id="21">Sertanejo domina a lista</segment>
    <segment id="22">, masmas há ainda canções de funk</segment>
    <segment id="23">, trap e pop.</segment>
    <segment id="24">Quarenta e nove músicas são nacionais</segment>
    <segment id="25">, e apenas uma é estrangeira.</segment>
    <segment id="26">Veja ensaio de Miley Cyrus para o disco &amp;#039</segment>
    <segment id="27">;Endless Summer Vacation&amp;#039</segment>
    <segment id="28">;Mais    novamente         de   de  de  representando um  Veja a seguir as 20 músicas mais tocadas segundo o ranking.     "Leão"</segment>
