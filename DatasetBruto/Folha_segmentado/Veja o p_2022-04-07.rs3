    <segment id="1">Da chegada da família real portuguesa</segment>
    <segment id="2">, em 1808</segment>
    <segment id="3">, à assinatura do tratado que reconhecia a legitimidade da emancipação do território brasileiro</segment>
    <segment id="4">, em 1825</segment>
    <segment id="5">, ocorreram diversos episódios que impulsionaram a independência do Brasil.</segment>
    <segment id="6">Nesse período de quase duas décadas</segment>
    <segment id="7">, a então porção americana do Reino Unido de Portugal</segment>
    <segment id="8">, Brasil e Algarves foi palco de revoltas</segment>
    <segment id="9">, acordos e proclamações que moldaram os primeiros passos de uma nação em construção</segment>
    <segment id="10">, momentos registrados em pinturas e gravuras feitas durante os séculos 19 e 20.</segment>
    <segment id="11">A galeria abaixo reúne 14 desses exemplos.</segment>
    <segment id="12">São obras que</segment>
    <segment id="13">, de forma mais ou menos realista</segment>
    <segment id="14">, ajudam a narrar esse processo histórico.</segment>
