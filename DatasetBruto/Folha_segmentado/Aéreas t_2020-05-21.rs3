  <rst>
    <segment id="1">Embora ainda muito distante do cen&amp;aacute</segment>
    <segment id="2">;rio pr&amp;eacute</segment>
    <segment id="3">;-pandemia do novo coronav&amp;iacute</segment>
    <segment id="4">;rus, as tr&amp;ecirc</segment>
    <segment id="5">;s grandes companhias a&amp;eacute</segment>
    <segment id="6">;reas do pa&amp;iacute</segment>
    <segment id="7">;s v&amp;atilde</segment>
    <segment id="8">;o operar em m&amp;eacute</segment>
    <segment id="9">;dia 100 novos voos di&amp;aacute</segment>
    <segment id="10">;rios em junho.</segment>
    <segment id="11">Ser&amp;atilde</segment>
    <segment id="12">;o 15 novos voos di&amp;aacute</segment>
    <segment id="13">;rios na Latam</segment>
    <segment id="14">, em m&amp;eacute</segment>
    <segment id="15">;dia, no pr&amp;oacute</segment>
    <segment id="16">;ximo m&amp;ecirc</segment>
    <segment id="17">;s, al&amp;eacute</segment>
    <segment id="18">;m de 32 na Gol e 53</segment>
    <segment id="19">, na Azul.</segment>
    <segment id="20">Gol e Azul tamb&amp;eacute</segment>
    <segment id="21">;m retomar&amp;atilde</segment>
    <segment id="22">;o as atividades no aeroporto de Congonhas</segment>
    <segment id="23">, enquanto a Latam anunciou o retorno de voos internacionais.</segment>
    <segment id="24">Segundo a Latam</segment>
    <segment id="25">, a previs&amp;atilde</segment>
    <segment id="26">;o &amp;eacute</segment>
    <segment id="27">; de crescimento gradual de suas opera&amp;ccedil</segment>
    <segment id="28">;&amp;otilde</segment>
    <segment id="29">;es nos pr&amp;oacute</segment>
    <segment id="30">;ximos dois meses.</segment>
    <segment id="31">Em junho</segment>
    <segment id="32">, ser&amp;atilde</segment>
    <segment id="33">;o em m&amp;eacute</segment>
    <segment id="34">;dia 50 voos di&amp;aacute</segment>
    <segment id="35">;rios no pa&amp;iacute</segment>
    <segment id="36">;s, ante os 35 voos de maio.</segment>
    <segment id="37">Como compara&amp;ccedil</segment>
    <segment id="38">;&amp;atilde</segment>
    <segment id="39">;o, antes da crise a companhia operava 750 voos di&amp;aacute</segment>
    <segment id="40">;rios no pa&amp;iacute</segment>
    <segment id="41">;s.</segment>
    <segment id="42">Viajando de avião durante a pandemiaMais    novamente         de   de  de  representando um</segment>
    <segment id="43">A partir de S&amp;atilde</segment>
    <segment id="44">;o Paulo</segment>
    <segment id="45">, ser&amp;atilde</segment>
    <segment id="46">;o operadas as rotas internacionais para Frankfurt</segment>
    <segment id="47">, Londres</segment>
    <segment id="48">, Madri</segment>
    <segment id="49">, Miami e Santiago.</segment>
    <segment id="50">Da capital chilena</segment>
    <segment id="51">, partir&amp;atilde</segment>
    <segment id="52">;o voos para Miami.</segment>
    <segment id="53">Dos 14.781 voos semanais previstos para o per&amp;iacute</segment>
    <segment id="54">;odo, a malha a&amp;eacute</segment>
    <segment id="55">;rea atende em maio apenas 1.254 voos semanais</segment>
    <segment id="56">, ou 8</segment>
    <segment id="57">,48% do total</segment>
    <segment id="58">, segundo a Anac (Ag&amp;ecirc</segment>
    <segment id="59">;ncia Nacional de Avia&amp;ccedil</segment>
    <segment id="60">;&amp;atilde</segment>
    <segment id="61">;o Civil).</segment>
    <segment id="62">No mercado internacional</segment>
    <segment id="63">, a redu&amp;ccedil</segment>
    <segment id="64">;&amp;atilde</segment>
    <segment id="65">;o &amp;eacute</segment>
    <segment id="66">; de praticamente 100%</segment>
    <segment id="67">, com os voos existentes tendo</segment>
    <segment id="68">comocomo objetivo a repatria&amp;ccedil</segment>
    <segment id="69">;&amp;atilde</segment>
    <segment id="70">;o de brasileiros que est&amp;atilde</segment>
    <segment id="71">;o no exterior e o transporte de cargas.</segment>
    <segment id="72">Em abril</segment>
    <segment id="73">, a demanda por voos dom&amp;eacute</segment>
    <segment id="74">;sticos recuou 93</segment>
    <segment id="75">,1%, com queda na oferta de 91</segment>
    <segment id="76">,6%.</segment>
    <segment id="77">J&amp;aacute</segment>
    <segment id="78">; nos voos internacionais</segment>
    <segment id="79">, a redu&amp;ccedil</segment>
    <segment id="80">;&amp;atilde</segment>
    <segment id="81">;o na demanda foi de 96</segment>
    <segment id="82">,1%, com oferta 91</segment>
    <segment id="83">,1% menor que no mesmo m&amp;ecirc</segment>
    <segment id="84">;s de 2019.</segment>
    <segment id="85">A opera&amp;ccedil</segment>
    <segment id="86">;&amp;atilde</segment>
    <segment id="87">;o de todo o grupo Latam Airlines passar&amp;aacute</segment>
    <segment id="88">; em junho dos atuais 5% de m&amp;eacute</segment>
    <segment id="89">;dia de voos di&amp;aacute</segment>
    <segment id="90">;rios para 9% de sua capacidade pr&amp;eacute</segment>
    <segment id="91">;-crise</segment>
    <segment id="92">, com previs&amp;atilde</segment>
    <segment id="93">;o de atingir 18% em julho.</segment>
    <segment id="94">Tamb&amp;eacute</segment>
    <segment id="95">;m em julho</segment>
    <segment id="96">, o grupo espera aumentar para 13 o total de destinos internacionais.</segment>
    <segment id="97">Na Am&amp;eacute</segment>
    <segment id="98">;rica do Sul</segment>
    <segment id="99">, a Latam Airlines Chile atender&amp;aacute</segment>
    <segment id="100">; 12 destinos em junho.</segment>
    <segment id="101">A subsidi&amp;aacute</segment>
    <segment id="102">;ria no Equador trabalha para retomar voos em junho</segment>
    <segment id="103">, enquanto na Col&amp;ocirc</segment>
    <segment id="104">;mbia e no Peru a previs&amp;atilde</segment>
    <segment id="105">;o &amp;eacute</segment>
    <segment id="106">; que isso ocorra no m&amp;ecirc</segment>
    <segment id="107">;s seguinte.</segment>
    <segment id="108">J&amp;aacute</segment>
    <segment id="109">;</segment>
    <segment id="110">a Gol anunciou que</segment>
    <segment id="111">, al&amp;eacute</segment>
    <segment id="112">;m de reabrir bases</segment>
    <segment id="113">, ter&amp;aacute</segment>
    <segment id="114">; um total de 100 voos di&amp;aacute</segment>
    <segment id="115">;rios em junho</segment>
    <segment id="116">, ante os 68 na chamada malha a&amp;eacute</segment>
    <segment id="117">;rea essencial de maio</segment>
    <segment id="118">, ou 47% mais.</segment>
    <segment id="119">Companhias aéreas desativam aviões após pandemia de coronavírus paralisar setorMais    novamente         de   de  de  representando um  Do total</segment>
    <segment id="120">, 20 voos come&amp;ccedil</segment>
    <segment id="121">;ar&amp;atilde</segment>
    <segment id="122">;o em 10 de junho</segment>
    <segment id="123">, quando ser&amp;atilde</segment>
    <segment id="124">;o reabertas bases em Chapec&amp;oacute</segment>
    <segment id="125">; (SC)</segment>
    <segment id="126">, Ilh&amp;eacute</segment>
    <segment id="127">;us e Porto Seguro (BA)</segment>
    <segment id="128">, Juazeiro do Norte (CE) e Petrolina (PE)</segment>
    <segment id="129">, todas com liga&amp;ccedil</segment>
    <segment id="130">;&amp;atilde</segment>
    <segment id="131">;o com Guarulhos.</segment>
    <segment id="132">Al&amp;eacute</segment>
    <segment id="133">;m de retomar opera&amp;ccedil</segment>
    <segment id="134">;&amp;otilde</segment>
    <segment id="135">;es nesses locais</segment>
    <segment id="136">, a Gol tamb&amp;eacute</segment>
    <segment id="137">;m voltar&amp;aacute</segment>
    <segment id="138">; a operar no aeroporto de Congonhas</segment>
    <segment id="139">, o que far&amp;aacute</segment>
    <segment id="140">; com que Guarulhos deixe de concentrar as atividades da a&amp;eacute</segment>
    <segment id="141">;rea.</segment>
    <segment id="142">Em rela&amp;ccedil</segment>
    <segment id="143">;&amp;atilde</segment>
    <segment id="144">;o ao per&amp;iacute</segment>
    <segment id="145">;odo pr&amp;eacute</segment>
    <segment id="146">;-pandemia do novo coronav&amp;iacute</segment>
    <segment id="147">;rus, por&amp;eacute</segment>
    <segment id="148">;m, o total de voos previstos para junho representa queda de 87%</segment>
    <segment id="149">, segundo a a&amp;eacute</segment>
    <segment id="150">;rea.</segment>
    <segment id="151">A Azul</segment>
    <segment id="152">, por sua vez</segment>
    <segment id="153">, passar&amp;aacute</segment>
    <segment id="154">; dos 115 em dias de pico neste m&amp;ecirc</segment>
    <segment id="155">;s para 168</segment>
    <segment id="156">, no m&amp;ecirc</segment>
    <segment id="157">;s que vem.</segment>
    <segment id="158">Em abril</segment>
    <segment id="159">, foram 70 voos.</segment>
    <segment id="160">Outras cinco bases ser&amp;atilde</segment>
    <segment id="161">;o reabertas pela companhia</segment>
    <segment id="162">, que voltar&amp;aacute</segment>
    <segment id="163">; a operar a partir de 15 de junho nos aeroportos de Congonhas</segment>
    <segment id="164">, Aracaju e Natal.</segment>
    <segment id="165">Ribeir&amp;atilde</segment>
    <segment id="166">;o</segment>
    <segment id="167">Preto</segment>
    <segment id="168">dever&amp;aacute</segment>
    <segment id="169">;</segment>
    <segment id="170">ter voos no dia 10 e Rondon&amp;oacute</segment>
    <segment id="171">;polis (MT) retomar&amp;aacute</segment>
    <segment id="172">;</segment>
    <segment id="173">as opera&amp;ccedil</segment>
    <segment id="174">;&amp;otilde</segment>
    <segment id="175">;es dia 22.</segment>
    <segment id="176">Na capital</segment>
    <segment id="177">, ser&amp;atilde</segment>
    <segment id="178">;o dois voos di&amp;aacute</segment>
    <segment id="179">;rios para Rio de Janeiro e Belo Horizonte</segment>
    <segment id="180">, al&amp;eacute</segment>
    <segment id="181">;m de opera&amp;ccedil</segment>
    <segment id="182">;&amp;otilde</segment>
    <segment id="183">;es di&amp;aacute</segment>
    <segment id="184">;rias para Recife e Cuiab&amp;aacute</segment>
    <segment id="185">;.</segment>
    <segment id="186">O governo de Mato Grosso divulgou nota em que o secret&amp;aacute</segment>
    <segment id="187">;rio do Desenvolvimento Econ&amp;ocirc</segment>
    <segment id="188">;mico, C&amp;eacute</segment>
    <segment id="189">;sar Miranda</segment>
    <segment id="190">, diz que a retomada dos voos &amp;ldquo</segment>
    <segment id="191">;sinaliza que a economia come&amp;ccedil</segment>
    <segment id="192">;a a voltar ao ritmo de forma lenta e gradual&amp;rdquo</segment>
    <segment id="193">;.​</segment>
    <segment id="194">Na &amp;uacute</segment>
    <segment id="195">;ltima ter&amp;ccedil</segment>
    <segment id="196">;a-feira (19)</segment>
    <segment id="197">, foram anunciadas novas medidas sanit&amp;aacute</segment>
    <segment id="198">;rias para a avia&amp;ccedil</segment>
    <segment id="199">;&amp;atilde</segment>
    <segment id="200">;o, como</segment>
    <segment id="201">como a necessidade de uso de m&amp;aacute</segment>
    <segment id="202">;scaras durante todo o voo</segment>
    <segment id="203">, regras para o servi&amp;ccedil</segment>
    <segment id="204">;o de bordo e distanciamento de ao menos dois metros entre as pessoas nos aeroportos.​</segment>
