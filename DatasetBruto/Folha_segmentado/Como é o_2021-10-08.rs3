  <rst>
    <segment id="1">Onde fica o melhor lugar do mundo?</segment>
    <segment id="2">Durante a pandemia</segment>
    <segment id="3">, ficou f&amp;aacute</segment>
    <segment id="4">;cil de responder.</segment>
    <segment id="5">&amp;Eacute</segment>
    <segment id="6">; onde n&amp;atilde</segment>
    <segment id="7">;o existe coronav&amp;iacute</segment>
    <segment id="8">;rus e ningu&amp;eacute</segment>
    <segment id="9">;m precisa usar m&amp;aacute</segment>
    <segment id="10">;scara para</segment>
    <segment id="11">sese proteger.</segment>
    <segment id="12">&amp;Eacute</segment>
    <segment id="13">; um espa&amp;ccedil</segment>
    <segment id="14">;o cheio de amigos e de abra&amp;ccedil</segment>
    <segment id="15">;os dados pela fam&amp;iacute</segment>
    <segment id="16">;lia.</segment>
    <segment id="17">Mas ser&amp;aacute</segment>
    <segment id="18">; que &amp;eacute</segment>
    <segment id="19">; mesmo assim?</segment>
    <segment id="20">No poema que d&amp;aacute</segment>
    <segment id="21">;</segment>
    <segment id="22">t&amp;iacute</segment>
    <segment id="23">;tulo ao livro &amp;ldquo</segment>
    <segment id="24">;O</segment>
    <segment id="25">Melhor Lugar do Mundo&amp;rdquo</segment>
    <segment id="26">;, do escritor Eduardo Sens</segment>
    <segment id="27">, o personagem jura de p&amp;eacute</segment>
    <segment id="28">;</segment>
    <segment id="29">junto que j&amp;aacute</segment>
    <segment id="30">; viajou para l&amp;aacute</segment>
    <segment id="31">;.</segment>
    <segment id="32">Mas n&amp;atilde</segment>
    <segment id="33">;o vou contar o que ele diz</segment>
    <segment id="34">, sen&amp;atilde</segment>
    <segment id="35">;o a surpresa vai estragar.</segment>
    <segment id="36">Dou uma dica: o melhor lugar do mundo &amp;eacute</segment>
    <segment id="37">; bem diferente do que voc&amp;ecirc</segment>
    <segment id="38">; imagina.</segment>
    <segment id="39">Ali&amp;aacute</segment>
    <segment id="40">;s, essa poesia e tamb&amp;eacute</segment>
    <segment id="41">;m v&amp;aacute</segment>
    <segment id="42">;rias outras do livro s&amp;atilde</segment>
    <segment id="43">;o cheias de reviravoltas e mostram que nada &amp;eacute</segment>
    <segment id="44">; como</segment>
    <segment id="45">como parece ser &amp;agrave</segment>
    <segment id="46">; primeira vista.</segment>
    <segment id="47">Veja ilustrações do livro &amp;#039</segment>
    <segment id="48">;O Melhor Lugar do Mundo&amp;#039</segment>
    <segment id="49">;Mais    novamente         de   de  de  representando um  Duvida?</segment>
    <segment id="50">O livro tem versos sobre russo que desce pela privada</segment>
    <segment id="51">, sobre escuro que tem medo de crian&amp;ccedil</segment>
    <segment id="52">;a e at&amp;eacute</segment>
    <segment id="53">;</segment>
    <segment id="54">sobre umbigo que segura a bunda.</segment>
    <segment id="55">Isso sem falar do braquiossauro que ruge.</segment>
    <segment id="56">Tudo &amp;eacute</segment>
    <segment id="57">; ilustrado pelo Galv&amp;atilde</segment>
    <segment id="58">;o Bertazzi</segment>
    <segment id="59">, que faz os desenhos da coluna da Fl&amp;aacute</segment>
    <segment id="60">;via Boggio aqui na Folha.</segment>
    <segment id="61">As ilustra&amp;ccedil</segment>
    <segment id="62">;&amp;otilde</segment>
    <segment id="63">;es s&amp;atilde</segment>
    <segment id="64">;o todas em preto e branco</segment>
    <segment id="65">, com exce&amp;ccedil</segment>
    <segment id="66">;&amp;atilde</segment>
    <segment id="67">;o da capa.</segment>
    <segment id="68">Eu avisei que era tudo meio diferente e maluco.</segment>
    <segment id="69">D&amp;aacute</segment>
    <segment id="70">; vontade de pegar a canetinha e colorir cada um dos personagens.  Mas n&amp;atilde</segment>
    <segment id="71">;o s&amp;atilde</segment>
    <segment id="72">;o s&amp;oacute</segment>
    <segment id="73">; as imagens que podem parecer familiares aos adultos</segment>
    <segment id="74">, que veem o tra&amp;ccedil</segment>
    <segment id="75">;o do Galv&amp;atilde</segment>
    <segment id="76">;o todas as semanas no jornal.</segment>
    <segment id="77">Alguns poemas d&amp;atilde</segment>
    <segment id="78">;o uma piscadinha para poetas importantes e agradam gente grande e crian&amp;ccedil</segment>
    <segment id="79">;a.</segment>
    <segment id="80">O passarinho dos versos famosos do Mario Quintana</segment>
    <segment id="81">, por exemplo</segment>
    <segment id="82">, voa nas p&amp;aacute</segment>
    <segment id="83">;ginas.</segment>
    <segment id="84">J&amp;aacute</segment>
    <segment id="85">;</segment>
    <segment id="86">o ritmo do trem de ferro do Manuel Bandeira</segment>
    <segment id="87">, que foi declamado at&amp;eacute</segment>
    <segment id="88">;</segment>
    <segment id="89">no &amp;ldquo</segment>
    <segment id="90">;Castelo R&amp;aacute</segment>
    <segment id="91">;-Tim-Bum&amp;rdquo</segment>
    <segment id="92">;, parece o do rel&amp;oacute</segment>
    <segment id="93">;gio da poesia &amp;ldquo</segment>
    <segment id="94">;Perda de Tempo&amp;rdquo</segment>
    <segment id="95">;, cheia dos tic-tac</segment>
    <segment id="96">, tic-tac</segment>
    <segment id="97">, tic-tac.</segment>
    <segment id="98">Ainda n&amp;atilde</segment>
    <segment id="99">;o falei</segment>
    <segment id="100">comocomo &amp;eacute</segment>
    <segment id="101">; o melhor lugar do mundo descrito no poema que d&amp;aacute</segment>
    <segment id="102">; nome ao livro</segment>
    <segment id="103">, n&amp;eacute</segment>
    <segment id="104">;?</segment>
    <segment id="105">Vou dar um pequeno spoiler ent&amp;atilde</segment>
    <segment id="106">;o.</segment>
    <segment id="107">Calma, n&amp;atilde</segment>
    <segment id="108">;o precisa parar de ler</segment>
    <segment id="109">, porque</segment>
    <segment id="110">porque n&amp;atilde</segment>
    <segment id="111">;o vou entregar o jogo tanto assim.</segment>
    <segment id="112">Como disse</segment>
    <segment id="113">, o melhor lugar descrito no livro &amp;ldquo</segment>
    <segment id="114">;O Melhor Lugar do Mundo&amp;rdquo</segment>
    <segment id="115">; &amp;eacute</segment>
    <segment id="116">; um pouco diferente.</segment>
    <segment id="117">L&amp;aacute</segment>
    <segment id="118">;, o p&amp;atilde</segment>
    <segment id="119">;o n&amp;atilde</segment>
    <segment id="120">;o &amp;eacute</segment>
    <segment id="121">; branquinho</segment>
    <segment id="122">, n&amp;atilde</segment>
    <segment id="123">;o existe samba e ningu&amp;eacute</segment>
    <segment id="124">;m d&amp;aacute</segment>
    <segment id="125">; um abra&amp;ccedil</segment>
    <segment id="126">;o.</segment>
    <segment id="127">Pior, ningu&amp;eacute</segment>
    <segment id="128">;m fala a nossa l&amp;iacute</segment>
    <segment id="129">;ngua.</segment>
    <segment id="130">Acredita?</segment>
    <segment id="131">O personagem n&amp;atilde</segment>
    <segment id="132">;o gosta muito disso e define esse local com uma palavra.</segment>
    <segment id="133">Um palavr&amp;atilde</segment>
    <segment id="134">;o.</segment>
    <segment id="135">N&amp;atilde</segment>
    <segment id="136">;o digo qual &amp;eacute</segment>
    <segment id="137">;</segment>
    <segment id="138">&amp;mdash</segment>
    <segment id="139">;s&amp;oacute</segment>
    <segment id="140">; que ele rima com aposta</segment>
    <segment id="141">, crosta</segment>
    <segment id="142">, birosca.</segment>
    <segment id="143">Afinal</segment>
    <segment id="144">, como</segment>
    <segment id="145">como diz outro poeta</segment>
    <segment id="146">, o Gilberto Gil</segment>
    <segment id="147">, o melhor lugar do mundo &amp;eacute</segment>
    <segment id="148">; aqui.</segment>
    <segment id="149">E agora.</segment>
    <segment id="150">O Melhor Lugar do MundoPreço R$ 40 (156 págs.)Autor Eduardo SensEditora</segment>
    <segment id="151">Caiaponte EdiçõesIlustrador</segment>
