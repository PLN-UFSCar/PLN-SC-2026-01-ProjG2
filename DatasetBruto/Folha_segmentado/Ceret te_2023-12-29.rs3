  <rst>
    <segment id="1">O Centro Esportivo</segment>
    <segment id="2">, Recreativo e Educativo do Trabalhador (Ceret)</segment>
    <segment id="3">, na zona leste de São Paulo</segment>
    <segment id="4">, está agora com a nova pista de atletismo e os campos de futebol e de rúgbi com certificações internacionais</segment>
    <segment id="5">, ou seja</segment>
    <segment id="6">, com padrões e tamanhos oficiais de competições.</segment>
    <segment id="7">Esses equipamentos esportivos do Ceret</segment>
    <segment id="8">, que recebe cerca de 35 mil pessoas semanalmente</segment>
    <segment id="9">, foram requalificados</segment>
    <segment id="10">, em um investimento da Prefeitura de mais de R$ 28 milhões.</segment>
    <segment id="11">Ainda na pista de atletismo</segment>
    <segment id="12">, as obras da arquibancada devem ser concluídas no início de 2024.  Praticantes de rúgbi brincam no gramado do campo do Ceret que agora tem padrão oficial após investimento da Prefeitura- Marcelo Pereira/SECOMCom certificado da Fifa</segment>
    <segment id="13">, os gramados sintéticos instalados nos campos de futebol contam com base drenante e agora poderão receber jogos noturnos por conta da nova iluminação.</segment>
    <segment id="14">Dentro dos padrões internacionais</segment>
    <segment id="15">, o novo campo de rúgbi</segment>
    <segment id="16">, modalidade que vem crescendo na cidade de São Paulo</segment>
    <segment id="17">, conta com gramado sintético e uma base drenante que auxilia no resfriamento do piso</segment>
    <segment id="18">, além de pontos de iluminação.</segment>
    <segment id="19">CERET</segment>
    <segment id="20">O Ceret abriga a maior piscina pública da América Latina</segment>
    <segment id="21">, com 100 metros de comprimento e 50 metros de largura.</segment>
    <segment id="22">Frequentadores fazem aquecimento no campo de futebol do Ceret</segment>
    <segment id="23">, agora com certificação internacional após passar por requalificação- Marcelo Pereira/SECOMO centro tem uma área total de 286 mil m².</segment>
    <segment id="24">Oferece ampla estrutura para a prática esportiva e de atividades físicas</segment>
    <segment id="25">, dispondo de campos de futebol</segment>
    <segment id="26">, quadras de vôlei</segment>
    <segment id="27">, quadra de vôlei de praia</segment>
    <segment id="28">, quadras de basquete</segment>
    <segment id="29">, quadras poliesportivas</segment>
    <segment id="30">, campo de rúgbi</segment>
    <segment id="31">, quadra de tênis</segment>
    <segment id="32">, pista para caminhada</segment>
    <segment id="33">, pista de atletismo</segment>
    <segment id="34">, salas de ginástica</segment>
    <segment id="35">, academias ao ar livre</segment>
    <segment id="36">, entre outros espaços.</segment>
    <segment id="37">Saiba mais sobre o Ceret clicando aqui.   *</segment>
    <segment id="38">Conteúdo patrocinado produzido pelo Estúdio Folha</segment>
  </rst>
</analysis>