  <rst>
    <segment id="1">O astro do rock britânico Roger Waters levou ao palco da Arena Fonte Nova</segment>
    <segment id="2">, em Salvador</segment>
    <segment id="3">, 12 crianças em situação de vulnerabilidades social do Projeto Axé para</segment>
    <segment id="4">sese apresentarem durante The Wall parte 2.</segment>
    <segment id="5">Vestidos</segment>
    <segment id="6">comocomo presidiários estadunidenses</segment>
    <segment id="7">, de macacão laranja</segment>
    <segment id="8">, com capuzes pretos na cabeça</segment>
    <segment id="9">, as crianças vestiam uma camisa com o escrito "resist".</segment>
    <segment id="10">Show de Roger Waters em Salvador</segment>
    <segment id="11">, nesta quarta-feira (17) - Franco Adailton/FolhapressLogo em seguida</segment>
    <segment id="12">, o público presente no show desta quarta-feira (17)</segment>
    <segment id="13">, emendou um estrondoso "</segment>
    <segment id="14">Ele não" —grito que endossou atos de rua contra o presidenciável Jair Bolsonaro (PSL).</segment>
    <segment id="15">Roger Waters apresentou as crianças do projeto e saiu para um intervalo.</segment>
    <segment id="16">"</segment>
    <segment id="17">São crianças excelentes</segment>
    <segment id="18">, daqui mesmo de Salvador.</segment>
    <segment id="19">Vamos fazer um intervalo e voltar com a resistência"</segment>
    <segment id="20">, disse.</segment>
    <segment id="21">Durante o intervalo</segment>
    <segment id="22">, o telão exibiu a mensagem para resistir a Mark Zuckerberg.</segment>
    <segment id="23">"</segment>
    <segment id="24">Resista ao anti-semitismo de Israel".</segment>
    <segment id="25">Ao contrário da polarização demonstrada nos shows anteriores pelo Brasil</segment>
    <segment id="26">, Rogers Waters</segment>
    <segment id="27">sese sentiu em casa para manifestar-</segment>
    <segment id="28">sese politicamente na Bahia</segment>
    <segment id="29">, onde o petista Fernando Haddad ganhou em 411 dos 417 municípios</segment>
    <segment id="30">, com 60% dos votos.</segment>
    <segment id="31">Se houve manifestações em favor do candidato do PSL</segment>
    <segment id="32">, Jair Bolsonaro —que foi o mais votado em apenas seis municípios baianos—</segment>
    <segment id="33">, os gritos foram abafados pela catarse que sintonizava com os ideais do roqueiro britânico</segment>
    <segment id="34">, em sua primeira passagem pelo nordeste.</segment>
    <segment id="35">Waters tornou a exibir no telão a frase</segment>
    <segment id="36">"ponto de vista censurado"</segment>
    <segment id="37">, retribuído pelo público com o coro "ele não".</segment>
    <segment id="38">Depois de o telão exibir a frase "resista a volta da tortura</segment>
    <segment id="39">, resista a forças policiais militarizadas"</segment>
    <segment id="40">, seguiu-</segment>
    <segment id="41">sese novamente o coro de "ele não"</segment>
    <segment id="42">Mas um grupo de cerca de 5 pessoas ensaiou rebater com gritos de "mito"</segment>
    <segment id="43">, "ele sim"</segment>
    <segment id="44">, que foram rapidamente cessados.  Roger WatersMais    novamente         de   de  de  representando um</segment>
    <segment id="45">Um casal que estava no grupo</segment>
    <segment id="46">, ao ser questionado sobre a manutenção de ir ao espetáculo</segment>
    <segment id="47">, mesmo ciente do posicionamento político de Roger Waters</segment>
    <segment id="48">, respondeu a Folha que "foi pela música".</segment>
    <segment id="49">A mulher</segment>
    <segment id="50">, que não quis</segment>
    <segment id="51">sese identificar</segment>
    <segment id="52">, sese referiu aos partidários do "ele não"</segment>
    <segment id="53">comocomo "comunistas de shopping center" e criticou Roger Waters.  "</segment>
    <segment id="54">Pra ele</segment>
    <segment id="55">, que mora fora</segment>
    <segment id="56">, é fácil vir falar ele não.</segment>
    <segment id="57">Ele que venha morar aqui pra ver"</segment>
    <segment id="58">, disse</segment>
    <segment id="59">, enraivada.</segment>
    <segment id="60">"</segment>
    <segment id="61">Aqui no Nordeste</segment>
    <segment id="62">, nós estamos sintonizados com o que é o certo a fazer</segment>
    <segment id="63">, sobretudo no que diz respeito aos direitos humanos.</segment>
    <segment id="64">Nossa cultura é da paz"</segment>
    <segment id="65">, cravou.</segment>
    <segment id="66">Outra que comunga com as ideais de Waters</segment>
    <segment id="67">, a bióloga Adriana Bispo</segment>
    <segment id="68">, 43 anos</segment>
    <segment id="69">, avaliou que o momento não é de divisão.  "</segment>
    <segment id="70">O Brasil já tem mortes demais.</segment>
    <segment id="71">Precisamos estar sintonizados com a preservação do bem maior</segment>
    <segment id="72">, que é a vida.</segment>
    <segment id="73">Não precisamos de mais violência".​</segment>
    <segment id="74">Apesar das manifestações</segment>
    <segment id="75">, as divergências políticas não</segment>
    <segment id="76">sese impuseram ante o clima de simbiose entre público e artistas</segment>
    <segment id="77">, sobretudo durante as baladas “Wish you were here”</segment>
    <segment id="78">, “Us and them” e “Great gig in the sky “</segment>
    <segment id="79">O tom mais ácido da passagem de Waters pela capital baiana teve passagens pontuais</segment>
    <segment id="80">, com música do mais recente disco solo e sucessos</segment>
    <segment id="81">comocomo The Wall</segment>
    <segment id="82">, "Welcome to the machine"</segment>
    <segment id="83">, "Money"</segment>
    <segment id="84">, "Pigs".</segment>
    <segment id="85">Roger apareceu no palco com as mãos amarradas por uma corda que descia do teto</segment>
    <segment id="86">, enquanto o telão exibia pessoas sob tortura.</segment>
    <segment id="87">Durante a exibição de Eclipse</segment>
    <segment id="88">, a produção de Waters levou ao público uma pirâmides de luzes</segment>
    <segment id="89">, acompanhada com as cores da luta LGBT.</segment>
    <segment id="90">MOA DO KATENDÊ   Roger Waters faz homenagem a Moa do Katendê em show em Salvador</segment>
    <segment id="91">, nesta quarta (17)- Franco Adailton/FolhapressWaters fez uma homenagem a mestre</segment>
    <segment id="92">Moa do Katendê</segment>
    <segment id="93">, assassinado no último dia 7</segment>
    <segment id="94">, por discordar de um eleitor de Bolsonaro.</segment>
    <segment id="95">“Ele foi morto por causa das ideias que ele acreditava</segment>
    <segment id="96">, de paz</segment>
    <segment id="97">, de amor.</segment>
    <segment id="98">Perdemos um enorme talento”.</segment>
    <segment id="99">“</segment>
    <segment id="100">O futuro do Brasil deve ser construído com base na filosofia de vida dele</segment>
    <segment id="101">, não dos agressores.</segment>
    <segment id="102">Mesmo que não acredite nos direitos humanos</segment>
    <segment id="103">, você deve defendê-los para todos os povos</segment>
    <segment id="104">, não só no Brasil.</segment>
    <segment id="105">Independentemente da cor da pele.</segment>
    <segment id="106">Nós somos incolores”.</segment>
    <segment id="107">A homenagem a mestre Moa provocou de gritos de "ele não"</segment>
    <segment id="108">, masmas também ouvia-</segment>
    <segment id="109">sese em menor amplitude gritos de reprovação por partidários de Bolsonaro.</segment>
    <segment id="110">Sem direito a bis</segment>
    <segment id="111">, Water encerrou a apresentação ao som anestesiante de "</segment>
    <segment id="112">Comfortably numb".</segment>
    <segment id="113">Preocupado com o horário do metrô construído sob a gestão dos petistas Jaques Wagner e Rui Costa</segment>
    <segment id="114">, cuja circulação foi anunciada até 1h</segment>
    <segment id="115">, o público tratou de esvaziar a arena sem insistir.</segment>
  </rst>
</analysis>