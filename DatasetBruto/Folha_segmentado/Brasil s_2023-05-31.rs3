  <rst>
    <segment id="1">Pela primeira vez</segment>
    <segment id="2">, a cerimônia de premiação dos melhores restaurantes da América Latina do 50 Best vai acontecer no Brasil</segment>
    <segment id="3">, no dia 28 de novembro</segment>
    <segment id="4">, no hotel Copacabana Palace</segment>
    <segment id="5">, no Rio de Janeiro.</segment>
    <segment id="6">Na data</segment>
    <segment id="7">, serão anunciados os vencedores da edição deste ano do prêmio —que</segment>
    <segment id="8">, nos últimos anos</segment>
    <segment id="9">, foi encabeçado por restaurantes peruanos</segment>
    <segment id="10">, masmas que vem contando com maior presença de brasileiros.</segment>
    <segment id="11">O anúncio foi feito nesta quinta-feira (31) pela manhã no Rio de Janeiro</segment>
    <segment id="12">, por Charles Reed</segment>
    <segment id="13">, CEO do Latin America's 50 Best Restaurants</segment>
    <segment id="14">, e pelo prefeito da cidade</segment>
    <segment id="15">, Eduardo Paes (PSD) —a cidade do Rio de Janeiro é patrocinadora do evento.</segment>
    <segment id="16">Jefferson e Janaína Rueda</segment>
    <segment id="17">, d&amp;#039</segment>
    <segment id="18">;A Casa do Porco - Maria Vargas/DivulgaçãoA premiação</segment>
    <segment id="19">, um dos braços regionais do ranking global World’s 50 Best</segment>
    <segment id="20">, já aconteceu antes no Peru</segment>
    <segment id="21">, na Colômbia</segment>
    <segment id="22">, Argentina e no México.</segment>
    <segment id="23">Era, há tempos</segment>
    <segment id="24">, era um desejo da comunidade de chefs e donos de restaurantes que também acontecesse no Brasil —já que comparecem à cerimônia jurados e imprensa estrangeira</segment>
    <segment id="25">, o que contribui</segment>
    <segment id="26">para que</segment>
    <segment id="27">para que restaurantes locais sejam visitados e tenham mais destaque em futuras edições.</segment>
    <segment id="28">Conheça o menu-degustação da Casa do PorcoMais    novamente         de   de  de  representando um  No ano passado</segment>
    <segment id="29">, o Brasil teve seu melhor ano na premiação:</segment>
    <segment id="30">foram 10 brasileiros entre os 50 melhores</segment>
    <segment id="31">, com destaque para A Casa do Porco</segment>
    <segment id="32">, novamente na quarta posição.</segment>
    <segment id="33">O Oteque</segment>
    <segment id="34">, de Alberto Landgraf</segment>
    <segment id="35">, no Rio de Janeiro</segment>
    <segment id="36">, foi o segundo melhor colocado do Brasil (12º).</segment>
    <segment id="37">Três novos restaurantes brasileiros estrearam na lista: Nelita (39)</segment>
    <segment id="38">, Charco (35) e Metzi (27)</segment>
    <segment id="39">, todos em São Paulo.</segment>
    <segment id="40">Na mesma cidade</segment>
    <segment id="41">, o D.O.M</segment>
    <segment id="42">, de Alex Atala</segment>
    <segment id="43">, caiu 20 posições.</segment>
    <segment id="44">As duas primeiras posições ficaram com o peruano Central e o argentino Don Julio.</segment>
  </rst>
