  <rst>
    <segment id="1">Essa foi uma das manchetes no noticiário em 2017.</segment>
    <segment id="2">Veículos em todo o mundo noticiaram a descoberta do "diamante da paz" em Serra Leoa.</segment>
    <segment id="3">Em uma nação africana onde diamantes são sinônimo de derramamento de sangue e miséria</segment>
    <segment id="4">, havia uma expectativa de que a pedra poderia ser usada para enriquecer a vida da população local.</segment>
    <segment id="5">Enorme pedra preciosa</segment>
    <segment id="6">, conhecida</segment>
    <segment id="7">comocomo &amp;#039</segment>
    <segment id="8">;diamante da paz&amp;#039</segment>
    <segment id="9">;  - Getty ImagesPor trás do frenesi da mídia</segment>
    <segment id="10">, estavam os escavadores</segment>
    <segment id="11">, os homens cujo trabalho exaustivo tornou possível a descoberta da pedra preciosa.</segment>
    <segment id="12">Komba Johnbull e Andrew Saffea —ainda na adolescência— eram os mais jovens do grupo de cinco escavadores.</segment>
    <segment id="13">Quando viram aquela pedra grande e brilhante no chão</segment>
    <segment id="14">, eles acreditaram que todos os seus sonhos haviam</segment>
    <segment id="15">sese tornado realidade.</segment>
    <segment id="16">Seis anos depois</segment>
    <segment id="17">, no entanto</segment>
    <segment id="18">, a descoberta ficou marcada pela decepção.</segment>
    <segment id="19">Plano de sobrevivência</segment>
    <segment id="20">Saffea era um estudante excelente</segment>
    <segment id="21">, masmas foi forçado a abandonar a escola devido à pobreza.  E a família de Johnbull foi devastada pela guerra civil de 1991-2002.</segment>
    <segment id="22">Johnbull foi o primeiro a ver o diamante debaixo d&amp;#039</segment>
    <segment id="23">;água - BBCJuntos</segment>
    <segment id="24">, eles</segment>
    <segment id="25">sese juntaram a um grupo de cinco escavadores patrocinados por um pastor local.</segment>
    <segment id="26">Eles não seriam pagos</segment>
    <segment id="27">, masmas receberiam equipamento básico e alimentos para si e para as suas famílias.</segment>
    <segment id="28">Se um diamante fosse descoberto</segment>
    <segment id="29">, o patrão ficaria com a maior parte dele.</segment>
    <segment id="30">Os jovens aceitaram uma jornada de trabalho exaustiva: acordar de madrugada para trabalhar em uma fazenda de dendezeiros antes do café da manhã e depois passar o resto do dia trabalhando na mina.</segment>
    <segment id="31">A esperança era poupar dinheiro suficiente para voltar à escola</segment>
    <segment id="32">, masmas a realidade do trabalho era devastadora.</segment>
    <segment id="33">"Eu disse a Johnbull que meu sonho havia sido destruído"</segment>
    <segment id="34">, diz Saffea.</segment>
    <segment id="35">Johnbull</segment>
    <segment id="36">sese lembra de</segment>
    <segment id="37">comocomo eles enfrentaram as fortes chuvas e o forte calor do verão.</segment>
    <segment id="38">"</segment>
    <segment id="39">Nós trocávamos palavras de incentivo</segment>
    <segment id="40">, fazíamos piadas</segment>
    <segment id="41">, tínhamos Bluetooth para tocar música.</segment>
    <segment id="42">"</segment>
    <segment id="43">Além disso</segment>
    <segment id="44">, eles sonhavam com o que fariam</segment>
    <segment id="45">sese de repente ficassem ricos.</segment>
    <segment id="46">Johnbull queria uma casa de dois andares e um Toyota FJ Cruiser</segment>
    <segment id="47">, enquanto Saffea queria terminar os estudos.</segment>
    <segment id="48">Diamante enorme</segment>
    <segment id="49">O dia em que finalmente tiveram sorte começou</segment>
    <segment id="50">comocomo qualquer outro</segment>
    <segment id="51">, com um café da manhã de bananas cozidas e uma oração antes de seguirem para a mina.</segment>
    <segment id="52">Maioria dos mineiros não recebe dinheiro suficiente para conseguir mudar de vida  - Getty ImagesOs escavadores gastam apenas uma pequena quantidade de tempo procurando ativamente por diamantes.</segment>
    <segment id="53">Naquela sexta-feira</segment>
    <segment id="54">, 13 de março de 2017</segment>
    <segment id="55">, o plano era trabalhar nos preparativos da mineração:</segment>
    <segment id="56">começar a retirar terra</segment>
    <segment id="57">, extrair cascalho e lidar com enchentes do início da estação chuvosa.</segment>
    <segment id="58">Foi então que os olhos de Johnbull brilharam.  "</segment>
    <segment id="59">Vi uma pedra debaixo da água corrente que estava sendo arrastada.</segment>
    <segment id="60">Foi puro instinto</segment>
    <segment id="61">porque</segment>
    <segment id="62">porque nunca tinha visto um diamante antes.</segment>
    <segment id="63">"  "</segment>
    <segment id="64">Fiquei olhando para a pedra por mais de um minuto.</segment>
    <segment id="65">Então eu disse ao meu tio: 'Cara</segment>
    <segment id="66">, essa pedra brilha</segment>
    <segment id="67">, que tipo de pedra é essa?'"  Johnbull</segment>
    <segment id="68">sese abaixou e puxou-a para fora da água.</segment>
    <segment id="69">"Estava muito frio.</segment>
    <segment id="70">Assim que a peguei</segment>
    <segment id="71">, eles tiraram a pedra de mim e disseram:</segment>
    <segment id="72">'Isto é um diamante!'"  Tinha 709 quilates —o décimo quarto maior registrado no mundo.</segment>
    <segment id="73">Os garimpeiros alertaram o seu patrocinador</segment>
    <segment id="74">, o pastor Emmanuel Momoh</segment>
    <segment id="75">, que resolveu levar o diamante ao governo</segment>
    <segment id="76">, em vez de vendê-lo no mercado clandestino.</segment>
    <segment id="77">O diamante foi vendido em leilão por US$ 6</segment>
    <segment id="78">,5 milhões (em cotação atual</segment>
    <segment id="79">, como</segment>
    <segment id="80">como referência</segment>
    <segment id="81">, esse valor seria equivalente a mais de R$ 30 milhões).</segment>
    <segment id="82">Patrocinadores dos mineiros ficam com a maior parte do dinheiro - Getty ImagesCentenas de milhares de serra-leoneses trabalham</segment>
    <segment id="83">comocomo escavadores em minas informais</segment>
    <segment id="84">comocomo Johnbull e Saffea.</segment>
    <segment id="85">Se tiverem sorte</segment>
    <segment id="86">, poderão encontrar um pequeno fragmento de diamante</segment>
    <segment id="87">, masmas é o sonho de encontrar um diamante inteiro</segment>
    <segment id="88">comocomo este que mantém tantas pessoas na difícil luta.</segment>
    <segment id="89">O acordo estipulado com os garimpeiros é que cada um deles recebe uma parte do lucro —e que outra parte vai para o governo para o desenvolvimento local.</segment>
    <segment id="90">Os escavadores receberam um pagamento inicial de apenas US$ 80 mil (R$ 400 mil</segment>
    <segment id="91">, na cotação atual) cada.  Era mais dinheiro do que Saffea e Johnbull esperavam ganhar quando</segment>
    <segment id="92">sese associaram pela primeira vez.</segment>
    <segment id="93">Mas eles ficaram decepcionados ao receber uma parte tão pequena</segment>
    <segment id="94">, em relação ao valor total do diamante.</segment>
    <segment id="95">"</segment>
    <segment id="96">Quando recebi minha parte do dinheiro</segment>
    <segment id="97">, guardei-o durante uma semana inteira sem tocar nele.</segment>
    <segment id="98">Finalmente viajei para Freetown (capital de Serra Leoa) para comprar uma casa"</segment>
    <segment id="99">, diz Johnbull.</segment>
    <segment id="100">Saffea queria ir para o Canadá para continuar seus estudos e Johnbull queria ir com ele.</segment>
    <segment id="101">Eles pagaram a um agente US$ 15 mil (R$ 75 mil) para viagens</segment>
    <segment id="102">, acomodação e taxas universitárias.</segment>
    <segment id="103">Eles foram levados para Gana</segment>
    <segment id="104">, onde passaram seis meses e gastaram grande parte do dinheiro.</segment>
    <segment id="105">O plano falhou</segment>
    <segment id="106">porque</segment>
    <segment id="107">porque o pedido de visto foi rejeitado.</segment>
    <segment id="108">Johnbull regressou à Serra Leoa</segment>
    <segment id="109">, tendo perdido grande parte do seu dinheiro</segment>
    <segment id="110">, enquanto Saffea ainda fez outra viagem.</segment>
    <segment id="111">Ele foi para um terceiro país</segment>
    <segment id="112">, cujo nome não mencionamos para sua segurança</segment>
    <segment id="113">, onde lhe disseram que poderia trabalhar</segment>
    <segment id="114">comocomo motorista durante o dia e estudar à noite.</segment>
    <segment id="115">Mas quando Saffea chegou ao seu destino</segment>
    <segment id="116">, a realidade era muito diferente.</segment>
    <segment id="117">"</segment>
    <segment id="118">Cuido de cavalos em um estábulo</segment>
    <segment id="119">, onde também durmo e</segment>
    <segment id="120">comocomo.</segment>
    <segment id="121">Outros trabalhadores receberam alojamento</segment>
    <segment id="122">, enquanto eu fiquei dormindo no estábulo.</segment>
    <segment id="123">"</segment>
    <segment id="124">Essa não é a vida de quem sonhava enriquecer com diamantes.</segment>
    <segment id="125">Agora ele diz que só quer ir para casa.</segment>
    <segment id="126">Sem reconhecimento</segment>
    <segment id="127">O que mais magoa Saffea e Johnbull é a sensação de que nunca obtiveram o devido reconhecimento pela sua descoberta.</segment>
    <segment id="128">As reportagens da mídia sobre o diamante focaram no pastor que os patrocinou.</segment>
    <segment id="129">Os escavadores mal foram mencionados.</segment>
    <segment id="130">Saffea sentiu-</segment>
    <segment id="131">sese excluído.</segment>
    <segment id="132">Komba Johnbull está feliz por seus filhos não sofrerem com pobreza - BBCJohnbull</segment>
    <segment id="133">, por sua vez</segment>
    <segment id="134">, gostaria de ter usado seu dinheiro de forma diferente.  "</segment>
    <segment id="135">Quando eu ganhei o dinheiro</segment>
    <segment id="136">, eu era muito jovem.</segment>
    <segment id="137">Naquela época eu só me exibia e comprava roupas e tudo mais.</segment>
    <segment id="138">Você sabe</segment>
    <segment id="139">comocomo é com os jovens.</segment>
    <segment id="140">Olhando para trás</segment>
    <segment id="141">, não me sinto bem com isso"</segment>
    <segment id="142">, diz.</segment>
    <segment id="143">"</segment>
    <segment id="144">Se eu não tivesse a ambição de viajar para o exterior na esperança de ganhar mais dinheiro lá</segment>
    <segment id="145">, teria feito muito aqui com o dinheiro desperdiçado.</segment>
    <segment id="146">"</segment>
    <segment id="147">A realidade pode não ser</segment>
    <segment id="148">comocomo eles sonharam</segment>
    <segment id="149">, masmas Johnbull agora ganha a vida fazendo esquadrias de alumínio em Freetown</segment>
    <segment id="150">, e Saffea planeja</segment>
    <segment id="151">sese juntar a ele</segment>
    <segment id="152">sese suas ambições no exterior não derem certo.</segment>
    <segment id="153">"</segment>
    <segment id="154">Meus pais não tinham onde morar quando nasci"</segment>
    <segment id="155">, diz Johnbull.</segment>
    <segment id="156">"</segment>
    <segment id="157">Meus filhos estão crescendo na casa do pai em Freetown.</segment>
    <segment id="158">Isso é muito importante.</segment>
    <segment id="159">Meus filhos não sofrerão</segment>
    <segment id="160">comocomo eu.</segment>
    <segment id="161">"</segment>
  </rst>
</analysis>