  <rst>
    <segment id="1">Rodeada por dez pessoas</segment>
    <segment id="2">, entre assessores e seguranças</segment>
    <segment id="3">, Anitta causou furor ao chegar ao Camarote N1</segment>
    <segment id="4">, na Marquês de Sapucaí</segment>
    <segment id="5">, no Rio</segment>
    <segment id="6">, na madrugada desta segunda (12).</segment>
    <segment id="7">De cara</segment>
    <segment id="8">, tratou de negar que tenha recebido uma fortuna —os rumores são de que a cantora não sai de casa por menos de R$ 1 milhão.</segment>
    <segment id="9">Anitta chega ao Camarote N1</segment>
    <segment id="10">, na Marquês de Sapucaí</segment>
    <segment id="11">, no Rio</segment>
    <segment id="12">, na madrugada desta segunda (12) - Marlene Bergamo/Folhapress  "</segment>
    <segment id="13">Gente...</segment>
    <segment id="14">Não é bem assim [risos].</segment>
    <segment id="15">Realmente</segment>
    <segment id="16">, eu saio de casa por um bom cachê</segment>
    <segment id="17">, masmas</segment>
    <segment id="18">, antes de qualquer coisa</segment>
    <segment id="19">, eu tenho que gostar.</segment>
    <segment id="20">Se gosto</segment>
    <segment id="21">, aceito</segment>
    <segment id="22">, e aí depois vamos conversar"</segment>
    <segment id="23">, afirmou.  Anitta</segment>
    <segment id="24">, que já desfilou na Mocidade Independente de Padre Miguel</segment>
    <segment id="25">comocomo musa em 2016</segment>
    <segment id="26">, diz que até gostaria de voltar a desfilar</segment>
    <segment id="27">, masmas que</segment>
    <segment id="28">, por incrível que pareça</segment>
    <segment id="29">, não recebeu convites.</segment>
    <segment id="30">Famosos e personalidades no primeiro dia de desfiles na SapucaíMais    novamente         de   de  de  representando um  "Acredita?</segment>
    <segment id="31">Nunca mais ninguém me chamou.</segment>
    <segment id="32">Gostaria</segment>
    <segment id="33">, sim, de desfilar.</segment>
    <segment id="34">Mas, como</segment>
    <segment id="35">como tudo que faço</segment>
    <segment id="36">, eu gosto de me dedicar.</segment>
    <segment id="37">Vou ter que me planejar</segment>
    <segment id="38">," afirma.</segment>
    <segment id="39">"</segment>
    <segment id="40">Mas super toparia.</segment>
    <segment id="41">"</segment>
  </rst>
