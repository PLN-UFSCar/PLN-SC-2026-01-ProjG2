  <rst>
    <segment id="1">Tyrannosaurus rex</segment>
    <segment id="2">, Velociraptor e o brasileiro Gnathovorax.</segment>
    <segment id="3">Cópias desses dinossauros em tamanho real são algumas das atrações do Aventura Jurássica</segment>
    <segment id="4">, um dos maiores parques temáticos sobre dinossauros do Brasil.</segment>
    <segment id="5">O espaço foi inaugurado no último dia 23 em Balneário Camboriú (Santa Catarina)</segment>
    <segment id="6">, com mais de 100 réplicas dos animais que</segment>
    <segment id="7">sese movimentam e produzem rugidos.</segment>
    <segment id="8">O parque fica em uma área de quase 30 mil metros quadrados e recebeu</segment>
    <segment id="9">, no primeiro fim de semana</segment>
    <segment id="10">, cerca de 5.000 visitantes</segment>
    <segment id="11">, de acordo com a empresa que administra o espaço.</segment>
    <segment id="12">Os ingressos custam a partir de R$ 49</segment>
    <segment id="13">,90 (meia).</segment>
    <segment id="14">Réplicas dos dinossauros</segment>
    <segment id="15">, como</segment>
    <segment id="16">como deste Alossauro que poderia chegar a 10 metros de comprimento</segment>
    <segment id="17">, foram feitas em tamanho natural no parque em Balneário Camboriú (SC)  - DivulgaçãoDe acordo com o Grupo Oceanic</segment>
    <segment id="18">, que investiu R$ 60 milhões no projeto</segment>
    <segment id="19">, o parque é o maior no Brasil em número de réplicas.</segment>
    <segment id="20">O Terra dos Dinos</segment>
    <segment id="21">, em Miguel Pereira (RJ)</segment>
    <segment id="22">, conta com mais de 40 modelos</segment>
    <segment id="23">, masmas tem uma área maior</segment>
    <segment id="24">, de 1</segment>
    <segment id="25">,4 milhão de metros quadrados.</segment>
    <segment id="26">Recentemente também foi lançado o Vale dos Dinossauros</segment>
    <segment id="27">, em Olímpia</segment>
    <segment id="28">, no interior de São Paulo</segment>
    <segment id="29">, com 38 réplicas.</segment>
    <segment id="30">O jornalista Gian Del Sent visitou o parque no dia da inauguração com a esposa Emanuelle e as filhas gêmeas Isadora e Rafaela</segment>
    <segment id="31">, 14.</segment>
    <segment id="32">A família curtiu algumas das atrações</segment>
    <segment id="33">, como</segment>
    <segment id="34">como arvorismo e tirolesa</segment>
    <segment id="35">, masmas ficaram encantados mesmo com os animais.</segment>
    <segment id="36">"</segment>
    <segment id="37">Desde quando assisti</segment>
    <segment id="38">Jurassic Park tenho uma fascinação pelo tema"</segment>
    <segment id="39">, contou o jornalista.</segment>
    <segment id="40">"</segment>
    <segment id="41">O que achei mais interessante no parque foi a junção de diversão e informação.</segment>
    <segment id="42">"  Chamou a atenção da família a informação estampada em uma das placas: o Velociraptor pesava apenas 20 kg.</segment>
    <segment id="43">"</segment>
    <segment id="44">Pensamos que eles tinham errado"</segment>
    <segment id="45">, disse Sent.</segment>
    <segment id="46">Isso porque</segment>
    <segment id="47">porque ele lembrava que no filme Jurassic o animal era bem maior.</segment>
    <segment id="48">Foram tirar a dúvida com um dos monitores do parque.</segment>
    <segment id="49">"</segment>
    <segment id="50">Ele foi conferir a informação e um paleontólogo veio até nós e explicou que a informação estava correta.</segment>
    <segment id="51">E ainda nos contou que o animal tinha pena.</segment>
    <segment id="52">"  Balneário Camboriú (SC) ganha parque temático com cem réplicas de dinossaurosMais    novamente         de   de  de  representando um</segment>
    <segment id="53">De acordo com André Tedesco</segment>
    <segment id="54">, paleontólogo da empresa DinOrigin</segment>
    <segment id="55">, que prestou consultoria ao parque</segment>
    <segment id="56">, o objetivo foi agregar ciência e conhecimento à diversão.</segment>
    <segment id="57">"</segment>
    <segment id="58">Criamos um ambiente pensando na evolução</segment>
    <segment id="59">, onde o visitante vai passando por todos os períodos da Era Mesozoica</segment>
    <segment id="60">, quando viveram os os dinossauros.</segment>
    <segment id="61">Ela está dividida em três períodos: Triássico [de 252 a 201 milhões de anos atrás]</segment>
    <segment id="62">, quando surgem os dinossauros</segment>
    <segment id="63">, o Jurássico [201 a 145 milhões] e o Cretáceo [145 a 66 milhões]</segment>
    <segment id="64">, quando eles foram extintos"</segment>
    <segment id="65">, disse.</segment>
    <segment id="66">Leia mais sobre dinossaurosVeja quem são os dez maiores &amp;#039</segment>
    <segment id="67">;caçadores de dinossauros&amp;#039</segment>
    <segment id="68">; conhecidosNo Dia Mundial do Dinossauro</segment>
    <segment id="69">, veja seis espécies bizarrasMary Anning</segment>
    <segment id="70">, 1ª mulher paleontóloga</segment>
    <segment id="71">, tem biografia feita há pelo menos 175 anos encontradaNova espécie de dinossauro carnívoro brasileiro homenageia &amp;#039</segment>
    <segment id="72">;deus do sexo&amp;#039</segment>
    <segment id="73">;</segment>
    <segment id="74">guaraniPaleontólogo lança guia definitivo de dinossauros brasileirosPara criar o habitat de cada período</segment>
    <segment id="75">, foram usadas plantas que pudessem lembrar a época em que os animais viveram.  Foi criada uma ambientação para separar as réplicas por período</segment>
    <segment id="76">, trazendo um pouco do habitat e da vegetação de cada momento.</segment>
    <segment id="77">"</segment>
    <segment id="78">Buscamos plantas que são parentes das daquela época"</segment>
    <segment id="79">, afirmou Tedesco.</segment>
    <segment id="80">Cada réplica é acompanhada por uma placa explicativa.</segment>
    <segment id="81">Ela informa o nome popular e científico do dinossauro</segment>
    <segment id="82">, a origem</segment>
    <segment id="83">, onde foi encontrado</segment>
    <segment id="84">, há quanto tempo viveu</segment>
    <segment id="85">, o peso e o tamanho estimado.</segment>
    <segment id="86">Há também alguma forma de comparação para o visitante ter noção de escala</segment>
    <segment id="87">, como</segment>
    <segment id="88">como um ser humano</segment>
    <segment id="89">, baleia ou girafa.</segment>
    <segment id="90">Ainda foram formados monitores</segment>
    <segment id="91">, chamados de exploradores no parque</segment>
    <segment id="92">, para prestar esclarecimentos aos visitantes.</segment>
    <segment id="93">Os dinossauros mais famosos costumam chamar a atenção</segment>
    <segment id="94">, como</segment>
    <segment id="95">como o Tiranossauro rex e o Velociraptor</segment>
    <segment id="96">, geralmente representados em filmes.</segment>
    <segment id="97">Os grandes também têm destaque.</segment>
    <segment id="98">O maior dinossauro exposto no parque é o Argentinossauro</segment>
    <segment id="99">, com cerca de 35 metros de comprimento e dez metros de altura.</segment>
    <segment id="100">Para o paleontólogo Tedesco</segment>
    <segment id="101">, no entanto</segment>
    <segment id="102">, um dos diferenciais do parque são os animais do Triássico</segment>
    <segment id="103">, período em que dinossauros surgiram.</segment>
    <segment id="104">"</segment>
    <segment id="105">O Triássico tem uma importância</segment>
    <segment id="106">, não só por ser a origem dos dinossauros</segment>
    <segment id="107">, masmas pela origem ser aqui no Brasil.</segment>
    <segment id="108">Um dos objetivos era divulgar isso".</segment>
    <segment id="109">As pesquisas mostram que os primeiros dinossauros que surgiram foram encontrados no Brasil</segment>
    <segment id="110">, em uma região do Rio Grande do Sul</segment>
    <segment id="111">, e na Argentina.</segment>
    <segment id="112">"</segment>
    <segment id="113">Os primeiros dinossauros do planeta são brasileiros.</segment>
    <segment id="114">É uma conquista nossa e conseguimos colocar no Guiness Book"</segment>
    <segment id="115">, lembrou Tedesco.</segment>
    <segment id="116">Em 2021</segment>
    <segment id="117">, o Guinness World Records reconheceu que os dinossauros mais antigos do mundo foram encontrados no Brasil.</segment>
    <segment id="118">Um desses dinossauros encontrados no Brasil e que conta com uma réplica no parque é o Gnathovorax.</segment>
    <segment id="119">"É o primeiro dinossauro predador a pisar no planeta"</segment>
    <segment id="120">, comentou Tedesco.</segment>
    <segment id="121">Foi encontrado no município de São João do Polêsine (RS) e podia chegar a 4</segment>
    <segment id="122">,5 metros de comprimento.</segment>
    <segment id="123">Seu nome significa</segment>
    <segment id="124">"</segment>
    <segment id="125">mandíbulas vorazes".  Aventura Jurássica  Local Rua Aqueduto</segment>
    <segment id="126">, 360 Estados - Balneário Camboriú (SC)  Telefone (47) 3311-7000</segment>
    <segment id="127">Ingressos R$ 99 inteira.</segment>
    <segment id="128">Gratuito para crianças até 4 anos</segment>
    <segment id="129">, mediante documentação</segment>
    <segment id="130">; R$ 49</segment>
    <segment id="131">,90 para crianças até 12 anos e idosos acima de 60 anos.</segment>
  </rst>
</analysis>