  <rst>
    <segment id="1">Prática proibida pelo STF e proposta recentemente pelo Depen (Departamento Penitenciário Nacional)</segment>
    <segment id="2">, órgão do Ministério da Justiça</segment>
    <segment id="3">, o uso de contêineres para detentos já é utilizado no Brasil na prática.</segment>
    <segment id="4">No Paraná</segment>
    <segment id="5">, existem 159 unidades para aproximadamente 2.000 presos.</segment>
    <segment id="6">Em Goiás</segment>
    <segment id="7">, foi definido que um contêiner que seria utilizado</segment>
    <segment id="8">comocomo sala de aula seria destinado para o isolamento de adolescentes presos com suspeita de contaminação pelo novo coronavírus.</segment>
    <segment id="9">O CNPCP (Conselho Nacional de Política Criminal e Penitenciária) pretende avaliar ainda nesta semanaa proposta do Depen segundo a qual presos contaminados pelo coronavírus ou com suspeita de que tenham contraído a doença seriam isolados dos demais em contêineres.</segment>
    <segment id="10">Sem a aprovação do CNPCP</segment>
    <segment id="11">, o Depen não pode levar a proposta adiante.</segment>
    <segment id="12">Contêineres para presos    novamente         de   de  de  representando um</segment>
    <segment id="13">Na composição do CNPCP há diversos juízes e advogados e</segment>
    <segment id="14">, com a proibição do STF e também do CNJ (Conselho Nacional de Justiça)</segment>
    <segment id="15">, é considerada difícil a aprovação da proposta do Depen.</segment>
    <segment id="16">Além disso</segment>
    <segment id="17">, o conselho tem sido pressionado pela reprovação pública da proposta por diversas entidades</segment>
    <segment id="18">, como</segment>
    <segment id="19">como o Ministério Público Federal</segment>
    <segment id="20">, a Defensoria Pública da União e a OAB.</segment>
    <segment id="21">No conselho</segment>
    <segment id="22">, há relatos de desconforto interno com o fato de o presidente</segment>
    <segment id="23">, Cesar Mecchi Morales</segment>
    <segment id="24">, e o vice</segment>
    <segment id="25">, Fernando Kfouri</segment>
    <segment id="26">, serem próximos de Alexandre de Moraes.</segment>
    <segment id="27">Os atritos do ministro do STF com o governo Jair Bolsonaro chegaram a um pico recentemente quando ele decidiu barrar a nomeação de Alexandre Ramagem</segment>
    <segment id="28">, amigo dos filhos do presidente</segment>
    <segment id="29">, para o cargo de diretor-geral da Polícia Federal.</segment>
    <segment id="30">Com Guilherme Seto e Mariana Carneiro</segment>
  </rst>
</analysis>