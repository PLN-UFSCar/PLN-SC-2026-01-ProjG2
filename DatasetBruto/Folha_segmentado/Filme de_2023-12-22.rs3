  <rst>
    <segment id="1">O megaconcerto da cantora Taylor Swift</segment>
    <segment id="2">, em que ela revista as dez fases de sua carreira</segment>
    <segment id="3">, passou pelo Brasil em novembro.</segment>
    <segment id="4">Antes disso</segment>
    <segment id="5">, este documentário que registra três apresentações em Inglewood</segment>
    <segment id="6">, na Califórnia</segment>
    <segment id="7">, já havia estreado no circuito nacional.</segment>
    <segment id="8">Cantora americana na estreia do filme &amp;quot</segment>
    <segment id="9">;Taylor Swift: The Eras Tour&amp;quot</segment>
    <segment id="10">;, em Los Angeles</segment>
    <segment id="11">, Califórnia - AFPO filme agora pode ser visto em casa</segment>
    <segment id="12">, com três músicas a mais: "</segment>
    <segment id="13">Long Live"</segment>
    <segment id="14">, "The Archer" e "Wildest Dreams".</segment>
    <segment id="15">Para aluguel na Amazon Prime Video</segment>
    <segment id="16">, Apple TV+</segment>
    <segment id="17">, Google Play</segment>
    <segment id="18">, Vivo Play e YouTube – livre   Eu Odeio Natal</segment>
    <segment id="19">A série italiana sobre uma mulher solteira que é pressionada pela família a levar um namorado à ceia de Natal volta para mais uma temporada.</segment>
    <segment id="20">Netflix</segment>
    <segment id="21">, 14 anos</segment>
    <segment id="22">Caldeirão com Mion  Romeo</segment>
    <segment id="23">, filho de Marcos Mion</segment>
    <segment id="24">, apresenta um número de dança ao lado de sua professora Mariana Pires.</segment>
    <segment id="25">E o quadro Caldeirola especial de Natal tem Susana Vieira na bancada.</segment>
    <segment id="26">Programa Caldeirão Mion (2023)Mais    novamente         de   de  de  representando um  Globo</segment>
    <segment id="27">, 15h50</segment>
    <segment id="28">, 10 anos</segment>
    <segment id="29">Minha Família Quer que Eu Case  Lily James faz uma jovem cineasta que decide registrar os preparativos para o casamento arranjado de um amigo de infância</segment>
    <segment id="30">, do Paquistão.</segment>
    <segment id="31">Durante o processo</segment>
    <segment id="32">, ela revê seus sentimentos por ele.</segment>
    <segment id="33">Telecine Premium</segment>
    <segment id="34">, 22h, 14 anos   Cavaleiros do Zodíaco – Saint Seya:</segment>
    <segment id="35">O Começo</segment>
    <segment id="36">Um rapaz que vive nas ruas descobre</segment>
    <segment id="37">, durante uma luta</segment>
    <segment id="38">, que tem poderes.</segment>
    <segment id="39">Mas ele ainda precisará de muitos treinamentos e sacrifícios para</segment>
    <segment id="40">sese tornar um autêntico Cavaleiro do Zodíaco.</segment>
    <segment id="41">Veja imagens de &amp;quot</segment>
    <segment id="42">;Os Cavaleiros do Zodíaco&amp;quot</segment>
    <segment id="43">;Mais    novamente         de   de  de  representando um  HBO</segment>
    <segment id="44">, 22h, 12 anos   Il Volo – Natal em Jerusalém  Formado por Gianluca Ginoble</segment>
    <segment id="45">, Ignazio Boschetto e Piero Barone</segment>
    <segment id="46">, o trio de tenores interpreta canções natalinas acompanhado pela Orquestra Filarmônica de Franciacorta.</segment>
    <segment id="47">Cultura</segment>
    <segment id="48">, 22h30</segment>
    <segment id="49">, livre</segment>
    <segment id="50">Recordar É TV</segment>
    <segment id="51">O programa homenageia o cantor e compositor Carlos Lyra</segment>
    <segment id="52">, morto há uma semana.</segment>
    <segment id="53">O tributo mescla trechos de "</segment>
    <segment id="54">Eu Sou o Show"</segment>
    <segment id="55">, de 1986</segment>
    <segment id="56">, com números musicais e entrevistas</segment>
    <segment id="57">, e do espetáculo "Carlos Lyra – 60 Anos de Bossa"</segment>
    <segment id="58">, de 2018.  TV Brasil</segment>
    <segment id="59">, 23h, livre</segment>
