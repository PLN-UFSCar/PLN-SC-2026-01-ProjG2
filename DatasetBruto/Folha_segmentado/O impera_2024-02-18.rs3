  <rst>
    <segment id="1">Difícil imaginar setor importante da atividade econômica que cresça com o dinamismo das energias limpas.</segment>
    <segment id="2">Assiste-</segment>
    <segment id="3">sese a um frenesi de investimentos</segment>
    <segment id="4">, ainda insuficientes</segment>
    <segment id="5">, porém</segment>
    <segment id="6">porém, para destravar uma transição energética capaz de conter o aquecimento global.</segment>
    <segment id="7">Só no ano passado</segment>
    <segment id="8">sese agregou o equivalente a 36 Itaipus de capacidade de geração de eletricidade por fontes de baixo carbono.</segment>
    <segment id="9">A Agência Internacional de Energia prevê que o salto de aportes deva triplicar a geração potencial por fontes limpas até 2030.  Espera-</segment>
    <segment id="10">sese que energias solar e eólica venham a ser responsáveis por 95% da expansão.</segment>
    <segment id="11">As modalidades limpas ultrapassarão o carvão mineral na geração</segment>
    <segment id="12">, alcançando 42% da matriz elétrica global.</segment>
    <segment id="13">Eis aí boa notícia para o Brasil</segment>
    <segment id="14">, que por seu clima oferece grande potencial de expansão dessas fontes.</segment>
    <segment id="15">Espera-</segment>
    <segment id="16">sese que o país mais que duplique</segment>
    <segment id="17">, até 2028</segment>
    <segment id="18">, tudo que</segment>
    <segment id="19">sese instalou delas nos últimos cinco anos.</segment>
    <segment id="20">A matriz elétrica brasileira é uma das mais limpas do planeta</segment>
    <segment id="21">, com 80% ou mais de renováveis.</segment>
    <segment id="22">O panorama muda quando</segment>
    <segment id="23">sese considera a energia total</segment>
    <segment id="24">, incluindo o setor de transportes</segment>
    <segment id="25">, o que reduz essa parcela para 45% —ainda assim notável</segment>
    <segment id="26">, diante dos quase 82% de combustíveis fósseis na matriz mundial.</segment>
    <segment id="27">Somente 23% das emissões nacionais de gases do efeito estufa provêm do consumo de energia.</segment>
    <segment id="28">Dois terços</segment>
    <segment id="29">sese originam de desmatamento e agropecuária.</segment>
    <segment id="30">O cenário mundial</segment>
    <segment id="31">, do ponto de vista da mudança do clima</segment>
    <segment id="32">, é alarmante.</segment>
    <segment id="33">Com o predomínio dos fósseis na produção de energia</segment>
    <segment id="34">, apesar de todo o investimento</segment>
    <segment id="35">, a trajetória atual não</segment>
    <segment id="36">sese mostra compatível com as metas do Acordo de Paris.</segment>
    <segment id="37">A transformação necessária</segment>
    <segment id="38">, gigantesca</segment>
    <segment id="39">, gera resistências em setores políticos e empresariais</segment>
    <segment id="40">, perspectiva que pode anuviar-</segment>
    <segment id="41">sese com a ascensão de líderes negacionistas.</segment>
    <segment id="42">Mecanismos de mercado</segment>
    <segment id="43">, valiosos</segment>
    <segment id="44">, serão insuficientes.</segment>
    <segment id="45">São imprescindíveis a ação corajosa de governos e o apoio decidido da sociedade.</segment>
    <segment id="46">Esta Folha</segment>
    <segment id="47">, que não vê alternativa à energia limpa para evitar um desastre planetário</segment>
    <segment id="48">, dá início a uma campanha por sua expansão no país</segment>
    <segment id="49">, que envolverá seminários</segment>
    <segment id="50">, novas colunas e cobertura intensiva.</segment>
    <segment id="51">editoriais@grupoflha.com.br</segment>
  </rst>
</analysis>