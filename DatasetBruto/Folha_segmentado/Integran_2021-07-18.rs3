  <rst>
    <segment id="1">Integrantes do PSD indicam a concretização da ida de Geraldo Alckmin (PSDB-SP) para o partido</segment>
    <segment id="2">comocomo imprescindível para Gilberto Kassab tirar do papel o ensaio pela candidatura presidencial do senador Rodrigo Pacheco (DEM-MG).</segment>
    <segment id="3">Parlamentares dizem que o ex-governador de São Paulo fortalece a sigla no maior colégio eleitoral e consolida estrutura com palanques nos principais estados.</segment>
    <segment id="4">A conta feita é a de que o PSD está forte em locais chaves</segment>
    <segment id="5">comocomo Bahia</segment>
    <segment id="6">, Rio, Minas</segment>
    <segment id="7">, Paraná e</segment>
    <segment id="8">, caso</segment>
    <segment id="9">caso Alckmin confirme</segment>
    <segment id="10">, SP.</segment>
    <segment id="11">O mundo político não acredita na possibilidade de uma terceira via</segment>
    <segment id="12">, no entanto.</segment>
    <segment id="13">LEIA</segment>
    <segment id="14">OUTROS ASSUNTOS ABORDADOS PELA COLUNADecisão de Moraes fixando delegado em inquérito de interferência de Bolsonaro causa imbróglio na PFInvestimentos do governo</segment>
    <segment id="15">Bolsonaro voltados às crianças caíram 33% em 2021</segment>
    <segment id="16">, diz estudoIntegrantes do PSD dizem que Alckmin é imprescindível para plano de Pacheco candidato a presidente</segment>
    <segment id="17">De saída do PSB</segment>
    <segment id="18">, deputado Rigoni é procurado por partidos para concorrer a governo do Espírito Santo Bolsonaristas veem disputa de Luciano Havan e secretário da Pesca para eleição de 2022O PSD também avança nas negociações para disputar o governo de Goiás contra Ronaldo Caiado (DEM).</segment>
    <segment id="19">O objetivo é filiar o prefeito de Aparecida de Goiânia</segment>
    <segment id="20">, Gustavo Mendanha</segment>
    <segment id="21">, que está no MDB e</segment>
    <segment id="22">sese reelegeu em 2020 com 72%.</segment>
    <segment id="23">Integrante da ala mais jovem do partido</segment>
    <segment id="24">, o deputado federal Otto Alencar Filho</segment>
    <segment id="25">, embora</segment>
    <segment id="26">embora não fale sobre o</segment>
    <segment id="27">casocaso de Pacheco</segment>
    <segment id="28">, defende a candidatura própria para 2022.</segment>
    <segment id="29">“</segment>
    <segment id="30">A gente vem tentando convencer o partido há três anos</segment>
    <segment id="31">, e acho que isso vai acontecer.</segment>
    <segment id="32">O PSD é muito forte e vai ficar mais forte ainda para ter um candidato próprio em 2022”</segment>
    <segment id="33">, disse Alencar Filho.</segment>
    <segment id="34">Em entrevista à Folha nesta sexta-feira (16)</segment>
    <segment id="35">, o presidente do Senado disse não estar fechado a “absolutamente nada”</segment>
    <segment id="36">, masmas que a mudança de partido não deve ser tratada agora.</segment>
    <segment id="37">“</segment>
    <segment id="38">Em algum momento nós vamos identificar o caminho que nós devemos seguir</segment>
    <segment id="39">para que</segment>
    <segment id="40">para que essa realidade aconteça.</segment>
    <segment id="41">Mas isso tem o momento certo”</segment>
    <segment id="42">, disse Pacheco.</segment>
    <segment id="43">Este é Rodrigo PachecoMais    novamente         de   de  de  representando</segment>
    <segment id="44">um</segment>
  </rst>
