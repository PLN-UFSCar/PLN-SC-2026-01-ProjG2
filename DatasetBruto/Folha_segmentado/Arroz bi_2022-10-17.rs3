  <rst>
    <segment id="1">A década era 1980</segment>
    <segment id="2">, e, cansado do mesmo arroz branco servido nas churrascarias</segment>
    <segment id="3">, o jornalista Tarso de Castro pediu para o maître Cecílio que incrementasse o arroz.</segment>
    <segment id="4">O maître</segment>
    <segment id="5">, por sua vez</segment>
    <segment id="6">, repassou o pedido do cliente à cozinha</segment>
    <segment id="7">, que, em pouco minutos</segment>
    <segment id="8">, entregou um arroz especial</segment>
    <segment id="9">, feito com pedaços de ovos fritos.</segment>
    <segment id="10">Thomaz Souto</segment>
    <segment id="11">, também jornalista</segment>
    <segment id="12">, que estava na mesma mesa que seu colega de trabalho</segment>
    <segment id="13">, sugeriu que adicionassem bacon e batata palha.</segment>
    <segment id="14">Arroz biro-biro</segment>
    <segment id="15">, com receita de Larissa Morales - Larissa MoralesQuando viu o resultado do prato</segment>
    <segment id="16">, Cecílio resolveu dar o nome do seu ídolo do futebol: o jogador Biro Biro.</segment>
    <segment id="17">Para ele</segment>
    <segment id="18">, a batata palha com os grãos de arroz faziam lembrar o jogador.</segment>
    <segment id="19">Desde então</segment>
    <segment id="20">, o arroz elaborado virou um sucesso.</segment>
    <segment id="21">É servido até hoje em praticamente todas as churrascarias de São Paulo.</segment>
    <segment id="22">O biro-biro é uma ótima opção para reaproveitamento de sobras —você pode usar aquele arroz feito no dia anterior para preparar essa gostosura.</segment>
    <segment id="23">Arroz biro-biro  INGREDIENTES  2 xícaras de arroz já cozido  2 colheres de sopa de azeite  100 g de bacon frito  2 ovos  1 colher de sopa de salsinha</segment>
    <segment id="24">1 colher de sopa de cebolinha  ½ xícara de batata palha  PREPARO</segment>
    <segment id="25">Frite o bacon no azeite até dourar</segment>
    <segment id="26">, acrescente o arroz cozido e misture bem.</segment>
    <segment id="27">Desligue o fogo e acrescente a salsinha</segment>
    <segment id="28">, a cebolinha e a batata palha.</segment>
    <segment id="29">Misture bem e sirva.</segment>
  </rst>
</analysis>