  <rst>
    <segment id="1">Para vencer o prêmio São Paulo de Literatura</segment>
    <segment id="2">, Ana Paula Maia deixou para trás uma relação desfavorável às mulheres: na categoria para autores com livros já publicados havia 7 escritores e 3 escritoras (apenas 30% do total).</segment>
    <segment id="3">Além de Maia (vencedora com “Enterre Seus Mortos”)</segment>
    <segment id="4">, também competiam Carola Saavedra (“</segment>
    <segment id="5">Com Armas Sonolentas”) e Martha Batalha (“</segment>
    <segment id="6">Nunca Houve um Castelo”).</segment>
    <segment id="7">Já no troféu para estreantes</segment>
    <segment id="8">, a igualdade era precisa</segment>
    <segment id="9">, com 5 homens e 5 mulheres —o prêmio ficou com Tiago Ferro (“</segment>
    <segment id="10">O Pai da Menina Morta”).</segment>
    <segment id="11">Ou seja</segment>
    <segment id="12">, dos 20 finalistas do Prêmio São Paulo</segment>
    <segment id="13">, 8 eram autoras (40%).</segment>
    <segment id="14">A escritora Ana Paula Maia</segment>
    <segment id="15">, duas vezes vencedora do Prêmio São Paulo de Literatura - Rodolfo Buhrer/DivulgaçãoEntre os 10 finalistas do Oceanos</segment>
    <segment id="16">, só 3 são mulheres:</segment>
    <segment id="17">Nara Vidal (“Sorte”)</segment>
    <segment id="18">, Djaimilia Pereira de Almeida (“Luanda</segment>
    <segment id="19">, Lisboa</segment>
    <segment id="20">, Paraíso”) e Dulce Maria Cardoso (“Eliete”).</segment>
    <segment id="21">Os demais 7 são homens.</segment>
    <segment id="22">Como o Jabuti traz mais categorias</segment>
    <segment id="23">, o que faz com que nomes possam</segment>
    <segment id="24">sese repetir</segment>
    <segment id="25">, a conta é mais complexa.</segment>
    <segment id="26">Mas, entre os finalistas em livros de contos</segment>
    <segment id="27">, há 4 homens e 1 mulher (20%).</segment>
    <segment id="28">Nos romances</segment>
    <segment id="29">, são duas escritoras (40%).</segment>
    <segment id="30">A situação</segment>
    <segment id="31">sese inverte</segment>
    <segment id="32">, porém</segment>
    <segment id="33">porém, em crônica e poesia —cada uma traz 2 homens e 3 mulheres (60%).</segment>
    <segment id="34">Livro &amp;#039</segment>
    <segment id="35">;Lute como</segment>
    <segment id="36">como uma Princesa&amp;#039</segment>
    <segment id="37">; refaz contos de fadas   novamente         de   de  de  representando um  FEMINISMO Boitatá</segment>
    <segment id="38">, o selo infantil da Boitempo</segment>
    <segment id="39">, lança ainda neste ano “Lute</segment>
    <segment id="40">comocomo uma Princesa”</segment>
    <segment id="41">, de Vita Murrow e Julia Bereciartu</segment>
    <segment id="42">, que recria a história de 15 contos de fadas clássicos —entre eles</segment>
    <segment id="43">, “</segment>
    <segment id="44">A Bela Adormecida”</segment>
    <segment id="45">, “Rapunzel” e “</segment>
    <segment id="46">A Pequena Sereia”.</segment>
    <segment id="47">Cada uma dá novos ares e aspirações às princesas</segment>
    <segment id="48">, que não</segment>
    <segment id="49">sese limitam a procurar um príncipe encantado para chamar de seu.  NAÇÃO ZUMBI</segment>
    <segment id="50">Natalia Borges Polesso</segment>
    <segment id="51">, Marcelo Ferroni</segment>
    <segment id="52">, Luisa Geisler e Samir Machado preparam para 2020 um livro escrito a oito mãos:</segment>
    <segment id="53">“Corpos Secos”</segment>
    <segment id="54">, no qual cinco personagens narram uma invasão zumbi no Brasil.</segment>
    <segment id="55">O título vai sair pela Alfaguara.</segment>
    <segment id="56">EU SOZINHO Marcadas para 18 de novembro</segment>
    <segment id="57">, as eleições para o comando da Libre</segment>
    <segment id="58">, a Liga Brasileira de Editoras</segment>
    <segment id="59">, tiveram só uma chapa inscrita.</segment>
    <segment id="60">O grupo é encabeçado por Tomaz Adour</segment>
    <segment id="61">, da editora Vermelho Marinho</segment>
    <segment id="62">, e Lizandra Magon de Almeida</segment>
    <segment id="63">, da Pólen</segment>
    <segment id="64">, e deve começar a nova gestão a partir de 2 de janeiro de 2020.</segment>
    <segment id="65">Atualmente são mais de 150 editoras associadas.</segment>
    <segment id="66">RIO, SÃO PAULO O jornalista e escritor Claufe Rodrigues publica o livro de poemas “Avdavida” (ed. Carolina).</segment>
    <segment id="67">O lançamento ocorre na quarta-feira (13) na Livraria da Travessa do shopping Leblon</segment>
    <segment id="68">, no Rio de Janeiro</segment>
    <segment id="69">, e, no dia 5 de dezembro</segment>
    <segment id="70">, no Patuscada</segment>
    <segment id="71">, em São Paulo.</segment>
  </rst>
</analysis>