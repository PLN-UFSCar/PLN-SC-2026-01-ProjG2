  <rst>
    <segment id="1">Mesmo sem ser escalado para a partida contra o Rayo Vallecano</segment>
    <segment id="2">, Vinicius Junior pisou no gramado do estádio Santiago Bernabéu</segment>
    <segment id="3">, nesta quarta-feira (24)</segment>
    <segment id="4">, para saudar os torcedores que o homenageavam.</segment>
    <segment id="5">Apesar de ter a suspensão rescindida pela Real Federação Espanhola</segment>
    <segment id="6">, o atacante do Real Madrid não atuou por causa de dores no joelho.</segment>
    <segment id="7">Faixa de apoio a Vinicius Junior antes da partida entre Real Madrid e Rayo Vallecano - Javier Soriano/AFP</segment>
    <segment id="8">A partida foi marcada por homenagens ao brasileiro.</segment>
    <segment id="9">Todo o público do estádio</segment>
    <segment id="10">sese levantou para aplaudir o atleta no minuto 20</segment>
    <segment id="11">, número da camisa usada por ele.</segment>
    <segment id="12">Em um camarote</segment>
    <segment id="13">, ele agradeceu o apoio.</segment>
    <segment id="14">Na entrada em campo</segment>
    <segment id="15">, todos os jogadores do Real Madrid usavam o número 20.</segment>
    <segment id="16">Uma faixa foi estendida atrás de um dos gols com a mensagem em espanhol: "Vinicius somos todos.</segment>
    <segment id="17">Basta agora!</segment>
    <segment id="18">".</segment>
    <segment id="19">Vários torcedores levaram cartazes de apoio a ele.</segment>
    <segment id="20">O confronto terminou com vitória do time da casa por 2 a 1</segment>
    <segment id="21">, gols de Benzema e Rodrygo.</segment>
    <segment id="22">Ao comemorar o seu gol</segment>
    <segment id="23">, o atacante brasileiro ergueu o braço</segment>
    <segment id="24">, com o punho fechado</segment>
    <segment id="25">, em um gesto característico da luta contra o racismo.</segment>
    <segment id="26">Vinicius Junior reclamou de ter sido insultado e chamado de "macaco" durante o jogo entre Real e Valencia</segment>
    <segment id="27">, que chegou a ser interrompido pela arbitragem no último domingo (21).</segment>
    <segment id="28">Estes ataques levaram a Procuradoria a abrir uma investigação por "crime de ódio"</segment>
    <segment id="29">, categoria penal que</segment>
    <segment id="30">, na Espanha</segment>
    <segment id="31">, inclui crimes raciais.</segment>
    <segment id="32">Vinicius Junior reage a novo ato de racismoMais    novamente         de   de  de  representando um</segment>
    <segment id="33">É a 10ª vez que o brasileiro sofre ataques de cunho racial nos últimos dois anos.</segment>
    <segment id="34">Sete torcedores foram presos pela polícia espanhola.</segment>
    <segment id="35">Três deles relacionados às ofensas do último domingo.</segment>
    <segment id="36">Após depoimento</segment>
    <segment id="37">, eles foram liberados.</segment>
  </rst>
