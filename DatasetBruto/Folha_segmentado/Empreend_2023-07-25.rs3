  <rst>
    <segment id="1">Os donos da Villa Parnaíba Mall</segment>
    <segment id="2">, um pequeno negócio prestes a ser inaugurado no interior do Piauí</segment>
    <segment id="3">, tentaram ingressar</segment>
    <segment id="4">comocomo interessados no processo entre as gigantes Ambev e Heineken no Cade (Conselho Administrativo de Defesa Econômica).</segment>
    <segment id="5">Nesse caso</segment>
    <segment id="6">caso, a Heineken acusa a Ambev de quebrar regras da livre iniciativa ao impor</segment>
    <segment id="7">, via distribuidores</segment>
    <segment id="8">, contratos de exclusividade com bares</segment>
    <segment id="9">, restaurantes e casas de espetáculos.</segment>
    <segment id="10">A Heineken é uma das maiores empresas de cerveja do mundo - Paulo Whitaker - 12.jun.2018/ReutersFrancisco Dantas</segment>
    <segment id="11">, um dos donos do Villa Parnaíba</segment>
    <segment id="12">, acusa a Heineken de ter feito a mesma coisa ao impor exclusividade.</segment>
    <segment id="13">Com a recusa do Cade</segment>
    <segment id="14">, ele cogita ir à Justiça.</segment>
    <segment id="15">Por telefone</segment>
    <segment id="16">, ele afirmou à coluna que a Heineken é a única cervejaria na região.</segment>
    <segment id="17">Disse que a Petrópolis fechou um depósito por não conseguir competir com as grandes empresas e que a "Brahma (sic) está praticamente aniquilada".</segment>
    <segment id="18">"</segment>
    <segment id="19">Pedimos um contrato de parceria em infraestrutura com a Heineken</segment>
    <segment id="20">, masmas eles queriam que comprássemos cerveja para ter o apoio do marketing.</segment>
    <segment id="21">Queríamos cobrir as tendas de circulação e a praça de alimentação</segment>
    <segment id="22">, sem a exclusividade das cervejas"</segment>
    <segment id="23">, disse Dantas.  "</segment>
    <segment id="24">A Heineken enrolou por quatro meses.</segment>
    <segment id="25">Nesse meio tempo</segment>
    <segment id="26">, eles fecharam com uma empresa criada depois da nossa</segment>
    <segment id="27">, da filha de um sócio distribuidor</segment>
    <segment id="28">, e montaram o bar para ela"</segment>
    <segment id="29">, afirma o empresário.</segment>
    <segment id="30">A primeira pilsen do mundoMais    novamente         de   de  de  representando um  Dantas diz ter feito uma denúncia à Heineken contra o distribuidor que ele afirma ter beneficiado seu concorrente na cidade.</segment>
    <segment id="31">Pediu confidencialidade para evitar um conflito direto.</segment>
    <segment id="32">Porém, a cervejaria revelou seu nome</segment>
    <segment id="33">, infringindo o próprio código de conduta empresarial.</segment>
    <segment id="34">"</segment>
    <segment id="35">A Heineken mandou essa denúncia para o distribuidor"</segment>
    <segment id="36">, disse Dantas.</segment>
    <segment id="37">"Estou no Piauí e aqui é risca faca</segment>
    <segment id="38">, foi uma sacanagem deles.</segment>
    <segment id="39">"</segment>
    <segment id="40">Após o episódio</segment>
    <segment id="41">, a Villa Parnaíba Mall acionou o Cade com o objetivo de "ampliar para o país uma investigação sobre potencialidade econômica de exclusividade".</segment>
    <segment id="42">O Cade rejeitou o pedido duas vezes.</segment>
    <segment id="43">O órgão afirma que a empresa não demonstrou relação de nexo e causalidade</segment>
    <segment id="44">para que</segment>
    <segment id="45">para que ingressasse no processo.</segment>
    <segment id="46">"</segment>
    <segment id="47">Não vamos prosseguir</segment>
    <segment id="48">, porque</segment>
    <segment id="49">porque estamos com medo de levar alguma multa e comprometer o negócio.</segment>
    <segment id="50">Mas estamos avaliando uma ação na Justiça</segment>
    <segment id="51">, levantando esse debate sobre o contrato de comodato.</segment>
    <segment id="52">"</segment>
    <segment id="53">Procurada</segment>
    <segment id="54">, a Heineken disse que a decisão do Cade "reforça que o pleito carece de qualquer fundamento jurídico".</segment>
    <segment id="55">Com Diego</segment>
    <segment id="56">Felix e</segment>
    <segment id="57">Stéfanie</segment>
    <segment id="58">Rigamonti</segment>
  </rst>
</analysis>