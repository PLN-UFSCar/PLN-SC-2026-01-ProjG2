  <rst>
    <segment id="1">Sempre fui fascinada pela culinária japonesa e</segment>
    <segment id="2">, quando experimentei o okonomiyaki —uma panqueca preparada com muito repolho—</segment>
    <segment id="3">, quis logo saber a receita.</segment>
    <segment id="4">Eu era adolescente</segment>
    <segment id="5">, estava na casa de uma amiga de ascendência nipônica e arranquei risadas da família toda com a minha pergunta.</segment>
    <segment id="6">Colunas e BlogsReceba no seu email uma seleção de colunas e blogs da Folha</segment>
    <segment id="7">; exclusiva para assinantes.</segment>
    <segment id="8">Carregando...</segment>
    <segment id="9">Não há receita.</segment>
    <segment id="10">Ovos, farinha</segment>
    <segment id="11">, muito repolho</segment>
    <segment id="12">, cará e o que mais você quiser incluir na panqueca.</segment>
    <segment id="13">Foi basicamente essa a resposta que recebi.</segment>
    <segment id="14">Era o início dos anos 2000</segment>
    <segment id="15">, vivíamos o auge dos rodízios japoneses</segment>
    <segment id="16">, e o okonomiyaki não tinha espaço entre as barcas lotadas de sushi de morango com cream cheese.</segment>
    <segment id="17">O prato é bastante popular e</segment>
    <segment id="18">, no Japão</segment>
    <segment id="19">, há casas de okonomiyaki</segment>
    <segment id="20">, nas quais os clientes recebem na mesa a massa pronta da panqueca</segment>
    <segment id="21">, os molhos e</segment>
    <segment id="22">sese aventuram na chapa quente.</segment>
    <segment id="23">É, portanto</segment>
    <segment id="24">, um prato de simples execução.</segment>
    <segment id="25">O primeiro-ministro britânico</segment>
    <segment id="26">, Rishi Sunak (ao centro) e jornalistas aprendem a fazer okonomiyaki em restaurante em Hiroshima durante o encontro do G&amp;amp</segment>
    <segment id="27">; - Stefan Rousseau - 20.mai.23/Pool via AFPTradicionalmente</segment>
    <segment id="28">, o okonomiyaki leva o tubérculo yamaimo</segment>
    <segment id="29">, que no Brasil foi substituído pelo cará devido à sua imagem e semelhança.</segment>
    <segment id="30">Cará e repolho</segment>
    <segment id="31">, esses dois vegetais</segment>
    <segment id="32">, são as estrelas da panqueca japonesa</segment>
    <segment id="33">; os demais ingredientes são estruturantes e podem ser facilmente substituídos no preparo de uma versão 100% vegetal dessa iguaria.</segment>
    <segment id="34">Os ovos cedem espaço à farinha de grão-de-bico</segment>
    <segment id="35">, que, quando misturada com água</segment>
    <segment id="36">, forma sob o calor da frigideira uma massa com textura semelhante à da omelete.</segment>
    <segment id="37">O sabor da gema do ovo pode ser representado pelo kala namak (sal negro do Himalaia)</segment>
    <segment id="38">, masmas isso é um detalhe em nada necessário à execução da receita.</segment>
    <segment id="39">Para quem quiser substituir a farinha de trigo</segment>
    <segment id="40">, minha sugestão é usar farinha de arroz e tapioca.</segment>
    <segment id="41">A farinha de arroz dá estrutura à massa</segment>
    <segment id="42">, enquanto a tapioca atua</segment>
    <segment id="43">comocomo um agente unificador dos ingredientes</segment>
    <segment id="44">, função que seria exercida pelo glúten do trigo.</segment>
    <segment id="45">Okonomiyaki vegano feito a partir de receita de Luisa Mafei - Luisa MafeiConfesso que fugi um pouco à tradição na receita do molho</segment>
    <segment id="46">, que se</segment>
    <segment id="47">se assemelha a um molho barbecue e no Japão é vendido pronto.</segment>
    <segment id="48">No Brasil não encontramos esse molho pronto em supermercados.</segment>
    <segment id="49">Aprendi com a Marisa</segment>
    <segment id="50">Ono uma substituição fácil: uma mistura de ketchup</segment>
    <segment id="51">, mostarda</segment>
    <segment id="52">, molho de soja</segment>
    <segment id="53">, maionese e molho inglês (atenção à lista de ingredientes</segment>
    <segment id="54">, que pode conter anchova e/ou extrato de carne).</segment>
    <segment id="55">A receita do molho?</segment>
    <segment id="56">Não tem receita</segment>
    <segment id="57">, masmas vale a intuição.</segment>
    <segment id="58">PANQUECA JAPONESA (OKONOMIYAKI)</segment>
    <segment id="59">Rendimento: 3 panquecas.</segment>
    <segment id="60">Ingredientes  ½ xícara de farinha de grão de bico  ¼ xícara de farinha de arroz  ¼ xícara de tapioca  2 colheres de chá de fermento  1 xícara de água  200 g de repolho  100 g de cará  2 dentes de alho  4 ramas de cebolinha  1 colher de chá de sal  Pimenta preta</segment>
    <segment id="61">, a gosto  Óleo neutro ou azeite</segment>
    <segment id="62">, o quanto baste  Preparo    Misture a farinha de grão-de-bico com a farinha de arroz</segment>
    <segment id="63">, a tapioca</segment>
    <segment id="64">, a água</segment>
    <segment id="65">, o fermento e o sal numa tigela grande até dissolver todos os grumos.</segment>
    <segment id="66">Corte finamente o repolho e adicione na tigela.</segment>
    <segment id="67">Corte a cebolinha em rodelas</segment>
    <segment id="68">, adicione na tigela e misture bem.</segment>
    <segment id="69">Aqueça uma frigideira antiaderente com um fio de óleo e despeje uma concha da massa no centro da frigideira.</segment>
    <segment id="70">Com a ajuda de uma espátula</segment>
    <segment id="71">, acerte os contornos do círculo da panqueca.</segment>
    <segment id="72">Quando estiver bem cozida de um lado</segment>
    <segment id="73">, vire e cozinhe do outro.    MOLHO  Ingredientes  2 colheres de sopa de óleo neutro  2 colheres de sopa de suco de limão  1 colher de chá de melado de cana  1 colher de sopa de molho de soja  ½ colher de chá de pimenta em flocos  1 colher de chá de gengibre gengibre ralado  Preparo</segment>
    <segment id="74">Misture todos os ingredientes e sirva a seguir</segment>
    <segment id="75">, por cima e ao lado das panquecas.</segment>
  </rst>
</analysis>