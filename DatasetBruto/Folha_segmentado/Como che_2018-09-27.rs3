  <rst>
    <segment id="1">Localizado na região norte do Chile</segment>
    <segment id="2">, o Deserto do Atacama é conhecido</segment>
    <segment id="3">comocomo o mais seco da Terra.</segment>
    <segment id="4">A cidade de San Pedro de Atacama é a base para explorá-lo.</segment>
    <segment id="5">​O que fazer:</segment>
    <segment id="6">Há passeios que partem de San Pedro de Atacama</segment>
    <segment id="7">, organizados por agências de turismo.</segment>
    <segment id="8">Os principais são o Vale da Lua</segment>
    <segment id="9">, o Vale da Morte</segment>
    <segment id="10">, Salar de Atacama</segment>
    <segment id="11">, as Lagunas Altiplánicas e Piedras Rojas</segment>
    <segment id="12">, o Salar de Tara e os Geysers de Tatio.</segment>
    <segment id="13">Como chegar: San Pedro de Atacama fica a 1.600 km de Santiago.</segment>
    <segment id="14">O aeroporto que serve a região é o de Calama.</segment>
    <segment id="15">Não há voos diretos do Brasil para lá:</segment>
    <segment id="16">é necessário fazer conexão em Santiago.</segment>
    <segment id="17">A partir de Santiago</segment>
    <segment id="18">, são duas horas de voo.</segment>
    <segment id="19">Após o desembarque em Calama há mais um trecho</segment>
    <segment id="20">, de 100 km</segment>
    <segment id="21">, até chegar a San Pedro de Atacama.</segment>
    <segment id="22">A opção mais barata é ir de ônibus convencional (3.000 pesos ou cerca de R$ 18)</segment>
    <segment id="23">, masmas também é a mais cansativa.</segment>
    <segment id="24">O mais confortável e rápido é o transfer (a partir de 9.000 pesos ou R$ 55).  Moeda: Peso chileno.</segment>
    <segment id="25">Nesta quarta-feira (26)</segment>
    <segment id="26">, R$ 1 equivalia a 163 pesos.</segment>
    <segment id="27">Confira o que fazer nos 50 destinos eleitos pelo júri de Turismo:</segment>
    <segment id="28">​</segment>
  </rst>
