  <rst>
    <segment id="1">O cineasta Rodrigo García</segment>
    <segment id="2">, filho do escritor Gabriel García Márquez</segment>
    <segment id="3">, é radicado há décadas nos Estados Unidos e tem extensa filmografia em inglês.</segment>
