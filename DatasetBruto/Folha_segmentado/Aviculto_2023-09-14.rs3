  <rst>
    <segment id="1">Quando o avicultor Rubens Braz começou a criar galinhas</segment>
    <segment id="2">comocomo um hobby</segment>
    <segment id="3">, ele não tinha ideia do tamanho que a operação —ou as aves— alcançaria.</segment>
    <segment id="4">Cerca de 20 anos depois</segment>
    <segment id="5">, ele agora cria galos gigantes na região central do Brasil</segment>
    <segment id="6">, negócio de pequena escala que está ganhando força com o aumento das vendas em todo o país.</segment>
    <segment id="7">Denominados "Índios Gigantes"</segment>
    <segment id="8">, os galos podem medir mais de 1</segment>
    <segment id="9">,20 metro de altura.</segment>
    <segment id="10">O agrônomo Rubens Braz posa ao lado de seu galo Índio Gigante Urubu chamado Galalau na Avicultura Gigante</segment>
    <segment id="11">, que cria galos gigantes para produção de carne em pequena escala e para fins ornamentais</segment>
    <segment id="12">, em Formosa (GO) - Ueslei Marcelino - 1.set.2023/ReutersAs aves gigantescas</segment>
    <segment id="13">, que estão aguardando o reconhecimento formal</segment>
    <segment id="14">comocomo uma nova raça</segment>
    <segment id="15">, podem valer R$ 20 mil cada</segment>
    <segment id="16">, disse Braz</segment>
    <segment id="17">, diante do interesse de centenas de criadores no país.  "</segment>
    <segment id="18">No início</segment>
    <segment id="19">, era um hobby"</segment>
    <segment id="20">, disse ele em uma entrevista em uma de suas granjas no estado de Goiás.</segment>
    <segment id="21">"</segment>
    <segment id="22">Depois</segment>
    <segment id="23">, outros criadores</segment>
    <segment id="24">sese interessaram e hoje temos uma operação comercial.</segment>
    <segment id="25">"  Sua empresa</segment>
    <segment id="26">, chamada Avicultura Gigante</segment>
    <segment id="27">, ainda é uma empresa de nicho no Brasil</segment>
    <segment id="28">, o maior exportador de carne de frango do mundo e sede de grandes frigoríficos</segment>
    <segment id="29">, incluindo a BRF e a JBS.</segment>
    <segment id="30">Como a crise global da gripe aviária prejudicou os negócios neste ano</segment>
    <segment id="31">, limitando o transporte de animais vivos à medida que o Brasil busca evitar o aparecimento da doença em granjas comerciais</segment>
    <segment id="32">, Braz disse que</segment>
    <segment id="33">sese concentrou no fornecimento de ovos produzidos para fazendeiros próximos.</segment>
    <segment id="34">Suas próprias granjas abrigam cerca de 300 aves.</segment>
    <segment id="35">Avicultor brasileiro cria galos gigantes que podem valer R$ 20 milMais    novamente         de   de  de  representando um  Embora isso não seja suficiente para atender ao setor de carnes</segment>
    <segment id="36">, ele disse que há muita demanda por parte de colecionadores e fazendeiros que buscam reforçar seus lotes de galinhas caipiras</segment>
    <segment id="37">, ou animais sem gaiolas criados em pequenas propriedades principalmente para fins de subsistência.</segment>
    <segment id="38">Segundo informação do site da empresa</segment>
    <segment id="39">, o Índio Gigante é o resultado do cruzamento de aves caipiras com raças combatentes.</segment>
    <segment id="40">"</segment>
    <segment id="41">São rústicos</segment>
    <segment id="42">, bons produtores de carne e ovos"</segment>
    <segment id="43">, diz, destacando que a espécie é indicada também para cruzamento com outras raças para melhoramento de um plantel.</segment>
    <segment id="44">Folha MercadoReceba no seu email o que de mais importante acontece na economia</segment>
    <segment id="45">; aberta para não assinantes.</segment>
    <segment id="46">Carregando...</segment>
  </rst>
