  <rst>
    <segment id="1">O técnico da Sérvia</segment>
    <segment id="2">, Dragan Stojkovic</segment>
    <segment id="3">, descartou os rumores de que o Brasil espionou seus treinos usando um drone</segment>
    <segment id="4">, dizendo nesta quarta-feira (23) que a superpotência sul-americana não ganharia nada com as filmagens de seus treinos.</segment>
    <segment id="5">Brasil e Sérvia têm treinado nas instalações do Al Arabi em Doha</segment>
    <segment id="6">, com as bases das equipes situadas em ambos os lados da estrada.</segment>
    <segment id="7">"</segment>
    <segment id="8">Eu não acredito que eles nos assistiram.</segment>
    <segment id="9">Quem somos nós para eles nos assistirem?</segment>
    <segment id="10">Eles são uma superpotência do futebol"</segment>
    <segment id="11">, disse Stojkovic antes da estreia do Grupo G no Lusail Stadium nesta quinta (24).</segment>
    <segment id="12">Dragan Stojkovic observa atividade física de sua seleção</segment>
    <segment id="13">; o técnico sérvio não acredita que o Brasil tenha filmado seus treinos com um drone - Andrej Isakovic/AFP"Acho que é desinformação.</segment>
    <segment id="14">E mesmo que fosse um drone</segment>
    <segment id="15">, não sei o que teriam visto</segment>
    <segment id="16">, nada de especial"</segment>
    <segment id="17">, brincou.</segment>
    <segment id="18">O favorito da Copa do Mundo</segment>
    <segment id="19">, o Brasil</segment>
    <segment id="20">, tem uma variedade de talentos de ataque à sua disposição</segment>
    <segment id="21">, masmas Stojkovic disse que não vai fugir do desafio de enfrentar o pentacampeão.</segment>
    <segment id="22">O técnico da seleção brasileira</segment>
    <segment id="23">, Tite</segment>
    <segment id="24">, ampliou sua equipe com nove atacantes liderados por Neymar</segment>
    <segment id="25">, que pode ultrapassar Pelé</segment>
    <segment id="26">comocomo o maior artilheiro de todos os tempos do país</segment>
    <segment id="27">sese marcar mais três gols para adicionar à sua contagem de 75.</segment>
    <segment id="28">"</segment>
    <segment id="29">Será que quatro atacantes vão jogar contra a Sérvia?</segment>
    <segment id="30">Então acabamos...</segment>
    <segment id="31">Mas alguém vai jogar na defesa?</segment>
    <segment id="32">" disse Stojkovic.</segment>
    <segment id="33">Confira o treino da seleção brasileira Mais    novamente         de   de  de  representando um  "</segment>
    <segment id="34">O Brasil é um grande time</segment>
    <segment id="35">, um dos melhores do mundo.</segment>
    <segment id="36">Para mim</segment>
    <segment id="37">, eles têm uma geração de ouro neste momento e espero um jogo muito difícil...</segment>
    <segment id="38">O jogo começa em 0 a 0</segment>
    <segment id="39">, temos chances de vencer e não temos medo de ninguém</segment>
    <segment id="40">, nem mesmo do Brasil.</segment>
    <segment id="41">Temos jogadores mais maduros</segment>
    <segment id="42">, confiantes e com a experiência de ter disputado uma Copa do Mundo.</segment>
    <segment id="43">É um novo desafio.</segment>
    <segment id="44">"  Ele</segment>
    <segment id="45">, no entanto</segment>
    <segment id="46">, acrescentou que tiveram "muito azar" por serem sorteados no mesmo grupo que Brasil</segment>
    <segment id="47">, Suíça e Camarões.</segment>
    <segment id="48">"</segment>
    <segment id="49">O Brasil é um grande time</segment>
    <segment id="50">, individual e coletivamente.</segment>
    <segment id="51">Eles são</segment>
    <segment id="52">, com certeza</segment>
    <segment id="53">, um dos favoritos"</segment>
    <segment id="54">, disse o capitão Dusan Tadic.</segment>
    <segment id="55">"</segment>
    <segment id="56">Mas estamos focados em nós mesmos</segment>
    <segment id="57">, vamos olhar para as qualidades do Brasil</segment>
    <segment id="58">, masmas também vamos focar nas nossas qualidades</segment>
    <segment id="59">, queremos deixar nosso país orgulhoso e jogar nosso estilo de futebol.</segment>
    <segment id="60">"</segment>
    <segment id="61">Copa</segment>
    <segment id="62">2022Um guia diário no email com o que você precisa saber sobre o Mundial no Qatar.</segment>
    <segment id="63">Carregando...</segment>
    <segment id="64">A Sérvia tem suado com a disponibilidade do artilheiro Aleksandar Mitrovic depois que ele sofreu uma lesão no tornozelo</segment>
    <segment id="65">, masmas Stojkovic</segment>
    <segment id="66">, que se</segment>
    <segment id="67">se recusou a revelar sua escalação</segment>
    <segment id="68">, disse que o atacante está treinando com a equipe.  "</segment>
    <segment id="69">A boa notícia é que ele não está sentindo dor onde sofreu uma lesão"</segment>
    <segment id="70">, disse ele.</segment>
    <segment id="71">"Mas (Filip) Kostic está lesionado</segment>
    <segment id="72">, sente cansaço no músculo.</segment>
    <segment id="73">É um grande ponto de interrogação quando</segment>
    <segment id="74">sese trata dele.</segment>
    <segment id="75">"</segment>
