  <rst>
    <segment id="1">A atriz Riley Keough</segment>
    <segment id="2">, filha da cantora Lisa Marie Presley</segment>
    <segment id="3">, morta em janeiro do ano passado</segment>
    <segment id="4">, diz que está sendo cobrada por dívidas que eram de sua mãe.</segment>
    <segment id="5">Segundo o site TMZ</segment>
    <segment id="6">, Lisa Marie comprou uma mansão de 11 quartos por meio de um empréstimo bancário.</segment>
    <segment id="7">O banco</segment>
    <segment id="8">, porém</segment>
    <segment id="9">porém, afirma que ela não teria pagado a dívida</segment>
    <segment id="10">, que agora está em US$ 1</segment>
    <segment id="11">,6 milhão (R$ 7</segment>
    <segment id="12">,9 milhões).  Lisa Marie Presley</segment>
    <segment id="13">, morta no ano passado -Chris Delmas / AFPA instituição estaria cobrando esse valor de Riley Keough</segment>
    <segment id="14">, que administra o patrimônio da mãe.</segment>
    <segment id="15">Ela, porém</segment>
    <segment id="16">porém, alega que o prazo para o banco cobrar a quantia teria acabado.</segment>
    <segment id="17">Filha única do cantor Elvis Presley</segment>
    <segment id="18">, Lisa Marie morreu após ser levada ao hospital em razão de problemas cardíacos.</segment>
    <segment id="19">O médico legista listou a causa da morte</segment>
    <segment id="20">comocomo "sequelas de obstrução do intestino delgado".</segment>
    <segment id="21">"</segment>
    <segment id="22">A obstrução estava na forma de um intestino delgado estrangulado causado por aderências que</segment>
    <segment id="23">sese desenvolveram após uma cirurgia bariátrica anos atrás"</segment>
    <segment id="24">, disse o legista em um relatório.</segment>
    <segment id="25">"</segment>
    <segment id="26">Esta é uma complicação conhecida a longo prazo deste tipo de cirurgia.</segment>
    <segment id="27">"  Lisa Marie PresleyMais    novamente         de   de  de  representando um</segment>
    <segment id="28">O legista afirmou que ela também tinha um histórico de supermedicação em que</segment>
    <segment id="29">, esquecendo-</segment>
    <segment id="30">sese de ter tomado a medicação prescrita</segment>
    <segment id="31">, repetia as doses.</segment>
    <segment id="32">O relatório toxicológico mostrou que ela tinha "níveis terapêuticos" de oxicodona e outros medicamentos no sangue que não foram considerados fatores contribuintes.</segment>
  </rst>
