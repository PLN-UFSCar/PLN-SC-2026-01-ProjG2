  <rst>
    <segment id="1">Muitas cidades voltarão a ter desfiles em comemoração à independência do Brasil depois de dois anos de restrições devido à pandemia.</segment>
    <segment id="2">Em São Paulo</segment>
    <segment id="3">, cerca de 10 mil pessoas devem desfilar na avenida Dom Pedro 1º</segment>
    <segment id="4">, na zona sul</segment>
    <segment id="5">, e em Brasília são esperadas 280 mil pessoas para assistir à celebração.</segment>
    <segment id="6">A expectativa é a de que os atos</segment>
    <segment id="7">sese misturem a manifestações políticas</segment>
    <segment id="8">, especialmente em Brasília e no Rio de Janeiro</segment>
    <segment id="9">, onde o presidente Jair Bolsonaro (PL) estará pela manhã e à tarde</segment>
    <segment id="10">, respectivamente.</segment>
    <segment id="11">O candidato à reeleição deve ter pelo menos três estruturas montadas para possíveis discursos.</segment>
    <segment id="12">Bolsonaro está convocando seus apoiadores para o 7 de Setembro desde julho.</segment>
    <segment id="13">No ano passado</segment>
    <segment id="14">, o evento serviu para o presidente atacar o STF (Supremo Tribunal Federal) e os ministros da corte.</segment>
    <segment id="15">Comemoração dos 196 anos da Independência do Brasil</segment>
    <segment id="16">, em São Paulo - Danilo Verpa - 7.set.18/FolhapressEm Porto Alegre</segment>
    <segment id="17">, o evento cívico oficial</segment>
    <segment id="18">, com militares</segment>
    <segment id="19">, policiais e outros órgãos</segment>
    <segment id="20">, acontecerá na avenida Edvaldo Pereira Paiva</segment>
    <segment id="21">, em frente ao Lago Guaíba.</segment>
    <segment id="22">Apoiadores de Bolsonaro estão organizando uma manifestação náutica ao mesmo tempo</segment>
    <segment id="23">, às 10h</segment>
    <segment id="24">, com embarcações que deverão passar ao lado do desfile</segment>
    <segment id="25">, no sentido inverso.</segment>
    <segment id="26">À tarde</segment>
    <segment id="27">, às 14h</segment>
    <segment id="28">, acontecerá uma manifestação favorável ao presidente em um dos sentidos da avenida Goethe</segment>
    <segment id="29">, em frente ao Parcão</segment>
    <segment id="30">, com trio elétrico e comício.</segment>
    <segment id="31">Também há atos previstos para outras capitais brasileiras</segment>
    <segment id="32">, como</segment>
    <segment id="33">como Belo Horizonte</segment>
    <segment id="34">, Curitiba</segment>
    <segment id="35">, Recife e Salvador.    São Paulo</segment>
    <segment id="36">Cerca de 10 mil pessoas</segment>
    <segment id="37">, entre civis e militares</segment>
    <segment id="38">, desfilarão na pista central da av. Dom Pedro 1º   7h30 - apresentação da banda sinfônica do Exército 8h - hasteamento da bandeira 8h40 - execução do hino da Independência 8h45 - desfile 12h30 - salto de paraquedistas do Exército   Bloqueios das 22h de terça-feira (6) até as 14h de quarta-feira (7) afetarão as seguintes vias:</segment>
    <segment id="39">Praça do Monumento av. Dom Pedro 1º</segment>
    <segment id="40">r.</segment>
    <segment id="41">Leais Paulistanos</segment>
