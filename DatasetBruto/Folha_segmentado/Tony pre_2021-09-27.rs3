  <rst>
    <segment id="1">O musical "Moulin Rouge!</segment>
    <segment id="2">" e a peça sobre Aids "The Inheritance" foram os grande vencedores do prêmio Tony</segment>
    <segment id="3">, o maior do teatro americano</segment>
    <segment id="4">, em cerimônia realizada neste domingo (26).</segment>
    <segment id="5">O evento recompensou as produções da temporada 2019-2020</segment>
    <segment id="6">, interrompida em março do ano passado pela pandemia de Covid e só retomada agora</segment>
    <segment id="7">, 18 meses depois.</segment>
    <segment id="8">"</segment>
    <segment id="9">Moulin Rouge!</segment>
    <segment id="10">The Musical!</segment>
    <segment id="11">" venceu em dez categorias</segment>
    <segment id="12">, com destaque para melhor musical e melhor ator de musical para Aaron Tveit.</segment>
    <segment id="13">A obra é uma adaptação do filme "Moulin Rouge!</segment>
    <segment id="14">", do diretor</segment>
    <segment id="15">Baz Luhrmann</segment>
    <segment id="16">, com Nicole Kidman e Ewan McGregor.  Relembre o Tony Awards de 2019Mais</segment>
    <segment id="17">novamente         de   de  de  representando um    Já o Tony de melhor peça de teatro foi dado a "The Inheritance"</segment>
    <segment id="18">, adaptação para a Nova York de hoje do romance "Howards End"</segment>
    <segment id="19">, do britânico E. M. Forster.</segment>
    <segment id="20">Nele, um casal homossexual de 30 e poucos anos conhece dois homens —um de uma geração acima deles</segment>
    <segment id="21">, marcada pela Aids</segment>
    <segment id="22">, e outro de uma abaixo— que mudam suas perspectivas sobre relacionamentos.</segment>
    <segment id="23">Stephen Daldry recebeu o prêmio de melhor diretor pela mesma obra.</segment>
    <segment id="24">Por fim</segment>
    <segment id="25">, Adrienne Warren venceu na categoria de melhor atriz de musical por sua interpretação da cantora Tina Turner em "Tina".</segment>
    <segment id="26">Broadway lota com reabertura</segment>
    <segment id="27">, depois de 18 meses fechadaMais    novamente         de   de  de  representando um</segment>
    <segment id="28">Com duração de quatro horas</segment>
    <segment id="29">, a cerimônia do Tony aconteceu no Winter Garden Theatre</segment>
    <segment id="30">, no centro de Manhattan</segment>
    <segment id="31">, e foi veiculada pela rede de TV americana CBS.</segment>
    <segment id="32">Nela, apresentadores e vencedores celebraram a volta do teatro ao vivo e pediram mais oportunidades para artistas negros e latinos.</segment>
    <segment id="33">Foi o caso</segment>
    <segment id="34">caso, por exemplo</segment>
    <segment id="35">, do dramaturgo de "The Inheritance"</segment>
    <segment id="36">, Matthew Lopez</segment>
    <segment id="37">, descendente de portorriquenhos.</segment>
    <segment id="38">"</segment>
    <segment id="39">Este é o 74º Tony</segment>
    <segment id="40">, masmas sou o primeiro dramaturgo latino a vencer nesta categoria.</segment>
    <segment id="41">Isto precisa mudar"</segment>
    <segment id="42">, disse ele.</segment>
  </rst>
