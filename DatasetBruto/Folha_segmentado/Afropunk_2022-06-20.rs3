  <rst>
    <segment id="1">Emicida é a primeira atração confirmada para a segunda edição do Afropunk Bahia</segment>
    <segment id="2">, marcado para 26 e 27 de novembro no Parque de Exposições</segment>
    <segment id="3">, em Salvador.</segment>
    <segment id="4">O rapper paulista sobe ao palco no dia de abertura do festival.</segment>
    <segment id="5">Segundo a organização</segment>
    <segment id="6">, serão 26 horas de festa e mais de 30 artistas nacionais e estrangeiros.</segment>
    <segment id="7">Osingressos já estão disponíveis no site da Sympla</segment>
    <segment id="8">, com preços que variam de R$ 80 a R$ 460 (1º lote).</segment>
    <segment id="9">O Afropunk desembarcou no Brasil com sua primeira edição em 27 de novembro de 2021.</segment>
    <segment id="10">Na programação</segment>
    <segment id="11">, estiveram nomes</segment>
    <segment id="12">comocomo Mano Brown e Margareth Menezes</segment>
    <segment id="13">, que subiram ao palco no espaço Marés</segment>
    <segment id="14">, no Centro de Convenções de Salvador.</segment>
    <segment id="15">Emicida em show no palco</segment>
    <segment id="16">Budweiser do Lollapalooza</segment>
    <segment id="17">, no autódromo de Interlagos (zona sul de São Paulo) - Adriano Vizoni - 26.mar.2022/FolhapressO vocalista do Racionais MC’s cantou ao lado da cantora Duquesa</segment>
    <segment id="18">, aposta do R&amp;amp</segment>
    <segment id="19">;B, enquanto a sambista baiana</segment>
    <segment id="20">sese apresentou ao lado da carioca Malía.</segment>
    <segment id="21">Por causa da pandemia de Covid</segment>
    <segment id="22">, o evento foi adiado em 2020 e teve no ano passado um formato menor e híbrido</segment>
    <segment id="23">, com transmissão online pelo site oficial.</segment>
    <segment id="24">Com a intenção de exaltar o protagonismo preto e afroindígena</segment>
    <segment id="25">, a programação ainda contou com Tássia Reis com o bloco afro Ilê Aiyê</segment>
    <segment id="26">, a baiana Luedji Luna ao lado do duo Yoún</segment>
    <segment id="27">, além da cantora Urias em parceria com Vírus.</segment>
    <segment id="28">A capital baiana foi escolhida</segment>
    <segment id="29">comocomo ponto principal do Afropunk no país por ser conhecida</segment>
    <segment id="30">comocomo a cidade mais negra fora da África.</segment>
    <segment id="31">O festival nasceu em 2005</segment>
    <segment id="32">, em Nova York</segment>
    <segment id="33">, e desde então é realizado em cidades</segment>
    <segment id="34">comocomo Atlanta (Estados Unidos)</segment>
    <segment id="35">, Paris (França)</segment>
    <segment id="36">, Londres (Inglaterra) e Joanesburgo (África do Sul).</segment>
    <segment id="37">Afropunk Bahia 2021Mais    novamente         de   de  de  representando um  Afropunk Bahia 2022</segment>
    <segment id="38">Quando: 26 e 27 de novembro</segment>
    <segment id="39">Onde: Parque de Exposições (Av. Luís Viana Filho</segment>
    <segment id="40">, 1.590</segment>
    <segment id="41">, Salvador - Bahia)</segment>
    <segment id="42">Quanto: R$ 80 a R$ 460 (1º lote) Mais informação: sympla.com.br</segment>
  </rst>
