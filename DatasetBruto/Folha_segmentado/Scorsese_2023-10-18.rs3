  <rst>
    <segment id="1">Assassinos da Lua das FloresQuando</segment>
    <segment id="2">Estreia nesta quinta-feira (19) nos cinemasClassificação 14 anosElenco Leonardo DiCaprio</segment>
    <segment id="3">, Lily Gladstone</segment>
    <segment id="4">, Robert De NiroProdução EUA</segment>
    <segment id="5">, 2023Direção Martin ScorseseAssassinos da Lua das Flores5 stars -"Assassinos da Lua das Flores" Estranho destino o da nação osage.</segment>
    <segment id="6">Após aceitarem a derrota e serem jogados de um lugar para o outro</segment>
    <segment id="7">, acabam</segment>
    <segment id="8">, no início do século passado</segment>
    <segment id="9">, numa reserva em território árido e estéril</segment>
    <segment id="10">, em que estão destinados à miséria.</segment>
    <segment id="11">Por ironia</segment>
    <segment id="12">, ali mesmo começa a brotar petróleo e</segment>
    <segment id="13">, de uma hora para outra</segment>
    <segment id="14">, temos um grupo miserável tocado pela súbita riqueza.</segment>
    <segment id="15">Surge então uma situação original.</segment>
    <segment id="16">Os brancos é que são os criados</segment>
    <segment id="17">, e os indígenas</segment>
    <segment id="18">, os senhores.</segment>
    <segment id="19">É como</segment>
    <segment id="20">como servidor</segment>
    <segment id="21">, aliás</segment>
    <segment id="22">, que Ernest Buckhart</segment>
    <segment id="23">, personagem de Leonardo DiCaprio</segment>
    <segment id="24">, irrompe na cidadezinha que</segment>
    <segment id="25">sese criou em torno da rica reserva.</segment>
    <segment id="26">Leonardo DiCaprio e Lily Gladstone em cena do filme &amp;#039</segment>
    <segment id="27">;Assassinos da Lua das Flores&amp;#039</segment>
    <segment id="28">;, de Martin Scorsese - DivulgaçãoEle é designado pelo seu tio rico</segment>
    <segment id="29">, William Hale</segment>
    <segment id="30">, vivido por Robert De Niro</segment>
    <segment id="31">, para trabalhar</segment>
    <segment id="32">comocomo chofer.</segment>
    <segment id="33">Hale é um rico criador de gado</segment>
    <segment id="34">, masmas não sabemos</segment>
    <segment id="35">comocomo conseguiu tanto gado.</segment>
    <segment id="36">É homem de trato afável</segment>
    <segment id="37">, não discrimina os indígenas e até fala a língua deles.</segment>
    <segment id="38">É como</segment>
    <segment id="39">como chofer que Ernest conhecerá a bela indígena Moly</segment>
    <segment id="40">, papel de Lily Gladstone</segment>
    <segment id="41">, por quem</segment>
    <segment id="42">sese apaixona de imediato.</segment>
    <segment id="43">E vice-versa.</segment>
    <segment id="44">É então que começa a</segment>
    <segment id="45">sese revelar o duplo caráter de Hale</segment>
    <segment id="46">, mais conhecido</segment>
    <segment id="47">comocomo Rei.</segment>
    <segment id="48">Ele acha muito boa a ideia de casamento de Ernest</segment>
    <segment id="49">, pois</segment>
    <segment id="50">pois os indígenas sofrem de muitas doenças e raramente passam dos 50 anos.</segment>
    <segment id="51">A mãe de Moly está à beira da morte.</segment>
    <segment id="52">Se as irmãs também morrerem</segment>
    <segment id="53">, a herança virá para sua família.</segment>
    <segment id="54">Ou seja</segment>
    <segment id="55">, eles</segment>
    <segment id="56">sese tornarão os proprietários do petróleo da família.</segment>
    <segment id="57">Confira cenas de &amp;#039</segment>
    <segment id="58">;Assassinos da Lua das Flores&amp;#039</segment>
    <segment id="59">;, de Martin ScorseseMais    novamente         de   de  de  representando um</segment>
    <segment id="60">Não por acaso estaremos diante de uma série de assassinatos do povo osage</segment>
    <segment id="61">, cometidos pelos mais diversos métodos e devidamente encobertos pela comunidade branca do local.</segment>
    <segment id="62">Temos em "</segment>
    <segment id="63">Assassinos da Lua das Flores"</segment>
    <segment id="64">uma trama intrigante</segment>
    <segment id="65">, com um vilão cínico</segment>
    <segment id="66">, astuto e disfarçado</segment>
    <segment id="67">, na pessoa do Rei</segment>
    <segment id="68">, e um herói meio tapado</segment>
    <segment id="69">, em parte pelos sentimentos divididos de lealdade ao Rei e a Moly</segment>
    <segment id="70">, em parte por burrice mesmo.</segment>
    <segment id="71">Essa duplicidade engendrará uma situação de culpa profunda que</segment>
    <segment id="72">sese revelará ao final.</segment>
    <segment id="73">E essa culpa não deriva apenas de seus parcos dotes intelectuais</segment>
    <segment id="74">, masmas sobretudo do fato de perceber as sinistras intenções do tio em relação a Moly</segment>
    <segment id="75">, numa angústia que não</segment>
    <segment id="76">sese vê nas palavras</segment>
    <segment id="77">, masmas no rosto de Di Caprio.</segment>
    <segment id="78">Martin Scorsese promove neste filme o encontro entre um fato histórico —levantado por David Grann e publicado em um livro homônimo— e um suspense habilmente conduzido</segment>
    <segment id="79">, ao qual virá</segment>
    <segment id="80">sese juntar em dado momento uma equipe do FBI.</segment>
    <segment id="81">O que pensamos nós</segment>
    <segment id="82">, espectadores ingênuos.</segment>
    <segment id="83">Chegaremos a um final feliz?</segment>
    <segment id="84">Sim, o FBI resolverá o</segment>
    <segment id="85">casocaso.</segment>
    <segment id="86">Ou não?</segment>
    <segment id="87">Em vez de investir na felicidade fugaz do público</segment>
    <segment id="88">, Scorsese faz com que sua história</segment>
    <segment id="89">sese dobre</segment>
    <segment id="90">, quando</segment>
    <segment id="91">, a horas tantas</segment>
    <segment id="92">, nos coloca diante de uma plateia que aplaude intensamente a solução dada ao</segment>
    <segment id="93">casocaso.</segment>
    <segment id="94">Mas que plateia é essa?</segment>
    <segment id="95">Somos nós</segment>
    <segment id="96">, é evidente.</segment>
    <segment id="97">A plateia na tela é um espelho do que desejamos.</segment>
    <segment id="98">Do que o cinema nos ensinou a desejar ao longo de mais de um século.</segment>
    <segment id="99">Como alguma vantagem existe em ser um cineasta célebre aos 80 anos</segment>
    <segment id="100">, Scorsese dá um nó em seu espectador e também em seu filme.</segment>
    <segment id="101">Nos lembra de que a história está longe de terminar.</segment>
    <segment id="102">O espectador verá a seguir</segment>
    <segment id="103">comocomo são tortuosos os caminhos da justiça branca e que não é certo que o espectador saia da sala sorrindo e aliviado.</segment>
    <segment id="104">MaratonarUm guia com dicas de filmes e séries para assistir no streamingCarregando...</segment>
    <segment id="105">Em compensação</segment>
    <segment id="106">, sairá sabendo que as imagens de época —reais ou feitas no computador</segment>
    <segment id="107">, não importa— não estão no filme apenas</segment>
    <segment id="108">comocomo ilustração.</segment>
    <segment id="109">Elas se</segment>
    <segment id="110">se referem também ao começo dessa arte e do procedimento clássico do cinema hollywoodiano</segment>
    <segment id="111">, desde que Griffith criou o cinema narrativo tal</segment>
    <segment id="112">comocomo o conhecemos hoje</segment>
    <segment id="113">, e sua instituição mais resistente</segment>
    <segment id="114">, o "happy end"</segment>
    <segment id="115">, ou final feliz.</segment>
    <segment id="116">Ao investir nesse procedimento</segment>
    <segment id="117">, num filme de grande audiência</segment>
    <segment id="118">, Scorsese de certo modo conclui o trabalho de modernização do cinema dos Estados Unidos à que sua geração</segment>
    <segment id="119">sese propôs.</segment>
    <segment id="120">Não é pouca coisa para quem é</segment>
    <segment id="121">, talvez</segment>
    <segment id="122">, o mais fiel de todos os cineastas da chamada nova Hollywood à tradição —</segment>
    <segment id="123">masmas não ao academicismo.</segment>
    <segment id="124">E fica ainda melhor que seja ele</segment>
    <segment id="125">, o último dos diretores dessa geração</segment>
    <segment id="126">, a dar esse tranco no ilusionismo que</segment>
    <segment id="127">, filme após filme</segment>
    <segment id="128">, embala nossos sonhos.</segment>
    <segment id="129">É um gesto de audácia</segment>
    <segment id="130">, de desafio à instituição cinematográfica desde que Griffith e Irving Thalberg fixaram as bases do desenvolvimento dessa indústria</segment>
    <segment id="131">, até porque</segment>
    <segment id="132">porque ele o faz depois de nos deixar por um bom tempo em suspense sobre o fim da história.</segment>
    <segment id="133">Martin Scorsese para o The New York TimesMais    novamente         de   de  de  representando um  Parece um pouco o fim da história do cinema</segment>
    <segment id="134">, esta arte de que</segment>
    <segment id="135">, de tempos em tempos</segment>
    <segment id="136">, tem sua morte decratada</segment>
    <segment id="137">, masmas insiste em não morrer.</segment>
    <segment id="138">Como os indígenas</segment>
    <segment id="139">, afinal.</segment>
  </rst>
</analysis>