  <rst>
    <segment id="1">Presidente do Conass</segment>
    <segment id="2">, conselho que reúne os secretários estaduais de Saúde</segment>
    <segment id="3">, Nésio Fernandes afirma que o país segue sendo prejudicado por "omissão e respostas lentas" do governo Jair Bolsonaro (PL) em relação à Covid-19</segment>
    <segment id="4">, que apresenta novo pico no Brasil.</segment>
    <segment id="5">"</segment>
    <segment id="6">Não é aceitável que a gente tenha tantos casos.</segment>
    <segment id="7">Não podemos tomar</segment>
    <segment id="8">comocomo parâmetro de risco as primeiras ondas.</segment>
    <segment id="9">Se fizermos isso</segment>
    <segment id="10">, vamos naturalizar 100 óbitos por dia para uma doença que já tem vacina"</segment>
    <segment id="11">, afirma.</segment>
    <segment id="12">Fernandes</segment>
    <segment id="13">, que é secretário estadual de Saúde no Espírito Santo</segment>
    <segment id="14">, lista o que vê</segment>
    <segment id="15">comocomo um combo de falhas atuais do Ministério da Saúde: incorporação tímida de medicamentos eficazes (Paxlovid</segment>
    <segment id="16">, Baracetinibe)</segment>
    <segment id="17">, abandono da divulgação da vacinação e falta de doses</segment>
    <segment id="18">, e silêncio a respeito de medidas restritivas.</segment>
    <segment id="19">Nesio Fernandes</segment>
    <segment id="20">, secretário estadual de Saúde do Espírito Santo e presidente do Conass - Lucas Silva-25.out.2019/Divulgação/Ales  "</segment>
    <segment id="21">No Espírito Santo</segment>
    <segment id="22">, recebi medicamento para somente para 800 pessoas.</segment>
    <segment id="23">Como distribuo numa situação</segment>
    <segment id="24">comocomo a atual?</segment>
    <segment id="25">Preciso ter Paxlovid em todos os pontos de testagem.</segment>
    <segment id="26">Uma pessoa idosa tem que receber no momento de avaliação do quadro</segment>
    <segment id="27">, não pode ter que passar por mais uma rota de transporte"</segment>
    <segment id="28">, diz Fernandes.  "</segment>
    <segment id="29">No caso</segment>
    <segment id="30">caso da cloroquina</segment>
    <segment id="31">, houve a decisão de comprar milhões e entupir.</segment>
    <segment id="32">Agora que temos o Paxlovid</segment>
    <segment id="33">, não temos o medicamento amplamente distribuído"</segment>
    <segment id="34">, completa</segment>
    <segment id="35">, lembrando das recomendações do governo federal de remédios sem eficácia contra a Covid-19.</segment>
    <segment id="36">O secretário diz que o Ministério da Saúde</segment>
    <segment id="37">, comandado por Marcelo Queiroga</segment>
    <segment id="38">, não pode ter o papel de somente emitir notas técnicas</segment>
    <segment id="39">, deixando novamente estados e municípios à frente da estratégia de enfrentamento.</segment>
    <segment id="40">"Estamos falando de muitos temas a serem abordados</segment>
    <segment id="41">, sobre os quais existe uma omissão no debate nacional.</segment>
    <segment id="42">Quando a autoridade nacional não opina</segment>
    <segment id="43">, cada um escolhe a opinião que quer e ninguém diz qual é a opinião institucional"</segment>
    <segment id="44">, afirma Fernandes.</segment>
    <segment id="45">Ministério da Saúde com Marcelo QueirogaMais    novamente         de   de  de  representando um    Ele aponta que a aplicação de vacinas caiu drasticamente neste ano.</segment>
    <segment id="46">Em 2021</segment>
    <segment id="47">, 340,5 milhões de doses foram aplicadas.</segment>
    <segment id="48">Em 2022</segment>
    <segment id="49">, apenas 149</segment>
    <segment id="50">,7 milhões.</segment>
    <segment id="51">Segundo Fernandes</segment>
    <segment id="52">, isso</segment>
    <segment id="53">sese deve</segment>
    <segment id="54">, entre outros fatores</segment>
    <segment id="55">, à omissão do governo federal no incentivo à vacinação e na propagação de mensagens contra os imunizantes por lideranças</segment>
    <segment id="56">comocomo o próprio Bolsonaro.</segment>
    <segment id="57">"</segment>
    <segment id="58">Tivemos em outubro</segment>
    <segment id="59">, no Espírito Santo</segment>
    <segment id="60">, seis óbitos.</segment>
    <segment id="61">Uma pessoa que</segment>
    <segment id="62">sese vacinou há mais de 400 dias e cinco que não</segment>
    <segment id="63">sese vacinaram.</segment>
    <segment id="64">Imagine</segment>
    <segment id="65">comocomo estaríamos hoje com 95% da população com o esquema atualizado?</segment>
    <segment id="66">", questiona.</segment>
    <segment id="67">Segundo o presidente do Conass</segment>
    <segment id="68">, serão exceções os governantes que vão apresentar determinações mais rigorosas agora</segment>
    <segment id="69">, como</segment>
    <segment id="70">como a obrigatoriedade do uso de máscaras.</segment>
    <segment id="71">Para ele</segment>
    <segment id="72">, "estão todos cansados da polarização e da pandemia</segment>
    <segment id="73">, existe um desgaste das convicções que mobilizaram com vigor estados e municípios durante os piores momentos da pandemia.</segment>
    <segment id="74">"</segment>
    <segment id="75">Diante desse cenário</segment>
    <segment id="76">, diz, a energia tem que ser concentrada no reforço da necessidade do uso de máscaras</segment>
    <segment id="77">, testagem e tratamento.</segment>
    <segment id="78">Memorial para vítimas da Covid-19 é instalado na avenida Paulista</segment>
    <segment id="79">, em São PauloMais    novamente         de   de  de  representando um</segment>
