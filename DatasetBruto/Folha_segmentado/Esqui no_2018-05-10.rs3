  <rst>
    <segment id="1">O dólar turismo subiu R$ 0</segment>
    <segment id="2">,15 no último mês.</segment>
    <segment id="3">Esse aumento desacelerou as vendas de pacotes para esquiar na América do Sul durante a temporada de neve</segment>
    <segment id="4">, que vinham bem</segment>
    <segment id="5">, segundo as operadoras consultadas.</segment>
    <segment id="6">As estações abrem meados de junho e funcionam até o fim de setembro</segment>
    <segment id="7">, em geral.</segment>
    <segment id="8">"</segment>
    <segment id="9">O dólar alto deixa o turista inseguro"</segment>
    <segment id="10">, diz Bruno Monti</segment>
    <segment id="11">, consultor da Snowtime.</segment>
    <segment id="12">Os aumentos levam os viajantes a adaptar o roteiro.</segment>
    <segment id="13">Em geral</segment>
    <segment id="14">, os visitantes reservam sete noites em um hotel que fica em uma estação ou perto de alguma.</segment>
    <segment id="15">Mas também existem as "mini weeks"</segment>
    <segment id="16">, estadias de três ou quatro noites</segment>
    <segment id="17">, que algumas estações oferecem na temporada toda —</segment>
    <segment id="18">comocomo na chilena Valle Nevado— ou em semanas específicas</segment>
    <segment id="19">, caso</segment>
    <segment id="20">caso de Portillo</segment>
    <segment id="21">, também no Chile.</segment>
    <segment id="22">"</segment>
    <segment id="23">Estou percebendo uma procura maior por 'mini weeks' nesta temporada"</segment>
    <segment id="24">, diz Meg Raimondo</segment>
    <segment id="25">, especialista em esqui da agência Sete Mares.</segment>
    <segment id="26">Para atrair os visitantes</segment>
    <segment id="27">, algumas estações estão fazendo promoções agressivas.</segment>
    <segment id="28">Portillo dá 20% de desconto nas diárias para quem reservar quatro ou sete noites no hotel da estação ou em um dos hotéis da rede Tierra</segment>
    <segment id="29">, no Atacama</segment>
    <segment id="30">, em Chiloé ou na Patagonia.</segment>
    <segment id="31">O complexo chileno também oferece estadia</segment>
    <segment id="32">, alimentação e esqui grátis para crianças acompanhadas por adultos pagantes.</segment>
    <segment id="33">A promoção é válida para uma ou duas crianças</segment>
    <segment id="34">, dependendo da data.</segment>
    <segment id="35">No Valle Nevado</segment>
    <segment id="36">, quem chegar a Santiago com a Avianca tem 10% de desconto nos ingressos para a estação</segment>
    <segment id="37">, 20% no aluguel de equipamentos para esqui ou snowboard e 10% na hospedagem.</segment>
    <segment id="38">Usuários do cartão Mastercard podem reservar diárias em um dos três hotéis de Valle Nevado com desconto de 10% entre 6 de julho e 29 de setembro.</segment>
    <segment id="39">Se a hospedagem for entre 22 de junho (data de abertura da estação) e 5 de julho</segment>
    <segment id="40">, o desconto chega a 25%.</segment>
    <segment id="41">Estações de esqui no Chile e Argentina</segment>
    <segment id="42">Ícone seta para esquerdaÍcone seta para direita</segment>
    <segment id="43">novamenteÍcone seta para esquerda</segment>
    <segment id="44">VoltarÍcone seta para cimaÍcone seta para baixoÍcone seta para esquerda Voltar       de  PinterestPinterestÍcone  de  de  representando um  Valle ainda dá desconto de 30% nas diárias</segment>
    <segment id="45">sese o cliente também reservar um dos hotéis da rede</segment>
    <segment id="46">Explora no Chile</segment>
    <segment id="47">, Peru</segment>
    <segment id="48">, Argentina ou Bolívia.</segment>
    <segment id="49">Corralco</segment>
    <segment id="50">, também no Chile</segment>
    <segment id="51">, tem desconto de 40% para reservas entre 23 e 30 de junho</segment>
    <segment id="52">, 30% para 30 de junho a 7 de julho e de 20% entre 7 e 28 de julho</segment>
    <segment id="53">, além de outros descontos para as semanas até 22 de setembro.</segment>
    <segment id="54">Em Bariloche</segment>
    <segment id="55">, turistas que pagarem com cartões Ourocard têm 15% de desconto em hotéis e de 10% e 15% em restaurantes e cervejarias.</segment>
    <segment id="56">Na Argentina</segment>
    <segment id="57">, estrangeiros são isentos de IVA (Imposto sobre o Valor Acrescentado) e pagam 21% menos nos hotéis.  NOVIDADES  Bariloche</segment>
    <segment id="58">, que tem a maior estação da América do Sul —Cerro Catedral—</segment>
    <segment id="59">, espera receber 42 mil brasileiros</segment>
    <segment id="60">, 15% a mais do que no ano passado</segment>
    <segment id="61">, segundo o diretor do turismo local</segment>
    <segment id="62">, Diego Piquín.</segment>
    <segment id="63">A região aposta na facilidade de transporte para atrair mais visitantes.</segment>
    <segment id="64">A Latam terá voos diários de Guarulhos para a cidade entre 1º de julho e 15 de agosto.</segment>
    <segment id="65">A Azul vai operar a partir de Campinas três voos semanais entre 30 de junho e 5 de agosto e dois entre 11 de agosto e 1º de setembro.</segment>
    <segment id="66">Sinônimo de viagem de neve para brasileiros</segment>
    <segment id="67">, Bariloche tem hoje em Valle Nevado um concorrente à altura.</segment>
    <segment id="68">Segundo as operadoras consultadas</segment>
    <segment id="69">, o resort chileno já é mais procurado por quem quer esquiar.</segment>
    <segment id="70">Estação de esqui</segment>
    <segment id="71">Valle Nevado</segment>
    <segment id="72">, no ChileÍcone seta para esquerdaÍcone seta para direita</segment>
    <segment id="73">novamenteÍcone seta para esquerda</segment>
    <segment id="74">VoltarÍcone seta para cimaÍcone seta para baixoÍcone seta para esquerda Voltar       de  PinterestPinterestÍcone  de  de  representando um</segment>
    <segment id="75">A temporada chega também com melhorias nas estações e hotéis.</segment>
    <segment id="76">Em Nevados de Chillán</segment>
    <segment id="77">, no Chile</segment>
    <segment id="78">, há um novo teleférico que leva à pista Três Marias</segment>
    <segment id="79">, a maior da América do Sul</segment>
    <segment id="80">, com 13 quilômetros.</segment>
    <segment id="81">Valle Nevado</segment>
    <segment id="82">, que faz 30 anos</segment>
    <segment id="83">, tem festas e semanas temáticas</segment>
    <segment id="84">, como</segment>
    <segment id="85">como a Wine Week</segment>
    <segment id="86">, com degustação de vinhos</segment>
    <segment id="87">, de 17 a 24 de agosto.</segment>
    <segment id="88">A estação entrega em junho seu nono condomínio</segment>
    <segment id="89">, que poderá ser alugado em 2019.</segment>
    <segment id="90">Portillo terá uma nova pista com 310 metros de extensão</segment>
    <segment id="91">, de nível intermediário.</segment>
    <segment id="92">O complexo também redecorou parte dos apartamentos de seu único hotel.</segment>
    <segment id="93">PACOTES PARA ESQUIAR NO CHILE</segment>
    <segment id="94">E ARGENTINA  R$ 4.331 7 noites</segment>
    <segment id="95">, na CVC  Em Bariloche</segment>
    <segment id="96">, com café da manhã e sem passes para esquiar.</segment>
    <segment id="97">Valor por pessoa</segment>
    <segment id="98">, com passagem aérea  R$ 5.428 7 noites</segment>
    <segment id="99">, na Visual  Em Bariloche</segment>
    <segment id="100">, com passeio pelo Circuito Chico e Cerro Catedral e seguro viagem</segment>
    <segment id="101">, sem passe de esqui.</segment>
    <segment id="102">Valor por pessoa</segment>
    <segment id="103">, com passagem aérea  US$ 2.183 (R$ 7.811) 7 noites</segment>
    <segment id="104">, na Ski Brasil  Em Valle Nevado</segment>
    <segment id="105">, com passes de esqui</segment>
    <segment id="106">, pensão completa e massagem.</segment>
    <segment id="107">Preço por pessoa</segment>
    <segment id="108">, sem passagem aérea  US$ 3.360 (R$ 12.022) 7 noites</segment>
    <segment id="109">, na Interpoint  Em Chillán</segment>
    <segment id="110">, com pensão completa</segment>
    <segment id="111">, passes de esqui</segment>
    <segment id="112">, aulas e equipamentos.</segment>
    <segment id="113">Tem desconto de 30% em reservas até dia 15.</segment>
    <segment id="114">Valor por pessoa</segment>
    <segment id="115">, sem passagem aérea  US$ 3.400 (R$ 12.165) 7 noites</segment>
    <segment id="116">, na Sete Mares Turismo</segment>
    <segment id="117">Em Portillo</segment>
    <segment id="118">, passes de esqui e pensão completa.</segment>
    <segment id="119">Preço por pessoa</segment>
    <segment id="120">, com passagem aérea  US$ 3.400 (R$ 12.165) 7 noites</segment>
    <segment id="121">, na Snowtime</segment>
    <segment id="122">Em Portillo</segment>
    <segment id="123">, passes de esqui e quatro refeições diárias.</segment>
    <segment id="124">Uma criança esquia de graça.</segment>
    <segment id="125">Valor por pessoa</segment>
    <segment id="126">, sem passagem aérea</segment>
  </rst>
