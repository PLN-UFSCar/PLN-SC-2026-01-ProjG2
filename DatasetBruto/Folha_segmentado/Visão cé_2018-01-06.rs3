  <rst>
    <segment id="1">Em 2012</segment>
    <segment id="2">, convidei Carlos Heitor Cony a participar de um debate em São Paulo sobre Nelson Rodrigues</segment>
    <segment id="3">, num ciclo promovido pelo Sesi sobre o centenário de Nelson</segment>
    <segment id="4">, organizado por mim.</segment>
    <segment id="5">Cony, então com 86 anos</segment>
    <segment id="6">, já estava em cadeira de rodas.</segment>
    <segment id="7">Movia-</segment>
    <segment id="8">sese com dificuldade</segment>
    <segment id="9">, mal saía de seu apartamento na Lagoa</segment>
    <segment id="10">, quanto mais do Rio.</segment>
    <segment id="11">O fato de aceitar transportar-</segment>
    <segment id="12">sese até outra cidade para participar de uma mesa só podia indicar uma grande admiração por Nelson &amp;mdash</segment>
    <segment id="13">;ou consideração pelo organizador.</segment>
    <segment id="14">Memória</segment>
    <segment id="15">Carlos Heitor Cony morre aos 91 anos no RioAnálise:</segment>
    <segment id="16">Cony encarnou</segment>
    <segment id="17">comocomo poucos a figura do escritor profissional Escritores e colegas lamentam a morte de jornalista</segment>
    <segment id="18">Confira seis obras essenciais do escritor Em março</segment>
    <segment id="19">,</segment>
    <segment id="20">escritor publicou a coluna '</segment>
    <segment id="21">Se eu morrer amanhã' Releia a última coluna de Cony publicada na Folha</segment>
    <segment id="22">, em 31 de dezembro</segment>
    <segment id="23">Ao chegar ao prédio da avenida Paulista</segment>
    <segment id="24">, onde</segment>
    <segment id="25">sese daria o debate</segment>
    <segment id="26">, Cony foi recebido na garagem pelas moças encarregadas da produção.</segment>
    <segment id="27">Elas observaram nervosas enquanto ele era a custo descido do carro e colocado na cadeira.</segment>
    <segment id="28">Uma delas perguntou</segment>
    <segment id="29">, aflita: &amp;quot</segment>
    <segment id="30">;Está tudo bem</segment>
    <segment id="31">, Dr. Cony?&amp;quot</segment>
    <segment id="32">;.E</segment>
    <segment id="33">Cony, piscando para mim:</segment>
    <segment id="34">&amp;quot;Não</segment>
    <segment id="35">passo desta noite&amp;quot</segment>
    <segment id="36">;.Seguiu-</segment>
    <segment id="37">sese um alarido.</segment>
    <segment id="38">Elas acreditaram nele e acharam que o desenlace poderia acontecer ali mesmo</segment>
    <segment id="39">, na porta dos elevadores</segment>
    <segment id="40">, ou no meio do evento.</segment>
    <segment id="41">Uma quase começou a chorar.</segment>
    <segment id="42">Tive de me meter e dizer que era brincadeira</segment>
    <segment id="43">, que ele estava ótimo</segment>
    <segment id="44">, nada aconteceria.</segment>
    <segment id="45">E, de fato</segment>
    <segment id="46">, nada aconteceu</segment>
    <segment id="47">, exceto o brilho habitual de Cony naquela mesa</segment>
    <segment id="48">, usando Nelson</segment>
    <segment id="49">comocomo pretexto para falar de jornalismo</segment>
    <segment id="50">, coragem</segment>
    <segment id="51">, liberdade de opinião</segment>
    <segment id="52">, censura &amp;ndash</segment>
    <segment id="53">;o que</segment>
    <segment id="54">, de certa forma</segment>
    <segment id="55">, era a história dele próprio.</segment>
    <segment id="56">E, de novo chamando a minha cumplicidade</segment>
    <segment id="57">, meteu na conversa um de seus assuntos favoritos</segment>
    <segment id="58">, as Guerras Púnicas</segment>
    <segment id="59">, que nada tinham a ver com Nelson.</segment>
    <segment id="60">Seu jeito moleque sempre dizia a última palavra.</segment>
    <segment id="61">Cony nos habituou à ideia de sua morte.</segment>
    <segment id="62">No começo dos anos 1990</segment>
    <segment id="63">, recém-saído de um câncer de próstata perfeitamente resolvido</segment>
    <segment id="64">, ele às vezes aparteava a si próprio para informar:</segment>
    <segment id="65">&amp;quot;Você sabe</segment>
    <segment id="66">, não, Ruy?</segment>
    <segment id="67">Sou um homem terminal&amp;quot</segment>
    <segment id="68">;.</segment>
    <segment id="69">Minha ignorância a respeito de câncer levava-me a achar que ele estava falando sério.</segment>
    <segment id="70">Mas os anos</segment>
    <segment id="71">sese passavam e o homem terminal parecia mais ativo do que nunca</segment>
    <segment id="72">, principalmente depois que um romance chamado &amp;quot</segment>
    <segment id="73">;Quase Memória&amp;quot</segment>
    <segment id="74">;, em 1995 &amp;ndash</segment>
    <segment id="75">;seu primeiro em mais de 20 anos de silêncio no gênero&amp;ndash</segment>
    <segment id="76">;</segment>
    <segment id="77">devolveu-o espetacularmente à literatura.</segment>
    <segment id="78">No ano seguinte</segment>
    <segment id="79">, recebemos juntos o Prêmio Jabuti de Literatura</segment>
    <segment id="80">, cada qual em sua categoria (ele</segment>
    <segment id="81">, por &amp;quot</segment>
    <segment id="82">;Quase Memória&amp;quot</segment>
    <segment id="83">;</segment>
    <segment id="84">;</segment>
    <segment id="85">eu, por &amp;quot</segment>
    <segment id="86">;Estrela Solitária &amp;ndash</segment>
    <segment id="87">;Um</segment>
    <segment id="88">Brasileiro Chamado</segment>
    <segment id="89">Garrincha&amp;quot</segment>
    <segment id="90">;)</segment>
    <segment id="91">, e Cony partiu dali para uma espantosa carreira de conferencista.</segment>
    <segment id="92">Passou a ser solicitado a dar palestras para plateias de cidades de que nunca ouvira falar</segment>
    <segment id="93">, e não recusava convite.</segment>
    <segment id="94">Calculo que</segment>
    <segment id="95">, apenas pelos cinco anos seguintes</segment>
    <segment id="96">, Cony tenha feito perto de 300 palestras &amp;ndash</segment>
    <segment id="97">;no mínimo</segment>
    <segment id="98">, uma por semana.</segment>
    <segment id="99">E, sese todas foram iguais a algumas a que assisti</segment>
    <segment id="100">, posso avaliar o encantamento de tantas plateias por ele.</segment>
    <segment id="101">Um ano depois do ciclo do Sesi</segment>
    <segment id="102">, 2013</segment>
    <segment id="103">, Cony nos surpreendeu de novo ao aceitar um convite ainda mais torturante: o da Feira de Frankfurt</segment>
    <segment id="104">, dedicada naquele ano ao Brasil &amp;ndash</segment>
    <segment id="105">;e lá se</segment>
    <segment id="106">se foram</segment>
    <segment id="107">, ele e sua mulher</segment>
    <segment id="108">, Beatriz</segment>
    <segment id="109">, para a Alemanha.</segment>
    <segment id="110">Na qualidade de autor brasileiro mais velho ali presente e com uma obra daquele tamanho</segment>
    <segment id="111">, era obrigatório que lhe dessem</segment>
    <segment id="112">, só para ele</segment>
    <segment id="113">, um auditório e uma plateia de gala.</segment>
    <segment id="114">Mas não foi assim.</segment>
    <segment id="115">Escalaram-no com outros quatro romancistas numa sala fora de mão</segment>
    <segment id="116">, à noite e a quilômetros do pavilhão da feira e</segment>
    <segment id="117">, talvez para homenageá-lo</segment>
    <segment id="118">, determinaram que fosse o último a falar.</segment>
    <segment id="119">Só sese esqueceram de avisar aos outros que refreassem a narrativa sobre seus complexos &amp;</segment>
    <segment id="120">quot;processos de criação&amp;quot</segment>
    <segment id="121">; porque</segment>
    <segment id="122">porque</segment>
    <segment id="123">, mais de duas horas depois</segment>
    <segment id="124">, ao chegar a vez de Cony</segment>
    <segment id="125">, o auditório</segment>
    <segment id="126">sese reduzira a meia dúzia de pessoas esgotadas</segment>
    <segment id="127">, entre as quais eu.</segment>
    <segment id="128">Ele não</segment>
    <segment id="129">sese alterou.</segment>
    <segment id="130">Falou como</segment>
    <segment id="131">como se</segment>
    <segment id="132">se nós</segment>
    <segment id="133">, os gatos pingados</segment>
    <segment id="134">, fôssemos a plateia mais importante do mundo.</segment>
    <segment id="135">E não tocou no seu &amp;quot</segment>
    <segment id="136">;processo de criação&amp;quot</segment>
    <segment id="137">;.Chega.</segment>
    <segment id="138">Este não é um obituário.</segment>
    <segment id="139">Estou contando essas histórias apenas para disfarçar o sentimento de perda pela morte de alguém com quem convivi por tanto tempo &amp;ndash</segment>
    <segment id="140">;56 anos</segment>
    <segment id="141">comocomo leitor</segment>
    <segment id="142">, 49 como</segment>
    <segment id="143">como amigo&amp;ndash</segment>
    <segment id="144">;</segment>
    <segment id="145">e que, sem querer e sem saber</segment>
    <segment id="146">, me influenciou mais do que qualquer outra pessoa.</segment>
    <segment id="147">Quando Cony começou a escrever sua coluna &amp;quot</segment>
    <segment id="148">;Da</segment>
    <segment id="149">Arte de Falar Mal&amp;quot</segment>
    <segment id="150">;, no &amp;quot</segment>
    <segment id="151">;Correio da Manhã&amp;quot</segment>
    <segment id="152">;, em 1962</segment>
    <segment id="153">, não podia imaginar que sua visão cética e irônica estivesse marcando para sempre um garoto talvez já predisposto a esse ceticismo e ironia &amp;ndash</segment>
    <segment id="154">;masmas que precisava de um aval daquele peso para carregá-los pela vida.</segment>
    <segment id="155">Fomos assim</segment>
    <segment id="156">, eu e Cony.</segment>
    <segment id="157">E, como</segment>
    <segment id="158">como compete aos céticos e irônicos</segment>
    <segment id="159">, nunca discutimos esse assunto.</segment>
  </rst>
</analysis>