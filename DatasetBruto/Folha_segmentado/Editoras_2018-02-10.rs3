  <rst>
    <segment id="1">Um grupo de casas independentes</segment>
    <segment id="2">sese reuniu</segment>
    <segment id="3">, ao redor da editora Hedra</segment>
    <segment id="4">, em uma joint venture formada para melhor competir no mercado livreiro.</segment>
    <segment id="5">A Hedra</segment>
    <segment id="6">, que já havia feito o mesmo com a Demônio Negro</segment>
    <segment id="7">, acaba de assumir o departamento comercial da Azougue e da Circuito</segment>
    <segment id="8">, além da Kalinka</segment>
    <segment id="9">, especializada em literatura russa.</segment>
    <segment id="10">Assim, o grupo</segment>
    <segment id="11">, que preparou um roteiro de investimentos</segment>
    <segment id="12">, unifica departamento comercial</segment>
    <segment id="13">, a impressão</segment>
    <segment id="14">, a distribuição e o planejamento de lançamentos o que permite</segment>
    <segment id="15">, por exemplo</segment>
    <segment id="16">, negociar preços melhores com gráficas.</segment>
    <segment id="17">A casa paulista também está em negociações com outras duas editoras independentes para</segment>
    <segment id="18">sese juntarem à iniciativa.</segment>
    <segment id="19">Caso feche o acordo</segment>
    <segment id="20">, o grupo terá junto um catálogo de 3.000 títulos.</segment>
    <segment id="21">Jorge Sallum</segment>
    <segment id="22">, diretor da Hedra</segment>
    <segment id="23">, também diz que a casa prepara para breve a abertura de sua livraria em São Paulo e está em conversas com um possível investidor.</segment>
    <segment id="24">A ideia é ir convertendo pouco a pouco os títulos das editoras que formam o grupo para o formato digital o processo já começou com os livros da Kalinka.      ​Romance</segment>
    <segment id="25">A Sesi-SP Editora comprou os direitos de Upstate</segment>
    <segment id="26">, novo romance do crítico literário James Wood</segment>
    <segment id="27">, que será lançado em março no Reino Unido</segment>
    <segment id="28">, em março</segment>
    <segment id="29">, e nos EUA</segment>
    <segment id="30">, em junho.  Romance 2</segment>
    <segment id="31">No livro</segment>
    <segment id="32">, uma personagem cai em depressão e recebe a visita do pai e da irmã</segment>
    <segment id="33">, com quem quase não tinha contato.</segment>
    <segment id="34">O lançamento no Brasil será ainda neste semestre.</segment>
    <segment id="35">Ensaio</segment>
    <segment id="36">A Companhia das Letras comprou os direitos de Packing My Library</segment>
    <segment id="37">, do ensaísta e bibliófilo argentino Alberto Manguel.</segment>
    <segment id="38">O ensaio é uma reflexão iniciada quando Manguel precisou</segment>
    <segment id="39">sese desfazer de parte de sua biblioteca</segment>
    <segment id="40">, ao ir morar nos EUA.</segment>
    <segment id="41">Poesia</segment>
    <segment id="42">A Retornada</segment>
    <segment id="43">, de Laura Erber</segment>
    <segment id="44">, que saiu pela Relicário Edições em 2017</segment>
    <segment id="45">, será traduzido para o albanês.</segment>
    <segment id="46">Quem comprou os direitos foi a editora Buzuku</segment>
    <segment id="47">, sediada no Kosovo.  Poesia 2</segment>
    <segment id="48">A Relicário</segment>
    <segment id="49">, aliás</segment>
    <segment id="50">, lança neste semestre</segment>
    <segment id="51">Eu Nunca Fui ao Brasil</segment>
    <segment id="52">, seleção de poemas do autor austríaco Ernst Jandl.</segment>
    <segment id="53">Membro do grupo de Viena</segment>
    <segment id="54">, ele levou adiante</segment>
    <segment id="55">, nos anos 1950</segment>
    <segment id="56">, as experiências das vanguardas com seus versos experimentais.  Juvenil</segment>
    <segment id="57">A Record comprou os direitos de Far From The Tree</segment>
    <segment id="58">, de Robin Benway</segment>
    <segment id="59">, ganhador da categoria juvenil do National Book Award.</segment>
    <segment id="60">A obra conta a história de Grace</segment>
    <segment id="61">, jovem adotada</segment>
    <segment id="62">, e seus dois irmãos biológicos.</segment>
  </rst>
</analysis>