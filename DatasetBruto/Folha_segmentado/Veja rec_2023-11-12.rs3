  <rst>
    <segment id="1">Tortas de chocolate são boas opções de sobremesa para fazer no final de semana ou feriados.</segment>
    <segment id="2">Aprenda uma receita que tem recheio de Ovomaltine e doce de leite para elevar o docinho após almoço.</segment>
    <segment id="3">Selecione um dia livre</segment>
    <segment id="4">, já que a receita leva 4 horas para ficar pronta</segment>
    <segment id="5">, rendendo duas tortas (aro 15) de 1</segment>
    <segment id="6">,3 kg cada.</segment>
    <segment id="7">Torta recheada de Ovomaltine - Divulgação Ingredientes</segment>
    <segment id="8">Para a base   300g de Ovomaltine 150g de cobertura branca fracionada –tipo de cobertura pronta encontrada em lojas de festas e supermercados feita a base de chocolate branco.</segment>
    <segment id="9">10g de manteiga sem sal</segment>
    <segment id="10">Para 1ª camada de recheio   400g chocolate branco 100g chocolate ao leite 200g de creme de leite sem soro 150g de Ovomaltine</segment>
    <segment id="11">Para 2ª camada de recheio   500g de chantilly 400g de doce de leite 30g de gelatina sem sabor</segment>
    <segment id="12">Para a cobertura    400g de creme crocante Ovomaltine   Modo de Preparo  Base</segment>
    <segment id="13">Derreta a cobertura branca no micro-ondas em potência média de 30 em 30 segundos</segment>
    <segment id="14">, mexendo toda vez que apitar.</segment>
    <segment id="15">Repita o processo até que esteja totalmente derretido</segment>
    <segment id="16">Acrescente Ovomaltine Mexa com as mãos até formar uma farofa</segment>
    <segment id="17">Em duas assadeiras de aro 15 preencha toda lateral e fundo com a farofa Leve para gelar por 30 minutos   1ª camada de recheio</segment>
    <segment id="18">Bata o creme de leite e 150g de Ovomaltine no liquidificador e reserve</segment>
    <segment id="19">Derreta os chocolates no micro-ondas em potência média de 30 em 30 segundos</segment>
    <segment id="20">, mexendo toda vez que apitar.</segment>
    <segment id="21">Repita o processo até que esteja totalmente derretido</segment>
    <segment id="22">Acrescente o creme de leite e mexa até homogeneizar bem Coloque o recheio</segment>
    <segment id="23">, dividindo-o por cima das duas bases Deixe na geladeira por 2 horas ou até que esteja com boa consistência</segment>
    <segment id="24">2ª camada de recheio</segment>
    <segment id="25">Em um pote coloque 45ml de água gelada e salpique a gelatina incolor Deixe descansar por 5 minutos</segment>
    <segment id="26">Bata o chantilly com o doce de leite na batedeira</segment>
    <segment id="27">Derreta a massa da gelatina que estava repousando no micro-ondas por 20 segundos.</segment>
    <segment id="28">Acrescente gelatina derretida no chantilly com o doce de leite e mexa para incorporar bem Coloque esse recheio por cima do primeiro dividindo-o para as duas tortas Leve para geladeira por 1 hora   Cobertura</segment>
    <segment id="29">Espalhe o creme de Ovomaltine sobre as tortas já firmes</segment>
  </rst>
</analysis>