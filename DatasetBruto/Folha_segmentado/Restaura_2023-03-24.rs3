  <rst>
    <segment id="1">Quem visita o Nordeste brasileiro encontra uma culinária que mescla sabores do mar e da terra</segment>
    <segment id="2">, com frutas e animais estrelando pratos originais ou releituras de clássicos com ingredientes locais.</segment>
    <segment id="3">Nas capitais da região</segment>
    <segment id="4">, restaurantes têm renovado a cena gastronômica local.</segment>
    <segment id="5">Veja a seguir casas para conhecer.</segment>
    <segment id="6">Lâminas de haddock em emulsão de leite de tigre no restaurante Marechal</segment>
    <segment id="7">, em Natal - Reprodução   NO RECIFE</segment>
    <segment id="8">Arvo</segment>
    <segment id="9">Com horta própria e ambiente aberto com árvores</segment>
    <segment id="10">, oferece no almoço refeição com três pratos por R$ 79</segment>
    <segment id="11">,90.</segment>
    <segment id="12">Para começar</segment>
    <segment id="13">, linguiça de atum grelhada na banha de porco</segment>
    <segment id="14">, servida com farofa de beiju e vinagrete de caju.</segment>
    <segment id="15">Depois</segment>
    <segment id="16">, nos principais</segment>
    <segment id="17">, dá para escolher entre um prensado de porco empanado</segment>
    <segment id="18">, com chutney de abacaxi</segment>
    <segment id="19">, homus de cenoura e pão lavash ou peixe grelhado</segment>
    <segment id="20">, acompanhado de molho de coco e purê de couve-flor.</segment>
    <segment id="21">Vale finalizar a refeição com um picolé cremoso de chocolate branco recheado com morango</segment>
    <segment id="22">, coberto de nibs de cacau e castanha do Pará.</segment>
    <segment id="23">R. Djalma Farias</segment>
    <segment id="24">, 170, Torreão.</segment>
    <segment id="25">Recife</segment>
    <segment id="26">, Pernambuco.</segment>
    <segment id="27">Almoço</segment>
    <segment id="28">, ter.</segment>
    <segment id="29">a dom.</segment>
    <segment id="30">, das 11h45 às 16h.</segment>
    <segment id="31">Jantar</segment>
    <segment id="32">, ter.</segment>
    <segment id="33">a sáb.</segment>
    <segment id="34">, às 19h à 0h.</segment>
    <segment id="35">Instagram: @arvorestaurante.</segment>
    <segment id="36">Reservas disponível apenas no jantar.</segment>
    <segment id="37">Cá-já Traz</segment>
    <segment id="38">, no almoçou ou jantar</segment>
    <segment id="39">, ingredientes tradicionais de Pernambuco.</segment>
    <segment id="40">Para abrir o apetite</segment>
    <segment id="41">, entradas</segment>
    <segment id="42">comocomo caruru</segment>
    <segment id="43">, feito com camarão</segment>
    <segment id="44">, quiabo</segment>
    <segment id="45">, dendê</segment>
    <segment id="46">, amendoim e castanha (R$ 16)</segment>
    <segment id="47">, ou caldo de mariscos (R$ 15).</segment>
    <segment id="48">Nos pratos individuais</segment>
    <segment id="49">, oferece yaki com carne de sol (R$ 45)</segment>
    <segment id="50">, nhoque de inhame com ragu de chambaril (músculo com osso da perna do boi)</segment>
    <segment id="51">, por R$ 56.</segment>
    <segment id="52">Quem for em grupos maiores</segment>
    <segment id="53">, pode pedir peixadas (R$ 144)</segment>
    <segment id="54">, galinhadas (R$ 100) ou favadas (R$ 122) para compartilhar.</segment>
    <segment id="55">Detalhe</segment>
    <segment id="56">, no almoço de terça à sexta</segment>
    <segment id="57">, a caipirinha de limão sai por R$ 10.</segment>
    <segment id="58">R. Carneiro Viléla</segment>
    <segment id="59">, 648, Aflitos.</segment>
    <segment id="60">Recife</segment>
    <segment id="61">, Pernambuco.</segment>
    <segment id="62">Instagram: @vempracaja.</segment>
    <segment id="63">Telefone: (81) 3126-0648.</segment>
    <segment id="64">Conheça cinco restaurantes da nova cena gastronômica do NordesteMais    novamente         de   de  de  representando um  EM FORTALEZA  Casa Coral</segment>
    <segment id="65">Aberto há uma semana</segment>
    <segment id="66">, tem no menu opções para o dia todo.</segment>
    <segment id="67">Para café da manhã ou brunch</segment>
    <segment id="68">, traz bowls de frutas (R$ 16)</segment>
    <segment id="69">, ovos ou toasts</segment>
    <segment id="70">, como</segment>
    <segment id="71">como a de camarões flambados</segment>
    <segment id="72">, aioli de manjericão</segment>
    <segment id="73">, abacate e salada verde (R$ 38).</segment>
    <segment id="74">No almoço</segment>
    <segment id="75">, alternativas leves</segment>
    <segment id="76">comocomo a salada de búfala e melancia (R$ 42) ou quiche de alho-poró com gorgonzola (R$ 25).</segment>
    <segment id="77">Na carta de drinques</segment>
    <segment id="78">, clássicos</segment>
    <segment id="79">comocomo caipirinha ($ 22) e rabo de galo (R$ 26).</segment>
    <segment id="80">Rua dos Tabajaras</segment>
    <segment id="81">, 450, Praia de Iracema.</segment>
    <segment id="82">Fortaleza</segment>
    <segment id="83">, Ceará.</segment>
    <segment id="84">Sex.</segment>
    <segment id="85">e sáb, das 10h às 21h.</segment>
    <segment id="86">Dom., das 10h às 17h.</segment>
    <segment id="87">Atendimento por ordem de chegada ou reserva.</segment>
    <segment id="88">Instagram: @nacasacoral   EM NATAL  Nau Durante passeios turísticos por Natal</segment>
    <segment id="89">, guias potiguares costumam lembrar que descendem de uma população indígena que tinha</segment>
    <segment id="90">, entre os hábitos alimentares</segment>
    <segment id="91">, o de comer camarão.</segment>
    <segment id="92">O restaurante Nau</segment>
    <segment id="93">, que tem unidades em outros estados</segment>
    <segment id="94">, encontra no Rio Grande do Norte a matéria-prima de uma grande variedade de pratos à base do crustáceo —já que o estado é um dos grandes produtores do ingrediente no país.</segment>
    <segment id="95">Em um ambiente moderninho e amplo</segment>
    <segment id="96">, tem mais de duas páginas de sugestões que têm apenas o camarão</segment>
    <segment id="97">comocomo protagonista.</segment>
    <segment id="98">Entre elas</segment>
    <segment id="99">, está o mar vermelho</segment>
    <segment id="100">, com camarões envoltos em farinha panko</segment>
    <segment id="101">, servido com arroz de moqueca (R$ 112</segment>
    <segment id="102">, para duas ou até três pessoas).</segment>
    <segment id="103">Vale sentar perto do grande janelão de vidro que dá direito a vista para um espelho d'água situado abaixo da construção de concreto —que tem ares da arquitetura brasiliense.</segment>
    <segment id="104">Av. Odilon Gomes de Lima</segment>
    <segment id="105">, 1.772</segment>
    <segment id="106">, Cidade Jardim</segment>
    <segment id="107">, Natal.</segment>
    <segment id="108">@naurestaurante  Receita com camarão empanado e arroz de moqueca do restaurante Nau</segment>
    <segment id="109">, em Natal - Marília Miragaia/FolhapressMarechal Restaurante</segment>
    <segment id="110">Oferece menu especial (R$ 109) e executivo (R$ 69) com três pratos no almoço e no jantar.</segment>
    <segment id="111">Mais barato</segment>
    <segment id="112">, o executivo tem entradas com tartare de steak ou croquete de peixada</segment>
    <segment id="113">, seguidas de moqueca de peixe</segment>
    <segment id="114">, paillard de linguine artesanal ou picadinho de filé mignon.</segment>
    <segment id="115">No cardápio especial</segment>
    <segment id="116">, para começar</segment>
    <segment id="117">, carpaccio ou stick de mandioquinha.</segment>
    <segment id="118">Os principais incluem camarão com bacon ou escalope de mignon</segment>
    <segment id="119">, combinado com mousseline de mandioquinha</segment>
    <segment id="120">, pralineé de nozes e farofa de amêndoas.</segment>
    <segment id="121">Para finalizar</segment>
    <segment id="122">, tartellete de chocolate.</segment>
    <segment id="123">Av. Hermes da Fonseca</segment>
    <segment id="124">, 880, Petrópolis.</segment>
    <segment id="125">Natal, Rio Grande do Norte.</segment>
    <segment id="126">Seg.</segment>
    <segment id="127">a qua.</segment>
    <segment id="128">, das 17h à 0h.</segment>
    <segment id="129">Qui.</segment>
    <segment id="130">a sáb, das 12h à 0h.</segment>
    <segment id="131">EM SALVADOR  Omí Dentro do Fera Palace Hotel</segment>
    <segment id="132">, oferece almoços a preço fixo durante a semana</segment>
    <segment id="133">, com opções de dois (R$ 79) ou três pratos (R$ 99).</segment>
    <segment id="134">Na entrada</segment>
    <segment id="135">, dá para escolher entre tatare de angus</segment>
    <segment id="136">, ceviche de caju ou camarão crocante.</segment>
    <segment id="137">Depois</segment>
    <segment id="138">, no principal</segment>
    <segment id="139">, traz alternativas brasileiras</segment>
    <segment id="140">comocomo baião de dois com carne de panela suína ou italianas</segment>
    <segment id="141">, como</segment>
    <segment id="142">como o parpadelle</segment>
    <segment id="143">, combinado com ragu de brisket</segment>
    <segment id="144">, tomates assados e picles de cebola.</segment>
    <segment id="145">Se escolheu a opção com três etapas</segment>
    <segment id="146">, pode pedir sobremesa: bolo branco com frutas vermelhas e farofa de suspiro ou rocambole de brigadeiro de abacaxi.</segment>
    <segment id="147">Rua Chile</segment>
    <segment id="148">, 20, Centro Histórico.</segment>
    <segment id="149">Salvador</segment>
    <segment id="150">, Bahia.</segment>
    <segment id="151">Almoço</segment>
    <segment id="152">, de ter.</segment>
    <segment id="153">a sáb.</segment>
    <segment id="154">, das 12h às 15h.</segment>
    <segment id="155">Dom., das 12h às 17h.</segment>
    <segment id="156">Jantar</segment>
    <segment id="157">, de qua.</segment>
    <segment id="158">a sáb.</segment>
    <segment id="159">, das 19h às 23h.</segment>
    <segment id="160">É preciso reservar de forma antecipada.</segment>
    <segment id="161">Instagram:</segment>
    <segment id="162">@omirestaurante</segment>
  </rst>
</analysis>