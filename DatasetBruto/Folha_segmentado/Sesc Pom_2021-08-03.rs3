    <segment id="37">, de Ludwig Mies van der Rohe</segment>
    <segment id="38">, em Plano</segment>
    <segment id="39">, (Estados Unidos</segment>
    <segment id="40">, 1951)  3.</segment>
    <segment id="41">New Gourna Village</segment>
    <segment id="42">, de Hassan Fathy</segment>
    <segment id="43">, em Luxor (Egito</segment>
    <segment id="44">, 1952)  4.</segment>
    <segment id="45">Câmara Municipal de Säynätsalo</segment>
    <segment id="46">, de Alvar Aalto</segment>
