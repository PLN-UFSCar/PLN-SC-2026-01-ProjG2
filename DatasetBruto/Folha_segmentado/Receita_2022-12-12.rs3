  <rst>
    <segment id="1">Sai a Copa do Mundo</segment>
    <segment id="2">, entra o verão nas Receitas do Marcão.</segment>
    <segment id="3">Nos últimos dois anos</segment>
    <segment id="4">, tive o privilégio de voltar algumas vezes à Bahia</segment>
    <segment id="5">, que passei tempo demais sem visitar.</segment>
    <segment id="6">A comida por lá é uma coisa de louco</segment>
    <segment id="7">, tanto os clássicos de mar e dendê (moqueca</segment>
    <segment id="8">, bobó e cia.) quanto as coisas menos óbvias da alimentação cotidiana dos baianos.</segment>
    <segment id="9">Salada de feijão</segment>
    <segment id="10">, com receita de Marcos Nogueira - Marcos NogueiraAlgo que sempre me ganha na Bahia é a salada de feijão</segment>
    <segment id="11">, que acompanha tudo o que é porção nos botecos de Salvador.</segment>
    <segment id="12">Eles servem o feijão frio —em geral</segment>
    <segment id="13">, feijão-fradinho— numa espécie de vinagrete bem condimentado</segment>
    <segment id="14">, cheio de coentro.</segment>
    <segment id="15">No Bar da Mônica</segment>
    <segment id="16">, à beira da baía de Todos os Santos sob a comunidade da Gamboa</segment>
    <segment id="17">, ela vem com a carne de sol</segment>
    <segment id="18">, com o peixe frito</segment>
    <segment id="19">, com farofa e com cerveja gelada.</segment>
    <segment id="20">Por falar em Bahia e cerveja</segment>
    <segment id="21">, resolvi fazer a salada de feijão no embalo do calorão que ferveu São Paulo no último fim de semana.</segment>
    <segment id="22">Ela acompanhou uma lembrança muito especial que eu trouxe da última viagem à Bahia: carne de fumeiro</segment>
    <segment id="23">, um tipo de porco defumado tradicional do Recôncavo.</segment>
    <segment id="24">Isso é muito difícil de</segment>
    <segment id="25">sese achar fora da Bahia</segment>
    <segment id="26">, masmas a salada não precisa do fumeiro.</segment>
    <segment id="27">Você pode servi-la com qualquer tipo de carne ou peixe.</segment>
    <segment id="28">Pode comê-la</segment>
    <segment id="29">comocomo prato principal</segment>
    <segment id="30">, a depender da sua vontade e do calor.</segment>
    <segment id="31">Fiz minha salada com feijão de corda verde</segment>
    <segment id="32">, que eu achei para vender no sacolão perto de casa.</segment>
    <segment id="33">Ele cozinha muito rápido</segment>
    <segment id="34">, em questão de 15 minutos</segment>
    <segment id="35">, e não faz caldo.</segment>
    <segment id="36">A receita funciona também com qualquer tipo de feijão verde</segment>
    <segment id="37">, vendido na vagem nas feiras livres</segment>
    <segment id="38">, ou com feijão fradinho.</segment>
    <segment id="39">Para incrementar a receita</segment>
    <segment id="40">, para dar um pouco mais de sustança</segment>
    <segment id="41">, adicionei também uns ovos de codorna cozidos.</segment>
    <segment id="42">Tenho pavor de descascar esses ovinhos</segment>
    <segment id="43">, então os comprei prontos</segment>
    <segment id="44">, descascados e em conserva: o caldo avinagrado deixa os ovos com uma acidez que cai muito bem na salada.</segment>
    <segment id="45">Salada de feijão verde com ovo de codorna</segment>
    <segment id="46">Rendimento: 2 a 3 porções  Dificuldade: fácilSalada de feijão do Marcão</segment>
    <segment id="47">, com inspiração baiana - Marcos NogueiraINGREDIENTES  500 g de feijão de corda verde</segment>
    <segment id="48">, na vagem  1 cebola roxa em rodelas  ¼ de pimentão vermelho picado  1 pimenta dedo-de-moça picada (opcional)  2 colheres (sopa) de azeite  1 colher (sopa) de vinagre  1 tomate</segment>
    <segment id="49">, sem semente</segment>
    <segment id="50">, picado  12 ovos de codorna cozidos  2 colheres (sopa) de cebolinha picada  2 colheres (sopa) de coentro picado</segment>
    <segment id="51">Sal a gosto  PREPARO   Debulhe</segment>
    <segment id="52">, escolha e lave os feijões.</segment>
    <segment id="53">Cozinhe em água salgada por 15 a 20 minutos.</segment>
    <segment id="54">Escorra e deixe esfriar.</segment>
    <segment id="55">Enquanto o feijão esfria</segment>
    <segment id="56">, deixe a cebola</segment>
    <segment id="57">, o pimentão e a pimenta curtir com sal</segment>
    <segment id="58">, vinagre e azeite.</segment>
    <segment id="59">Assim, seu sabor ficará menos agressivo.</segment>
    <segment id="60">Misture o feijão frio</segment>
    <segment id="61">, as ervas e os ovos.</segment>
    <segment id="62">Ajuste o sal.</segment>
    <segment id="63">Deixe pegar gosto por 1 hora ou guarde na geladeira por até 1 dia antes de servir.</segment>
  </rst>
</analysis>