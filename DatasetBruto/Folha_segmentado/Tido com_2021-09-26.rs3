  <rst>
    <segment id="1">Sou candidato a primeiro-ministro</segment>
    <segment id="2">, não a animador de circo</segment>
    <segment id="3">, respondeu o social-democrata Olaf Scholz</segment>
    <segment id="4">, 63, quando lhe perguntaram</segment>
    <segment id="5">sese não lhe faltava demonstrar emoção.</segment>
    <segment id="6">Faltavam pouco mais de dois meses</segment>
    <segment id="7">, e seu partido (SPD) ainda</segment>
    <segment id="8">sese arrastava</segment>
    <segment id="9">comocomo terceiro colocado na corrida eleitoral.</segment>
    <segment id="10">Semanas depois</segment>
    <segment id="11">, inundações mataram 177 no oeste da Alemanha</segment>
    <segment id="12">, Scholz calçou botas de borracha</segment>
    <segment id="13">, visitou as cidades destruídas</segment>
    <segment id="14">, montou um pacote de ajuda e começou a escalada que levou seu partido ao primeiro lugar nas eleições alemãs.</segment>
    <segment id="15">O candidato a premiê pelo Partido Social-Democrata (SPD)</segment>
    <segment id="16">, Olaf Scholz</segment>
    <segment id="17">, vota em Potsdam</segment>
    <segment id="18">, cidade da região metropolitana de Berlim- Wolfgang Rattay - 26.set.21/ReutersDe personalidade controlada</segment>
    <segment id="19">, antes de ser candidato ele já havia sido apelidado por jornalistas de "Scholz-o-mat"</segment>
    <segment id="20">, expressão que o identifica com algo tão previsível quanto uma máquina de lavar roupas.</segment>
    <segment id="21">Muitas vezes descrito</segment>
    <segment id="22">comocomo "sem carisma" ou "alguém que saiu de um congresso de contadores"</segment>
    <segment id="23">, transmite mais tranquilidade que tédio</segment>
    <segment id="24">, porém</segment>
    <segment id="25">porém, e está longe de ser um tecnocrata obtuso</segment>
    <segment id="26">, sem outros interesses.</segment>
    <segment id="27">É apaixonado por literatura e um admirador do romancista austríaco Robert Musil (1880-1942) e dos irmãos alemães Henrich (1851-1950) e Thomas Mann (1875-1955).</segment>
    <segment id="28">Costuma acompanhar todas as edições da exposição de arte contemporânea Documenta —que acontece a cada cinco anos na Alemanha—e é aficionado por cinema.</segment>
    <segment id="29">Também ama cozinhar e</segment>
    <segment id="30">, segundo o jornal italiano Corriere della Sera</segment>
    <segment id="31">, atualmente é dono de um SUV da BMW —categoria para a qual defendeu impostos mais pesados em 2019</segment>
    <segment id="32">, por ter alto consumo de combustível.</segment>
    <segment id="33">Lá foraNa newsletter de Mundo</segment>
    <segment id="34">, semanalmente</segment>
    <segment id="35">, as análises sobre os principais fatos do globo</segment>
    <segment id="36">, explicados de forma leve e interessante.</segment>
    <segment id="37">Carregando...</segment>
    <segment id="38">Filho de um gerente comercial de empresas têxteis</segment>
    <segment id="39">, ele é o mais velho de três irmãos.</segment>
    <segment id="40">Nasceu em Osnabrück</segment>
    <segment id="41">, no noroeste alemão</segment>
    <segment id="42">, e cresceu em um bairro de classe média em Hamburgo</segment>
    <segment id="43">, no norte do país.</segment>
    <segment id="44">Entrou para a juventude do SPD aos 17 anos</segment>
    <segment id="45">, ainda no ensino médio.</segment>
    <segment id="46">Nessa segunda metade dos anos 1970</segment>
    <segment id="47">, identificou-</segment>
    <segment id="48">sese com o marxismo e protestou contra o "imperialismo americano".</segment>
    <segment id="49">A fase mais à esquerda foi branda e durou pouco.</segment>
    <segment id="50">Ele se</segment>
    <segment id="51">se moveu para o centro da centro-esquerda durante o curso de direito na Universidade de Hamburgo</segment>
    <segment id="52">, na qual</segment>
    <segment id="53">sese especializou em direito trabalhista.</segment>
    <segment id="54">Ainda tinha uma farta cabeleira castanha e ondulada quando</segment>
    <segment id="55">sese elegeu deputado federal</segment>
    <segment id="56">, em 1998.</segment>
    <segment id="57">Dois anos depois</segment>
    <segment id="58">, foi eleito chefe do SPD em Hamburgo</segment>
    <segment id="59">, estabelecendo-</segment>
    <segment id="60">sese na ala moderada da agremiação.</segment>
    <segment id="61">Scholz tornou-</segment>
    <segment id="62">sese secretário-geral do partido no ano 2000 e a partir de 2002 fez parte do governo social-democrata de Gerhard Schröder</segment>
    <segment id="63">, que reformou as regras trabalhistas alemãs.</segment>
    <segment id="64">Alemanha vai às urnas para escolher sucessor de Angela MerkelMais    novamente         de   de  de  representando um  Consideradas uma traição por sua base de apoio</segment>
    <segment id="65">, as reformas forçaram</segment>
    <segment id="66">Schröder a renunciar ao cargo de presidente do partido em 2004 e ajudaram Angela Merkel a vencer as eleições de 2005.</segment>
    <segment id="67">O revés não impediu que Scholz continuasse no governo</segment>
    <segment id="68">, como</segment>
    <segment id="69">como ministro do Trabalho.</segment>
    <segment id="70">Quando o SPD voltou para a oposição</segment>
    <segment id="71">, em 2009</segment>
    <segment id="72">, ele retornou a Hamburgo</segment>
    <segment id="73">, recuperou a liderança regional do partido e</segment>
    <segment id="74">sese elegeu prefeito.</segment>
    <segment id="75">Sua gestão</segment>
    <segment id="76">, de 2011 a 2018</segment>
    <segment id="77">, foi bem avaliada pelos moradores por ter saneado as contas da cidade e</segment>
    <segment id="78">, principalmente</segment>
    <segment id="79">, pelo investimento em habitação</segment>
    <segment id="80">, também um dos pilares de sua campanha a premiê.</segment>
    <segment id="81">Foi criticado</segment>
    <segment id="82">, porém</segment>
    <segment id="83">porém, por não ter prevenido nem contido protestos violentos em 2017</segment>
    <segment id="84">, durante a cúpula do G20</segment>
    <segment id="85">, que deixaram carros queimados</segment>
    <segment id="86">, vitrines quebradas e espalharam pânico.</segment>
    <segment id="87">O então prefeito também foi acusado de participação em uma fraude fiscal</segment>
    <segment id="88">, conhecida</segment>
    <segment id="89">comocomo "</segment>
    <segment id="90">casocaso CumEx" —que ainda não</segment>
    <segment id="91">sese encerrou</segment>
    <segment id="92">, masmas as investigações não encontraram provas de que Scholz tivesse culpa no esquema.</segment>
    <segment id="93">Desde 2018</segment>
    <segment id="94">, o social-democrata é vice-primeiro-ministro no governo Merkel e ministro das Finanças.</segment>
    <segment id="95">Dois anos atrás</segment>
    <segment id="96">, perdeu a disputa pela liderança do SPD para uma dupla de esquerda</segment>
    <segment id="97">, que o atacou por seu centrismo moderado</segment>
    <segment id="98">, masmas conseguiu ser escolhido o candidato a chanceler em agosto de 2020.</segment>
    <segment id="99">No governo</segment>
    <segment id="100">, acumulou trunfos.</segment>
    <segment id="101">Foi o responsável por montar o programa de ajuda contra a crise do coronavírus</segment>
    <segment id="102">, que ele apresentou</segment>
    <segment id="103">comocomo "a bazuca necessária" para segurar empregos e apoiar empresas: um pacote de 750 bilhões de euros (R$ 4</segment>
    <segment id="104">,7 trilhões)</segment>
    <segment id="105">, calçado em uma dívida de quase 400 bilhões de euros.</segment>
    <segment id="106">Também viu ser aprovada em julho deste ano</segment>
    <segment id="107">, na reunião do G20 em Veneza</segment>
    <segment id="108">, a proposta de imposto mínimo global</segment>
    <segment id="109">, da qual ele era um dos principais articuladores.</segment>
    <segment id="110">Nessa função federal</segment>
    <segment id="111">, também não escapou de acusações:</segment>
    <segment id="112">é investigado sob suspeita de falhar na fiscalização da financeira Wirecard</segment>
    <segment id="113">, que quebrou.</segment>
    <segment id="114">Seus índices nas pesquisas eleitorais não</segment>
    <segment id="115">sese mexeram após o</segment>
    <segment id="116">casocaso</segment>
    <segment id="117">, o que levou os jornais a chamá-lo em seus títulos de "candidato Teflon".</segment>
    <segment id="118">Em vez disso</segment>
    <segment id="119">, tiveram mais força seu slogan "</segment>
    <segment id="120">Scholz resolve" e suas investidas explícitas para</segment>
    <segment id="121">sese mostrar</segment>
    <segment id="122">comocomo o herdeiro do estilo Merkel de governar.</segment>
    <segment id="123">Numa delas</segment>
    <segment id="124">, posou para uma capa de revista imitando o gesto de mãos em forma de losango que é marca registrada de sua chefe.</segment>
    <segment id="125">Gesto de losango com as mãos é marca de Angela MerkelMais    novamente         de   de  de  representando um  Em outra</segment>
    <segment id="126">, lançou um cartaz de propaganda no qual</segment>
    <segment id="127">, sobre sua foto</segment>
    <segment id="128">, sese lê:</segment>
    <segment id="129">"</segment>
    <segment id="130">Ele pode ser primeira-ministra"</segment>
    <segment id="131">, empregando de propósito o gênero feminino.</segment>
    <segment id="132">Scholz é admirador do filósofo americano Michael Sandel</segment>
    <segment id="133">, um dos principais críticos da meritocracia</segment>
    <segment id="134">, apresentada</segment>
    <segment id="135">comocomo um sistema que mantém privilégios e mina a coesão social.</segment>
    <segment id="136">A visão casa bem com a carreira trabalhista de Scholz</segment>
    <segment id="137">, que em entrevista em 2008 já chamava de cínica a afirmação de que muitos desempregados preferem ficar em casa a aceitar um emprego de menor nível.  "Milhões de pessoas neste país ganham pouco</segment>
    <segment id="138">, muito pouco e ainda vão trabalhar todos os dias</segment>
    <segment id="139">, muitas vezes pelo resto de suas vidas.</segment>
    <segment id="140">Para mim</segment>
    <segment id="141">, esses são os verdadeiros heróis do nosso tempo"</segment>
    <segment id="142">, afirmou à revista Stern.</segment>
    <segment id="143">Na campanha</segment>
    <segment id="144">, ressaltou a importância de enfermeiros</segment>
    <segment id="145">, cuidadores</segment>
    <segment id="146">, motoristas</segment>
    <segment id="147">, caixas de supermercado e entregadores e prometeu elevar seus rendimentos.</segment>
    <segment id="148">"</segment>
    <segment id="149">Nossa sociedade está construída sobre os ombros de quem trabalha duro e ainda</segment>
    <segment id="150">sese beneficia muito pouco de uma recuperação econômica" foi uma de suas frases.</segment>
    <segment id="151">Scholz disse em entrevistas que é um engano achar que é apenas por "mérito" que as classes mais altas obtêm sucesso e que</segment>
    <segment id="152">, como</segment>
    <segment id="153">como resultado</segment>
    <segment id="154">, "aqueles que realmente mantêm o show na estrada não recebem o respeito que merecem".</segment>
    <segment id="155">Fotos marcantes da primeira-ministra alemã</segment>
    <segment id="156">, Angela MerkelMais    novamente         de   de  de  representando um  ​Nos debates</segment>
    <segment id="157">, apareceu sempre mais tranquilo e controlado que seus dois principais concorrentes</segment>
    <segment id="158">, Armin Laschet</segment>
    <segment id="159">, 60, da União</segment>
    <segment id="160">, e Annalena Baerbock</segment>
    <segment id="161">, 40, dos Verdes.</segment>
    <segment id="162">Com 1,70 metro</segment>
    <segment id="163">, corpo em forma de quem pratica remo e corrida assiduamente e os cabelos que lhe restam raspados</segment>
    <segment id="164">, Scholz parece confortável nos costumeiros paletó e camisa social sem gravata.</segment>
    <segment id="165">Sua fala é suave e séria</segment>
    <segment id="166">, masmas ele sorri com frequência</segment>
    <segment id="167">, o que chegou a irritar um de seus adversários políticos</segment>
    <segment id="168">, o líder da CSU</segment>
    <segment id="169">, Markus Söder.</segment>
    <segment id="170">"Não fique aí sentado com esse sorriso de Smurf"</segment>
    <segment id="171">, lhe disse o governador da Baviera durante reuniões sobre a crise da pandemia.</segment>
    <segment id="172">Scholz disse ter gostado da comparação com as criaturas azuis criadas pelo cartunista belga Peyo.</segment>
    <segment id="173">"</segment>
    <segment id="174">Eles são pequenos</segment>
    <segment id="175">, astutos e sempre ganham"</segment>
    <segment id="176">, retrucou</segment>
    <segment id="177">, segundo o site jornalístico Politico.</segment>
    <segment id="178">Em mais uma semelhança com Merkel</segment>
    <segment id="179">, Scholz é discreto sobre sua vida pessoal.</segment>
    <segment id="180">Desde 1998</segment>
    <segment id="181">, está casado com Britta Ernst</segment>
    <segment id="182">, que ele conheceu no SPD e é hoje secretária da Educação de Brandemburgo.</segment>
    <segment id="183">O casal decidiu não ter filhos.</segment>
    <segment id="184">Quando lhe perguntaram durante a campanha</segment>
    <segment id="185">sese Britta continuaria trabalhando</segment>
    <segment id="186">casocaso ele</segment>
    <segment id="187">sese torne premiê</segment>
    <segment id="188">, respondeu: "</segment>
    <segment id="189">A pergunta mostra o quanto nossa sociedade está longe da igualdade".</segment>
  </rst>
</analysis>