    <segment id="131">Bom Trabalho" ("</segment>
    <segment id="132">Beau Travail"</segment>
    <segment id="133">, 1998)</segment>
    <segment id="134">Galoup (Denis Lavant)</segment>
    <segment id="135">, um ex-oficial da Legião Estrangeira</segment>
    <segment id="136">, relembra o tempo que passou no golfo de Djibouti e a chegada desestabilizante de um novo soldado</segment>
    <segment id="137">, Sentain (Grégoire Colin).</segment>
    <segment id="138">Filmicca e Sesc Digital (grátis)</segment>
