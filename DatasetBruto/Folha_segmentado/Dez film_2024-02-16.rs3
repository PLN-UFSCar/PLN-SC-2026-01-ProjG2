    <segment id="114">"2001: Uma Odisseia no Espaço" ("2001:</segment>
    <segment id="115">A Space Odissey"</segment>
    <segment id="116">, 1968)</segment>
    <segment id="117">Uma equipe de astronautas é enviada para investigar a origem de um misterioso artefato encontrado na Lua.</segment>
    <segment id="118">No caminho</segment>
    <segment id="119">, o supercomputador HAL 9000</segment>
    <segment id="120">, que controla a espaçonave</segment>
    <segment id="121">, começa a</segment>
    <segment id="122">sese comportar de maneira estranha.  ClaroTV+</segment>
    <segment id="123">; Microsoft</segment>
