  <rst>
    <segment id="1">Ao fim de um 2020 de frustrações</segment>
    <segment id="2">, com o circuito mundial cancelado pela pandemia do novo coronavírus</segment>
    <segment id="3">, o surfe começa sua temporada 2021 em tom de otimismo.</segment>
    <segment id="4">A Covid-19 ainda é uma realidade e oferece desafios</segment>
    <segment id="5">, porém</segment>
    <segment id="6">porém tem início nesta semana o que promete ser um período histórico para a modalidade.</segment>
    <segment id="7">Ajustado em uma situação atípica</segment>
    <segment id="8">, o calendário do próximo ano será inaugurado oficialmente com a primeira etapa feminina da Liga Mundial</segment>
    <segment id="9">, em Maui</segment>
    <segment id="10">, no Havaí</segment>
    <segment id="11">, a partir desta sexta-feira (4).</segment>
    <segment id="12">O ponto alto serão os Jogos de Tóquio</segment>
    <segment id="13">, entre julho e agosto</segment>
    <segment id="14">, os primeiros a incluírem o esporte no programa olímpico.</segment>
    <segment id="15">As brasileiras que lutam por medalha olímpica nas ondas do Japão   novamente         de   de  de  representando um</segment>
    <segment id="16">A presença no tradicional evento é motivo de festa para os surfistas</segment>
    <segment id="17">, que vislumbram uma exposição inédita e uma também inédita luta por medalhas.</segment>
    <segment id="18">Entre os homens</segment>
    <segment id="19">, os representantes do Brasil no Japão serão Italo Ferreira e Gabriel Medina.</segment>
    <segment id="20">As mulheres de verde-amarelo serão Silvana Lima e Tatiana Weston-Webb.</segment>
    <segment id="21">As duas veem a Olimpíada</segment>
    <segment id="22">comocomo uma chance para o surfe crescer no mundo e uma grande oportunidade em suas carreiras.</segment>
    <segment id="23">A disputa em Chiba</segment>
    <segment id="24">, a cerca de 60 quilômetros de Tóquio</segment>
    <segment id="25">, ficará marcada na história</segment>
    <segment id="26">, e os vencedores do campeonato na praia de Tsurigasaki terão seus nomes sempre lembrados</segment>
    <segment id="27">comocomo os primeiros campeões olímpicos.</segment>
    <segment id="28">No caso</segment>
    <segment id="29">caso de Silvana</segment>
    <segment id="30">, todo o trabalho é voltado justamente para os Jogos.</segment>
    <segment id="31">A experiente cearense de 36 anos</segment>
    <segment id="32">, vice-campeã mundial em 2008 e em 2009</segment>
    <segment id="33">, viveu um 2019 difícil</segment>
    <segment id="34">, em recuperação de cirurgias nos joelhos</segment>
    <segment id="35">, e acabou rebaixada da elite –</segment>
    <segment id="36">embora</segment>
    <segment id="37">embora tenha conseguido resultados suficientes para ir ao Japão.</segment>
    <segment id="38">Ela não está</segment>
    <segment id="39">, portanto</segment>
    <segment id="40">, no Havaí</segment>
    <segment id="41">, para o início do circuito de 2021.</segment>
    <segment id="42">Sua ideia é</segment>
    <segment id="43">sese dedicar ao WQS</segment>
    <segment id="44">, a segunda divisão mundial</segment>
    <segment id="45">, e planejar sua temporada de maneira a chegar à Olimpíada na melhor forma possível.</segment>
    <segment id="46">“Vai ser o maior evento de todos os tempos para mim.</segment>
    <segment id="47">Superimportante.</segment>
    <segment id="48">Então, meu treino tem o foco na Olimpíada.</segment>
    <segment id="49">Por causa da pandemia</segment>
    <segment id="50">, tive um ano para treinar</segment>
    <segment id="51">, tempo para me recuperar.</segment>
    <segment id="52">Estou sem dores no joelho e trabalhando para estar mais do que 100% nos Jogos”</segment>
    <segment id="53">, afirmou à Folha.</segment>
    <segment id="54">Silvana</segment>
    <segment id="55">sese vê em condições de ter bons resultados - Thiago Diz - 19.jun.19/WSL via Getty ImagesA recuperação física não é seu único trunfo na tentativa de voltar a apresentar o desempenho que a colocou entre as melhores do planeta.</segment>
    <segment id="56">Também alimenta sua confiança o tipo de onda que será visto em Chiba</segment>
    <segment id="57">, familiar aos brasileiros.</segment>
    <segment id="58">“</segment>
    <segment id="59">Com certeza</segment>
    <segment id="60">, o Japão é bom para o Brasil</segment>
    <segment id="61">, porque</segment>
    <segment id="62">porque a onda é bem parecida com as do Nordeste e também com algumas do Sul.</segment>
    <segment id="63">É uma onda pequena</segment>
    <segment id="64">, ‘beach break’</segment>
    <segment id="65">, e a gente está acostumado no Brasil a surfar assim.</segment>
    <segment id="66">Só quando estiver lá</segment>
    <segment id="67">, com a cabeça boa e a prancha mágica</segment>
    <segment id="68">, a gente vai saber quem vai merecer.</segment>
    <segment id="69">Mas, com certeza</segment>
    <segment id="70">, o Brasil tem grande chance”</segment>
    <segment id="71">, disse a cearense de Paracuru.</segment>
    <segment id="72">Já Tatiana Weston-Webb não tem tanta experiência nessas ondas.</segment>
    <segment id="73">A gaúcha de Porto Alegre deixou o país ainda bebê e cresceu no Havaí</segment>
    <segment id="74">, habituada a um mar diferente.</segment>
    <segment id="75">Porém ela também alimenta a esperança de uma temporada vitoriosa</segment>
    <segment id="76">, tanto nos Jogos de Tóquio quanto na própria Liga Mundial.</segment>
    <segment id="77">Sexta colocada no ranking em 2019</segment>
    <segment id="78">, a brasileira de 24 anos aproveitou a paralisação das competições para remodelar seu surfe</segment>
    <segment id="79">, agora treinada pelo ex-surfista havaiano Ross Williams.</segment>
    <segment id="80">Ela teve tempo para</segment>
    <segment id="81">sese recuperar de velhos problemas físicos e testar equipamentos diferentes.</segment>
    <segment id="82">Tatiana está ansiosa para testar seu novo surfe - Matt Dunbar - 16.mai.19/WSL via</segment>
    <segment id="83">Getty Images“Estou morrendo de saudade de competir!</segment>
    <segment id="84">Trabalhei muito fortemente em algumas coisas que nunca tive oportunidade de mudar na carreira.</segment>
    <segment id="85">Mudei minhas pranchas e o tipo de treino que faço.</segment>
    <segment id="86">Estou muito animada para colocar tudo isso em prática.</segment>
    <segment id="87">Estou amarradão para ver”</segment>
    <segment id="88">, disse à Folha</segment>
    <segment id="89">, em um simpático esforço para falar português da melhor maneira.</segment>
    <segment id="90">Tatiana é filha da “bodyboarder” brasileira Tanira Guimarães e sempre manteve laços com o Brasil</segment>
    <segment id="91">, masmas cresceu no Havaí e tem uma natural dificuldade com o idioma.</segment>
    <segment id="92">Ela competia sob a bandeira do Havaí até 2018</segment>
    <segment id="93">, quando decidiu surfar</segment>
    <segment id="94">comocomo brasileira e assim conquistou sua vaga em Tóquio.</segment>
    <segment id="95">“</segment>
    <segment id="96">É uma honra representar a bandeira brasileira.</segment>
    <segment id="97">Espero conquistar um ouro pela nação do Brasil.</segment>
    <segment id="98">O Brasil está no fundo do meu coração</segment>
    <segment id="99">, sempre foi assim.</segment>
    <segment id="100">Sempre fez parte da minha vida e agora é parte da minha profissão.</segment>
    <segment id="101">Estou supergrata</segment>
    <segment id="102">, é uma honra”</segment>
    <segment id="103">, afirmou Tatiana.</segment>
    <segment id="104">Noiva do surfista brasileiro</segment>
    <segment id="105">Jessé Mendes</segment>
    <segment id="106">, a gaúcha tem planos de morar com ele no Brasil durante metade do ano</segment>
    <segment id="107">, ficando a outra metade na ilha de Kauai</segment>
    <segment id="108">, no Havaí.</segment>
    <segment id="109">Ela vem recebendo o apoio logístico do COB (Comitê Olímpico Brasileiro) e espera retribuir com uma grande temporada.</segment>
    <segment id="110">“Tenho dois grandes objetivos: o título mundial e o ouro na Olimpíada.</segment>
    <segment id="111">Vai ser o primeiro ano com tudo isso e a pressão está em alto nível</segment>
    <segment id="112">, masmas estou me sentindo muito bem</segment>
    <segment id="113">, meu surfe está evoluindo e meu equipamento está perfeito.</segment>
    <segment id="114">Então, bora lá!</segment>
    <segment id="115">Acho que vai ser uma boa challenge”</segment>
    <segment id="116">, sorriu</segment>
    <segment id="117">, misturando idiomas para descrever o desafio.</segment>
    <segment id="118">Tatiana veste com orgulho as cores do Brasil - Jackson Van Kirk - 20.set.19/WSL via</segment>
    <segment id="119">Getty ImagesEsse desafio começa em um local que ela conhece bem</segment>
    <segment id="120">, Maui</segment>
    <segment id="121">, em uma etapa cuja mera realização já é comemorada pela WSL (Liga Mundial de Surfe).</segment>
    <segment id="122">Com atletas de várias partes do mundo</segment>
    <segment id="123">, a organização do campeonato teve um trabalho inédito de negociação com os governos dos países que receberão as pernas da disputa</segment>
    <segment id="124">, acertando protocolos de fronteira e de testagem de Covid-19.</segment>
    <segment id="125">Como ocorre desde 2019</segment>
    <segment id="126">, o valor da premiação das etapas da primeira divisão é igualitário para homens e mulheres.</segment>
    <segment id="127">Essa passou a ser uma bandeira carregada pela liga</segment>
    <segment id="128">, o que</segment>
    <segment id="129">, para ela</segment>
    <segment id="130">, amplia o senso de justiça e o retorno com patrocinadores dispostos a</segment>
    <segment id="131">sese atrelar à causa.</segment>
    <segment id="132">“É uma decisão que veio para ficar</segment>
    <segment id="133">, não é algo que passou</segment>
    <segment id="134">, uma ideia que ficou para trás.</segment>
    <segment id="135">Ao contrário</segment>
    <segment id="136">, é algo em que a gente acredita</segment>
    <segment id="137">, algo inclusive que nos ajuda a nos conectar com marcas que compartilham desses valores conosco”</segment>
    <segment id="138">, disse à reportagem o executivo da WSL para a América Latina</segment>
    <segment id="139">, Ivan Martinho.</segment>
    <segment id="140">De acordo com ele</segment>
    <segment id="141">, isso representa apenas</segment>
    <segment id="142">“o primeiro passo”.</segment>
    <segment id="143">As etapas da segunda divisão –a maioria das quais é licenciada</segment>
    <segment id="144">, masmas não organizada pela WSL– ainda têm premiações distintas.</segment>
    <segment id="145">E existe uma grande diferença entre o número de homens e o de mulheres no circuito.</segment>
    <segment id="146">Há ainda quem critique a organização por não incluir a etapa de Pipeline</segment>
    <segment id="147">, onda do Havaí tida</segment>
    <segment id="148">comocomo a mais desafiadora do mundo</segment>
    <segment id="149">, na disputa feminina.</segment>
    <segment id="150">Porém as mulheres estão surfando em locais antes restritos aos homens</segment>
    <segment id="151">, como</segment>
    <segment id="152">como a também desafiadora onda do Taiti</segment>
    <segment id="153">, agora parte dos dois campeonatos.</segment>
    <segment id="154">Elas começarão a mostrar sua habilidade nesta semana.</segment>
    <segment id="155">Os homens darão início a seu circuito na próxima</segment>
    <segment id="156">, com Italo Ferreira defendendo seu título –e de olho</segment>
    <segment id="157">, como</segment>
    <segment id="158">como boa parte do mundo do surfe</segment>
    <segment id="159">, na aguardada oportunidade de fazer parte dos Jogos Olímpicos.</segment>
    <segment id="160">Etapas confirmadas da temporada 2021 da WSL  Maui</segment>
    <segment id="161">, Havaí (feminino) 4 a 15 de dezembro de 2020  Pipeline</segment>
    <segment id="162">, Oahu</segment>
    <segment id="163">, Havaí (masculino)</segment>
    <segment id="164">8 a 20 de dezembro de 2020  Sunset Beach</segment>
    <segment id="165">, Oahu</segment>
    <segment id="166">, Havaí 19 a 28 de janeiro de 2021  Santa Cruz</segment>
    <segment id="167">, Califórnia 2 a 12 de fevereiro de 2021  Bells Beach</segment>
    <segment id="168">, Austrália 1º a 11 de abril de 2021  Margaret River</segment>
    <segment id="169">, Austrália 16 a 26 de abril de 2021  Gold Coast</segment>
    <segment id="170">, Austrália 3 a 13 de maio de 2021  Saquarema</segment>
    <segment id="171">, Rio de Janeiro 11 a 20 de junho de 2021  J-Bay</segment>
    <segment id="172">, África do Sul 25 de junho a 9 de julho de 2021  Surf Ranch Pro</segment>
    <segment id="173">, Califórnia 12 a 15 de agosto de 2021  Teahupo'o</segment>
    <segment id="174">, Taiti 23 de agosto a 2 de setembro de 2021</segment>
    <segment id="175">The WSL Finals: Trestles</segment>
    <segment id="176">, Califórnia 8 a 17 de setembro de 2021</segment>
    <segment id="177">Surfe na Olimpíada de Tóquio</segment>
    <segment id="178">Janela de competições prevista de 25 de julho a 1º de agosto de 2021</segment>
  </rst>
</analysis>