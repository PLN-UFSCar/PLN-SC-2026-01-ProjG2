  <rst>
    <segment id="1">A primeira-dama Rosângela da Silva</segment>
    <segment id="2">, a Janja</segment>
    <segment id="3">, soltou a voz no casamento do senador Randolfe Rodrigues (sem partido-AP) com a advogada</segment>
    <segment id="4">Priscila Carnaúba</segment>
    <segment id="5">, realizado em Brasília</segment>
    <segment id="6">, na sexta-feira (28).</segment>
    <segment id="7">Os cantores Caetano Veloso e Orlando Morais ao lado da primeira-dama Rosângela da Silva</segment>
    <segment id="8">, a Janja</segment>
    <segment id="9">, em festa de casamento do senador Randolfe Rodrigues (sem partido-AP)</segment>
    <segment id="10">, em Brasília - @orlandomorais62 no InstagramOs cantores Caetano Veloso e Orlando Morais faziam um dueto de "</segment>
    <segment id="11">Como Nossos Pais"</segment>
    <segment id="12">, composição de Belchior consagrada na voz de Elis Regina</segment>
    <segment id="13">, quando Janja</segment>
    <segment id="14">, que entoava os versos desde a primeira fila da plateia</segment>
    <segment id="15">, foi chamada a</segment>
    <segment id="16">sese juntar a eles.</segment>
    <segment id="17">"</segment>
    <segment id="18">Vem, Janja"</segment>
    <segment id="19">, disse Morais.</segment>
    <segment id="20">Ao final da performance</segment>
    <segment id="21">, o trio foi aplaudido.</segment>
    <segment id="22">"</segment>
    <segment id="23">Eu morri</segment>
    <segment id="24">, masmas passo bem"</segment>
    <segment id="25">, disse a primeira-dama</segment>
    <segment id="26">, sorridente.</segment>
    <segment id="27">Em seguida</segment>
    <segment id="28">, ela recebeu um cumprimento de Caetano Veloso.</segment>
    <segment id="29">Janja e o presidente Luiz Inácio Lula da Silva (PT) foram padrinhos do casamento de Randolfe</segment>
    <segment id="30">, assim</segment>
    <segment id="31">comocomo Caetano e a produtora Paula Lavigne.</segment>
    <segment id="32">"</segment>
    <segment id="33">Viver no mesmo tempo de Lula e Caetano Veloso já é</segment>
    <segment id="34">, por si só</segment>
    <segment id="35">, um presente</segment>
    <segment id="36">, masmas poder desfrutar de suas amizades é uma honra"</segment>
    <segment id="37">, escreveu o senador</segment>
    <segment id="38">, nas redes sociais.</segment>
    <segment id="39">"</segment>
    <segment id="40">Além de serem tudo isso</segment>
    <segment id="41">, ainda me dão o privilégio de ter</segment>
    <segment id="42">comocomo madrinhas as minhas amigas Janja e Paula Lavigne.</segment>
    <segment id="43">Jamais esqueceremos este dia"</segment>
    <segment id="44">, finalizou.  com BIANKA VIEIRA (interina)</segment>
    <segment id="45">, KARINA MATIAS e MANOELLA SMITH</segment>
  </rst>
