  <rst>
    <segment id="1">O senador Romário (PL) mantém liderança folgada na disputa pela vaga para o Senado pelo Rio de Janeiro</segment>
    <segment id="2">, segundo pesquisa divulgada nesta quinta-feira (22) pelo Datafolha.</segment>
    <segment id="3">Ele tem 31% da preferência dos entrevistados</segment>
    <segment id="4">, mesmo percentual registrado nos três levantamentos anteriores.</segment>
    <segment id="5">O senador Romário (PL-RJ) em reunião da Comissão de Assuntos Sociais (CAS) do Senado</segment>
    <segment id="6">, em Brasília - Edilson Rodrigues - 20.fev.19/Agência SenadoO levantamento mostrou ainda que</segment>
    <segment id="7">, às portas da eleição</segment>
    <segment id="8">, 24% dos entrevistados ainda não têm candidato ao Senado.</segment>
    <segment id="9">Os adversários mais próximos de Romário apresentaram oscilações dentro da margem de erro de três pontos percentuais</segment>
    <segment id="10">, para mais ou para menos.  Alessandro Molon (PSB) aparece com 12%</segment>
    <segment id="11">, em empate técnico com Clarissa Garotinho (União Brasil)</segment>
    <segment id="12">, que alcançou 10% no levantamento.</segment>
    <segment id="13">Enquanto Molon oscilou um ponto para baixo</segment>
    <segment id="14">, Clarissa oscilou dois para cima na pesquisa.</segment>
    <segment id="15">O deputado federal Daniel Silveira (PTB) foi citado por 8%</segment>
    <segment id="16">, ante 6% do levantamento anterior</segment>
    <segment id="17">, enquanto Cabo Daciolo (PDT) atingiu 6% agora (7% no levantamento passado).</segment>
    <segment id="18">O presidente da Assembleia Legislativa</segment>
    <segment id="19">, André Ceciliano (PT)</segment>
    <segment id="20">, também teve 6%</segment>
    <segment id="21">, seguido por Bárbara Sinedino (PSTU)</segment>
    <segment id="22">, com 1%.</segment>
    <segment id="23">Eleições</segment>
    <segment id="24">2022Um resumo com o que de mais importante a Folha destaca sobre a eleiçãoCarregando...</segment>
    <segment id="25">O levantamento</segment>
    <segment id="26">, contratado pela Folha e pela TV Globo</segment>
    <segment id="27">, foi realizado de terça-feira (20) a quinta (22) e entrevistou 1.526 eleitores no estado.</segment>
    <segment id="28">A pesquisa está registrada no TSE sob o número RJ-07687/2022.</segment>
    <segment id="29">Segundo o levantamento</segment>
    <segment id="30">, 13% dos eleitores afirmam que votarão nulo ou em branco</segment>
    <segment id="31">, enquanto outros 11% não sabem em quem votarão.</segment>
    <segment id="32">Os demais candidatos —Professor Helvio Costa (DC)</segment>
    <segment id="33">, Raul (UP)</segment>
    <segment id="34">, Itagiba (Avante)</segment>
    <segment id="35">, Antônio Hermano (PCO)</segment>
    <segment id="36">, Hiran Roedel (PCB) e Sued Haidar (PMB)— foram citados</segment>
    <segment id="37">, masmas não alcançaram 1% das menções.</segment>
    <segment id="38">Leia mais sobre a pesquisa nos estados Haddad tem 34%</segment>
    <segment id="39">, e Tarcísio</segment>
    <segment id="40">sese isola em 2º com 23% em SP</segment>
    <segment id="41">Rejeição a Haddad sobe</segment>
    <segment id="42">, e 39% dizem não votar nele de jeito nenhumFrança (31%) lidera disputa ao Senado por SP</segment>
    <segment id="43">;</segment>
    <segment id="44">Marcos Pontes sobe para 19% Castro vai a 36% e abre vantagem sobre Freixo (26%) no Rio Zema cai</segment>
    <segment id="45">, e diferença para Kalil recua de 28 para 20 pontos em Minas Romário (31%) lidera corrida ao Senado no RJ</segment>
    <segment id="46">;</segment>
    <segment id="47">24% não têm candidato</segment>
    <segment id="48">Cleitinho lidera corrida ao Senado em MG</segment>
    <segment id="49">;</segment>
    <segment id="50">28% não sabem em quem votar</segment>
  </rst>
