  <rst>
    <segment id="1">​O Airbnb lançou</segment>
    <segment id="2">, neste mês</segment>
    <segment id="3">, 15 passeios turísticos guiados por moradores de Porto Seguro</segment>
    <segment id="4">, no sul da Bahia.</segment>
    <segment id="5">Vendidas por meio da plataforma</segment>
    <segment id="6">, as atividades vão desde uma visita a uma aldeia pataxó até uma aula de forró na vila de Caraíva</segment>
    <segment id="7">, a 62 quilômetros do centro do município.</segment>
    <segment id="8">Além do serviço de aluguel de imóveis por temporada</segment>
    <segment id="9">, o site ainda oferece o que chama de experiências —nas quais um morador pode guiar um turista em alguma atividade pelo destino.</segment>
    <segment id="10">A ideia é atender aos viajantes que desejam conhecer melhor</segment>
    <segment id="11">comocomo vivem os locais.</segment>
    <segment id="12">Experiências oferecidas pelo Airbnb em Porto Seguro   novamente         de   de  de  representando um</segment>
    <segment id="13">Em Porto Seguro</segment>
    <segment id="14">, o Airbnb</segment>
    <segment id="15">, pela primeira vez no Brasil</segment>
    <segment id="16">, participou ativamente da elaboração de experiências.</segment>
    <segment id="17">A empresa identificou moradores que poderiam proporcionar bons passeios e os capacitou para organizá-los.</segment>
    <segment id="18">Entre eles</segment>
    <segment id="19">, estão a agrônoma Juliana Dória</segment>
    <segment id="20">, que passou a receber visitantes em sua fazenda de açaí e cupuaçu</segment>
    <segment id="21">, e o artesão Dionísio Chile</segment>
    <segment id="22">, que agora mostra aos turistas</segment>
    <segment id="23">, em seu ateliê</segment>
    <segment id="24">, como</segment>
    <segment id="25">como ele produz biojoias com cocos</segment>
    <segment id="26">, sementes e ossos.</segment>
    <segment id="27">Para apresentar as 15 experiências</segment>
    <segment id="28">, foram criados dois guias</segment>
    <segment id="29">, um que reúne as atividades em Trancoso e outro</segment>
    <segment id="30">, em Caraíva —os dois locais são distritos de Porto Seguro.</segment>
    <segment id="31">A iniciativa é resultado de uma parceria da plataforma com a prefeitura da cidade.</segment>
  </rst>
</analysis>