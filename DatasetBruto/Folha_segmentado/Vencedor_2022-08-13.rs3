  <rst>
    <segment id="1">O Realness Festival reúne na noite deste sábado (13) alguns dos principais nomes do universo drag e da comunidade LGBTQIA+.</segment>
    <segment id="2">As americanas Alaska Thunderfuck e Kylie Sonique</segment>
    <segment id="3">, vencedoras do reality show "RuPaul's Drag Race: All Stars"</segment>
    <segment id="4">, fazem show na Audio (zona oeste de São Paulo).</segment>
    <segment id="5">O evento quer ser um dos maiores festivais drag da América Latina e ainda conta com personagens</segment>
    <segment id="6">comocomo Jujubee</segment>
    <segment id="7">, Trinity K Bonet</segment>
    <segment id="8">, Denali Foxx</segment>
    <segment id="9">, Tatianna</segment>
    <segment id="10">, Rajah</segment>
    <segment id="11">O' Hara</segment>
    <segment id="12">, Roxxxy Andrews</segment>
    <segment id="13">, que fizeram sucesso no programa.</segment>
    <segment id="14">Os ingressos estão disponíveis no site da Sympla</segment>
    <segment id="15">, com preços que variam de R$ 140 a R$ 585.</segment>
    <segment id="16">Festival traz vencedoras de RuPauls</segment>
    <segment id="17">Drag Race para shows no Brasil</segment>
    <segment id="18">; na foto</segment>
    <segment id="19">, a drag Kylie Sonique - VH1/DivulgaçãoNa edição do Emmy Awards de setembro do ano passado</segment>
    <segment id="20">, a 13ª temporada de "</segment>
    <segment id="21">RuPaul's Drag Race" ganhou o prêmio de melhor série de competição e levou RuPaul a ser o maior vencedor negro de troféus do Emmy</segment>
    <segment id="22">, com 11 ao todo.</segment>
    <segment id="23">Finalista da quinta temporada de "</segment>
    <segment id="24">RuPaul's Drag Race" e vencedora da segunda edição do spin-off "All Stars"</segment>
    <segment id="25">, Alaska Thunderfuck já veio ao Brasil e tem uma relação de carinho com os fãs do Brasil.</segment>
    <segment id="26">Da última vez que esteve no país</segment>
    <segment id="27">, inclusive</segment>
    <segment id="28">, a drag gravou o clipe da faixa "Come To Brazil"</segment>
    <segment id="29">, que já conta com quase 6 milhões de visualizações no YouTube.</segment>
    <segment id="30">Confira os vencedores do Emmy 2021</segment>
    <segment id="31">, marcado por acirrada disputa entre Netflix e HBO Mais    novamente         de   de  de  representando um</segment>
    <segment id="32">A cantora volta ao país para apresentar faixas dos álbuns "Anus" (2015)</segment>
    <segment id="33">", "Poundcake" (2016)</segment>
    <segment id="34">" e "Vagina" (2018)</segment>
    <segment id="35">, além de surpresas que prepara para seus fãs</segment>
    <segment id="36">.</segment>
    <segment id="37">Já Kylie Sonique</segment>
    <segment id="38">, vencedora da sexta edição da versão "All Stars"</segment>
    <segment id="39">, vem ao Brasil pela primeira vez.</segment>
    <segment id="40">Além das apresentações em lipsync -técnica de sincronia labial</segment>
    <segment id="41">, uma espécie de dublagem- que a consagrou no programa</segment>
    <segment id="42">, a drag também apresenta canções autorais</segment>
    <segment id="43">comocomo as recém-lançadas "Do It Like Dolly" e "Complete Me".</segment>
    <segment id="44">Criado para propagar e celebrar a cultura drag e LGBTQIA+</segment>
    <segment id="45">, o The Realness nasceu em 2017</segment>
    <segment id="46">comocomo uma festa com 12 edições em São Paulo e no Rio.</segment>
    <segment id="47">Após a pandemia</segment>
    <segment id="48">, a aposta é receber um público em um grande festival</segment>
    <segment id="49">, diz a organização.</segment>
    <segment id="50">The Realness Festival 2022</segment>
    <segment id="51">Quando: 13 de agosto</segment>
    <segment id="52">Onde: Audio – av. Francisco Matarazzo</segment>
    <segment id="53">, 694, Barra Funda</segment>
    <segment id="54">, zona oeste</segment>
    <segment id="55">, São Paulo</segment>
    <segment id="56">Quanto: R$ 140 a R$ 585 Mais informação: sympla.com.br</segment>
  </rst>
</analysis>