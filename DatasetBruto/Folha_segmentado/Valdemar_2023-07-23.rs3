  <rst>
    <segment id="1">O presidente do PL</segment>
    <segment id="2">, Valdemar Costa Neto</segment>
    <segment id="3">, disse em entrevista à Folha que Jair Bolsonaro é perseguido pelo TSE (Tribunal Superior Eleitoral) e insinua que Alexandre de Moraes</segment>
    <segment id="4">, presidente da corte</segment>
    <segment id="5">, provoca os apoiadores do ex-presidente com suas decisões.</segment>
    <segment id="6">"</segment>
    <segment id="7">Aí vão julgar o Bolsonaro</segment>
    <segment id="8">, tem tantos dias para escolher do mês</segment>
    <segment id="9">, ele escolhe o dia 22 [número do PL].</segment>
    <segment id="10">Isso, o cara do PL</segment>
    <segment id="11">, da direita</segment>
    <segment id="12">, que fez isso com ele [agrediu Moraes] lá na Itália</segment>
    <segment id="13">, acompanha.</segment>
    <segment id="14">Esse é o problema.</segment>
    <segment id="15">Não somos nós que fazemos campanha contra ele.</segment>
    <segment id="16">Ele [o apoiador de Bolsonaro] vê um negócio desse e não</segment>
    <segment id="17">sese conforma.</segment>
    <segment id="18">"</segment>
    <segment id="19">Valdemar ainda afirma que Bolsonaro não tem esperanças de conseguir ser candidato até 2030</segment>
    <segment id="20">, masmas que o PL estuda recorrer a tribunais internacionais para reaver esse direito.</segment>
    <segment id="21">Avalia também que caberá a Bolsonaro escolher quem disputará a Presidência pela direita em 2026 e que ele mantém boa relação com o governador de São Paulo</segment>
    <segment id="22">, Tarcísio de Freitas (Republicanos).</segment>
    <segment id="23">O presidente do PL</segment>
    <segment id="24">, Valdemar Costa Neto</segment>
    <segment id="25">, durante entrevista à Folha em sua sala</segment>
    <segment id="26">, na sede do PL em Brasília.</segment>
    <segment id="27">- Pedro Ladeira/Folhapress</segment>
    <segment id="28">Alguns aliados dizem que o Bolsonaro é o maior cabo eleitoral do país.</segment>
    <segment id="29">O sr. prefere ele inelegível</segment>
    <segment id="30">, como</segment>
    <segment id="31">como cabo eleitoral?  Queria que fosse candidato de novo.</segment>
    <segment id="32">A presidente.</segment>
    <segment id="33">Fiquei triste com essa decisão do TSE.</segment>
    <segment id="34">Nunca aconteceu isso no planeta de deixar um cidadão inelegível</segment>
    <segment id="35">, que não tinha nem mandato.</segment>
    <segment id="36">Nunca.</segment>
    <segment id="37">Mas ele tem rejeição.</segment>
    <segment id="38">É… Ele teve um comportamento</segment>
    <segment id="39">, na minha opinião</segment>
    <segment id="40">, difícil com o Supremo</segment>
    <segment id="41">, masmas nunca fez nada errado.</segment>
    <segment id="42">Comportamento difícil ou golpista?</segment>
    <segment id="43">Não, não golpista.</segment>
    <segment id="44">Pelo contrário</segment>
    <segment id="45">, ele nunca fez nada fora da lei.</segment>
    <segment id="46">Ele exortou a não obediência de decisões judiciais.</segment>
    <segment id="47">E o pessoal ficou um tempo assustado.</segment>
    <segment id="48">Ele estava muito agitado antes e todo mundo achava que iria fazer alguma coisa no 7 de setembro retrasado.</segment>
    <segment id="49">Eu, inclusive</segment>
    <segment id="50">, achava que ele ia fazer.</segment>
    <segment id="51">E mesmo assim o sr. continuou a apoiá-lo.</segment>
    <segment id="52">Sim, mas</segment>
    <segment id="53">mas ele não fez nada.</segment>
    <segment id="54">Ele não falou que ia fazer alguma coisa</segment>
    <segment id="55">, a gente entendia que ia fazer.</segment>
    <segment id="56">E o Supremo deve ter ficado numa situação difícil</segment>
    <segment id="57">, [com medo] do que ele iria fazer.</segment>
    <segment id="58">Mas [ele] não fez nada errado.</segment>
    <segment id="59">No ano passado</segment>
    <segment id="60">, o sr. defendeu o ex-ministro da Justiça Anderson Torres e falou que todo mundo tinha minuta de golpe.</segment>
    <segment id="61">Todo mundo me parava no aeroporto e falava:</segment>
    <segment id="62">vão deixar esse presidente assumir?</segment>
    <segment id="63">Cada voo</segment>
    <segment id="64">, umas oito pessoas</segment>
    <segment id="65">, dez pessoas.</segment>
    <segment id="66">E eu dizia: acabou a eleição</segment>
    <segment id="67">, não temos mais o que discutir.</segment>
    <segment id="68">Leia tambémValdemar diz que Bolsonaro errou na Reforma Tributária</segment>
    <segment id="69">, masmas é quem dá a palavra final no PL</segment>
    <segment id="70">Até chegar a 8 de janeiro</segment>
    <segment id="71">, Bolsonaro colocou em xeque a lisura das urnas eletrônicas e o PL não só endossou</segment>
    <segment id="72">, como</segment>
    <segment id="73">como reforçou esse discurso.</segment>
    <segment id="74">Vocês fizeram uma auditoria questionando as urnas.</segment>
    <segment id="75">O sr. se</segment>
    <segment id="76">se arrepende?</segment>
    <segment id="77">Não.</segment>
    <segment id="78">Contratei [a auditoria]</segment>
    <segment id="79">porque</segment>
    <segment id="80">porque o próprio tribunal incentivava a gente a fiscalizar.</segment>
    <segment id="81">Consegui encontrar aquele pessoal do ITA [Instituto Tecnológico da Aeronáutica]</segment>
    <segment id="82">, que tinha uma fundação.</segment>
    <segment id="83">E eles chegaram com essa novidade para mim</segment>
    <segment id="84">, do primeiro para o segundo turno.</segment>
    <segment id="85">Aí eu questionei o TSE.</segment>
    <segment id="86">O Alexandre de Moraes não me respondeu nada e me deu uma multa de R$ 22</segment>
    <segment id="87">,9 milhões.</segment>
    <segment id="88">É isso que o pessoal da direita não</segment>
    <segment id="89">sese conforma.</segment>
    <segment id="90">Por isso que atacam ele [Alexandre].</segment>
    <segment id="91">Um partido levar uma multa dessa?</segment>
    <segment id="92">E R$ 22</segment>
    <segment id="93">,9 milhões</segment>
    <segment id="94">, que são dois mais dois</segment>
    <segment id="95">, mais nove</segment>
    <segment id="96">, que é o número 13</segment>
    <segment id="97">, do PT.</segment>
    <segment id="98">Que engraçadinho.</segment>
    <segment id="99">Eles devem achar muito gozado isso aqui.</segment>
    <segment id="100">Aí vão julgar o Bolsonaro</segment>
    <segment id="101">, tem tantos dias para escolher do mês</segment>
    <segment id="102">, ele escolhe o dia 22 [número do PL].</segment>
    <segment id="103">Isso, o cara do PL</segment>
    <segment id="104">, da direita</segment>
    <segment id="105">, que fez isso com ele [agrediu Moraes] lá na Itália</segment>
    <segment id="106">, acompanha.</segment>
    <segment id="107">Esse é o problema.</segment>
    <segment id="108">Não somos nós que fazemos campanha contra ele.</segment>
    <segment id="109">Ele [o apoiador de Bolsonaro] vê um negócio desse e não</segment>
    <segment id="110">sese conforma.</segment>
    <segment id="111">O sr. quer dizer que Moraes toma medidas autoritárias?</segment>
    <segment id="112">Isso não é [medida] autoritária</segment>
    <segment id="113">, é uma brincadeira.</segment>
    <segment id="114">Dois mais dois</segment>
    <segment id="115">, mais nove é igual a 13.</segment>
    <segment id="116">Número do PT.  Acha que ele pensou nisso?</segment>
    <segment id="117">E o 22</segment>
    <segment id="118">, você acha o quê?</segment>
    <segment id="119">Você não acha que ele pensou nisso?</segment>
    <segment id="120">Julgou Bolsonaro dia 22 no TSE.</segment>
    <segment id="121">Você acha que foi ao acaso?</segment>
    <segment id="122">O sr. vê Bolsonaro perseguido pelo Moraes?</segment>
    <segment id="123">Bolsonaro é perseguido</segment>
    <segment id="124">, lógico.</segment>
    <segment id="125">Foi perseguido pelo TSE</segment>
    <segment id="126">, foi injustiçado.</segment>
    <segment id="127">Ele jamais podia ficar inelegível.</segment>
    <segment id="128">Isso o camarada da direita vê.</segment>
    <segment id="129">Eles são esclarecidos</segment>
    <segment id="130">, gente de opinião.</segment>
    <segment id="131">FolhaJus+Receba no seu email as notícias sobre o cenário jurídico e conteúdos exclusivos: análise</segment>
    <segment id="132">, dicas e eventos</segment>
    <segment id="133">; exclusiva para assinantes.</segment>
    <segment id="134">Carregando...</segment>
    <segment id="135">O sr. chama de gente de opinião</segment>
    <segment id="136">, masmas o ministro Alexandre Moraes foi agredido e hostilizado</segment>
    <segment id="137">, na Itália.</segment>
    <segment id="138">Acho errado isso.</segment>
    <segment id="139">Tem que ter educação e respeito pelos outros</segment>
    <segment id="140">, ainda mais por autoridade.</segment>
    <segment id="141">Porque</segment>
    <segment id="142">, sese você não tiver respeito pela autoridade</segment>
    <segment id="143">, acaba o país.</segment>
    <segment id="144">Quem está errado então?</segment>
    <segment id="145">Eu acho que o TSE está agindo mal com o Bolsonaro por ter deixado ele inelegível.</segment>
    <segment id="146">O pessoal da direita acompanha isso.</segment>
    <segment id="147">E daí reage.</segment>
    <segment id="148">Bolsonaro deve sofrer novas derrotas depois de revés no TSEMais    novamente         de   de  de  representando um</segment>
    <segment id="149">O 8 de janeiro foi uma tentativa de golpe?</segment>
    <segment id="150">Ali não</segment>
    <segment id="151">, porque</segment>
    <segment id="152">porque ninguém dá golpe com um pedaço de pau na mão.</segment>
    <segment id="153">Golpe é com metralhadora</segment>
    <segment id="154">, com tanque de guerra.</segment>
    <segment id="155">Chamam de golpista o pessoal do 8 de janeiro e a maioria ficou gritando ‘não quebra’.</segment>
    <segment id="156">O PT que tinha que ter posto policiamento lá.</segment>
    <segment id="157">Gente ruim tem em todo lugar e essa gente tem que pagar.</segment>
    <segment id="158">Mas o comportamento do Bolsonaro não influenciou?</segment>
    <segment id="159">Não.  Vai ser possível retomar o direito de Bolsonaro</segment>
    <segment id="160">sese candidatar a presidente?</segment>
    <segment id="161">Não sei.</segment>
    <segment id="162">Estamos estudando agora outra forma para ver</segment>
    <segment id="163">sese tem algum órgão internacional.</segment>
    <segment id="164">Para o Bolsonaro</segment>
    <segment id="165">, está liquidado o assunto.</segment>
    <segment id="166">Ele falou ‘</segment>
    <segment id="167">Não adianta</segment>
    <segment id="168">, do jeito que estão as coisas</segment>
    <segment id="169">, esse pessoal vai me deixar impedido de ser candidato’.</segment>
    <segment id="170">Eu pedi para uma pessoa amiga fazer um estudo na área internacional</segment>
    <segment id="171">, sem consultar o Bolsonaro e sem gastar dinheiro também.</segment>
    <segment id="172">Eu acho que</segment>
    <segment id="173">sese a gente tivesse um lugar [fora] para recorrer</segment>
    <segment id="174">, conseguiria reverter.</segment>
    <segment id="175">FolhaJus DiaReceba no seu email a seleção diária das principais notícias jurídicas</segment>
    <segment id="176">; aberta para não assinantes.</segment>
    <segment id="177">Carregando...</segment>
    <segment id="178">Sem Bolsonaro</segment>
    <segment id="179">, qual é a chapa ideal?</segment>
    <segment id="180">Não tem hoje.</segment>
    <segment id="181">É muito longe.</segment>
    <segment id="182">O Tarcísio é um cara bom</segment>
    <segment id="183">, lógico.</segment>
    <segment id="184">Você tem também o [Romeu] Zema [governador de Minas Gerais</segment>
    <segment id="185">, do Novo].</segment>
    <segment id="186">É muito bom.</segment>
    <segment id="187">Agora precisa ver o que o Bolsonaro vai decidir.</segment>
    <segment id="188">Este é Valdemar Costa NetoMais    novamente         de   de  de  representando um  E a Michelle?</segment>
    <segment id="189">Na minha opinião</segment>
    <segment id="190">, sai de senadora</segment>
    <segment id="191">, iria bem em Brasília.</segment>
    <segment id="192">A Michelle é uma surpresa.</segment>
    <segment id="193">Ela está indo muito bem.</segment>
    <segment id="194">Onde ela vai</segment>
    <segment id="195">, bomba.</segment>
    <segment id="196">Eu brinco com o Bolsonaro</segment>
    <segment id="197">, ‘essa acertou sem querer.</segment>
    <segment id="198">Não foi escolha tua’.</segment>
    <segment id="199">Porque ela é completamente diferente dele.</segment>
    <segment id="200">Bolsonaro não liga para roupa</segment>
    <segment id="201">, para nada.</segment>
    <segment id="202">Se deixar</segment>
    <segment id="203">, ele come Miojo todo dia.</segment>
    <segment id="204">O presidente vai operar [o intestino]?</segment>
    <segment id="205">Acho que não.</segment>
    <segment id="206">Ele precisa</segment>
    <segment id="207">sese alimentar direito.</segment>
    <segment id="208">Nós temos que preservar o Bolsonaro</segment>
    <segment id="209">, porque</segment>
    <segment id="210">porque ele é uma máquina de votos e o partido vive disso.</segment>
    <segment id="211">O sr. apontou perspectivas positivas para o governo Lula.</segment>
    <segment id="212">Nesse cenário</segment>
    <segment id="213">, qual é a chance de uma outra candidatura ser competitiva?</segment>
    <segment id="214">Bolsonaro teve metade dos votos.</segment>
    <segment id="215">Com o que estão [Judiciário] fazendo com ele</segment>
    <segment id="216">, pode crescer.</segment>
    <segment id="217">Por exemplo</segment>
    <segment id="218">, vamos dizer que ele vai apoiar o Tarcísio.</segment>
    <segment id="219">Eu te garanto que muita mulher que não votou no Bolsonaro em São Paulo votará no Tarcísio para presidente</segment>
    <segment id="220">, porque</segment>
    <segment id="221">porque ele não carrega a rejeição.</segment>
    <segment id="222">Como está a relação entre Tarcísio e Bolsonaro hoje?</segment>
    <segment id="223">Está boa.</segment>
    <segment id="224">Bolsonaro vai dormir na semana que vem no Palácio dos Bandeirantes.</segment>
    <segment id="225">Ele adora o Tarcísio</segment>
    <segment id="226">, descobriu no próprio governo.</segment>
    <segment id="227">Ele pode ir para o PL?</segment>
    <segment id="228">Nunca conversamos sobre isso</segment>
    <segment id="229">, e nem é o momento.</segment>
    <segment id="230">Tem o desejo de filiá-lo?</segment>
    <segment id="231">Quem que não queria ter o Tarcísio?</segment>
    <segment id="232">Eu só não tive o Tarcísio antes</segment>
    <segment id="233">porque</segment>
    <segment id="234">porque eu não tive condições de assumir a campanha dele [em 2022]</segment>
    <segment id="235">, não tínhamos dinheiro.</segment>
    <segment id="236">Raio-X | Valdemar Costa Neto</segment>
    <segment id="237">, 73  É presidente do PL há 23 anos.</segment>
    <segment id="238">Natural de Mogi das Cruzes (SP)</segment>
    <segment id="239">, é formado em administração pela Universidade Braz Cubas (UBC).</segment>
    <segment id="240">Filho de Waldemar Costa Filho</segment>
    <segment id="241">, ex-prefeito de Mogi das Cruzes</segment>
    <segment id="242">, ocupou cargos públicos no município.</segment>
    <segment id="243">Posteriormente</segment>
    <segment id="244">, foi eleito seis vezes para uma vaga na Câmara dos Deputados.</segment>
    <segment id="245">Em 2013</segment>
    <segment id="246">, renunciou ao mandato de deputado após a Justiça determinar sua prisão</segment>
    <segment id="247">, depois de ele ter sido condenado por corrupção passiva e lavagem de dinheiro no</segment>
    <segment id="248">casocaso do mensalão.</segment>
    <segment id="249">Recebeu o perdão da pena em 2016.</segment>
  </rst>
</analysis>