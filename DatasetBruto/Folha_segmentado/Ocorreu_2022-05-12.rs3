  <rst>
    <segment id="1">Eles vão para a última curva</segment>
    <segment id="2">, foi na última no ano passado…</segment>
    <segment id="3">Hoje não</segment>
    <segment id="4">, hoje não</segment>
    <segment id="5">, hoje sim…</segment>
    <segment id="6">hoje sim.</segment>
    <segment id="7">Aconteceu há 20 anos uma das narrações mais emblemáticas da televisão brasileira</segment>
    <segment id="8">, que veio junto com um dos maiores emputecimentos de torcedores brasileiros em qualquer esporte.</segment>
    <segment id="9">Foi no GP da Áustria de F1 de 2002</segment>
    <segment id="10">, quando Rubens Barrichello pilotava uma Ferrari</segment>
    <segment id="11">, a outra era do alemão Michael Schumacher</segment>
    <segment id="12">; e quem narrava era Cleber Machado</segment>
    <segment id="13">, na Globo.</segment>
    <segment id="14">Àquela altura</segment>
    <segment id="15">, já haviam sido disputadas 5 das 17 corridas da temporada.</segment>
    <segment id="16">Schumacher tinha quatro vitórias —na verdade</segment>
    <segment id="17">, tinha cinco</segment>
    <segment id="18">, a outra era do mano Ralf.</segment>
    <segment id="19">Barrichello tinha feito a pole</segment>
    <segment id="20">, largou na frente e liderou praticamente do início ao fim.</segment>
    <segment id="21">Apontou na reta da 71ª e última volta para vencer</segment>
    <segment id="22">, e freou abruptamente</segment>
    <segment id="23">para que</segment>
    <segment id="24">para que Schumacher o ultrapassasse</segment>
    <segment id="25">, obedecendo assim uma ordem da escuderia italiana</segment>
    <segment id="26">, para desespero de Cleber e dos torcedores (incluindo este escriba).</segment>
    <segment id="27">"</segment>
    <segment id="28">Olha, é inacreditável</segment>
    <segment id="29">, não há nenhuma necessidade de a Ferrari fazer isso"</segment>
    <segment id="30">, emendou o narrador</segment>
    <segment id="31">, ainda indignado</segment>
    <segment id="32">, em 2002.</segment>
    <segment id="33">Barrichello (à dir.</segment>
    <segment id="34">)</segment>
    <segment id="35">freia no final e dá passagem a Schumacher - Leonhard Foerger - 12.mai.02/Reuters</segment>
    <segment id="36">Aquela corrida</segment>
    <segment id="37">, daquele jeito</segment>
    <segment id="38">, escancarou algo que muita gente sabia</segment>
    <segment id="39">, só não falava em voz alta.</segment>
    <segment id="40">Era como</segment>
    <segment id="41">como dizer o nome de Voldemort em "Harry Potter"</segment>
    <segment id="42">, você não fala para não atrair coisa ruim.</segment>
    <segment id="43">Mas muitas equipes</segment>
    <segment id="44">, principalmente quando brigam pelo título com outra</segment>
    <segment id="45">, sempre deram (e dão) ordem para a troca de posições.</segment>
    <segment id="46">O problema é que o brasileiro era um torcedor de F1 mal-acostumado</segment>
    <segment id="47">, achava que todo ano tinha que ter um piloto "nosso" brigando pelo título —culpa de Emerson Fittipaldi</segment>
    <segment id="48">, Nelson Piquet e Ayrton Senna.</segment>
    <segment id="49">Segundo lugar não era aceitável.</segment>
    <segment id="50">E ver um brasileiro forçadamente entregar o primeiro lugar era para muitos inaceitável.</segment>
    <segment id="51">O que tornou o ato da Ferrari ainda mais condenável foi a falta de competitividade da temporada de 2002.</segment>
    <segment id="52">A Ferrari dominava fácil</segment>
    <segment id="53">, no fim do ano perdeu apenas duas corridas.</segment>
    <segment id="54">Schumacher seria campeão com trocentos pontos de vantagem</segment>
    <segment id="55">, mesmo perdendo aquele GP.</segment>
    <segment id="56">Barrichello terminou aquele campeonato em segundo</segment>
    <segment id="57">, com Juan Pablo Montoya bem atrás</segment>
    <segment id="58">, em terceiro.</segment>
    <segment id="59">Parte da torcida brasileira não perdoou</segment>
    <segment id="60">, ou não entendeu</segment>
    <segment id="61">, masmas</segment>
    <segment id="62">, ao deixar Schumacher passar apenas na última reta</segment>
    <segment id="63">, Barrichello foi genial —talvez involuntariamente.</segment>
    <segment id="64">O pódio foi ainda mais bizarro</segment>
    <segment id="65">, com Schumacher completamente desconcertado</segment>
    <segment id="66">, vaiado</segment>
    <segment id="67">, dando o lugar ao brasileiro.  Schumacher</segment>
    <segment id="68">, constrangido</segment>
    <segment id="69">, pôs Barrichello no topo do pódio - Jean-Pierre Muller - 12.mai.02/AFP  ​Valtteri</segment>
    <segment id="70">Bottas foi companheiro de Lewis Hamilton durante anos.</segment>
    <segment id="71">Pois quantas vezes você viu Bottas brigar pela vitória contra o inglês com um campeonato em aberto?</segment>
    <segment id="72">Ou Pérez com Verstappen?</segment>
    <segment id="73">A F1 sempre foi e sempre será um campeonato com equipes para o benefício de um piloto.</segment>
    <segment id="74">Quando não foi</segment>
    <segment id="75">, a equipe pagou o preço</segment>
    <segment id="76">, como</segment>
    <segment id="77">como no campeonato de 1986</segment>
    <segment id="78">, quando Nelson Piquet e Nigel Mansell perderam para Alain Prost mesmo com um carro melhor que o do francês.</segment>
    <segment id="79">Entre os pilotos que não conseguiram um título na F1</segment>
    <segment id="80">, e são muitos</segment>
    <segment id="81">, Rubens Barrichello está entre os melhores</segment>
    <segment id="82">, assim</segment>
    <segment id="83">comocomo Felipe Massa…</segment>
    <segment id="84">E, 20 anos depois</segment>
    <segment id="85">, o Brasil não tem pilotos na principal categoria do automobilismo</segment>
    <segment id="86">, masmas Cleber Machado discute futebol e outros esportes em seu podcast</segment>
    <segment id="87">, "</segment>
    <segment id="88">Hoje Sim".    Atualização - Round 38</segment>
    <segment id="89">Após cinco rodadas de Brasileiro</segment>
    <segment id="90">, o Cuiabá tem 7 pontos</segment>
    <segment id="91">, à frente de Palmeiras</segment>
    <segment id="92">, Flamengo e Fortaleza</segment>
    <segment id="93">, para citar apenas times da Libertadores.</segment>
    <segment id="94">Está em 11º lugar</segment>
    <segment id="95">, posição que provavelmente deve garantir vaga para Champions League</segment>
    <segment id="96">, Copa do Mundo ou algo parecido.</segment>
    <segment id="97">Logo, o professor Pintado foi demitido.</segment>
    <segment id="98">Parece que ficaram chateados por lá com eliminações na Sul-Americana e na Copa do Brasil.</segment>
    <segment id="99">Assim, chegamos a seis demissões antes do início do round 6.</segment>
    <segment id="100">Demitidos: Brasileiros 5 x 1 Estrangeiros.</segment>
    <segment id="101">Sobreviventes: Brasileiros 7 x 8 Estrangeiros.</segment>
  </rst>
