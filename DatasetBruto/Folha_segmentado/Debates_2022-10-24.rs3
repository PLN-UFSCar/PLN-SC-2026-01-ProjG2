  <rst>
    <segment id="1">Neste longo e tenebroso outubro</segment>
    <segment id="2">, os debates com os presidenciáveis</segment>
    <segment id="3">, que deveriam ser sobre o melhor projeto de futuro para o país</segment>
    <segment id="4">, acabaram</segment>
    <segment id="5">sese transformando em um game show chamado Quem Roubou Menos?.</segment>
    <segment id="6">Uma espécie de remake político de Passa ou Repassa</segment>
    <segment id="7">, a competição chega ao seu ápice no quadro Mensalão vs. Bolsolão</segment>
    <segment id="8">, em que os principais constrangidos não são os competidores</segment>
    <segment id="9">, e sim o eleitor brasileiro.</segment>
    <segment id="10">Por isso</segment>
    <segment id="11">, a coluna convida seus leitores para responder a essa pergunta por conta própria</segment>
    <segment id="12">, sem baixaria e tortas na cara.</segment>
    <segment id="13">Ilustração de Silvis para coluna de Manuela Cantuária - SilvisO mensalão foi um esquema de desvios de recursos em troca de apoio parlamentar a projetos do Executivo.</segment>
    <segment id="14">Importante frisar que</segment>
    <segment id="15">, segundo as investigações da Polícia Federal</segment>
    <segment id="16">, os partidos que mais</segment>
    <segment id="17">sese beneficiaram com o desvio foram: o Progressistas (PP)</segment>
    <segment id="18">, do atual ministro-chefe da Casa Civil do governo Bolsonaro e de Arthur Lira</segment>
    <segment id="19">, atual presidente da Câmara dos Deputados</segment>
    <segment id="20">; e o Partido Liberal</segment>
    <segment id="21">, ao qual Bolsonaro é filiado.</segment>
    <segment id="22">O presidente do PL</segment>
    <segment id="23">, Valdemar Costa Neto</segment>
    <segment id="24">, estava no centro do escândalo e foi preso por corrupção e lavagem de dinheiro.</segment>
    <segment id="25">Já o orçamento secreto ou bolsolão</segment>
    <segment id="26">, criado em 2020</segment>
    <segment id="27">, direciona dezenas de bilhões em verbas públicas para atender aos interesses de deputados e senadores sem que eles sejam identificados e sem mecanismos claros para acompanhar essas verbas —abrindo espaço para grandes desvios de dinheiro público.</segment>
    <segment id="28">Desde que o sistema foi adotado</segment>
    <segment id="29">, uma série de irregularidades foram denunciadas por indícios de corrupção.</segment>
    <segment id="30">Lula e Bolsonaro participam do primeiro debate do 2º turnoMais    novamente         de   de  de  representando um  Uma delas foi o desvio de R$ 36 milhões de verbas do SUS do Maranhão que resultou na prisão de dois laranjas pela PF</segment>
    <segment id="31">, neste mês</segment>
    <segment id="32">, enquanto o nome do parlamentar permanece em segredo.</segment>
    <segment id="33">Este é apenas um</segment>
    <segment id="34">casocaso citado e o valor desviado aqui já configura</segment>
    <segment id="35">comocomo mais de um terço do valor total desviado no esquema do mensalão: R$ 101 milhões.</segment>
    <segment id="36">Um levantamento feito pela revista Piauí revelou que os partidos políticos mais beneficiados pelo orçamento secreto são do centrão (incluindo o PL e o PP)</segment>
    <segment id="37">, e receberam a modesta quantia de R$ 6</segment>
    <segment id="38">,2 bilhões.</segment>
    <segment id="39">Os recursos destinados ao orçamento secreto</segment>
    <segment id="40">, só neste ano</segment>
    <segment id="41">, foram de R$ 16</segment>
    <segment id="42">,5 bilhões.</segment>
    <segment id="43">Na avaliação da Transparência Internacional Brasil</segment>
    <segment id="44">, organização focada no combate à corrupção</segment>
    <segment id="45">,</segment>
    <segment id="46">o orçamento secreto é o "maior processo de institucionalização da corrupção que</segment>
    <segment id="47">sese tem registro no país".</segment>
  </rst>
</analysis>