  <rst>
    <segment id="1">O deputado federal Guilherme Boulos (PSOL-SP)</segment>
    <segment id="2">sese mudou de mala</segment>
    <segment id="3">, cuia e "Celtinha" para Brasília.</segment>
    <segment id="4">Ele decidiu levar o carro para usar na capital federal</segment>
    <segment id="5">, onde passará pelo menos três dias da semana cumprindo o mandato.</segment>
    <segment id="6">O deputado Guilherme Boulos em frente ao seu Celta e ao Congresso Nacional</segment>
    <segment id="7">, em Brasília</segment>
    <segment id="8">, na quarta (1º) - @guilhermeboulos.oficialDE CELTINHA</segment>
    <segment id="9">Um assessor dirigiu o Celta 2010 por cerca de mil quilômetros até Brasília a tempo de o parlamentar chegar com ele ao Congresso para tomar posse</segment>
    <segment id="10">, na quarta (1º).</segment>
    <segment id="11">PNEU</segment>
    <segment id="12">FURADO</segment>
    <segment id="13">O cronograma</segment>
    <segment id="14">, no entanto</segment>
    <segment id="15">, quase fracassa: o pneu do carro</segment>
    <segment id="16">, que levava também objetos pessoais de Boulos</segment>
    <segment id="17">, furou na estrada.</segment>
    <segment id="18">Guilherme Boulos em entrevista à FolhaMais    novamente         de   de  de  representando um  PLACA</segment>
    <segment id="19">Ao desembarcar do carro na frente do Parlamento</segment>
    <segment id="20">, Boulos ergueu um cartaz onde</segment>
    <segment id="21">sese lia "fazer os fascistas temerem".</segment>
    <segment id="22">ESTANTE</segment>
    <segment id="23">Lançamento do livro &amp;#</segment>
    <segment id="24">039;Noites Tropicais&amp;#039</segment>
    <segment id="25">;, de Nelson MottaMais    novamente         de   de  de  representando um</segment>
    <segment id="26">O produtor musical</segment>
    <segment id="27">, compositor e escritor Nelson Motta recebeu convidados no lançamento da nova edição do seu livro "Noites Tropicais".</segment>
    <segment id="28">O músico Wilson Simoninha prestigiou o evento</segment>
    <segment id="29">, que ocorreu na noite de terça-feira (31)</segment>
    <segment id="30">, na Livraria da Travessa de Pinheiros</segment>
    <segment id="31">, em São Paulo.</segment>
    <segment id="32">O diretor da Biblioteca Mário de Andrade</segment>
    <segment id="33">, Jurandy Valença</segment>
    <segment id="34">, passou por lá.  com BIANKA VIEIRA</segment>
    <segment id="35">, KARINA MATIAS e MANOELLA SMITH</segment>
  </rst>
