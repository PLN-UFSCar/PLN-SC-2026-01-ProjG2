  <rst>
    <segment id="1">Javier Milei tomou posse</segment>
    <segment id="2">comocomo presidente da Argentina neste domingo (10) num momento em que o país está com inflação de 15.000%</segment>
    <segment id="3">, segundo ele.</segment>
    <segment id="4">Seu primeiro discurso</segment>
    <segment id="5">, no Congresso</segment>
    <segment id="6">, foi voltado para questões econômicas</segment>
    <segment id="7">, com propostas para superar a crise</segment>
    <segment id="8">, e críticas ao peronismo.</segment>
    <segment id="9">Veja alguns dos destaques de sua primeira fala para os argentinos.</segment>
    <segment id="10">Javier Milei ao tomar posse</segment>
    <segment id="11">, na Casa Rosada</segment>
    <segment id="12">, em Buenos Aires - Emiliano Lasalvia / AFP   Hoje começa uma nova era na Argentina.</segment>
    <segment id="13">Hoje encerramos uma longa e triste história de decadência e declínio e iniciamos o caminho da reconstrução do nosso país.</segment>
    <segment id="14">Os argentinos expressaram vigorosamente uma vontade de mudança que não tem retorno.</segment>
    <segment id="15">Não há caminho de volta.</segment>
    <segment id="16">Há mais de 100 anos que os políticos insistem em defender um modelo que só gera pobreza</segment>
    <segment id="17">, estagnação e miséria.</segment>
    <segment id="18">Um modelo que considere que os cidadãos existem para servir a política e não que a política existe para servir os cidadãos.</segment>
    <segment id="19">Veja imagens da posse de Javier Milei</segment>
    <segment id="20">, novo presidente da ArgentinaMais    novamente         de   de  de  representando um   Tal</segment>
    <segment id="21">comocomo a queda do Muro de Berlim marcou o fim de um período trágico para o mundo</segment>
    <segment id="22">, estas eleições marcaram o ponto de virada da nossa história.</segment>
    <segment id="23">Nenhum governo recebeu uma herança pior do que a que estamos recebendo.</segment>
    <segment id="24">Este é o legado que nos deixam: uma inflação de 15.000% ao ano</segment>
    <segment id="25">, contra a qual vamos lutar com unhas e dentes para erradicá-la.</segment>
    <segment id="26">E infelizmente</segment>
    <segment id="27">, devo dizer novamente</segment>
    <segment id="28">, não há dinheiro.</segment>
    <segment id="29">A única opção possível é o ajuste</segment>
    <segment id="30">, um ajuste ordenado que recai com toda a sua força sobre o Estado e não sobre o setor privado.</segment>
    <segment id="31">Em termos de segurança</segment>
    <segment id="32">, a Argentina tornou-</segment>
    <segment id="33">sese um banho de sangue.</segment>
    <segment id="34">O tráfico de drogas tomou conta das nossas ruas.</segment>
    <segment id="35">Lá foraReceba no seu email uma seleção semanal com o que de mais importante aconteceu no mundoCarregando...</segment>
    <segment id="36">A situação na Argentina é crítica e emergencial.</segment>
    <segment id="37">Não temos alternativas nem tempo.</segment>
    <segment id="38">Nosso país exige ação e ação imediata.</segment>
    <segment id="39">Não procurávamos nem desejávamos as decisões difíceis que terão de ser tomadas nas próximas semanas</segment>
    <segment id="40">, masmas elas não nos deixaram escolha.</segment>
    <segment id="41">Hoje começamos a percorrer o caminho da prosperidade.</segment>
    <segment id="42">Temos tudo para ser o país que sempre sonhamos.</segment>
    <segment id="43">Apoiadores de Javier Milei próximos à Casa Rosada - Luis Robayo/AFP</segment>
    <segment id="44">O novo contrato social que os argentinos escolheram propõe um país diferente</segment>
    <segment id="45">, onde o Estado não dirige as nossas vidas</segment>
    <segment id="46">, masmas sim zela pelos nossos direitos.</segment>
    <segment id="47">Um país que permite tudo dentro da lei</segment>
    <segment id="48">, masmas fora da lei não permite nada.</segment>
    <segment id="49">Os ideais de liberdade são a única forma de sair do buraco em que nos colocaram.</segment>
    <segment id="50">Vamos seguir em frente.</segment>
    <segment id="51">Será difícil</segment>
    <segment id="52">, masmas vamos conseguir.</segment>
    <segment id="53">Levante-</segment>
    <segment id="54">sese, vamos sair.</segment>
  </rst>
</analysis>