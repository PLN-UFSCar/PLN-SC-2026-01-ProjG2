  <rst>
    <segment id="1">Em sua primeira declaração após o resultado do primeiro turno</segment>
    <segment id="2">, a candidata a vice-presidente de Ciro Gomes</segment>
    <segment id="3">, Kátia Abreu</segment>
    <segment id="4">, disse que não tem ânimo em apoiar nem PT nem PSL no segundo turno.</segment>
    <segment id="5">Em entrevista à Folha</segment>
    <segment id="6">, ela disse que a sua posição</segment>
    <segment id="7">, a princípio</segment>
    <segment id="8">, será de neutralidade</segment>
    <segment id="9">, masmas que ainda conversará o presidente nacional do PDT</segment>
    <segment id="10">, Carlos Lupi</segment>
    <segment id="11">, e com Ciro Gomes.</segment>
    <segment id="12">Katia</segment>
    <segment id="13">Abreu vota to Tocantins - Cecília Santos/Folhapress</segment>
    <segment id="14">“</segment>
    <segment id="15">Do ponto de vista pessoal</segment>
    <segment id="16">, não tenho ânimo em apoiar nem um nem outro.</segment>
    <segment id="17">Essa guerra é essa briga não vão terminar bem.</segment>
    <segment id="18">Não quero participar disso”</segment>
    <segment id="19">, afirmou.</segment>
    <segment id="20">A senadora pelo Tocantins criticou o PT por</segment>
    <segment id="21">, segundo ela</segment>
    <segment id="22">, ter criado Bolsonaro.</segment>
    <segment id="23">Ela avaliou que a governabilidade do país estará prejudicada independentemente de quem seja eleito.</segment>
    <segment id="24">As duas maiores bancadas eleitas na Câmara dos Deputados nas eleições deste ano foram do PT e do PSL</segment>
    <segment id="25">, partidos antagônicos no espectro político.  Kátia Abreu no Poder e PolíticaMais    novamente         de   de  de  representando um    Derrotado com um desempenho inferior ao que esperava</segment>
    <segment id="26">,</segment>
    <segment id="27">Ciro indicou que deve Haddad.</segment>
    <segment id="28">A tendência é de que ele declare apoio a Haddad</segment>
    <segment id="29">, apesar de ter ficado magoado com Lula.</segment>
    <segment id="30">O PDT acusa o petista de ter agido de maneira desleal ao ter atuado para esvaziar sua candidatura</segment>
    <segment id="31">, impedindo o apoio dos partidos do centrão e influenciado o PSB a declarar neutralidade na disputa presidencial.</segment>
    <segment id="32">O anúncio</segment>
    <segment id="33">, contudo</segment>
    <segment id="34">contudo</segment>
    <segment id="35">, deve ser feito de maneira protocolar</segment>
    <segment id="36">, sem uma adesão imediata a uma eventual gestão petista.</segment>
    <segment id="37">A ideia é que ele repita o formato adotado por Marina Silva na disputa presidencial de 2014</segment>
    <segment id="38">, quando ela informou um apoio</segment>
    <segment id="39">, masmas não uma aliança</segment>
    <segment id="40">, com Aécio Neves</segment>
    <segment id="41">, do PSDB</segment>
    <segment id="42">, no segundo turno da disputa eleitoral.</segment>
  </rst>
</analysis>