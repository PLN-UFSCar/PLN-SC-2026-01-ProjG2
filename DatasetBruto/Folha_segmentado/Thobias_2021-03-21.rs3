  <rst>
    <segment id="1">O cantor Edmar Tobias da Silva</segment>
    <segment id="2">, 62 anos</segment>
    <segment id="3">, mais conhecido</segment>
    <segment id="4">comocomo o Thobias da Vai-Vai</segment>
    <segment id="5">, está internado desde quarta-feira (17) no Hospital São Camilo</segment>
    <segment id="6">, em São Paulo.</segment>
    <segment id="7">Segundo sua filha Cláudia</segment>
    <segment id="8">, o quadro estava estável até sábado (20).</segment>
    <segment id="9">"</segment>
    <segment id="10">Porém, hoje deu uma piorada</segment>
    <segment id="11">, está em máscara de oxigênio e uso de antibióticos"</segment>
    <segment id="12">, informou ela à coluna Olá.</segment>
    <segment id="13">"</segment>
    <segment id="14">Estamos orando</segment>
    <segment id="15">para que</segment>
    <segment id="16">para que ele reaja bem aos medicamentos"</segment>
    <segment id="17">, completou.</segment>
    <segment id="18">A Vai-Vai obteve oito dos seus 13 títulos sob a interpretação de Thobias</segment>
    <segment id="19">, considerado um dos maiores puxadores de samba-enredo do Brasil.</segment>
    <segment id="20">Também radialista</segment>
    <segment id="21">, Thobias lançou nove discos e foi presidente da Vai-Vai.</segment>
    <segment id="22">Escolas de samba de SP tentam</segment>
    <segment id="23">sese adaptar a um novo normalMais    novamente         de   de  de  representando um</segment>
  </rst>
