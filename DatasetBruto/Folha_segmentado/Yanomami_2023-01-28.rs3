  <rst>
    <segment id="1">O rapper Criolo deu início ao seu show no Festival de Verão Salvador</segment>
    <segment id="2">, neste sábado (28)</segment>
    <segment id="3">, protestando contra a crise humanitária vivida pelos indígenas yanomamis.</segment>
    <segment id="4">"</segment>
    <segment id="5">Salvem os yanomamis.</segment>
    <segment id="6">Chega de extermínio dos povos indígenas"</segment>
    <segment id="7">, afirmou ele ao saudar o público.</segment>
    <segment id="8">O cantor ainda puxou a frase em coro por mais seis vezes —em todas elas</segment>
    <segment id="9">, acompanhado com veemência pelos espectadores—</segment>
    <segment id="10">, antes de iniciar a música "</segment>
    <segment id="11">Ogum Ogum".</segment>
    <segment id="12">Os músicos da banda</segment>
    <segment id="13">sese juntaram ao protesto com os punhos cerrados.</segment>
    <segment id="14">O rapper Criolo exibe as inscrições &amp;quot</segment>
    <segment id="15">;yanomami resiste&amp;quot</segment>
    <segment id="16">; e &amp;quot</segment>
    <segment id="17">;chega de extermínio&amp;quot</segment>
    <segment id="18">; no telão durante a abertura de seu show no Festival de Verão Salvador</segment>
    <segment id="19">, neste sábado (28) - ReproduçãoAinda neste sábado</segment>
    <segment id="20">, Criolo recebeu no palco o cantor Ney Matogrosso.</segment>
    <segment id="21">Sob muitos aplausos</segment>
    <segment id="22">, o rapper disse que estava "muito emocionado" em chamar o cantor ao palco.</segment>
    <segment id="23">Eles começaram a parceria no palco com "</segment>
    <segment id="24">Eu Quero É Botar Meu Bloco na Rua"</segment>
    <segment id="25">, com o paulistano fazendo backing vocals para o mato-grossense.</segment>
    <segment id="26">Ney disse que os baianos eram "a gente mais gostosa e mais tesuda do Brasil"</segment>
    <segment id="27">, antes de puxar "</segment>
    <segment id="28">Jardins da Babilônia".</segment>
    <segment id="29">Criolo ficou deitado no chão enquanto o parceira cantava "Sangue Latino"</segment>
    <segment id="30">, sucesso da época de Secos e Molhados.</segment>
    <segment id="31">Foi o momento mais celebrado do show</segment>
    <segment id="32">, incluindo também a performance de "</segment>
    <segment id="33">Homem com H"</segment>
    <segment id="34">–esta, cantada com afinco pela plateia.</segment>
    <segment id="35">Alcançando seus agudos clássicos mesmo com mais de 80 anos</segment>
    <segment id="36">, Ney saiu do palco celebrado pelos baianos.</segment>
    <segment id="37">Criolo ainda fez sua homenagem à Bahia cantando "</segment>
    <segment id="38">Deixa a Gira Girar"</segment>
    <segment id="39">, do grupo local Tincoãs</segment>
    <segment id="40">, e emendou "Bogotá"</segment>
    <segment id="41">, seu afrobeat sobre tráfico de drogas</segment>
    <segment id="42">, antes de sair do palco.</segment>
    <segment id="43">A essa altura</segment>
    <segment id="44">, a plateia já estava abarrotada no Parque de Exposições de Salvador</segment>
    <segment id="45">, onde acontece o festival.</segment>
    <segment id="46">Criolo e Ney Matogrosso</segment>
    <segment id="47">sese conheceram há mais de dez anos</segment>
    <segment id="48">, nos bastidores do longa "Luz</segment>
    <segment id="49">Nas Trevas –</segment>
    <segment id="50">A Volta do Bandido da Luz Vermelha" (2012)</segment>
    <segment id="51">, protagonizado por Ney.</segment>
    <segment id="52">O encontro ocorreu quando o rapper</segment>
    <segment id="53">, que foi convidado a fazer uma participação no filme</segment>
    <segment id="54">, pediu uma foto ao lado do ídolo.  "</segment>
    <segment id="55">Humildemente</segment>
    <segment id="56">, eu cheguei para alguém da produção e falei: '</segment>
    <segment id="57">Quando ele [Ney] tiver um momento de folga e de descanso</segment>
    <segment id="58">, vocês poderiam tirar uma foto?</segment>
    <segment id="59">Porque eu sou muito fã</segment>
    <segment id="60">, masmas a minha mãe é muito mais'"</segment>
    <segment id="61">, contou Criolo em entrevista ao programa Altas Horas</segment>
    <segment id="62">, da TV Globo.</segment>
    <segment id="63">Veja imagens do Festival de Verão de Salvador 2023Mais    novamente         de   de  de  representando um</segment>
    <segment id="64">Em 2013</segment>
    <segment id="65">, Ney incluiu a música "Freguês da Meia-Noite"</segment>
    <segment id="66">, de Criolo</segment>
    <segment id="67">, na turnê "</segment>
    <segment id="68">Atento aos Sinais".</segment>
    <segment id="69">Na ocasião</segment>
    <segment id="70">, o cantor completava 40 anos de carreira e apostava em releituras de artistas novos e consagrados.</segment>
    <segment id="71">Um ano antes</segment>
    <segment id="72">, ele e Criolo já tinham gravado uma versão ao vivo da canção.</segment>
    <segment id="73">Em 2022</segment>
    <segment id="74">, o duo voltou a</segment>
    <segment id="75">sese reunir nos vocais de "Algoritmo Íntimo"</segment>
    <segment id="76">, cuja composição é assinada por Arnaldo Antunes</segment>
    <segment id="77">, Criolo</segment>
    <segment id="78">, Gabrieu</segment>
    <segment id="79">, Keviin e Marcia Xavier.</segment>
  </rst>
</analysis>