  <rst>
    <segment id="1">O arraial da ONG Adote</segment>
    <segment id="2">Um Gatinho está de volta.</segment>
    <segment id="3">A sexta edição presencial será neste domingo (10)</segment>
    <segment id="4">, das 12h às 19h</segment>
    <segment id="5">, na Associação Hokkaido de Cultura e Assistência</segment>
    <segment id="6">, na Vila Mariana</segment>
    <segment id="7">, zona sul de São Paulo.</segment>
    <segment id="8">A festa terá muitas comidinhas e brincadeiras típicas de festa junina</segment>
    <segment id="9">, além de lojinhas com produtos para gatos e também para humanos.</segment>
    <segment id="10">O ingresso custa R$ 20 e</segment>
    <segment id="11">, sese adquirido antecipadamente pelo site Sympla</segment>
    <segment id="12">, dá direito a uma bebida quente ou refrigerante e a uma brincadeira.</segment>
    <segment id="13">Crianças de até 7 anos não pagam para entrar.</segment>
    <segment id="14">"Estamos muito felizes com a volta do arraial depois de dois anos de pandemia.</segment>
    <segment id="15">Animados para rever o público que nos acompanha desde o começo</segment>
    <segment id="16">, fazer uma grande festa e levantar fundos para os gatinhos"</segment>
    <segment id="17">, diz Susan Yamamoto</segment>
    <segment id="18">, que fundou a ONG com Juliana Bussab</segment>
    <segment id="19">, em 2003.</segment>
    <segment id="20">Em 2020 e 2021</segment>
    <segment id="21">, o evento aconteceu virtualmente.</segment>
    <segment id="22">Arraial da ONG Adote</segment>
    <segment id="23">Um Gatinho volta a acontecer presencialmente em SPMais    novamente         de   de  de  representando um    ​Susan conta que os dois últimos anos não foram fáceis para o grupo.</segment>
    <segment id="24">"</segment>
    <segment id="25">As doações caíram muito</segment>
    <segment id="26">porque</segment>
    <segment id="27">porque elas acabam acompanhando o cenário econômico do país</segment>
    <segment id="28">, está todo mundo apertado.</segment>
    <segment id="29">Os custos aumentaram também</segment>
    <segment id="30">, desde ração até os procedimentos veterinários.</segment>
    <segment id="31">Infelizmente</segment>
    <segment id="32">, estamos usando nosso fundinho que era para a compra da nossa sede.</segment>
    <segment id="33">Mas ainda bem que tínhamos esse dinheiro guardado.</segment>
    <segment id="34">"</segment>
    <segment id="35">O dinheiro arrecadado com o evento será usado para pagar as despesas dos cerca de 400 gatinhos que atualmente estão sob os cuidados da ONG.</segment>
    <segment id="36">Os voluntários da Adote Um Gatinho estarão recebendo doações de cobertores e mantinhas no local para a campanha de inverno.  +</segment>
    <segment id="37">GaticesLeia</segment>
    <segment id="38">mais sobre gatosMorre BeeJay</segment>
    <segment id="39">, gatão que conquistou fãs e um lar após campanha de abrigoDominação felina: gatos lideram crescimento de animais de estimação no BrasilGatos precisam de cuidados especiais nos dias frios​6º</segment>
    <segment id="40">Arraial presencial da ONG</segment>
    <segment id="41">Adote</segment>
    <segment id="42">um Gatinho Onde:</segment>
    <segment id="43">Associação Hokkaido de Cultura e Assistência</segment>
    <segment id="44">, rua Joaquim Távora</segment>
    <segment id="45">, 605, Vila Mariana</segment>
    <segment id="46">, zona sul de São Paulo</segment>
    <segment id="47">Quanto: R$ 20</segment>
    <segment id="48">; crianças de até 7 anos não pagam para entrar</segment>
    <segment id="49">;</segment>
    <segment id="50">clique aqui para comprar Quando:</segment>
    <segment id="51">Domingo (10)</segment>
    <segment id="52">, das 12h às 19h Saiba mais na página do evento no Facebook  Siga o blog Gatices no Twitter</segment>
    <segment id="53">, Instagram e Facebook.</segment>
  </rst>
