  <rst>
    <segment id="1">O Grammy deste ano foi marcado pela quebra de recordes de Beyoncé</segment>
    <segment id="2">, que agora</segment>
    <segment id="3">sese tornou a artista mulher com mais gramofones da história.</segment>
    <segment id="4">Outro momento marcante da cerimônia foi durante a performance de "WAP"</segment>
    <segment id="5">, de Meghan Thee Stallion e Cardi B.</segment>
    <segment id="6">, que reuniu um trecho da versão em funk do produtor brasileiro Pedro Sampaio.</segment>
    <segment id="7">O Expresso Ilustrada dessa semana analisa as mudanças que a cerimônia vem passando</segment>
    <segment id="8">, os impactos dos prêmios deste ano na indústria da música</segment>
    <segment id="9">, e, claro</segment>
    <segment id="10">, discute os esnobados</segment>
    <segment id="11">, os consagrados da 63ª edição da cerimônia.</segment>
    <segment id="12">Conheça os vencedores do Grammy na pandemiaMais    novamente         de   de  de  representando um  Para isso</segment>
    <segment id="13">, o episódio conta com a participação da repórter da Folha Laura Lewer e do jornalista Felipe Maia</segment>
    <segment id="14">, colaborador do jornal.</segment>
    <segment id="15">Com novos episódios todas as quintas</segment>
    <segment id="16">, às 16h</segment>
    <segment id="17">, o Expresso Ilustrada discute música</segment>
    <segment id="18">, cinema</segment>
    <segment id="19">, literatura</segment>
    <segment id="20">, moda</segment>
    <segment id="21">, teatro</segment>
    <segment id="22">, artes plásticas e televisão.</segment>
    <segment id="23">A edição desta semana é da Laila Mouallem</segment>
    <segment id="24">, e o roteiro é de Lucas Brêda</segment>
    <segment id="25">, que também apresenta o programa ao lado de Isabella Menon.</segment>
    <segment id="26">O feed RSS é https://folhaexpressoilustrada.libsyn.com/rs.</segment>
    <segment id="27">O PODCAST ESTÁ DISPONÍVEL</segment>
    <segment id="28">EM TODAS AS PLATAFORMAS DE STREAMING.</segment>
    <segment id="29">AQUI ESTÃO ALGUMAS DELAS:</segment>
    <segment id="30">Spotify  iTunes  Deezer  Google Podcasts  Castbox  Stitcher</segment>
    <segment id="31">Logo Podcast Expresso Ilustrada</segment>
  </rst>
