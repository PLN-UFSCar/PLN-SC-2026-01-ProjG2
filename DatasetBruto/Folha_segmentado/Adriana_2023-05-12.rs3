  <rst>
    <segment id="1">Os shows que Adriana Calcanhotto tem feito em homenagem a Gal Costa passaram a contar</segment>
    <segment id="2">, nos últimos espetáculos</segment>
    <segment id="3">, com um item especial em sua cenografia: um banquinho usado pela baiana na apresentação que deu origem ao clássico "Fa-Tal:</segment>
    <segment id="4">Gal a Todo Vapor"</segment>
    <segment id="5">, de 1971</segment>
    <segment id="6">, e serviu de inspiração para o tributo.</segment>
    <segment id="7">A cantora Adriana Calcanhotto apresenta show em homenagem a Gal Costa</segment>
    <segment id="8">, em São Paulo</segment>
    <segment id="9">; ao seu lado</segment>
    <segment id="10">, o banco usado pela baiana para gravar o clássico &amp;quot</segment>
    <segment id="11">;Fa-Tal: Gal a Todo Vapor&amp;quot</segment>
    <segment id="12">;, de 1971 - @adrianacalcanhotto no Instagram  MEMORABILIA</segment>
    <segment id="13">A peça</segment>
    <segment id="14">, esculpida em madeira</segment>
    <segment id="15">, tem origem indígena e foi cedida a Calcanhotto pela professora e pesquisadora Juliana Chrispim</segment>
    <segment id="16">, também colecionadora da obra de Gal.</segment>
    <segment id="17">"</segment>
    <segment id="18">No show ‘Fa-Tal’</segment>
    <segment id="19">, a Gal fazia toda a primeira parte</segment>
    <segment id="20">, com voz e violão</segment>
    <segment id="21">, sentada nesse banquinho"</segment>
    <segment id="22">, destaca ela.</segment>
    <segment id="23">BALANÇO  Lançamento do Anuário da Justiça Brasil 2023</segment>
    <segment id="24">, na sede do STF</segment>
    <segment id="25">, em BrasíliaMais    novamente         de   de  de  representando um</segment>
    <segment id="26">A presidente do STF (Supremo Tribunal Federal)</segment>
    <segment id="27">, Rosa Weber</segment>
    <segment id="28">, participou e discursou durante o lançamento do Anuário da Justiça Brasil 2023</segment>
    <segment id="29">, editado pela Conjur.</segment>
    <segment id="30">O evento foi realizado na sede da mais alta corte do país</segment>
    <segment id="31">, em Brasília</segment>
    <segment id="32">, na quarta-feira (10).</segment>
    <segment id="33">Os ministros do STF Gilmar Mendes</segment>
    <segment id="34">, Edson Fachin</segment>
    <segment id="35">, Alexandre de Moraes e André Mendonça também estiveram lá</segment>
    <segment id="36">, assim</segment>
    <segment id="37">comocomo a vice-procuradora-geral da República</segment>
    <segment id="38">, Lindôra Araújo.  com BIANKA VIEIRA</segment>
    <segment id="39">, KARINA MATIAS e MANOELLA SMITH</segment>
  </rst>
</analysis>