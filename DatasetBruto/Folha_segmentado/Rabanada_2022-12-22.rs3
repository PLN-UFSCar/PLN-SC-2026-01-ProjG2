  <rst>
    <segment id="1">Rabanadas são rodelas de pão fritas previamente mergulhadas em leite com açúcar e ovos batidos</segment>
    <segment id="2">, e finalizadas com mais açúcar e um toque de canela</segment>
    <segment id="3">, certo?</segment>
    <segment id="4">A versão tradicional</segment>
    <segment id="5">, sim.</segment>
    <segment id="6">A vegana</segment>
    <segment id="7">, não,</segment>
    <segment id="8">masmas</segment>
    <segment id="9">, ao optar pela receita sem ovos e sem leite de vaca</segment>
    <segment id="10">, omita o fato de que</segment>
    <segment id="11">sese trata de uma rabanada 100% vegetal.</segment>
    <segment id="12">Sirva, e</segment>
    <segment id="13">, depois que todos lamberem os dedos</segment>
    <segment id="14">, revele o segredinho.</segment>
    <segment id="15">Ninguém vai acreditar.</segment>
    <segment id="16">Na minha receita de rabanada</segment>
    <segment id="17">, que surgiu de um acaso</segment>
    <segment id="18">, o painço batido com leite vegetal faz as vezes tanto dos ovos quanto do leite de vaca.</segment>
    <segment id="19">A farinha de aveia envolve as rodelas de pão antes de irem à frigideira</segment>
    <segment id="20">, para deixar a rabanada crocante</segment>
    <segment id="21">, sem a necessidade de fritar por imersão.</segment>
    <segment id="22">Rabanada em versão vegana</segment>
    <segment id="23">, sem leite nem ovos - Luisa MafeiPara uma versão sem glúten</segment>
    <segment id="24">, basta utilizar um pão sem glúten e optar pela farinha de aveia sem glúten.</segment>
    <segment id="25">A aveia não contém glúten</segment>
    <segment id="26">, masmas pode ser contaminada por cruzamento</segment>
    <segment id="27">, ao ser processada em máquinas que recebem cereais com glúten</segment>
    <segment id="28">, como</segment>
    <segment id="29">como o trigo.</segment>
    <segment id="30">Por isso</segment>
    <segment id="31">, no caso</segment>
    <segment id="32">caso dos celíacos</segment>
    <segment id="33">, é importante ter atenção ao rótulo.</segment>
    <segment id="34">E, para quem quiser uma receita de rabanadas à base de plantas com direito a glúten e ingredientes acessíveis</segment>
    <segment id="35">, a dica é seguir a do cozinheiro e comunicador Guilherme Lima</segment>
    <segment id="36">, mais conhecido</segment>
    <segment id="37">comocomo Veggui no Instagram.</segment>
    <segment id="38">A receita do Gui</segment>
    <segment id="39">, além de deliciosa</segment>
    <segment id="40">, não exige nada além de pão</segment>
    <segment id="41">, leite vegetal</segment>
    <segment id="42">, açúcar</segment>
    <segment id="43">, amido</segment>
    <segment id="44">, óleo de coco e canela.</segment>
    <segment id="45">Uma curiosidade: em Portugal</segment>
    <segment id="46">, existem as rabanadas e as fatias douradas.</segment>
    <segment id="47">Ambas são pães fritos</segment>
    <segment id="48">, masmas as fatias douradas são fritas em manteiga</segment>
    <segment id="49">, enquanto as rabanadas —também chamadas de fatias paridas— são fritas em óleo.</segment>
    <segment id="50">Tanto na minha versão quanto na do Gui</segment>
    <segment id="51">, sugerimos o uso do óleo de coco</segment>
    <segment id="52">, que agrega doçura nos pãezinhos que</segment>
    <segment id="53">, apesar de saírem da frigideira dourados</segment>
    <segment id="54">, são, sim</segment>
    <segment id="55">, rabanadas.</segment>
    <segment id="56">Rabanada da Luisa  INGREDIENTES  6 rodelas de pão  1 xícara de cuscuz natalino (a receita foi publicada na coluna anterior</segment>
    <segment id="57">, e é muito simples de preparar)  ½ xícara de leite vegetal  2 colheres de sopa de açúcar demerara  ½ xícara de farinha de aveia  4 colheres de sopa de óleo de coco + para acrescentar durante a "fritura"  Açúcar e canela</segment>
    <segment id="58">, para polvilhar  Agave</segment>
    <segment id="59">, o quanto baste (opcional)  PREPARO</segment>
    <segment id="60">Bata o cuscuz de painço com o leite vegetal e o açúcar no liquidificador até obter uma mistura homogênea e lisa.</segment>
    <segment id="61">Despeje a mistura num prato fundo.</segment>
    <segment id="62">Em outro prato fundo</segment>
    <segment id="63">, coloque a farinha de aveia.</segment>
    <segment id="64">Passe cada fatia de pão na mistura de painço</segment>
    <segment id="65">, e, em seguida</segment>
    <segment id="66">, na farinha de aveia</segment>
    <segment id="67">, tirando bem os excessos com os dedos.</segment>
    <segment id="68">Disponha as fatias já empanadas em uma travessa com um pouco de farinha de aveia polvilhada e</segment>
    <segment id="69">, em seguida</segment>
    <segment id="70">, comece a "fritar" em uma frigideira com óleo de coco em fogo médio</segment>
    <segment id="71">, primeiro de um lado</segment>
    <segment id="72">, e depois do outro</segment>
    <segment id="73">, até que ambos fiquem dourados (aproximadamente dois minutos de cada lado).</segment>
    <segment id="74">Faça o mesmo procedimento com as laterais do pão</segment>
    <segment id="75">, com a ajuda de um pegador.</segment>
    <segment id="76">Toda a superfície do pão deve entrar em contato com a frigideira</segment>
    <segment id="77">para que</segment>
    <segment id="78">para que a rabanada fique</segment>
    <segment id="79">"selada".</segment>
    <segment id="80">Retire as rabanadas da frigideira e transfira para um prato com papel toalha.</segment>
    <segment id="81">Finalize com canela e</segment>
    <segment id="82">, sese quiser</segment>
    <segment id="83">, açúcar por cima e sirva quente ou em temperatura ambiente.</segment>
    <segment id="84">Para caprichar na apresentação</segment>
    <segment id="85">, faça uma mistura de agave e óleo de coco (derretido) e pincele por cima na hora de servir.</segment>
    <segment id="86">Rabanada do Guilherme  Rabanadas do Gui Lima - Guilherme LimaINGREDIENTES</segment>
    <segment id="87">Para a rabanada:  1 xícara de leite vegetal (de preferência um leite mais cremoso e grossinho)  2 colheres de sopa de açúcar  1 colheres de sopa de amido de milho  Pitada de sal  1/2 colheres de chá de extrato de baunilha (opcional)  3 unidades de pão francês (de preferência amanhecido)</segment>
    <segment id="88">Para polvilhar:  Açúcar e canela em pó  Óleo de coco</segment>
    <segment id="89">, ou outro óleo</segment>
    <segment id="90">, para fritar.</segment>
    <segment id="91">PREPARO</segment>
    <segment id="92">Misture todos os ingredientes da rabanada até ficar homogêneo.</segment>
    <segment id="93">Mergulhe as fatias de pão na mistura e</segment>
    <segment id="94">, logo em seguida</segment>
    <segment id="95">, leve as fatias para uma frigideira aquecida com 2 colheres de sopa de óleo de coco (ou outro óleo vegetal) e frite em fogo médio</segment>
    <segment id="96">, dourando os dois lados.</segment>
    <segment id="97">Depois é só passar na mistura de açúcar e canela e está pronto!</segment>
  </rst>
</analysis>