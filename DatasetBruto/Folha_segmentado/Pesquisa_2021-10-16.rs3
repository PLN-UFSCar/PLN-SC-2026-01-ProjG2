  <rst>
    <segment id="1">No próximo dia 29</segment>
    <segment id="2">, circula junto com a versão impressa do jornal a edição especial</segment>
    <segment id="3">Folha Top of Mind 2021.</segment>
    <segment id="4">A partir das 20h da véspera</segment>
    <segment id="5">, dia 28</segment>
    <segment id="6">, o conteúdo estará no site da revista.</segment>
    <segment id="7">​“Qual é a primeira marca que lhe vem à cabeça?</segment>
    <segment id="8">”,</segment>
    <segment id="9">perguntaram pesquisadores do Datafolha que percorreram todas as regiões para descobrir os nomes que estão na memória dos brasileiros.</segment>
    <segment id="10">Na noite do dia 28</segment>
    <segment id="11">, a partir das 20h</segment>
    <segment id="12">, as marcas campeãs serão anunciadas ao público em vídeo</segment>
    <segment id="13">, que será transmitido no canal da TV Folha no YouTube e no site do jornal.</segment>
    <segment id="14">O elefante símbolo da Folha Top of Mind</segment>
    <segment id="15">; edição de 2021 acontece no dia 28 de outubro - Dirceu Neto/FolhapressCom apresentação dos atores Adriana Lessa e Juan Alba</segment>
    <segment id="16">, a premiação online vai reunir vídeos comemorativos das marcas vencedoras.</segment>
    <segment id="17">Assim como</segment>
    <segment id="18">como no ano passado</segment>
    <segment id="19">, a festa de entrega do prêmio foi cancelada para evitar aglomeração durante a pandemia de Covid.</segment>
    <segment id="20">Para chegar às marcas vitoriosas</segment>
    <segment id="21">, o Datafolha ouviu 7.758 brasileiras e brasileiros a partir de 16 anos de todas as regiões</segment>
    <segment id="22">, sexos e classes sociais</segment>
    <segment id="23">, entre os dias 2 e 14 de agosto.</segment>
    <segment id="24">A pesquisa engloba categorias de serviços e produtos presentes no dia a dia da população brasileira</segment>
    <segment id="25">, de segmentos distintos</segment>
    <segment id="26">, como</segment>
    <segment id="27">como saúde</segment>
    <segment id="28">, alimentação</segment>
    <segment id="29">, transporte</segment>
    <segment id="30">, comunicação</segment>
    <segment id="31">, higiene e beleza e finanças</segment>
    <segment id="32">, entre outros.</segment>
    <segment id="33">Há, ainda</segment>
    <segment id="34">, 12 categorias especiais</segment>
    <segment id="35">, como</segment>
    <segment id="36">como o Top do Top</segment>
    <segment id="37">, que revela a marca mais lembrada entre todas as pesquisadas</segment>
    <segment id="38">, e o Top Destaques Regionais</segment>
    <segment id="39">, com os nomes mais citados em cada região do Brasil.</segment>
    <segment id="40">Novos itens foram adicionados ao levantamento deste ano</segment>
    <segment id="41">, como</segment>
    <segment id="42">como banco digital</segment>
    <segment id="43">, cosméticos e desinfetante.</segment>
    <segment id="44">Essas mudanças são feitas para contemplar a importância que alguns setores assumiram no período de isolamento social</segment>
    <segment id="45">, explica Alessandro Janoni</segment>
    <segment id="46">, diretor de pesquisas do Datafolha.</segment>
    <segment id="47">“Todos os anos</segment>
    <segment id="48">, a alternância atende à relevância que alguns produtos e serviços passam a assumir na vida do consumidor brasileiro.</segment>
    <segment id="49">”  Maior estudo de lembrança de marcas da América Latina</segment>
    <segment id="50">, a Folha Top of Mind faz o mapeamento das transformações econômicas e sociais do país e dos comportamentos dos consumidores ao longo dos anos.</segment>
    <segment id="51">Auxilia também a medir a eficiência das estratégias adotadas pelas empresas.</segment>
    <segment id="52">“</segment>
    <segment id="53">O Top of Mind reconhece as marcas que estão na memória das pessoas”</segment>
    <segment id="54">, diz Silvio Soledade</segment>
    <segment id="55">, presidente da APP (Associação dos Profissionais de Propaganda).</segment>
    <segment id="56">“Ser lembrado dentre tantas marcas mostra que um diálogo e uma conexão foram estabelecidos.</segment>
    <segment id="57">É o reconhecimento de que a estratégia tem funcionado”</segment>
    <segment id="58">, diz.</segment>
    <segment id="59">Além das campeãs</segment>
    <segment id="60">, a revista trará análises</segment>
    <segment id="61">, reportagens especiais</segment>
    <segment id="62">, ensaios fotográficos e artigos de opinião de representantes das marcas e de agências de publicidade.</segment>
    <segment id="63">Reportagens sobre os ganhadores também estarão disponíveis no site do Top of Mind.</segment>
    <segment id="64">Ações das 30 maiores agências de publicidade do país podem ser conferidas no Instagram  @folhatopofmind.</segment>
  </rst>
</analysis>