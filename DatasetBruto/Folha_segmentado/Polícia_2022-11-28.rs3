  <rst>
    <segment id="1">A Europol disse nesta segunda-feira (28) ter desmantelado um "supercartel</segment>
    <segment id="2">"</segment>
    <segment id="3">responsável por um terço do mercado de cocaína da Europa.</segment>
    <segment id="4">Ao todo</segment>
    <segment id="5">, 49 pessoas foram presas em diversos países —seis das quais</segment>
    <segment id="6">, apontadas</segment>
    <segment id="7">comocomo possíveis chefes da organização</segment>
    <segment id="8">, em Dubai.</segment>
    <segment id="9">Apelidada de Operação Desert Light (luz do deserto)</segment>
    <segment id="10">, a ação internacional resultou na apreensão de 30 toneladas de entorpecentes</segment>
    <segment id="11">, além da prisão de suspeitos na Espanha</segment>
    <segment id="12">, na França</segment>
    <segment id="13">, na Bélgica</segment>
    <segment id="14">, na Holanda e nos Emirados Árabes Unidos.</segment>
    <segment id="15">Dos detidos em Dubai</segment>
    <segment id="16">, dois tinham relações com a França</segment>
    <segment id="17">, dois com a Holanda e os dois últimos com a Espanha.</segment>
    <segment id="18">Autoridades de diversas agências policiais europeias realizam operação junto à Europol e detém suspeito de tráfico de drogas - Divulgação Europol</segment>
    <segment id="19">Em comunicado</segment>
    <segment id="20">, a Europol detalhou que "alvos de alto valor haviam</segment>
    <segment id="21">sese unido" para dar origem ao que foi descrito</segment>
    <segment id="22">comocomo "supercartel".</segment>
    <segment id="23">No ano passado</segment>
    <segment id="24">, a polícia obteve autorização para rastrear os celulares dos traficantes</segment>
    <segment id="25">, possibilitando a leva de prisões.</segment>
    <segment id="26">Participaram da investigação</segment>
    <segment id="27">, além das quatro nações europeias</segment>
    <segment id="28">, autoridades policiais e judiciárias dos EUA e dos Emirados Árabes.</segment>
    <segment id="29">Sob a mira da cooperação internacional</segment>
    <segment id="30">, a rede trabalhava principalmente com cocaína procedente da América do Sul</segment>
    <segment id="31">, que chegava à Europa pelos portos de Roterdã</segment>
    <segment id="32">, na Holanda</segment>
    <segment id="33">, e Antuérpia</segment>
    <segment id="34">, na Bélgica.</segment>
    <segment id="35">Lá foraReceba no seu email uma seleção semanal com o que de mais importante aconteceu no mundo</segment>
    <segment id="36">; aberta para não assinantes.</segment>
    <segment id="37">Carregando...</segment>
    <segment id="38">A Guarda Civil da Espanha classificou a operação</segment>
    <segment id="39">comocomo um "um marco histórico na luta contra o tráfico de drogas global" e destacou o ineditismo de uma ação realizada em Dubai.</segment>
    <segment id="40">No início de novembro</segment>
    <segment id="41">, a guarda espanhola realizou incursões simultâneas em Málaga</segment>
    <segment id="42">, Madri e Barcelona.</segment>
    <segment id="43">A operação prendeu 15 pessoas e está relacionada a uma apreensão de março de 2020 que confiscou 698 kg de cocaína em um contêiner no porto de Valência</segment>
    <segment id="44">, no leste do país.</segment>
    <segment id="45">O líder da organização</segment>
    <segment id="46">, um cidadão britânico</segment>
    <segment id="47">, fugiu da Espanha para Dubai depois de ter sido vítima de uma tentativa de sequestro.</segment>
    <segment id="48">De lá, "continuou dirigindo e coordenando as atividades criminosas" do cartel</segment>
    <segment id="49">, explicou a Guarda Civil.</segment>
    <segment id="50">A cocaína era importada do Panamá</segment>
    <segment id="51">, e seu fornecedor</segment>
    <segment id="52">, um panamenho também radicado em Dubai</segment>
    <segment id="53">, "mantinha contatos com os demais barões do emirado".</segment>
    <segment id="54">PF prende nigeriano que tentava embarcar 4kg de cocaína em livros infantisMais    novamente         de   de  de  representando um    Promotores da Holanda indicaram que devem pedir a extradição dos dois suspeitos detidos nos Emirados.</segment>
    <segment id="55">Um deles é um homem de 37 anos</segment>
    <segment id="56">, de nacionalidade holandesa e marroquina —preso acusado de traficar milhares de quilos de cocaína para a Holanda em 2020 e 2021.</segment>
    <segment id="57">O outro é um homem de 40 anos</segment>
    <segment id="58">, de nacionalidade holandesa e bósnia.</segment>
    <segment id="59">Os suspeitos holandeses estariam ligados a Ridouan Taghi</segment>
    <segment id="60">, preso em Dubai em 2019 e hoje em julgamento na Holanda</segment>
    <segment id="61">, segundo disse à agência de notícias</segment>
    <segment id="62">AFP uma fonte que pediu anonimato.</segment>
    <segment id="63">Taghi é acusado de comandar uma quadrilha de tráfico de cocaína em Amsterdã e</segment>
    <segment id="64">, entre outros crimes</segment>
    <segment id="65">, de homicídio.</segment>
  </rst>
</analysis>