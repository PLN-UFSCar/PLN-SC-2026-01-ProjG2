  <rst>
    <segment id="1">Único jogador tricampeão da Copa do Mundo</segment>
    <segment id="2">, atleta que parou uma guerra</segment>
    <segment id="3">, autor de mais de 1.283 gols.</segment>
    <segment id="4">Morreu nesta quinta (29) aos 82 anos o melhor jogador de futebol da história</segment>
    <segment id="5">, Pelé.</segment>
    <segment id="6">Ele estava internado no Hospital Albert Einstein</segment>
    <segment id="7">, em São Paulo</segment>
    <segment id="8">, onde tratava um câncer em estado terminal.</segment>
    <segment id="9">Nas redes</segment>
    <segment id="10">, multiplicaram-</segment>
    <segment id="11">sese as mensagens de luto e tristeza</segment>
    <segment id="12">, acompanhadas de emojis de corações quebrados e carinhas de choro.</segment>
    <segment id="13">Ao mesmo tempo</segment>
    <segment id="14">, fãs agradeceram ao Rei pela contribuição ao esporte e resgataram vídeos de antigas jogadas.</segment>
    <segment id="15">Em pouco tempo</segment>
    <segment id="16">, o nome esportista chegou ao primeiro lugar nos ranking mundial dos tópicos mais comentados do Twitter.</segment>
    <segment id="17">A repercussão não veio só de falantes da língua portuguesa.</segment>
    <segment id="18">O lendário jogador brasileiro foi citado em publicações em ao menos outros sete idiomas: espanhol</segment>
    <segment id="19">, inglês</segment>
    <segment id="20">, francês</segment>
    <segment id="21">, italiano</segment>
    <segment id="22">, alemão</segment>
    <segment id="23">, turco</segment>
    <segment id="24">, croata e holandês.</segment>
    <segment id="25">As expressões "Rest in Peace"</segment>
    <segment id="26">, que significa "descanse em paz" na língua inglesa</segment>
    <segment id="27">, e "GOAT"</segment>
    <segment id="28">, gíria no idioma para "o melhor de todos os tempos" estiveram entre os tópicos mais comentador do Twitter.</segment>
    <segment id="29">Não ficou para trás a alcunha "</segment>
    <segment id="30">O Rey"</segment>
    <segment id="31">, das homenagens feitas em espanhol.</segment>
    <segment id="32">"</segment>
    <segment id="33">Não era fã de futebol quando criança</segment>
    <segment id="34">, masmas lembro do meu pai por volta de 1970 nos levando para ver Pelé em um desfile em Toronto e ouvindo que ele era realmente um grande.</segment>
    <segment id="35">Sim, ele era realmente um grande negócio.</segment>
    <segment id="36">Muito possivelmente o maior de todos os tempos.</segment>
    <segment id="37">82.</segment>
    <segment id="38">Muito jovem"</segment>
    <segment id="39">, contou</segment>
    <segment id="40">, em inglês</segment>
    <segment id="41">, uma internauta.</segment>
    <segment id="42">LEIA MAIS SOBRE PELÉCâncer de Pelé progrediu</segment>
    <segment id="43">, e tratamento não surtiu efeitoPelé</segment>
    <segment id="44">sese revelou ao mundo aos 17 anos</segment>
    <segment id="45">, na Copa de 1958Preservado pela família</segment>
