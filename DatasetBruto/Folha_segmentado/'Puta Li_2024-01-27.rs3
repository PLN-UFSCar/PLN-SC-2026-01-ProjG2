  <rst>
    <segment id="1">Puta Livro BomPreço R$ 74</segment>
    <segment id="2">,90 (322 págs.)</segment>
    <segment id="3">; R$ 39</segment>
    <segment id="4">,90 (ebook)Autoria Jason MottEditora RecordTradução Rogerio W. GalindoSegundo Frank Wilderson 3º</segment>
    <segment id="5">, há uma falência da lógica narrativa em um mundo antinegro</segment>
    <segment id="6">, uma vez que o caráter arbitrário e gratuito da violência contra pessoas negras interdita qualquer nexo de causa entre os acontecimentos e desfaz as fronteiras entre escravidão e liberdade.</segment>
    <segment id="7">O escritor americano Jason Mott</segment>
    <segment id="8">, premiado com o National Book Award - Michael Becker/DivulgaçãoO escritor afro-americano Jason Mott</segment>
    <segment id="9">, vencedor do National Book Award em 2021 com este "Puta Livro Bom"</segment>
    <segment id="10">, assume de forma brilhante e inventiva essa falência ao borrar os limites entre real e imaginado em seu premiado romance.</segment>
    <segment id="11">Mott constrói um livro que mergulha no letramento de sobrevivência de meninos e homens negros</segment>
    <segment id="12">, aprisionados por uma realidade que limita a força de sua imaginação</segment>
    <segment id="13">, pois</segment>
    <segment id="14">pois viver</segment>
    <segment id="15">sese torna uma tentativa constante de não morrer —escapando do clarão branco da morte que os faróis da polícia anunciam quando deitam suas luzes sobre os corpos negros.</segment>
    <segment id="16">Acompanhamos os passos de três figuras sem nome: o Autor</segment>
    <segment id="17">, o Garoto e Fuligem.</segment>
    <segment id="18">"</segment>
    <segment id="19">Puta</segment>
    <segment id="20">Livro</segment>
    <segment id="21">Bom</segment>
    <segment id="22">" é o mesmo título do livro do Autor</segment>
    <segment id="23">, que faz uma turnê de divulgação do seu best-seller rodando pelo país com seu rosto negro estampado em capas de revistas e sites.</segment>
    <segment id="24">Em meio ao glamour do sucesso e às aventuras amorosas</segment>
    <segment id="25">, sua história é intercalada com a de Fuligem</segment>
    <segment id="26">, um menino negro de uma cidadezinha do Sul</segment>
    <segment id="27">, cujos pais o ensinam a ficar invisível para</segment>
    <segment id="28">sese proteger.</segment>
    <segment id="29">No entanto</segment>
    <segment id="30">, todos os dias ele fracassa ao ser lembrado de que é "preto feito fuligem de chaminé" e ao ver notícias de meninos negros que são baleados.</segment>
    <segment id="31">Protestos contra morte de Daunte Wright</segment>
    <segment id="32">, homem negro baleado em abordagem policial nos arredores de MinneapolisMais    novamente         de   de  de  representando um</segment>
    <segment id="33">Enquanto o Autor vive o auge de uma visibilidade midiática</segment>
    <segment id="34">, reconhecido em todos os lugares</segment>
    <segment id="35">comocomo um grande escritor negro</segment>
    <segment id="36">, Fuligem é um menino solitário que</segment>
    <segment id="37">, com sua pele preta "feito uma noite sem estrelas"</segment>
    <segment id="38">, deseja ficar invisível para não mais sofrer.</segment>
    <segment id="39">É como</segment>
    <segment id="40">como se</segment>
    <segment id="41">se a história de Fuligem fosse também o passado que o escritor quer evitar e</segment>
    <segment id="42">, ao mesmo tempo</segment>
    <segment id="43">, um lembrete de</segment>
    <segment id="44">comocomo muitos jovens negros</segment>
    <segment id="45">, contraditoriamente</segment>
    <segment id="46">, permanecem invisíveis em sua vulnerabilidade e beleza.</segment>
    <segment id="47">Entre esses dois personagens emerge o Garoto</segment>
    <segment id="48">, visível apenas para o Autor e que o acompanha em sua turnê.</segment>
    <segment id="49">Esse Garoto</segment>
    <segment id="50">, cuja pele tem o mesmo "esplendor" e "negrume" de um exuberante pavão preto</segment>
    <segment id="51">, sese torna o que há de mais real e belo para um escritor.</segment>
    <segment id="52">Sua gargalhada tem "o som de todas as coisas boas que já aconteceram comigo"</segment>
    <segment id="53">, segundo o Autor</segment>
    <segment id="54">, masmas nem todos podem ouvi-la quando tiros silenciam a risada de tantos meninos negros.</segment>
    <segment id="55">Não à toa</segment>
    <segment id="56">, o Autor queria o impossível:</segment>
    <segment id="57">"que esse menino pudesse rir para sempre".</segment>
    <segment id="58">Tudo a lerReceba no seu email uma seleção com lançamentos</segment>
    <segment id="59">, clássicos e curiosidades literáriasCarregando...</segment>
    <segment id="60">Mott abre espaço para uma relação entre um homem e um menino negro que instaura outra realidade:</segment>
    <segment id="61">é o mundo invisível que</segment>
    <segment id="62">sese torna real.</segment>
    <segment id="63">Nesse encontro</segment>
    <segment id="64">, o Garoto bagunça as distinções entre real e imaginário</segment>
    <segment id="65">, levando o Autor a</segment>
    <segment id="66">sese voltar para traumas e memórias do passado</segment>
    <segment id="67">, entendendo o quanto ele precisou</segment>
    <segment id="68">sese tornar escritor para sobreviver.</segment>
    <segment id="69">Com o Autor lidando com as armadilhas racistas do sucesso</segment>
    <segment id="70">, com o alcoolismo</segment>
    <segment id="71">, com a insegurança</segment>
    <segment id="72">, é o Garoto que "vai deixando a vida mais insuportável"</segment>
    <segment id="73">, uma vez que não sabe</segment>
    <segment id="74">sese "um negro pode ser feliz nesse mundo".</segment>
    <segment id="75">Pensar</segment>
    <segment id="76">sese Garoto</segment>
    <segment id="77">, Fuligem e Autor são a mesma pessoa é irrelevante</segment>
    <segment id="78">, pois</segment>
    <segment id="79">pois os três coexistem em todos os homens negros "despedaçados e tentando lembrar que são belos".</segment>
    <segment id="80">E, mesmo sem nomes próprios</segment>
    <segment id="81">, eles não são estatísticas.</segment>
    <segment id="82">Ao não lhes dar nome</segment>
    <segment id="83">, Mott parece sugerir que não é preciso um nome</segment>
    <segment id="84">para que</segment>
    <segment id="85">para que a vida de um homem negro importe.</segment>
    <segment id="86">Mas em Fuligem</segment>
    <segment id="87">, Garoto e</segment>
    <segment id="88">Autor cabe o nome de cada homem negro que</segment>
    <segment id="89">sese foi e que segue vivo</segment>
    <segment id="90">, pois</segment>
    <segment id="91">pois esse romance é</segment>
    <segment id="92">, como</segment>
    <segment id="93">como diz o Autor</segment>
    <segment id="94">, "uma história sobre amor".</segment>
    <segment id="95">E, realmente</segment>
    <segment id="96">, um puta livro bom.</segment>
  </rst>
