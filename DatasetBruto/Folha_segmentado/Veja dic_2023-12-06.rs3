  <rst>
    <segment id="1">O fim do ano chegou e</segment>
    <segment id="2">, com ele</segment>
    <segment id="3">, está aberta a temporada de presentes natalinos.</segment>
    <segment id="4">Como quase todo mundo tem parentes ou amigos apaixonados por café</segment>
    <segment id="5">, o Café na Prensa separou algumas dicas de presentes</segment>
    <segment id="6">, para todos os bolsos e para pessoas com diferentes níveis de conhecimento sobre a bebida.</segment>
    <segment id="7">Equipamentos e utensílios são boas opções de presente para quem é apaixonado por café - Karime Xavier/FolhapressUma das primeiras dicas para presentear alguém que está começando a</segment>
    <segment id="8">sese aventurar no mundo dos cafés de qualidade é um bom coador.</segment>
    <segment id="9">Fazer um café no tradicional filtro de papel estilo Melitta não é ruim</segment>
    <segment id="10">, masmas há no mercado opções de coador que produzem cafés bem mais limpos.</segment>
    <segment id="11">Um dos mais famosos e acessíveis é o modelo V60</segment>
    <segment id="12">, da Hario</segment>
    <segment id="13">, que custa cerca de R$ 60.</segment>
    <segment id="14">Outro ótimo presente é um moedor.</segment>
    <segment id="15">É unânime entre os especialistas que moer o café na hora faz toda a diferença.</segment>
    <segment id="16">Há opções manuais –que normalmente produzem uma moagem mais precisa– e automáticas –mais práticas</segment>
    <segment id="17">, pois</segment>
    <segment id="18">pois basta apertar um botão.</segment>
    <segment id="19">Confira na galeria e na lista abaixo várias dicas de presentes para os apaixonados por café.</segment>
    <segment id="20">Dicas de presente para quem ama caféMais    novamente         de   de  de  representando um    MOEDORES</segment>
    <segment id="21">Um moedor é um ótimo presente para quem quer fazer um café mais fresco e saboroso.</segment>
    <segment id="22">Há no mercado opções por menos de R$ 50.</segment>
    <segment id="23">Quem puder investir um pouco mais</segment>
    <segment id="24">, há versões automáticas</segment>
    <segment id="25">, como</segment>
    <segment id="26">como o da marca Cadence</segment>
    <segment id="27">, a partir de R$ 110.</segment>
    <segment id="28">Existem também os manuais de marcas mais renomadas</segment>
    <segment id="29">, como</segment>
    <segment id="30">como a japonesa Hario</segment>
    <segment id="31">, que conseguem produzir uma moagem mais uniforme.</segment>
    <segment id="32">Custam a partir de R$ 300.</segment>
    <segment id="33">Colunas e BlogsReceba no seu email uma seleção de colunas e blogs da FolhaCarregando...</segment>
    <segment id="34">MÉTODOS DE PREPARO   Quem quiser algo mais completo pode presentear alguém querido com o kit de preparo da Hario.</segment>
    <segment id="35">Além do coador</segment>
    <segment id="36">, vem com a jarra de vidro de 700ml</segment>
    <segment id="37">, pacote de filtros de papel e uma colher medidora.</segment>
    <segment id="38">Custa a partir de R$ 150.</segment>
    <segment id="39">Método charmoso de preparo de café por infusão</segment>
    <segment id="40">, a prensa francesa agrada sobretudo àqueles que gostam de cafés mais encorpados.</segment>
    <segment id="41">Há opções no mercado por menos de R$ 50.</segment>
    <segment id="42">As opções de marcas mais tradicionais</segment>
    <segment id="43">, no entanto</segment>
    <segment id="44">, podem passar dos R$ 200</segment>
    <segment id="45">, como</segment>
    <segment id="46">como esta da Bialetti</segment>
    <segment id="47">, que custa R$ 299.</segment>
    <segment id="48">A mesma Bialetti</segment>
    <segment id="49">, criadora da cafeteira italiana</segment>
    <segment id="50">, tem um kit com uma Moka Express e duas canecas</segment>
    <segment id="51">, por R$ 570.</segment>
    <segment id="52">CONJUNTOS COM CAFÉ   Tradicional empresa de café italiana</segment>
    <segment id="53">, a illy tem kits de presentes em elegantes embalagens</segment>
    <segment id="54">, como</segment>
    <segment id="55">como o Wonder Box</segment>
    <segment id="56">, que traz duas xícaras</segment>
    <segment id="57">Art Collection Judy Chicago e duas latas de café (250g</segment>
    <segment id="58">, cada)</segment>
    <segment id="59">, sendo um clássico e outro intenso.</segment>
    <segment id="60">Sai por R$ 428</segment>
    <segment id="61">,45.</segment>
    <segment id="62">O kit presenteável da Orfeu inclui duas canecas e uma caixa de drip coffee</segment>
    <segment id="63">, para preparar o coado direto na caneca</segment>
    <segment id="64">, por R$ 154</segment>
    <segment id="65">,90.</segment>
    <segment id="66">A torrefação paulistana Wolff tem um kit para degustação das quatro linhas</segment>
    <segment id="67">W que a marca oferece.</segment>
    <segment id="68">Há desde cafés com notas de caramelo até perfis sensoriais frutados.</segment>
    <segment id="69">Cada um dos quatro cafés tem 250 g e pode vir já moído ou em grãos.</segment>
    <segment id="70">R$ 152</segment>
    <segment id="71">,00.</segment>
    <segment id="72">MenuA newsletter de gastronomia exclusiva para assinantes da Folha no plano Digital PremiumCarregando...</segment>
    <segment id="73">OUTROS KITS   Para aqueles que gostam de café e também não dispensam uma cervejinha</segment>
    <segment id="74">, um ótimo presente são as três versões da Coffee Time Baristas</segment>
    <segment id="75">, da paulistana Trilha Cervejaria</segment>
    <segment id="76">, que foram assinadas por três baristas renomados: Boram</segment>
    <segment id="77">Um, Tiago de Mello e Mari Mesquita.</segment>
    <segment id="78">Há quem não dispense um chocolate para acompanhar aquele cafezinho da tarde.</segment>
    <segment id="79">Por isso</segment>
    <segment id="80">, o kit presenteável montado pela chocolateria Dengo pode ser um ótimo presente.</segment>
    <segment id="81">Além de 1 chocolate quebra-quebra de banana com castanha (200g)</segment>
    <segment id="82">, ele vem com duas bonitas xícaras de cerâmica e sai por R$ 225</segment>
    <segment id="83">,70.</segment>
    <segment id="84">Já que época de Natal é verão no Brasil</segment>
    <segment id="85">, um café gelado pode ser um bom presente</segment>
    <segment id="86">, sobretudo para quem gosta dessa onda de cold brews hipercafeinados.</segment>
    <segment id="87">Uma das opções disponíveis no mercado é o Mombak</segment>
    <segment id="88">, que tem uma caixa com 6 garrafas sendo duas de cada um dos sabores fabricados pela marca: Macchiato</segment>
    <segment id="89">, Cappuccino e Dark Chocolate.</segment>
    <segment id="90">O conjunto custa R$ 50</segment>
    <segment id="91">,76.</segment>
    <segment id="92">  Acompanhe o Café na Prensa também pelo Instagram @davidmclucena e pelo Twitter @davidlucena</segment>
    <segment id="93">Qual assunto você gostaria de ver aqui no blog?</segment>
    <segment id="94">Envie sugestões para david.lucena@folhapress.com.br</segment>
  </rst>
</analysis>