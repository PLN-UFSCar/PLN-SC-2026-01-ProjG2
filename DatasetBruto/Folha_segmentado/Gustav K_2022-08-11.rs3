  <rst>
    <segment id="1">A mulher é o motivo mais importante da obra de Gustav Klimt</segment>
    <segment id="2">, pintor cuja trajetória é tema do 14º volume da Coleção Folha Grandes Pintores e para o qual a mãe e as irmãs tiveram papel central</segment>
    <segment id="3">, já que</segment>
    <segment id="4">, depois da morte do pai e do irmão</segment>
    <segment id="5">, passou a viver com elas.</segment>
    <segment id="6">O artista austríaco</segment>
    <segment id="7">sese dedicou tanto a figuras da mitologia grega</segment>
    <segment id="8">comocomo a retratos de damas da sociedade vienense.</segment>
    <segment id="9">Estes, além de funcionar</segment>
    <segment id="10">comocomo testemunho da aristocracia</segment>
    <segment id="11">, também representam exercícios quase abstratos por meio da exploração da cor e dos motivos decorativos.</segment>
    <segment id="12">&amp;#</segment>
    <segment id="13">039;O Beijo&amp;#039</segment>
    <segment id="14">;, de Gustav Klimt</segment>
    <segment id="15">, que ilustra a capa do 14º volume da Coleção Folha Grandes Pintores</segment>
    <segment id="16">, &amp;#039</segment>
    <segment id="17">;Klimt: Realidade Simbólica&amp;#039</segment>
    <segment id="18">; - DivulgaçãoQuando viajou à Itália</segment>
    <segment id="19">, em 1903</segment>
    <segment id="20">, e visitou Veneza e Florença</segment>
    <segment id="21">, Klimt ficou deslumbrado pela riqueza dos mosaicos bizantinos de Ravena e o fundo dourado característico desse período.</segment>
    <segment id="22">Tal descoberta deu início à "fase dourada" e culminou na realização de "</segment>
    <segment id="23">O Beijo"</segment>
    <segment id="24">, sua obra mais conhecida</segment>
    <segment id="25">, realizada em 1908 e 1909.</segment>
    <segment id="26">A coleção enfatiza</segment>
    <segment id="27">comocomo</segment>
    <segment id="28">, em suas pinturas de paisagem e natureza</segment>
    <segment id="29">, Klimt renunciou à perspectiva e trabalhou o espaço pictórico a partir de escalas de cor.</segment>
    <segment id="30">Ao contrário dos impressionistas</segment>
    <segment id="31">, no entanto</segment>
    <segment id="32">, ele nunca</segment>
    <segment id="33">sese interessou pelas variações atmosféricas.</segment>
    <segment id="34">Preferia</segment>
    <segment id="35">sese concentrar na imobilidade da cena e recorrer a soluções plásticas neoimpressionistas para elaborar uma linguagem formal.</segment>
    <segment id="36">Exposição de Gustav KlimtMais    novamente         de   de  de  representando um</segment>
    <segment id="37">Nos últimos anos de sua vida</segment>
    <segment id="38">, o pintor substituiu os retratos da alta burguesia por mulheres anônimas</segment>
    <segment id="39">, pensativas e sorridentes</segment>
    <segment id="40">, que são representadas com um estilo claramente expressionista</segment>
    <segment id="41">, com roupas que</segment>
    <segment id="42">sese distanciam da "alta-costura" e assumem cores liquefeitas.</segment>
    <segment id="43">Confira todos os volumes da Coleção Folha Grandes PintoresMais    novamente         de   de  de  representando um</segment>
    <segment id="44">A sua produção em desenho</segment>
    <segment id="45">, que foi por muito tempo subestimada</segment>
    <segment id="46">, também é assunto da coleção.</segment>
    <segment id="47">Nela, Klimt</segment>
    <segment id="48">sese voltou</segment>
    <segment id="49">, mais uma vez</segment>
    <segment id="50">, para as mulheres.</segment>
    <segment id="51">Ali, com traços rápidos e sem retoque</segment>
    <segment id="52">, as representou nuas ou praticamente sem roupa.</segment>
    <segment id="53">Para observar seus movimentos</segment>
    <segment id="54">, é sabido que ele costumava pedir a duas ou três modelos que andassem nuas pelo seu ateliê sem posar.</segment>
    <segment id="55">O artista morreu em 1918 de apoplexia</segment>
    <segment id="56">, assim</segment>
    <segment id="57">comocomo seu pai.</segment>
    <segment id="58">Sua obra abrange cerca de 230 pinturas</segment>
    <segment id="59">, entre 54 paisagens</segment>
    <segment id="60">, e conta ainda com afrescos e milhares de desenhos.</segment>
    <segment id="61">COMO COMPRAR</segment>
    <segment id="62">Site da coleção</segment>
    <segment id="63">Telefone: (11)</segment>
    <segment id="64">3224-3090 (Grande São Paulo) e 0800 775 8080 (outras localidades)</segment>
    <segment id="65">Frete grátis SP</segment>
    <segment id="66">, RJ, MG e PR (na compra da coleção completa)</segment>
    <segment id="67">Nas bancas por R$ 22</segment>
    <segment id="68">,90 o volume</segment>
    <segment id="69">Coleção completa: R$ 687</segment>
    <segment id="70">; lote avulso (com seis volumes</segment>
    <segment id="71">):</segment>
    <segment id="72">R$ 134</segment>
    <segment id="73">,70</segment>
  </rst>
</analysis>