  <rst>
    <segment id="1">Sorocaba</segment>
    <segment id="2">, cidade que fica a 99 km da capital paulista</segment>
    <segment id="3">, recebe neste fim de semana um evento com 200 felinos.</segment>
    <segment id="4">A 4ª Expo Gatos</segment>
    <segment id="5">Sorocaba terá concurso de beleza</segment>
    <segment id="6">, adoção de bichanos e bate-papo sobre a saúde dos pets.</segment>
    <segment id="7">O encontro é organizado pela Amacoon (Associação Maine Coon no Brasil) e será realizado neste sábado (3) e neste domingo (4)</segment>
    <segment id="8">, das 10h às 18h</segment>
    <segment id="9">, no Hotel Golden Park</segment>
    <segment id="10">, no bairro Iporanga.</segment>
    <segment id="11">A entrada é gratuita</segment>
    <segment id="12">, masmas os visitantes podem levar uma lata de ração em pasta ou um sachê.</segment>
    <segment id="13">As doações serão entregues à AATAN (Associação Abrigo Temporário de Animais Necessitados)</segment>
    <segment id="14">, que cuida de animais abandonados em Sorocaba.</segment>
    <segment id="15">Exposição de gatos em SorocabaMais    novamente         de   de  de  representando um</segment>
    <segment id="16">Os gatos participarão de competições de beleza nas categorias:</segment>
    <segment id="17">Melhor da Classe</segment>
    <segment id="18">;</segment>
    <segment id="19">Melhor da Cor</segment>
    <segment id="20">;</segment>
    <segment id="21">Melhor da Raça</segment>
    <segment id="22">;</segment>
    <segment id="23">Melhor da Categoria e o Campeão entre todos.</segment>
    <segment id="24">Entre as raças que irão competir estão maine coon</segment>
    <segment id="25">, ocicat</segment>
    <segment id="26">, exótico</segment>
    <segment id="27">, oriental de pelo curto</segment>
    <segment id="28">, persa</segment>
    <segment id="29">, british short hair</segment>
    <segment id="30">, ragdoll</segment>
    <segment id="31">, bengal e sphynx.</segment>
    <segment id="32">"Estamos muito ansiosos por mais uma exposição na cidade de Sorocaba</segment>
    <segment id="33">, que sempre é um sucesso com diversas raças de gatos.</segment>
    <segment id="34">Um ótimo passeio para a família e com entrada gratuita"</segment>
    <segment id="35">, comenta o presidente da Amacoon</segment>
    <segment id="36">, Hugo Cavalheiro.</segment>
    <segment id="37">Os juízes responsáveis por avaliar os felinos são Aliosha Romero (Islândia)</segment>
    <segment id="38">, Grażyna Laskowska-Malaga (Polônia)</segment>
    <segment id="39">, Juan José Martinez Vizcaino (Espanha) e Marteinn Tausen (Islândia).</segment>
    <segment id="40">A competição internacional</segment>
    <segment id="41">, realizada pela quarta vez em Sorocaba</segment>
    <segment id="42">, é uma etapa do Campeonato Brasileiro FIFe de Gatos de Raça.</segment>
    <segment id="43">Esta também é última etapa classificatória para a American Winner 2023.</segment>
    <segment id="44">"</segment>
    <segment id="45">Um diferencial deste ano é que a Expo Gatos Sorocaba será a última oportunidade para classificação dos gatos para o American Winner</segment>
    <segment id="46">, competição de titulação internacional que terá o Brasil</segment>
    <segment id="47">comocomo sede pela primeira vez"</segment>
    <segment id="48">, diz Marcelo Ravagnani</segment>
    <segment id="49">, vice-presidente da Amacoon.</segment>
    <segment id="50">Adoção de gatos Haverá uma feirinha de adoção com 45 gatos da AATAN.</segment>
    <segment id="51">Na edição do ano passado do evento</segment>
    <segment id="52">, 42 bichanos foram adotados.</segment>
    <segment id="53">"</segment>
    <segment id="54">Atualmente</segment>
    <segment id="55">, nós temos 70 gatinhos à espera de uma nova família.</segment>
    <segment id="56">Essa parceria com a Amacoon é de grande ajuda para nós</segment>
    <segment id="57">, também</segment>
    <segment id="58">comocomo forma de divulgar o nosso trabalho"</segment>
    <segment id="59">, conta Caroline Vitale</segment>
    <segment id="60">, tesoureira da AATAN.</segment>
    <segment id="61">Papo de gato</segment>
    <segment id="62">Palestras realizadas em parceria com a Royal Canin</segment>
    <segment id="63">, patrocinadora oficial do evento</segment>
    <segment id="64">, serão conduzidas por especialistas em felinos.</segment>
    <segment id="65">Os workshops fazem parte da campanha Meu Gato no Vet</segment>
    <segment id="66">, que estimula tutores a cuidarem melhor da saúde de seus pets.</segment>
    <segment id="67">+</segment>
    <segment id="68">GaticesLeia</segment>
    <segment id="69">mais sobre gatosPerfil reúne fotos de gatos espiando a vida alheia em janelasRinotraqueíte em gatos causa coriza</segment>
    <segment id="70">, espirros e conjuntiviteGata com deficiência viraliza ao abrir a boca para pedir comidaGatos adultos</segment>
    <segment id="71">, frajolas e escaminhas são rejeitados na adoção4ª Expo Gatos Sorocaba</segment>
    <segment id="72">Quando: sábado (3) e domingo (4)</segment>
    <segment id="73">, das 10h às 18h</segment>
    <segment id="74">Onde: Hotel Golden Park</segment>
    <segment id="75">, rodovia SP-75 (Castelinho)</segment>
    <segment id="76">, km 2</segment>
    <segment id="77">,6 sentido Sul</segment>
    <segment id="78">, s/n, bairro Iporanga</segment>
    <segment id="79">Quanto:</segment>
    <segment id="80">entrada gratuita</segment>
    <segment id="81">, masmas a doação de uma lata de ração em basta ou sachê é bem-vinda</segment>
    <segment id="82">Saiba mais: amacoon.com.br</segment>
    <segment id="83">Siga o blog</segment>
    <segment id="84">Gatices</segment>
    <segment id="85">no Twitter</segment>
    <segment id="86">, Instagram e Facebook</segment>
    <segment id="87">.</segment>
  </rst>
</analysis>