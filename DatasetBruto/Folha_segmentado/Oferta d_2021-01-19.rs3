  <rst>
    <segment id="1">Em 2020</segment>
    <segment id="2">, ano em que a pandemia dificultou o abastecimento pela indústria</segment>
    <segment id="3">, o produto que mais faltou no supermercado foi o ovo</segment>
    <segment id="4">, segundo monitoramento da Neogrid</segment>
    <segment id="5">, empresa de software para o varejo.</segment>
    <segment id="6">O índice que mede a falta de variedades do produto nas gôndolas chegou a 22</segment>
    <segment id="7">,73%, enquanto foi de 17</segment>
    <segment id="8">, 83% em 2019.</segment>
    <segment id="9">Robson Munhoz</segment>
    <segment id="10">, vice-presidente da empresa</segment>
    <segment id="11">, diz que os supermercados seguraram a compra dos ovos para negociar os preços</segment>
    <segment id="12">, que subiam devido ao aumento do valor dos insumos de avicultores</segment>
    <segment id="13">, e ao mesmo tempo a demanda por esse item</segment>
    <segment id="14">sese manteve forte por causa do consumo maior na pandemia.</segment>
    <segment id="15">Variedade de ovos foi afetada em 2020 - Erol Ahmed/Unsplash</segment>
    <segment id="16">No ranking dos produtos mais afetados</segment>
    <segment id="17">, atrás do ovo está o leite longa vida.</segment>
    <segment id="18">O índice relativo ao produto em 2020 foi de 17</segment>
    <segment id="19">,56%, ante 16</segment>
    <segment id="20">,13% do ano anterior.</segment>
    <segment id="21">Também aparacem na lista álcool (16</segment>
    <segment id="22">,52%) e massa</segment>
    <segment id="23">, (14,34%).</segment>
    <segment id="24">Cervejas</segment>
    <segment id="25">, que foram motivo de preocupação após a flexibilização das medidas de distanciamento</segment>
    <segment id="26">, fecharam o ano com 14</segment>
    <segment id="27">,28%.</segment>
    <segment id="28">No índice que considera todos os produtos</segment>
    <segment id="29">, a falta de variedades chegou a 11</segment>
    <segment id="30">,86%, acima dos 10</segment>
    <segment id="31">,97% de 2019 e de 10</segment>
    <segment id="32">,01% de 2018.​  Ida ao supermercado requer cuidados especiaisMais    novamente         de   de  de  representando um    Filipe Oliveira (interino)</segment>
    <segment id="33">, com Mariana Grazini e Arthur Cagliari</segment>
  </rst>
