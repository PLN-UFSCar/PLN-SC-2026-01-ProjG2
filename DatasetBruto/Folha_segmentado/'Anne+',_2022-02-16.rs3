  <rst>
    <segment id="1">Em "Anne+: O Filme"</segment>
    <segment id="2">, uma jovem escritora lésbica de Amsterdã</segment>
    <segment id="3">sese muda para Montreal para ficar com sua namorada.</segment>
    <segment id="4">Mas seus planos mudam depois que ela conhece um homem trans e passa a questionar o que realmente quer da vida.</segment>
    <segment id="5">Cena do filme &amp;#039</segment>
    <segment id="6">;Anne+&amp;#039</segment>
    <segment id="7">;, dirigido por Valerie Bisscheroux e exclusivo da Netflix - Divulgação</segment>
    <segment id="8">Este filme holandês exclusivo da Netflix é uma continuação da série de mesmo nome</segment>
    <segment id="9">, cujas duas temporadas estão disponíveis gratuitamente no YouTube.</segment>
    <segment id="10">Netflix</segment>
    <segment id="11">, 16 anos   TQM</segment>
    <segment id="12">Uma famosa psiquiatra mexicana decide pôr seus filhos à prova para resolver</segment>
    <segment id="13">comocomo dividir sua herança.</segment>
    <segment id="14">Mas nem tudo sai conforme o planejado.</segment>
    <segment id="15">Amazon Prime Video</segment>
    <segment id="16">, 16 anos</segment>
    <segment id="17">O Maracatu e Suas Imagens: Festa</segment>
    <segment id="18">, Resistência e Tensões</segment>
    <segment id="19">O artista e comunicador Valmir do Coco e o músico Anderson Miguel</segment>
    <segment id="20">, que participam do filme "Azougue Nazaré"</segment>
    <segment id="21">, conversam sobre o maracatu e outras festas pernambucanas nesta live mediada por Clarisse Kubrusly e Lucas Van de Beuque.</segment>
    <segment id="22">YouTube do Museu do Pontal</segment>
    <segment id="23">, 18h</segment>
    <segment id="24">Conheça folias centenárias de PernambucoMais    novamente         de   de  de  representando um  Modernismo Hoje: Estudos Atuais</segment>
    <segment id="25">Esta série documental em 11 episódios da Academia Paulista de Letras discute o legado da Semana de Arte Moderna de 1922.</segment>
    <segment id="26">Também exibida aos domingos</segment>
    <segment id="27">, às 20h30.  culturaemcasa.com.br</segment>
    <segment id="28">, 20h30</segment>
    <segment id="29">, livre</segment>
    <segment id="30">Conheça obras que marcaram o modernismo Mais    novamente         de   de  de  representando um  Linhas Cruzadas</segment>
    <segment id="31">A jornalista Thaís Oyama e o filósofo e colunista da Folha Luiz Felipe Pondé discutem o fenômeno do "burnout"</segment>
    <segment id="32">, o cansaço extremo causado pelo excesso de trabalho.</segment>
    <segment id="33">Cultura</segment>
    <segment id="34">, 22h, 16 anos</segment>
    <segment id="35">Não Matarás  Em 1988</segment>
    <segment id="36">, o cineasta polonês Krzysztof Kieslowski lançou "</segment>
    <segment id="37">O Decálogo"</segment>
    <segment id="38">, uma série de dez filmes baseados nos Dez Mandamentos.</segment>
    <segment id="39">No mais famoso deles</segment>
    <segment id="40">, um rapaz mata um taxista</segment>
    <segment id="41">, sem ter motivo.</segment>
    <segment id="42">Telecine Cult</segment>
    <segment id="43">, 22h, 16 anos</segment>
    <segment id="44">O Dono da Bola  Carlos Bronco</segment>
    <segment id="45">, personagem que Ronald Golias encarnou por muitos anos</segment>
    <segment id="46">, participa de uma gincana num programa de TV</segment>
    <segment id="47">, em busca de prêmios para saldar dívidas.</segment>
    <segment id="48">Esta chanchada de 1961 ainda tem Grande Otelo e Costinha no elenco.  TV Brasil</segment>
    <segment id="49">, 22h30</segment>
    <segment id="50">, 12 anos</segment>
