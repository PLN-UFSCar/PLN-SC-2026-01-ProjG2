  <rst>
    <segment id="1">Quem já teve um sonho lúcido sabe do que estou falando.</segment>
    <segment id="2">Tudo ao seu redor parece vívido</segment>
    <segment id="3">, como</segment>
    <segment id="4">como as cores amarela e verde da camisa de um bolsonarista agarrado na dianteira de um caminhão em movimento.</segment>
    <segment id="5">Você acha estranho</segment>
    <segment id="6">, masmas segue em frente</segment>
    <segment id="7">, com a determinação de um caminhoneiro que dirige quilômetros olhando para a cara de um golpista colada em seu para-brisas.</segment>
    <segment id="8">Mas daí você tropeça em uma cena tão estapafúrdia</segment>
    <segment id="9">, tão surreal</segment>
    <segment id="10">, que os filmes de David Lynch agora parecem mais claros e coerentes do que uma bula de remédio.</segment>
    <segment id="11">Trata-</segment>
    <segment id="12">sese de um grupo de pessoas ao redor de um pneu</segment>
    <segment id="13">, cantando o hino nacional</segment>
    <segment id="14">, no meio de uma estrada.</segment>
    <segment id="15">Ilustração de Silvis para a coluna da Manuela Cantuária - FolhapressE</segment>
    <segment id="16">, quando você</segment>
    <segment id="17">sese pega tentando interpretar o simbolismo da roda enquanto representação dos ciclos e do constante movimento da vida</segment>
    <segment id="18">, é aí que bate aquela dúvida: será que botaram alguma coisa na sua bebida?</segment>
    <segment id="19">Ou ainda: será que botaram alguma coisa na bebida desse pessoal?</segment>
    <segment id="20">A segunda hipótese ganha força quando chega até você uma teoria que vem circulando em grupos de WhatsApp</segment>
    <segment id="21">, de que a Lady Gaga seria a "primeira-ministra</segment>
    <segment id="22">" do Tribunal de Haia</segment>
    <segment id="23">e estaria prestes a promover uma intervenção federal no país.</segment>
    <segment id="24">Aqui você flerta com a ideia de estar sonhando</segment>
    <segment id="25">, masmas não vai adiante</segment>
    <segment id="26">, certo de que seu inconsciente não seria criativo a esse ponto.</segment>
    <segment id="27">Veja manifestações antidemocráticas nas rodovias na quarta-feira (2)Mais    novamente         de   de  de  representando</segment>
    <segment id="28">um  Você é obrigado a dar o braço a torcer.</segment>
    <segment id="29">O bolsonarista tem um talento nato para teorias da conspiração.</segment>
    <segment id="30">Consegue elaborar em tempo recorde uma narrativa híbrida de gêneros que mistura crime</segment>
    <segment id="31">, cultura pop</segment>
    <segment id="32">, humor nonsense</segment>
    <segment id="33">, política</segment>
    <segment id="34">, religião</segment>
    <segment id="35">, terror psicológico.</segment>
    <segment id="36">Faz sentido?</segment>
    <segment id="37">Claro que não</segment>
    <segment id="38">, masmas a arte bolsonarista não</segment>
    <segment id="39">sese explica</segment>
    <segment id="40">, sese sente.</segment>
    <segment id="41">E o sentimento que essa arte evoca é o mais puro</segment>
    <segment id="42">, risonho e límpido constrangimento.</segment>
    <segment id="43">Em seguida você descobre que pilotos relataram ter visto objetos voadores não identificados em Porto Alegre.</segment>
    <segment id="44">Bom, você acredita que existe vida inteligente em outros planetas.</segment>
    <segment id="45">Talvez os ETs também tenham ficado intrigados com os estranhos fenômenos acontecendo no sul do Brasil nesse momento.</segment>
    <segment id="46">Saudação ao pneu</segment>
    <segment id="47">, saudação nazista</segment>
    <segment id="48">, comemoração em clima de Copa de uma prisão que nunca aconteceu.</segment>
    <segment id="49">Na dúvida entre sonho e realidade</segment>
    <segment id="50">, você</segment>
    <segment id="51">sese pergunta quem são os negacionistas: você ou eles.</segment>
  </rst>
</analysis>