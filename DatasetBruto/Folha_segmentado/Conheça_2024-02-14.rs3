  <rst>
    <segment id="1">A Marvel anunciou o elenco do novo filme do Quarteto Fantástico</segment>
    <segment id="2">, com lançamento previsto para julho do ano que vem.</segment>
    <segment id="3">A direção é do cineasta Matt Shakman</segment>
    <segment id="4">, que tenta salvar o estúdio do marasmo na bilheteria.</segment>
    <segment id="5">O líder do grupo de heróis Reed Richards</segment>
    <segment id="6">, ou Senhor Fantástico</segment>
    <segment id="7">, vai ser interpretado por Pedro Pascal</segment>
    <segment id="8">, que virou queridinho de Hollywood com papéis em "The Last of Us" e "The Mandalorian"</segment>
    <segment id="9">, a série derivada de "Star Wars".</segment>
    <segment id="10">Da esq.</segment>
    <segment id="11">para dir.</segment>
    <segment id="12">, os atores Pedro Pascal</segment>
    <segment id="13">, Ebon Moss-Bachrach</segment>
    <segment id="14">, Vanessa Kirby e Joseph Quinn</segment>
    <segment id="15">, que formam o novo Quarteto Fantástico - AFP e ReutersSue Storm</segment>
    <segment id="16">, ou Mulher Invisível</segment>
    <segment id="17">, será vivida por Vanessa Kirby</segment>
    <segment id="18">, de "Napoleão" e "The Crown".</segment>
    <segment id="19">Ebon Moss-Bachrach</segment>
    <segment id="20">, que fez sucesso</segment>
    <segment id="21">comocomo Richie na série "</segment>
    <segment id="22">O Urso"</segment>
    <segment id="23">, foi escalado para o papel de Ben Grimm</segment>
    <segment id="24">, ou Coisa</segment>
    <segment id="25">, homem que tem pedra no lugar de pele.</segment>
    <segment id="26">Completa o grupo o ator Joseph Quinn</segment>
    <segment id="27">, o Eddie Munson de "Stranger Things"</segment>
    <segment id="28">, que fará Johnny Storm</segment>
    <segment id="29">, chamado também de Tocha Humana.</segment>
    <segment id="30">Conheça o novo Quarteto Fantástico da MarvelMais    novamente         de   de  de  representando um</segment>
    <segment id="31">A escalação dos atores tem sido alvo de especulação dos fãs há anos</segment>
    <segment id="32">, que esperam por um novo filme desde o fiasco da última encarnação do quarteto</segment>
    <segment id="33">, em 2015.</segment>
    <segment id="34">Antes, o grupo havia sido interpretado por outros nomes em dois filmes</segment>
    <segment id="35">, de 2005 e 2007</segment>
    <segment id="36">, que também não vingaram.</segment>
    <segment id="37">As três primeiras adaptações foram lançadas pela Fox.</segment>
    <segment id="38">O novo longa-metragem é produto da Disney</segment>
    <segment id="39">, que adquiriu os direitos sobre os personagens</segment>
    <segment id="40">, e, por causa disso</segment>
    <segment id="41">, pode incorporar os personagens ao seu universo de filmes de heróis</segment>
    <segment id="42">, com Thor</segment>
    <segment id="43">, Hulk</segment>
    <segment id="44">, Capitã Marvel e todos os Vingadores.</segment>
    <segment id="45">Veja cenas do &amp;#039</segment>
    <segment id="46">;Quarteto Fantástico&amp;#039</segment>
    <segment id="47">;</segment>
    <segment id="48">de 2015Mais    novamente         de   de  de  representando</segment>
    <segment id="49">um</segment>
  </rst>
