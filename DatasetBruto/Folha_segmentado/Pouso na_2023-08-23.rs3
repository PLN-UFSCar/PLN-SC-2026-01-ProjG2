    <segment id="116">Populismo</segment>
    <segment id="117">, inépcia</segment>
    <segment id="118">, irresponsabilidade</segment>
    <segment id="119">, patrimonialismo</segment>
    <segment id="120">, culto ao estado hipertrofiado</segment>
    <segment id="121">, aversão à modernização do Estado</segment>
    <segment id="122">, intervenções governamentais na economia</segment>
    <segment id="123">, patrimonialismo e corrupção são os ingredientes presentes em quase todo governo argentino</segment>
    <segment id="124">, em especial os peronistas</segment>
    <segment id="125">, e são os grandes culpados pela desgraça que assola o país.</segment>
    <segment id="126">Tais ingredientes são endêmicos na América Latina e encontrados também no Brasil e Venezuela.</segment>
    <segment id="127">Jorge Rodrigues (Rio de Janeiro</segment>
    <segment id="128">, RJ)</segment>
