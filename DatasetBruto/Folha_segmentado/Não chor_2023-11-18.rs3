  <rst>
    <segment id="1">Buemba!</segment>
    <segment id="2">Buemba!</segment>
    <segment id="3">Macaco Simão urgente!</segment>
    <segment id="4">O esculhambador-geral da República!  Piada pronta: "</segment>
    <segment id="5">Energia cai durante a CPI da Enel para ouvir o presidente da empresa".</segment>
    <segment id="6">Enel que é acrônimo para E</segment>
    <segment id="7">Nada de Energia ou Luz!</segment>
    <segment id="8">Rarará!</segment>
    <segment id="9">E muita atenção!</segment>
    <segment id="10">Não chores por mim Argentina</segment>
    <segment id="11">, que no dia de amanhã és tu na latrina!</segment>
    <segment id="12">Eleições na Argentina!</segment>
    <segment id="13">A eleição presidencial na Argentina não está acirrada</segment>
    <segment id="14">, está acirrose.</segment>
    <segment id="15">Ela dói no fígado!</segment>
    <segment id="16">Milei contra Massa!</segment>
    <segment id="17">MMA: Milei e Massa na Argentina!</segment>
    <segment id="18">O Milei é o Debi e Loide juntos</segment>
    <segment id="19">, dentro da mesma pessoa!Ilustração de Fê para coluna de José Simão de 18 de novembro de 2023 - FolhapressE adoro aquele óculos que voam para tudo quanto é lado.</segment>
    <segment id="20">Ele mais parece um fliperama que está desgovernado!</segment>
    <segment id="21">Se ele ganhar</segment>
    <segment id="22">, a Argentina será governada por um verdadeiro desgovernado!</segment>
    <segment id="23">Rarará!</segment>
    <segment id="24">Milei é um novo "Bozonaro"!  Do Piauí Herald: "</segment>
    <segment id="25">Milei passa a chamar os seus cachorros de 01</segment>
    <segment id="26">, 02, 03 e 04!</segment>
    <segment id="27">".</segment>
    <segment id="28">Rarará!</segment>
    <segment id="29">Por outro lado</segment>
    <segment id="30">, Massa!</segment>
    <segment id="31">Massa é baiano.</segment>
    <segment id="32">Na Bahia tudo é massa!</segment>
    <segment id="33">Eu não entendo os peronistas</segment>
    <segment id="34">, a economia na Argentina está uma merda e eles botam para candidato o atual ministro da Economia.</segment>
    <segment id="35">O verdadeiro ministro da Merda!</segment>
    <segment id="36">É Debi e Loide contra ministro da Merda!</segment>
    <segment id="37">Rarará!</segment>
    <segment id="38">E sabe de uma coisa: eles que</segment>
    <segment id="39">sese danem!</segment>
    <segment id="40">Não choro por ti</segment>
    <segment id="41">, Argentina!</segment>
    <segment id="42">Foda-se</segment>
    <segment id="43">se!</segment>
    <segment id="44">Rarará!</segment>
    <segment id="45">E o bafo da semana foi o bafo.</segment>
    <segment id="46">O bafo dos infernos.</segment>
    <segment id="47">O calor era tamanho que o meu pinguim de geladeira resolveu dormir dentro da geladeira.</segment>
    <segment id="48">Acordei no meio da noite</segment>
    <segment id="49">, fui beber água e o pinguim estava dentro da geladeira.</segment>
    <segment id="50">Rarará!</segment>
    <segment id="51">Não eram as calotas polares que estavam derretendo</segment>
    <segment id="52">, eram as calotas do meu carro!</segment>
    <segment id="53">E um amigo recebeu o boleto</segment>
    <segment id="54">, que diz o seguinte:</segment>
    <segment id="55">"</segment>
    <segment id="56">Bar da Valkiria:</segment>
    <segment id="57">Cinco boquetes</segment>
    <segment id="58">, R$ 130!</segment>
    <segment id="59">Nove programas: R$ 300!</segment>
    <segment id="60">Três fio terra</segment>
    <segment id="61">: R$ 80!</segment>
    <segment id="62">Total: R$ 510!</segment>
    <segment id="63">".</segment>
    <segment id="64">Eita que o dinheiro foi muito bem gasto!</segment>
    <segment id="65">Rarará!</segment>
    <segment id="66">E um Rivotril com muito gelo</segment>
    <segment id="67">, por favor!</segment>
    <segment id="68">Nóis sofre</segment>
    <segment id="69">, masmas nóis goza!</segment>
    <segment id="70">Que eu vou pingar o meu colírio alucinógeno!</segment>
