  <rst>
    <segment id="1">Três marcas devem sair na frente no processo de retomada dos carros populares.</segment>
    <segment id="2">Renault Kwid</segment>
    <segment id="3">, Fiat Mobi e Citroën C3</segment>
    <segment id="4">, nessa ordem</segment>
    <segment id="5">, são os carros mais em conta vendidos hoje no Brasil.</segment>
    <segment id="6">Em parceria com a Folha</segment>
    <segment id="7">, o Instituto Mauá de Tecnologia fez as medições de desempenho e consumo desses modelos</segment>
    <segment id="8">, tanto com etanol</segment>
    <segment id="9">comocomo com gasolina.</segment>
    <segment id="10">Para aferir o desempenho dos carros</segment>
    <segment id="11">, o IMT (Instituto Mauá de Tecnologia) utiliza o V-Box</segment>
    <segment id="12">, equipamento que usa sinal de GPS.</segment>
    <segment id="13">Os testes de aceleração e retomada são feitos na pista da empresa ZF</segment>
    <segment id="14">, em Limeira (interior de São Paulo).</segment>
    <segment id="15">A etapa que verifica o consumo na cidade tem 27 km.</segment>
    <segment id="16">Para simular um percurso rodoviário a 90 km/h</segment>
    <segment id="17">, os engenheiros dirigem por 31 km.</segment>
    <segment id="18">Ambos os trajetos ficam em São Caetano do Sul (ABC)</segment>
    <segment id="19">, onde está a sede do instituto.</segment>
    <segment id="20">Se o carro for flex</segment>
    <segment id="21">, são feitas duas medições: uma com etanol</segment>
    <segment id="22">, outra com gasolina.</segment>
    <segment id="23">Hatch compacto Renault Kwid passou por mudanças na linha 2023 - DivulgaçãoRenault Kwid é o mais econômico tanto na cidade</segment>
    <segment id="24">comocomo na estrada  O Kwid deve ser o primeiro lançamento entre os novos carros populares.</segment>
    <segment id="25">Seu preço começa em R$ 69 mil na versão Zen</segment>
    <segment id="26">, masmas a Renault tem feito promoções</segment>
    <segment id="27">, quando o valor baixa para aproximadamente R$ 63 mil.</segment>
    <segment id="28">A lista atual de equipamentos de série traz quatro airbags</segment>
    <segment id="29">, direção com assistência elétrica</segment>
    <segment id="30">, ar-condicionado</segment>
    <segment id="31">, controles de estabilidade</segment>
    <segment id="32">, sistema de som com Bluetooth e acionamento elétrico das travas das portas e das janelas dianteiras.</segment>
    <segment id="33">O espaço interno é razoável para quatro adultos.</segment>
    <segment id="34">Os joelhos de quem viaja no banco traseiro ficam bem próximos dos assentos frontais</segment>
    <segment id="35">, masmas há um bom vão livre para a cabeça.</segment>
    <segment id="36">Os pontos fortes do compacto são a agilidade no meio urbano e o consumo de combustível</segment>
    <segment id="37">, com média de 23</segment>
    <segment id="38">,1 km/l na estrada quando abastecido com gasolina.  Renault Kwid Zen  Preço: R$ 69 mil Motor: dianteiro</segment>
    <segment id="39">, transversal</segment>
    <segment id="40">, flex</segment>
    <segment id="41">, três cilindros 999 cm³ Potência: 71 cv (E) e 68 cv (G) a 6.250 rpm Torque: 10 kgfm (E) e 9</segment>
    <segment id="42">,4 kgfm (G) a 4.250 rpm Transmissão: câmbio manual</segment>
    <segment id="43">, cinco marchas</segment>
    <segment id="44">; tração dianteira</segment>
    <segment id="45">Pneus: 165/70 R14</segment>
    <segment id="46">Peso: 818 kg</segment>
    <segment id="47">Porta-malas: 290 litros</segment>
    <segment id="48">Comprimento: 3</segment>
    <segment id="49">,68 m</segment>
    <segment id="50">Largura: 1</segment>
    <segment id="51">,60 m Altura: 1</segment>
    <segment id="52">,48 m Entre-eixos: 2</segment>
    <segment id="53">,42 m</segment>
    <segment id="54">Aceleração (0 a 100 km/h</segment>
    <segment id="55">, em segundos):</segment>
    <segment id="56">15,2 (E)</segment>
    <segment id="57">, 16,9 (G) Retomada (80 km/h a 120 km/h</segment>
    <segment id="58">, em segundos): 17</segment>
    <segment id="59">,3 (E)</segment>
    <segment id="60">, 18,4 (G)</segment>
    <segment id="61">Frenagem: (80 km/h a 0):</segment>
    <segment id="62">41,8 m</segment>
    <segment id="63">Consumo urbano: 12</segment>
    <segment id="64">,6 km/l (E)</segment>
    <segment id="65">, 17,9 km/l (G)</segment>
    <segment id="66">Consumo rodoviário: 16</segment>
    <segment id="67">,6 km/l (E)</segment>
    <segment id="68">, 23,1 (G)  Renault Kwid 2023Mais    novamente         de   de  de  representando um  Mobi oferece mecânica conhecida e manutenção fácil</segment>
    <segment id="69">, masmas é apertado</segment>
    <segment id="70">A versão de entrada do Fiat Mobi custa R$ 69 mil e divide com o Kwid o posto de carro zero-quilômetro mais barato.</segment>
    <segment id="71">Contudo essa opção não estava disponível para o teste.</segment>
    <segment id="72">A opção avaliada foi a Trekking</segment>
    <segment id="73">, vendida a R$ 72</segment>
    <segment id="74">,3 mil.</segment>
    <segment id="75">Sua suspensão é mais alta</segment>
    <segment id="76">, indica para regiões com estradas de terra e asfalto ruim.</segment>
    <segment id="77">Fiat Mobi muda e ganha nova versão aventureiraMais    novamente         de   de  de  representando um</segment>
    <segment id="78">A mecânica é simples e conhecida pelos reparadores.</segment>
    <segment id="79">Seu motor é o 1.0 flex de quatro cilindros</segment>
    <segment id="80">, e os principais itens de série atuais são direção com assistência hidráulica</segment>
    <segment id="81">, ar-condicionado</segment>
    <segment id="82">, sistema de som e acionamento elétrico dos vidros dianteiros e das travas das portas.</segment>
    <segment id="83">É, contudo</segment>
    <segment id="84">contudo</segment>
    <segment id="85">, o mais apertado entre os candidatos a carro popular.</segment>
    <segment id="86">O espaço é menor tanto na cabine</segment>
    <segment id="87">comocomo no porta-malas.</segment>
    <segment id="88">Fiat Mobi Trekking  Preço: R$ 72</segment>
    <segment id="89">,3 mil Motor: dianteiro</segment>
    <segment id="90">, transversal</segment>
    <segment id="91">, flex</segment>
    <segment id="92">, quatro cilindros</segment>
    <segment id="93">, 999 cm³ Potência: 74 cv (E) e 71 cv (G) a 5.500 rpm Torque: 9</segment>
    <segment id="94">,7 kgfm (E) e 9</segment>
    <segment id="95">,3 kgfm (G) a 3.250 rpm Transmissão: câmbio manual</segment>
    <segment id="96">, cinco marchas</segment>
    <segment id="97">; tração dianteira</segment>
    <segment id="98">Pneus: 175/65 R14</segment>
    <segment id="99">Peso: 969 kg</segment>
