  <rst>
    <segment id="1">Priscilla</segment>
    <segment id="2">, o novo filme de Sofia Copolla</segment>
    <segment id="3">, chega à América Latina no dia 26 de dezembro pelo streaming da Mubi.</segment>
    <segment id="4">A informação foi compartilhada nas redes sociais da plataforma nesta segunda-feira</segment>
    <segment id="5">, dia da estreia do filme no festival de Veneza</segment>
    <segment id="6">, e inclui Reino Unido</segment>
    <segment id="7">, Irlanda e Alemanha na mesma data.</segment>
    <segment id="8">A assessoria da plataforma ainda não confirmou</segment>
    <segment id="9">sese Brasil está na lista de países considerados.</segment>
    <segment id="10">Cena do filme &amp;#039</segment>
    <segment id="11">;Priscilla&amp;#039</segment>
    <segment id="12">;, de Sofia Coppola</segment>
    <segment id="13">, distribuído pela Mubi - ReproduçãoA plataforma anunciou neste mês que manteria os direitos de distribuição do longa-metragem de Sofia Copolla para América Latina</segment>
    <segment id="14">, além de Reino Unido</segment>
    <segment id="15">, Irlanda</segment>
    <segment id="16">, Alemanha</segment>
    <segment id="17">, Áustria</segment>
    <segment id="18">, Bélgica</segment>
    <segment id="19">, Holanda</segment>
    <segment id="20">, Luxemburgo e Turquia.</segment>
    <segment id="21">"Priscilla" é um romance baseado no livro "Elvis and Me"</segment>
    <segment id="22">, de Priscilla Presley.</segment>
    <segment id="23">Priscilla</segment>
    <segment id="24">, que foi mulher de Elvis Presley</segment>
    <segment id="25">, é encarnada por Cailee Spaeny enquanto Jacob Elordi</segment>
    <segment id="26">, ator da série "Euphoria"</segment>
    <segment id="27">, interpreta o rei do rock.</segment>
    <segment id="28">O filme estreia agora no Festival de Veneza</segment>
    <segment id="29">, trazendo uma nova visão sobre a relação do astro com a ex-mulher</segment>
    <segment id="30">, que ainda era adolescente quando conheceu o cantor que já desfrutava da fama.</segment>
    <segment id="31">Veja destaques do Festival de Veneza de 2023Mais    novamente         de   de  de  representando</segment>
    <segment id="32">um</segment>
