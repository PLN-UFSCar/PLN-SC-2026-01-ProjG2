  <rst>
    <segment id="1">Hadi Matar</segment>
    <segment id="2">, suspeito do ataque ao escritor Salman Rushdie em um evento no interior do estado americano de Nova York nesta sexta (12) foi formalmente acusado de tentativa de homicídio e está detido</segment>
    <segment id="3">, sem possibilidade de fiança</segment>
    <segment id="4">, pela promotoria do condado de Chautauqua neste sábado (13).</segment>
    <segment id="5">Ainda segundo o órgão</segment>
    <segment id="6">, o crime foi premeditado</segment>
    <segment id="7">, informa o jornal The New York Times.</segment>
    <segment id="8">Matar, um homem de 24 anos morador de Fairview</segment>
    <segment id="9">, no estado de Nova Jersey</segment>
    <segment id="10">, é também acusado de agressão com uso de arma</segment>
    <segment id="11">, disse o promotor distrital local</segment>
    <segment id="12">, Jason Schmidt</segment>
    <segment id="13">, em comunicado.</segment>
    <segment id="14">O escritor anglo-indiano Salman Rushdie</segment>
    <segment id="15">, que foi alvo de um ataque nesta sexta</segment>
    <segment id="16">, 12  - Joel Saget-10.set.2018/AFPO suspeito</segment>
    <segment id="17">, que foi preso no local</segment>
    <segment id="18">, compareceu na tarde deste sábado ao Tribunal do Condado de Chautauqua.</segment>
    <segment id="19">No local</segment>
    <segment id="20">, os promotores disseram que o ataque ao autor foi premeditado e direcionado.</segment>
    <segment id="21">Matar, dizem</segment>
    <segment id="22">, viajou de ônibus para o evento</segment>
    <segment id="23">, na cidade a cerca de sete horas da cidade de Nova York</segment>
    <segment id="24">, e comprou um ingresso para a palestra de Rushdie</segment>
    <segment id="25">, na manhã de sexta.</segment>
    <segment id="26">No tribunal</segment>
    <segment id="27">, ele usava um macacão listrado</segment>
    <segment id="28">, algemas</segment>
    <segment id="29">, algemas e sapatos cor de laranja brilhantes e não falava</segment>
    <segment id="30">, ainda segundo relatou o jornal The New York Times.</segment>
    <segment id="31">O defensor público</segment>
    <segment id="32">Nathaniel Barone diz que seu assistido tem direito à presunção de inocência.</segment>
    <segment id="33">Quem é o escritor Salman RushdieMais    novamente         de   de  de  representando um  ​Rushdie</segment>
    <segment id="34">, escritor anglo-indiano que passou anos escondido depois que o Irã pediu aos muçulmanos que o matassem por causa de seu romance "</segment>
    <segment id="35">Os Versos Satânicos</segment>
    <segment id="36">"</segment>
    <segment id="37">,</segment>
    <segment id="38">foi esfaqueado no pescoço e no torso enquanto ele</segment>
    <segment id="39">sese preparava para uma palestra.</segment>
    <segment id="40">Após horas de cirurgia</segment>
    <segment id="41">, Rushdie estava sob ventilação e incapaz de falar.</segment>
    <segment id="42">A Reuters não conseguiu identificar imediatamente</segment>
    <segment id="43">sese Matar</segment>
    <segment id="44">, que comprou um ingresso para o evento na Chautauqua Institution</segment>
    <segment id="45">, no oeste do estado de Nova York</segment>
    <segment id="46">, tem representação legal.</segment>
    <segment id="47">Uma análise preliminar das redes sociais de Matar por parte das autoridades policiais mostrou que ele era simpático ao extremismo xiita e ao Exército dos Guardiães da Revolução Islâmica</segment>
    <segment id="48">, conhecido popularmente</segment>
    <segment id="49">comocomo Guarda Revolucionária Iraniana</segment>
    <segment id="50">, segundo a NBC de Nova York.</segment>
    <segment id="51">Hadi Matar</segment>
    <segment id="52">, acusado de esfaquear o escritor anglo-indiano Salman Rushdie  - Cadeia do condado de Chautauqua via REUTERS</segment>
    <segment id="53">Matar nasceu na Califórnia e</segment>
    <segment id="54">sese mudou recentemente para Nova Jersey</segment>
    <segment id="55">, disse a reportagem da NBC</segment>
    <segment id="56">, acrescentando que ele tinha consigo uma carteira de motorista falsa.</segment>
    <segment id="57">As polícias de Nova York e Nova Jersey não responderam imediatamente a um pedido de comentário sobre a reportagem da NBC.</segment>
  </rst>
