  <rst>
    <segment id="1">A Air One</segment>
    <segment id="2">, primeira estação aérea do mundo para aeronaves elétricas de decolagem e pouso vertical (eVTOL)</segment>
    <segment id="3">, abriu suas portas em Coventry</segment>
    <segment id="4">, no Reino Unido.</segment>
    <segment id="5">A empresa britânica Urban-Air Port</segment>
    <segment id="6">, responsável pela infraestrutura do local</segment>
    <segment id="7">, afirmou que este é o início de uma nova era de transporte urbano com emissões zero.</segment>
    <segment id="8">Coventry foi selecionada por sua localização geográfica e histórico de inovação automotiva e aeroespacial.</segment>
    <segment id="9">Para a Urban-Air Port</segment>
    <segment id="10">, "representa o local ideal para mostrar o futuro da mobilidade".</segment>
    <segment id="11">A empresa vai operar o aeroporto por pelo menos um mês.</segment>
    <segment id="12">A atividade servirá de modelo para os mais de 200 projetos semelhantes que a Urban-Air planeja inaugurar em todo o mundo nos próximos cinco anos</segment>
    <segment id="13">, para atender à crescente demanda pelo eVTOL.</segment>
    <segment id="14">Concepção gráfica do &amp;#039</segment>
    <segment id="15">;vertiporto&amp;#039</segment>
    <segment id="16">;, primeira estação aérea do mundo para aeronaves de decolagem e pouso vertical - Urban-Air Port / DivulgaçãoO mercado de mobilidade aérea avançada (AAM</segment>
    <segment id="17">, na sigla em inglês) está crescendo e um grande número de aeronaves</segment>
    <segment id="18">eVTOL começará a operar comercialmente durante esta década</segment>
    <segment id="19">, masmas a falta de infraestrutura terrestre adequada para sustentar as operações continua sendo um dos maiores obstáculos ao crescimento do setor</segment>
    <segment id="20">, segundo a Nasa.  "</segment>
    <segment id="21">A Air One é apenas o primeiro modelo em nossa frota de infraestrutura</segment>
    <segment id="22">, e nossa carteira de pedidos não está apenas aberta</segment>
    <segment id="23">, masmas já crescendo"</segment>
    <segment id="24">, disse Ricky Sandhu</segment>
    <segment id="25">, fundador e CEO da Urban-Air Port.</segment>
    <segment id="26">A empresa está atualmente trabalhando no desenvolvimento de aeroportos em Londres</segment>
    <segment id="27">, West Midlands</segment>
    <segment id="28">, Estados Unidos</segment>
    <segment id="29">, Austrália</segment>
    <segment id="30">, Coreia do Sul</segment>
    <segment id="31">, França</segment>
    <segment id="32">, Alemanha</segment>
    <segment id="33">, Escandinávia e no Sudeste Asiático.</segment>
    <segment id="34">A localização do novo aeroporto</segment>
    <segment id="35">, próximo à estação ferroviária de Coventry</segment>
    <segment id="36">, pretende mostrar</segment>
    <segment id="37">comocomo um hub integrado para aeronaves</segment>
    <segment id="38">eVTOL pode operar em um ambiente urbano congestionado.</segment>
    <segment id="39">Para isso</segment>
    <segment id="40">, várias avaliações serão realizadas ao longo do próximo mês.</segment>
    <segment id="41">Os "vertiportos" da Urban-Air</segment>
    <segment id="42">Port são projetados para atender a quatro mercados diferentes: táxi aéreo de passageiros</segment>
    <segment id="43">, drones de entrega autônomos</segment>
    <segment id="44">, gerenciamento de emergências e operações de defesa e logística.</segment>
    <segment id="45">Eles têm a capacidade de ser implantados em curto prazo</segment>
    <segment id="46">para que</segment>
    <segment id="47">para que as aeronaves peguem e transportem suprimentos de emergência</segment>
    <segment id="48">, equipamentos e pessoas.</segment>
    <segment id="49">A empresa gerará receita por meio de um modelo de infraestrutura</segment>
    <segment id="50">comocomo serviço</segment>
    <segment id="51">, permitindo que os clientes decidam sobre o que precisam.</segment>
    <segment id="52">Eles poderão adquirir apenas a infraestrutura ou contratar um serviço abrangente que incluirá o projeto específico do local e suporte de manutenção.</segment>
    <segment id="53">Conheça o eVTOL</segment>
    <segment id="54">, aeronave elétrica chamada de carro voadorMais    novamente         de   de  de  representando</segment>
    <segment id="55">um</segment>
  </rst>
</analysis>