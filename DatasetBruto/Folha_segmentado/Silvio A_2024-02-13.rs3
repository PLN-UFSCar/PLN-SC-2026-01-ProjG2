  <rst>
    <segment id="1">Calmo,</segment>
    <segment id="2">masmas bastante emocionado com a recepção dos componentes da Portela.</segment>
    <segment id="3">Essa foi a descrição que o ministro dos Direitos Humanos e da Cidadania</segment>
    <segment id="4">, Silvio Almeida</segment>
    <segment id="5">, fez à coluna na concentração da escola azul e branco de Madureira</segment>
    <segment id="6">, subúrbio do Rio.</segment>
    <segment id="7">"É o reconhecimento do meu trabalho sério e de compromisso com as pessoas e o Brasil"</segment>
    <segment id="8">, diz.  Ministro Silvio Almeida vive Luiz Gama em desfile da Portela - Ana Cora Lima - 12.fev.2024/Folhapress</segment>
    <segment id="9">O chefe da pasta contou que estava estreando no Carnaval do Rio.</segment>
    <segment id="10">"</segment>
    <segment id="11">Não poderia ficar de fora de um enredo tão potente.</segment>
    <segment id="12">A Portela me convidou e aceitei prontamente"</segment>
    <segment id="13">, disse Almeida</segment>
    <segment id="14">, que veio representando o advogado Luiz Gama</segment>
    <segment id="15">, abolicionista</segment>
    <segment id="16">, orador</segment>
    <segment id="17">, jornalista</segment>
    <segment id="18">, escritor e patrono da abolição da escravidão do Brasil.</segment>
    <segment id="19">O ministro ainda disse que leu várias vezes o livro em que a Portela baseou seu enredo: "</segment>
    <segment id="20">Um Defeito de Cor"</segment>
    <segment id="21">, da escritora Ana Maria Gonçalves.</segment>
    <segment id="22">"É uma obra clássica e importante da nossa cultura.</segment>
    <segment id="23">"  Famosos e personalidades no segundo dia de desfiles na SapucaíMais    novamente         de   de  de  representando</segment>
    <segment id="24">um</segment>
  </rst>
