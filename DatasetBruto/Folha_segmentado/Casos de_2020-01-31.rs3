  <rst>
    <segment id="1">O estado de SP pode enfrentar uma epidemia retardada de dengue.</segment>
    <segment id="2">Os casos da doença</segment>
    <segment id="3">, que estavam caindo em janeiro</segment>
    <segment id="4">, em relação ao mesmo período do ano passado</segment>
    <segment id="5">, começaram a subir.</segment>
    <segment id="6">Já são 24.888 registros</segment>
    <segment id="7">, com um óbito.</segment>
    <segment id="8">META</segment>
    <segment id="9">A Secretaria de Saúde</segment>
    <segment id="10">sese reunirá com gestores de municípios para discutir o que fazer em</segment>
    <segment id="11">casocaso de um novo pico da doença.</segment>
    <segment id="12">“</segment>
    <segment id="13">O sinal amarelo está ligado”</segment>
    <segment id="14">, diz o infectologista Marcos Boulos</segment>
    <segment id="15">, superintendente do Controle de Endemias do estado.</segment>
    <segment id="16">MUITA CALMA</segment>
    <segment id="17">Já o coronavírus</segment>
    <segment id="18">, que mobiliza os governos federal e estadual</segment>
    <segment id="19">, não deve trazer pânico</segment>
    <segment id="20">, diz Boulos.</segment>
    <segment id="21">“</segment>
    <segment id="22">Pelo que</segment>
    <segment id="23">sese conhece até agora</segment>
    <segment id="24">, o potencial de transmissão e de gravidade dele é baixo.</segment>
    <segment id="25">”  DE LONGE</segment>
    <segment id="26">O coronavírus</segment>
    <segment id="27">, segundo Boulos</segment>
    <segment id="28">, “é um grande problema na China”</segment>
    <segment id="29">, masmas ainda não em outros lugares</segment>
    <segment id="30">, onde casos são identificados apenas em pessoas que estiveram no país asiático.  DE LADO   Ele diz que as autoridades têm que</segment>
    <segment id="31">sese preocupar e que a população tem que ser informada —</segment>
    <segment id="32">masmas sem pavor.</segment>
    <segment id="33">Na China</segment>
    <segment id="34">, 170 pessoas já morreram por causa do coronavírus.</segment>
    <segment id="35">“</segment>
    <segment id="36">O H1N1 mata de 200 a 300 pessoas por ano no Brasil”</segment>
    <segment id="37">, compara.</segment>
    <segment id="38">Leia todos os temas abordados pela coluna nesta sexta (31):  ​Doria e Covas devem anunciar medidas contra possível chegada de coronavírus</segment>
    <segment id="39">Coronavírus faz funcionários da Petrobras e da Vale na China voltarem ao Brasil</segment>
    <segment id="40">Dedé Santana diz que é absurdo pensar que ele apoia o fim da meia-entrada</segment>
    <segment id="41">Gabriela Duarte está apreensiva com mãe no governo</segment>
    <segment id="42">Bolsonaro  Marta Suplicy janta com o senador Randolfe Rodrigues no domingo</segment>
    <segment id="43">Spcine apoia quatro longas no Festival de Berlim  Mais de 80 mil produtos piratas são confiscados em Congresso de Odontologia em SP   NOITE ILUSTRADA    Premiações da Cultura de SP   novamente         de   de  de  representando um</segment>
    <segment id="44">Os atores Juca de Oliveira e Christiane Torloni compareceram ao evento Premiações da Cultura de SP</segment>
    <segment id="45">, realizado na quarta (29)</segment>
    <segment id="46">, no Palácio dos Bandeirantes.</segment>
    <segment id="47">O escritor Ignácio de Loyola Brandão</segment>
    <segment id="48">, o maestro João Carlos Martins</segment>
    <segment id="49">, o secretário de Cultura de SP</segment>
    <segment id="50">, Sérgio Sá Leitão</segment>
    <segment id="51">, e o músico e escritor Zuza Homem de Mello |marcaram presença.</segment>
    <segment id="52">REUNIÃO</segment>
    <segment id="53">Jantar oferecido por Walfrido Warde   novamente         de   de  de  representando um</segment>
    <segment id="54">A diretora do Instituto Marielle Franco</segment>
    <segment id="55">, Anielle Franco</segment>
    <segment id="56">, e a escritora Helena Trevisan foram ao jantar oferecido pelo advogado Walfrido Warde para os organizadores e participantes do seminário</segment>
    <segment id="57">O Futuro da Segurança Pública no Brasil.</segment>
    <segment id="58">O professor Antoninho Trevisan</segment>
    <segment id="59">, o advogado Pierpaolo Bottini</segment>
    <segment id="60">, o historiador Marcos Rezende e o advogado Adilson Moreira estiveram no evento</segment>
    <segment id="61">, em SP.      CURTO-CIRCUITO</segment>
    <segment id="62">O escritório DTSC Advogados debate Lei do Abuso de Autoridade e Pacote Anticrime.</segment>
    <segment id="63">No dia 13 de fevereiro</segment>
    <segment id="64">, a partir das 8h30.</segment>
    <segment id="65">A Orquestra Petrobras Sinfônica apresenta hoje o concerto infantil “Bebeethoven”.</segment>
    <segment id="66">No CCBB</segment>
    <segment id="67">, às 14h30.  com BRUNO B. SORAGGI e VICTORIA AZEVEDO</segment>
    <segment id="68">; colaborou BIANKA VIEIRA</segment>
