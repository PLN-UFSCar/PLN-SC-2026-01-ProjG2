  <rst>
    <segment id="1">Presente no velório de Rita Lee</segment>
    <segment id="2">, nesta quarta-feira</segment>
    <segment id="3">, dia 10</segment>
    <segment id="4">, o apresentador Serginho Groisman afirmou ter adiantado a exibição de um programa em homenagem à cantora e compositora</segment>
    <segment id="5">, para que</segment>
    <segment id="6">para que ela fosse homenageada ainda em vida.</segment>
    <segment id="7">Serginho Groisman - 30.abr.2022/GloboO tributo ao legado de Rita foi ao ar em 15 de abril</segment>
    <segment id="8">, com participações de Tom Zé</segment>
    <segment id="9">, Luisa Sonza</segment>
    <segment id="10">, Paula Toller</segment>
    <segment id="11">, Manu Gavassi e Paulo Ricardo.</segment>
    <segment id="12">Na ocasião</segment>
    <segment id="13">, Groisman inaugurou um palco com o nome da artista.</segment>
    <segment id="14">Fãs fazem fila na chuva no velório de Rita LeeMais    novamente         de   de  de  representando um  "</segment>
    <segment id="15">É isso o que a gente tem feito</segment>
    <segment id="16">, homenagens em vida.</segment>
    <segment id="17">Essa homenagem a ela seria um pouco mais para frente</segment>
    <segment id="18">, masmas intuitivamente falei para a gente fazer agora" disse ele</segment>
    <segment id="19">, no velório da cantora.</segment>
    <segment id="20">"</segment>
    <segment id="21">Depois que gente deu a homenagem</segment>
    <segment id="22">, fiquei sabendo do que realmente tava acontecendo"</segment>
    <segment id="23">, afirmou o apresentador</segment>
    <segment id="24">, referindo -</segment>
    <segment id="25">sese ao estado de saúde de Rita.</segment>
    <segment id="26">"</segment>
    <segment id="27">Ainda bem que ela teve esse momento na televisão.</segment>
    <segment id="28">Mas foi muito triste saber que ela tinha falecido.</segment>
    <segment id="29">"</segment>
