    <segment id="74">sese o julgador é isento e não está contaminado por interesses pessoais.</segment>
    <segment id="75">Mateus Vaz de Sá (Goiânia</segment>
    <segment id="76">, GO)</segment>
    <segment id="77">Capa Amei essa capa da Tomie Ohtake (Ilustrada.</segment>
    <segment id="78">17/2), velhinha adorável e que ousadia!</segment>
