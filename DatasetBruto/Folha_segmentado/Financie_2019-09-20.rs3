  <rst>
    <segment id="1">O presidente do Senado</segment>
    <segment id="2">, Davi Alcolumbre (DEM-AP)</segment>
    <segment id="3">, está certo.</segment>
    <segment id="4">É uma insensatez manter em R$ 1</segment>
    <segment id="5">,7 bilhão o fundo eleitoral.</segment>
    <segment id="6">Talvez devesse dobrar.</segment>
    <segment id="7">Alguém escandalizado?</segment>
    <segment id="8">Deve estar entre aqueles que acreditam que as eleições do ano passado realmente custaram algo em torno de R$ 3 bilhões —considerados também o fundo partidário e as doações de pessoas físicas.</segment>
    <segment id="9">O presidente do Senado Federal</segment>
    <segment id="10">, Davi Alcolumbre (DEM-AP) - Pedro Ladeira-28.mai.19/FolhapressCom essa bagatela</segment>
    <segment id="11">, consta</segment>
    <segment id="12">, elegeram-</segment>
    <segment id="13">sese um presidente da República</segment>
    <segment id="14">, 513 deputados</segment>
    <segment id="15">, 54 senadores</segment>
    <segment id="16">, 1.059 deputados estaduais ou distritais e 27 governadores.</segment>
    <segment id="17">Candidataram-</segment>
    <segment id="18">sese 28.216 pessoas.</segment>
    <segment id="19">É história da Carochinha.</segment>
    <segment id="20">A estúpida proibição da doação de empresas jogou o financiamento de campanha numa clandestinidade inédita.</segment>
    <segment id="21">Nenhuma imoralidade é tão destrutiva</segment>
    <segment id="22">comocomo a do moralismo</segment>
    <segment id="23">, que é a moral na sua expressão doentia</segment>
    <segment id="24">, fanática</segment>
    <segment id="25">, missionária.</segment>
    <segment id="26">Alcolumbre lembra que</segment>
    <segment id="27">, no ano que vem</segment>
    <segment id="28">, serão eleitos 5.570 prefeitos e 57 mil vereadores.</segment>
    <segment id="29">Disputaram o pleito de 2016 nada menos de 481.783 pessoas.</segment>
    <segment id="30">Esse número deve crescer.</segment>
    <segment id="31">Se essas pessoas não tiverem o apoio necessário</segment>
    <segment id="32">, diz ele</segment>
    <segment id="33">, “acaba-</segment>
    <segment id="34">sese criando um caminho para não agirem em suas campanhas dentro da legislação”.</segment>
    <segment id="35">A exemplo de 2018.</segment>
    <segment id="36">Alcolumbre</segment>
    <segment id="37">, claro!</segment>
    <segment id="38">, vai apanhar.</segment>
    <segment id="39">A demagogia de esquerda dirá que ele quer grana para seus brioches quando falta pão.</segment>
    <segment id="40">E a de direita vai berrar:</segment>
    <segment id="41">“Não quero financiar ladrões”.</segment>
    <segment id="42">O ódio à política permanecerá por muito tempo</segment>
    <segment id="43">comocomo a característica nacional do Brasil.</segment>
    <segment id="44">Parafraseio o abolicionista Joaquim Nabuco.</segment>
    <segment id="45">Ele escreveu “escravidão” em lugar de “ódio à política”.</segment>
    <segment id="46">Somos cativos em qualquer</segment>
    <segment id="47">casocaso.</segment>
    <segment id="48">Peço licença para divergir</segment>
    <segment id="49">, em parte ou por inteiro</segment>
    <segment id="50">, de alguns pares de colunismo ao ver as reações à proposta de aumentar o fundo e às mudanças que o Congresso fez na lei eleitoral.</segment>
    <segment id="51">Não vou entrar em minudências —este jornal tratou do assunto no detalhe—</segment>
    <segment id="52">porque</segment>
    <segment id="53">porque me interessa mesmo é a visão de mundo que embala as críticas.</segment>
    <segment id="54">A velha esquerda vê os políticos</segment>
    <segment id="55">comocomo uma classe social.</segment>
    <segment id="56">Representariam os interesses da burguesia espoliativa com o intuito de impedir a ascensão dos oprimidos —os verdadeiros criadores da riqueza.</segment>
    <segment id="57">Ainda que subsista nesses setores</segment>
    <segment id="58">, como</segment>
    <segment id="59">como crença e abstração</segment>
    <segment id="60">, a ideia da luta de classes</segment>
    <segment id="61">, eles tomaram a decisão prudente</segment>
    <segment id="62">, mundo afora</segment>
    <segment id="63">, de fazer a disputa segundo “as regras da democracia deles” para</segment>
    <segment id="64">, então</segment>
    <segment id="65">, formar uma nova maioria em favor “da democracia nossa”.</segment>
    <segment id="66">Neste ponto</segment>
    <segment id="67">, leitor</segment>
    <segment id="68">, poderia nascer um novo artigo para evidenciar que o desastre a que o petismo conduziu a própria história</segment>
    <segment id="69">, do qual tenta</segment>
    <segment id="70">sese levantar</segment>
    <segment id="71">, nasce desse erro essencial.</segment>
    <segment id="72">Existe apenas uma democracia.</segment>
    <segment id="73">É a de todos.</segment>
    <segment id="74">Será sempre uma luta entre desiguais por mais igualdade de bens e de direitos.</segment>
    <segment id="75">É a marcha civilizatória.</segment>
    <segment id="76">Já a direita</segment>
    <segment id="77">, velha ou nova —muito especialmente essa turma da Lava Jato</segment>
    <segment id="78">, que promove o terror jurídico</segment>
    <segment id="79">, com a complacência de setores da imprensa—</segment>
    <segment id="80">, vê os políticos</segment>
    <segment id="81">comocomo uma casta.</segment>
    <segment id="82">Veja as regras de financiamento eleitoral pelo mundo   novamente         de   de  de  representando um  São tratados</segment>
    <segment id="83">comocomo aristocratas renitentes de uma República que deveria escorraçá-los</segment>
    <segment id="84">, dispensando-lhes o tratamento de aproveitadores —sobreviventes de um velho regime</segment>
    <segment id="85">, derrubado pela ágora das redes sociais.  Surgiu</segment>
    <segment id="86">, assim</segment>
    <segment id="87">, uma tal “nova política”</segment>
    <segment id="88">, que se</segment>
    <segment id="89">se compraz em promover o ódio à própria política.</segment>
    <segment id="90">Sua precondição de existência é a crise permanente.</segment>
    <segment id="91">Prefiro a velha democracia e a velha institucionalidade.</segment>
    <segment id="92">E fujo da demagogia e da hipocrisia</segment>
    <segment id="93">comocomo a Lava Jato foge da Constituição e do Estado de Direito.</segment>
    <segment id="94">Políticos não são nem classe nem casta.</segment>
    <segment id="95">São apenas o menor dos males possíveis.</segment>
    <segment id="96">O sistema precisa de dinheiro para funcionar.</segment>
    <segment id="97">Se não for privado</segment>
    <segment id="98">, será público.</segment>
    <segment id="99">Se não for o legal</segment>
    <segment id="100">, será o ilegal.</segment>
    <segment id="101">O custo desse moralismo</segment>
    <segment id="102">, potencializado pela gritaria da ágora virtual</segment>
    <segment id="103">, é a instabilidade permanente</segment>
    <segment id="104">, que só interessa a fascistoides de vários matizes.</segment>
    <segment id="105">Ou alguém alimenta dúvida razoável sobre a distopia que nasceu nesse esterco?</segment>
    <segment id="106">Sempre que</segment>
    <segment id="107">sese aproximam de mim de mim para</segment>
    <segment id="108">, por exemplo</segment>
    <segment id="109">, elogiar a Lava Jato e atacar o governo Bolsonaro</segment>
    <segment id="110">, eu me afasto.</segment>
    <segment id="111">“É melhor morrer de vodca do que de tédio”.</segment>
    <segment id="112">O moralismo</segment>
    <segment id="113">, que é a moral em estado mórbido</segment>
    <segment id="114">, entorpece a razão.</segment>
    <segment id="115">Ele agradece.</segment>
  </rst>
</analysis>