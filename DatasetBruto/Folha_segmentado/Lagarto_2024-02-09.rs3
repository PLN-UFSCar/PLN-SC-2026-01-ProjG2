  <rst>
    <segment id="1">Um grupo de cientistas descobriu em uma reserva natural do Peru uma nova espécie de lagarto que batizaram de Bruce Dickinson</segment>
    <segment id="2">, em homenagem ao vocalista da banda britânica de heavy metal Iron Maiden</segment>
    <segment id="3">, informou o Serviço Nacional de Áreas Naturais Protegidas pelo Estado nesta sexta-feira (9).</segment>
    <segment id="4">O exemplar Enyalioides dickinsoni</segment>
    <segment id="5">, nome científico do réptil</segment>
    <segment id="6">, foi descoberto junto com outra nova espécie</segment>
    <segment id="7">, a Enyalioides cyanocephalus</segment>
    <segment id="8">, nas florestas úmidas da Cordilheira de Colán</segment>
    <segment id="9">, disse a instituição.</segment>
    <segment id="10">O Enyalioides dickinsoni</segment>
    <segment id="11">, nome científico de uma nova espécie de lagarto descoberta recentemente em uma reserva na selva peruana e nomeada em homenagem a Bruce Dickinson</segment>
    <segment id="12">, vocalista da lendária banda britânica de heavy metal Iron Maiden - Sernanp/AFP"Chamado</segment>
    <segment id="13">comocomo lagarto de Dickinson</segment>
    <segment id="14">; recebe seu nome específico em homenagem a Paul Bruce Dickinson</segment>
    <segment id="15">, vocalista principal da lendária banda de heavy metal Iron Maiden"</segment>
    <segment id="16">, destacou o Sernanp</segment>
    <segment id="17">, sem detalhar</segment>
    <segment id="18">sese há fãs do grupo entre os cientistas responsáveis pela descoberta.</segment>
    <segment id="19">Dickinson</segment>
    <segment id="20">, de 65 anos</segment>
    <segment id="21">, é o vocalista do Iron Maiden</segment>
    <segment id="22">, a banda fundada em 1975 em Londres.</segment>
    <segment id="23">Considerado um dos conjuntos mais importantes e representativos do gênero</segment>
    <segment id="24">, o grupo conta com legiões de fãs em todo o mundo</segment>
    <segment id="25">, em particular na América Latina</segment>
    <segment id="26">, onde costumam encher estádios em suas turnês.</segment>
    <segment id="27">Leia maisCabras parecem conseguir distinguir emoção na voz humanaCientistas colocaram animais para ouvir expressão de &amp;#</segment>
    <segment id="28">039;felicidade&amp;#039</segment>
    <segment id="29">; e &amp;#039</segment>
    <segment id="30">;raiva&amp;#039</segment>
    <segment id="31">;Tamanho do focinho e porte influenciam na longevidade dos cãesRaças de pequeno porte e com focinho longo</segment>
    <segment id="32">, por exemplo</segment>
    <segment id="33">, tendem a viver maisPerda de mamíferos</segment>
    <segment id="34">comocomo antas e veados prejudica interações entre plantas e &amp;#</segment>
    <segment id="35">039;pragas&amp;#039</segment>
    <segment id="36">;Pesquisadores compararam danos nas folhas causados por insetos e patógenos em áreas com e sem a presença de animaisA nova espécie de lagarto</segment>
    <segment id="37">sese destaca por sua cabeça laranja</segment>
    <segment id="38">, corpo verde e pernas curtas.</segment>
    <segment id="39">As novas espécies foram descobertas recentemente</segment>
    <segment id="40">comocomo parte de uma pesquisa desenvolvida por especialistas da Rainforest Partnership</segment>
    <segment id="41">, dos Estados Unidos</segment>
    <segment id="42">, do Instituto Peruano de Herpetologia e do Museu de Zoologia da Escola de Ciências Biológicas da Pontifícia Universidade Católica do Equador.</segment>
    <segment id="43">O santuário nacional Cordilheira de Colán tem 39.215 hectares de extensão e acolhe cerca de 470 espécies de aves e 70 de mamíferos.</segment>
    <segment id="44">Lagarto de Dickinson homenageia vocalista do Iron MaidenMais    novamente         de   de  de  representando um</segment>
  </rst>
