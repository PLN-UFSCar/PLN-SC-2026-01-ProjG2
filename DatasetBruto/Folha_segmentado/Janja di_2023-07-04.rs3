  <rst>
    <segment id="1">A primeira-dama Rosângela da Silva</segment>
    <segment id="2">, a Janja</segment>
    <segment id="3">, disse que</segment>
    <segment id="4">sese emocionou com uma campanha publicitária da Volkswagen que mostrou</segment>
    <segment id="5">, com uso de inteligência artificial</segment>
    <segment id="6">, um dueto entre Elis Regina e Maria Rita.</segment>
    <segment id="7">As cantoras Maria Rita e Elis Regina no filme publicitário - Divulgação/Volkswagen</segment>
    <segment id="8">O vídeo foi lançado na noite de segunda-feira (3) na convenção que comemorou os 70 anos da empresa no Brasil.</segment>
    <segment id="9">"</segment>
    <segment id="10">Sete e pouco da manhã aqui na Argentina</segment>
    <segment id="11">e eu me acabando de chorar"</segment>
    <segment id="12">,</segment>
    <segment id="13">escreveu Janja nas redes sociais em um post com a peça da campanha.</segment>
    <segment id="14">Ela acompanha o presidente Lula (PT) em uma viagem ao país.</segment>
    <segment id="15">A publicação da primeira-dama soma mais de 700 mil visualizações e foi curtido por mais de 21 mil internautas.</segment>
    <segment id="16">A campanha viralizou na internet.</segment>
    <segment id="17">O nome de Elis ficou entre os assuntos mais comentados no Twitter.</segment>
    <segment id="18">Artistas</segment>
    <segment id="19">comocomo a cantora Sandy</segment>
    <segment id="20">, o ator Silvero Pereira e o cantor Rogério Flausino também comentaram a peça publicitária.</segment>
    <segment id="21">No vídeo</segment>
    <segment id="22">, mãe e filha cantam "</segment>
    <segment id="23">Como Nossos Pais"</segment>
    <segment id="24">, de Belchior</segment>
    <segment id="25">, enquanto dirigem em uma estrada lado a lado.</segment>
    <segment id="26">Elis aparece na direção de uma Kombi clássica</segment>
    <segment id="27">, enquanto Maria Rita pilota a recém-lançada ID.Buzz</segment>
    <segment id="28">, uma versão elétrica do modelo.</segment>
    <segment id="29">Segundo a montadora</segment>
    <segment id="30">, a campanha fez uso da tecnologia deepfake para retratar Elis</segment>
    <segment id="31">, que morreu em janeiro de 1982</segment>
    <segment id="32">, aos 36 anos.</segment>
    <segment id="33">Maria Rita tinha apenas quatro anos e costuma dizer que tem poucas lembranças maternas.</segment>
    <segment id="34">Esta é JanjaMais    novamente         de   de  de  representando um</segment>
    <segment id="35">Em junho</segment>
    <segment id="36">, a Volkswagen anunciou que iria parar temporariamente a produção nas fábricas de São José dos Pinhais (PR)</segment>
    <segment id="37">, São Bernardo do Campo e Taubaté (SP) por conta da estagnação do mercado automotivo.</segment>
    <segment id="38">A fábrica da região metropolitana de Curitiba</segment>
    <segment id="39">, onde é produzido o T-Cross</segment>
    <segment id="40">, está com um turno em layoff desde o dia 5 de junho</segment>
    <segment id="41">, com duração prevista entre dois e cinco meses.</segment>
    <segment id="42">Na fábrica Anchieta</segment>
    <segment id="43">, em São Bernardo do Campo</segment>
    <segment id="44">, onde são produzidos o Novo Virtus</segment>
    <segment id="45">, Novo Polo</segment>
    <segment id="46">, Nivus e Saveiro</segment>
    <segment id="47">, a empresa protocolou férias coletivas de dez dias para os dois turnos a partir de 10 de julho.</segment>
    <segment id="48">A montadora afirmou que as ferramentas de flexibilização estão previstas em acordo coletivo firmado entre o sindicato e seus funcionários.</segment>
    <segment id="49">Maria Rita faz 20 anos de carreira</segment>
    <segment id="50">;</segment>
    <segment id="51">leia trechos de entrevistaMais    novamente         de   de  de  representando um  com BIANKA VIEIRA</segment>
    <segment id="52">, KARINA MATIAS e MANOELLA SMITH</segment>
  </rst>
