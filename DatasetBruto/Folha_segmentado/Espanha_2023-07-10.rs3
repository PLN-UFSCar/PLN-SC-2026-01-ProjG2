  <rst>
    <segment id="1">A antecipação das eleições do final do ano para o dia 23 de julho</segment>
    <segment id="2">, convocadas pelo premiê Pedro Sánchez na Espanha após seu partido</segment>
    <segment id="3">, o PSOE</segment>
    <segment id="4">, ser derrotado em grande parte das regiões do país em maio</segment>
    <segment id="5">, vem causando inúmeros desdobramentos.</segment>
    <segment id="6">Um deles é que a Espanha nunca em sua história recente teve um pleito durante o verão.</segment>
    <segment id="7">Mas, para além do fator curioso</segment>
    <segment id="8">, um efeito não previsto do movimento de Sánchez é a ascensão da figura de Alberto</segment>
    <segment id="9">Núñez Feijóo</segment>
    <segment id="10">, presidente do Partido Popular (PP)</segment>
    <segment id="11">, de direita</segment>
    <segment id="12">, como</segment>
    <segment id="13">como um dos nomes mais viáveis para primeiro-ministro do país europeu.</segment>
    <segment id="14">O líder do Partido Popular</segment>
    <segment id="15">, Alberto Feijóo</segment>
    <segment id="16">, ao lado de apoiadores em Barcelona- Josep Lago - 6.jul.23/AFPPelas pesquisas</segment>
    <segment id="17">, Feijóo tem grandes chances de ser o destino da Espanha nos próximos anos.</segment>
    <segment id="18">Pelo sistema parlamentarista</segment>
    <segment id="19">, espanhóis não votam em candidatos</segment>
    <segment id="20">, masmas em partidos que</segment>
    <segment id="21">, por sua vez</segment>
    <segment id="22">, indicam os deputados.</segment>
    <segment id="23">A sigla ou a coalizão que conquistar a maioria de 176 cadeiras do Parlamento estará apta a indicar o nome do premiê.</segment>
    <segment id="24">Segundo levantamento diário realizado pelo instituto Sigma para o jornal El Mundo</segment>
    <segment id="25">, o PP está na faixa dos 34% desde o início de junho</segment>
    <segment id="26">, enquanto o PSOE ronda os 28%.</segment>
    <segment id="27">Para "salvar a Espanha do sanchismo"</segment>
    <segment id="28">, conforme Feijóo tem declarado em sua campanha</segment>
    <segment id="29">, ele atua em três eixos básicos de promessas</segment>
    <segment id="30">, diz Juan Fernández-Miranda</segment>
    <segment id="31">, diretor-adjunto do jornal conservador ABC.</segment>
    <segment id="32">Lá foraReceba no seu email uma seleção semanal com o que de mais importante aconteceu no mundo</segment>
    <segment id="33">; aberta para não assinantes.</segment>
    <segment id="34">Carregando...</segment>
    <segment id="35">"Em primeiro lugar</segment>
    <segment id="36">, há a pauta propositiva</segment>
    <segment id="37">, na qual ele visualiza uma grande reforma fiscal.</segment>
    <segment id="38">Para isso</segment>
    <segment id="39">, no entanto</segment>
    <segment id="40">, ele está dizendo que vai baixar os impostos</segment>
    <segment id="41">, o que é claramente uma promessa eleitoreira.</segment>
    <segment id="42">"  Feijóo também busca diminuir o déficit de 4</segment>
    <segment id="43">,8% do PIB em 2022 e uma dívida pública superior a € 1</segment>
    <segment id="44">,5 trilhão (R$ 8 trilhões)</segment>
    <segment id="45">, número que equivale a 113% do PIB espanhol do ano passado.</segment>
    <segment id="46">"</segment>
    <segment id="47">Vamos gerir o orçamento melhor que os socialistas" é outro de seus motes.</segment>
    <segment id="48">O político também indicou que deverá diminuir o número de ministérios</segment>
    <segment id="49">, masmas não detalhou ainda cortes substanciais em nenhuma área.  "</segment>
    <segment id="50">Em segundo lugar</segment>
    <segment id="51">, ele propõe revogar algumas das mudanças realizadas por Sánchez.</segment>
    <segment id="52">Por exemplo</segment>
    <segment id="53">, a promessa de voltar a tipificar</segment>
    <segment id="54">comocomo crime no Código Penal os referendos ilegais —</segment>
    <segment id="55">comocomo os feitos por movimentos independentistas em seus territórios"</segment>
    <segment id="56">, segue Miranda.  China</segment>
    <segment id="57">, terra do meioReceba no seu email os grandes temas da China explicados e contextualizados</segment>
    <segment id="58">; exclusiva para assinantes.</segment>
    <segment id="59">Carregando...</segment>
    <segment id="60">Outra frente é reformar atos de Sánchez</segment>
    <segment id="61">comocomo a regulamentação da eutanásia.</segment>
    <segment id="62">Feijóo ironizou a lei que permite o suicídio assistido de pessoas em situação terminal.</segment>
    <segment id="63">Chegou a dizer que "havia tentado</segment>
    <segment id="64">sese suicidar 12 vezes nos últimos meses por culpa da lei"</segment>
    <segment id="65">, pois</segment>
    <segment id="66">pois não a havia entendido e havia pensado que a eutanásia agora era obrigatória.</segment>
    <segment id="67">A pedra no sapato de Feijóo é que os 34% que o PP alcança nas pesquisas não lhe garantem a maioria absoluta das cadeiras do Parlamento —a porcentagem lhe daria 119 deputados</segment>
    <segment id="68">, longe dos 176 necessários.</segment>
    <segment id="69">Mesmo se</segment>
    <segment id="70">se o partido fizer coalizão com o Vox</segment>
    <segment id="71">, de ultradireita —o que Feijóo não gostaria—</segment>
    <segment id="72">, o número de cadeiras aumentaria para 164 ou 165.</segment>
    <segment id="73">O Vox tem aparecido com 13% nas pesquisas.</segment>
    <segment id="74">Regionalmente</segment>
    <segment id="75">, porém</segment>
    <segment id="76">porém, o PP</segment>
    <segment id="77">sese uniu ao Vox para governar em dez grandes cidades espanholas.</segment>
    <segment id="78">"</segment>
    <segment id="79">Alberto Feijóo não gosta do Vox</segment>
    <segment id="80">, masmas ele gosta mais do poder do que não gosta do Vox"</segment>
    <segment id="81">, resume Carlos Cué</segment>
    <segment id="82">, analista político que participou</segment>
    <segment id="83">, ao lado de Miranda</segment>
    <segment id="84">, de um debate sobre a eleições do próximo dia 23 organizado pelo Círculo de Correspondentes de Madri na manhã da última sexta-feira (7).</segment>
    <segment id="85">Para Cué</segment>
    <segment id="86">, "o PP vive em um estado idílico</segment>
    <segment id="87">, no qual acredita que poderá prescindir do Vox e governar com 150 deputados.</segment>
    <segment id="88">O sonho de Feijóo seria chegar a essas 150 cadeiras e impedir o Vox de chegar ao governo.</segment>
    <segment id="89">Mas nos últimos quatro anos</segment>
    <segment id="90">, Sánchez</segment>
    <segment id="91">, coligado com o Podemos</segment>
    <segment id="92">, governou com 155 cadeiras</segment>
    <segment id="93">, e foi muito difícil e frágil.</segment>
    <segment id="94">Governar com menos de 140 deputados será inviável.</segment>
    <segment id="95">"</segment>
    <segment id="96">O premiê Pedro Sánchez</segment>
    <segment id="97">, do PSOE</segment>
    <segment id="98">, em evento de campanha nesta sexta (7)  - Javier Soriano/AFPOs especialistas também apontam para a grande novidade de as eleições ocorreram em plenas férias de verão.</segment>
    <segment id="99">Feijóo insiste em reclamar da data das eleições antecipadas e já acusou Sánchez de marcar essa data por acreditar que "os ricos estariam de férias</segment>
    <segment id="100">, fora de suas cidades</segment>
    <segment id="101">, e, assim</segment>
    <segment id="102">, sem possibilidade de votar".  "</segment>
    <segment id="103">A Espanha é um país rico e todos os extratos da população saem de férias em julho e agosto"</segment>
    <segment id="104">, diz Cué sobre a alegação do direitista.</segment>
    <segment id="105">Com voto não obrigatório</segment>
    <segment id="106">, a abstenção é um ponto de preocupação.</segment>
    <segment id="107">Em 2019</segment>
    <segment id="108">, quando Sánchez</segment>
    <segment id="109">sese elegeu</segment>
    <segment id="110">, 28,5% dos eleitores não compareceram às urnas.</segment>
    <segment id="111">Em 2016</segment>
    <segment id="112">, esse número foi de 33</segment>
    <segment id="113">,5%.</segment>
    <segment id="114">Hoje estão cadastrados 35</segment>
    <segment id="115">,5 milhões de eleitores.</segment>
  </rst>
</analysis>