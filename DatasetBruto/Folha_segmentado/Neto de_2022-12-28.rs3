  <rst>
    <segment id="1">Morreu na tarde desta terça-feira o cantor jamaicano Jo Mersa Marley</segment>
    <segment id="2">, neto da lenda do reggae Bob Marley</segment>
    <segment id="3">, aos 31 anos.</segment>
    <segment id="4">As informações foram confirmadas pela revista Rolling Stone com representantes do artista</segment>
    <segment id="5">, que não divulgaram a causa da morte.</segment>
    <segment id="6">O artista sofria de asma e</segment>
    <segment id="7">, de acordo com a estação de rádio WZPP</segment>
    <segment id="8">, do estado americano da Flórida</segment>
    <segment id="9">, ele foi encontrado inconsciente em um carro.</segment>
    <segment id="10">O cantor Jo Mersa Marley - Divulgação</segment>
    <segment id="11">Seguindo os passos do avô</segment>
    <segment id="12">, Mersa iniciou a carreira fonográfica em 2010</segment>
    <segment id="13">, com a edição do single "</segment>
    <segment id="14">My Girl".</segment>
    <segment id="15">Em 2014</segment>
    <segment id="16">, lançou seu primeiro EP</segment>
    <segment id="17">, "Confortable"</segment>
    <segment id="18">, seguido</segment>
    <segment id="19">, em 2021</segment>
    <segment id="20">, por seu primeiro álbum</segment>
    <segment id="21">, "Eternal".</segment>
    <segment id="22">Veja imagens de Bob MarleyMais    novamente         de   de  de  representando um</segment>
    <segment id="23">Em 2018</segment>
    <segment id="24">, o músico compôs e gravou uma canção em parceria com Bárbara Fialho</segment>
    <segment id="25">, modelo brasileira da Victoria’s Secret.</segment>
    <segment id="26">A canção "</segment>
    <segment id="27">Um Beijo" foi apresentada</segment>
    <segment id="28">comocomo uma mistura de bossa nova</segment>
    <segment id="29">, reggae e samba.</segment>
