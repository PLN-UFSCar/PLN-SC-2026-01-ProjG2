    <segment id="206">, preço não disponível (PC</segment>
    <segment id="207">, PS 4/5</segment>
    <segment id="208">, Xbox One/X/S)  Promoção da semana</segment>
    <segment id="209">A Humble está organizando uma promoção de games para arrecadar doações para ONGs que atuam no auxílio às vítimas dos terremotos na Turquia e na Síria.</segment>
    <segment id="210">Por valores a partir de US$ 30 (R$ 156) é possível comprar um pacote com 69 games</segment>
    <segment id="211">, como</segment>
    <segment id="212">como "Gotham Knights"</segment>
    <segment id="213">, "Ghostrunner"</segment>
    <segment id="214">, "XCOM 2" e "Backbone"</segment>
    <segment id="215">, incluindo 19 jogos de desenvolvedores turcos.</segment>
    <segment id="216">Todo o dinheiro arrecadado será enviado para as ONGs Direct Relief</segment>
    <segment id="217">, International Medical Corps e Save the Children.</segment>
    <segment id="218">A promoção termina em 8 de março.</segment>
  </rst>
</analysis>