  <rst>
    <segment id="1">O barulho de um bebê que estava em casa com sua mãe advogada durante uma sessão virtual de julgamento incomodou um desembargador do TJAM (Tribunal de Justiça do Amazonas) na tarde desta segunda-feira (22).</segment>
    <segment id="2">No vídeo</segment>
    <segment id="3">, o desembargador Elcio Simões</segment>
    <segment id="4">, presidente da Segunda Câmara</segment>
    <segment id="5">Cível do tribunal</segment>
    <segment id="6">,</segment>
    <segment id="7">adverte a advogada Malu Borges Nunes após o barulho do bebê "vazar" de seu microfone na audiência em que ela defendia segurados do INSS (Instituto Nacional do Seguro Social) em ações de benefício por incapacidade.</segment>
    <segment id="8">Ao ouvir os resmungos da criança</segment>
    <segment id="9">, que parecia estar mamando (não é possível ver o bebê na tela)</segment>
    <segment id="10">, Simões dirige-</segment>
    <segment id="11">sese à profissional</segment>
    <segment id="12">, advertindo-a.</segment>
    <segment id="13">Ele afirma que interferências externas</segment>
    <segment id="14">, como</segment>
    <segment id="15">como latido de cachorro ou barulho de bebê</segment>
    <segment id="16">, atrapalham a sessão do tribunal</segment>
    <segment id="17">, que requer silêncio.</segment>
    <segment id="18">"</segment>
    <segment id="19">Se tiver alguma criança</segment>
    <segment id="20">, coloque no local adequado"</segment>
    <segment id="21">, diz ele a Malu</segment>
    <segment id="22">, chegando a falar sobre a "ética" da advogada</segment>
    <segment id="23">, que responde</segment>
    <segment id="24">, agradecendo a "compreensão" do magistrado.</segment>
    <segment id="25">"OK, Excelência</segment>
    <segment id="26">, agradeço a compreensão"</segment>
    <segment id="27">, diz ela.</segment>
    <segment id="28">Em nota</segment>
    <segment id="29">, o TJAM</segment>
    <segment id="30">, afirmou que o colegiado chegou a votar o direito de a mãe ter prioridade no debate dos processos em que apresentaria defesa</segment>
    <segment id="31">, a pedido da advogada</segment>
    <segment id="32">, masmas a prioridade foi negada</segment>
    <segment id="33">, já que ela estava em home office.</segment>
    <segment id="34">Sobre a bronca</segment>
    <segment id="35">, o órgão diz que foi uma recomendação dada de forma educada.</segment>
    <segment id="36">"Recomendou-</segment>
    <segment id="37">sese educadamente e com todo o cuidado evitar barulhos durante a sessão</segment>
    <segment id="38">, ainda mais em respeito a presença de outros advogados em audiência pública complexa e extensa"</segment>
    <segment id="39">, diz o órgão.</segment>
    <segment id="40">Procurada</segment>
    <segment id="41">, a advogada ainda não</segment>
    <segment id="42">sese manifestou sobre a questão.</segment>
    <segment id="43">LEIA TAMBÉMA mãe que ainda não foi interrompida no home office não tem filhosA participação da advogada na sessão começou com uma hora do início</segment>
    <segment id="44">, quando ela deu seu primeiro posicionamento em favor de uma cliente.</segment>
    <segment id="45">Depois</segment>
    <segment id="46">, passaram a ser debatidos vários outros processos em que ela defendia os cidadãos</segment>
    <segment id="47">, e a advogada precisou</segment>
    <segment id="48">, então</segment>
    <segment id="49">, abrir o microfone e fazer as defesas.</segment>
    <segment id="50">Antes mesmo da bronca do desembargador</segment>
    <segment id="51">, o bebê de Malu já havia resmungado</segment>
    <segment id="52">, fazendo sons que saíam pelo microfone enquanto a mãe falava</segment>
    <segment id="53">, masmas foi em duas ocasiões e o barulho não era alto.</segment>
    <segment id="54">No entanto</segment>
    <segment id="55">, na terceira vez</segment>
    <segment id="56">, o magistrado a repreendeu.</segment>
    <segment id="57">Não houve alteração na voz dele</segment>
    <segment id="58">, que usou o mesmo tom do debate dos casos julgados.</segment>
    <segment id="59">Malu também não</segment>
    <segment id="60">sese alterou e o respondeu com tranquilidade.</segment>
    <segment id="61">No entanto</segment>
    <segment id="62">, era possível ver no semblante da mãe um certo ar de incômodo pela situação.</segment>
    <segment id="63">A advogada Malu Borges</segment>
    <segment id="64">, em sessão na qual o desembargador Elcio Simões</segment>
    <segment id="65">, do TJAM</segment>
    <segment id="66">, lhe deu uma bronca pelos barulhos de seu bebê - ReproduçãoNas redes sociais</segment>
    <segment id="67">, há quem condene a mãe</segment>
    <segment id="68">Nas redes</segment>
    <segment id="69">, a sociedade</segment>
    <segment id="70">sese divide.</segment>
    <segment id="71">Muitas pessoas</segment>
    <segment id="72">, incluindo mulheres</segment>
    <segment id="73">, dizem que a atitude de Simões é correta</segment>
    <segment id="74">, condenando a mãe por estar com seu bebê.</segment>
    <segment id="75">Outras poucas acreditam que a situação foi constrangedora para a mulher.</segment>
    <segment id="76">Sou mãe e</segment>
    <segment id="77">, exatamente nesta segunda-feira (22)</segment>
    <segment id="78">, participei de reunião online com uma de milhas filhas na sala.</segment>
    <segment id="79">Ela tem dez anos e não resmunga mais</segment>
    <segment id="80">comocomo um bebê</segment>
    <segment id="81">, masmas estava visível no vídeo enquanto eu participava da reunião.  Minhas filhas</segment>
    <segment id="82">, inclusive</segment>
    <segment id="83">, gostam de cumprimentar as pessoas que estão em reunião comigo quando podem.</segment>
    <segment id="84">Afinal</segment>
    <segment id="85">, "entram" na sala de casa.</segment>
    <segment id="86">Meus colegas</segment>
    <segment id="87">, educadamente e amorosamente</segment>
    <segment id="88">, sempre têm um cumprimento e um sorriso para minhas meninas.</segment>
    <segment id="89">Home office amplia desequilíbrio de gênero na JustiçaMais    novamente         de   de  de  representando um  Também já fiz entrevistas ouvindo criança gritando do outro lado da linha</segment>
    <segment id="90">, mamando</segment>
    <segment id="91">, chorando e mesmo cachorro latindo.</segment>
    <segment id="92">Todos os entrevistados —em sua maioria homens— me pediram desculpas.</segment>
    <segment id="93">E eu sempre digo que não há problema.</segment>
    <segment id="94">Porque não há.</segment>
    <segment id="95">Quando</segment>
    <segment id="96">sese trata de pai cuidando do filho</segment>
    <segment id="97">, aproveito para parabenizar pela atitude.</segment>
    <segment id="98">O trabalho segue.</segment>
    <segment id="99">A vida segue.</segment>
    <segment id="100">Os profissionais</segment>
    <segment id="101">sese sentem respeitados e as crianças</segment>
    <segment id="102">, acolhidas.</segment>
    <segment id="103">Penso na sensação de tristeza dessa mãe.</segment>
    <segment id="104">Na realidade</segment>
    <segment id="105">, a única coisa que a gente quer é poder cuidar dos nossos filhos da melhor forma e vê-los sendo respeitados</segment>
    <segment id="106">comocomo um ser humano que faz parte da sociedade.</segment>
  </rst>
</analysis>