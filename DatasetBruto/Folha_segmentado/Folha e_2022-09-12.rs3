  <rst>
    <segment id="1">Na próxima quinta-feira (15)</segment>
    <segment id="2">, das 16h às 18h</segment>
    <segment id="3">, a Folha e o Itaú Cultural promovem a terceira edição do seminário Vida Cultural</segment>
    <segment id="4">, que aborda a mudança de hábito dos brasileiros ao consumir e</segment>
    <segment id="5">sese informar sobre cultura.</segment>
    <segment id="6">O evento será transmitido ao vivo e o público poderá acompanhá-lo nesta página.</segment>
    <segment id="7">Embora as atividades culturais sejam percebidas</segment>
    <segment id="8">comocomo um fator importante para manter a saúde mental</segment>
    <segment id="9">, a frequência de idas ao cinema e ao teatro diminuiu para 62% dos entrevistados pela pesquisa Hábitos Culturais 3</segment>
    <segment id="10">, realizada pelo Datafolha e pelo Itaú Cultural entre junho e julho de 2022</segment>
    <segment id="11">, com 2.240 pessoas de todas as regiões do país.</segment>
    <segment id="12">As dificuldades da volta ao presencial</segment>
    <segment id="13">, as possíveis razões para a mudança de comportamento identificada pelo estudo e as estratégias de institutos culturais para atrair o público neste novo cenário serão discutidas pelos convidados da primeira mesa</segment>
    <segment id="14">, com início às 16h.</segment>
    <segment id="15">Sala do Espaço Itaú de Cinema Frei Caneca</segment>
    <segment id="16">, eleito pelo Guia Folha nas categorias melhor programação e melhor cinema do centro - Rubens Cavallari/FolhapressJá no segundo painel</segment>
    <segment id="17">, às 17h</segment>
    <segment id="18">, os palestrantes debatem sobre as fontes de informação sobre cultura.</segment>
    <segment id="19">Segundo a pesquisa</segment>
    <segment id="20">, 55% dos brasileiros</segment>
    <segment id="21">sese informam sobre o tema nas redes sociais —neste</segment>
    <segment id="22">casocaso</segment>
    <segment id="23">, o YouTube é a plataforma preferida de 63% dos entrevistados—</segment>
    <segment id="24">, enquanto 35% consideram a indicação de amigos e parentes.</segment>
    <segment id="25">O seminário será mediado por Eduardo Saron</segment>
    <segment id="26">, diretor do Itaú Cultural</segment>
    <segment id="27">, e por Marcos Augusto Gonçalves</segment>
    <segment id="28">, editor da Ilustríssima.</segment>
    <segment id="29">O público pode participar enviando perguntas e comentários por WhatsApp</segment>
    <segment id="30">, no número (11) 99648-3478.</segment>
    <segment id="31">Seminário Vida Cultural - 3ª edição  Mesa 1 - A volta ao presencial   Data e horário: 15 de setembro (quinta-feira)</segment>
    <segment id="32">, das 16h às 17h  Palestrantes: André Acioli</segment>
    <segment id="33">, gestor de teatro e curador</segment>
    <segment id="34">;</segment>
    <segment id="35">João Luiz de Figueiredo</segment>
    <segment id="36">, professor do mestrado em gestão da economia criativa da ESPM-Rio</segment>
    <segment id="37">; Roberto Gervitz</segment>
    <segment id="38">, diretor e roteirista de cinema</segment>
    <segment id="39">;</segment>
    <segment id="40">Rosi Campos</segment>
    <segment id="41">, atriz   Mesa 2 - Os influenciadores da vida cultural  Data e horário: 15 de setembro (quinta-feira)</segment>
    <segment id="42">, das 17h às 18h  Palestrantes: Carol Moreira</segment>
    <segment id="43">, youtuber e podcaster</segment>
    <segment id="44">;</segment>
    <segment id="45">Inácio Araujo</segment>
    <segment id="46">, crítico de cinema da Folha</segment>
    <segment id="47">; Manuel da Costa Pinto</segment>
    <segment id="48">, jornalista e crítico literário</segment>
    <segment id="49">;</segment>
    <segment id="50">Patrick Torres</segment>
    <segment id="51">, booktoker e podcaster</segment>
  </rst>
</analysis>