  <rst>
    <segment id="1">Baixe esta pesquisaPesquisa Datafolha revela que diminui a reprovação ao Congresso Nacional.</segment>
    <segment id="2">O índice dos que avaliam o desempenho dos congressistas</segment>
    <segment id="3">comocomo ruim ou péssimo passou de 39% para 33% em relação à pesquisa realizada em fevereiro desse ano e de 14% para16% entre aqueles que avaliam</segment>
    <segment id="4">comocomo ótimo ou bom.</segment>
    <segment id="5">O índice dos que avaliam o desempenho</segment>
    <segment id="6">comocomo regular passou de 39% para 41%.O Datafolha ouviu 4.158 brasileiros de 16 anos ou mais</segment>
    <segment id="7">, nos dias 25 e 26 de março de 2010.</segment>
    <segment id="8">Para o total da amostra</segment>
    <segment id="9">, a margem de erro é de dois pontos percentuais</segment>
    <segment id="10">, para mais ou para menos.</segment>
    <segment id="11">Quanto à escolaridade é maior a aprovação entre aqueles que declaram possuir ensino fundamental do que entre os mais escolarizados</segment>
    <segment id="12">, 20% e 10% respectivamente.</segment>
    <segment id="13">A reprovação é maior entre os homens e entre os que possuem ensino superior</segment>
    <segment id="14">, 36% e 47%</segment>
    <segment id="15">, respectivamente.</segment>
    <segment id="16">Já entre aqueles que aprovam o desempenho do presidente Lula</segment>
    <segment id="17">, 19% consideram ótima ou boa a atuação do Congresso e 30% consideram-na ruim ou péssima.</segment>
    <segment id="18">Dos que reprovam o desempenho do presidente</segment>
    <segment id="19">, 66% também avaliam</segment>
    <segment id="20">comocomo ruim ou péssima a atuação do Congresso.</segment>
  </rst>
</analysis>