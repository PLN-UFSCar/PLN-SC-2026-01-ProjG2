  <rst>
    <segment id="1">O “imposto do pecado” sobre itens</segment>
    <segment id="2">comocomo bebida e tabaco</segment>
    <segment id="3">, proposto pelo ministro da Economia</segment>
    <segment id="4">, Paulo Guedes</segment>
    <segment id="5">, já está previsto nas propostas de emenda constitucional que tramitam na Câmara e no Senado —e que devem servir de base para a negociação com o governo.</segment>
    <segment id="6">Paulo Guedes e suas metáforas econômicas   novamente         de   de  de  representando um  SOB</segment>
    <segment id="7">O SOL   “Não tem novidade</segment>
    <segment id="8">, já está no nosso projeto”</segment>
    <segment id="9">, diz o senador Roberto Rocha (PSDB-MA)</segment>
    <segment id="10">, que relata a PEC do Senado.</segment>
    <segment id="11">CUSTA CARO</segment>
    <segment id="12">O artigo 154 da proposta prevê a criação de “impostos seletivos”</segment>
    <segment id="13">, destinados a “desestimular o consumo de determinados bens</segment>
    <segment id="14">, serviços ou direitos” —</segment>
    <segment id="15">comocomo álcool e tabaco</segment>
    <segment id="16">, completa o parlamentar.</segment>
    <segment id="17">COM AÇÚCAR</segment>
    <segment id="18">A novidade sugerida pelo ministro seria a tributação de produtos açucarados</segment>
    <segment id="19">, como</segment>
    <segment id="20">como ele anunciou em Davos no mês passado.   LEIA</segment>
    <segment id="21">TODOS OS TEMAS ABORDADOS PELA COLUNA NESTA SEGUNDA (10)</segment>
    <segment id="22">Fux deve levar questão do juiz das garantias a votação</segment>
    <segment id="23">Netflix vai fazer série sobre João de Deus   Regina Duarte quer levar TV Escola para a Cultura   Casos de Zika em SP caem de 72 para zero em janeiro</segment>
    <segment id="24">Número de usuários de planos de saúde caiu em 2019</segment>
    <segment id="25">Defensoria acionará metrô contra câmeras de reconhecimento facial</segment>
    <segment id="26">Baile da Vogue   novamente         de   de  de  representando um    CONFETE E SERPENTINA</segment>
    <segment id="27">As apresentadoras Sabrina Sato e Xuxa Meneghel foram ao Baile da Vogue 2020</segment>
    <segment id="28">, na sexta-feira (7)</segment>
    <segment id="29">, no Copacabana Palace</segment>
    <segment id="30">, no Rio de Janeiro.</segment>
    <segment id="31">As atrizes Isis Valverde e Bruna Linzmeyer também compareceram.</segment>
    <segment id="32">Festa de reestreia da peça &amp;#039</segment>
    <segment id="33">;O Mistério de Irmã Vap&amp;#039</segment>
    <segment id="34">;   novamente         de   de  de  representando um  RETORNO</segment>
    <segment id="35">Os atores Luís Miranda e Mateus Solano protagonizam a peça</segment>
    <segment id="36">“</segment>
    <segment id="37">O Mistério de Irma Vap”</segment>
    <segment id="38">, que teve sua festa de reestreia realizada na quinta (6)</segment>
    <segment id="39">, no Café Society</segment>
    <segment id="40">, em SP.</segment>
    <segment id="41">A obra tem direção de Jorge Farjalla.</segment>
    <segment id="42">A cantora Roberta Miranda e o ator Gero Camilo estiveram lá.   CURTO-CIRCUITO  Fórum de Empreendedores</segment>
    <segment id="43">, Facebook e a vereadora Janaína Lima (Novo-SP) realizam encontro com startups e empreendedores.</segment>
    <segment id="44">Nesta terça (11)</segment>
    <segment id="45">, na Estação Hack.</segment>
    <segment id="46">A Bonard apresenta nesta segunda (10) pesquisa sobre o mercado de residências estudantis.  com BRUNO B. SORAGGI</segment>
    <segment id="47">, BIANKA VIEIRA e VICTORIA AZEVEDO</segment>
