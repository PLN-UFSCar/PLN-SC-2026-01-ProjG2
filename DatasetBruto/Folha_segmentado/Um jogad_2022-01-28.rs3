  <rst>
    <segment id="1">Chega um novo brother na casa.</segment>
    <segment id="2">Na verdade dois</segment>
    <segment id="3">, porque</segment>
    <segment id="4">porque Fernando vem acompanhado de Homero</segment>
    <segment id="5">, seu cão-guia</segment>
    <segment id="6">, que logo</segment>
    <segment id="7">sese sente muito à vontade no novo lar</segment>
    <segment id="8">, abana o rabinho e já</segment>
    <segment id="9">sese aninha no sofá para receber cafunés de todos.</segment>
    <segment id="10">Não passa nem um dia e os brothers e sisters mais exaltados</segment>
    <segment id="11">sese rebelam contra os novos moradores.</segment>
    <segment id="12">Como competir com um jogador que vem com um aliado tão forte?</segment>
    <segment id="13">Afinal</segment>
    <segment id="14">, que telespectador iria votar para tirar da casa mais vigiada do país um labrador fofo</segment>
    <segment id="15">, que dá patinha</segment>
    <segment id="16">, gosta de nadar</segment>
    <segment id="17">, aprende algo novo todo dia e entende inglês e alemão?</segment>
    <segment id="18">A regra é clara</segment>
    <segment id="19">, cão-guia pode ir para qualquer lugar</segment>
    <segment id="20">, é lei</segment>
    <segment id="21">, masmas Big Brother é um jogo e tem muito dinheiro envolvido</segment>
    <segment id="22">para que</segment>
    <segment id="23">para que as condições não sejam iguais para todos os participantes.</segment>
    <segment id="24">A produção atende ao pleito</segment>
    <segment id="25">, que dividiu as redes sociais.</segment>
    <segment id="26">Mero, como</segment>
    <segment id="27">como passou a ser conhecido pelo Brasil nos dois dias em que foi uma estrela</segment>
    <segment id="28">, voltará para sua casa de verdade.</segment>
    <segment id="29">Fernando</segment>
    <segment id="30">, que se</segment>
    <segment id="31">se derramou em lágrimas em rede nacional</segment>
    <segment id="32">, dependerá apenas da Magrelinha</segment>
    <segment id="33">, sua bengala</segment>
    <segment id="34">, e do cotovelo dos outros jogadores para andar por sua nova casa</segment>
    <segment id="35">, que ainda não está totalmente mapeada na mente dele.</segment>
    <segment id="36">Todos se</segment>
    <segment id="37">se comprometem a ajudar  Quem ficou famoso com o Big Brother BrasilMais    novamente         de   de  de  representando um</segment>
    <segment id="38">A estratégia de eliminar Fernando começando por Mero</segment>
    <segment id="39">, porém</segment>
    <segment id="40">porém, não</segment>
    <segment id="41">sese mostrou vitoriosa.</segment>
    <segment id="42">O vídeo da despedida do cãozinho recebe mais de 15 milhões de cliques em um dia.</segment>
    <segment id="43">Os líderes da revolta anti-canina são sacados da casa um a um nos paredões seguintes.</segment>
    <segment id="44">Gostaria muito de ver barracos assim sendo mostrados para todo o país.</segment>
    <segment id="45">O Big Brother Brasil ano após ano pauta o debate público sobre temas</segment>
    <segment id="46">comocomo machismo</segment>
    <segment id="47">, feminismo</segment>
    <segment id="48">, preconceito contra pessoas LGBTQIA+</segment>
    <segment id="49">, contra pessoas de diferentes regiões do Brasil</segment>
    <segment id="50">, entre tantos outros.</segment>
    <segment id="51">A participação de um brother cego traria a oportunidade de espiarmos</segment>
    <segment id="52">comocomo uma pessoa que não enxerga é tratado no dia a dia e em situações de estresse criadas pelo programa.</segment>
    <segment id="53">,Seria uma oportunidade de discutirmos o capacitismo preconceito contra a pessoa com deficiência) e de ouvirmos de alguém que vive em condições desconhecidas pela maioria de nós qual sua história</segment>
    <segment id="54">, desafios</segment>
    <segment id="55">, conquistas e frustrações.</segment>
    <segment id="56">Colunas e BlogsReceba no seu email uma seleção de colunas e blogs da Folha</segment>
    <segment id="57">; exclusiva para assinantes.</segment>
    <segment id="58">Carregando...</segment>
    <segment id="59">Acima de tudo</segment>
    <segment id="60">, seria educativo.</segment>
    <segment id="61">O Brasil descobriria que braille não é hebraico</segment>
    <segment id="62">, que cego pode ir ao banheiro sozinho</segment>
    <segment id="63">, sese vestir</segment>
    <segment id="64">, cuidar da casa</segment>
    <segment id="65">, dançar</segment>
    <segment id="66">, sese divertir</segment>
    <segment id="67">, falar palavrão</segment>
    <segment id="68">, sese embriagar</segment>
    <segment id="69">, fazer alianças e trair</segment>
    <segment id="70">, ser gentil ou um bavaca.</segment>
    <segment id="71">Será que haverá muita diferença no modo</segment>
    <segment id="72">comocomo cada brother e sister trataria Fernando?</segment>
    <segment id="73">Ele receberia ajuda até aprender os caminhos de seu novo lar</segment>
    <segment id="74">, que mereceriam uma boa reforma para incluir piso-tátil?</segment>
    <segment id="75">para Teria companhia para</segment>
    <segment id="76">sese virar na hora de fazer o almoço?</segment>
    <segment id="77">Seria incluído de forma criativa na hora de enfrentar os demais em um jogo que não é acessível a princípio?</segment>
    <segment id="78">Provavelmente haverá participantes que</segment>
    <segment id="79">, seja por uma personalidade mais cuidadora</segment>
    <segment id="80">, seja para ganhar apreço do público</segment>
    <segment id="81">, não deixariam Fernando em paz</segment>
    <segment id="82">, iriam querer levá-lo o tempo todo e quase dar comida na boca.</segment>
    <segment id="83">Outros</segment>
    <segment id="84">, assistiremos</segment>
    <segment id="85">, vão fazer silêncio quando ele está perto para não serem notados e importunados por ele.</segment>
    <segment id="86">Taí um meme que ficará famoso</segment>
    <segment id="87">, Fernando procurando seus brothers para pedir auxílio em alguma tarefa mais ingrata para</segment>
    <segment id="88">sese fazer com os olhos fechados e vários brothers escondidos sob a mesa</segment>
    <segment id="89">, fazendo sinal</segment>
    <segment id="90">para que</segment>
    <segment id="91">para que fiquem em silêncio.</segment>
    <segment id="92">Quem sabe Fernando não encontraria um crush na casa.</segment>
    <segment id="93">A internet explodiria com a torcida e outros torcendo o nariz para esse romance.</segment>
    <segment id="94">O que chamaria a atenção não seria a imagem do primeiro beijo</segment>
    <segment id="95">, e sim da primeira vez em que ele sente com calma e paixão o rosto de sua nova namorada.</segment>
    <segment id="96">Mulheres e homens tentariam</segment>
    <segment id="97">sese lembrar</segment>
    <segment id="98">sese alguma vez já foram tocados assim</segment>
    <segment id="99">, com uma avidez delicada de quem busca conhecer o outro de verdade.</segment>
    <segment id="100">Relembre as celebridades que participaram do Big Brother Brasil em 2020 e 2021Mais    novamente         de   de  de  representando um</segment>
    <segment id="101">A participação de Fernando em um programa de tamanha audiência também movimentaria a comunidade de pessoas com deficiência visual</segment>
    <segment id="102">, chamada por nós de cegolândia.</segment>
    <segment id="103">Vídeos amadores com episódios do BBB com audiodescrição (descrição de imagens para ampliar a compreensão de quem não enxerga)circulariam na internet</segment>
    <segment id="104">, o que facilitará muito a compreensão dos acontecimentos da casa</segment>
    <segment id="105">, especialmente das festas e momentos de maior exaltação</segment>
    <segment id="106">, em que todo mundo grita junto e a gente só entendia o apito agudo a cada três segundos para encobrir os palavrões.</segment>
    <segment id="107">Mesmo com todas essas peripécias</segment>
    <segment id="108">, o paredão será a hora de descobrirmos</segment>
    <segment id="109">sese a participação de Fernando valeu à pena.</segment>
    <segment id="110">Não importa tanto o resultado</segment>
    <segment id="111">, e sim o que</segment>
    <segment id="112">sese dirá a respeito.</segment>
    <segment id="113">Será que a sociedade brasileira vai amadurecer a ponto de entender que um cego é</segment>
    <segment id="114">comocomo outro ser humano qualquer</segment>
    <segment id="115">, de quem podemos gostar ou não por quem ele é de fato</segment>
    <segment id="116">, não por sua deficiência?</segment>
    <segment id="117">O importante é conhecer e respeitar as suas diferenças.</segment>
    <segment id="118">Fernando não é nem um santo</segment>
    <segment id="119">, que não</segment>
    <segment id="120">sese possa criticar</segment>
    <segment id="121">, nem um café-com-leite</segment>
    <segment id="122">, que não está na vida e no jogo para ganhar.</segment>
    <segment id="123">Primeira festa do Big Brother Brasil em 2022</segment>
    <segment id="124">;- Globoplay/Reprodução</segment>
  </rst>
</analysis>