  <rst>
    <segment id="1">Com três semanas de exibição nos cinemas</segment>
    <segment id="2">, o filme “Minha Mãe é uma Peça 3” ultrapassou a marca de R$ 100 milhões em arrecadação e 6 milhões de espectadores.</segment>
    <segment id="3">O saldo coloca o filme de Paulo Gustavo à frente da nova animação da Disney</segment>
    <segment id="4">, “Frozen 2”</segment>
    <segment id="5">, visto por 1 milhão de brasileiros até agora.</segment>
    <segment id="6">&amp;#</segment>
    <segment id="7">039;Minha</segment>
    <segment id="8">Mãe É uma Peça 3&amp;#039</segment>
    <segment id="9">;Mais    novamente         de   de  de  representando um  'AS NOVINHAS QUE LUTEM'  Com 40 anos feitos</segment>
    <segment id="10">, Juliana Paes ostenta boa forma em fotos quase diárias no Instagram</segment>
    <segment id="11">, e a frequência só aumenta na temporada de verão.</segment>
    <segment id="12">Em uma de suas mais recentes publicações</segment>
    <segment id="13">, a atriz bota o corpão na foto e não</segment>
    <segment id="14">sese faz de rogada na legenda:</segment>
    <segment id="15">“</segment>
    <segment id="16">As novinhas que lutem</segment>
    <segment id="17">, hahahaha”.</segment>
    <segment id="18">O complemento sugere: “sol na laje”.</segment>
    <segment id="19">Em férias desde o fim de “A Dona do Pedaço</segment>
    <segment id="20">”,</segment>
    <segment id="21">a atriz ganhou longo período de folga na Globo para descansar sua imagem</segment>
    <segment id="22">, como</segment>
    <segment id="23">como se</segment>
    <segment id="24">se diz no jargão televisivo.</segment>
    <segment id="25">A próxima solicitação de expediente será para  projetos no cinema e em séries</segment>
    <segment id="26">, menos exaustivos.</segment>
    <segment id="27">Gatas de janeiroMais    novamente         de   de  de  representando um  FRASE  :"</segment>
    <segment id="28">Nunca gostei de casar várias vezes</segment>
    <segment id="29">, nunca gostei de ter trocado de pessoa</segment>
    <segment id="30">, de ter desfeito a minha família</segment>
    <segment id="31">, masmas</segment>
    <segment id="32">, às vezes</segment>
    <segment id="33">, as coisas não correm</segment>
    <segment id="34">comocomo a gente quer"   Gretchen</segment>
    <segment id="35">, no YouTube</segment>
    <segment id="36">, sobre o fim de seu casamento com Carlos Marques  É PIQUE!</segment>
    <segment id="37">Com presenças de Valeska Popozuda e do pessoal da escola de samba Beija Flor de Nilópolis</segment>
    <segment id="38">, Ludmilla</segment>
    <segment id="39">, 24 anos</segment>
    <segment id="40">, não economizou na festa de aniversário da namorada</segment>
    <segment id="41">, a bailarina Brunna Gonçalves</segment>
    <segment id="42">, que completou 28 anos.</segment>
    <segment id="43">A celebração aconteceu em uma casa de festas no Rio na segunda-feira (13).</segment>
    <segment id="44">AÇÃO</segment>
    <segment id="45">Lucas Lucco adotou em Campinas (SP) uma cadelinha que perdeu uma pata traseira em um acidente.</segment>
    <segment id="46">SURPRESA</segment>
    <segment id="47">A ex-Rouge Karin Hils vai aos poucos revelando imagens oficiais de seu novo trabalho</segment>
    <segment id="48">, que chega às plataformas digitais nesta sexta-feira (17).</segment>
    <segment id="49">A foto do ensaio de capa realizada para o single da música “Fogo” deu uma pista do que vem por aí.</segment>
    <segment id="50">Karin Hills</segment>
    <segment id="51">, ex-Rouge</segment>
    <segment id="52">, cantora</segment>
    <segment id="53">, lança o single Fogo</segment>
    <segment id="54">, primeiro da carreira solo - Adriana Lima/DivulgaçãoATÉ TU</segment>
    <segment id="55">O Madame Tussauds</segment>
    <segment id="56">, famoso museu de cera de Londres</segment>
    <segment id="57">, mudou de lugar as estátuas de Harry e Meghan um dia depois de o casal anunciar que</segment>
    <segment id="58">sese afastaria da realeza.</segment>
    <segment id="59">Antes posicionadas ao lado de William e Kate</segment>
    <segment id="60">, pouco atrás da rainha Elizabeth e do príncipe Philip</segment>
    <segment id="61">, as imagens agora estão em frente a outras peças do clã.</segment>
    <segment id="62">LÍDER</segment>
    <segment id="63">O meme “Brazil</segment>
    <segment id="64">, I’m devastated” (“Brasil</segment>
    <segment id="65">, eu estou devastada”) fez de Lady Gaga o nome mais comentado em conversas sobre o Rock in Rio no Twitter</segment>
    <segment id="66">, no ranking mundial</segment>
    <segment id="67">, desde janeiro de 2015</segment>
    <segment id="68">, segundo levantamento divulgado pela rede de microblogs.</segment>
    <segment id="69">Logo atrás de Lady Gaga vem Anitta</segment>
    <segment id="70">, única brasileira da lista.</segment>
    <segment id="71">Completam o ranking Shawn Mendes</segment>
    <segment id="72">, Drake</segment>
