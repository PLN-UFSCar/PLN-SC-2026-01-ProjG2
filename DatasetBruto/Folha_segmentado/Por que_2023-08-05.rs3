  <rst>
    <segment id="1">Durante a COP27</segment>
    <segment id="2">, em 2022</segment>
    <segment id="3">, no Egito</segment>
    <segment id="4">, o presidente Lula afirmou que o governo tem a "obrigação moral e ética de fazer reparação pelo o que foi causado aos povos indígenas".</segment>
    <segment id="5">Hoje, milhares de pessoas começam a</segment>
    <segment id="6">sese reunir em Belém para a Cúpula da Amazônia</segment>
    <segment id="7">, inclusive quase 1.000 indígenas de todos os países da região.</segment>
    <segment id="8">Debateremos soluções para a proteção da floresta</segment>
    <segment id="9">, a defesa dos direitos indígenas e o desenvolvimento sustentável</segment>
    <segment id="10">para que</segment>
    <segment id="11">para que "ninguém fique para trás"</segment>
    <segment id="12">, como</segment>
    <segment id="13">como diz o secretário-geral da ONU</segment>
    <segment id="14">, Antonio Guterres.</segment>
    <segment id="15">Após quatro anos de terror durante o governo Bolsonaro</segment>
    <segment id="16">, nós, povos indígenas</segment>
    <segment id="17">, queremos garantia de voz e voto para decidir o futuro da floresta.</segment>
    <segment id="18">Por isso</segment>
    <segment id="19">, eu me somo a uma Declaração dos Povos pela Amazônia para mostrar aos presidentes que somos muitos e que estamos atentos às decisões que eles tomarão nos próximos dias.</segment>
    <segment id="20">O presidente Lula</segment>
    <segment id="21">, durante reunião técnico-científica da Amazônia</segment>
    <segment id="22">, no início de julho- Cláudio Kbene/PR/Divulgação</segment>
    <segment id="23">Os cientistas e a sociedade civil nos alertam que a Amazônia está prestes a um ponto de não retorno</segment>
    <segment id="24">, algo que nós indígenas temos afirmado há muito mais tempo.</segment>
    <segment id="25">Se desmatarmos mais do que a floresta suporta</segment>
    <segment id="26">, ela pode entrar em colapso.</segment>
    <segment id="27">Para evitar isto</segment>
    <segment id="28">, precisamos proteger ao menos 80% da Amazônia.</segment>
    <segment id="29">Não em 2030</segment>
    <segment id="30">, muito menos 2050.</segment>
    <segment id="31">Mas agora.</segment>
    <segment id="32">Esta precisa ser a prioridade dos líderes reunidos em Belém.</segment>
    <segment id="33">Para atingir esse objetivo</segment>
    <segment id="34">, um importante resultado da cúpula é garantir a demarcação total dos nossos territórios.</segment>
    <segment id="35">Os povos originários sabem</segment>
    <segment id="36">comocomo ninguém manejar sustentavelmente a floresta.</segment>
    <segment id="37">Mas, se</segment>
    <segment id="38">se continuarmos a sermos ameaçados</segment>
    <segment id="39">, atacados</segment>
    <segment id="40">, expulsos de nossos territórios e mortos</segment>
    <segment id="41">, a Amazônia não ficará de pé.</segment>
    <segment id="42">Não há um futuro da Amazônia sem nós.</segment>
    <segment id="43">Ibama faz operação contra desmatamento no ParáMais    novamente         de   de  de  representando um</segment>
    <segment id="44">A declaração política desta cúpula precisa reconhecer o ponto de não retorno e assumir um compromisso ambicioso de proteção</segment>
    <segment id="45">, colocando os povos indígenas no centro.</segment>
    <segment id="46">Presidente Lula</segment>
    <segment id="47">, por favor concretize sua promessa de reparação com nossos povos já.</segment>
  </rst>
</analysis>