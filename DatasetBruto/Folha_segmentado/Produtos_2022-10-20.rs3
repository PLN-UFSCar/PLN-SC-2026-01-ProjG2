  <rst>
    <segment id="1">Supense.</segment>
    <segment id="2">Rivalidade.</segment>
    <segment id="3">Emoção.</segment>
    <segment id="4">Acelera-</segment>
    <segment id="5">sese a disputa eleitoral.</segment>
    <segment id="6">A famosa socialite Bibi Abdalla estava mobilizada.  —Bolsonarôôô.</segment>
    <segment id="7">A seu modo</segment>
    <segment id="8">, a simpática cadelinha Tiffany tentava participar.  —Wák.</segment>
    <segment id="9">Wák.  —Você é sempre fiel</segment>
    <segment id="10">, né, Tiffany?  —Wák.  —Tão diferente das minhas amigas...</segment>
    <segment id="11">De fato.</segment>
    <segment id="12">Várias frequentadoras do seleto círculo de Bibi tinham perdido o entusiasmo pelo presidente.  —</segment>
    <segment id="13">Justo nessa hora...  —</segment>
    <segment id="14">Wák.  —</segment>
    <segment id="15">Quando todo voto conta...</segment>
    <segment id="16">Era preciso aumentar a vantagem de Bolsonaro no bairro de Bibi.  —Aqui no Jardim América nós temos mais é de ter orgulho</segment>
    <segment id="17">, gente.</segment>
    <segment id="18">A socialite caprichava nos detalhes amarelos do guarda-roupa.  —Essa echarpe...</segment>
    <segment id="19">comprei em Paris.</segment>
    <segment id="20">Foi quando ela</segment>
    <segment id="21">sese deu conta.  —A Tiffany...</segment>
    <segment id="22">comocomo é que eu fui esquecer?</segment>
    <segment id="23">Na loja Petty-Bourgeois</segment>
    <segment id="24">, cadelinhas de luxo tinham à disposição um guarda-roupa completo.  —</segment>
    <segment id="25">Essa jaquetinha da Seleção...</segment>
    <segment id="26">o que você acha</segment>
    <segment id="27">, Tifanny?</segment>
    <segment id="28">—Whorc... Whonk?</segment>
    <segment id="29">O animalzinho parecia em dúvida.  —Que é que você está cheirando aí</segment>
    <segment id="30">, meu amor?</segment>
    <segment id="31">Tiffany</segment>
    <segment id="32">sese dirigia a outra seção do pet shop.  —</segment>
    <segment id="33">Mas aí é tudo vermelho... com estrelinha!</segment>
    <segment id="34">Opções de candidaturas mais à esquerda também estavam disponíveis para a cachorrada dos Jardins.  —</segment>
    <segment id="35">Wák.</segment>
    <segment id="36">Wák.  —Abanando o rabinho?</segment>
    <segment id="37">Será possível?</segment>
    <segment id="38">Bibi fez o teste.  —</segment>
    <segment id="39">Um casaquinho de cada lado.</segment>
    <segment id="40">Assim ela escolhe.</segment>
    <segment id="41">A cadelinha agachou-</segment>
    <segment id="42">sese sobre o coletinho de tricô amarelo.  —</segment>
    <segment id="43">Fazendo xixi?</segment>
    <segment id="44">Mas o que é isso?</segment>
    <segment id="45">Um leve puxão de orelha assinalou para Tiffany que seu comportamento era antidemocrático.  —Kaíính...</segment>
    <segment id="46">kaíính.</segment>
    <segment id="47">Bibi se</segment>
    <segment id="48">se arrependeu do gesto impulsivo.  —Desculpe</segment>
    <segment id="49">, Tiffany.</segment>
    <segment id="50">A socialite ficou pensando um pouco mais.  —</segment>
    <segment id="51">Mas é claro!</segment>
    <segment id="52">Como eu sou buuuurra</segment>
    <segment id="53">, genteeee.</segment>
    <segment id="54">Bibi comprou para Tifanny a roupinha bolsonarista.  —Ela fez xixi em cima...</segment>
    <segment id="55">masmas foi para deixar mais amarela ainda.  —Wók?</segment>
    <segment id="56">Wóóók?</segment>
    <segment id="57">Grhhh...  Cachorros</segment>
    <segment id="58">, como</segment>
    <segment id="59">como as rosas</segment>
    <segment id="60">, não falam.</segment>
    <segment id="61">Mas para bom entendedor meio xixi já basta.</segment>
    <segment id="62">Veja como</segment>
    <segment id="63">como Bolsonaro e Lula aparecem em estampas de bonés e camisetasMais    novamente         de   de  de  representando um</segment>
