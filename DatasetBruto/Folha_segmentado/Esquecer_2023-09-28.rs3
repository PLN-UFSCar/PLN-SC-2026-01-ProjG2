  <rst>
    <segment id="1">Eu estava no supermercado recentemente quando uma mulher veio correndo em minha direção.</segment>
    <segment id="2">"</segment>
    <segment id="3">Jancee!</segment>
    <segment id="4">", ela disse.</segment>
    <segment id="5">"</segment>
    <segment id="6">Como você está?</segment>
    <segment id="7">"</segment>
    <segment id="8">Eu sorri.</segment>
    <segment id="9">Ela parecia familiar</segment>
    <segment id="10">, masmas qual era o nome dela?</segment>
    <segment id="11">Enquanto ela conversava</segment>
    <segment id="12">, eu recitava silenciosamente o alfabeto</segment>
    <segment id="13">, esperando que isso me ajudasse a lembrar.</segment>
    <segment id="14">Por favor</segment>
    <segment id="15">, que o nome dela não seja Zoe</segment>
    <segment id="16">, pensei</segment>
    <segment id="17">; eu não consigo fingir por muito mais tempo.</segment>
    <segment id="18">É natural</segment>
    <segment id="19">sese perguntar</segment>
    <segment id="20">sese nossa memória está piorando à medida que envelhecemos — e essas preocupações não são infundadas: cerca de 5</segment>
    <segment id="21">,8 milhões de americanos vivem com demência</segment>
    <segment id="22">, que é marcada por uma perda significativa das funções cognitivas.</segment>
    <segment id="23">E o maior fator de risco para demência é o envelhecimento.</segment>
    <segment id="24">Mas algumas falhas de memória relacionadas à idade não são motivo de preocupação.</segment>
    <segment id="25">Conversei com quatro especialistas sobre as maneiras</segment>
    <segment id="26">comocomo a memória muda</segment>
    <segment id="27">, como</segment>
    <segment id="28">como podemos lembrar um pouco mais e quando discutir o esquecimento com um médico.</segment>
    <segment id="29">Alguns esquecimentos fazem parte do funcionamento normal do cérebro</segment>
    <segment id="30">, dizem especialistas- Nicolàs Ortega/The New York</segment>
    <segment id="31">TimesEsquecer temporariamente nomes e perder objetos é normal</segment>
    <segment id="32">Perguntei ao médico Mario Mendez</segment>
    <segment id="33">, diretor de neurologia comportamental da Escola de Medicina David Geffen da Universidade da Califórnia</segment>
    <segment id="34">, Los Angeles</segment>
    <segment id="35">, sobre problemas de memória relacionados à idade</segment>
    <segment id="36">, masmas ele corrigiu minha escolha de palavras:</segment>
    <segment id="37">"</segment>
    <segment id="38">Eu diria 'mudanças de memória'"</segment>
    <segment id="39">, diz ele.</segment>
    <segment id="40">"E isso não necessariamente</segment>
    <segment id="41">sese traduz em um problema.</segment>
    <segment id="42">"</segment>
    <segment id="43">Em um estudo com quase 50.000 pessoas</segment>
    <segment id="44">, os pesquisadores descobriram que a memória de curto prazo atinge o pico por volta dos 25 anos.</segment>
    <segment id="45">Mas a partir dos 50 anos</segment>
    <segment id="46">, afirma Mendez</segment>
    <segment id="47">, a área do cérebro responsável pela recuperação da memória é menos eficiente.</segment>
    <segment id="48">Ainda assim</segment>
    <segment id="49">, "ser menos eficiente é diferente de ter um comprometimento"</segment>
    <segment id="50">, pontua.</segment>
    <segment id="51">Então,</segment>
    <segment id="52">sese você está lutando para lembrar "aquele filme com aquele cara"</segment>
    <segment id="53">, a memória geralmente está lá</segment>
    <segment id="54">, diz Mendez –apenas leva mais tempo para surgir.</segment>
    <segment id="55">"</segment>
    <segment id="56">E então</segment>
    <segment id="57">, veja só</segment>
    <segment id="58">, cinco minutos depois</segment>
    <segment id="59">, você</segment>
    <segment id="60">sese lembra.</segment>
    <segment id="61">"</segment>
    <segment id="62">Esquecer as chaves do carro ou o nome de alguém muitas vezes é visto</segment>
    <segment id="63">comocomo uma falha do cérebro</segment>
    <segment id="64">, masmas não é</segment>
    <segment id="65">, diz Ronald Davis</segment>
    <segment id="66">, professor de neurociência no Instituto Herbert Wertheim UF Scripps para Inovação e Tecnologia Biomédica.</segment>
    <segment id="67">Somos inundados com muita informação</segment>
    <segment id="68">, pontua Davis</segment>
    <segment id="69">, e o cérebro precisa gerenciar as memórias.</segment>
    <segment id="70">"</segment>
    <segment id="71">Esquecer é uma parte normal da função cerebral"</segment>
    <segment id="72">, afirma.</segment>
    <segment id="73">Conheça fatores de risco para demência no BrasilMais    novamente         de   de  de  representando um  Como manter sua memória relativamente afiada</segment>
    <segment id="74">Só porque</segment>
    <segment id="75">porque as mudanças de memória são normais</segment>
    <segment id="76">, não significa que você não possa tentar melhorá-la</segment>
    <segment id="77">, diz Arman Fesharaki-Zadeh</segment>
    <segment id="78">, professor assistente de neurologia e psiquiatria na Escola de Medicina de Yale.</segment>
    <segment id="79">Em vez de usar truques para a recordação (</segment>
    <segment id="80">comocomo o que eu tentei no supermercado)</segment>
    <segment id="81">, algumas mudanças no estilo de vida podem ajudar.</segment>
    <segment id="82">Primeiro</segment>
    <segment id="83">, recomenda Fesharaki-Zadeh</segment>
    <segment id="84">, limite a multitarefa.</segment>
    <segment id="85">Não é bom para a saúde do seu cérebro em geral</segment>
    <segment id="86">, e à medida que envelhecemos</segment>
    <segment id="87">, nossa capacidade de fazer várias coisas ao mesmo tempo "geralmente diminui"</segment>
    <segment id="88">, pontua.</segment>
    <segment id="89">Esteja atento ao estresse</segment>
    <segment id="90">, que tem uma influência direta na memória</segment>
    <segment id="91">, afirma Fesharaki-Zadeh.</segment>
    <segment id="92">Vários estudos ligam a perda de sono a déficits de memória</segment>
    <segment id="93">, acrescenta ele</segment>
    <segment id="94">, então faça o possível para descansar adequadamente.</segment>
    <segment id="95">A dieta também pode afetar a memória.</segment>
    <segment id="96">Comer frutas</segment>
    <segment id="97">, legumes</segment>
    <segment id="98">, grãos integrais</segment>
    <segment id="99">, proteínas magras e gorduras saudáveis tem sido relacionado a uma melhor cognição.</segment>
    <segment id="100">Por fim</segment>
    <segment id="101">, Fesharaki-Zadeh diz que meia hora de exercício cardiovascular diário pode gerar novos neurônios na área do hipocampo do cérebro</segment>
    <segment id="102">, que é fundamental para a consolidação da memória.</segment>
    <segment id="103">Às vezes</segment>
    <segment id="104">, uma visita ao médico é necessária</segment>
    <segment id="105">Existem circunstâncias em que você deve consultar seu médico</segment>
    <segment id="106">, afirma Fesharaki-Zadeh.</segment>
    <segment id="107">Se alguém que te conhece bem apontar que seu esquecimento mudou significativamente</segment>
    <segment id="108">, pode ser um sinal de algo mais sério.</segment>
    <segment id="109">Os primeiros sinais de demência</segment>
    <segment id="110">, de acordo com a Alzheimer's Association</segment>
    <segment id="111">, incluem perder a capacidade de voltar atrás nos passos</segment>
    <segment id="112">, problemas para julgar distâncias e cada vez mais precisar de auxílios de memória</segment>
    <segment id="113">, como</segment>
    <segment id="114">como anotações ou alertas no telefone.</segment>
    <segment id="115">Se você sentir que a perda de memória está atrapalhando sua vida diária</segment>
    <segment id="116">, marque uma consulta com um médico</segment>
    <segment id="117">, pontua Scott Small</segment>
    <segment id="118">, professor de neurologia na Universidade de Columbia e autor de "Forgetting: The Benefits of Not Remembering" (Esquecer: os benefícios de não lembrar</segment>
    <segment id="119">, em português).</segment>
    <segment id="120">Um bom clínico</segment>
    <segment id="121">, diz ele</segment>
    <segment id="122">, pode explorar as possíveis causas dos problemas de memória</segment>
    <segment id="123">, seja uma doença ou outros fatores</segment>
    <segment id="124">, como</segment>
    <segment id="125">como certos analgésicos ou auxílios para dormir.</segment>
    <segment id="126">Depois de conversar com os especialistas em cérebro</segment>
    <segment id="127">, me senti tranquilizada.</segment>
    <segment id="128">E o nome da minha amiga</segment>
    <segment id="129">, como</segment>
    <segment id="130">como acabei descobrindo</segment>
    <segment id="131">, era Erica — então tive que fingir reconhecimento por apenas alguns segundos.</segment>
  </rst>
</analysis>