  <rst>
    <segment id="1">Quando</segment>
    <segment id="2">sese pensa em churrasco</segment>
    <segment id="3">, é comum vir à mente suculentos pedaços de carne sendo grelhados até a perfeição.</segment>
    <segment id="4">No entanto</segment>
    <segment id="5">, a criatividade na churrasqueira não tem limites</segment>
    <segment id="6">, e os sabores que podem ser explorados vão muito além do convencional.</segment>
    <segment id="7">Colunas e BlogsReceba no seu email uma seleção de colunas e blogs da Folha</segment>
    <segment id="8">; exclusiva para assinantes.</segment>
    <segment id="9">Carregando...</segment>
    <segment id="10">Em tempos onde a busca por opções mais saudáveis e sustentáveis</segment>
    <segment id="11">sese faz presente</segment>
    <segment id="12">, o espetinho de queijo minas fresco com abobrinha grelhada surge</segment>
    <segment id="13">comocomo uma alternativa deliciosa e criativa.</segment>
    <segment id="14">A ideia de um espetinho vegetariano pode parecer inusitada para alguns</segment>
    <segment id="15">, masmas a combinação de queijo minas fresco</segment>
    <segment id="16">, abobrinha e ervas frescas promete conquistar o paladar de todos</segment>
    <segment id="17">, até dos carnívoros fervorosos.</segment>
    <segment id="18">O queijo minas fresco</segment>
    <segment id="19">, com sua textura macia e sabor suave</segment>
    <segment id="20">, ganha uma nova dimensão quando colocado na churrasqueira</segment>
    <segment id="21">, e esse é o queijo perfeito para a churrasqueira</segment>
    <segment id="22">, porque</segment>
    <segment id="23">porque ele não derrete com o calor</segment>
    <segment id="24">, consegue manter sua estrutura e</segment>
    <segment id="25">, ao ser grelhado</segment>
    <segment id="26">, suas bordas adquirem um toque tostado e ligeiramente crocante.</segment>
    <segment id="27">Já a abobrinha traz um sabor adocicado que harmoniza perfeitamente com o queijo.</segment>
    <segment id="28">Para elevar os sabores desse prato tão simples</segment>
    <segment id="29">, ervas frescas e alho dão um toque final e ajudam a criar uma película</segment>
    <segment id="30">para que</segment>
    <segment id="31">para que a abobrinha não grude na grelha.</segment>
    <segment id="32">Pode besuntar bastante azeite nos espetos e bom apetite!</segment>
    <segment id="33">Espetinho de Queijo Minas Fresco com Abobrinha e Ervas Frescas  Ingredientes  200g de queijo minas fresco  1 abobrinha média  2 colheres de sopa de azeite de oliva extra virgem  2 dentes de alho picados</segment>
    <segment id="34">Um punhado de ervas frescas (manjericão</segment>
    <segment id="35">, salsa</segment>
    <segment id="36">, tomilho etc.) picadas</segment>
    <segment id="37">Sal a gosto</segment>
    <segment id="38">Palitos de espetinho (madeira ou metal)</segment>
    <segment id="39">Receita de espetinho de queijo minas com abobrinha</segment>
    <segment id="40">, de Larissa Morales - Felipe MargaridoModo de preparo</segment>
    <segment id="41">Corte a abobrinha em fatias finas no sentido do comprimento.</segment>
    <segment id="42">Corte o queijo minas fresco em cubos de tamanho médio</segment>
    <segment id="43">, cerca de 2cm.</segment>
    <segment id="44">Em uma tigela pequena</segment>
    <segment id="45">, misture as ervas frescas picadas</segment>
    <segment id="46">, o alho picado</segment>
    <segment id="47">, o azeite de oliva e uma pitada de sal.</segment>
    <segment id="48">Reserve.</segment>
    <segment id="49">Pegue uma fatia de abobrinha e coloque um cubo de queijo minas fresco na extremidade.</segment>
    <segment id="50">Enrole a fatia de abobrinha ao redor do queijo</segment>
    <segment id="51">, formando uma espécie de rolinho.</segment>
    <segment id="52">Repita o processo até que todos os cubos de queijo estejam envoltos nas fatias de abobrinha.</segment>
    <segment id="53">Tempere com o azeite de ervas e leve para grelhar por cerca de 3 minutos cada lado em fogo alto</segment>
    <segment id="54">, até tostar.</segment>
  </rst>
</analysis>