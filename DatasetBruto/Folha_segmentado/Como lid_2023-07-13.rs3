  <rst>
    <segment id="1">A nossa coluna de hoje vai falar sobre um tema muito complicado para homens de variadas idades: a ejaculação rápida</segment>
    <segment id="2">, mais conhecida</segment>
    <segment id="3">comocomo ejaculação precoce.</segment>
    <segment id="4">Ou seja</segment>
    <segment id="5">, aquela que</segment>
    <segment id="6">, quando viu</segment>
    <segment id="7">, já foi.</segment>
    <segment id="8">A que ocorre beeem rapidamente</segment>
    <segment id="9">, tão acelerada que praticamente nem</segment>
    <segment id="10">sese chega a sentir prazer.</segment>
    <segment id="11">Muito menos a ter o máximo de prazer sexual</segment>
    <segment id="12">, que é o clímax</segment>
    <segment id="13">, o orgasmo.</segment>
    <segment id="14">Colunas e BlogsReceba no seu email uma seleção de colunas e blogs da Folha</segment>
    <segment id="15">; exclusiva para assinantes.</segment>
    <segment id="16">Carregando...</segment>
    <segment id="17">É justamente para entender melhor essa história toda</segment>
    <segment id="18">, e como</segment>
    <segment id="19">como lidar com ela</segment>
    <segment id="20">, que vamos conversar bem detalhadamente por aqui.</segment>
    <segment id="21">Pesquisas científicas das mais variadas apontam dados</segment>
    <segment id="22">comocomo os seguintes:</segment>
    <segment id="23">cerca de dois terços dos jovens apresentam ejaculação precoce em algum momento da vida sexual.</segment>
    <segment id="24">Isso vale para adolescência e adulto jovem.</segment>
    <segment id="25">Entretanto</segment>
    <segment id="26">, essa dificuldade não é "privilégio" só de gente jovem não.</segment>
    <segment id="27">Pessoas mais velhas também podem enfrentar problemas no controle da ejaculação.</segment>
    <segment id="28">E quais seriam as causas desse mal?</segment>
    <segment id="29">Podemos dizer que a totalidade dos casos envolve algum grau de ansiedade elevada.</segment>
    <segment id="30">Ocorre assim: o adolescente</segment>
    <segment id="31">, o adulto</segment>
    <segment id="32">, ou o homem mais velho</segment>
    <segment id="33">, entra em um estado de ansiedade tão alto que isso arranca dele as possibilidades de obter prazer sexual</segment>
    <segment id="34">, e a ejaculação vem</segment>
    <segment id="35">comocomo que do nada</segment>
    <segment id="36">, em questão de segundos ou minutos.</segment>
    <segment id="37">Ejaculação precoce pode ser tratada- FolhapressPara quem tem essa dificuldade sexual</segment>
    <segment id="38">, basta</segment>
    <segment id="39">sese ver no meio de algo eroticamente estimulante que o corpo já responde com a ejaculação precoce.</segment>
    <segment id="40">Pode ser ao assistir algo erótico</segment>
    <segment id="41">, como</segment>
    <segment id="42">como uma cena de nudez ou um vídeo</segment>
    <segment id="43">, ou receber uma carícia erótica</segment>
    <segment id="44">, como</segment>
    <segment id="45">como um toque no pênis ou em outra parte estimulante do corpo</segment>
    <segment id="46">, ou começar uma prática sexual</segment>
    <segment id="47">, como</segment>
    <segment id="48">como penetração vaginal ou anal</segment>
    <segment id="49">, ou sexo oral.  Ou ficar apenas na imaginação erótica</segment>
    <segment id="50">, como</segment>
    <segment id="51">como quando algo leva a pessoa a pensar em sexo e isso a estimula muito.</segment>
    <segment id="52">Ou ainda apenas beijar ou abraçar</segment>
    <segment id="53">, entre outras coisas que tragam excitação sexual.</segment>
    <segment id="54">Ou seja</segment>
    <segment id="55">, ocorre um estímulo erótico</segment>
    <segment id="56">, por meio da imaginação e/ou dos órgãos de sentido (tato</segment>
    <segment id="57">, olfato</segment>
    <segment id="58">, visão</segment>
    <segment id="59">, audição</segment>
    <segment id="60">, paladar)</segment>
    <segment id="61">, e isso leva a uma excitação gigantesca</segment>
    <segment id="62">, masmas também a uma ansiedade tão enorme quanto.</segment>
    <segment id="63">Vibrador</segment>
    <segment id="64">, 150Mais    novamente         de   de  de  representando um  O corpo masculino produz</segment>
    <segment id="65">, então</segment>
    <segment id="66">, uma série de contrações involuntárias na região dos genitais</segment>
    <segment id="67">, contrações essas que expulsam o sêmen (o esperma) pelo canal da uretra.</segment>
    <segment id="68">Esse expulsar do sêmen ganha o nome de ejaculação.</segment>
    <segment id="69">E ela é considerada um problema</segment>
    <segment id="70">, como</segment>
    <segment id="71">como a ejaculação precoce</segment>
    <segment id="72">, quando ocorre muito</segment>
    <segment id="73">, muito</segment>
    <segment id="74">, muito rapidamente</segment>
    <segment id="75">, antes mesmo que a pessoa comece a curtir as sensações de prazer.</segment>
    <segment id="76">A boa notícia é que tem tratamento para TODOS os casos.</segment>
    <segment id="77">O primeiro passo é tentar localizar em si mesmo o que causa tanta ansiedade.</segment>
    <segment id="78">Preocupações e medos dos mais variados (de falhar</segment>
    <segment id="79">, de ejacular rapidamente</segment>
    <segment id="80">, de não satisfazer quem está ao lado</segment>
    <segment id="81">, de não</segment>
    <segment id="82">sese satisfazer etc)?</segment>
    <segment id="83">Ou o que mais?</segment>
    <segment id="84">Essa investigação emocional é fundamental para descobrir e tratar as raízes do problema.</segment>
    <segment id="85">E, para isso</segment>
    <segment id="86">, uma boa ajuda pode ser procurar um psicólogo ou uma psicóloga</segment>
    <segment id="87">, ou seja</segment>
    <segment id="88">, um especialista nas questões da psique</segment>
    <segment id="89">, do nosso lado emocional.</segment>
    <segment id="90">Série &amp;#039</segment>
    <segment id="91">;Sessão de Terapia&amp;#039</segment>
    <segment id="92">; - 5ª temporada (2021)Mais    novamente         de   de  de  representando um</segment>
    <segment id="93">O médico psiquiatra também pode ajudar</segment>
    <segment id="94">, avaliando o</segment>
    <segment id="95">casocaso e vendo a necessidade ou não do uso de alguma medicação para aliviar a ansiedade.</segment>
    <segment id="96">Lembrando que um profissional não exclui o outro: o psicólogo vai conversar e tratar as questões emocionais</segment>
    <segment id="97">, e o psiquiatra vai olhar para as queixas e medicar</segment>
    <segment id="98">sese necessário.</segment>
    <segment id="99">Outro passo é também procurar o médico urologista</segment>
    <segment id="100">, para verificar</segment>
    <segment id="101">comocomo está a saúde sexual</segment>
    <segment id="102">comocomo um todo.</segment>
    <segment id="103">A sua saúde sexual precisa estar em dia</segment>
    <segment id="104">para que</segment>
    <segment id="105">para que você possa viver o sexo de forma tranquila</segment>
    <segment id="106">, responsável e com muito prazer.</segment>
    <segment id="107">Para finalizar</segment>
    <segment id="108">, uma dica fundamental:</segment>
    <segment id="109">sese você tem alguma dificuldade sexual</segment>
    <segment id="110">, experimente parar de</segment>
    <segment id="111">sese cobrar tanto e aceitar que ninguém é perfeito</segment>
    <segment id="112">, e tente ir para o sexo da forma mais tranquila e relaxada possível.</segment>
    <segment id="113">Assim, as chances são grandes de você</segment>
    <segment id="114">, por si só</segment>
    <segment id="115">, ir baixando a sua ansiedade e descobrindo jeitos de ficar cada vez mais à vontade no sexo</segment>
    <segment id="116">, sem dificuldades nem complicações.</segment>
    <segment id="117">Fica a dica!</segment>
    <segment id="118">Esse texto surgiu a partir de uma pergunta de leitor.</segment>
