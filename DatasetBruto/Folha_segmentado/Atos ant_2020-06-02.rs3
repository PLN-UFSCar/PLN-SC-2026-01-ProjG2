  <rst>
    <segment id="1">Ap&amp;oacute</segment>
    <segment id="2">;s o assassinato de George Floyd</segment>
    <segment id="3">, homem negro cujo pesco&amp;ccedil</segment>
    <segment id="4">;o foi prensado no ch&amp;atilde</segment>
    <segment id="5">;o pelo joelho de um policial branco em 25 de maio</segment>
    <segment id="6">, protestos pelo fim do racismo e da brutalidade policial eclodiram nos EUA.</segment>
    <segment id="7">Agora, organiza&amp;ccedil</segment>
    <segment id="8">;&amp;otilde</segment>
    <segment id="9">;es internacionais tamb&amp;eacute</segment>
    <segment id="10">;m sese manifestam sobre o</segment>
    <segment id="11">casocaso.</segment>
    <segment id="12">Nesta ter&amp;ccedil</segment>
    <segment id="13">;a-feira (2)</segment>
    <segment id="14">, o chefe de diplomacia da Uni&amp;atilde</segment>
    <segment id="15">;o Europeia</segment>
    <segment id="16">, Josep Borrell</segment>
    <segment id="17">, afirmou em discurso televisionado que a organiza&amp;ccedil</segment>
    <segment id="18">;&amp;atilde</segment>
    <segment id="19">;o est&amp;aacute</segment>
    <segment id="20">;</segment>
    <segment id="21">&amp;ldquo</segment>
    <segment id="22">;chocada&amp;rdquo</segment>
    <segment id="23">; e &amp;ldquo</segment>
    <segment id="24">;horrorizada&amp;rdquo</segment>
    <segment id="25">; com a morte de Floyd.</segment>
    <segment id="26">Para Borrell</segment>
    <segment id="27">, todas as sociedades devem</segment>
    <segment id="28">sese manter vigilantes em rela&amp;ccedil</segment>
    <segment id="29">;&amp;atilde</segment>
    <segment id="30">;o ao uso for&amp;ccedil</segment>
    <segment id="31">;a e todos t&amp;ecirc</segment>
    <segment id="32">;m direito de realizar protestos pac&amp;iacute</segment>
    <segment id="33">;ficos.</segment>
    <segment id="34">&amp;ldquo</segment>
    <segment id="35">;N&amp;oacute</segment>
    <segment id="36">;s condenamos todo tipo de racismo.</segment>
    <segment id="37">Todas as vidas importam</segment>
    <segment id="38">, vidas negras tamb&amp;eacute</segment>
    <segment id="39">;m importam&amp;rdquo</segment>
    <segment id="40">;, completou.</segment>
    <segment id="41">Manifestantes em Amsterdã durante protesto contra a morte de George Floyd - Sem Van Der Wal - 1º.jun.20/AFPA alta comiss&amp;aacute</segment>
    <segment id="42">;ria da Na&amp;ccedil</segment>
    <segment id="43">;&amp;otilde</segment>
    <segment id="44">;es Unidas para os direitos humanos</segment>
    <segment id="45">, Michelle Bachelet</segment>
    <segment id="46">, disse em comunicado que os protestos nos EUA jogam luz n&amp;atilde</segment>
    <segment id="47">;o s&amp;oacute</segment>
    <segment id="48">;</segment>
    <segment id="49">sobre a viol&amp;ecirc</segment>
    <segment id="50">;ncia policial contra pessoas negras</segment>
    <segment id="51">, masmas tamb&amp;eacute</segment>
    <segment id="52">;m sobre a desigualdade hist&amp;oacute</segment>
    <segment id="53">;rica vivida por essa popula&amp;ccedil</segment>
    <segment id="54">;&amp;atilde</segment>
    <segment id="55">;o no acesso a sa&amp;uacute</segment>
    <segment id="56">;de, educa&amp;ccedil</segment>
    <segment id="57">;&amp;atilde</segment>
    <segment id="58">;o e ao mercado de trabalho.</segment>
    <segment id="59">Essas desigualdades</segment>
    <segment id="60">, afirmou Bachelet</segment>
    <segment id="61">, t&amp;ecirc</segment>
    <segment id="62">;m sido ignoradas h&amp;aacute</segment>
    <segment id="63">; tempos e acabaram expostas tamb&amp;eacute</segment>
    <segment id="64">;m pela pandemia de coronav&amp;iacute</segment>
    <segment id="65">;rus.</segment>
    <segment id="66">No &amp;</segment>
    <segment id="67">uacute</segment>
    <segment id="68">;ltimo domingo (31)</segment>
    <segment id="69">, centenas de pessoas protestaram em Londres e em Berlim em solidariedade aos atos americanos.</segment>
    <segment id="70">Na cidade brit&amp;acirc</segment>
    <segment id="71">;nica, manifestantes ajoelharam na Trafalgar Square</segment>
    <segment id="72">, bradaram gritos</segment>
    <segment id="73">comocomo &amp;quot</segment>
    <segment id="74">;sem justi&amp;ccedil</segment>
    <segment id="75">;a, sem paz&amp;quot</segment>
    <segment id="76">; e marcharam at&amp;eacute</segment>
    <segment id="77">; a sede do Parlamento e a embaixada dos EUA na cidade.</segment>
    <segment id="78">Protestos contra morte de George Floyd em cidades da Europa   novamente         de   de  de  representando um</segment>
    <segment id="79">Em Berlim</segment>
    <segment id="80">, centenas de protestantes tamb&amp;eacute</segment>
    <segment id="81">;m foram at&amp;eacute</segment>
    <segment id="82">; a embaixada americana</segment>
    <segment id="83">, com cartazes com frases</segment>
    <segment id="84">comocomo &amp;quot</segment>
    <segment id="85">;justi&amp;ccedil</segment>
    <segment id="86">;a para George Floyd&amp;quot</segment>
    <segment id="87">; e &amp;quot</segment>
    <segment id="88">;parem de nos matar&amp;quot</segment>
    <segment id="89">;.</segment>
    <segment id="90">Na segunda-feira (1&amp;ordm</segment>
    <segment id="91">;), centenas de pessoas ocuparam a pra&amp;ccedil</segment>
    <segment id="92">;a Dam</segment>
    <segment id="93">, em Amsterd&amp;atilde</segment>
    <segment id="94">;, contra a morte do seguran&amp;ccedil</segment>
    <segment id="95">;a.</segment>
    <segment id="96">No mesmo dia</segment>
    <segment id="97">, manifestantes parisienses</segment>
    <segment id="98">sese ajoelharam em frente &amp;agrave</segment>
    <segment id="99">; embaixada americana segurando cartazes com a frase &amp;ldquo</segment>
    <segment id="100">;eu n&amp;atilde</segment>
    <segment id="101">;o consigo respirar&amp;rdquo</segment>
    <segment id="102">;, repetida diversas vezes por Floyd antes de morrer.</segment>
    <segment id="103">Protestos tamb&amp;eacute</segment>
    <segment id="104">;m aconteceram ao longo do fim de semana na B&amp;eacute</segment>
    <segment id="105">;lgica</segment>
    <segment id="106">, na Dinamarca</segment>
    <segment id="107">, na Espanha</segment>
    <segment id="108">, na Gr&amp;eacute</segment>
    <segment id="109">;cia e no Canad&amp;aacute</segment>
    <segment id="110">;.</segment>
    <segment id="111">Na Cidade do M&amp;eacute</segment>
    <segment id="112">;xico, rosas e desenhos de Floyd foram pendurados nos port&amp;otilde</segment>
    <segment id="113">;es da embaixada americana.</segment>
    <segment id="114">Nesta ter&amp;ccedil</segment>
    <segment id="115">;a (2)</segment>
    <segment id="116">, atos em Sydney</segment>
    <segment id="117">, na Austr&amp;aacute</segment>
    <segment id="118">;lia, repudiavam tanto o assassinato de Floyd quanto o uso excessivo de for&amp;ccedil</segment>
    <segment id="119">;a na pris&amp;atilde</segment>
    <segment id="120">;o de um adolescente de origem abor&amp;iacute</segment>
    <segment id="121">;gene.</segment>
    <segment id="122">Gritos de &amp;quot</segment>
    <segment id="123">;sem justi&amp;ccedil</segment>
    <segment id="124">;a, sem paz&amp;quot</segment>
    <segment id="125">;</segment>
    <segment id="126">tamb&amp;eacute</segment>
    <segment id="127">;m foram ouvidos nas ruas de Paris nesta ter&amp;ccedil</segment>
    <segment id="128">;a.</segment>
    <segment id="129">Segundo o jornal Le Figaro</segment>
    <segment id="130">, cerca de 15 mil pessoas</segment>
    <segment id="131">sese reuniram em frente ao Tribunal de Justi&amp;ccedil</segment>
    <segment id="132">;a para protestar contra a morte do jovem negro Adama Traor&amp;eacute</segment>
    <segment id="133">;.</segment>
    <segment id="134">Ele morreu em 2016</segment>
    <segment id="135">, duas horas ap&amp;oacute</segment>
    <segment id="136">;s ter sido abordado pela pol&amp;iacute</segment>
    <segment id="137">;cia em Beaumont-sur-Oise</segment>
    <segment id="138">, a 65 km da capital.</segment>
    <segment id="139">A causa da morte ainda n&amp;atilde</segment>
    <segment id="140">;o foi determinada pela Justi&amp;ccedil</segment>
    <segment id="141">;a.</segment>
    <segment id="142">Nos &amp;uacute</segment>
    <segment id="143">;ltimos quatro anos</segment>
    <segment id="144">, foram realizadas quatro per&amp;iacute</segment>
    <segment id="145">;cias com resultados divergentes</segment>
    <segment id="146">, de acordo com o Le Parisien.</segment>
    <segment id="147">Duas delas concluem que Traor&amp;eacute</segment>
    <segment id="148">; foi asfixiado.</segment>
    <segment id="149">Manifestantes correm após a polícia disparar bombas de gás lacrimogêneo durante manifestação em Paris - Gonzalo Fuentes/ReutersA pol&amp;iacute</segment>
    <segment id="150">;cia proibiu o ato com base nas regras de combate ao novo coronav&amp;iacute</segment>
    <segment id="151">;rus &amp;mdash</segment>
    <segment id="152">;s&amp;atilde</segment>
    <segment id="153">;o permitidas apenas aglomera&amp;ccedil</segment>
    <segment id="154">;&amp;otilde</segment>
    <segment id="155">;es de at&amp;eacute</segment>
    <segment id="156">; dez pessoas.</segment>
    <segment id="157">Houve confrontos entre a multid&amp;atilde</segment>
    <segment id="158">;o e a pol&amp;iacute</segment>
    <segment id="159">;cia, que usou bombas de g&amp;aacute</segment>
    <segment id="160">;s lacrimog&amp;ecirc</segment>
    <segment id="161">;neo.</segment>
    <segment id="162">Os manifestantes dispararam fogos de artif&amp;iacute</segment>
    <segment id="163">;cio e acenderam fogueiras com restos de material de constru&amp;ccedil</segment>
    <segment id="164">;&amp;atilde</segment>
    <segment id="165">;o de obras pr&amp;oacute</segment>
    <segment id="166">;ximas ao tribunal.</segment>
    <segment id="167">J&amp;aacute</segment>
    <segment id="168">; os usu&amp;aacute</segment>
    <segment id="169">;rios do Instagram viram</segment>
    <segment id="170">, tamb&amp;eacute</segment>
    <segment id="171">;m nesta ter&amp;ccedil</segment>
    <segment id="172">;a, as tradicionais selfies e fotos de p&amp;atilde</segment>
    <segment id="173">;es feitos da quarentena e publicadas na rede social darem lugar a quadrados pretos.</segment>
    <segment id="174">Sob o nome de &amp;ldquo</segment>
    <segment id="175">;Blackout Tuesday&amp;rdquo</segment>
    <segment id="176">; (apag&amp;atilde</segment>
    <segment id="177">;o da ter&amp;ccedil</segment>
    <segment id="178">;a-feira)</segment>
    <segment id="179">, as postagens</segment>
    <segment id="180">sese tornaram a vers&amp;atilde</segment>
    <segment id="181">;o virtual &amp;mdash</segment>
    <segment id="182">;e silenciosa&amp;mdash</segment>
    <segment id="183">; das manifesta&amp;ccedil</segment>
    <segment id="184">;&amp;otilde</segment>
    <segment id="185">;es que tomaram as ruas dos Estados Unidos na &amp;uacute</segment>
    <segment id="186">;ltima semana.</segment>
    <segment id="187">Criado por duas executivas negras da ind&amp;uacute</segment>
    <segment id="188">;stria da m&amp;uacute</segment>
    <segment id="189">;sica, Jamila Thomas e Brianna Agyemang</segment>
    <segment id="190">, a ideia por tr&amp;aacute</segment>
    <segment id="191">;s da iniciativa &amp;eacute</segment>
    <segment id="192">;</segment>
    <segment id="193">&amp;ldquo</segment>
    <segment id="194">;perturbar intencionalmente a semana de trabalho&amp;rdquo</segment>
    <segment id="195">;, como</segment>
    <segment id="196">como explicam no site do manifesto</segment>
    <segment id="197">, intitulado #TheShowMustBePaused (o show tem que parar).  &amp;ldquo</segment>
    <segment id="198">;A segunda-feira sugere um fim de semana prolongado</segment>
    <segment id="199">, e n&amp;atilde</segment>
    <segment id="200">;o podemos esperar at&amp;eacute</segment>
    <segment id="201">;</segment>
    <segment id="202">sexta-feira para a mudan&amp;ccedil</segment>
    <segment id="203">;a.</segment>
    <segment id="204">[2 de junho] &amp;eacute</segment>
    <segment id="205">; um dia de pausa para uma conversa honesta</segment>
    <segment id="206">, reflexiva e produtiva sobre quais a&amp;ccedil</segment>
    <segment id="207">;&amp;otilde</segment>
    <segment id="208">;es precisamos tomar</segment>
    <segment id="209">, coletivamente</segment>
    <segment id="210">, para apoiar a comunidade negra&amp;rdquo</segment>
    <segment id="211">;, acrescentam.</segment>
  </rst>
</analysis>