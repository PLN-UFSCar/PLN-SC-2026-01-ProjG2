  <rst>
    <segment id="1">Um dos principais hospitais do Vale do Aço</segment>
    <segment id="2">, em Minas Gerais</segment>
    <segment id="3">, enfrenta falta de sangue para pacientes que precisam de transfusões em decorrência do aumento de casos de dengue e chikungunya na região.</segment>
    <segment id="4">O HMC (Hospital Márcio Cunha)</segment>
    <segment id="5">, que fica em Ipatinga</segment>
    <segment id="6">, a 215 km de Belo Horizonte</segment>
    <segment id="7">, fez pedido de doações pelas redes sociais.</segment>
    <segment id="8">O hospital atende uma região com aproximadamente 800 mil moradores</segment>
    <segment id="9">, onde estão localizadas cidades</segment>
    <segment id="10">comocomo Coronel Fabriciano e Timóteo.</segment>
    <segment id="11">O Hospital Márcio Cunha (HMC)</segment>
    <segment id="12">, em Ipatinga (MG)</segment>
    <segment id="13">, que atende a cerca de 800 mil pessoas por ano e enfrenta falta de sangue.</segment>
    <segment id="14">- Prefeitura de IpatingaA transfusão é utilizada quando há redução no nível de plaquetas dos infectados pelas duas doenças.</segment>
    <segment id="15">O hospital é uma fundação e atende pelo SUS (Sistema Único de Saúde) e por convênios.  "</segment>
    <segment id="16">A hemoterapia do HMC enfrenta atualmente</segment>
    <segment id="17">, um déficit nos estoques</segment>
    <segment id="18">, recebendo apenas cerca de 30 doadores por dia</segment>
    <segment id="19">, enquanto a média necessária para a sustentabilidade é de 60 doações diárias"</segment>
    <segment id="20">, afirma o hospital</segment>
    <segment id="21">, ao justificar o pedido de doações.  "</segment>
    <segment id="22">Além do período de férias e do Carnaval que</segment>
    <segment id="23">sese aproxima</segment>
    <segment id="24">, que geralmente causam a diminuição de doadores</segment>
    <segment id="25">, a unidade enfrenta uma emergência de saúde pública devido ao cenário crítico de arboviroses</segment>
    <segment id="26">, como</segment>
    <segment id="27">como dengue e chikungunya"</segment>
    <segment id="28">, diz a instituição.</segment>
    <segment id="29">No sábado (27)</segment>
    <segment id="30">, o governo de Minas Gerais decretou estado de emergência para as duas doenças e também para zika</segment>
    <segment id="31">, todas transmitidas pelo mosquito Aedes aegypti.</segment>
    <segment id="32">O que é dengueMais    novamente         de   de  de  representando um</segment>
    <segment id="33">O boletim epidemiológico da Secretaria de Estado de Saúde publicado na segunda (2) registra 752 casos de dengue e 2.010 de chikungunya.</segment>
    <segment id="34">No boletim anterior</segment>
    <segment id="35">, de 22 de janeiro</segment>
    <segment id="36">, os casos de dengue somavam 252 e os de chikungunya</segment>
    <segment id="37">, 755.</segment>
    <segment id="38">Ipatinga tem 227 mil habitantes.</segment>
    <segment id="39">Na vizinha Coronel Fabriciano</segment>
    <segment id="40">, os casos de dengue em 29 de janeiro totalizaram 119 e os de chikungunya</segment>
    <segment id="41">,184.</segment>
    <segment id="42">No relatório de 22 de janeiro os números eram de 42 e 24</segment>
    <segment id="43">, respectivamente.</segment>
    <segment id="44">A cidade tem 104 mil habitantes.</segment>
    <segment id="45">A Secretaria de Estado de Saúde de Minas Gerais informou que o HMC não tem contrato com a Fundação Hemominas</segment>
    <segment id="46">, o banco de sangue estadual.</segment>
    <segment id="47">"</segment>
    <segment id="48">Porém,</segment>
    <segment id="49">casocaso o hospital não possua estoque</segment>
    <segment id="50">, em caso</segment>
    <segment id="51">caso de emergências comprovadas</segment>
    <segment id="52">, a fundação realiza a destinação de hemocomponentes ao referido hospital</segment>
    <segment id="53">, mediante solicitação"</segment>
    <segment id="54">, afirma a pasta</segment>
    <segment id="55">, em nota.  "</segment>
    <segment id="56">A secretaria esclarece ainda que o hospital em questão possui banco de sangue próprio</segment>
    <segment id="57">, onde é realizado todo o ciclo do sangue</segment>
    <segment id="58">, desde coleta até transfusões</segment>
    <segment id="59">, atendendo hospitais SUS</segment>
    <segment id="60">, filantrópicos e privados"</segment>
    <segment id="61">, diz o comunicado.</segment>
  </rst>
</analysis>