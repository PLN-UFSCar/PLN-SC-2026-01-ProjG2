  <rst>
    <segment id="1">Um empres&amp;aacute</segment>
    <segment id="2">;rio de 34 anos</segment>
    <segment id="3">, apontado pela pol&amp;iacute</segment>
    <segment id="4">;cia como</segment>
    <segment id="5">como traficante de animais</segment>
    <segment id="6">, e duas mulheres</segment>
    <segment id="7">, foram presos quando transportavam tr&amp;ecirc</segment>
    <segment id="8">;s filhotes de macaco-prego em uma picape no fim da noite de ter&amp;ccedil</segment>
    <segment id="9">;a-feira (11)</segment>
    <segment id="10">, em Santana</segment>
    <segment id="11">, zona norte de S&amp;atilde</segment>
    <segment id="12">;o Paulo.</segment>
    <segment id="13">A abordagem ocorreu ap&amp;oacute</segment>
    <segment id="14">;s o 13&amp;ordm</segment>
    <segment id="15">; DP (Casa Verde) receber uma den&amp;uacute</segment>
    <segment id="16">;ncia de que o suspeito iria comercializar animais silvestres</segment>
    <segment id="17">, em uma rua de classe m&amp;eacute</segment>
    <segment id="18">;dia alta</segment>
    <segment id="19">, no bairro da zona norte paulistana.</segment>
    <segment id="20">&amp;ldquo</segment>
    <segment id="21">;Nos passaram o modelo do ve&amp;iacute</segment>
    <segment id="22">;culo [uma caminhonete Mitsubishi L 200]</segment>
    <segment id="23">, o endere&amp;ccedil</segment>
    <segment id="24">;o e hor&amp;aacute</segment>
    <segment id="25">;rio em que o suspeito estaria com os bichos.</segment>
    <segment id="26">A partir da&amp;iacute</segment>
    <segment id="27">;, organizamos uma campana&amp;rdquo</segment>
    <segment id="28">;, afirmou o delegado Vitor Franchini Luna.</segment>
    <segment id="29">Seis investigadores</segment>
    <segment id="30">sese posicionaram na rua</segment>
    <segment id="31">, at&amp;eacute</segment>
    <segment id="32">; a chegada da caminhonete</segment>
    <segment id="33">, por volta das 22h40.</segment>
    <segment id="34">Ap&amp;oacute</segment>
    <segment id="35">;s ele desembarcar</segment>
    <segment id="36">, narrou o delegado</segment>
    <segment id="37">, pegou no banco traseiro duas caixas</segment>
    <segment id="38">, semelhantes &amp;agrave</segment>
    <segment id="39">;s usadas para transportar c&amp;atilde</segment>
    <segment id="40">;es e gatos de pequeno porte.</segment>
    <segment id="41">&amp;ldquo</segment>
    <segment id="42">;Essa foi a deixa para a gente agir.</segment>
    <segment id="43">Quando nos aproximamos do suspeito</segment>
    <segment id="44">, identificamos que ele transportava dois filhotes de macaco-prego</segment>
    <segment id="45">, um em cada caixa&amp;rdquo</segment>
    <segment id="46">;</segment>
    <segment id="47">, disse ainda o delegado.</segment>
    <segment id="48">Segundo o Minist&amp;eacute</segment>
    <segment id="49">;rio do Meio Ambiente</segment>
    <segment id="50">, o macaco-prego &amp;eacute</segment>
    <segment id="51">; uma das esp&amp;eacute</segment>
    <segment id="52">;cies de primatas amea&amp;ccedil</segment>
    <segment id="53">;adas de extin&amp;ccedil</segment>
    <segment id="54">;&amp;atilde</segment>
    <segment id="55">;o no Brasil.</segment>
    <segment id="56">Macaco-prego foi encontrado em carro de empresário</segment>
    <segment id="57">, terça-feira (11)</segment>
    <segment id="58">, na zona norte da capital paulista.</segment>
    <segment id="59">Homem e duas mulheres foram presos por tráfico de animais silvestres e associação criminosa- Divulgação/Polícia CivilEnquanto parte da equipe abordava o homem</segment>
    <segment id="60">, um investigador foi at&amp;eacute</segment>
    <segment id="61">;</segment>
    <segment id="62">a caminhonete</segment>
    <segment id="63">, momento em que a namorada do suspeito</segment>
    <segment id="64">, uma empres&amp;aacute</segment>
    <segment id="65">;ria de 32 anos acabava de assumir o volante.</segment>
    <segment id="66">Ela acelerou em seguida</segment>
    <segment id="67">, arrastando o policial</segment>
    <segment id="68">, que se</segment>
    <segment id="69">se segurou &amp;agrave</segment>
    <segment id="70">; porta da Mitsubishi por alguns metros</segment>
    <segment id="71">, at&amp;eacute</segment>
    <segment id="72">; que a picape colidiu contra uma sarjeta e parou.</segment>
    <segment id="73">&amp;ldquo</segment>
    <segment id="74">;Mesmo com todo mundo</segment>
    <segment id="75">sese identificando</segment>
    <segment id="76">comocomo policial</segment>
    <segment id="77">, a mulher disse ter pensado que era um assalto e</segment>
    <segment id="78">, por isso</segment>
    <segment id="79">, acelerou o carro&amp;rdquo</segment>
    <segment id="80">;, acrescentou o delegado.</segment>
    <segment id="81">Ningu&amp;eacute</segment>
    <segment id="82">;m sese feriu.</segment>
    <segment id="83">Dentro do ve&amp;iacute</segment>
    <segment id="84">;culo, policiais tamb&amp;eacute</segment>
    <segment id="85">;m encontraram uma dona de casa de 35 anos</segment>
    <segment id="86">, no banco traseiro.</segment>
    <segment id="87">Ao lado dela</segment>
    <segment id="88">, havia outra caixa de transporte de animais com mais um filhote de macaco-prego.</segment>
    <segment id="89">Todos foram levados em seguida at&amp;eacute</segment>
    <segment id="90">; o 13&amp;ordm</segment>
    <segment id="91">; DP, onde acabaram indiciados por tr&amp;aacute</segment>
    <segment id="92">;fico de animais e associa&amp;ccedil</segment>
    <segment id="93">;&amp;atilde</segment>
    <segment id="94">;o criminosa.</segment>
    <segment id="95">A Justi&amp;ccedil</segment>
    <segment id="96">;a decretou a pris&amp;atilde</segment>
    <segment id="97">;o preventiva do trio</segment>
    <segment id="98">, que ficar&amp;aacute</segment>
    <segment id="99">; detido por tempo indeterminado.</segment>
    <segment id="100">Segundo a pol&amp;iacute</segment>
    <segment id="101">;cia, nenhum advogado de defesa havia assumido o</segment>
    <segment id="102">casocaso at&amp;eacute</segment>
    <segment id="103">; a publica&amp;ccedil</segment>
    <segment id="104">;&amp;atilde</segment>
    <segment id="105">;o desta reportagem.</segment>
    <segment id="106">Propaganda</segment>
    <segment id="107">Com um filhote em um dos ombros</segment>
    <segment id="108">, o empres&amp;aacute</segment>
    <segment id="109">;rio preso sob a suspeita de tr&amp;aacute</segment>
    <segment id="110">;fico de animais informa que o bicho est&amp;aacute</segment>
    <segment id="111">; &amp;agrave</segment>
    <segment id="112">; venda</segment>
    <segment id="113">, segundo um v&amp;iacute</segment>
    <segment id="114">;deo feito por ele e publicado na internet.</segment>
    <segment id="115">Dando peda&amp;ccedil</segment>
    <segment id="116">;os de ma&amp;ccedil</segment>
    <segment id="117">;&amp;atilde</segment>
    <segment id="118">; ao bicho</segment>
    <segment id="119">, que faz alguns sons com a boca</segment>
    <segment id="120">, o homem diz que cada macaco-prego custa R$ 6.000.</segment>
    <segment id="121">&amp;ldquo</segment>
    <segment id="122">;Igual a esse aqui tenho alguns</segment>
    <segment id="123">, n&amp;atilde</segment>
    <segment id="124">;o v&amp;aacute</segment>
    <segment id="125">;rios,</segment>
    <segment id="126">poispois a gente n&amp;atilde</segment>
    <segment id="127">;o explora a natureza</segment>
    <segment id="128">, simplesmente ganha dinheiro com os animais</segment>
    <segment id="129">, &amp;eacute</segment>
    <segment id="130">;</segment>
    <segment id="131">diferente&amp;quot</segment>
    <segment id="132">;, afirma o homem em trecho do v&amp;iacute</segment>
    <segment id="133">;deo.</segment>
    <segment id="134">Segundo o delegado Vitor Franchini Luna</segment>
    <segment id="135">, o empres&amp;aacute</segment>
    <segment id="136">;rio seria um dos maiores traficantes de animais silvestres do Brasil.</segment>
    <segment id="137">&amp;ldquo</segment>
    <segment id="138">;Levantamos que</segment>
    <segment id="139">, em um s&amp;oacute</segment>
    <segment id="140">; dia, ele chegava a comercializar R$ 50 mil.&amp;rdquo</segment>
    <segment id="141">;</segment>
    <segment id="142">A pol&amp;iacute</segment>
    <segment id="143">;cia agora d&amp;aacute</segment>
    <segment id="144">; continuidade &amp;agrave</segment>
    <segment id="145">;s investiga&amp;ccedil</segment>
    <segment id="146">;&amp;otilde</segment>
    <segment id="147">;es para identificar os compradores dos animais</segment>
    <segment id="148">, al&amp;eacute</segment>
    <segment id="149">;m de localizar eventuais comparsas do empres&amp;aacute</segment>
    <segment id="150">;rio preso.</segment>
    <segment id="151">Polícia apreende três filhotes macacos-prego em carro de empresário na zona norte da capital paulista    novamente         de   de  de  representando um</segment>
  </rst>
</analysis>