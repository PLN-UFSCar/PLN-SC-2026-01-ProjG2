  <rst>
    <segment id="1">Ativista pelos direitos femininos em um dos países com maior desigualdade de gênero no mundo</segment>
    <segment id="2">, a afegã Khatera Mohmand</segment>
    <segment id="3">, 38, enfrentou muitas batalhas para combater a violência contra a mulher no serviço público que chefiava.</segment>
    <segment id="4">Mas poucos momentos foram tão difíceis quanto ter que explicar à própria filha</segment>
    <segment id="5">, Lema</segment>
    <segment id="6">, 8, que ela não poderia mais ir à escola.</segment>
    <segment id="7">"Ela me perguntou:</segment>
    <segment id="8">‘o quê?</segment>
    <segment id="9">Por quê?</segment>
    <segment id="10">Eu adoro a escola</segment>
    <segment id="11">, eu quero ir’"</segment>
    <segment id="12">, conta.</segment>
    <segment id="13">"</segment>
    <segment id="14">Como eu iria explicar isso para ela?</segment>
    <segment id="15">Como dizer que ela não pode estudar</segment>
    <segment id="16">, masmas os meninos</segment>
    <segment id="17">, sim?</segment>
    <segment id="18">".</segment>
    <segment id="19">Chefe do departamento de equidade de gênero de uma organização do governo</segment>
    <segment id="20">, Khatera deixou seu escritório às pressas no dia 15 de agosto do ano passado</segment>
    <segment id="21">, quando o Talibã entrou em Cabul e</segment>
    <segment id="22">, em um ofensiva relâmpago</segment>
    <segment id="23">, assumiu o poder central.</segment>
    <segment id="24">Ela tinha lembranças nítidas do outro período em que o grupo fundamentalista controlou seu país</segment>
    <segment id="25">, de 1996 a 2001.</segment>
    <segment id="26">Filha de um casal de professores</segment>
    <segment id="27">, Khatera passou quase seis anos estudando em casa</segment>
    <segment id="28">, com a irmã</segment>
    <segment id="29">, às escondidas</segment>
    <segment id="30">, "como</segment>
    <segment id="31">como se</segment>
    <segment id="32">se fosse um crime".  Desta vez</segment>
    <segment id="33">, temendo que o mesmo acontecesse com Lema e vendo a própria vida ameaçada devido à causa que defendia</segment>
    <segment id="34">, ela decidiu migrar para o Brasil com o marido</segment>
    <segment id="35">, com Lema e com Sohail</segment>
    <segment id="36">, o filho mais velho.</segment>
    <segment id="37">Auxiliados por uma ONG</segment>
    <segment id="38">, eles foram para Jundiaí (SP)</segment>
    <segment id="39">, onde as crianças já vão à escola pública.</segment>
    <segment id="40">No pequeno apartamento com varanda</segment>
    <segment id="41">, lampejos da vida anterior podem ser vislumbrados em uma cristaleira</segment>
    <segment id="42">, com objetos que antes decoravam o imóvel de cinco quartos onde moravam em Cabul: medalhas escolares de Sohail</segment>
    <segment id="43">, um livro escrito pela mãe de Khatera</segment>
    <segment id="44">, suvenires</segment>
    <segment id="45">, artesanato de mulheres afegãs.</segment>
    <segment id="46">"</segment>
    <segment id="47">Você não consegue colocar toda a sua casa em uma mala</segment>
    <segment id="48">, masmas eu quis trazer os objetos de maior valor sentimental"</segment>
    <segment id="49">, conta ela.</segment>
    <segment id="50">Leia os outros textos da série Afegãs no BrasilSetara JoyaTalibã matou meu pai</segment>
    <segment id="51">porque</segment>
    <segment id="52">porque eu era militar</segment>
    <segment id="53">, diz afegã refugiada em SPZahra KarimiDecidi me matar</segment>
    <segment id="54">sese o Talibã me sequestrasse</segment>
    <segment id="55">, diz fotógrafa afegã refugiada em SPKhatera é a última entrevistada de uma série de três mulheres que contaram suas histórias à Folha um ano depois que o Talibã voltou a governar o país.</segment>
    <segment id="56">São afegãs que viveram a maior parte da vida com acesso a alguns direitos básicos —ir à escola</segment>
    <segment id="57">, caminhar pelas ruas e trabalhar— e que viram tudo isso desaparecer de um dia para o outro.</segment>
    <segment id="58">A sociedade afegã é tradicional e sempre deu mais direitos aos homens do que às mulheres.</segment>
    <segment id="59">Isso começa dentro das famílias</segment>
    <segment id="60">, porque</segment>
    <segment id="61">porque a maioria dos homens acredita que o trabalho das mulheres deveria ser ficar em casa</segment>
    <segment id="62">, cuidar das crianças</segment>
    <segment id="63">, cozinhar.</segment>
    <segment id="64">Eu sou de uma família diferente.</segment>
    <segment id="65">Minha mãe era professora e escritora</segment>
    <segment id="66">, meu pai também foi professor</segment>
    <segment id="67">, e eles nunca trataram de forma diferente os filhos meninos e meninas.</segment>
    <segment id="68">Eles nos diziam: "</segment>
    <segment id="69">Nunca tolere que cometam violência contra você ou contra qualquer pessoa à sua volta".</segment>
    <segment id="70">Acho que aí começou meu ativismo.</segment>
    <segment id="71">China, terra do meioReceba no seu email os grandes temas da China explicados e contextualizados</segment>
    <segment id="72">; exclusiva para assinantes.</segment>
    <segment id="73">Carregando...</segment>
    <segment id="74">Meus pais também deixaram os filhos escolherem com quem queriam</segment>
    <segment id="75">sese casar.</segment>
    <segment id="76">Meu casamento foi por amor</segment>
    <segment id="77">, não arranjado pelos pais.</segment>
    <segment id="78">Desde que me graduei em ciências da computação</segment>
    <segment id="79">, eu ficava chateada de ver a desigualdade no mercado de trabalho.</segment>
    <segment id="80">Então passei em um concurso público e novamente vi isso acontecer.</segment>
    <segment id="81">Nessa época</segment>
    <segment id="82">, o governo criou departamentos de gênero em cada organização e eu me tornei a chefe desse departamento.</segment>
    <segment id="83">E aí começou minha luta para convencer os homens a agir diferente e as mulheres de que elas tinham direitos.</segment>
    <segment id="84">Muitas não denunciavam casos de assédio ou violência</segment>
    <segment id="85">, por medo de sofrer retaliação.</segment>
    <segment id="86">A afegã Khatera Mohmand</segment>
    <segment id="87">, 38, combateu</segment>
    <segment id="88">, enquanto pôde</segment>
    <segment id="89">, a violência contra a mulher em seu paísMais    novamente         de   de  de  representando um</segment>
    <segment id="90">Quando o Talibã entrou em Cabul</segment>
    <segment id="91">, parecia um dia comum e eu fui trabalhar normalmente</segment>
    <segment id="92">, masmas o ambiente estava tenso.</segment>
    <segment id="93">Então uma amiga me ligou e me disse: "Khatera</segment>
    <segment id="94">, vai para casa.</segment>
    <segment id="95">Acabou".</segment>
    <segment id="96">Só consegui pegar meu laptop.</segment>
    <segment id="97">Olhei para o escritório e percebi que algo acabava ali</segment>
    <segment id="98">, especialmente para mim.</segment>
    <segment id="99">Foi um momento triste.</segment>
    <segment id="100">Meu marido já estava em casa com as crianças.</segment>
    <segment id="101">E assim ficamos por uns quatro ou cinco meses.</segment>
    <segment id="102">Eu não podia sair</segment>
    <segment id="103">, outras ativistas foram agredidas</segment>
    <segment id="104">, desapareceram.</segment>
    <segment id="105">Para piorar</segment>
    <segment id="106">, não tínhamos mais emprego</segment>
    <segment id="107">, salário.</segment>
    <segment id="108">Como poderíamos viver sem nenhuma renda?</segment>
    <segment id="109">Então decidimos migrar.</segment>
    <segment id="110">Quando você está em perigo</segment>
    <segment id="111">, começa a procurar</segment>
    <segment id="112">comocomo sair do país.</segment>
    <segment id="113">Minha família e eu entramos em contato com amigos e amigos de amigos ao redor do mundo</segment>
    <segment id="114">, até que soubemos que o Brasil era um país seguro e estava dando vistos para afegãos.</segment>
    <segment id="115">Então viemos.</segment>
    <segment id="116">Quando saí do avião</segment>
    <segment id="117">, percebi que todas as pessoas que estavam carimbando os passaportes na alfândega eram mulheres</segment>
    <segment id="118">, uma delas parecia ser a diretora de todos ali.</segment>
    <segment id="119">Enquanto esperávamos</segment>
    <segment id="120">, vi aquelas mulheres trabalhando</segment>
    <segment id="121">, interagindo.</segment>
    <segment id="122">Nesse momento eu já senti: sim</segment>
    <segment id="123">, o Brasil é um lugar que valoriza as mulheres.</segment>
    <segment id="124">Depois percebi que muitas mulheres</segment>
    <segment id="125">, como</segment>
    <segment id="126">como homens</segment>
    <segment id="127">, são responsáveis por suas famílias.</segment>
    <segment id="128">Elas trabalham</segment>
    <segment id="129">, dirigem.</segment>
    <segment id="130">Até dirigir é um problema no meu país.</segment>
    <segment id="131">Tudo isso me faz perceber que o Brasil tem igualdade de gênero.</segment>
    <segment id="132">Fico feliz por isso.</segment>
    <segment id="133">Mas tornar-</segment>
    <segment id="134">sese um refugiado é um enorme desafio.</segment>
    <segment id="135">Imagine ter que deixar sua casa</segment>
    <segment id="136">, o lugar onde você cresceu e tem um monte de memórias</segment>
    <segment id="137">, parentes</segment>
    <segment id="138">, amigos</segment>
    <segment id="139">, tudo.</segment>
    <segment id="140">E chegando você não sabe o idioma</segment>
    <segment id="141">, não consegue</segment>
    <segment id="142">sese comunicar nem para dizer que tem um problema</segment>
    <segment id="143">, para pedir ajuda.</segment>
    <segment id="144">Afeganistão um ano após a volta do Talibã ao poderMais    novamente         de   de  de  representando um  Nunca vou me esquecer do dia em que a professora da minha filha me disse algo em português</segment>
    <segment id="145">, gesticulando com o número dois.</segment>
    <segment id="146">Eu só acenei</segment>
    <segment id="147">, masmas não entendi.</segment>
    <segment id="148">Quando já estava em casa</segment>
    <segment id="149">, minha filha ligou chorando</segment>
    <segment id="150">, dizendo que estava sozinha com a professora</segment>
    <segment id="151">porque</segment>
    <segment id="152">porque ninguém tinha ido buscá-la.</segment>
    <segment id="153">O que a professora tinha me dito era para buscar as crianças mais cedo naquele dia</segment>
    <segment id="154">, às 14h</segment>
    <segment id="155">, não às 17h</segment>
    <segment id="156">, masmas eu não entendi.</segment>
    <segment id="157">Fiquei muito chateada.</segment>
    <segment id="158">Mas devagar estamos aprendendo português</segment>
    <segment id="159">, fazendo amigos</segment>
    <segment id="160">, tentando achar um trabalho.</segment>
    <segment id="161">Os brasileiros em geral não falam inglês</segment>
    <segment id="162">, masmas são pessoas boas e estão nos tratando muito bem</segment>
    <segment id="163">, sese esforçam para ajudar.</segment>
    <segment id="164">Não sabemos</segment>
    <segment id="165">comocomo será o futuro</segment>
    <segment id="166">, precisamos conseguir um emprego</segment>
    <segment id="167">, aprender o idioma.</segment>
    <segment id="168">Eu gosto do sotaque de vocês.</segment>
    <segment id="169">Tomara que um dia eu consiga dar essa entrevista em português.</segment>
    <segment id="170">A crise humanitária no AfeganistãoDados da ONU e do Afghanistan Protection Cluster24 milhões de afegãos precisam de ajuda humanitária urgente700 mil afegãos tiveram que</segment>
    <segment id="171">sese deslocar internamente devido a conflitos em 202198 países abrigam refugiados afegãos atualmente65% foi o aumento no número de solicitações de asilo por afegãos em 202155% da população afegã não tem comida suficiente90% das mulheres afegãs foram vítimas de algum tipo de violência de gênero8</segment>
    <segment id="172">,3% das afegãs com idade entre 20 e 24 anos</segment>
    <segment id="173">sese casaram antes dos 18</segment>
  </rst>
</analysis>