  <rst>
    <segment id="1">Em 25 anos de atuação</segment>
    <segment id="2">, instituições sem fins lucrativos gerenciam somente 2</segment>
    <segment id="3">,2% de toda a rede pública do SUS</segment>
    <segment id="4">, entre hospitais</segment>
    <segment id="5">, clínicas e postos de atendimento.</segment>
    <segment id="6">São Paulo concentra a maioria (58%) dessas entidades</segment>
    <segment id="7">, conhecidas</segment>
    <segment id="8">comocomo OSS (Organização Social de Saúde).</segment>
    <segment id="9">Na prática</segment>
    <segment id="10">, elas atuam</segment>
    <segment id="11">comocomo terceirizadas do poder público.</segment>
    <segment id="12">Os governos definem e planejam políticas a serem adotadas por organizações desse gênero</segment>
    <segment id="13">, obrigadas a seguir metas de produção e qualidade de atendimento.</segment>
    <segment id="14">Pronto atendimento do hospital Vila Nova Cachoeirinha - Rubens Cavallari - 16.dez.2022/FolhapressÉ a primeira vez que o setor</segment>
    <segment id="15">, representado pelo instituto Ibross</segment>
    <segment id="16">, faz um mapeamento de sua atividade no país.</segment>
    <segment id="17">O levantamento foi realizado em parceria com a Universidade Federal de Minas Gerais</segment>
    <segment id="18">, que cruzou dados da Fiocruz</segment>
    <segment id="19">, TCU (Tribunal de Contas da União)</segment>
    <segment id="20">, secretarias estaduais e municipais.</segment>
    <segment id="21">De acordo com o Ibross</segment>
    <segment id="22">, atualmente</segment>
    <segment id="23">, 1.874 unidades de atendimento da rede pública são geridas por 158 OSS</segment>
    <segment id="24">, que cobrem 270 municípios em 20 estados.</segment>
    <segment id="25">A maioria dos estabelecimentos está no Sudeste.</segment>
    <segment id="26">São Paulo concentra a maioria (1.101) e é seguido pelo Rio de Janeiro (360) e Minas Gerais (113).</segment>
    <segment id="27">Esse mercado é pouco pulverizado.</segment>
    <segment id="28">Do total de 158 organizações sociais</segment>
    <segment id="29">, 76 delas controlam um único estabelecimento de saúde</segment>
    <segment id="30">, enquanto 27 instituições comandam 1.335 unidades (81% do total).</segment>
    <segment id="31">A líder no setor é a SPDM (Associação Paulista para o Desenvolvimento da Medicina)</segment>
    <segment id="32">, que administra 387 unidades</segment>
    <segment id="33">, seguida pela Casa de Saúde Santa Marcelina</segment>
    <segment id="34">, com 111.</segment>
    <segment id="35">Os hospitais-dia (39%) e os hospitais especializados (18%) são os serviços mais administrados pelas organizações de saúde.</segment>
    <segment id="36">Unidades de pronto atendimento e pronto-socorro somam quase 40%.</segment>
    <segment id="37">Com Diego</segment>
    <segment id="38">Felix</segment>
  </rst>
</analysis>