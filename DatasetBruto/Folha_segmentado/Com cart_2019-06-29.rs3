  <rst>
    <segment id="1">Os super especialistas todos já contaram:</segment>
    <segment id="2">impossível não ser ex-ce-len-te o que sai das mãos de Alê D’Agostino</segment>
    <segment id="3">, responsável pelo bar do Spot por quase 18 anos.</segment>
    <segment id="4">É sempre ele o destaque quando</segment>
    <segment id="5">sese lê algo sobre o Apothek Cocktails &amp;amp</segment>
    <segment id="6">;</segment>
    <segment id="7">Co., aberto em 2017.</segment>
    <segment id="8">Pois bem.</segment>
    <segment id="9">Em 2019</segment>
    <segment id="10">, comemoremos: o que nasceu com objetivo de vender drinques engarrafados continua a servir</segment>
    <segment id="11">, no espaço de 17 metros quadrados</segment>
    <segment id="12">, os melhores coquetéis da cidade.</segment>
    <segment id="13">E como</segment>
    <segment id="14">como Alê já tem todos os elogios</segment>
    <segment id="15">, vamos aos cardápios do vencedor melhor bar da cidade</segment>
    <segment id="16">, segundo a escolha do júri.</segment>
    <segment id="17">Apothek é eleito melhor bar por júri de O Melhor de sãopauloÍcone seta para esquerdaÍcone seta para direita   novamenteÍcone seta para esquerda VoltarÍcone seta para cimaÍcone seta para baixoÍcone seta para esquerda Voltar       de  PinterestPinterestÍcone  de  de  representando um    Dentre as receitas clássicas e autorais</segment>
    <segment id="18">, servidas sempre em copo ideal e gelo perfeito</segment>
    <segment id="19">, a carta especial de negronis tem que ser explorada —mesmo</segment>
    <segment id="20">sese achar que não gosta de negroni</segment>
    <segment id="21">, pois</segment>
    <segment id="22">pois vai mudar de ideia.</segment>
    <segment id="23">O ótimo boulevardier (bourbon Bulleit</segment>
    <segment id="24">, vermute e amaro) é queridinho</segment>
    <segment id="25">, masmas o preferido da reportagem (após nove provados) foi o autoral smoked boulevardier</segment>
    <segment id="26">, acrescido de uísque Ardbeg.</segment>
    <segment id="27">O segundo lugar ficou com o saccharum (cachaça</segment>
    <segment id="28">, Bacardi 8</segment>
    <segment id="29">, Lucano e vermute).</segment>
    <segment id="30">Da outra carta de drinques</segment>
    <segment id="31">, aposte no old 23 (rum Zacapa</segment>
    <segment id="32">, Ardbeg</segment>
    <segment id="33">, Lillet Blanc</segment>
    <segment id="34">, amaro</segment>
    <segment id="35">, xarope de açúcar e twist de limão-siciliano).  Iluminação e música acompanham</segment>
    <segment id="36">, quase tão bem quanto as opções de comes.</segment>
    <segment id="37">O melhor conselho: não jante</segment>
    <segment id="38">, passeie por cada uma delas.</segment>
    <segment id="39">Se tiver sorte</segment>
    <segment id="40">, aproveite o que sai da cozinha e não está no menu.</segment>
    <segment id="41">Foi o caso</segment>
    <segment id="42">caso do pastel de pupunha com edamame (R$ 10)</segment>
    <segment id="43">, oferecido em bandeja até o segundo andar da casa</segment>
    <segment id="44">, onde funciona uma galeria e estão expostas as tentadoras garrafas.</segment>
    <segment id="45">BaresApothekDrinquesAlê</segment>
    <segment id="46">dAgostino liderou o bar do Spot por 18 anos.</segment>
    <segment id="47">Em 2015</segment>
    <segment id="48">, fundou uma empresa de drinques engarrafados nesse exíguo espaço</segment>
    <segment id="49">, embaixo de uma galeria em Pinheiros.</segment>
    <segment id="50">Nasceu assim um bar que abre só às segundas</segment>
    <segment id="51">, quintas e sextas.</segment>
    <segment id="52">Há criações e clássicos</segment>
    <segment id="53">, caso</segment>
    <segment id="54">caso do Tuxedo</segment>
    <segment id="55">, com gim</segment>
    <segment id="56">, xerez</segment>
    <segment id="57">, vermute e licor marasquino.</segment>
    <segment id="58">R. Oscar Freire</segment>
    <segment id="59">, 2.221 - Pinheiros</segment>
  </rst>
</analysis>