  <rst>
    <segment id="1">Ser sol e acender outros sóis.</segment>
    <segment id="2">É desta maneira que Thiago Jamelão define a faixa-título de seu EP de estreia</segment>
    <segment id="3">, SÓIS.</segment>
    <segment id="4">O maior astro do sistema solar aparece</segment>
    <segment id="5">comocomo uma alegoria para representar a busca por ser aquilo que almeja e</segment>
    <segment id="6">, principalmente</segment>
    <segment id="7">, como</segment>
    <segment id="8">como forma de inspirar outras pessoas.</segment>
    <segment id="9">Nesta terça-feira</segment>
    <segment id="10">, 8 de novembro</segment>
    <segment id="11">, a música ganha um videoclipe e vira esquenta para o show de lançamento do EP</segment>
    <segment id="12">, que o cantor e compositor realiza no dia 15 de novembro</segment>
    <segment id="13">, no Blue Note</segment>
    <segment id="14">, em São Paulo.</segment>
    <segment id="15">Thiago Jamelão em lançamento de &amp;#039</segment>
    <segment id="16">;Sóis&amp;#039</segment>
    <segment id="17">; - Pedro Lenehr</segment>
    <segment id="18">A vontade de motivar os outros por meio da faixa "SÓIS"</segment>
    <segment id="19">sese desdobrou em um registro audiovisual dirigido por Pedro Lenehr.</segment>
    <segment id="20">Gravado em uma ecovila —lugar em que as pessoas tem um estilo de vida sustentável—</segment>
    <segment id="21">, em Brasília</segment>
    <segment id="22">, o clipe faz alusão ao passado e ao presente</segment>
    <segment id="23">, mostrando em tela dois protagonistas</segment>
    <segment id="24">, sendo um dos personagens o próprio Jamelão.</segment>
    <segment id="25">"</segment>
    <segment id="26">As crianças são o nosso amanhã</segment>
    <segment id="27">, então nada melhor do que acender sóis e traduzir a esperança que a música aborda através delas"</segment>
    <segment id="28">, explica Thiago</segment>
    <segment id="29">, que completa: "</segment>
    <segment id="30">Enquanto cantava</segment>
    <segment id="31">, parecia que estava olhando e falando comigo".</segment>
    <segment id="32">Gravar em uma ecovila foi uma escolha muito consciente e integrada às convicções e princípios do cantor.</segment>
    <segment id="33">"</segment>
    <segment id="34">A gente vive uma situação em que a comida é algo difícil.</segment>
    <segment id="35">Estar ali</segment>
    <segment id="36">, colhendo</segment>
    <segment id="37">, compartilhando os alimentos e sorrisos</segment>
    <segment id="38">, expressa um pouco dos elementos que venho trabalhando no EP</segment>
    <segment id="39">, que é ser mais sensível e cuidadoso uns com outros"</segment>
    <segment id="40">, finaliza.</segment>
    <segment id="41">Além de "Sóis"</segment>
    <segment id="42">, o EP é composto por outras cinco faixas: "2000ealgumacoisa"</segment>
    <segment id="43">, "Morada"</segment>
    <segment id="44">, "</segment>
    <segment id="45">Diálogo sobre Vivência"</segment>
    <segment id="46">, "Beijando" e "Êlua".</segment>
    <segment id="47">Três destas canções são em parceria com Emicida.</segment>
    <segment id="48">A sua relação com o rapper paulistano</segment>
    <segment id="49">, inclusive</segment>
    <segment id="50">, vai além do processo criativo do EP SÓIS — lançado pela Laboratório Fantasma.</segment>
    <segment id="51">Jamelão integra a banda de Emicida e ainda assinou a preparação vocal do artista no álbum AmarElo (2019).</segment>
    <segment id="52">Lançamento do EP &amp;#</segment>
    <segment id="53">039;&amp;#039</segment>
    <segment id="54">;Sóis&amp;#039</segment>
    <segment id="55">;Quando 15 de novembroOnde</segment>
    <segment id="56">Blue Note São Paulo: Avenida Paulista</segment>
    <segment id="57">, 2073 - 2º Andar</segment>
    <segment id="58">, Consolação</segment>
    <segment id="59">, região centralPreço A partir de R$90 + taxasLink: https://www.eventim.com.br/artist/novacena-joysales-thiagojamelao/</segment>
  </rst>
</analysis>