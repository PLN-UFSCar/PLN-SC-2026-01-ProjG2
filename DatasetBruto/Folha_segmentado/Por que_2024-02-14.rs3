  <rst>
    <segment id="1">É sério</segment>
    <segment id="2">, tenho o livro aqui.</segment>
    <segment id="3">Bárbara Bulhosa</segment>
    <segment id="4">sese levanta e some pela porta de uma das salas do escritório da editora Tinta-da-China</segment>
    <segment id="5">, em Lisboa.</segment>
    <segment id="6">Menos de um minuto depois</segment>
    <segment id="7">, a diretora da casa editorial portuguesa reaparece com uma edição lusitana de "</segment>
    <segment id="8">O Menino Maluquinho"</segment>
    <segment id="9">, o clássico de Ziraldo</segment>
    <segment id="10">, lançada no país em 1995.</segment>
    <segment id="11">A estranheza já está no título</segment>
    <segment id="12">, que virou "</segment>
    <segment id="13">As Maluquices do Menino Maluquinho".</segment>
    <segment id="14">O texto tampouco é igual.</segment>
    <segment id="15">Enquanto o original começa só com "era uma vez um menino maluquinho"</segment>
    <segment id="16">, a versão publicada na época pela editora Dinapress diz que "era uma vez um menino maluquinho</segment>
    <segment id="17">, travesso até mais não".</segment>
    <segment id="18">Mais adiante</segment>
    <segment id="19">, o uirapuru brasileiro com o qual o protagonista é comparado</segment>
    <segment id="20">sese torna um rouxinol.</segment>
    <segment id="21">E, na alteração mais gritante e nonsense</segment>
    <segment id="22">, o Saci</segment>
    <segment id="23">, outra figura com quem Maluquinho é comparado</segment>
    <segment id="24">, é chamado de espantalho.</segment>
    <segment id="25">Trecho de edição de 1980 de &amp;#039</segment>
    <segment id="26">;O Menino Maluquinho&amp;#039</segment>
    <segment id="27">;, de Ziraldo</segment>
    <segment id="28">, da editora Melhoramentos</segment>
    <segment id="29">, em que o protagonista é comparado a um Saci - Reprodução"São intervenções inúteis.</segment>
    <segment id="30">As crianças portuguesas chegam ao Ziraldo privadas de seu ritmo e de sua dimensão literária"</segment>
    <segment id="31">, diz Bulhosa.</segment>
    <segment id="32">"</segment>
    <segment id="33">Ele está a fazer um Saci</segment>
    <segment id="34">, não um espantalho.</segment>
    <segment id="35">Parece que nós somos burros para perceber isso.</segment>
    <segment id="36">"</segment>
    <segment id="37">À primeira vista</segment>
    <segment id="38">, os cortes e intromissões podem soar</segment>
    <segment id="39">comocomo mais uma das anedotas que rondam as relações entre Brasil e Portugal.</segment>
    <segment id="40">Mas são sintomas de algo mais profundo.</segment>
    <segment id="41">Historicamente</segment>
    <segment id="42">, a literatura infantojuvenil brasileira enfrenta diversas dificuldades para ser publicada no país europeu</segment>
    <segment id="43">, mesmo compartilhando um idioma comum.</segment>
    <segment id="44">E, ao ser lançada além-mar</segment>
    <segment id="45">, quase sempre tem seu texto adaptado para eliminar as marcas do português falado no Brasil.</segment>
    <segment id="46">Personagens de ZiraldoMais    novamente         de   de  de  representando um  Na avaliação de Gustavo de Sá</segment>
    <segment id="47">, chefe do setor cultural da embaixada brasileira em Lisboa</segment>
    <segment id="48">, a questão é a língua.</segment>
    <segment id="49">"</segment>
    <segment id="50">É como</segment>
    <segment id="51">como se</segment>
    <segment id="52">se publicar os livros no original fosse uma ofensa</segment>
    <segment id="53">, uma ameaça à integridade linguística das crianças portuguesas</segment>
    <segment id="54">, que precisam ser protegidas do português ‘errado’ do Brasil.</segment>
    <segment id="55">"  Para tentar preencher esse vácuo</segment>
    <segment id="56">, a Tinta-da-China lançou no ano passado a coleção Pererê</segment>
    <segment id="57">, que leva às livrarias lusitanas dez clássicos brasileiros para a infância.</segment>
    <segment id="58">Entre as publicações</segment>
    <segment id="59">, que têm texto original e nenhuma adaptação</segment>
    <segment id="60">, estão o próprio "</segment>
    <segment id="61">O Menino Maluquinho" e títulos</segment>
    <segment id="62">comocomo "</segment>
    <segment id="63">Marcelo</segment>
    <segment id="64">, Marmelo Martelo"</segment>
    <segment id="65">, de Ruth Rocha</segment>
    <segment id="66">, "Reinações de Narizinho</segment>
    <segment id="67">"</segment>
    <segment id="68">, de Monteiro Lobato</segment>
    <segment id="69">, e "</segment>
    <segment id="70">A Arca de Noé"</segment>
    <segment id="71">, de Vinicius de Moraes</segment>
    <segment id="72">, por exemplo.</segment>
    <segment id="73">Os 10 livros da Pererê‘A Arca de Noé’Vinicius de Moraes</segment>
    <segment id="74">; ilus.</segment>
    <segment id="75">:</segment>
    <segment id="76">Joana Estrela‘Bisa Bia</segment>
    <segment id="77">, Bisa Bel’Ana Maria Machado</segment>
    <segment id="78">; ilus.</segment>
    <segment id="79">:</segment>
    <segment id="80">João Fazenda‘A Bolsa Amarela’Lygia Bojunga</segment>
    <segment id="81">; ilus.</segment>
    <segment id="82">: Marie Louise Nery‘Chapeuzinho Amarelo’Chico</segment>
    <segment id="83">Buarque</segment>
    <segment id="84">; ilus.</segment>
    <segment id="85">:</segment>
    <segment id="86">André Letria‘Doze Reis e a Moça no Labirinto do Vento’Marina Colasanti‘Flicts’ e ‘</segment>
    <segment id="87">O Menino Maluquinho’Ziraldo‘História de Dois Amores’ Carlos Drummond de Andrade e Ziraldo‘Marcelo</segment>
    <segment id="88">, Marmelo</segment>
    <segment id="89">, Martelo’Ruth Rocha</segment>
    <segment id="90">; ilus.</segment>
    <segment id="91">:</segment>
    <segment id="92">Raquel Costa‘Reinações de Narizinho’Monteiro Lobato</segment>
    <segment id="93">; ilus.</segment>
    <segment id="94">: André LeBlancEditada com apoio da embaixada e do Instituto Guimarães Rosa</segment>
    <segment id="95">, órgão ligado ao Itamaraty para promover a cultura brasileira</segment>
    <segment id="96">, a série apresenta obras que nunca tinham atravessado o Atlântico</segment>
    <segment id="97">, algumas delas com novo projeto gráfico e ilustrações feitas por artistas portugueses contemporâneos.</segment>
    <segment id="98">"</segment>
    <segment id="99">Para além de ser uma coleção literária</segment>
    <segment id="100">, é uma coleção política</segment>
    <segment id="101">, no sentido de política da língua"</segment>
    <segment id="102">, afirma Bulhosa.</segment>
    <segment id="103">"</segment>
    <segment id="104">Hoje temos muitas crianças brasileiras em Portugal</segment>
    <segment id="105">, e elas muitas vezes são discriminadas nas escolas até pelos professores</segment>
    <segment id="106">, que dizem que elas falam errado e não sabem escrever bem em português.</segment>
    <segment id="107">"</segment>
    <segment id="108">Conheça 5 livros esquecidos de Monteiro LobatoMais    novamente         de   de  de  representando um  Atualmente</segment>
    <segment id="109">, cerca de 400 mil brasileiros vivem legalmente no país —o número total é bem maior</segment>
    <segment id="110">, já que a cifra não considera quem está em situação irregular ou tem dupla nacionalidade.</segment>
    <segment id="111">O aumento recente da imigração fez com que crescessem também os casos de xenofobia e de violência.</segment>
    <segment id="112">Segundo dados da Comissão para a Igualdade e Contra a Discriminação Racial portuguesa</segment>
    <segment id="113">, 34% das denúncias de discriminação feitas no país em 2022</segment>
    <segment id="114">, último ano do estudo</segment>
    <segment id="115">, ocorreram devido à nacionalidade brasileira.</segment>
    <segment id="116">Casos de xenofobia contra brasileiros em PortugalMais    novamente         de   de  de  representando um</segment>
    <segment id="117">Embora a produção literária infantojuvenil do Brasil não conte com muito prestígio na terra de Camões e Pessoa</segment>
    <segment id="118">, seus autores e ilustradores estão entre os mais premiados do mundo e</segment>
    <segment id="119">sese tornaram os mais reconhecidos da língua portuguesa no plano internacional para crianças e jovens.</segment>
    <segment id="120">Lygia Bojunga</segment>
    <segment id="121">, Ana Maria Machado e Roger Mello venceram o Hans Christian Andersen</segment>
    <segment id="122">, considerado o Nobel para esse público.</segment>
    <segment id="123">Neste ano</segment>
    <segment id="124">, Marina Colasanti e Nelson Cruz são finalistas do troféu</segment>
    <segment id="125">, tornando o Brasil o único país com dois indicados.</segment>
    <segment id="126">Além disso</segment>
    <segment id="127">, Bojunga ganhou ainda o Alma</segment>
    <segment id="128">, sigla do Astrid Lindgren Memorial Award</segment>
    <segment id="129">, outro dos reconhecimentos internacionais mais importantes.</segment>
    <segment id="130">Nenhum autor português ou mesmo africano ou asiático de língua portuguesa venceu esses prêmios.</segment>
    <segment id="131">Obras de Lygia BojungaMais    novamente         de   de  de  representando um  "</segment>
    <segment id="132">É por isso que as lacunas impressionam</segment>
    <segment id="133">, porque</segment>
    <segment id="134">porque é uma produção reconhecida"</segment>
    <segment id="135">, diz Sá</segment>
    <segment id="136">, da embaixada brasileira.</segment>
    <segment id="137">"</segment>
    <segment id="138">Mas já ouvi pais portugueses dizerem</segment>
    <segment id="139">, por exemplo</segment>
    <segment id="140">, que preferem não expor seus filhos em idade escolar ao português do Brasil.</segment>
    <segment id="141">"  Segundo ele</segment>
    <segment id="142">, é isso o que fez Ana Maria Machado e Lygia Bojunga só terem ganhado edições pontuais em Portugal e o que mantém nas sombras nomes</segment>
    <segment id="143">comocomo Marina Colasanti</segment>
    <segment id="144">, Ruth Rocha</segment>
    <segment id="145">, Pedro Bandeira</segment>
    <segment id="146">, Roger Mello ou Nelson Cruz.</segment>
    <segment id="147">"</segment>
    <segment id="148">Tenho oito livros publicados na China e mais quatro em produção.</segment>
    <segment id="149">Mas nenhum em Portugal"</segment>
    <segment id="150">, conta Roger Mello</segment>
    <segment id="151">, indicado ao prêmio Alma deste ano.</segment>
    <segment id="152">"</segment>
    <segment id="153">Acho que o eurocentrismo</segment>
    <segment id="154">sese manifesta mais nos livros para crianças.</segment>
    <segment id="155">Não só em Portugal</segment>
    <segment id="156">, masmas em toda a Europa.</segment>
    <segment id="157">É como</segment>
    <segment id="158">como se</segment>
    <segment id="159">se tentassem passar a literatura dos outros países por um filtro.</segment>
    <segment id="160">"</segment>
    <segment id="161">Tudo a lerReceba no seu email uma seleção com lançamentos</segment>
    <segment id="162">, clássicos e curiosidades literáriasCarregando...</segment>
    <segment id="163">É possível argumentar que o contrário também poderia ser verdade.</segment>
    <segment id="164">Afinal</segment>
    <segment id="165">, a literatura portuguesa tampouco costumava chegar ao Brasil.</segment>
    <segment id="166">Só que esse cenário vem mudando.</segment>
    <segment id="167">Um levantamento feito por Tainá Amado em seu mestrado na Universidade de Aveiro</segment>
    <segment id="168">, em Portugal</segment>
    <segment id="169">, contabilizou quantas obras infantojuvenis de autores brasileiros foram lançadas por editoras portuguesas de 2009 a 2018 e quantos títulos lusitanos fizeram o caminho inverso nesses mesmos dez anos.</segment>
    <segment id="170">Enquanto apenas 36 livros brasileiros cruzaram o oceano</segment>
    <segment id="171">, 109 publicações portuguesas para crianças e jovens ganharam edições no Brasil.</segment>
    <segment id="172">Ao entrar na seção infantil de qualquer livraria portuguesa</segment>
    <segment id="173">, notamos esse abismo.</segment>
    <segment id="174">As prateleiras geralmente estão abarrotadas de nomes estrangeiros</segment>
    <segment id="175">, com até mais britânicos</segment>
    <segment id="176">, espanhóis</segment>
    <segment id="177">, franceses</segment>
    <segment id="178">, americanos e sul-coreanos do que propriamente portugueses.</segment>
    <segment id="179">Só que é raríssimo encontrar brasileiros</segment>
    <segment id="180">, angolanos ou moçambicanos.</segment>
    <segment id="181">Roteiro literário no norte de PortugalMais    novamente         de   de  de  representando um</segment>
    <segment id="182">A professora Ana Margarida Ramos</segment>
    <segment id="183">, que orientou a pesquisa de Amado e é especializada em literatura infantojuvenil e livro ilustrado</segment>
    <segment id="184">, confirma que escritores</segment>
    <segment id="185">, ilustradores e obras fundamentais da literatura infantojuvenil brasileira continuam ignorados em Portugal.</segment>
    <segment id="186">Mas diz enxergar outras causas para isso.</segment>
    <segment id="187">"</segment>
    <segment id="188">A mesma língua que nos aproxima também nos distancia"</segment>
    <segment id="189">, afirma.</segment>
    <segment id="190">"</segment>
    <segment id="191">Mas não me parece que a distância seja por falta de interesse do público.</segment>
    <segment id="192">Há outros elementos que interferem no circuito do livro.</segment>
    <segment id="193">"</segment>
    <segment id="194">De acordo com ela</segment>
    <segment id="195">, editores brasileiros não investem tanto na divulgação dos lançamentos em Portugal</segment>
    <segment id="196">, talvez por considerarem o mercado editorial pequeno.</segment>
    <segment id="197">Além disso</segment>
    <segment id="198">, ela lembra</segment>
    <segment id="199">comocomo fatores de desequilíbrio os entraves alfandegários e um maior apoio do governo português do que do brasileiro na internacionalização dos catálogos</segment>
    <segment id="200">, sobretudo nos últimos anos.</segment>
    <segment id="201">Ruth Rocha e Ana Maria Machado fazem 50 anos de carreiraMais    novamente         de   de  de  representando um  "</segment>
    <segment id="202">Na minha percepção</segment>
    <segment id="203">, não estou a ver o português falado no Brasil</segment>
    <segment id="204">comocomo problema ou obstáculo</segment>
    <segment id="205">, masmas</segment>
    <segment id="206">, sim, os mecanismos de promoção da produção no exterior"</segment>
    <segment id="207">, conta.</segment>
    <segment id="208">Ao ser questionada sobre as vendas da coleção</segment>
    <segment id="209">Pererê em Portugal</segment>
    <segment id="210">, Bárbara Bulhosa faz uma pausa e responde que não divulga números</segment>
    <segment id="211">, masmas que estão abaixo do esperado.</segment>
    <segment id="212">"</segment>
    <segment id="213">Deveriam estar a vender muito mais pela qualidade que têm.</segment>
    <segment id="214">Há uma resistência".</segment>
    <segment id="215">Veja livros lançados por Ana Maria Machado na pandemiaMais    novamente         de   de  de  representando um</segment>
  </rst>
</analysis>