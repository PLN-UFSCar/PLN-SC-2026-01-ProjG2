  <rst>
    <segment id="1">Ingrediente aromático e valioso para a indústria dos cosméticos</segment>
    <segment id="2">, o óleo de breu branco já era um velho conhecido das comunidades da RDS (Reserva de Desenvolvimento Sustentável) Uatumã</segment>
    <segment id="3">, que fica a cerca de 330 km de Manaus.</segment>
    <segment id="4">Mas foi há dois anos que o investimento em uma usina para produção do óleo alavancou o potencial econômico.</segment>
    <segment id="5">Sempre que sofre uma perfuração</segment>
    <segment id="6">, a árvore breu branco evita a invasão por insetos ao liberar uma resina de mesmo nome</segment>
    <segment id="7">, que depois endurece sobre sua casca.</segment>
    <segment id="8">Resina de breu</segment>
    <segment id="9">, raspada da casca da árvore</segment>
    <segment id="10">, antes do beneficiamento</segment>
    <segment id="11">; passo seguinte é extração do óleo essencial - Fred Rahal/Idesam"Em 2019</segment>
    <segment id="12">, extraíamos a resina da árvore e vendíamos a R$ 2</segment>
    <segment id="13">,50 o quilo.</segment>
    <segment id="14">Hoje produzimos o óleo essencial na usina e vendemos por R$ 1.300 o litro"</segment>
    <segment id="15">, diz Vanderley Cruz</segment>
    <segment id="16">, gestor da usina de óleos da RDS Uatumã</segment>
    <segment id="17">, que foi construída com recursos do Fundo Amazônia.</segment>
    <segment id="18">Ele diz que 400 kg de resina rendem 2</segment>
    <segment id="19">,5 litros de óleo.</segment>
    <segment id="20">"Fui o primeiro comprador</segment>
    <segment id="21">, ajudei no início com consultorias</segment>
    <segment id="22">, masmas hoje não consigo comprar</segment>
    <segment id="23">, porque</segment>
    <segment id="24">porque eles têm muita demanda"</segment>
    <segment id="25">, afirma Domingos Amaral Neto</segment>
    <segment id="26">, diretor da Biozer da Amazônia</segment>
    <segment id="27">, que desenvolve cosméticos naturais e fitoterápicos.</segment>
    <segment id="28">A Biozer também recebeu apoio graças a recursos de P&amp;amp</segment>
    <segment id="29">;D (pesquisa e desenvolvimento) destinados por uma fabricante de eletrônicos da Zona Franca de Manaus</segment>
    <segment id="30">, que tem participação nos lucros.</segment>
    <segment id="31">O direcionamento de investimentos para a bioeconomia é feito através do PPBio (Programa Prioritário de Bioeconomia).</segment>
    <segment id="32">É uma opção criada pela Suframa (Superintendência da Zona Franca de Manaus) para o investimento obrigatório que as empresas devem fazer em P&amp;amp</segment>
    <segment id="33">;D.</segment>
    <segment id="34">O valor deve corresponder a</segment>
    <segment id="35">, no mínimo</segment>
    <segment id="36">, 5% do faturamento</segment>
    <segment id="37">comocomo contrapartida aos benefícios tributários.</segment>
    <segment id="38">Entre 2019 e 2022</segment>
    <segment id="39">, o programa arrecadou R$ 91</segment>
    <segment id="40">,6 milhões de 33 empresas.</segment>
    <segment id="41">Mas convencer os negócios da Zona Franca de Manaus —majoritariamente voltados ao setor tecnológico— a investir na floresta ainda é um desafio.  "</segment>
    <segment id="42">O primeiro objetivo dessa política de P&amp;amp</segment>
    <segment id="43">;D é dar autonomia técnica para a empresa aumentar a competitividade e permanecer na região.</segment>
    <segment id="44">Por isso a gente não impõe</segment>
    <segment id="45">, masmas busca dar os incentivos corretos para a própria empresa investir nessas áreas"</segment>
    <segment id="46">, diz Rafael Gouveia</segment>
    <segment id="47">, coordenador de gestão tecnológica da Suframa.</segment>
    <segment id="48">A tarefa de construir parcerias com empreendedores</segment>
    <segment id="49">, comunidades e pesquisadores fica por conta do Idesam (Instituto de Conservação e Desenvolvimento Sustentável da Amazônia)</segment>
    <segment id="50">, que coordena o PPBio desde 2019.</segment>
    <segment id="51">No início do ano</segment>
    <segment id="52">, a ONG promoveu uma expedição à RDS Uatumã reunindo investidores</segment>
    <segment id="53">, empreendedores</segment>
    <segment id="54">, instituições de tecnologia e inovação e comunidades da reserva.</segment>
    <segment id="55">"</segment>
    <segment id="56">Cerca de 99% das empresas investem em P&amp;amp</segment>
    <segment id="57">;D visando economizar nos processos</segment>
    <segment id="58">, gastar menos</segment>
    <segment id="59">, masmas é possível pensar</segment>
    <segment id="60">comocomo soluções tecnológicas voltadas para uma empresa lá na Zona Franca</segment>
    <segment id="61">podem servir aqui na comunidade"</segment>
    <segment id="62">, afirma André Machado</segment>
    <segment id="63">, diretor do instituto de tecnologia Creathus.</segment>
    <segment id="64">Bioeconomia avança em comunidades florestais do AmazonasMais    novamente         de   de  de  representando um</segment>
    <segment id="65">Por outro lado</segment>
    <segment id="66">, a tecnologia esbarra nas dificuldades de acesso.</segment>
    <segment id="67">Em conversa com pesquisadores e empreendedores</segment>
    <segment id="68">, líderes comunitários de Uatumã afirmaram que falta conhecimento sobre os desafios na floresta</segment>
    <segment id="69">, como</segment>
    <segment id="70">como a falta de internet e de eletricidade.  "</segment>
    <segment id="71">Diversas parcerias acabam não prosperando</segment>
    <segment id="72">porque</segment>
    <segment id="73">porque não contam com o fato de que não temos internet 5</segment>
    <segment id="74">G para rodar um sistema</segment>
    <segment id="75">"</segment>
    <segment id="76">,</segment>
    <segment id="77">diz Cruz.</segment>
    <segment id="78">Embora seja atravessada pelo linhão de Tucuruí</segment>
    <segment id="79">, que transmite energia elétrica a Manaus</segment>
    <segment id="80">, a região não integra o Sistema Interligado de Energia e depende do diesel para a geração energética.</segment>
    <segment id="81">"</segment>
    <segment id="82">Estamos estudando junto à iniciativa privada</segment>
    <segment id="83">comocomo levar gás natural através de barcaças a algumas regiões</segment>
    <segment id="84">para que</segment>
    <segment id="85">para que os sistemas isolados também tenham essa matriz limpa"</segment>
    <segment id="86">, afirmou o governador Wilson Lima (União Brasil)</segment>
    <segment id="87">, em visita à RDS Uatumã para a entrega de kits de energia solar.</segment>
    <segment id="88">Lima disse que prevê combinar o uso de energia solar</segment>
    <segment id="89">, fonte renovável</segment>
    <segment id="90">, e gás (de origem fóssil) em um programa de mudança da matriz energética do estado.</segment>
    <segment id="91">Questionado sobre a vantagem do gás em relação à energia solar para sistemas isolados</segment>
    <segment id="92">, o governador disse que "o gás tem maior eficiência e precisa de volume menor</segment>
    <segment id="93">, enquanto a energia solar precisa de área muito maior".</segment>
    <segment id="94">Outro desafio é garantir volume e escala para os produtos que mantêm a floresta em pé.  "</segment>
    <segment id="95">Com a cadeia ainda pulverizada</segment>
    <segment id="96">, o preço da polpa de tucumã oscilou no ano passado entre R$ 30 e R$ 130 reais o quilo.</segment>
    <segment id="97">Nenhuma indústria sobrevive com essa oscilação"</segment>
    <segment id="98">, diz o chef Beto Pinto</segment>
    <segment id="99">, sócio da Smart Food</segment>
    <segment id="100">, que produz hambúrgueres de tucumã.</segment>
    <segment id="101">Popular na região</segment>
    <segment id="102">, o fruto amazônico é usado em lanches</segment>
    <segment id="103">comocomo o X-caboquinho.</segment>
    <segment id="104">A textura da polpa</segment>
    <segment id="105">, alaranjada</segment>
    <segment id="106">, lembra coco.</segment>
    <segment id="107">"</segment>
    <segment id="108">Quem vem para cá adora</segment>
    <segment id="109">, masmas ele não sai daqui.</segment>
    <segment id="110">O açaí já está no mundo inteiro</segment>
    <segment id="111">, então queremos levar o tucumã"</segment>
    <segment id="112">, afirma o chef.</segment>
    <segment id="113">A Smart Food tem 32 pontos de venda em oito estados</segment>
    <segment id="114">, masmas Pinto diz não querer expandir o negócio a qualquer custo.</segment>
    <segment id="115">"Tem que ser bom para a comunidade</segment>
    <segment id="116">, para o empreendedor e para o consumidor.</segment>
    <segment id="117">Se alguém não estiver feliz</segment>
    <segment id="118">, não é sociobiodiversidade.</segment>
    <segment id="119">"</segment>
    <segment id="120">Exploração de madeira nas proximidades da comunidade de Cachoeira do Aruã (PA)Mais    novamente         de   de  de  representando um  Um dos desejos do comunitário Gracilazo Miranda era continuar trabalhando com madeira.</segment>
    <segment id="121">"</segment>
    <segment id="122">Tinha as máquinas</segment>
    <segment id="123">, masmas sem documentação</segment>
    <segment id="124">, andava escondido.</segment>
    <segment id="125">Agora trabalho de cabeça erguida.</segment>
    <segment id="126">"</segment>
    <segment id="127">Hoje ele é manejador e gestor da movelaria de Uatumã</segment>
    <segment id="128">, que produz peças encomendadas por designers de renome.</segment>
    <segment id="129">"</segment>
    <segment id="130">Antes era entrar numa mata</segment>
    <segment id="131">, derrubar 20</segment>
    <segment id="132">, 30 árvores</segment>
    <segment id="133">, cortar em prancha</segment>
    <segment id="134">, levar para o atravessador"</segment>
    <segment id="135">, lembra.</segment>
    <segment id="136">"</segment>
    <segment id="137">Hoje não</segment>
    <segment id="138">, a gente faz plano de manejo florestal</segment>
    <segment id="139">, tudo licenciado.</segment>
    <segment id="140">Se você me perguntar de onde saiu a madeira de uma peça</segment>
    <segment id="141">, eu te levo até a árvore.</segment>
    <segment id="142">"</segment>
    <segment id="143">A reserva mantém a produção de alimentos em sistemas agroflorestais e ainda administra uma pousada.</segment>
    <segment id="144">"</segment>
    <segment id="145">É um sonho</segment>
    <segment id="146">, para fortalecer os vínculos familiares e com a comunidade</segment>
    <segment id="147">, para que</segment>
    <segment id="148">para que meus filhos não precisem sair por aí em busca de salário.</segment>
    <segment id="149">Se eu quero um mundo melhor</segment>
    <segment id="150">, é porque</segment>
    <segment id="151">porque estou neste mundo"</segment>
    <segment id="152">, afirma Elizangela Cavalcante</segment>
    <segment id="153">, gestora da movelaria e uma das lideranças da reserva.</segment>
    <segment id="154">A repórter viajou a convite do Idesam (Instituto de Conservação e Desenvolvimento Sustentável da Amazônia)</segment>
  </rst>
</analysis>