  <rst>
    <segment id="1">O nadador cubano Yunerki Ortega</segment>
    <segment id="2">, que participou dos Jogos Parapan-Americanos de Santiago-2023</segment>
    <segment id="3">, deixou a vila dos atletas para pedir refúgio no Chile</segment>
    <segment id="4">, sese juntando a outros sete atletas da ilha que também querem permanecer no país</segment>
    <segment id="5">, informou seu advogado nesta segunda-feira (20).  Ortega</segment>
    <segment id="6">, um atleta cego de 33 anos que competiu no sábado nos 50 metros livres</segment>
    <segment id="7">, apresentará em breve seu pedido de refúgio às autoridades chilenas</segment>
    <segment id="8">, disse à AFP seu representante legal</segment>
    <segment id="9">, Mijail Bonito</segment>
    <segment id="10">, sem dar mais detalhes.</segment>
    <segment id="11">A delegação cubana havia denunciado à polícia o desaparecimento de Ortega</segment>
    <segment id="12">, depois que o nadador deixou a Vila Parapan-Americana com seus pertences.</segment>
    <segment id="13">Nadador cubano</segment>
    <segment id="14">Yunerki Ortega em imagem publicada em sua rede social - Reprodução:</segment>
    <segment id="15">Facebook</segment>
    <segment id="16">O caso</segment>
    <segment id="17">caso se</segment>
    <segment id="18">se soma ao de sete cubanos que não retornaram ao seu país após participarem dos últimos Jogos Pan-Americanos.</segment>
    <segment id="19">Os atletas estão no Chile esperando que o governo chileno lhes conceda refúgio.</segment>
    <segment id="20">O advogado Bonito também representa as seis jogadoras da seleção cubana feminina de hóquei sobre grama e o atleta Yoao Illas</segment>
    <segment id="21">, que obteve a medalha de bronze nos 400 metros com barreiras masculino em Santiago-2023.</segment>
    <segment id="22">Apesar das perdas de atletas de elite</segment>
    <segment id="23">, Cuba encerrou sua participação no top-5 do quadro de medalhas do Pan de Santiago-2023</segment>
    <segment id="24">, atrás de Estados Unidos</segment>
    <segment id="25">, Brasil</segment>
    <segment id="26">, México e Canadá.</segment>
    <segment id="27">Segundo dados oficiais cubanos</segment>
    <segment id="28">, de 2022 até hoje</segment>
    <segment id="29">, migraram quase 200 atletas cubanos de alto rendimento</segment>
    <segment id="30">, entre eles mais de dez boxeadores</segment>
    <segment id="31">, incluindo o astro Andy Cruz</segment>
    <segment id="32">, considerado por muitos o maior boxeador do país.</segment>
  </rst>
</analysis>