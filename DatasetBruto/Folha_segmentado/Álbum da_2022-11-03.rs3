  <rst>
    <segment id="1">Estádio Vélodrome</segment>
    <segment id="2">, Marselha.</segment>
    <segment id="3">Em campo</segment>
    <segment id="4">, o Olympique recebia o Tottenham</segment>
    <segment id="5">, da Inglaterra</segment>
    <segment id="6">, em jogo da Champions League.</segment>
    <segment id="7">Aos 23 minutos do primeiro tempo</segment>
    <segment id="8">, o atacante Son disputou a bola com o intrépido Mbemba</segment>
    <segment id="9">, bateu o rosto no ombro do amiguinho e caiu no gramado</segment>
    <segment id="10">, tonto.</segment>
    <segment id="11">Foi substituído</segment>
    <segment id="12">, e parecia que ganharia apenas um olho roxo.</segment>
    <segment id="13">No entanto</segment>
    <segment id="14">, foi divulgado que Son precisará fazer uma cirurgia para estabilizar uma fratura em volta do olho esquerdo.</segment>
    <segment id="15">Assim, a torcida sul-coreana vive momentos de angústia com a possibilidade de perder seu principal jogador para a Copa do Mundo</segment>
    <segment id="16">, ou, como</segment>
    <segment id="17">como diria o Galvão coreano</segment>
    <segment id="18">, "vive um k-drrrrama a torcida sul-coreana".</segment>
    <segment id="19">Caso o ótimo atacante não</segment>
    <segment id="20">sese recupere a tempo</segment>
    <segment id="21">, o álbum da Copa terá mais um desfalque</segment>
    <segment id="22">, a KOR 19.</segment>
    <segment id="23">Son é atendido após sofrer fratura no rosto - Eric Gaillard/ReutersDe acordo com uma não pesquisa do DataMacedo</segment>
    <segment id="24">, esta deve ser a Copa com o maior número de desfalques por contusão —margem de erro beira os 100%.</segment>
    <segment id="25">Em outros tempos considerada uma das principais candidatas ao título</segment>
    <segment id="26">, a seleção francesa chega sob desconfiança justamente pelos desfalques.</segment>
    <segment id="27">Pogba está fora</segment>
    <segment id="28">, assim</segment>
    <segment id="29">comocomo Kanté.</segment>
    <segment id="30">Ambos passaram por cirurgias e só voltam em 2023.</segment>
    <segment id="31">Recentemente foi a vez de o zagueiro Varane deixar o campo chorando depois de uma lesão na coxa em jogo do Manchester United.</segment>
    <segment id="32">O time inglês informou que ele não atua mais pelo clube neste ano</segment>
    <segment id="33">, e agora o jogador tenta convencer Didier Deschamps de que pode</segment>
    <segment id="34">sese recuperar e ser convocado.</segment>
    <segment id="35">Em comum</segment>
    <segment id="36">, Pogba</segment>
    <segment id="37">, Kanté e Varane foram titulares da final de 2018 —e também estão lado a lado no álbum</segment>
    <segment id="38">, FRA 10</segment>
    <segment id="39">, FRA 11 e FRA 12…</segment>
    <segment id="40">Pode jogar essa página fora.</segment>
    <segment id="41">E tem mais:</segment>
    <segment id="42">Wijnaldum</segment>
    <segment id="43">, o NED 15</segment>
    <segment id="44">, meio-campista holandês da Roma</segment>
    <segment id="45">, teve fratura na tíbia e só volta no ano que vem</segment>
    <segment id="46">; o atacante português do Liverpool Diogo Jota (POR 19) tem uma lesão muscular séria e também já foi descartado para o torneio no Qatar</segment>
    <segment id="47">;</segment>
    <segment id="48">os ingleses do Manchester City</segment>
    <segment id="49">, e normalmente titulares da seleção</segment>
    <segment id="50">, Kyle Walker (ENG 10) e Kalvin Phillips (ENG 15) estão em fase final de recuperação</segment>
    <segment id="51">, masmas chegariam fora de ritmo para um campeonato de tiro curtíssimo.</segment>
    <segment id="52">Sem falar nos ótimos laterais Reece James e Ben Chilwell…</segment>
    <segment id="53">O quê?</segment>
    <segment id="54">James e Chilwell não estão no álbum da Copa?</segment>
    <segment id="55">Bem, perde o álbum da Copa.</segment>
    <segment id="56">Veja a produção das figurinhas do álbum da Copa do Mundo de 2022Mais    novamente         de   de  de  representando um  Na turma</segment>
    <segment id="57">"correndo contra o tempo" a lista inclui os argentinos Di Maria (ARG 11) e Dybala...</segment>
    <segment id="58">Dybala também não está no álbum?</segment>
    <segment id="59">Quem escolheu essas figurinhas?</segment>
    <segment id="60">Meu Deus.</segment>
    <segment id="61">No Brasil</segment>
    <segment id="62">, nossa parcela de drama aconteceu com Richarlison</segment>
    <segment id="63">, o estimado BRA 19</segment>
    <segment id="64">, que joga justamente na mesma equipe do sul-coreano Son —parece-me um time meio pé-frio neste período pré-Copa.</segment>
    <segment id="65">Mas a lesão muscular do atacante foi de grau 1 (gostamos de grau 1</segment>
    <segment id="66">, leve).</segment>
    <segment id="67">E ele deve voltar à forma na véspera do Mundial.</segment>
    <segment id="68">Diante do quadro</segment>
    <segment id="69">, este humilde escriba gostaria de oferecer dois conselhos: 1) para o pessoal da Panini: incluir no álbum duas páginas para figurinhas de jogadores que</segment>
    <segment id="70">sese machucaram e ficaram fora do Mundial</segment>
    <segment id="71">; e 2) para quem for entrar em campo neste fim de semana e no próximo: pega leve!</segment>
    <segment id="72">Parabéns  Congratulações aos mais recentes campeões do Brasil.</segment>
    <segment id="73">Ao Flamengo</segment>
    <segment id="74">, campeão da Copa do Brasil Premium</segment>
    <segment id="75">, chamada também de Libertadores</segment>
    <segment id="76">; e ao Palmeiras</segment>
    <segment id="77">, que ensinou a todos uma palavra nova e nos deu a possibilidade de escrever "</segment>
    <segment id="78">Endrick é hendeca".</segment>
    <segment id="79">Lamentação</segment>
    <segment id="80">O que seria pior: a diretora de responsabilidade social (oi?)</segment>
    <segment id="81">Angela Machado (bolsonarista) postar a declaração xenofóbica</segment>
    <segment id="82">"ganhamos onde</segment>
    <segment id="83">sese produz</segment>
    <segment id="84">, perdemos onde</segment>
    <segment id="85">sese passa férias</segment>
    <segment id="86">, bora trabalhar</segment>
    <segment id="87">porque</segment>
    <segment id="88">porque</segment>
    <segment id="89">sese o gado morrer o carrapato passa fome"</segment>
    <segment id="90">, após a acachapante derrota de Bolsonaro no Nordeste… ooouuuu</segment>
    <segment id="91">, o presidente do Flamengo</segment>
    <segment id="92">, Rodolfo Landim (marido da tal diretora</segment>
    <segment id="93">, masmas isso é só coincidência) dizer que "o problema não é meu</segment>
    <segment id="94">, é da minha mulher</segment>
    <segment id="95">, ela é uma pessoa física e tem o direito de</segment>
    <segment id="96">sese posicionar"?</segment>
  </rst>
</analysis>