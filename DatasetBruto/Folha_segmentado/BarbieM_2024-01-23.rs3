  <rst>
    <segment id="1">A Academia de Artes e Ciências Cinematográficas de Hollywood anunciou na manhã desta terça-feira (23) os indicados à 96ª edição do Academy Awards</segment>
    <segment id="2">, o Oscar</segment>
    <segment id="3">, a mais importante premiação da indústria americana de cinema.</segment>
    <segment id="4">As indicações a "</segment>
    <segment id="5">Oppenheimer"</segment>
    <segment id="6">, "</segment>
    <segment id="7">Assassinato na Lua das Flores" e "</segment>
    <segment id="8">Pobres</segment>
    <segment id="9">Criaturas’"já eram esperadas</segment>
    <segment id="10">, masmas o que surpreendeu mesmo foi a ausência de Margot Robbie no páreo para Melhor Atriz</segment>
    <segment id="11">, por seu papel em "Barbie"</segment>
    <segment id="12">, enquanto os coadjuvantes Ryan Gosling e America Ferrera foram reconhecidos por suas atuações</segment>
    <segment id="13">comocomo Ken e Gloria no longa de Greta Gerwig.</segment>
    <segment id="14">Ryan Gosling e Margot Robbie em cena do filme &amp;quot</segment>
    <segment id="15">;Barbie&amp;quot</segment>
    <segment id="16">;, dirigido por Greta Gerwig - Divulgação"Nenhuma indicação para Margot Robbie ou Greta Gerwig ao Oscar</segment>
    <segment id="17">, enquanto o Ryan Gosling consegue uma.</segment>
    <segment id="18">Literalmente o ponto do filme da Barbie"</segment>
    <segment id="19">, opina um usuário.</segment>
    <segment id="20">Veja os indicados a melhor filme no Oscar 2024Mais    novamente         de   de  de  representando um  Nas redes</segment>
    <segment id="21">, o clima é de indignação.</segment>
    <segment id="22">Os termos "Margot Robbie"</segment>
    <segment id="23">, "Oscar"</segment>
    <segment id="24">, "Greta"</segment>
    <segment id="25">, "Barbie" e "Ryan Gosling" dominam os assuntos mais comentados do X</segment>
    <segment id="26">, ex-Twitter</segment>
    <segment id="27">, na manhã desta terça.</segment>
    <segment id="28">Pode acontecer…</segment>
    <segment id="29">Preferência à Suzi.</segment>
    <segment id="30">Crimes.</segment>
    <segment id="31">"</segment>
    <segment id="32">Vocês já pensaram na morte?</segment>
    <segment id="33">"</segment>
    <segment id="34">Mas os fãs estão satisfeitos com a indicação de Ryan Gosling pelo personagem Ken e pela possível performance de "I’m Just Ken".</segment>
    <segment id="35">Internautas também questionam a indicação de Bradley Cooper</segment>
    <segment id="36">comocomo melhor ator em "Maestro" e a não-indicação</segment>
    <segment id="37">comocomo diretor do mesmo filme.</segment>
    <segment id="38">"</segment>
    <segment id="39">A Academia seleciona Bradley Cooper para melhor ator enquanto esnoba Margot Robbie e o Charles Melton"</segment>
    <segment id="40">, diz tuíte.</segment>
    <segment id="41">Outros ainda reclamam de Leonardo DiCaprio ficar de fora.</segment>
    <segment id="42">"</segment>
    <segment id="43">Eu vou quebrar minha casa inteira"</segment>
    <segment id="44">, disse um usuário do X.</segment>
