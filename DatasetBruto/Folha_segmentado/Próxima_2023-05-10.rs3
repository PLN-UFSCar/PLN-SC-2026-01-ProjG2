      <rel name="non-volitional-result" type="rst"/>
      <rel name="volitional-cause" type="rst"/>
      <rel name="volitional-result" type="rst"/>
    </relations>
  </header>
  <rst>
    <segment id="1">Ah, como</segment>
    <segment id="2">como é incrível mergulhar na cultura persa em Teerã.</segment>
    <segment id="3">Dançar sem compromisso numa casa de músicos que você conheceu no mesmo dia em Havana!</segment>
    <segment id="4">E o que é o passeio de barco em Hvar até a caverna azul?  Colunas e BlogsReceba no seu email uma seleção de colunas e blogs da Folha</segment>
    <segment id="5">; exclusiva para assinantes.</segment>
    <segment id="6">Carregando...</segment>
    <segment id="7">Frases assim saem facilmente da boca de quem já foi ao Irã</segment>
    <segment id="8">, a Cuba e à Croácia.</segment>
    <segment id="9">E eu poderia facilmente reproduzi-las</segment>
    <segment id="10">comocomo minhas</segment>
    <segment id="11">, aliás</segment>
    <segment id="12">, como</segment>
    <segment id="13">como acabei de fazer acima.</segment>
    <segment id="14">Mas eu estaria blefando.</segment>
    <segment id="15">Eu nunca fui a nenhum desses três países.</segment>
    <segment id="16">Aliás, não conheço uns 80 deles</segment>
    <segment id="17">, pelo menos segundo a lista de nações reconhecidas pela ONU.</segment>
    <segment id="18">Sim, eu sei</segment>
    <segment id="19">, na minha contabilidade</segment>
    <segment id="20">, já somo 114 países.</segment>
    <segment id="21">É bastante</segment>
    <segment id="22">, masmas ainda falta tanto!</segment>
    <segment id="23">Esse número talvez seja familiar para quem acompanha minhas aventuras.</segment>
    <segment id="24">Já há algum tempo</segment>
    <segment id="25">, quando em alguma entrevista me perguntam quanto países eu conheço</segment>
    <segment id="26">, a resposta vem rápida: 114.</segment>
    <segment id="27">Ocorre que desde a pandemia esse placar permanece fixo.</segment>
    <segment id="28">Até 2019</segment>
    <segment id="29">, eu tinha sempre o objetivo de incluir dois</segment>
    <segment id="30">, sese possível três</segment>
    <segment id="31">, países por ano nela.</segment>
    <segment id="32">Mas aí... bem</segment>
    <segment id="33">, você sabe o que aconteceu.</segment>
    <segment id="34">Desde que as fronteiras</segment>
    <segment id="35">sese abriram</segment>
    <segment id="36">, diga-</segment>
    <segment id="37">sese, lentamente (minha adorada Tailândia</segment>
    <segment id="38">, por exemplo</segment>
    <segment id="39">, só foi totalmente liberada para turistas no final do ano passado)</segment>
    <segment id="40">, eu já fiz várias viagens internacionais.</segment>
    <segment id="41">Todas elas</segment>
    <segment id="42">, porém</segment>
    <segment id="43">porém, para destinos já conhecidos.</segment>
    <segment id="44">Muitas dessas aventuras você acompanhou aqui</segment>
    <segment id="45">, como</segment>
    <segment id="46">como a recente viagem a Paris para celebrar meus 60 anos.</segment>
    <segment id="47">E, entusiasmado</segment>
    <segment id="48">comocomo sempre</segment>
    <segment id="49">, eu talvez tenha escondido essa minha...</segment>
    <segment id="50">chamemos de frustração: a de não estar colecionando novos carimbos no meu passaporte.</segment>
    <segment id="51">Bem, os ventos vão mudar.</segment>
    <segment id="52">Aliás, já estão mudando!</segment>
    <segment id="53">No momento em que você lê isso</segment>
    <segment id="54">, eu já estou pisando no que os antigos navegadores chamavam de "terra incognita".</segment>
    <segment id="55">Antigo mapa com Terra Incognita - Reprodução</segment>
    <segment id="56">Talvez não tão incógnita assim</segment>
    <segment id="57">, já que estou em uma cidade que não é exatamente nos confins do mundo.</segment>
    <segment id="58">(Não, eu não vou contar ainda onde estou!).</segment>
    <segment id="59">Mas tudo nas próximas três semanas vai ser novo para mim!</segment>
    <segment id="60">Nessa lista de países ainda não explorados</segment>
    <segment id="61">, além dos três que já citei ali no início</segment>
    <segment id="62">, existem dezenas que eu sonho em conhecer.</segment>
    <segment id="63">Alguns deles de difícil acesso</segment>
    <segment id="64">, é verdade</segment>
    <segment id="65">, como</segment>
    <segment id="66">como o próprio Irã</segment>
    <segment id="67">, que,</segment>
    <segment id="68">sese já é complicado para um turista em geral</segment>
    <segment id="69">, imagine para um que é jornalista!</segment>
    <segment id="70">Nações em conflito grave</segment>
    <segment id="71">, como</segment>
    <segment id="72">como a Rússia e</segment>
    <segment id="73">, mais recentemente</segment>
    <segment id="74">, o Sudão</segment>
    <segment id="75">, estão fora de questão por enquanto.</segment>
    <segment id="76">E destinos</segment>
    <segment id="77">comocomo a Coreia do Norte</segment>
    <segment id="78">, o Iêmen e o Paquistão</segment>
    <segment id="79">, parafraseando Tolstói quando escreve sobre famílias infelizes</segment>
    <segment id="80">, são complicados a sua maneira.</segment>
    <segment id="81">Aí você tem os lugares mais remotos</segment>
    <segment id="82">, pelo menos para nós aqui no Brasil</segment>
    <segment id="83">, como</segment>
    <segment id="84">como Nauru</segment>
    <segment id="85">, Guam</segment>
    <segment id="86">, Palau</segment>
    <segment id="87">, nomes que as ondas da Oceania trazem aos nosso ouvidos com um misto de encantamento e curiosidade.</segment>
    <segment id="88">Mas essa é uma região do planeta que prefiro deixar para o final da lista.</segment>
    <segment id="89">Aqui "do lado"</segment>
    <segment id="90">, sempre olhando de horizontes brasileiros</segment>
    <segment id="91">, temos "as Guianas": a Francesa</segment>
    <segment id="92">, a antiga holandesa (Suriname) e a antiga inglesa (que reteve o nome original</segment>
    <segment id="93">, Guiana).</segment>
    <segment id="94">Como estão aqui perto</segment>
    <segment id="95">, sempre acho que posso visitá-las a qualquer momento.</segment>
    <segment id="96">Tenho lacunas na América Central (poucas) e Caribe (muitas)</segment>
    <segment id="97">, masmas isso eu resolvo uma outra hora.</segment>
    <segment id="98">E na África</segment>
    <segment id="99">, bem...</segment>
    <segment id="100">Gosto de dizer</segment>
    <segment id="101">, com orgulho</segment>
    <segment id="102">, que já visitei 16 países no continente.</segment>
    <segment id="103">Mas quando você lembra que são 54 no total</segment>
    <segment id="104">, dá um certo desespero: vai fechar a conta?</segment>
    <segment id="105">Bem, vou chegar mais perto disso até o final de maio.</segment>
    <segment id="106">E vou contar para você.</segment>
    <segment id="107">Não agora.</segment>
    <segment id="108">Não como</segment>
    <segment id="109">como um spoiler.</segment>
    <segment id="110">Não, não é tortura</segment>
    <segment id="111">, tampouco superstição.</segment>
    <segment id="112">É apenas a vontade de</segment>
    <segment id="113">, nos próximos dias</segment>
    <segment id="114">, viajar</segment>
    <segment id="115">comocomo na Antiguidade</segment>
    <segment id="116">, antes de as redes sociais entrarem nas nossas vidas.</segment>
    <segment id="117">Vou simplesmente viajar.</segment>
  </rst>
</analysis>