  <rst>
    <segment id="1">Acontece neste sábado (20)</segment>
    <segment id="2">, às 22h</segment>
    <segment id="3">, no Tokio Marine Hall</segment>
    <segment id="4">, em São Paulo</segment>
    <segment id="5">, os shows da banda de rock Biquini Cavadão e do polêmico cantor</segment>
    <segment id="6">, compositor e baterista Lobão.</segment>
    <segment id="7">Lobão ataca de power trio.</segment>
    <segment id="8">Segundo ele</segment>
    <segment id="9">, a proposta é levar a sonoridade dessa formação ao máximo de suas possibilidades</segment>
    <segment id="10">, deixando a audiência curiosa sobre</segment>
    <segment id="11">comocomo pode sair tanto som de um palco com apenas três caras.</segment>
    <segment id="12">A banda Biquini Cavadão e o compositor</segment>
    <segment id="13">, cantor e baterista Lobão - DivulgaçãoJá a banda Biquini Cavadão</segment>
    <segment id="14">, formada em 1985 no Rio de Janeiro por Bruno Gouveia (vocal)</segment>
    <segment id="15">, Miguel Flores (teclados)</segment>
    <segment id="16">, Álvaro Birita (bateria) e Carlos Coelho (guitarra)</segment>
    <segment id="17">, mostrará músicas de seu álbum mais recente "</segment>
    <segment id="18">Através dos Tempos</segment>
    <segment id="19">" lançado no final de 2021.</segment>
    <segment id="20">O disco traz um recado de otimismo</segment>
    <segment id="21">, resiliência e perseverança.</segment>
    <segment id="22">A banda</segment>
    <segment id="23">, através de nove faixas aborda esses assuntos</segment>
    <segment id="24">, com a certeza de que</segment>
    <segment id="25">, de um jeito ou de outro</segment>
    <segment id="26">, superaremos as crises que nos acometem.</segment>
    <segment id="27">É Lobão quem resume o show:</segment>
    <segment id="28">"Teremos um arsenal de hits incríveis que fazem parte do inconsciente coletivo de todo brasileiro.</segment>
    <segment id="29">Sendo assim</segment>
    <segment id="30">, a missão desse show é abalar as estruturas e mostrar ao Brasil que a potência</segment>
    <segment id="31">, a exuberância</segment>
    <segment id="32">, a criatividade e a irreverência do rock nacional estão mais vivas e quicantes do que nunca".</segment>
    <segment id="33">Bom show!</segment>
    <segment id="34">SHOW BIQUINI CAVADÃO E LOBÃO  QUANDO Sábado (20)</segment>
    <segment id="35">, às 22h</segment>
    <segment id="36">ONDE</segment>
    <segment id="37">Tokio Marine Hall</segment>
    <segment id="38">, r. Bragança Paulista</segment>
    <segment id="39">, 1281</segment>
    <segment id="40">, Chácara Santo Antônio</segment>
    <segment id="41">, São Paulo</segment>
    <segment id="42">, tel. (11)</segment>
    <segment id="43">5646-2153  QUANTO</segment>
    <segment id="44">De R$ 200 a R$ 380</segment>
  </rst>
