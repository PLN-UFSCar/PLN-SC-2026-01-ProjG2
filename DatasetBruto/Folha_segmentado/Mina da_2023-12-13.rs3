  </header>
  <rst>
    <segment id="1">O colapso da mina 18 da Braskem no domingo (10)</segment>
    <segment id="2">, em Maceió</segment>
    <segment id="3">, não encerrou os efeitos do afundamento na lagoa Mundaú.</segment>
    <segment id="4">Os impactos ambientais e os próximos movimentos —a estabilização ou o agravamento do problema— ainda estão sendo mensurados.</segment>
    <segment id="5">Outros episódios</segment>
    <segment id="6">, como</segment>
    <segment id="7">como a formação de um redemoinho em uma área da lagoa</segment>
    <segment id="8">, geram dúvida sobre o que pode acontecer.</segment>
    <segment id="9">No domingo</segment>
    <segment id="10">, a mina 18</segment>
    <segment id="11">, uma das 35 para extração de sal-gema na região</segment>
    <segment id="12">, colapsou.</segment>
    <segment id="13">O efeito mais visível foi uma perturbação no espelho d’água.</segment>
    <segment id="14">Parte do material transbordou</segment>
    <segment id="15">, masmas não foi possível verificar</segment>
    <segment id="16">, ainda</segment>
    <segment id="17">, a extensão do estrago.</segment>
    <segment id="18">Na superfície</segment>
    <segment id="19">, foi estabelecida uma área de colapso</segment>
    <segment id="20">, com raio de aproximadamente 234 metros.</segment>
    <segment id="21">Essa distância tem três vezes o raio da mina</segment>
    <segment id="22">, de 78 metros</segment>
    <segment id="23">, segundo a Defesa Civil de Maceió.</segment>
    <segment id="24">Outra área</segment>
    <segment id="25">, de segurança tem cinco vezes o raio da mina.</segment>
    <segment id="26">Imagem da lagoa</segment>
    <segment id="27">Mundaú após o colapso da mina 18 da Braskem</segment>
    <segment id="28">, em Maceió - Governo de AlagoasO monitoramento da região continua.</segment>
    <segment id="29">Nesta terça (12)</segment>
    <segment id="30">, uma nova movimentação de água foi registrada na lagoa.</segment>
    <segment id="31">Segundo a Defesa Civil de Maceió</segment>
    <segment id="32">, o redemoinho é normal</segment>
    <segment id="33">, por causa da acomodação que ainda acontece após o colapso da mina.</segment>
    <segment id="34">De acordo com o pesquisador Emerson Soares</segment>
    <segment id="35">, da Universidade Federal de Alagoas</segment>
    <segment id="36">, o movimento acontece</segment>
    <segment id="37">porque</segment>
    <segment id="38">porque a água entra na cavidade da área colapsada.</segment>
    <segment id="39">"</segment>
    <segment id="40">O terreno da mina está</segment>
    <segment id="41">sese moldando</segment>
    <segment id="42">, e o redemoinho está dentro do perímetro de segurança"</segment>
    <segment id="43">, afirma.</segment>
    <segment id="44">O desabamento é propagado de baixo para cima desde a área a 1.200 metros de profundidade de onde a Braskem extraía o sal-gema</segment>
    <segment id="45">, usado para a fabricação de soda cáustica e PVC (plástico usado na construção civil).</segment>
    <segment id="46">Reportagem da Folha mostrou que os poços para a exploração do sal atravessavam seis camadas de rochas não compactas.</segment>
    <segment id="47">Ao longo dos anos</segment>
    <segment id="48">, a retirada de sal —dissolvido por jatos de líquido— deixou grandes buracos.</segment>
    <segment id="49">Ainda eram apontados</segment>
    <segment id="50">comocomo riscos a proximidade de poços e a infiltração de água nas diferentes camadas de solo.</segment>
    <segment id="51">O colapso acontece quando as rochas desmoronam e caem</segment>
    <segment id="52">, preenchendo esses buracos.</segment>
    <segment id="53">Assim, deixam um novo teto pelas rochas que caíram.</segment>
    <segment id="54">Esse teto</segment>
    <segment id="55">, por sua vez</segment>
    <segment id="56">, tende a cair</segment>
    <segment id="57">porque</segment>
    <segment id="58">porque perde a sustentação abaixo.</segment>
    <segment id="59">Esse efeito</segment>
    <segment id="60">sese propaga de forma ascendente</segment>
    <segment id="61">, com rochas e água caindo e fazendo esse buraco "subir".</segment>
    <segment id="62">O que se</segment>
    <segment id="63">se viu na superfície da lagoa</segment>
    <segment id="64">, então</segment>
    <segment id="65">, não veio por um espaço vazio desde o fundo da mina.</segment>
    <segment id="66">"Não se</segment>
    <segment id="67">se forma um buraco da área do sal até o topo"</segment>
    <segment id="68">, diz Edilson Pizzato</segment>
    <segment id="69">, professor do Departamento de Geologia Ambiental e Sedimentar do Instituto de Geociências da USP.</segment>
    <segment id="70">"</segment>
    <segment id="71">As rochas foram caindo</segment>
    <segment id="72">, caindo</segment>
    <segment id="73">, e a desestabilização chegou à parte de cima.</segment>
    <segment id="74">Ainda é preciso ver o que é essa lama escura.</segment>
    <segment id="75">"  Desabamento da mina 18 da Braskem em Maceió (AL)Mais    novamente         de   de  de  representando um</segment>
    <segment id="76">Além disso</segment>
    <segment id="77">, Pizzato aponta que os tubos dos poços usados para retirar o sal podem estar comprometidos pelo movimento de rochas quebrando e afundando no local.</segment>
    <segment id="78">"</segment>
    <segment id="79">Se estivesse tudo passando pelo tubo</segment>
    <segment id="80">, já teria estabilizado.</segment>
    <segment id="81">"</segment>
    <segment id="82">A movimentação após o colapso da mina 18 é o começo do que ainda pode acontecer a lagoa.</segment>
    <segment id="83">"</segment>
    <segment id="84">Não muda muito a situação geral da área.</segment>
    <segment id="85">É mais um processo de deslocamento</segment>
    <segment id="86">porque</segment>
    <segment id="87">porque tem um monte dessas cavidades lá embaixo"</segment>
    <segment id="88">, afirma Pizzato.</segment>
    <segment id="89">Ele diz que os materiais vão rachar</segment>
    <segment id="90">, quebrar e</segment>
    <segment id="91">sese acomodar</segment>
    <segment id="92">, num processo que pode levar anos</segment>
    <segment id="93">, como</segment>
    <segment id="94">como tem sido monitorado.</segment>
    <segment id="95">Segundo a Defesa Civil de Maceió</segment>
    <segment id="96">, a área continua isolada</segment>
    <segment id="97">, inclusive para pescadores.</segment>
  </rst>
</analysis>