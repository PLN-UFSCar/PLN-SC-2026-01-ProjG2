  <rst>
    <segment id="1">Pabllo Vittar lança nesta semana o álbum "Noitada"</segment>
    <segment id="2">, o quinto de sua carreira.</segment>
    <segment id="3">A obra marca uma abertura para falar mais explicitamente sobre sexo</segment>
    <segment id="4">, conforme ela disse em entrevista à Folha.</segment>
    <segment id="5">Leia a íntegra da entrevista com Pabllo Vittar   "</segment>
    <segment id="6">Dois anos atrás</segment>
    <segment id="7">, eu jamais falaria um ‘caralho’ numa música"</segment>
    <segment id="8">, afirmou a drag queen.</segment>
    <segment id="9">"</segment>
    <segment id="10">Se você reparar</segment>
    <segment id="11">, todos os meus álbuns são para a família ouvir</segment>
    <segment id="12">,</segment>
    <segment id="13">tocam em qualquer lugar.</segment>
    <segment id="14">Por mais que tenha algum duplo sentido</segment>
    <segment id="15">, não é nada muito [escandaloso].</segment>
    <segment id="16">Neste álbum</segment>
    <segment id="17">, já estou bem mais explícita</segment>
    <segment id="18">, falando as verdades de</segment>
    <segment id="19">comocomo estou me sentindo.</segment>
    <segment id="20">"</segment>
    <segment id="21">Pabllo Vittar em cartaz de divulgação de &amp;#</segment>
    <segment id="22">039;À Meia Noite&amp;#039</segment>
    <segment id="23">;, single de seu novo disco</segment>
    <segment id="24">, &amp;#039</segment>
    <segment id="25">;Noitada&amp;#039</segment>
    <segment id="26">; - Rodolfo Magalhãs/DivulgaçãoEla afirmou que</segment>
    <segment id="27">, antes</segment>
    <segment id="28">, tinha receio de falar sobre sexo ou falar palavrões nas letras por já sofrer preconceito por ser uma drag queen no país que mais mata LGBTs no mundo.</segment>
    <segment id="29">Agora, com uma carreira já reconhecida</segment>
    <segment id="30">, ela pode fazer letras mais despudoradas.</segment>
    <segment id="31">"</segment>
    <segment id="32">Nossa preocupação antes era divulgar a música</segment>
    <segment id="33">, tocar nos lugares.</segment>
    <segment id="34">Eu não falava e já era um pouco barrada"</segment>
    <segment id="35">, ela afirmou.</segment>
    <segment id="36">"</segment>
    <segment id="37">Agora, nesse álbum</segment>
    <segment id="38">, não tenho nenhum pudor.</segment>
    <segment id="39">"</segment>
  </rst>
