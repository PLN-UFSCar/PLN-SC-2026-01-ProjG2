  <rst>
    <segment id="1">Embora tenha conseguido controlar melhor o tamanho de suas filas de entrada em relação ao sábado</segment>
    <segment id="2">, a Bienal do Livro de São Paulo segue lotada no segundo dia do evento</segment>
    <segment id="3">, um domingo também ensolarado que dobrou a aposta na literatura pop.</segment>
    <segment id="4">Leitores</segment>
    <segment id="5">sese reúnem na Bienal do Livro de São Paulo</segment>
    <segment id="6">, no Expo Center Norte - Adriano Vizoni/FolhapressÀ tarde</segment>
    <segment id="7">, a arena central recebeu a primeira aparição em feira literária da espanhola Elena Armas</segment>
    <segment id="8">, que lançou "</segment>
    <segment id="9">Uma Farsa de Amor na Espanha</segment>
    <segment id="10">" pela Arqueiro</segment>
    <segment id="11">, romance que</segment>
    <segment id="12">sese disseminou</segment>
    <segment id="13">comocomo fogo de palha entre os booktokers</segment>
    <segment id="14">, que divulgam livros no TikTok.</segment>
    <segment id="15">Com tradição de atrair multidões com literatura jovem</segment>
    <segment id="16">, a Bienal do Livro tem um feliz casamento com a rede social preferida da geração</segment>
    <segment id="17">Z, que tem sido aliada de peso para editoras voltadas a esse público.</segment>
    <segment id="18">Caminhando pelas tendas</segment>
    <segment id="19">, era comum ver estantes com legendas</segment>
    <segment id="20">comocomo "bombou no TikTok".</segment>
    <segment id="21">Conheça os &amp;#</segment>
    <segment id="22">039;booktokers&amp;#039</segment>
    <segment id="23">; brasileiros</segment>
    <segment id="24">, que divulgam livros no TikTokMais    novamente         de   de  de  representando um</segment>
    <segment id="25">À palestra de Armas</segment>
    <segment id="26">sese seguiu uma de Brian Zepka</segment>
    <segment id="27">, autor que publicou "</segment>
    <segment id="28">A Temperatura entre Você e Eu"</segment>
    <segment id="29">, fantasia young adult sobre uma relação gay</segment>
    <segment id="30">, pela editora Buzz —que ergueu em frente à arena um palco com microfone e globo espelhado</segment>
    <segment id="31">para que</segment>
    <segment id="32">para que os visitantes fizessem fotos</segment>
    <segment id="33">comocomo popstars.</segment>
    <segment id="34">Não foi a única editora a montar algo assim.</segment>
    <segment id="35">Na Rocco</segment>
    <segment id="36">, dava para posar ao lado de um ator vestido de Newt Scamander</segment>
    <segment id="37">, o protagonista da saga "Animais Fantásticos"</segment>
    <segment id="38">, que teve o roteiro publicado pela casa</segment>
    <segment id="39">; mais perto da Panini</segment>
    <segment id="40">, havia um rapaz montado</segment>
    <segment id="41">comocomo Doutor Estranho sorrindo para as câmeras.</segment>
    <segment id="42">Aqui e ali</segment>
    <segment id="43">, também dava para ver gente vestida em cosplay digno de Comic Con.</segment>
    <segment id="44">Assim como</segment>
    <segment id="45">como no sábado</segment>
    <segment id="46">, era difícil caminhar pelos corredores sem esbarrar em ninguém ou</segment>
    <segment id="47">sese ver numa fila indiana involuntária.</segment>
    <segment id="48">Quem queria comer num horário razoável tinha de</segment>
    <segment id="49">sese plantar em filas longas e esperar quase uma hora por um lanche simples.</segment>
    <segment id="50">Muita gente recorreu a pipoca</segment>
    <segment id="51">, que rapidamente</segment>
    <segment id="52">sese transformou em sujeira espalhada pelo chão.</segment>
    <segment id="53">Veja fotos da Bienal do Livro de São Paulo 2022Mais    novamente         de   de  de  representando um  Também era preciso cuidado para não tropeçar em grupos sentados no chão por todo o pavilhão ao lado de sacolas cheias de livros —os mais concentrados até conseguiam abrir um e ler.</segment>
    <segment id="54">Procurada</segment>
    <segment id="55">, a organização não informou quantos visitantes recebeu neste fim de semana nem quantos ingressos tinham sido vendidos.</segment>
    <segment id="56">Mas há pistas de que a lotação é maior do que o normal —a Rocco</segment>
    <segment id="57">, por exemplo</segment>
    <segment id="58">, vendeu 157% a mais neste sábado e domingo que nos dois primeiros dias da última Bienal presencial.</segment>
    <segment id="59">Tudo a lerReceba no seu email uma seleção com lançamentos</segment>
    <segment id="60">, clássicos e curiosidades literárias</segment>
    <segment id="61">; aberta para não assinantesCarregando...</segment>
    <segment id="62">Obstáculos superados</segment>
    <segment id="63">, dava para ouvir conversas ricas</segment>
    <segment id="64">comocomo a da escritora moçambicana Paulina Chiziane com Ana Maria Gonçalves</segment>
    <segment id="65">, ou Noemi Jaffe discutir com a portuguesa Dulce Maria Cardoso o que separa história de ficção.</segment>
    <segment id="66">Cardoso argumentou que a escrita de ficção</segment>
    <segment id="67">sese volta ao futuro</segment>
    <segment id="68">, enquanto aquilo que</segment>
    <segment id="69">sese prende em fatos reais</segment>
    <segment id="70">sese volta ao passado.</segment>
    <segment id="71">"</segment>
    <segment id="72">A literatura não fala sobre algo</segment>
    <segment id="73">, como</segment>
    <segment id="74">como o jornalismo ou os livros de história</segment>
    <segment id="75">, masmas faz com que a realidade fale"</segment>
    <segment id="76">, disse Jaffe.</segment>
    <segment id="77">A Bienal do Livro continua até o próximo domingo com figuras</segment>
    <segment id="78">comocomo Xuxa</segment>
    <segment id="79">, Lázaro Ramos e Matilde Campilho.</segment>
  </rst>
</analysis>