  <rst>
    <segment id="1">Você já deve ter</segment>
    <segment id="2">sese deparado com algum café que trazia</segment>
    <segment id="3">, no rótulo</segment>
    <segment id="4">, a informação:</segment>
    <segment id="5">"100% arábica".</segment>
    <segment id="6">Mas você sabe o que isso significa?</segment>
    <segment id="7">Qual a diferença entre o arábica e o robusta?</segment>
    <segment id="8">E dizer que é 100% arábica significa que o café é melhor?</segment>
    <segment id="9">Colunas e BlogsReceba no seu email uma seleção de colunas e blogs da Folha</segment>
    <segment id="10">; exclusiva para assinantes.</segment>
    <segment id="11">Carregando...</segment>
    <segment id="12">Existem dezenas de espécies de café no mundo</segment>
    <segment id="13">, sendo que duas são mais conhecidas e exploradas comercialmente: o arábica (cujo nome científico é Coffea arabica) e o canéfora (Coffea canephora).</segment>
    <segment id="14">O robusta</segment>
    <segment id="15">, termo que por vezes é usado</segment>
    <segment id="16">comocomo sinônimo de canéfora</segment>
    <segment id="17">, na verdade é apenas uma das variedades de canéfora.</segment>
    <segment id="18">Além do robusta</segment>
    <segment id="19">, existem outras</segment>
    <segment id="20">, como</segment>
    <segment id="21">como o conilon</segment>
    <segment id="22">, por exemplo.</segment>
    <segment id="23">Mas qual é de fato a diferença entre o arábica e o canéfora (ou robusta)?</segment>
    <segment id="24">E qual é o melhor?</segment>
    <segment id="25">Café 100% arábica em um supermercado de São Paulo - David Lucena/FolhapressEm geral</segment>
    <segment id="26">, o arábica tem maior qualidade sensorial e notas mais complexas.</segment>
    <segment id="27">Já o canéfora tem o dobro de cafeína do arábica.</segment>
    <segment id="28">Além disso</segment>
    <segment id="29">, os robustas são mais resistentes a pragas e variações climáticas.</segment>
    <segment id="30">O cultivo de arábica</segment>
    <segment id="31">, por exemplo</segment>
    <segment id="32">, requer uma condição climática mais específica –em geral</segment>
    <segment id="33">, altitudes elevadas e temperaturas amenas.</segment>
    <segment id="34">Já o canéfora pode ser plantado abaixo dos 500 metros de altitude e sob umidade e calor.</segment>
    <segment id="35">Confira na galeria abaixo as principais diferenças entre as duas espécies:  Entenda as diferenças entre café arábica e canéforaMais    novamente         de   de  de  representando um  Assim</segment>
    <segment id="36">, um café 100% arábica</segment>
    <segment id="37">, embora</segment>
    <segment id="38">embora não seja sinônimo de qualidade por si só</segment>
    <segment id="39">, costuma ser um pouco mais caro do que aquele que tem grãos de canéfora na sua composição.</segment>
    <segment id="40">Apesar disso</segment>
    <segment id="41">, canéfora não é</segment>
    <segment id="42">, de maneira nenhuma</segment>
    <segment id="43">, sinônimo de café ruim</segment>
    <segment id="44">, como</segment>
    <segment id="45">como explica a barista (especialista no preparo de café) Isabela Raposeiras.</segment>
    <segment id="46">"</segment>
    <segment id="47">Canéfora de qualidade sempre existiu.</segment>
    <segment id="48">É que a gente tinha aqui no Brasil um manejo feito de qualquer jeito</segment>
    <segment id="49">, e a nossa variedade de canéfora é mais limitada"</segment>
    <segment id="50">, explica.  "</segment>
    <segment id="51">Mas a gente tem outras variedades no mundo que são incríveis.</segment>
    <segment id="52">A Índia já produz canéfora de alta qualidade e caríssima há décadas</segment>
    <segment id="53">, a Indonésia também"</segment>
    <segment id="54">, afirma Raposeiras</segment>
    <segment id="55">, que já serviu café 100% canéfora em sua conceituada cafeteria em São Paulo</segment>
    <segment id="56">, o Coffee Lab.</segment>
    <segment id="57">Canéfora de qualidade sempre existiu.</segment>
    <segment id="58">É que a gente tinha aqui no Brasil um manejo feito de qualquer jeito</segment>
    <segment id="59">, e a nossa variedade de canéfora é mais limitada.</segment>
    <segment id="60">Mas a gente tem outras variedades no mundo que são incríveis.</segment>
    <segment id="61">Isabela Raposeiras</segment>
    <segment id="62">, barista fundadora do Coffee LabSobre a qualidade do café canéforaMas ela faz uma ressalva:</segment>
    <segment id="63">"</segment>
    <segment id="64">Eles são limitados em aromas e sabores.</segment>
    <segment id="65">Então o melhor canéfora nunca vai superar o melhor arábica".</segment>
    <segment id="66">A crise do clima</segment>
    <segment id="67">, contudo</segment>
    <segment id="68">contudo</segment>
    <segment id="69">, tem estimulado pesquisas para o desenvolvimento de canéforas de maior qualidade sensorial.</segment>
    <segment id="70">Isto porque</segment>
    <segment id="71">porque</segment>
    <segment id="72">, com o aquecimento do planeta</segment>
    <segment id="73">, o cultivo de arábica tem</segment>
    <segment id="74">sese tornado cada vez mais complexo e custoso.</segment>
    <segment id="75">Leia maisConfira outros textos publicados pelo Café na PrensaCom ou sem açúcar?</segment>
    <segment id="76">Tem jeito certo de beber café?Bebida não deve ser amarga</segment>
    <segment id="77">, masmas tomar puro é um gosto adquirido</segment>
    <segment id="78">; veja dicas para abandonar o açúcarVocê sabe quais são os dias nacional e internacional do café?Bebida é tão popular que tem várias celebrações</segment>
    <segment id="79">, masmas nem todas são &amp;#</segment>
    <segment id="80">039;de verdade&amp;#039</segment>
    <segment id="81">;</segment>
    <segment id="82">; confira quais datas são oficiaisCafé colombiano registra fortes quedas na produçãoFamoso</segment>
    <segment id="83">pela qualidade dos seus grãos</segment>
    <segment id="84">, país tem enfrentado problemas</segment>
    <segment id="85">; entenda o que está causando issoA barista e consultora Maíra Teixeira explica que esse é um movimento recente</segment>
    <segment id="86">, pois</segment>
    <segment id="87">pois o foco de cafés de alta qualidade no Brasil sempre foi muito direcionado para a espécie arábica.</segment>
    <segment id="88">"</segment>
    <segment id="89">Por muito tempo o mercado de café especial somente trabalhou em tecnologias para melhorar a qualidade do café arábica.</segment>
    <segment id="90">Mas a gente está passando por um momento novo no mercado de cafés canéforas especiais também.</segment>
    <segment id="91">Hoje existem produtores cujo foco são robustas e conilons especiais"</segment>
    <segment id="92">, afirma Teixeira.</segment>
    <segment id="93">Até espécies pouco comercializadas</segment>
    <segment id="94">, como</segment>
    <segment id="95">como a Coffea liberica –ainda mais resistente às mudanças climáticas–</segment>
    <segment id="96">, têm sido analisadas</segment>
    <segment id="97">comocomo possibilidades para manter a produtividade no futuro</segment>
    <segment id="98">, quando o planeta deve enfrentar temperaturas mais elevadas.</segment>
    <segment id="99">Veja na galeria abaixo imagens desta espécie tão pouco cultivada.</segment>
    <segment id="100">Café Liberica excelsa é mais resistente à mudança climática e às pragasMais    novamente         de   de  de  representando um  Agora</segment>
    <segment id="101">, da próxima vez que você vir um rótulo com a inscrição</segment>
    <segment id="102">"100% arábica"</segment>
    <segment id="103">, já sabe o que significa.</segment>
    <segment id="104">Só não esqueça que a espécie é apenas um dos fatores para gerar uma bebida de qualidade.</segment>
    <segment id="105">Afinal</segment>
    <segment id="106">, de nada adianta cultivar um arábica de excelente qualidade</segment>
    <segment id="107">sese o manejo dos grãos</segment>
    <segment id="108">, a secagem e a torra forem feitas sem o devido cuidado.    Qual assunto você gostaria de ver aqui no blog?</segment>
    <segment id="109">Envie sugestões para david.lucena@folhapress.com.br</segment>
    <segment id="110">Acompanhe o Café na Prensa também pelo Instagram @davidmclucena e pelo Twitter @davidlucena</segment>
