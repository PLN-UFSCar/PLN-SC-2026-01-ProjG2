  <rst>
    <segment id="1">A Moriah Asset anuncia nesta terça-feira (9) que vai ampliar sua carteira de investimentos e integrar o Grupo Frutaria</segment>
    <segment id="2">, donos de marcas</segment>
    <segment id="3">comocomo Frutaria São Paulo</segment>
    <segment id="4">, Empório Frutaria e Néctar.</segment>
    <segment id="5">Os valores do negócio não foram informados.</segment>
    <segment id="6">Criada em 2019 pelo empresário Fabiano Zettel</segment>
    <segment id="7">, a Moriah Asset já investiu nas empresas Les Cinq</segment>
    <segment id="8">, Desinchá</segment>
    <segment id="9">, Smoov</segment>
    <segment id="10">, Naturanic</segment>
    <segment id="11">, FOONE 2 e Be.</segment>
    <segment id="12">A Néctar</segment>
    <segment id="13">, uma das marcas do Grupo Frutaria</segment>
    <segment id="14">, é focada em alimentos fast food saudáveis- Neuton Araujo/DivulgaçãoCom a chegada da Moriah</segment>
    <segment id="15">, o plano é que o grupo saia dos atuais R$ 120 milhões em faturamento para R$ 200 milhões até 2027.</segment>
    <segment id="16">Para isso</segment>
    <segment id="17">, pretendem ampliar o número de lojas da Frutaria São Paulo</segment>
    <segment id="18">, Empório Frutaria e Néctar.</segment>
    <segment id="19">A previsão é de que a Frutaria São Paulo chegue a 20 lojas (hoje são 13)</segment>
    <segment id="20">, o Empório a 6 (hoje são 2) e o Néctar alcance 200 lojas (neste</segment>
    <segment id="21">casocaso</segment>
    <segment id="22">, a expansão seria para Minas Gerais</segment>
    <segment id="23">, Pernambuco</segment>
    <segment id="24">, e Bahia por meio de franquias).</segment>
    <segment id="25">Com Diego</segment>
    <segment id="26">Felix</segment>
  </rst>
