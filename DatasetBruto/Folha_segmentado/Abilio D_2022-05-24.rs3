  <rst>
    <segment id="1">Abilio Diniz resolveu entrar no TikTok.</segment>
    <segment id="2">Aos 85 anos</segment>
    <segment id="3">, o empresário abriu uma conta na rede social mais voltada aos adolescentes para divulgar conteúdos sobre gestão</segment>
    <segment id="4">, liderança</segment>
    <segment id="5">, qualidade de vida e histórias de sua rotina.</segment>
    <segment id="6">Abilio Diniz</segment>
    <segment id="7">, fundador e presidente do conselho de administração da Península Participações</segment>
    <segment id="8">, membro do conselho do grupo Carrefour e do Carrefour Brasil - Bruno Santos - 19.dez.2019/FolhapressNos detalhes do perfil</segment>
    <segment id="9">, ele se</segment>
    <segment id="10">se apresenta</segment>
    <segment id="11">comocomo pai de seis filhos</segment>
    <segment id="12">, marido</segment>
    <segment id="13">, empresário e professor na FGV.</segment>
    <segment id="14">Nesta terça (24)</segment>
    <segment id="15">, tinha cerca de 250 seguidores na plataforma.</segment>
    <segment id="16">Nas outras redes em que já está presente</segment>
    <segment id="17">, tem cerca de 2</segment>
    <segment id="18">,6 milhões.</segment>
    <segment id="19">Abilio ganhou prática com os vídeos na pandemia fazendo mais de 70 lives.</segment>
    <segment id="20">Segundo o empresário</segment>
    <segment id="21">, além de compartilhar seu conteúdo com a turma mais jovem</segment>
    <segment id="22">, o que ele busca na interação do TikTok é aprender também com o feedback deles.</segment>
    <segment id="23">Colunas e BlogsReceba no seu email uma seleção de colunas e blogs da Folha</segment>
    <segment id="24">; exclusiva para assinantes.</segment>
    <segment id="25">Carregando...</segment>
