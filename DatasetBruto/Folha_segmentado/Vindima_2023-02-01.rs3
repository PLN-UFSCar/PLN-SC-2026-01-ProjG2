  <rst>
    <segment id="1">Que tal participar de uma autêntica vindima</segment>
    <segment id="2">, vivenciar a colheita e depois a pisa das uvas e finalizar a diversão com um almoço em um restaurante dentro da vinícola?</segment>
    <segment id="3">Essa é a proposta da Vindima Vila Don Patto</segment>
    <segment id="4">, que acontece em São Roque</segment>
    <segment id="5">, a pouco mais de 60 km da capital paulista.</segment>
    <segment id="6">A experiência acontece nos dias 4</segment>
    <segment id="7">, 5 e 12 de fevereiro e começa na Vila Don Patto</segment>
    <segment id="8">, no Km 2</segment>
    <segment id="9">,5 do Roteiro do Vinho</segment>
    <segment id="10">, às 9:30h.</segment>
    <segment id="11">De lá, o grupo segue para a Vinícola Casa da Árvore a bordo de uma jardineira reformada</segment>
    <segment id="12">, onde acontece a visita ao parreiral com a colheita e a pisa das uvas.</segment>
    <segment id="13">O passeio é finalizado com um almoço no La Pasta</segment>
    <segment id="14">, um dos restaurantes do complexo Vila Don Patto especializado em pratos italianos.</segment>
    <segment id="15">O valor de R$ 345 inclui chapéu</segment>
    <segment id="16">, café da manhã e almoço.</segment>
    <segment id="17">Crianças de 4 a 11 anos pagam R$ 272.</segment>
    <segment id="18">Mais informações pelo Whatsapp: +55 11 97563-9637.</segment>
    <segment id="19">Participantes da vindima</segment>
    <segment id="20">, a colheita das uvas</segment>
    <segment id="21">, que acontece na Vinícola Don Patto</segment>
    <segment id="22">, em São Roque</segment>
    <segment id="23">, SP - DivulgaçãoHoje tem Master Series no Copacabana Palace</segment>
    <segment id="24">, no Rio</segment>
    <segment id="25">, com os chefs peruanos</segment>
    <segment id="26">Virgilio Martínez e Pía León do premiado restaurante Central</segment>
    <segment id="27">, localizado em Lima</segment>
    <segment id="28">, no Peru.</segment>
    <segment id="29">Eleito em 2022 o melhor restaurante da América Latina e o segundo melhor no ranking mundial do The World’s 50 Best Restaurants</segment>
    <segment id="30">, o Central apresenta uma cozinha que passeia pelos ecossistemas do seu país</segment>
    <segment id="31">, valorizando o que há de melhor do Pacífico aos Andes</segment>
    <segment id="32">, como</segment>
    <segment id="33">como algas</segment>
    <segment id="34">, frutos do mar e cacau.</segment>
    <segment id="35">J  á amanhã</segment>
    <segment id="36">, dia 2</segment>
    <segment id="37">, Nello Casesse</segment>
    <segment id="38">, chef executivo do Copa e do Ristorante Hotel Cipriani</segment>
    <segment id="39">, fecha o primeiro Master Series do ano com um menu especial onde vai apresentar criações inéditas baseadas na culinária tradicional italiana</segment>
    <segment id="40">comocomo o ravioli de pato</segment>
    <segment id="41">, cenoura e alface do mar e o leitão com salsa verde</segment>
    <segment id="42">, alcaçuz e batatas.</segment>
    <segment id="43">Os jantares fazem parte dos festejos dos 100 anos do Copacabana Palace</segment>
    <segment id="44">, celebrados neste ano</segment>
    <segment id="45">, e acontecem às 20h</segment>
    <segment id="46">, na Avenida Atlântica</segment>
    <segment id="47">, 1702</segment>
    <segment id="48">, Rio de Janeiro.</segment>
    <segment id="49">Mais informações e reservas: restaurantes.cop@belmond.com e (21)</segment>
    <segment id="50">2548-7070.</segment>
    <segment id="51">Salão do Ristorante Hotel Cipriani</segment>
    <segment id="52">, localizado junto à piscina do hotel Copacabana Palace</segment>
    <segment id="53">, no Rio de Janeiro - DivulgaçãoA Antica Salumeria é uma casa localizada na Rua Pamplona</segment>
    <segment id="54">, 1783</segment>
    <segment id="55">, Jardins</segment>
    <segment id="56">, e que produz uma linha de embutidos artesanais típicos italianos</segment>
    <segment id="57">, pães rústicos e especiais</segment>
    <segment id="58">comocomo tórtano de linguiça</segment>
    <segment id="59">, pão de ricota com pancetta</segment>
    <segment id="60">, crostatas</segment>
    <segment id="61">, grissinis e antepastos.</segment>
    <segment id="62">Os destaques ficam por conta da pancetta defumada (R$ 7</segment>
    <segment id="63">,90 - 100 g)</segment>
    <segment id="64">, do pastrami (R$ 20 - 100 g)</segment>
    <segment id="65">, do lombo defumado com limão siciliano (R$ 9</segment>
    <segment id="66">,50 - 100 g) e das linguiças defumadas (R$ 7</segment>
    <segment id="67">,90 - 100 g).</segment>
    <segment id="68">A casa também prepara belas tábuas personalizadas para festas e eventos com preços a partir de R$ 150.</segment>
    <segment id="69">A salumeria dispõe de um espaço confortável que pode ser usado desde o café da manhã até o happy hour</segment>
    <segment id="70">, onde são servidos desde matinais até sanduíches especiais –olha esse sanduba de bacon crocante!</segment>
    <segment id="71">– acompanhados de uma taça de vinho</segment>
    <segment id="72">; a adega conta com 20 rótulos.</segment>
    <segment id="73">Nesse domingo a casa terá uma porchetta pururucada</segment>
    <segment id="74">comocomo a grande atração</segment>
    <segment id="75">masmas as encomendas devem ser feitas até hoje.</segment>
    <segment id="76">Veja um preview aqui e resista</segment>
    <segment id="77">sese for capaz!</segment>
    <segment id="78">Contato: (11) 97276-8001.</segment>
    <segment id="79">Pancetta defumada artesanal da Antica Salumeria - DivulgaçãoO Guilhotina Bar lançou uma nova carta de drinques com o tema Antikamnia</segment>
    <segment id="80">, elaborada pelo mixologista Spencer Amereno.</segment>
    <segment id="81">Mas o que é o Antikamnia?</segment>
    <segment id="82">Trata-</segment>
    <segment id="83">sese de um medicamento que prometia ser um alívio para dores e febre</segment>
    <segment id="84">, produzido nos Estados Unidos em 1890 e cujo nome em grego significa "contra dores".</segment>
    <segment id="85">Mas o grande diferencial eram os produtos promocionais</segment>
    <segment id="86">comocomo calendários ilustrados por esqueletos criados pelo artista plástico Louis Crusius.</segment>
    <segment id="87">A nova carta traz 12 coquetéis autorais</segment>
    <segment id="88">, um para cada mês do ano.</segment>
    <segment id="89">O drinque que leva o nome da casa</segment>
    <segment id="90">,Antikamnia (R$ 47)</segment>
    <segment id="91">, representa o mês de maio e é feito com o gin Jardim Botânico</segment>
    <segment id="92">, Hidromel</segment>
    <segment id="93">, limão tahiti</segment>
    <segment id="94">, drambuie flambado com garnish de grade de mel.</segment>
    <segment id="95">Novembro traz o Analgesic</segment>
    <segment id="96">, com vodka com kinkan</segment>
    <segment id="97">, hortelã bicolor</segment>
    <segment id="98">, hortelã</segment>
    <segment id="99">, melão e limão siciliano.</segment>
    <segment id="100">Para acompanhar</segment>
    <segment id="101">, as dicas são o pulled pork na miniciabatta com picles de cebola roxa (R$ 32</segment>
    <segment id="102">,00) e o taki</segment>
    <segment id="103">, um sanduíche de polvo com vinagrete de cebola-roxa e coentro (R$ 45</segment>
    <segment id="104">,00).</segment>
    <segment id="105">O Guilhotina fica na Rua Costa Carvalho</segment>
    <segment id="106">, 84, Pinheiros</segment>
    <segment id="107">, telefone (11)</segment>
    <segment id="108">3031-0955.  Antikamnia</segment>
    <segment id="109">, drinque da nova carta de coquetéis do bar Guilhotina elaborada pelo mixologista Spencer Amereno - Divulgação</segment>
  </rst>
</analysis>