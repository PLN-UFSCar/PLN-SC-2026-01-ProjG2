  <rst>
    <segment id="1">Fernando Diniz não poderá contar com o atacante Marinho no jogo decisivo do Santos contra o Barcelona de Guayaquil</segment>
    <segment id="2">, nesta quarta-feira (26)</segment>
    <segment id="3">, às 21h</segment>
    <segment id="4">, pela última rodada da fase de grupos da Copa Libertadores.</segment>
    <segment id="5">Apesar de estar clinicamente recuperado de uma lesão na coxa esquerda</segment>
    <segment id="6">, o jogador ainda não readquiriu o condicionamento físico ideal para voltar a jogar.</segment>
    <segment id="7">Por isso</segment>
    <segment id="8">, ele nem viajou com a delegação santista para o Equador</segment>
    <segment id="9">, onde a partida será disputada.</segment>
    <segment id="10">O duelo será exibido pelo Fox Sports.</segment>
    <segment id="11">O camisa 11 sofreu uma lesão de grau 1 no dia 6 de maio</segment>
    <segment id="12">, no clássico contra o Palmeiras</segment>
    <segment id="13">, pela penúltima rodada da fase de grupos do Campeonato Paulista</segment>
    <segment id="14">, jogo vencido pelos palmeirenses por 3 a 2.</segment>
    <segment id="15">O atacante Marinho está fora do duelo com o Barcelona - Ivan Storti - 11.abr.21/Santos FC</segment>
    <segment id="16">A recuperação para esse tipo de contusão costuma durar</segment>
    <segment id="17">, em média</segment>
    <segment id="18">, dez dias.</segment>
    <segment id="19">Por isso</segment>
    <segment id="20">, a comissão técnica esperava poder contar com ele diante dos equatorianos.</segment>
    <segment id="21">A previsão</segment>
    <segment id="22">, agora</segment>
    <segment id="23">, é que ele possa estar em campo no próximo sábado (29)</segment>
    <segment id="24">, quando o Santos estreará no Campeonato Brasileiro</segment>
    <segment id="25">, diante do Bahia</segment>
    <segment id="26">, às 20h</segment>
    <segment id="27">, em Salvador.</segment>
    <segment id="28">Além de Marinho</segment>
    <segment id="29">, Alison e Jean Mota</segment>
    <segment id="30">, suspensos</segment>
    <segment id="31">, são baixas no elenco de Diniz.</segment>
    <segment id="32">Sem a presença do trio</segment>
    <segment id="33">, a escalação deverá ser a seguinte:</segment>
    <segment id="34">João Paulo</segment>
    <segment id="35">;</segment>
    <segment id="36">Pará, Kaiky</segment>
    <segment id="37">, Luan Peres e Felipe Jonatan</segment>
    <segment id="38">; Vinicius Balieiro</segment>
    <segment id="39">, Kevin Malthus e Gabriel Pirani</segment>
    <segment id="40">; Ângelo</segment>
    <segment id="41">, Kaio Jorge e Lucas Braga.</segment>
    <segment id="42">É com essa formação que o Santos tentará evitar o adeus à competição antes das oitavas de final.</segment>
    <segment id="43">Mas a missão não será fácil.</segment>
    <segment id="44">Para sobreviver</segment>
    <segment id="45">, além de vencer no Equador</segment>
    <segment id="46">, o time alvinegro precisa torcer por um tropeço do Boca Juniors (ARG) diante do The Strongest (BOL)</segment>
    <segment id="47">, na Argentina.</segment>
    <segment id="48">Uma vitória dos donos da casa na Bombonera acaba com qualquer chance da formação praiana.</segment>
    <segment id="49">No Grupo C</segment>
    <segment id="50">, o Barcelona já está classificado</segment>
    <segment id="51">, com dez pontos.</segment>
    <segment id="52">Na briga pela segunda vaga da chave no mata-mata</segment>
    <segment id="53">, o Boca</segment>
    <segment id="54">, com sete</segment>
    <segment id="55">, entra na rodada derradeira em vantagem sobre o Santos</segment>
    <segment id="56">, que soma seis.</segment>
    <segment id="57">O The Strongest também tem seis pontos</segment>
    <segment id="58">, masmas um saldo de gols muito ruim (-7).</segment>
    <segment id="59">A conta</segment>
    <segment id="60">, portanto</segment>
    <segment id="61">, é simples.</segment>
    <segment id="62">A equipe de Fernando Diniz só</segment>
    <segment id="63">sese classifica vencendo o Barcelona em Guayaquil e contando com um empate ou uma derrota do Boca diante do The Strongest.</segment>
  </rst>
</analysis>