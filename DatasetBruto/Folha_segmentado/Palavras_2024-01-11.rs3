  <rst>
    <segment id="1">Ziquizira inesperada no equipamento me levou a chamar meu técnico em computador.</segment>
    <segment id="2">Diante da emergência</segment>
    <segment id="3">, ele se</segment>
    <segment id="4">se despencou.</segment>
    <segment id="5">Clicando em velocidade</segment>
    <segment id="6">, fez todas aquelas operações em que milhares de letrinhas correm pela tela</segment>
    <segment id="7">, produzindo silvos e apitos</segment>
    <segment id="8">, e, quando pensei que iria</segment>
    <segment id="9">sese meter fisicamente pelas entranhas do bicho</segment>
    <segment id="10">, ele anunciou: "Prontinho.</segment>
    <segment id="11">Resolvido".</segment>
    <segment id="12">Aliviado</segment>
    <segment id="13">, bufei: "</segment>
    <segment id="14">O que era</segment>
    <segment id="15">?</segment>
    <segment id="16">Isso nunca aconteceu antes!</segment>
    <segment id="17">Como se</segment>
    <segment id="18">se explica?</segment>
    <segment id="19">".</segment>
    <segment id="20">Ele respondeu:</segment>
    <segment id="21">"</segment>
    <segment id="22">Não tem explicação.</segment>
    <segment id="23">Você pensa que computador é só matemática.</segment>
    <segment id="24">É macumba também".</segment>
    <segment id="25">Colunas e BlogsReceba no seu email uma seleção de colunas e blogs da FolhaCarregando...</segment>
    <segment id="26">Queria dizer que a informática não é uma ciência exata.</segment>
    <segment id="27">Pode ser também uma ciência mágica</segment>
    <segment id="28">, o que a aproximaria dos nossos próprios limites</segment>
    <segment id="29">, que nos impedem de saber por que algumas coisas são</segment>
    <segment id="30">comocomo são.</segment>
    <segment id="31">Comentei a história com uma amiga e disse que podia me render uma crônica.</segment>
    <segment id="32">Ela advertiu: "</segment>
    <segment id="33">Cuidado.</segment>
    <segment id="34">A palavra macumba foi cancelada.</segment>
    <segment id="35">É considerada pejorativa dos cultos afrobrasileiros".</segment>
    <segment id="36">Embatuquei.</segment>
    <segment id="37">Macumba é uma das mil palavras de origem afro que nos definem</segment>
    <segment id="38">comocomo falantes brasileiros da língua portuguesa.</segment>
    <segment id="39">Como dispensá-la apenas</segment>
    <segment id="40">porque</segment>
    <segment id="41">porque um ou outro a emprega com impropriedade?</segment>
    <segment id="42">Será enxotando-a da língua que iremos reabilitá-la?</segment>
    <segment id="43">Se sim</segment>
    <segment id="44">, todas as palavras</segment>
    <segment id="45">comocomo ela estarão um dia sujeitas ao opróbrio.</segment>
    <segment id="46">Exemplos:  Acarajé</segment>
    <segment id="47">, agogô</segment>
    <segment id="48">, angu</segment>
    <segment id="49">, axé, babá</segment>
    <segment id="50">, bagunça</segment>
