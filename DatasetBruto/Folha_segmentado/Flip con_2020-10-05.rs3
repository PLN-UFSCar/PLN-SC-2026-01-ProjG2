  <rst>
    <segment id="1">A Festa Liter&amp;aacute</segment>
    <segment id="2">;ria Internacional de Paraty confirmou que vai mesmo ter uma edi&amp;ccedil</segment>
    <segment id="3">;&amp;atilde</segment>
    <segment id="4">;o ainda neste ano</segment>
    <segment id="5">, masmas desta vez num formato totalmente virtual</segment>
    <segment id="6">, sem homenageado e sem curador.</segment>
    <segment id="7">O evento acontece a partir do dia 3 de dezembro</segment>
    <segment id="8">, com uma palestra da vencedora do &amp;uacute</segment>
    <segment id="9">;ltimo pr&amp;ecirc</segment>
    <segment id="10">;mio Booker</segment>
    <segment id="11">, Bernardine Evaristo</segment>
    <segment id="12">, e segue at&amp;eacute</segment>
    <segment id="13">;</segment>
    <segment id="14">o dia 6 de dezembro.</segment>
    <segment id="15">Al&amp;eacute</segment>
    <segment id="16">;m da escritora brit&amp;acirc</segment>
    <segment id="17">;nica, que lan&amp;ccedil</segment>
    <segment id="18">;a &amp;quot</segment>
    <segment id="19">;Garota</segment>
    <segment id="20">, Mulher</segment>
    <segment id="21">, Outras&amp;quot</segment>
    <segment id="22">; pela Companhia das Letras neste m&amp;ecirc</segment>
    <segment id="23">;s, tamb&amp;eacute</segment>
    <segment id="24">;m est&amp;atilde</segment>
    <segment id="25">;o confirmados no evento virtual a colombiana Pilar Quintana</segment>
    <segment id="26">, que deve ser publicada em breve por aqui pela Intr&amp;iacute</segment>
    <segment id="27">;nseca</segment>
    <segment id="28">, e o brasileiro Itamar Vieira Junior</segment>
    <segment id="29">, autor de &amp;quot</segment>
    <segment id="30">;Torto Arado&amp;quot</segment>
    <segment id="31">;, da Todavia.</segment>
    <segment id="32">Veja autores que falaram na Flip 2019   novamente         de   de  de  representando um  Liz Calder</segment>
    <segment id="33">, presidente do conselho da Flip</segment>
    <segment id="34">, afirma que a homenagem a um escritor seria incompat&amp;iacute</segment>
    <segment id="35">;vel com uma pandemia que trouxe tantas mortes ao mundo das artes.</segment>
    <segment id="36">&amp;quot;N&amp;atilde</segment>
    <segment id="37">;o teremos um autor espec&amp;iacute</segment>
    <segment id="38">;fico em destaque</segment>
    <segment id="39">, iremos homenagear coletivamente os que partiram&amp;rdquo</segment>
    <segment id="40">;, diz</segment>
    <segment id="41">, em nota.</segment>
    <segment id="42">Como adiantou a coluna</segment>
    <segment id="43">Painel das Letras</segment>
    <segment id="44">, a edi&amp;ccedil</segment>
    <segment id="45">;&amp;atilde</segment>
    <segment id="46">;o deste ano n&amp;atilde</segment>
    <segment id="47">;o ter&amp;aacute</segment>
    <segment id="48">; curador.</segment>
    <segment id="49">A nota divulgada pela Flip &amp;quot</segment>
    <segment id="50">;agradece a excelente participa&amp;ccedil</segment>
    <segment id="51">;&amp;atilde</segment>
    <segment id="52">;o de Fernanda</segment>
    <segment id="53">Diamant</segment>
    <segment id="54">comocomo curadora convidada&amp;quot</segment>
    <segment id="55">; e afirma ter dado seguimento ao trabalho feito por ela.</segment>
    <segment id="56">Diamant pediu demiss&amp;atilde</segment>
    <segment id="57">;o em agosto</segment>
    <segment id="58">, exortando a Flip a p&amp;ocirc</segment>
    <segment id="59">;r no seu lugar uma curadora negra que pudesse reinventar o evento.</segment>
    <segment id="60">Com a sa&amp;iacute</segment>
    <segment id="61">;da dela</segment>
    <segment id="62">, o festival abandonou a ideia de homenagear a poeta americana Elizabeth Bishop</segment>
    <segment id="63">, como</segment>
    <segment id="64">como estava nos planos.</segment>
    <segment id="65">Os convites internacionais idealizados por ela para a Flip que aconteceria presencialmente em julho em Paraty</segment>
    <segment id="66">, no litoral fluminense</segment>
    <segment id="67">, foram aproveitados pela equipe interna da Associa&amp;ccedil</segment>
    <segment id="68">;&amp;atilde</segment>
    <segment id="69">;o Casa Azul</segment>
    <segment id="70">, que organiza o evento.</segment>
    <segment id="71">A programa&amp;ccedil</segment>
    <segment id="72">;&amp;atilde</segment>
    <segment id="73">;o da festa ter&amp;aacute</segment>
    <segment id="74">; transmiss&amp;atilde</segment>
    <segment id="75">;o ao vivo numa plataforma pr&amp;oacute</segment>
    <segment id="76">;pria e nas redes sociais da Flip.</segment>
    <segment id="77">Tamb&amp;eacute</segment>
    <segment id="78">;m ser&amp;atilde</segment>
    <segment id="79">;o veiculados v&amp;iacute</segment>
    <segment id="80">;deos gravados previamente e a festa deve contar</segment>
    <segment id="81">, como</segment>
    <segment id="82">como de h&amp;aacute</segment>
    <segment id="83">;bito, com eventos e programa&amp;ccedil</segment>
    <segment id="84">;&amp;otilde</segment>
    <segment id="85">;es paralelos.</segment>
    <segment id="86">O comunicado divulgado pela Flip nesta segunda ressaltou que a receita da festa deste ano deve ter uma queda significativa.</segment>
    <segment id="87">A edi&amp;ccedil</segment>
    <segment id="88">;&amp;atilde</segment>
    <segment id="89">;o continua em fase de capta&amp;ccedil</segment>
    <segment id="90">;&amp;atilde</segment>
    <segment id="91">;o de recursos</segment>
    <segment id="92">, tendo patroc&amp;iacute</segment>
    <segment id="93">;nio do Ita&amp;uacute</segment>
    <segment id="94">; e da Secretaria Especial da Cultura do governo federal.</segment>
  </rst>
</analysis>