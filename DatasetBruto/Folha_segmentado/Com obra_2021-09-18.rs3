  <rst>
    <segment id="1">Enquanto aguarda o fim de uma obra no telhado de casa</segment>
    <segment id="2">, Tatá Werneck</segment>
    <segment id="3">sese mudou com o marido</segment>
    <segment id="4">, Rafa Vitti</segment>
    <segment id="5">, e a filha</segment>
    <segment id="6">, Clara Maria</segment>
    <segment id="7">, para a casa de Marcello Antony.</segment>
    <segment id="8">O ator</segment>
    <segment id="9">sese mudou para Portugal há mais de dois anos</segment>
    <segment id="10">, masmas mantém seu imóvel no Rio todo mobiliado.</segment>
    <segment id="11">"</segment>
    <segment id="12">Vi agora que tem matérias sobre o quarto da Clara: eu tô numa casa que aluguei do Marcello Antony</segment>
    <segment id="13">, o quarto é do filhos dele.</segment>
    <segment id="14">Tem até porta-retrato dos filhos aqui</segment>
    <segment id="15">, inclusive damos bom dia e boa noite sempre.</segment>
    <segment id="16">Essa casa toda é do Marcello Antony.</segment>
    <segment id="17">A Clara passa TODOS os dias pelos porta-retratos e diz 'papai não'.</segment>
    <segment id="18">Porque ela apontava falando papai e a gente tinha que explicar que no</segment>
    <segment id="19">casocaso era o Marcello Antony"</segment>
    <segment id="20">, contou a atriz.</segment>
    <segment id="21">Tatá Werneck em entrevista a Monica BergamoMais    novamente         de   de  de  representando um  PAPAI  Enzo</segment>
    <segment id="22">, 24 anos</segment>
    <segment id="23">, e Sophia</segment>
    <segment id="24">, 18, vão ganhar uma irmãzinha</segment>
    <segment id="25">, masmas ainda não da mãe</segment>
    <segment id="26">, Claudia Raia</segment>
    <segment id="27">, que tem falado em adotar uma criança.</segment>
    <segment id="28">Foi o pai</segment>
    <segment id="29">, Edson Celulari</segment>
    <segment id="30">, 63, que anunciou a gravidez de Karin Roepke</segment>
    <segment id="31">, 39, com quem é casado desde 2017.</segment>
    <segment id="32">“Estamos grávidos.</segment>
    <segment id="33">Queremos dividir essa alegria com vocês.</segment>
    <segment id="34">Nossa menina</segment>
    <segment id="35">, fruto de tanto amor</segment>
    <segment id="36">, vem para iluminar ainda mais a nossa jornada”</segment>
    <segment id="37">, publicaram Edson e Karin nas redes sociais.  FORÇA  Ana Maria Braga recebeu a mãe de Paulo Gustavo no “Mais Você” desta sexta-feira (17)</segment>
    <segment id="38">, Déa Lúcia</segment>
    <segment id="39">, que fez 74 anos.</segment>
    <segment id="40">No primeiro aniversário sem o filho</segment>
    <segment id="41">, que morreu em março em decorrência da Covid-19</segment>
    <segment id="42">, ela protestou contra o atrasona vacinação e disse que não tem o que comemorar.</segment>
    <segment id="43">Thales Brêtas</segment>
    <segment id="44">, viúvo do ator</segment>
    <segment id="45">, surpreendeu Déa ao entrar ao vivo</segment>
    <segment id="46">, via telão</segment>
    <segment id="47">, com com os netos da aniversariante</segment>
    <segment id="48">, Gael e Romeu.</segment>
    <segment id="49">Relembre alguns dos personagens de Paulo GustavoMais    novamente         de   de  de  representando um  LOIRA NO PÓDIO</segment>
    <segment id="50">“Blond Ambition” (“Ambição loira”</segment>
    <segment id="51">, em tradução livre)</segment>
    <segment id="52">, legendou Luísa Sonza nesta foto publicada em seu Instagram.</segment>
    <segment id="53">A cantora é uma das primeiras a</segment>
    <segment id="54">sese apresentar no MTV MIAW 2021 e lidera a lista de indicações a prêmios</segment>
    <segment id="55">, junto com Pabllo Vittar</segment>
    <segment id="56">, concorrendo a nove deles.</segment>
    <segment id="57">Em suas redes sociais</segment>
    <segment id="58">, Sonza compartilha publicações de fãs que estão fazendo mutirões de votação para “Doce 22”</segment>
    <segment id="59">, álbum da artista lançado recentemente.</segment>
    <segment id="60">Em segundo lugar vem Anitta</segment>
    <segment id="61">, que concorre em oito categorias</segment>
    <segment id="62">, seguida por Xamã</segment>
    <segment id="63">, em sete.</segment>
    <segment id="64">A premiação será na quinta-feira (23)</segment>
    <segment id="65">, às 22h</segment>
    <segment id="66">, pela MTV Brasil</segment>
    <segment id="67">Quando entrar Setembro</segment>
    <segment id="68">, as gatas aí estãoMais    novamente         de   de  de  representando um  ADEUS  Ao</segment>
    <segment id="69">sese despedir de James Bond</segment>
    <segment id="70">, o 007</segment>
    <segment id="71">, Daniel Craig foi às lágrimas.</segment>
    <segment id="72">À beira da estreia de “Sem Tempo para Morrer”</segment>
    <segment id="73">, no dia 30</segment>
    <segment id="74">, circula nas redes sociais um vídeo em que o ator</segment>
    <segment id="75">sese despede da equipe com quem trabalhou em cinco dos 25 filmes da franquia.</segment>
    <segment id="76">“Eu adorei cada segundo desses filmes”</segment>
    <segment id="77">, disse.</segment>
    <segment id="78">O ator britânico Daniel Craig- Photo by VICTOR CRUZ / AFPDEVOLUÇÃO</segment>
    <segment id="79">O ex-marido de Kaley Duoco</segment>
    <segment id="80">, 35 anos</segment>
    <segment id="81">, atriz da série “The Big Bang Theory”</segment>
    <segment id="82">, quer que ela lhe devolva as joias que ele lhe deu durante o casamento.</segment>
    <segment id="83">O pedido</segment>
    <segment id="84">, anexado ao processo de divórcio</segment>
    <segment id="85">, foi feito pelos advogados do empresário e cavaleiro profissional Karl Cook</segment>
    <segment id="86">, 30, segundo o site do canal TV Fox News.</segment>
    <segment id="87">A devolução atenderia a um acordo pré-nupcial rígido.</segment>
  </rst>
</analysis>