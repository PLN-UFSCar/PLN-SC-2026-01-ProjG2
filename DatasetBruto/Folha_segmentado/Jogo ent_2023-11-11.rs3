  <rst>
    <segment id="1">Uma invasão de campo</segment>
    <segment id="2">, seguida por uma briga generalizada entre torcedores de Coritiba e Cruzeiro interrompeu a partida entre as duas equipes na tarde deste sábado (11)</segment>
    <segment id="3">, no estádio Vila Capanema</segment>
    <segment id="4">, na capital do Paraná.</segment>
    <segment id="5">A confusão começou já nos acréscimos do segundo tempo</segment>
    <segment id="6">, quando Robson abriu o placar para os donos da casa</segment>
    <segment id="7">, completando um cruzamento a partir de uma cobrança de falta.</segment>
    <segment id="8">Imediatamente depois</segment>
    <segment id="9">, enquanto os jogadores ainda comemoravam</segment>
    <segment id="10">, parte da torcida do Cruzeiro invadiu o gramado.</segment>
    <segment id="11">Torcedores de Coritiba e Cruzeiro brigam no gramado da Vila Capanema - Reprodução/Premiere Assustados</segment>
    <segment id="12">, os jogadores deixaram o campo</segment>
    <segment id="13">, masmas torcedores do Coritiba</segment>
    <segment id="14">, em maior número</segment>
    <segment id="15">, também foram ao gramado para brigar com os mineiros.</segment>
    <segment id="16">Eles trocaram socos e chutes por alguns minutos</segment>
    <segment id="17">, até as forças de segurança dispersá-los.</segment>
    <segment id="18">Um torcedor teve de ser atendido na arquibancada e foi levado de maca pela equipe médica.</segment>
    <segment id="19">A partida foi suspensa momentaneamente pelo árbitro Bráulio da Silva Machado.</segment>
    <segment id="20">Depois que as torcidas foram tiradas do estádio</segment>
    <segment id="21">, a arbitragem resolveu retomar a partida.</segment>
    <segment id="22">Ainda havia seis minutos a</segment>
    <segment id="23">sese jogar.</segment>
    <segment id="24">O jogo foi retomada cerca de meia hora depois.</segment>
    <segment id="25">O tempo restante foi disputado</segment>
    <segment id="26">, sem alteração no placar</segment>
    <segment id="27">, que se</segment>
    <segment id="28">se manteve 1 a 0 para o Coritiba.</segment>
    <segment id="29">Ao final da partida</segment>
    <segment id="30">, o atacante Robson</segment>
    <segment id="31">, autor do único gol</segment>
    <segment id="32">, disse ao Premiere que a invasão é "algo triste de</segment>
    <segment id="33">sese ver".</segment>
    <segment id="34">Goleiro do Cruzeiro</segment>
    <segment id="35">, Rafael disse que fica triste com a invasão</segment>
    <segment id="36">, masmas que não teceria mais comentários sobre o assunto.</segment>
    <segment id="37">"</segment>
    <segment id="38">Mas vou falar o quê?</segment>
    <segment id="39">Se falar muito</segment>
    <segment id="40">, ainda me prejudico</segment>
    <segment id="41">"</segment>
    <segment id="42">, afirmou</segment>
    <segment id="43">, também ao canal.</segment>
    <segment id="44">Os dois clubes lutam contra o rebaixamento no Campeonato Brasileiro.</segment>
    <segment id="45">Antes do início da rodada</segment>
    <segment id="46">, o Coritiba tinha 26 pontos</segment>
    <segment id="47">, na penúltima colocação</segment>
    <segment id="48">, enquanto o Cruzeiro</segment>
    <segment id="49">, com 37</segment>
    <segment id="50">, era o 17º</segment>
    <segment id="51">, o primeiro dentro da parte vermelha da tabela.</segment>
    <segment id="52">As duas equipes jogavam na Vila Capanema</segment>
    <segment id="53">, estádio do Paraná Clube</segment>
    <segment id="54">, já que o Couto Pereira</segment>
    <segment id="55">, estádio do Coritiba</segment>
    <segment id="56">, receberá show da banda</segment>
    <segment id="57">Red Hot Chili Peppers.</segment>
    <segment id="58">Briga no gramado da Vila Capanema entre torcedores do Coritiba e do Cruzeiro - Joka Madruga/Futura Press/Folhapress</segment>
  </rst>
</analysis>