  <rst>
    <segment id="1">Em clima de comemoração</segment>
    <segment id="2">, Camilla de Lucas completou 27 anos na quarta-feira (13) jogando queimada com os amigos mais próximos.</segment>
    <segment id="3">A influenciadora começou a celebrar o aniversário no dia das crianças</segment>
    <segment id="4">, quando distribuiu maquiagens e roupas para os adolescentes do condomínio onde mora.</segment>
    <segment id="5">A apresentadora agradeceu aos pais pelo aprendizado e disse estar pronta para novos desafios.</segment>
    <segment id="6">“</segment>
    <segment id="7">A jornada dos 26 foi a melhor da minha vida…</segment>
    <segment id="8">Me arrisquei</segment>
    <segment id="9">, me descobri</segment>
    <segment id="10">, coloquei a julgamento meu caráter</segment>
    <segment id="11">, expus a construção da minha vida para milhões de pessoas e estou certa de que esses 26 anos foram muito bem transmitidos”.</segment>
    <segment id="12">Parabenizada por famosos</segment>
    <segment id="13">comocomo Fernanda Gentil</segment>
    <segment id="14">, Flávia Alessandra</segment>
    <segment id="15">, Maisa</segment>
    <segment id="16">, Jéssica Ellen e os brothers Gil</segment>
    <segment id="17">, Juliette e Viih Tube</segment>
    <segment id="18">, a ex-BBB 21 completou:</segment>
    <segment id="19">“Estou curiosa para ver as experiências que a vida vai me dar.</segment>
    <segment id="20">Só desejo que venha com muita saúde</segment>
    <segment id="21">, alegria</segment>
    <segment id="22">, paz, dinheiro e felicidade!</segment>
    <segment id="23">".</segment>
    <segment id="24">Na próxima terça-feira (19)</segment>
    <segment id="25">, Camilla encerra seu primeiro trabalho</segment>
    <segment id="26">comocomo apresentadora</segment>
    <segment id="27">, com a final do The Masked Singer Brasil</segment>
    <segment id="28">, disputada entre a Arara</segment>
    <segment id="29">, a Gata Espelhada</segment>
    <segment id="30">, o Monstro e o Unicórnio.</segment>
    <segment id="31">Elas desfilam na sua telaMais    novamente         de   de  de  representando um    DESABAFO  Depois de ter o rompimento de seu namoro com Bruno Magri apontado</segment>
    <segment id="32">comocomo marketing</segment>
    <segment id="33">, Viih Tube</segment>
    <segment id="34">, 21 anos</segment>
    <segment id="35">, desabafou nas redes sociais: "</segment>
    <segment id="36">Até no término a gente tem que ler de tudo (...) não vai ter uma fanfic para vocês".</segment>
    <segment id="37">Segundo a influenciadora</segment>
    <segment id="38">, o fim</segment>
    <segment id="39">sese deve às mudanças que os dois viveram durante sua estadia no BBB: "</segment>
    <segment id="40">Depois do confinamento</segment>
    <segment id="41">, eu mudei muito</segment>
    <segment id="42">, as minhas ideias mudaram</segment>
    <segment id="43">, as dele também".</segment>
    <segment id="44">POPULAR  Anitta</segment>
    <segment id="45">, 28 anos</segment>
    <segment id="46">, participou da festa de aniversário de 29 anos da rapper Cardi B</segment>
    <segment id="47">, que aconteceu em Los Angeles</segment>
    <segment id="48">, nos Estados Unidos</segment>
    <segment id="49">, na segunda-feira (11).</segment>
    <segment id="50">Embora não tenha publicado nas redes sociais</segment>
    <segment id="51">, a cantora foi vista saindo do local na madrugada de terça</segment>
    <segment id="52">, além de ter sido marcada em uma foto ao lado da modelo Winnie Harlow</segment>
    <segment id="53">, 27, na quarta (13).</segment>
    <segment id="54">Modelo Winnie Harlow e Annita em seu instagram - @winnieharlow  ASSALTO  Luísa Sonza</segment>
    <segment id="55">, 23 anos</segment>
    <segment id="56">, foi assaltada na noite de terça (12)</segment>
    <segment id="57">, em São Paulo.</segment>
    <segment id="58">A assessoria da cantora disse que ela está bem</segment>
    <segment id="59">, e não divulgou detalhes do ocorrido.</segment>
    <segment id="60">Segundo o colunista Leo Dias</segment>
    <segment id="61">, do Metrópoles</segment>
    <segment id="62">, homens renderam a cantora e seus amigos em uma farmácia e roubaram o celular dela</segment>
    <segment id="63">, além de pertences de outras vítimas.</segment>
    <segment id="64">Luísa Sonza lança &amp;#</segment>
    <segment id="65">039;Doce 22&amp;#039</segment>
    <segment id="66">;Mais    novamente         de   de  de  representando um    FRASE  "</segment>
    <segment id="67">A minha arma foi a arte.</segment>
    <segment id="68">A minha possibilidade de mostrar ao universo que eu existia foi a arte</segment>
    <segment id="69">, com o saber da educação.</segment>
    <segment id="70">"  Jonathan</segment>
    <segment id="71">Azevedo</segment>
    <segment id="72">ao canal Fala</segment>
    <segment id="73">, Célio  REENCONTRO  Angelina Jolie</segment>
    <segment id="74">, 46 anos</segment>
    <segment id="75">, foi vista com seu primeiro ex-marido</segment>
    <segment id="76">, o ator Jonny Lee Miller</segment>
    <segment id="77">, 48, em um jantar</segment>
    <segment id="78">, em Beverlly Hills.</segment>
    <segment id="79">Segundo o jornal Daily Mail</segment>
    <segment id="80">, o encontro aconteceu na segunda-feira (11) e gerou rumores sobre uma possível reconciliação amorosa entre os dois.</segment>
    <segment id="81">Em seguida</segment>
    <segment id="82">, a atriz teria ido</segment>
    <segment id="83">embora</segment>
    <segment id="84">embora no banco do passageiro</segment>
    <segment id="85">, enquanto Miller dirigia o carro.</segment>
    <segment id="86">DEFESA  Letitia Wright</segment>
    <segment id="87">, a princesa Shuri em “Pantera Negra”</segment>
    <segment id="88">, negou ter atitudes antivacina nos bastidores do segundo filme</segment>
    <segment id="89">, “Wakanda Forever”.</segment>
    <segment id="90">A atriz</segment>
    <segment id="91">sese defendeu em seu Instagram</segment>
    <segment id="92">, em resposta ao jornal The Hollywood Reporter: "</segment>
    <segment id="93">Eu honestamente afirmo que isso é completamente falso (...)</segment>
    <segment id="94">eu trabalho duro e meu foco principal é sempre fazer um trabalho que seja impactante e inspirador"</segment>
    <segment id="95">, afirmou.</segment>
