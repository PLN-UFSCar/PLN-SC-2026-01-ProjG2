  <rst>
    <segment id="1">O MIS (Museu da Imagem e do Som) irá realizar no mês de março uma mostra de cinema em homenagem à atriz e produtora Frances McDormand.</segment>
    <segment id="2">O filme "Nomaland"</segment>
    <segment id="3">, vencedor do Oscar e protagonizado pela artista</segment>
    <segment id="4">, está entre as 15 produções que serão exibidas na instituição.</segment>
    <segment id="5">Veja cenas de &amp;#039</segment>
    <segment id="6">;Nomadland&amp;#039</segment>
    <segment id="7">;, sobre americanos que vivem</segment>
    <segment id="8">sese mudando em busca de trabalhoMais    novamente         de   de  de  representando um  LEIA</segment>
    <segment id="9">TODOS OS TEMAS ABORDADOS PELA COLUNA NA EDIÇÃO</segment>
    <segment id="10">IMPRESSA</segment>
    <segment id="11">DESTA SEGUNDA (18)Depois de Frias em NY</segment>
    <segment id="12">, braço direito de secretário gasta R$ 20 mil em viagem de 5 dias para Los AngelesGreengo</segment>
    <segment id="13">Dictionary entra no catálogo de influenciadores da agência de Felipe NetoFundação Casa gasta R$ 800 mil em sala para monitorar jovens</segment>
    <segment id="14">internadosMIS fará mostra em homenagem à atriz Frances McDormand em marçoSextante lança novo livro de Marie Kondo em marçoGiulia</segment>
    <segment id="15">Be lança single &amp;#039</segment>
    <segment id="16">;2 Palabras&amp;#039</segment>
    <segment id="17">;, gravado em espanhol</segment>
    <segment id="18">, na próxima sexta (25)  SOM</segment>
    <segment id="19">A cantora Giulia Be durante a gravação do videoclipe de seu novo single</segment>
    <segment id="20">, &amp;#039</segment>
    <segment id="21">;2 Palabras&amp;#039</segment>
    <segment id="22">; - João Viegas/DivulgaçãoA cantora Giulia Be lança na próxima sexta (25) o single "2 Palabras"</segment>
    <segment id="23">, gravado em espanhol.</segment>
    <segment id="24">A faixa</segment>
    <segment id="25">, que fala sobre amor e desejo</segment>
    <segment id="26">, ganhará um videoclipe em que Giulia contracena com o ator Rômulo Arantes Neto.</segment>
    <segment id="27">Segundo a artista</segment>
    <segment id="28">, a composição foi inspirada na série "Gossip Girl"</segment>
    <segment id="29">, enquanto o clipe contém referências do filme "Closer" (2004).</segment>
    <segment id="30">A produção audiovisual será exibida pela primeira vez numa festa para convidados em Miami</segment>
    <segment id="31">, na quinta-feira (22).  com BIANKA VIEIRA e MANOELLA SMITH</segment>
