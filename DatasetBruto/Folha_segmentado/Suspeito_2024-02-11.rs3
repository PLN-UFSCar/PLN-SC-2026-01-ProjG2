  <rst>
    <segment id="1">O cubano Alejandro Prevez</segment>
    <segment id="2">, de 30 anos</segment>
    <segment id="3">, suspeito de matar a facadas o galerista americano Brent Sikkema</segment>
    <segment id="4">, que tinha 75 anos</segment>
    <segment id="5">, planejou o crime por um ano</segment>
    <segment id="6">, aponta a polícia.</segment>
    <segment id="7">Informações de um relatório policial ao qual a Folha teve acesso indicam</segment>
    <segment id="8">, ainda</segment>
    <segment id="9">, que uma tentativa frustrada de assassinato aconteceu em dezembro passado.</segment>
    <segment id="10">Alejandro Prevez segura a besta com a qual pretendia matar a vítima</segment>
    <segment id="11">, segundo seu depoimento - ReproduçãoA tentativa teria ocorrido numa segunda invasão da residência do galerista no Rio de Janeiro.</segment>
    <segment id="12">Prevez entrou no sobrado no dia 11 de dezembro de 2023</segment>
    <segment id="13">, masmas Brent Sikkema estava dormindo no quarto com a porta trancada com chave.</segment>
    <segment id="14">Nesse dia</segment>
    <segment id="15">, Prevez enviou uma mensagem a Daniel Sikkema</segment>
    <segment id="16">, de 53 anos</segment>
    <segment id="17">, ex-marido do galerista que teve a prisão decretada por ter supostamente encomendado o crime</segment>
    <segment id="18">, perguntando</segment>
    <segment id="19">comocomo proceder</segment>
    <segment id="20">, já que não tinha acesso à vítima.</segment>
    <segment id="21">O galerista Brent SikkemaMais    novamente         de   de  de  representando um</segment>
    <segment id="22">Enquanto isso</segment>
    <segment id="23">, fez uma selfie na cozinha</segment>
    <segment id="24">, sorrindo.</segment>
    <segment id="25">Daniel</segment>
    <segment id="26">, por sua vez</segment>
    <segment id="27">, recomendou que ele pensasse em uma forma de tirar Brent Sikkema do quarto.</segment>
    <segment id="28">O cubano</segment>
    <segment id="29">, então</segment>
    <segment id="30">, desligou o disjuntor da casa.</segment>
    <segment id="31">A falta de luz</segment>
    <segment id="32">, porém</segment>
    <segment id="33">porém, não tirou o galerista do quarto</segment>
    <segment id="34">, e Prevez</segment>
    <segment id="35">, de alguma forma</segment>
    <segment id="36">, percebeu que o americano estava mexendo no celular.</segment>
    <segment id="37">Receoso</segment>
    <segment id="38">, o cubano alertou Daniel</segment>
    <segment id="39">, por mensagem</segment>
    <segment id="40">, que sairia do local por receio de o galerista estar chamando a polícia.</segment>
  </rst>
