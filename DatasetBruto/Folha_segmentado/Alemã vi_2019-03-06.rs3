  <rst>
    <segment id="1">A alemã Andrea David</segment>
    <segment id="2">, 41, viaja o mundo para conhecer na vida real cenários da ficção</segment>
    <segment id="3">, como</segment>
    <segment id="4">como o castelo de Hogwarts</segment>
    <segment id="5">, dos filmes de "Harry Potter"</segment>
    <segment id="6">, na Inglaterra</segment>
    <segment id="7">, ou o Grande Septo de Baelor</segment>
    <segment id="8">, da série "Game of Thrones"</segment>
    <segment id="9">, na Espanha.</segment>
    <segment id="10">Desde 2004</segment>
    <segment id="11">, ela já visitou mais de 50 países para retratar locais em que cenas foram gravadas.</segment>
    <segment id="12">Para identificar as obras</segment>
    <segment id="13">, Andrea “encaixa” na paisagem imagens com trechos dos filmes ou séries.</segment>
    <segment id="14">Alemã viaja o mundo atrás de cenários de filmes   novamente         de   de  de  representando um  Andrea teve a ideia de unir suas viagens com os filmes durante o curso de gestão de turismo.</segment>
    <segment id="15">Cinéfila</segment>
    <segment id="16">, ela pesquisou sobre a influência dos filmes na escolha dos destinos de viagem para a sua tese de conclusão.</segment>
    <segment id="17">“Decidi compartilhar as minhas experiências em 2007 e muita gente me agradeceu</segment>
    <segment id="18">porque</segment>
    <segment id="19">porque tiveram novas ideias de viagem.</segment>
    <segment id="20">Isso me motivou a continuar”</segment>
    <segment id="21">, diz Andrea.</segment>
    <segment id="22">Hoje, seu perfil no Instagram</segment>
    <segment id="23">, @filmtourismus</segment>
    <segment id="24">, tem mais de 340 mil seguidores.</segment>
    <segment id="25">Entre os cenários fotografados estão os de produções</segment>
    <segment id="26">comocomo "Star Wars"</segment>
    <segment id="27">, "Esqueceram de mim"</segment>
    <segment id="28">, "Forrest Gump"</segment>
    <segment id="29">, "La La Land"</segment>
    <segment id="30">, "</segment>
    <segment id="31">O Artista"</segment>
    <segment id="32">, "Harry Potter" e "Game Of Thrones".</segment>
    <segment id="33">As imagens publicadas são simples</segment>
    <segment id="34">, masmas exigem muita pesquisa.</segment>
    <segment id="35">Muitas vezes ela compara as cenas do filme com imagens da plataforma Google Street View.</segment>
    <segment id="36">Andrea também conta com informações dos moradores locais e de pontos de ajuda aos turistas.</segment>
    <segment id="37">“É um trabalho de detetive”</segment>
    <segment id="38">, diz Andrea</segment>
    <segment id="39">, que é fã do ator Matt Damon e dos diretores Steven Spielberg</segment>
    <segment id="40">, Quentin Tarantino e Christopher Nolan.</segment>
    <segment id="41">Sua maior dificuldade</segment>
    <segment id="42">, conta</segment>
    <segment id="43">, é que muitos dos locais de filmagem ficam em lugares privados.</segment>
    <segment id="44">“Em Malta eu queria visitar o lugar onde o rei Joffrey julgou Ned Stark [personagens de Game of Thrones].</segment>
    <segment id="45">O local não é aberto ao público</segment>
    <segment id="46">, masmas no último dia</segment>
    <segment id="47">,  bem antes de ir ao aeroporto</segment>
    <segment id="48">, um homem da comissão de filmes de Malta achou alguém para abrir a porta para mim.</segment>
    <segment id="49">Eu só tive um minuto para fazer a fotografia”</segment>
    <segment id="50">, conta.</segment>
    <segment id="51">Andrea não conhece o Brasil</segment>
    <segment id="52">, masmas quer visitar as Cataratas do Iguaçu e o Rio de Janeiro</segment>
    <segment id="53">, onde ela lembra que foi gravado o filme "007 contra o Foguete da Morte".</segment>
    <segment id="54">“</segment>
    <segment id="55">Já assisti tantos filmes e séries que tenho uma longa lista de destinos para viajar.</segment>
    <segment id="56">Com os novos lançamentos essa lista só fica maior e maior”</segment>
    <segment id="57">, afirma.</segment>
  </rst>
</analysis>