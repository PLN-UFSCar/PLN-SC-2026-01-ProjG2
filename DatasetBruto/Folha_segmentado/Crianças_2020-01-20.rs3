  <rst>
    <segment id="1">Famílias com crianças de colo e cartazes pedindo esmola nas ruas tornaram-</segment>
    <segment id="2">sese uma cena comum em Cuiabá.</segment>
    <segment id="3">Semáforos próximos a shoppings são as regiões preferidas dos grupos</segment>
    <segment id="4">, formados principalmente por venezuelanos que</segment>
    <segment id="5">, desde 2018</segment>
    <segment id="6">, chegam todos os dias a Mato Grosso.</segment>
    <segment id="7">Só em 2019 o estado recebeu mais de mil imigrantes do país vizinho.</segment>
    <segment id="8">A maioria trouxe os filhos.</segment>
    <segment id="9">No dia a dia</segment>
    <segment id="10">, as crianças muitas vezes ficam correndo entre os carros</segment>
    <segment id="11">, enquanto os pais recolhem a ajuda oferecida pelos motoristas.</segment>
    <segment id="12">Mães venezuelanas com filhos na Casa do Migrante</segment>
    <segment id="13">, em Cuiabá - Juliana Arini/FolhapressDesde novembro passado</segment>
    <segment id="14">, menores de idade indígenas da etnia warao</segment>
    <segment id="15">, também vindos do país vizinho</segment>
    <segment id="16">, sese juntaram aos demais que fugiram do caos econômico e político.</segment>
    <segment id="17">Para o Ministério Público Estadual</segment>
    <segment id="18">, a situação dessas crianças é de alto risco.</segment>
    <segment id="19">O órgão tem orientado conselheiros tutelares para abordarem as famílias</segment>
    <segment id="20">, pedindo que não levem as crianças para a rua.</segment>
    <segment id="21">"</segment>
    <segment id="22">Mas a maioria dos adultos fogem assustados</segment>
    <segment id="23">, por causa da dificuldade de comunicação</segment>
    <segment id="24">, quando os vê.</segment>
    <segment id="25">E nas escolas de Cuiabá não há vagas para todos"</segment>
    <segment id="26">, diz Davino Mario de Arruda</segment>
    <segment id="27">, coordenador-geral dos conselheiros da cidade.</segment>
    <segment id="28">"</segment>
    <segment id="29">Ter uma criança ao lado sensibiliza mais</segment>
    <segment id="30">, e já flagramos situações em que os menores são filhos de conhecidos</segment>
    <segment id="31">, não dos adultos que estavam com eles.</segment>
    <segment id="32">Mas não temos ainda condições de intervenções maiores</segment>
    <segment id="33">, só orientá-los".</segment>
    <segment id="34">A promotora de Justiça Valnice Silva dos Santos</segment>
    <segment id="35">, que criou a força-tarefa para acompanhar as crianças venezuelanas</segment>
    <segment id="36">, reconhece que ações de orientação são insuficientes.</segment>
    <segment id="37">"É necessária uma política pública do migrante"</segment>
    <segment id="38">, afirma.</segment>
    <segment id="39">Entre imigrantes que recorrem à mendicância</segment>
    <segment id="40">, os indígenas estão em maior número.</segment>
    <segment id="41">Apenas em um acampamento perto da rodoviária estão cinco crianças do povo warao</segment>
    <segment id="42">, original do delta do rio Orinoco</segment>
    <segment id="43">, no norte da Venezuela.</segment>
    <segment id="44">"Somos todos da mesma família.</segment>
    <segment id="45">Estou com minha sogra e meus tios</segment>
    <segment id="46">, chegamos de Manaus"</segment>
    <segment id="47">, diz Diana Warao</segment>
    <segment id="48">, uma das que lideram o grupo.</segment>
    <segment id="49">As crianças</segment>
    <segment id="50">, de diversas idades</segment>
    <segment id="51">, passam o dia entre as ruas e as redes armadas no local improvisado</segment>
    <segment id="52">, e estão todas fora da escola.</segment>
    <segment id="53">"</segment>
    <segment id="54">Não temos documentos"</segment>
    <segment id="55">, afirma Diana.</segment>
    <segment id="56">"</segment>
    <segment id="57">Me ajude</segment>
    <segment id="58">, sou venezuelano</segment>
    <segment id="59">, preciso de emprego e comida" era a frase</segment>
    <segment id="60">, em português</segment>
    <segment id="61">, escrita em um cartaz por Germano Warao</segment>
    <segment id="62">, que, com grande dificuldade de comunicação</segment>
    <segment id="63">, explica que domina pouco o espanhol.</segment>
    <segment id="64">Ele lidera um grupo de indígenas que fica diariamente em um viaduto próximo à UFMT (Universidade Federal do Mato Grosso)</segment>
    <segment id="65">, em uma avenida movimentada.</segment>
    <segment id="66">"</segment>
    <segment id="67">Ninguém nos emprega"</segment>
    <segment id="68">, explica-</segment>
    <segment id="69">sese, ao ser questionado sobre a mendicância.</segment>
    <segment id="70">"</segment>
    <segment id="71">Só nos resta o 'recaudito'"</segment>
    <segment id="72">, diz, em referência às esmolas.</segment>
    <segment id="73">Apenas um abrigo recebe os venezuelanos que chegam a Cuiabá</segment>
    <segment id="74">, a Casa do Migrante.</segment>
    <segment id="75">O local</segment>
    <segment id="76">, porém</segment>
    <segment id="77">porém, está lotado.</segment>
    <segment id="78">Na época do Natal</segment>
    <segment id="79">, houve fila de espera e alguns dormiram na rua por falta de vagas.</segment>
    <segment id="80">Atualmente são 120 abrigados</segment>
    <segment id="81">; a lotação é de 100 leitos.</segment>
    <segment id="82">A casa existe há três décadas e foi construída com dinheiro da Caritas Pastoral do Migrante para atender estrangeiros em situações de exílio.</segment>
    <segment id="83">Índios fogem da crise na Venezuela   novamente         de   de  de  representando um</segment>
    <segment id="84">Em 2019</segment>
    <segment id="85">, mais de mil venezuelanos passaram pelo abrigo.</segment>
    <segment id="86">A capital mato-grossense é ponto de acolhida de venezuelanos desde 2018</segment>
    <segment id="87">, quando</segment>
    <segment id="88">, a pedido da ONU</segment>
    <segment id="89">, entrou no rol de cidades aptas a recebê-los.</segment>
    <segment id="90">"</segment>
    <segment id="91">Estamos tentando recursos para construir um segundo abrigo</segment>
    <segment id="92">, masmas ainda é um projeto"</segment>
    <segment id="93">, explica Eliane Vitalino</segment>
    <segment id="94">, coordenadora do local.</segment>
    <segment id="95">O retorno às ruas é um fantasma para os abrigados com filhos.</segment>
    <segment id="96">"</segment>
    <segment id="97">Chegamos a andar com as crianças por mais de 300 km através do deserto do Equador para chegar ao Peru.</segment>
    <segment id="98">Um dos meus filhos nasceu nas ruas"</segment>
    <segment id="99">, conta o venezuelano Keny Ottoniel Esteves Navarro</segment>
    <segment id="100">, pai de Samuel Abraham</segment>
    <segment id="101">, 3, e Aaron Ottoniel</segment>
    <segment id="102">, 1.</segment>
    <segment id="103">A família passou por três países até chegar ao Brasil.</segment>
    <segment id="104">Os abrigados vivem uma corrida por doações. "</segment>
    <segment id="105">Meu marido conseguiu um emprego</segment>
    <segment id="106">, masmas precisamos de estrutura e vamos</segment>
    <segment id="107">embora</segment>
    <segment id="108">embora do abrigo amanhã"</segment>
    <segment id="109">, diz Majuri Rivas Bernais</segment>
    <segment id="110">, mãe de um bebê de dez meses.</segment>
    <segment id="111">"</segment>
    <segment id="112">Agora só preciso de duas camas.</segment>
    <segment id="113">Já conseguimos tudo.</segment>
    <segment id="114">"</segment>
  </rst>
</analysis>