  <rst>
    <segment id="1">Na praia da Barra do Sahy</segment>
    <segment id="2">, litoral norte de São Paulo</segment>
    <segment id="3">, placas do Corpo de Bombeiros</segment>
    <segment id="4">, a água barrenta e alguns galhos denunciam que o local foi acometido por fortes chuvas.</segment>
    <segment id="5">Porém, o local</segment>
    <segment id="6">, que fica próximo da Vila do Sahy</segment>
    <segment id="7">, região mais afetada pelas tempestades do último fim de semana</segment>
    <segment id="8">, não tem tantas marcas da tragédia quanto a praia da Baleia.</segment>
    <segment id="9">Localizada a menos de 3 km da praia do Sahy</segment>
    <segment id="10">, a Baleia é conhecida pela concentração de casas de veraneio luxuosas e condomínios de alto padrão ainda em construção.</segment>
    <segment id="11">Na foto a Praia da Baleia</segment>
    <segment id="12">, em São Sebastião</segment>
    <segment id="13">, que após o temporal do ultimo fim de semana ficou cheia de galhos e arvores na faixa de areia - Bruno Santos/FolhapressNa praia</segment>
    <segment id="14">, troncos de árvores agora compõem o cenário do local</segment>
    <segment id="15">, assim</segment>
    <segment id="16">comocomo sujeira localizada na beira do mar.</segment>
    <segment id="17">Uma turista</segment>
    <segment id="18">, que alugou a casa para passar a semana do Carnaval e prefere não ser identificada</segment>
    <segment id="19">, era uma das poucas pessoas que tomava sol no local.</segment>
    <segment id="20">De maiô</segment>
    <segment id="21">, saída de banho e viseira</segment>
    <segment id="22">, ela comentava</segment>
    <segment id="23">comocomo o local</segment>
    <segment id="24">sese assemelha agora com um "cenário de guerra".</segment>
    <segment id="25">Alguns que andam pela praia de bicicleta precisam desviar dos troncos e detritos.</segment>
    <segment id="26">Outros poucos</segment>
    <segment id="27">sese arriscavam a surfavar.</segment>
    <segment id="28">O vendedor de queijinho Gilvan Pereira da Silva</segment>
    <segment id="29">, 36, foi até a praia no início da tarde deste sábado (25) para registrar algumas imagens do local.</segment>
    <segment id="30">Ele vive na Baleia Verde</segment>
    <segment id="31">, perto da praia</segment>
    <segment id="32">, e perdeu a casa que alugava.</segment>
    <segment id="33">Oásis de ricos</segment>
    <segment id="34">, praia da Baleia agora é cheia de destroços de árvoresMais    novamente         de   de  de  representando um  Além do imóvel</segment>
    <segment id="35">, Gilvan viu a água destruir os insumos do trabalho: queijinho</segment>
    <segment id="36">, pão de alho</segment>
    <segment id="37">, carne</segment>
    <segment id="38">, linguiça.</segment>
    <segment id="39">"</segment>
    <segment id="40">Só o carrinho que eu não perdi.</segment>
    <segment id="41">Consegui salvar só RG e CPF"</segment>
    <segment id="42">, disse ele</segment>
    <segment id="43">, que vivia de aluguel.</segment>
    <segment id="44">A enxurrada invadiu sua casa e formou diversas rachaduras.</segment>
    <segment id="45">Desde aquela trágica noite</segment>
    <segment id="46">, ele está abrigado na escola municipal de Barra do Sahy.</segment>
    <segment id="47">"</segment>
    <segment id="48">Tem muita gente</segment>
    <segment id="49">, gritaria</segment>
    <segment id="50">, muita criança.</segment>
    <segment id="51">Não dá para dormir e nem descansar muito.</segment>
    <segment id="52">"</segment>
    <segment id="53">Gilvan planejava juntar R$ 2.000 para viajar para a região Norte do país</segment>
    <segment id="54">, onde sua mãe vive.</segment>
    <segment id="55">Ele não a visita há cinco anos.</segment>
    <segment id="56">"</segment>
    <segment id="57">Queria usar o Carnaval para juntar esse dinheiro.</segment>
    <segment id="58">Agora, não tem mais</segment>
    <segment id="59">comocomo ir.</segment>
    <segment id="60">"  Sem trabalho e nem perspectiva</segment>
    <segment id="61">, ele diz que está sobrevivendo com doações</segment>
    <segment id="62">, como</segment>
    <segment id="63">como marmitex.</segment>
    <segment id="64">"</segment>
    <segment id="65">Quando acabar</segment>
    <segment id="66">, vamos viver do quê?</segment>
    <segment id="67">Não dá para trabalhar"</segment>
    <segment id="68">, diz ele</segment>
    <segment id="69">, que vive há oito anos no litoral norte.</segment>
    <segment id="70">Neste sábado</segment>
    <segment id="71">, ele aguardava a chegada de doações de móveis para ver</segment>
    <segment id="72">sese conseguia algo para montar uma casa.</segment>
    <segment id="73">"</segment>
    <segment id="74">Agora, dependo de ajuda de governo.</segment>
    <segment id="75">Não tenho para onde ir.</segment>
    <segment id="76">"</segment>
    <segment id="77">Segundo o Corpo de Bombeiros</segment>
    <segment id="78">, foram encontrados</segment>
    <segment id="79">, até a manhã deste domingo</segment>
    <segment id="80">, 64 corpos: 63 em São Sebastião e 1 em Ubatuba.</segment>
    <segment id="81">Equipes de psicólogas e assistentes sociais fazem um trabalho de acolhimento dos familiares das vítimas.</segment>
    <segment id="82">.</segment>
  </rst>
</analysis>