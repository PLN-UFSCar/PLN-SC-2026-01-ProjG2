  <rst>
    <segment id="1">Um trem na Holanda descarrilou após colidir com um guindaste na madrugada desta terça-feira (4)</segment>
    <segment id="2">, matando o operador do equipamento e ferindo ao menos 30 passageiros</segment>
    <segment id="3">, incluindo 19 com gravidade.</segment>
    <segment id="4">O acidente aconteceu por volta das 3h25 do horário local (22h25 da véspera</segment>
    <segment id="5">, no horário de Brasília) no vilarejo de Voorschoten</segment>
    <segment id="6">, a oito quilômetros de Haia —destino final do comboio.</segment>
    <segment id="7">Vagões de trem que descarrilou ao colidir com materiais de construção em trilho em Voorschoten</segment>
    <segment id="8">, vilarejo próximo de Haia</segment>
    <segment id="9">, na Holanda - Pascal Rossignol/Reuters</segment>
    <segment id="10">Cerca de 60 passageiros estavam a bordo no momento do ocorrido.</segment>
    <segment id="11">Serviços de emergência encaminharam os feridos em estado grave</segment>
    <segment id="12">, incluindo o condutor do comboio</segment>
    <segment id="13">, que sofreu várias fraturas</segment>
    <segment id="14">, para um hospital local e trataram os demais em residências próximas.</segment>
    <segment id="15">Imagens mostram que</segment>
    <segment id="16">, após o choque</segment>
    <segment id="17">, a parte dianteira do trem avançou pelo campo</segment>
    <segment id="18">, e um segundo vagão ficou inclinado sobre os trilhos.</segment>
    <segment id="19">Um terceiro vagão não sofreu danos</segment>
    <segment id="20">, masmas o quarto pegou fogo</segment>
    <segment id="21">, em um incêndio apagado logo em seguida.</segment>
    <segment id="22">O trem de passageiros de dois andares tinha partido de Leiden</segment>
    <segment id="23">, cidade histórica no sul do país —a linha que a liga a Haia é uma das mais movimentadas da Holanda.</segment>
    <segment id="24">A ProRaid</segment>
    <segment id="25">, empresa responsável pela infraestrutura ferroviária no país</segment>
    <segment id="26">, informou que o trajeto será interrompido por alguns dias</segment>
    <segment id="27">para que</segment>
    <segment id="28">para que as circunstâncias do acidente sejam investigadas.  CEO da ProRaid</segment>
    <segment id="29">, John Voppen afirmou que a operação de manutenção que envolvia o guindaste estava prevista</segment>
    <segment id="30">, masmas que não</segment>
    <segment id="31">sese sabe</segment>
    <segment id="32">comocomo o equipamento foi parar no meio dos trilhos.</segment>
    <segment id="33">Um porta-voz da mesma empresa</segment>
    <segment id="34">, Jeroen Wienen</segment>
    <segment id="35">, disse que o acidente ainda envolveu um outro veículo</segment>
    <segment id="36">, este de carga.</segment>
    <segment id="37">Um passageiro que estava no trem no momento da colisão afirmou à emissora local Omroep West que ouviu um barulho muito forte e</segment>
    <segment id="38">, de repente</segment>
    <segment id="39">, as luzes</segment>
    <segment id="40">sese apagaram.</segment>
    <segment id="41">Ele contou que não conseguiu sair do comboio em um primeiro momento</segment>
    <segment id="42">porque</segment>
    <segment id="43">porque não havia energia elétrica.</segment>
    <segment id="44">Lá foraReceba no seu email uma seleção semanal com o que de mais importante aconteceu no mundo</segment>
    <segment id="45">; aberta para não assinantes.</segment>
    <segment id="46">Carregando...</segment>
    <segment id="47">O premiê holandês</segment>
    <segment id="48">, Mark Rutte</segment>
    <segment id="49">, e a família real do país lamentaram o episódio.</segment>
    <segment id="50">"</segment>
    <segment id="51">Meus pensamentos estão com todas as vítimas e seus parentes.</segment>
    <segment id="52">Desejo o melhor a todos eles"</segment>
    <segment id="53">, escreveu Rutte no Twitter.</segment>
    <segment id="54">"</segment>
    <segment id="55">Empatizamos profundamente com todos eles"</segment>
    <segment id="56">, disseram o rei Willem-Alexander e a rainha Maxima</segment>
    <segment id="57">, que depois visitaram o local do descarrilamento</segment>
    <segment id="58">, a cerca de dez quilômetros do palácio onde vivem.</segment>
    <segment id="59">Willem-Alexander é o novo rei da HolandaMais    novamente         de   de  de  representando um</segment>
    <segment id="60">O acidente ferroviário mais grave da história da Holanda aconteceu em 1962</segment>
    <segment id="61">, quando o choque de dois trens de passageiros em Harmelen</segment>
    <segment id="62">, perto da cidade de Utrecht</segment>
    <segment id="63">, matou 93 pessoas e deixou 52 feridos.</segment>
    <segment id="64">Em 2016</segment>
    <segment id="65">, uma pessoa morreu e seis ficaram feridas quando um comboio bateu em uma grua hidráulica no centro do país.</segment>
    <segment id="66">Outra colisão perto de Amsterdã em 2012 deixou um morto e 117 feridos.</segment>
  </rst>
</analysis>