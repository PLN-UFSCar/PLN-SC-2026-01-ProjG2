  <rst>
    <segment id="1">&amp;ldquo</segment>
    <segment id="2">;Quando falavam no ano 2000</segment>
    <segment id="3">, eu dizia que &amp;lsquo</segment>
    <segment id="4">;no ano 2000 a gente j&amp;aacute</segment>
    <segment id="5">; morreu&amp;rsquo</segment>
    <segment id="6">;, tinha certeza de que n&amp;atilde</segment>
    <segment id="7">;o virava o ano 2000&amp;rdquo</segment>
    <segment id="8">;, diz Ney Matogrosso</segment>
    <segment id="9">, lembrando quando tinha 30 e poucos anos</segment>
    <segment id="10">, uma Bras&amp;iacute</segment>
    <segment id="11">;lia e tantos hits tocando no r&amp;aacute</segment>
    <segment id="12">;dio quanto couberam nos dois lados do LP de estreia da banda dele</segment>
    <segment id="13">, os Secos &amp;amp</segment>
    <segment id="14">; Molhados.</segment>
    <segment id="15">Em 1973 e 1974</segment>
    <segment id="16">, acima de sua cabe&amp;ccedil</segment>
    <segment id="17">;a, havia s&amp;oacute</segment>
    <segment id="18">;</segment>
    <segment id="19">o c&amp;eacute</segment>
    <segment id="20">;u.</segment>
    <segment id="21">Hippie e artes&amp;atilde</segment>
    <segment id="22">;o que batalhava para</segment>
    <segment id="23">sese tornar ator</segment>
    <segment id="24">, ele ouvia rindo</segment>
    <segment id="25">, deitado de sunga em alguma praia do Rio de Janeiro</segment>
    <segment id="26">, as fofocas sobre qual seria a sexualidade do homem misterioso de canto fino e rebolado solto que aparecia com o rosto maquiado no Fant&amp;aacute</segment>
    <segment id="27">;stico.  Ney Matogrosso em 10 figurinos   novamente         de   de  de  representando um  Ney sabia que estavam falando dele</segment>
    <segment id="28">, masmas n&amp;atilde</segment>
    <segment id="29">;o s&amp;oacute</segment>
    <segment id="30">;</segment>
    <segment id="31">dele.</segment>
    <segment id="32">Quem estava na boca no povo era a entidade extra humana que havia</segment>
    <segment id="33">sese materializado em seu corpo desde que cobriu o rosto com purpurina para subir ao palco &amp;mdash</segment>
    <segment id="34">;daquela vez n&amp;atilde</segment>
    <segment id="35">;o como</segment>
    <segment id="36">como um personagem desimportante de algum musical ca&amp;iacute</segment>
    <segment id="37">;do, mas</segment>
    <segment id="38">mas um que ele nem sequer havia conhecido at&amp;eacute</segment>
    <segment id="39">; ent&amp;atilde</segment>
    <segment id="40">;o.</segment>
    <segment id="41">Neste domingo</segment>
    <segment id="42">, Ney chega aos 80 anos</segment>
    <segment id="43">, celebrados com um novo disco</segment>
    <segment id="44">, &amp;ldquo</segment>
    <segment id="45">;Nu com a Minha M&amp;uacute</segment>
    <segment id="46">;sica&amp;rdquo</segment>
    <segment id="47">;, lan&amp;ccedil</segment>
    <segment id="48">;ado em duas partes entre agosto e novembro.</segment>
    <segment id="49">Tamb&amp;eacute</segment>
    <segment id="50">;m &amp;eacute</segment>
    <segment id="51">; tema de uma nova biografia</segment>
    <segment id="52">, que leva seu nome</segment>
    <segment id="53">, escrita pelo jornalista Julio Maria</segment>
    <segment id="54">, e de um longa biogr&amp;aacute</segment>
    <segment id="55">;fico, anunciado recentemente pela Paris Filmes.</segment>
    <segment id="56">Mais do que o pacote de lan&amp;ccedil</segment>
    <segment id="57">;amentos</segment>
    <segment id="58">, a data &amp;eacute</segment>
    <segment id="59">;</segment>
    <segment id="60">a lembran&amp;ccedil</segment>
    <segment id="61">;a de uma trajet&amp;oacute</segment>
    <segment id="62">;ria improv&amp;aacute</segment>
    <segment id="63">;vel, de algu&amp;eacute</segment>
    <segment id="64">;m que forjou a pr&amp;oacute</segment>
    <segment id="65">;pria liberdade no seio do conservadorismo brasileiro.</segment>
    <segment id="66">&amp;</segment>
    <segment id="67">ldquo;Na primeira vez que fomos a Belo Horizonte</segment>
    <segment id="68">,</segment>
    <segment id="69">tocamos num festival que foi no campo de futebol.</segment>
    <segment id="70">Na hora que entramos</segment>
    <segment id="71">, que comecei a cantar</segment>
    <segment id="72">, algu&amp;eacute</segment>
    <segment id="73">;m da plateia gritou para mim &amp;lsquo</segment>
    <segment id="74">;bota para quebrar</segment>
    <segment id="75">, Ney,</segment>
    <segment id="76">porque</segment>
    <segment id="77">porque voc&amp;ecirc</segment>
    <segment id="78">; pode!&amp;rsquo</segment>
    <segment id="79">;.</segment>
    <segment id="80">Na minha cabe&amp;ccedil</segment>
    <segment id="81">;a, todos n&amp;oacute</segment>
    <segment id="82">;s poder&amp;iacute</segment>
    <segment id="83">;amos, n&amp;eacute</segment>
    <segment id="84">;?</segment>
    <segment id="85">Para algu&amp;eacute</segment>
    <segment id="86">;m gritar uma coisa dessa &amp;eacute</segment>
    <segment id="87">;</segment>
    <segment id="88">porque</segment>
    <segment id="89">porque estava muito reprimido e vendo ali uma possibilidade</segment>
    <segment id="90">, algu&amp;eacute</segment>
    <segment id="91">;m sese expressando com total liberdade.&amp;rdquo</segment>
    <segment id="92">;Ney Matogrosso (à esq.)</segment>
    <segment id="93">, João Ricardo e Gerson Conrad</segment>
    <segment id="94">, do grupo Secos &amp;amp</segment>
    <segment id="95">;</segment>
    <segment id="96">Molhados</segment>
    <segment id="97">, no camarim antes de histórico show do grupo no Maracanãzinho</segment>
    <segment id="98">, em 1974.</segment>
    <segment id="99">Imagem integra livro &amp;quot</segment>
    <segment id="100">;Vira-Lata de Raça&amp;quot</segment>
    <segment id="101">; - Ari Brandi/DivulgaçãoQualquer pessoa que</segment>
    <segment id="102">, ao modo de Ney</segment>
    <segment id="103">, explorasse corpo e voz</segment>
    <segment id="104">comocomo bem entendesse em cima de um palco</segment>
    <segment id="105">, n&amp;atilde</segment>
    <segment id="106">;o passaria ileso no Brasil da ditadura militar.</segment>
    <segment id="107">Ney tamb&amp;eacute</segment>
    <segment id="108">;m n&amp;atilde</segment>
    <segment id="109">;o passou.</segment>
    <segment id="110">Foi alvo da censura e detido pela pol&amp;iacute</segment>
    <segment id="111">;cia diversas vezes</segment>
    <segment id="112">, masmas criou uma armadura que tanto o protegia quanto o revelava para o mundo.</segment>
    <segment id="113">&amp;ldquo</segment>
    <segment id="114">;Aquele [Ney] era quase um animal</segment>
    <segment id="115">, n&amp;eacute</segment>
    <segment id="116">;?</segment>
    <segment id="117">Na verdade</segment>
    <segment id="118">, o animal foi logo depois dos Secos &amp;amp</segment>
    <segment id="119">; Molhados</segment>
    <segment id="120">, no primeiro show solo</segment>
    <segment id="121">, que vim com crina de cavalo</segment>
    <segment id="122">, pele de bicho.</segment>
    <segment id="123">Queria que as pessoas vissem o que elas quisessem ver.</segment>
    <segment id="124">Era uma coisa t&amp;atilde</segment>
    <segment id="125">;o amb&amp;iacute</segment>
    <segment id="126">;gua, t&amp;atilde</segment>
    <segment id="127">;o para todos os lados</segment>
    <segment id="128">, que eu poderia ser um inseto</segment>
    <segment id="129">, uma cobra</segment>
    <segment id="130">, uma ave</segment>
    <segment id="131">, qualquer coisa.</segment>
    <segment id="132">Era esse grau de abertura que eu propunha.&amp;rdquo</segment>
    <segment id="133">;  Ney j&amp;aacute</segment>
    <segment id="134">; tinha vendido artesanato no Rio e trabalhado num hospital em Bras&amp;iacute</segment>
    <segment id="135">;lia antes de</segment>
    <segment id="136">sese mudar para um ateli&amp;ecirc</segment>
    <segment id="137">; na Bela Vista</segment>
    <segment id="138">, em S&amp;atilde</segment>
    <segment id="139">;o Paulo</segment>
    <segment id="140">, e cair nos Secos &amp;amp</segment>
    <segment id="141">; Molhados.</segment>
    <segment id="142">Indicado pela amiga</segment>
    <segment id="143">Luhli, cantora</segment>
    <segment id="144">, violonista e compositora da dupla Luli e Lucina</segment>
    <segment id="145">, virou em pouco tempo a pe&amp;ccedil</segment>
    <segment id="146">;a mais importante na banda que o portugu&amp;ecirc</segment>
    <segment id="147">;s Jo&amp;atilde</segment>
    <segment id="148">;o</segment>
    <segment id="149">Ricardo criou para interpretar poemas musicados</segment>
    <segment id="150">, com veia pol&amp;iacute</segment>
    <segment id="151">;tica e influ&amp;ecirc</segment>
    <segment id="152">;ncia do rock.</segment>
    <segment id="153">Com exce&amp;ccedil</segment>
    <segment id="154">;&amp;atilde</segment>
    <segment id="155">;o das pe&amp;ccedil</segment>
    <segment id="156">;as e musicais de que participara</segment>
    <segment id="157">, Ney jamais havia subido num palco para cantar at&amp;eacute</segment>
    <segment id="158">; o fim de 1972.</segment>
    <segment id="159">Ainda era Ney de Souza</segment>
    <segment id="160">, masmas estava prestes a incorporar o sobrenome do pai sargento &amp;mdash</segment>
    <segment id="161">;e tamb&amp;eacute</segment>
    <segment id="162">;m do estado onde nasceu e cresceu&amp;mdash</segment>
    <segment id="163">; para</segment>
    <segment id="164">sese tornar algo que ele jamais aprovaria</segment>
    <segment id="165">, um cantor.</segment>
    <segment id="166">O primeiro show dos Secos &amp;amp</segment>
    <segment id="167">;</segment>
    <segment id="168">Molhados foi tamb&amp;eacute</segment>
    <segment id="169">;m a primeira vez que ele pintou o rosto.</segment>
    <segment id="170">&amp;ldquo</segment>
    <segment id="171">;N&amp;atilde</segment>
    <segment id="172">;o com aquela tinta branca que ia ter depois.</segment>
    <segment id="173">Ganhei da mulher do Paulinho Mendon&amp;ccedil</segment>
    <segment id="174">;a &amp;mdash</segment>
    <segment id="175">;que comp&amp;ocirc</segment>
    <segment id="176">;s &amp;lsquo</segment>
    <segment id="177">;Sangue Latino&amp;rsquo</segment>
    <segment id="178">;&amp;mdash</segment>
    <segment id="179">;</segment>
    <segment id="180">v&amp;aacute</segment>
    <segment id="181">;rios vidros de purpurina</segment>
    <segment id="182">, pintei meu rosto inteiro.</segment>
    <segment id="183">Ningu&amp;eacute</segment>
    <segment id="184">;m sabia</segment>
    <segment id="185">comocomo eu era j&amp;aacute</segment>
    <segment id="186">;</segment>
    <segment id="187">no primeiro dia.</segment>
    <segment id="188">E aquilo foi</segment>
    <segment id="189">sese desenvolvendo.&amp;rdquo</segment>
    <segment id="190">;  Ele estava no camarim da Casa de Badala&amp;ccedil</segment>
    <segment id="191">;&amp;atilde</segment>
    <segment id="192">;o e T&amp;eacute</segment>
    <segment id="193">;dio, espa&amp;ccedil</segment>
    <segment id="194">;o underground de S&amp;atilde</segment>
    <segment id="195">;o Paulo para cerca de 80 pessoas que recebia pe&amp;ccedil</segment>
    <segment id="196">;as e shows</segment>
    <segment id="197">, conforme narra Julio Maria no livro.</segment>
    <segment id="198">Tamb&amp;eacute</segment>
    <segment id="199">;m estava sem camisa e usava cal&amp;ccedil</segment>
    <segment id="200">;a branca de cetim e uma grinalda de rosas na cabe&amp;ccedil</segment>
    <segment id="201">;a.</segment>
    <segment id="202">A entidade que</segment>
    <segment id="203">sese apossara de Ney</segment>
    <segment id="204">, e que</segment>
    <segment id="205">sese tornaria nacionalmente conhecida dentro de alguns meses</segment>
    <segment id="206">, virou tamb&amp;eacute</segment>
    <segment id="207">;m o esconderijo de um homem &amp;agrave</segment>
    <segment id="208">;quela altura sem dinheiro</segment>
    <segment id="209">, sem rumo e um tanto t&amp;iacute</segment>
    <segment id="210">;mido.</segment>
    <segment id="211">&amp;ldquo</segment>
    <segment id="212">;Ouvi dizer que artista n&amp;atilde</segment>
    <segment id="213">;o podia andar na rua.</segment>
    <segment id="214">A gente tem que colocar no contexto.</segment>
    <segment id="215">Eu j&amp;aacute</segment>
    <segment id="216">; tinha 31 anos.</segment>
    <segment id="217">Como eu ia perder o direito de andar na rua</segment>
    <segment id="218">porque</segment>
    <segment id="219">porque tinha virado artista?&amp;rdquo</segment>
    <segment id="220">;  Em 1974</segment>
    <segment id="221">, o &amp;uacute</segment>
    <segment id="222">;ltimo ano dos Secos &amp;amp</segment>
    <segment id="223">;</segment>
    <segment id="224">Molhados</segment>
    <segment id="225">, o grupo j&amp;aacute</segment>
    <segment id="226">; tinha estourado no r&amp;aacute</segment>
    <segment id="227">;dio com &amp;ldquo</segment>
    <segment id="228">;Rosa de Hiroshima&amp;rdquo</segment>
    <segment id="229">;, &amp;ldquo</segment>
    <segment id="230">;O Vira&amp;rdquo</segment>
    <segment id="231">;</segment>
    <segment id="232">e &amp;ldquo</segment>
    <segment id="233">;Sangue Latino&amp;rdquo</segment>
    <segment id="234">;, entre outras can&amp;ccedil</segment>
    <segment id="235">;&amp;otilde</segment>
    <segment id="236">;es.</segment>
    <segment id="237">Tinham alcan&amp;ccedil</segment>
    <segment id="238">;ado um sucesso de propor&amp;ccedil</segment>
    <segment id="239">;&amp;otilde</segment>
    <segment id="240">;es in&amp;eacute</segment>
    <segment id="241">;ditas ao superar em vendas o ent&amp;atilde</segment>
    <segment id="242">;o imbat&amp;iacute</segment>
    <segment id="243">;vel Roberto Carlos.</segment>
    <segment id="244">Mais do que isso</segment>
    <segment id="245">, ao aparecer na Globo</segment>
    <segment id="246">, eles haviam &amp;</segment>
    <segment id="247">ldquo;colocado a quest&amp;atilde</segment>
    <segment id="248">;o da androginia na macarronada de domingo na sala do brasileiro&amp;rdquo</segment>
    <segment id="249">;, como</segment>
    <segment id="250">como diz Miguel de Almeida</segment>
    <segment id="251">, bi&amp;oacute</segment>
    <segment id="252">;grafo da banda.</segment>
    <segment id="253">Se, no palco</segment>
    <segment id="254">, Ney tinha o costume de olhar as plateias nos olhos</segment>
    <segment id="255">, na TV ele encarava a c&amp;acirc</segment>
    <segment id="256">;mera provocativamente</segment>
    <segment id="257">, transpondo o magnetismo de sua figura para a telinha.</segment>
    <segment id="258">Todo aquele sucesso era in&amp;eacute</segment>
    <segment id="259">;dito e estranho.</segment>
    <segment id="260">Nada explicava uma banda que tratava de quest&amp;otilde</segment>
    <segment id="261">;es pol&amp;iacute</segment>
    <segment id="262">;ticas e existenciais ser t&amp;atilde</segment>
    <segment id="263">;o adorada pelas crian&amp;ccedil</segment>
    <segment id="264">;as.</segment>
    <segment id="265">Quando cantaram para 20 mil pessoas no Maracan&amp;atilde</segment>
    <segment id="266">;zinho</segment>
    <segment id="267">, nada era maior que os Secos &amp;amp</segment>
    <segment id="268">; Molhados no pop brasileiro.</segment>
    <segment id="269">&amp;ldquo</segment>
    <segment id="270">;A</segment>
    <segment id="271">gente fazendo temporada no Teatro Ruth Escobar</segment>
    <segment id="272">, no Teatro Tereza Rachel e depois no Maracan&amp;atilde</segment>
    <segment id="273">;zinho</segment>
    <segment id="274">, eu ia &amp;agrave</segment>
    <segment id="275">;</segment>
    <segment id="276">praia e ficava ouvindo as pessoas falarem daquele grupo.</segment>
    <segment id="277">E eu deitado de sunga.&amp;rdquo</segment>
    <segment id="278">;  A manuten&amp;ccedil</segment>
    <segment id="279">;&amp;atilde</segment>
    <segment id="280">;o da privacidade poderia at&amp;eacute</segment>
    <segment id="281">; ser motivada por quest&amp;otilde</segment>
    <segment id="282">;es particulares</segment>
    <segment id="283">, masmas</segment>
    <segment id="284">, de certa forma</segment>
    <segment id="285">, acabou servindo</segment>
    <segment id="286">comocomo m&amp;eacute</segment>
    <segment id="287">;todo de sobreviv&amp;ecirc</segment>
    <segment id="288">;ncia.</segment>
    <segment id="289">N&amp;atilde</segment>
    <segment id="290">;o foram poucos os que</segment>
    <segment id="291">, por inveja ou puro moralismo</segment>
    <segment id="292">, pediram a cabe&amp;ccedil</segment>
    <segment id="293">;a de Ney.</segment>
    <segment id="294">Em colunas nos jornais Tribuna da Imprensa e O Fluminense</segment>
    <segment id="295">, escreve Julio Maria</segment>
    <segment id="296">, Chacrinha tirava sarro das qualidades art&amp;iacute</segment>
    <segment id="297">;sticas de Ney e ia al&amp;eacute</segment>
    <segment id="298">;m.</segment>
    <segment id="299">&amp;ldquo</segment>
    <segment id="300">;Estranho privil&amp;eacute</segment>
    <segment id="301">;gio!</segment>
    <segment id="302">Secos &amp;amp</segment>
    <segment id="303">;</segment>
    <segment id="304">Molhados podem tirar a roupa!&amp;rdquo</segment>
    <segment id="305">;, era o t&amp;iacute</segment>
    <segment id="306">;tulo de uma delas.</segment>
    <segment id="307">&amp;ldquo</segment>
    <segment id="308">;Deveria ser proibido pela censura e pelo juizado de menores&amp;rdquo</segment>
    <segment id="309">;</segment>
    <segment id="310">por ser &amp;ldquo</segment>
    <segment id="311">;rebolativo</segment>
    <segment id="312">, er&amp;oacute</segment>
    <segment id="313">;tico e muito do bich&amp;acirc</segment>
    <segment id="314">;nico&amp;rdquo</segment>
    <segment id="315">;, diz outro texto.</segment>
    <segment id="316">Ney Matogrosso   novamente         de   de  de  representando um  Ney criava brechas no anonimato</segment>
    <segment id="317">, masmas dentro dos Secos &amp;amp</segment>
    <segment id="318">;</segment>
    <segment id="319">Molhados todos sabiam quem ele era.</segment>
    <segment id="320">&amp;ldquo</segment>
    <segment id="321">;Dizer que todo mundo</segment>
    <segment id="322">sese maquiava &amp;eacute</segment>
    <segment id="323">;</segment>
    <segment id="324">mentira.</segment>
    <segment id="325">Passaram a</segment>
    <segment id="326">sese maquiar quando o Paulinho Mendon&amp;ccedil</segment>
    <segment id="327">;a disse a eles que era um absurdo s&amp;oacute</segment>
    <segment id="328">; eu estar daquele jeito e eles caretas.&amp;rdquo</segment>
    <segment id="329">;  Apaixonado por m&amp;uacute</segment>
    <segment id="330">;sica, Ney n&amp;atilde</segment>
    <segment id="331">;o tocava instrumentos e nem tinha tino para comandar m&amp;uacute</segment>
    <segment id="332">;sicos.</segment>
    <segment id="333">Essa miss&amp;atilde</segment>
    <segment id="334">;o ficava com Jo&amp;atilde</segment>
    <segment id="335">;o Ricardo</segment>
    <segment id="336">, que a certa altura passou &amp;mdash</segment>
    <segment id="337">;ao lado do violonista e compositor Gerson Conrad e dos outros</segment>
    <segment id="338">instrumentistas&amp;mdash</segment>
    <segment id="339">;</segment>
    <segment id="340">a sese incomodar com a pecha de grupo gay.</segment>
    <segment id="341">Ney se</segment>
    <segment id="342">se lembra de uma reuni&amp;atilde</segment>
    <segment id="343">;o na qual ouviu essas reclama&amp;ccedil</segment>
    <segment id="344">;&amp;otilde</segment>
    <segment id="345">;es.</segment>
    <segment id="346">&amp;ldquo</segment>
    <segment id="347">;Eu disse &amp;lsquo</segment>
    <segment id="348">;olha, voc&amp;ecirc</segment>
    <segment id="349">;s podem dizer que voc&amp;ecirc</segment>
    <segment id="350">;s n&amp;atilde</segment>
    <segment id="351">;o s&amp;atilde</segment>
    <segment id="352">;o [homossexuais]&amp;rsquo</segment>
    <segment id="353">;.</segment>
    <segment id="354">Resolvia</segment>
    <segment id="355">, n&amp;eacute</segment>
    <segment id="356">;?</segment>
    <segment id="357">Mas continuaram me pressionando</segment>
    <segment id="358">, e eu disse &amp;lsquo</segment>
    <segment id="359">;n&amp;atilde</segment>
    <segment id="360">;o, ent&amp;atilde</segment>
    <segment id="361">;o voc&amp;ecirc</segment>
    <segment id="362">;s botem outro no meu lugar&amp;rsquo</segment>
    <segment id="363">;.&amp;rdquo</segment>
    <segment id="364">;  &amp;ldquo</segment>
    <segment id="365">;Mas j&amp;aacute</segment>
    <segment id="366">; era tarde para botar outro no meu lugar</segment>
    <segment id="367">, porque</segment>
    <segment id="368">porque a gente j&amp;aacute</segment>
    <segment id="369">; fazia show em S&amp;atilde</segment>
    <segment id="370">;o Paulo</segment>
    <segment id="371">, sem ter gravado o disco</segment>
    <segment id="372">, lotando teatros</segment>
