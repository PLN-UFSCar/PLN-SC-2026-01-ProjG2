  <rst>
    <segment id="1">A partir do próximo ano</segment>
    <segment id="2">, as livrarias ganham algumas contribuições de peso no pensamento sobre a diáspora africana.</segment>
    <segment id="3">Enquanto a Zahar investe em obras essenciais de Frantz Fanon</segment>
    <segment id="4">, a Bazar do Tempo aposta em livros de Aimé Césaire e Patrick Chamoiseau.</segment>
    <segment id="5">Os três intelectuais negros</segment>
    <segment id="6">, nascidos na Martinica em diferentes gerações</segment>
    <segment id="7">, refletem sobre os efeitos da colonização e do racismo em abordagens que</segment>
    <segment id="8">sese complementam.</segment>
    <segment id="9">Fanon, psiquiatra que teve recentemente editados "</segment>
    <segment id="10">Pele Negra</segment>
    <segment id="11">, Máscaras Brancas" e "</segment>
    <segment id="12">Por uma Revolução Africana"</segment>
    <segment id="13">, agora terá talvez seu livro mais famoso</segment>
    <segment id="14">, "</segment>
    <segment id="15">Os Condenados da Terra"</segment>
    <segment id="16">, em uma grande editora.</segment>
    <segment id="17">A Zahar lança a obra no primeiro semestre de 2022.</segment>
    <segment id="18">E, no ano seguinte</segment>
    <segment id="19">, a casa traz "</segment>
    <segment id="20">O Fim do Colonialismo: Sociologia de uma Revolução".</segment>
    <segment id="21">Tudo a lerReceba no seu email uma seleção com lançamentos</segment>
    <segment id="22">, clássicos e curiosidades literárias</segment>
    <segment id="23">; aberta para não assinantes.</segment>
    <segment id="24">Carregando...</segment>
    <segment id="25">Já Césaire</segment>
    <segment id="26">, celebrado poeta e político cujo "Discurso sobre o Colonialismo" saiu por aqui ano passado</segment>
    <segment id="27">, terá publicado "</segment>
    <segment id="28">Toussaint Louverture:</segment>
    <segment id="29">A Revolução Francesa e o Problema Colonial"</segment>
    <segment id="30">, estudo historiográfico sobre o líder revolucionário haitiano</segment>
    <segment id="31">, pela Bazar do Tempo ano que vem.</segment>
    <segment id="32">A mesma editora é também responsável por trazer Chamoiseau</segment>
    <segment id="33">, escritor contemporâneo que venceu o Goncourt por "Texaco"</segment>
    <segment id="34">, que traz agora ao Brasil seu ensaio "Escrever em País Dominado".</segment>
    <segment id="35">As publicações que destrincham o pensamento decolonial têm sido torrenciais nas editoras do país.</segment>
    <segment id="36">O investimento da Bazar</segment>
    <segment id="37">, aliás</segment>
    <segment id="38">, vem na esteira do lançamento de Édouard Glissant</segment>
    <segment id="39">, ainda outro martinicano</segment>
    <segment id="40">, na Bienal de São Paulo com "Poética da Relação".</segment>
    <segment id="41">Ilustrações da nova edição de &amp;#</segment>
    <segment id="42">039;Cândido&amp;#039</segment>
    <segment id="43">;Mais    novamente         de   de  de  representando um    ​VOLTA DO MUNDO</segment>
    <segment id="44">, CAMARÁ "</segment>
    <segment id="45">Torto Arado"</segment>
    <segment id="46">, por sua vez</segment>
    <segment id="47">,</segment>
    <segment id="48">está colonizando terras cada vez mais longínquas.</segment>
    <segment id="49">A Marco Polo Press</segment>
    <segment id="50">, na Coreia do Sul</segment>
    <segment id="51">, e a Lijiang Publishing Limited</segment>
    <segment id="52">, na China</segment>
    <segment id="53">, acabaram de comprar os direitos do romance de Itamar Vieira Junior.</segment>
    <segment id="54">Agora, a história sobre as irmãs Belonísia e Bibiana já conta 15 edições fora do Brasil.  REFAZENDA</segment>
    <segment id="55">O podcast "Vinte Mil Léguas"</segment>
    <segment id="56">, que procura ler cientistas</segment>
    <segment id="57">comocomo escritores e acaba de estrear sua segunda temporada</segment>
    <segment id="58">, vai virar livro pela editora Fósforo em fevereiro.</segment>
    <segment id="59">As autoras</segment>
    <segment id="60">, Leda Cartum e Sofia Nestrovski</segment>
    <segment id="61">, adaptaram e ampliaram o roteiro da primeira temporada</segment>
    <segment id="62">, que dissecava "</segment>
    <segment id="63">A Origem das Espécies" de Darwin de forma acessível.</segment>
    <segment id="64">CÉREBRO ELETRÔNICO</segment>
    <segment id="65">E Roger Penrose lança por aqui sua primeira obra desde que ganhou o Nobel de física</segment>
    <segment id="66">, em 2020.</segment>
    <segment id="67">No livro "Sombras da Mente"</segment>
    <segment id="68">, que apresenta numa live da editora Unesp dia 30</segment>
    <segment id="69">, ele reflete sobre a inteligência artificial e aponta o caminho de uma ciência capaz de explicar a mente humana.</segment>
  </rst>
</analysis>