  <rst>
    <segment id="1">A deputada estadual Marina Helou</segment>
    <segment id="2">, candidata à Prefeitura de São Paulo pela Rede Sustentabilidade</segment>
    <segment id="3">, recebeu decisão liminar favorável do Tribunal Regional Eleitoral</segment>
    <segment id="4">para que</segment>
    <segment id="5">para que participe do primeiro debate entre os postulantes ao cargo</segment>
    <segment id="6">, a ser realizado pela TV Band na quinta-feira (1º)</segment>
    <segment id="7">, a partir das 22h30.</segment>
    <segment id="8">A Band convidou dez candidatos para o debate: Andrea Matarazzo (PSD)</segment>
    <segment id="9">, Arthur do Val (Patriota)</segment>
    <segment id="10">, Bruno Covas (PSDB)</segment>
    <segment id="11">, Celso Russomanno (Republicanos)</segment>
    <segment id="12">, Filipe Sabará (Novo)</segment>
    <segment id="13">, Guilherme Boulos (PSOL)</segment>
    <segment id="14">, Jilmar Tatto (PT)</segment>
    <segment id="15">, Joice Hesselmann (PSL)</segment>
    <segment id="16">, Marcio França (PSB) e Orlando Silva (PC do B).</segment>
    <segment id="17">O critério utilizado</segment>
    <segment id="18">, ao que tudo indica</segment>
    <segment id="19">, foi o de convidar aqueles cujos partidos ou coligações possuam</segment>
    <segment id="20">, atualmente</segment>
    <segment id="21">, ao menos cinco representantes no Congresso.</segment>
    <segment id="22">Saiba quais são os candidatos e as candidatas à Prefeitura de SP nas eleições de 2020 Mais    novamente         de   de  de  representando um  Helou argumentou</segment>
    <segment id="23">, então</segment>
    <segment id="24">, que a Rede Sustentabilidade elegeu seis representantes para o Congresso em 2018.</segment>
    <segment id="25">Como o partido não alcançou a cláusula de barreira</segment>
    <segment id="26">, três deles deixaram a sigla.</segment>
    <segment id="27">De acordo com o artigo 44 da resolução nº 23.610/2019</segment>
    <segment id="28">, do Tribunal Superior Eleitoral</segment>
    <segment id="29">, no entanto</segment>
    <segment id="30">, como</segment>
    <segment id="31">como mostrou a candidata</segment>
    <segment id="32">, as mudanças de filiação partidária relacionadas à emenda constitucional 97/2017 (que</segment>
    <segment id="33">sese refere à cláusula de barreira) não devem ser consideradas para o cálculo do tamanho de bancada na definição dos participantes de debates.</segment>
    <segment id="34">"[Para]</segment>
    <segment id="35">Os partidos que não alcançaram a cláusula de barreira e que perderam filiados detentores de cargo eletivo com fundamento no § 5º</segment>
    <segment id="36">, do art. 17</segment>
    <segment id="37">, da Constituição Federal</segment>
    <segment id="38">, o marco temporal para a verificação do número de representantes no Congresso Nacional continua a ser o resultado da eleição"</segment>
    <segment id="39">, escreveu em sua decisão o juiz eleitoral Emílio Migliano Neto.</segment>
    <segment id="40">"</segment>
    <segment id="41">Minha presença nos debates é uma oportunidade democrática para mostrar que São Paulo tem opção.</segment>
    <segment id="42">Já passou da hora de São Paulo sair da mesmice.</segment>
    <segment id="43">Das mesmas promessas e dos mesmos políticos.</segment>
    <segment id="44">Eu trago novas soluções para os problemas de sempre.</segment>
    <segment id="45">Terei a oportunidade de mostrar que soluções sustentáveis são soluções inteligentes para colocar São Paulo de novo</segment>
    <segment id="46">comocomo protagonista no mundo e trazer qualidade de vida para todas as pessoas"</segment>
    <segment id="47">, diz Helou ao Painel.</segment>
  </rst>
</analysis>