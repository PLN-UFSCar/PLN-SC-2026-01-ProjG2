<analysis>
  <header>
    <relations>
      <rel name="antithesis" type="rst"/>
      <rel name="attribution" type="rst"/>
      <rel name="circumstance" type="rst"/>
      <rel name="comparison" type="rst"/>
      <rel name="concession" type="rst"/>
      <rel name="conclusion" type="rst"/>
      <rel name="condition" type="rst"/>
      <rel name="elaboration" type="rst"/>
      <rel name="enablement" type="rst"/>
      <rel name="explanation" type="rst"/>
      <rel name="evaluation" type="rst"/>
      <rel name="evidence" type="rst"/>
      <rel name="interpretation" type="rst"/>
      <rel name="elaboration" type="rst"/>
      <rel name="non-volitional-cause" type="rst"/>
      <rel name="non-volitional-result" type="rst"/>
      <rel name="volitional-cause" type="rst"/>
      <rel name="volitional-result" type="rst"/>
    </relations>
  </header>
  <rst>
    <segment id="1">É uma manhã de inverno fria em janeiro de 1969 e três dos quatro Beatles estão reunidos em um cavernoso estúdio de cinema em Londres</segment>
    <segment id="2">; as câmeras estão rolando</segment>
    <segment id="3">, e há microfones ligados em toda parte.</segment>
    <segment id="4">"</segment>
    <segment id="5">Lennon está atrasado de novo"</segment>
    <segment id="6">, diz Paul McCartney em tom de nenhuma surpresa</segment>
    <segment id="7">, enquanto pluga seu baixo.  Ringo Starr e George Harrison estão sentados diante dele e parecem meio grogues</segment>
    <segment id="8">, e há uma bandeja de torradas com geleia posicionada ao lado dos músicos.</segment>
    <segment id="9">McCartney começa a tocar e cantar</segment>
    <segment id="10">, procurando inspiração.</segment>
    <segment id="11">Em poucos minutos</segment>
    <segment id="12">, ele parece ter uma linha de baixo de andamento médio</segment>
    <segment id="13">, e uma melodia familiar emerge.</segment>
    <segment id="14">"</segment>
    <segment id="15">Get back"</segment>
    <segment id="16">, ele canta</segment>
    <segment id="17">, em um uivo contido.</segment>
    <segment id="18">"</segment>
    <segment id="19">Get back to where you once belonged.</segment>
    <segment id="20">"</segment>
    <segment id="21">Quase em um passe de mágica</segment>
    <segment id="22">, um clássico dos Beatles começa a</segment>
    <segment id="23">sese formar</segment>
    <segment id="24">, aparentemente do nada.</segment>
    <segment id="25">Mais tarde naquele mesmo dia</segment>
    <segment id="26">, depois da chegada de Lennon</segment>
    <segment id="27">, as quatro divindades do rock</segment>
    <segment id="28">sese acomodam em um círculo –e resmungam.</segment>
    <segment id="29">A banda tem planos mal definidos para um especial de TV com canções inéditas</segment>
    <segment id="30">, masmas a maioria dos integrantes parece encarar a perspectiva com medo —e eles talvez também estejam com medo uns dos outros.</segment>
    <segment id="31">Lennon</segment>
    <segment id="32">, que parece completamente desconcentrado por boa parte da reunião</segment>
    <segment id="33">, declara vagamente que "comunicação" com uma audiência é seu único objetivo</segment>
    <segment id="34">, e McCartney</segment>
    <segment id="35">, impaciente</segment>
    <segment id="36">, desafia os colegas a demonstrar algum entusiasmo pelo projeto ou abandonar a coisa de vez.</segment>
    <segment id="37">Harrison de repente deixa escapar em voz alta aquilo que todos parecem estar pensando.</segment>
    <segment id="38">"</segment>
    <segment id="39">Talvez seja hora de um divórcio.</segment>
    <segment id="40">"</segment>
    <segment id="41">Essas duas cenas sucessivas em "The Beatles: Get Back"</segment>
    <segment id="42">, série documentál de Peter Jackson</segment>
    <segment id="43">, um projeto de mais de sete horas de duração que será exibido em três episódios no serviço Disney Plus entre 25 e 27 de novembro</segment>
    <segment id="44">, encapsula os lados gêmeos do período mais contestado na história dos Beatles —a glória da criação artística da banda de rock mais amada e influente do planeta e os conflitos extenuantes que conduziram à sua dissolução</segment>
    <segment id="45">, anunciada um ano mais tarde.</segment>
    <segment id="46">Para os fãs dos Beatles ou qualquer estudioso da cultura pop do século 20</segment>
    <segment id="47">, o documentário oferece vislumbres espantosos sobre a vida profissional da banda e as tensões que cercavam seus integrantes.</segment>
    <segment id="48">"</segment>
    <segment id="49">É mais ou menos a realização daquele sonho impossível dos fãs"</segment>
    <segment id="50">, disse Jackson em uma entrevista por vídeo de Welington</segment>
    <segment id="51">, na Nova Zelândia</segment>
    <segment id="52">, onde ele trabalhou por boa parte dos últimos quatro anos na penumbra de uma sala de edição</segment>
    <segment id="53">, cercado de recordações dos Beatles.</segment>
    <segment id="54">"</segment>
    <segment id="55">Eu queria poder viajar em uma máquina do tempo e me posicionar no cantinho do palco em que eles estavam trabalhando"</segment>
    <segment id="56">, ele disse</segment>
    <segment id="57">, descrevendo um sonho duradouro com a mesma intensidade com que uma criança reza pelo presente de Natal mais cobiçado.</segment>
    <segment id="58">"</segment>
    <segment id="59">Só por um dia</segment>
    <segment id="60">, para os poder ver</segment>
    <segment id="61">, e eu ficaria quietinho</segment>
    <segment id="62">, sentado lá.</segment>
    <segment id="63">"  "</segment>
    <segment id="64">Bem, quer saber?</segment>
    <segment id="65">", ele prosseguiu.</segment>
    <segment id="66">"</segment>
    <segment id="67">A máquina do tempo agora existe.</segment>
    <segment id="68">"</segment>
    <segment id="69">Veja cenas de &amp;#039</segment>
    <segment id="70">;The Beatles: Get Back&amp;#039</segment>
    <segment id="71">;, série que traz momentos inéditos da bandaMais    novamente         de   de  de  representando um</segment>
    <segment id="72">O filme de Jackson também é uma nova rodada de um dos debates mais duradouros entre os estudiosos dos Beatles.</segment>
    <segment id="73">A jornada da banda em janeiro de 1969 começou com intensa pressão</segment>
    <segment id="74">para que</segment>
    <segment id="75">para que eles realizassem um show ao vivo conceitual inovador</segment>
    <segment id="76">, e terminou com algo nada conceitual</segment>
    <segment id="77">, e maravilhoso –um show realizado sem aviso</segment>
    <segment id="78">, no topo de um edifício em Londres</segment>
    <segment id="79">, que serviu para lembrar ao mundo a majestade</segment>
    <segment id="80">, espontaneidade e humor dos Beatles.</segment>
    <segment id="81">"</segment>
    <segment id="82">Quem sabe conseguimos passar na audição"</segment>
    <segment id="83">, brincou Lennon no fim do show.</segment>
    <segment id="84">O período já é tema de "Let It Be"</segment>
    <segment id="85">, de 1970</segment>
    <segment id="86">, um trabalho de cinéma verité de Michael Lindsay-Hogg</segment>
    <segment id="87">; a trilha sonora do filme foi último disco de estúdio lançado pelos Beatles.</segment>
    <segment id="88">Com o tempo</segment>
    <segment id="89">, o filme ganhou a reputação de ser um registro tristonho do colapso da banda</segment>
    <segment id="90">, e depoimentos posteriores de integrantes dos Beatles parecem sustentar essa visão.</segment>
    <segment id="91">Lennon descreveu as sessões</segment>
    <segment id="92">comocomo "um inferno"</segment>
    <segment id="93">, e Harrison as definiu</segment>
    <segment id="94">comocomo "inverno de descontentamento".</segment>
    <segment id="95">Mas essa narrativa vem sendo contestada há um bom tempo por alguns estudiosos dos Beatles.</segment>
    <segment id="96">O filme de Lindsay-Hogg</segment>
    <segment id="97">, argumentam</segment>
    <segment id="98">, foi editado seletivamente a fim de mostrar o máximo possível de desânimo —talvez</segment>
    <segment id="99">comocomo uma forma de explicar retroativamente o rompimento.</segment>
    <segment id="100">"</segment>
    <segment id="101">Abbey Road"</segment>
    <segment id="102">, o último LP dos Beatles por ordem de gravação</segment>
    <segment id="103">, foi registrado depois de "Let It Be"</segment>
    <segment id="104">masmas lançado antes.</segment>
    <segment id="105">Indicações de gravações piratas mostram uma mistura de prazer e frustração conhecida de todo músico que está no take</segment>
    <segment id="106">24 de uma determinada faixa –e com prazo para acabar.</segment>
    <segment id="107">A simples existência de "</segment>
    <segment id="108">Get Back" é um sinal de que</segment>
    <segment id="109">, mais de meio século depois que os Beatles</segment>
    <segment id="110">sese separaram</segment>
    <segment id="111">, a história deles continua aberta a interpretações e a pesquisas aprofundadas e narrativas alternativas.</segment>
    <segment id="112">O filme de Jackson</segment>
    <segment id="113">, que chega com a autoridade de um relâmpago lançado do topo de uma montanha na Terra Média</segment>
    <segment id="114">, pode</segment>
    <segment id="115">sese tornar a palavra final nas discussões sobre esse período</segment>
    <segment id="116">, embora</segment>
    <segment id="117">embora a história que o documentário conte seja longe de simples.</segment>
    <segment id="118">Jackson</segment>
    <segment id="119">, cineasta premiado com o Oscar pela trilogia "</segment>
    <segment id="120">O Senhor dos Anéis" —e beatlemaníaco declarado— obteve acesso a cerca de 60 horas de imagens filmadas inéditas</segment>
    <segment id="121">, fornecidas pela Apple Corps</segment>
    <segment id="122">, a empresa dos Beatles</segment>
    <segment id="123">, e não foram impostas restrições sobre</segment>
    <segment id="124">comocomo ele poderia usar os registros.</segment>
    <segment id="125">A instrução foi só a de restaurar o filme e contar a história completa.</segment>
    <segment id="126">Os Beatles</segment>
    <segment id="127">, ou pelo menos as empresas que os representam</segment>
    <segment id="128">, aceitaram com agrado a maneira pela qual Jackson volta a contar a história</segment>
    <segment id="129">, e um trailer do documentário mostrava momentos de irmandade brincalhona</segment>
    <segment id="130">, com a banda dançando e fazendo micagens no estúdio.</segment>
    <segment id="131">Jeff Jones</segment>
    <segment id="132">, presidente da Apple Corps</segment>
    <segment id="133">, prometeu que o novo filme "poria fim ao mito" de que aquelas sessões de gravação foram o prego final no caixão dos Beatles.</segment>
    <segment id="134">Mas Jackson disse que a banda não influenciou seu trabalho.</segment>
    <segment id="135">"</segment>
    <segment id="136">Todo mundo mais ou menos acha que vamos passar por cima das controvérsias"</segment>
    <segment id="137">, porque</segment>
    <segment id="138">porque os Beatles autorizaram o filme</segment>
    <segment id="139">, disse Jackson</segment>
    <segment id="140">, rindo.</segment>
    <segment id="141">"</segment>
    <segment id="142">Mas na verdade é praticamente o oposto.</segment>
    <segment id="143">Mostra tudo que Michael Lindsay-Hogg não pôde mostrar em 1970.</segment>
    <segment id="144">É um olhar realmente direto quanto ao que aconteceu".</segment>
    <segment id="145">Para os fãs que recordam o filme de Lindsay-Hogg ou leram histórias lúgubres sobre ele em dezenas de livros sobre os Beatles</segment>
    <segment id="146">, as cenas que Jackson mostra</segment>
    <segment id="147">, com os amigos brincando</segment>
    <segment id="148">, e com momentos de criação bruta</segment>
    <segment id="149">, saltam aos olhos.</segment>
    <segment id="150">Vemos os Beatles tirando onda com os colegas</segment>
    <segment id="151">, imitando sotaques pretensiosos e fazendo cenas de humor absurdo que parecem saídas de um sketch do Monty Python.</segment>
    <segment id="152">"</segment>
    <segment id="153">Você pode ver aqueles quatro grandes amigos</segment>
    <segment id="154">, grandes músicos</segment>
    <segment id="155">, que se</segment>
    <segment id="156">se conectam e desenvolvem canções.</segment>
    <segment id="157">Tudo está lá</segment>
    <segment id="158">, bem claro na tela"</segment>
    <segment id="159">, disse Jackson.</segment>
    <segment id="160">As imagens restauradas do diretor em "Get Back" são impressionantemente claras e ajudam a estabelecer os contornos de uma história de ansiedade criativa e de confortos pessoais</segment>
    <segment id="161">, dentro da fortaleza Beatles.</segment>
    <segment id="162">Auxiliares servem vinho para os músicos enquanto eles ensaiam</segment>
    <segment id="163">;</segment>
    <segment id="164">Yoko Ono faz pinturas em caligrafia japonesa</segment>
    <segment id="165">, enquanto Lennon e McCartney</segment>
    <segment id="166">, a poucos metros de distância</segment>
    <segment id="167">, zoam a gravação de "Two of Us"</segment>
    <segment id="168">, adotando sotaques bizarros.</segment>
    <segment id="169">Mas o sofrimento não parece estar muito longe</segment>
    <segment id="170">;</segment>
    <segment id="171">as brigas</segment>
    <segment id="172">sese agravam tanto que começa a parecer milagroso que os Beatles ainda consigam</segment>
    <segment id="173">sese manter unidos.</segment>
    <segment id="174">Em dado momento</segment>
    <segment id="175">, Harrison larga a banda por algum tempo</segment>
    <segment id="176">, aparentemente irritado por seu status subalterno.</segment>
    <segment id="177">No refeitório do estúdio</segment>
    <segment id="178">, Lennon diz a McCartney que os desentendimentos entre a banda e seu guitarrista solo eram "uma ferida abertas".</segment>
    <segment id="179">Depois que Harrison abandona o estúdio</segment>
    <segment id="180">, os demais Beatles fazem uma jam session barulhenta e raivosa.</segment>
    <segment id="181">Starr quase destrói a bateria.</segment>
    <segment id="182">Ono, vestida toda de preto</segment>
    <segment id="183">, está no microfone e uiva até um clímax selvagem –talvez o som mais violento que os Beatles criaram em suas carreiras.</segment>
    <segment id="184">Um tema recorrente é o desconforto da banda com o papel de Ono</segment>
    <segment id="185">, que passa o tempo todo sentada ao lado de Lennon</segment>
    <segment id="186">, durante as sessões</segment>
    <segment id="187">, e viria a ser atacada pelos fãs por seu suposto papel na dissolução da banda.</segment>
    <segment id="188">Um livro que acompanha o filme e traz transcrições adicionais das gravações cita Lennon dizendo a McCartney que "eu sacrificaria todos vocês por ela".</segment>
    <segment id="189">Mas havia coisas demais em jogo para os Beatles</segment>
    <segment id="190">, e a perspectiva da dissolução da banda pende</segment>
    <segment id="191">comocomo uma nuvem sobre todo o filme.</segment>
    <segment id="192">No começo</segment>
    <segment id="193">, McCartney sugere uma ideia para um especial de TV ainda indefinido.</segment>
    <segment id="194">As canções dos Beatles</segment>
    <segment id="195">, ele propõe</segment>
    <segment id="196">, seriam entremeadas por reportagens sobre terremotos e outros eventos noticiosos "quentes"</segment>
    <segment id="197">, no mundo todo.</segment>
    <segment id="198">E, no final</segment>
    <segment id="199">, diz McCartney</segment>
    <segment id="200">, "o boletim final seria "os Beatles</segment>
    <segment id="201">sese separaram".</segment>
    <segment id="202">Em alguma medida</segment>
    <segment id="203">, "</segment>
    <segment id="204">Get Back" e o "Let It Be" original são</segment>
    <segment id="205">comocomo referências em um estudo da verdade.</segment>
    <segment id="206">As imagens realmente mostram o fim dos Beatles ou a história entendeu o período erroneamente por todos esses anos?</segment>
    <segment id="207">As provas majoritariamente apontam que banda continuava a</segment>
    <segment id="208">sese sentir alegre e criativamente fecunda</segment>
    <segment id="209">, ou os integrantes não suportavam mais a companhia dos colegas?</segment>
    <segment id="210">A resposta pode ser "todas as anteriores".</segment>
    <segment id="211">Em uma nota que acompanhou um relançamento do álbum "Let</segment>
    <segment id="212">It Be"</segment>
    <segment id="213">, McCartney escreveu que o filme original era "bem triste</segment>
    <segment id="214">, porque</segment>
    <segment id="215">porque lidava com a separação de nossa banda</segment>
    <segment id="216">, masmas o novo filme mostra a camaradagem e o amor que nós quatro sentíamos uns pelos outros".</segment>
    <segment id="217">Lindsay-Hogg acredita que não só os fãs</segment>
    <segment id="218">masmas talvez também os integrantes dos Beatles venham interpretando "Let</segment>
    <segment id="219">It Be</segment>
    <segment id="220">"</segment>
    <segment id="221">erroneamente há anos.</segment>
    <segment id="222">"</segment>
    <segment id="223">Creio que parte da má reputação de 'Let It Be’ é que ninguém vê o filme há muito tempo"</segment>
    <segment id="224">, ele declarou em entrevista.</segment>
    <segment id="225">"E ele tendia a ser muito confundido com o momento em que foi lançado</segment>
    <segment id="226">, logo depois da dissolução da banda.</segment>
    <segment id="227">"</segment>
    <segment id="228">Os Beatles não</segment>
    <segment id="229">sese separaram em janeiro de 1969</segment>
    <segment id="230">, é claro.</segment>
    <segment id="231">Mais tarde no ano</segment>
    <segment id="232">, gravaram "Abbey Road"</segment>
    <segment id="233">, com muito cuidado.</segment>
    <segment id="234">A maioria das canções daquele disco —</segment>
    <segment id="235">comocomo "</segment>
    <segment id="236">Octopus’s Garden"</segment>
    <segment id="237">, "Mean Mr. Mustard"</segment>
    <segment id="238">, "</segment>
    <segment id="239">Carry That Weight" e "Something"— são ouvidas em suas versões iniciais</segment>
    <segment id="240">, em "</segment>
    <segment id="241">Get Back".</segment>
    <segment id="242">Mas o filme de Jackson deixa claro que o fim estava perto.</segment>
    <segment id="243">Se houve um verdadeiro culpado pela dissolução</segment>
    <segment id="244">, foram os conflitos de negócios que surgiram em 1969</segment>
    <segment id="245">, quando a banda entrou em disputa quanto a quem a deveria representar</segment>
    <segment id="246">, e Lennon e McCartney tentaram</segment>
    <segment id="247">, sem sucesso</segment>
    <segment id="248">, tomar o controle da empresa que detinha os direitos de licenciamento de suas canções.</segment>
    <segment id="249">Todos esses problemas são prenunciados em "</segment>
    <segment id="250">Get Back" com a menção de um simples nome –</segment>
    <segment id="251">Allen Klein</segment>
    <segment id="252">, um empresário americano de artistas que chegou poucos dias antes do show no topo do edifício para oferecer seus serviços à banda.</segment>
    <segment id="253">Logo depois dos acontecimentos retratados em "</segment>
    <segment id="254">Get Back"</segment>
    <segment id="255">, Lennon</segment>
    <segment id="256">, Harrison e Starr assinaram com Klein</segment>
    <segment id="257">; McCartney</segment>
    <segment id="258">sese recusou</segment>
    <segment id="259">, e essa cisão jamais foi resolvida.</segment>
    <segment id="260">Klein morreu em 2009.  "</segment>
    <segment id="261">Nosso filme não mostra a separação dos Beatles"</segment>
    <segment id="262">, disse Jackson</segment>
    <segment id="263">, "mas</segment>
    <segment id="264">mas mostra o momento singular da história que pode talvez ser descrito</segment>
    <segment id="265">comocomo o começo do fim".</segment>
    <segment id="266">Se os estudiosos e a posição dos fãs dos Beatles provaram alguma coisa é que até mesmo um sumário contraditório da banda e de sua influência pode ainda assim ser verdade.</segment>
    <segment id="267">Os Beatles eram uma boy band pop que terminou estendendo as fronteiras criativas do rock muito mais do que qualquer rival</segment>
    <segment id="268">; quase todos os dias da existência deles</segment>
    <segment id="269">comocomo grupo foram documentados exaustivamente</segment>
    <segment id="270">, masmas descrever completamente suas motivações é impossível.</segment>
    <segment id="271">"</segment>
    <segment id="272">Get Back" parece conter todas essas multidões</segment>
    <segment id="273">, o prazer</segment>
    <segment id="274">, a tensão</segment>
    <segment id="275">, as disputas e a maravilha de ver os Beatles só tocando música no topo do prédio.</segment>
    <segment id="276">"</segment>
    <segment id="277">Não há mocinhos no filme.</segment>
    <segment id="278">Não há bandidos"</segment>
    <segment id="279">, disse Jackson.</segment>
    <segment id="280">"</segment>
    <segment id="281">Não há vilões.</segment>
    <segment id="282">Não há heróis.</segment>
    <segment id="283">É só uma história humana.</segment>
    <segment id="284">"</segment>
  </rst>
</analysis>