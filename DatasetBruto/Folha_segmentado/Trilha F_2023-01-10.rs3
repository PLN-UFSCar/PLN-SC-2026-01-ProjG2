  <rst>
    <segment id="1">Depois de</segment>
    <segment id="2">sese estabelecer em Perdizes com um dos bons brewpubs (bares que fabricam a cerveja no local) da cidade</segment>
    <segment id="3">, a Trilha Cervejaria deu um novo passo</segment>
    <segment id="4">, mais ao centro</segment>
    <segment id="5">, no fim de 2022.</segment>
    <segment id="6">Ou dois.</segment>
    <segment id="7">Pouco antes do início da Copa do Mundo</segment>
    <segment id="8">, foi inaugurada na Barra</segment>
    <segment id="9">Funda</segment>
    <segment id="10">a Trilha Fermentaria</segment>
    <segment id="11">, agora com comidinhas próprias.</segment>
    <segment id="12">As disputadas cervejas artesanais têm a companhia de pizzas e petiscos para compartilhar</segment>
    <segment id="13">, todos</segment>
    <segment id="14">, como</segment>
    <segment id="15">como o nome indica</segment>
    <segment id="16">, feitos a partir de diferentes processos de fermentação.</segment>
    <segment id="17">Barris no fundo da Trilha Fermentaria</segment>
    <segment id="18">, que oferece cervejas e pizzas na Barra Funda - Divulgação"Criamos uma massa própria de longa fermentação [para as pizzas]</segment>
    <segment id="19">, fazemos nossos vinagres</segment>
    <segment id="20">, picles</segment>
    <segment id="21">, refrescos e vamos servir sidra.</segment>
    <segment id="22">Nesta nova casa</segment>
    <segment id="23">, a gente fermenta muito mais que cerveja"</segment>
    <segment id="24">, comemora Beto Tempel</segment>
    <segment id="25">, sócio de Daniel Bekeierman no empreendimento.</segment>
    <segment id="26">Há sugestões</segment>
    <segment id="27">comocomo o cogumelo com pipoca de cevada (R$ 30) ou o sanduba de cordeiro (R$ 37)</segment>
    <segment id="28">, com pão feito na casa e carne marinada na cerveja.</segment>
    <segment id="29">Feitas no forno a lenha</segment>
    <segment id="30">, as pizzas são quase primas das cervejas —que já foi chamado de "pão líquido"—</segment>
    <segment id="31">, com levedura e bagaço do malte na massa.</segment>
    <segment id="32">Em tamanho único</segment>
    <segment id="33">, estilo brotinho</segment>
    <segment id="34">, oferece sabores</segment>
    <segment id="35">comocomo Shak (com coalhada e gema curada com especiarias) ou a autoexplicativa Frango</segment>
    <segment id="36">, Cerveja e Curry</segment>
    <segment id="37">, ambas por R$ 52.</segment>
    <segment id="38">Os barris no fundo da casa</segment>
    <segment id="39">, um antigo depósito</segment>
    <segment id="40">, são bem mais do que uma bela decoração.</segment>
    <segment id="41">Eles guardam cervejas da marca</segment>
    <segment id="42">, que estão maturando</segment>
    <segment id="43">, em diferentes estilos —a Trilha desenvolve há algum tempo uma ótima linha de cervejas "</segment>
    <segment id="44">barrel aged".</segment>
    <segment id="45">Trilha FermentariaMais    novamente         de   de  de  representando um    Continuando na parte cervejeira</segment>
    <segment id="46">, a nova casa tem 18 torneiras</segment>
    <segment id="47">, seis a mais que a de Perdizes —</segment>
    <segment id="48">masmas nem todas estão necessariamente ativas (atualmente</segment>
    <segment id="49">, são 14).</segment>
    <segment id="50">São rótulos</segment>
    <segment id="51">comocomo a refrescante Pils (pilsen com 5</segment>
    <segment id="52">,7% de álcool</segment>
    <segment id="53">, por R$ 15</segment>
    <segment id="54">, 300 ml)</segment>
    <segment id="55">, Lobozó (witbier com uvaia</segment>
    <segment id="56">, por R$ 21</segment>
    <segment id="57">, 350 ml) ou a Pão de Mel</segment>
    <segment id="58">, uma pastry stout clássica da marca</segment>
    <segment id="59">, com mel</segment>
    <segment id="60">, chocolate e especiarias</segment>
    <segment id="61">, e 12</segment>
    <segment id="62">,2% de álcool (R$ 38</segment>
    <segment id="63">, no copo com 200 ml).</segment>
    <segment id="64">Quem preferir</segment>
    <segment id="65">, pode optar pela régua de degustação</segment>
    <segment id="66">, com quatro copinhos de 100 ml.</segment>
    <segment id="67">E tem mais: um pequeno corredor com fitas vermelhas de um lado</segment>
    <segment id="68">, que levam ao banheiro</segment>
    <segment id="69">, e latas amassadas na parede</segment>
    <segment id="70">, do outro</segment>
    <segment id="71">, criaram um interessante espaço com ares de instagramável.</segment>
    <segment id="72">Depois dele</segment>
    <segment id="73">, há geladeiras com cervejas para levar e uma lojinha com outros itens para alegrar os cervejeiros.</segment>
    <segment id="74">Uma pequena ressalva</segment>
    <segment id="75">; entre as 14 receitas engatadas</segment>
    <segment id="76">, talvez</segment>
    <segment id="77">sese privilegie mais o público já iniciado nas artesanais</segment>
    <segment id="78">, com muitas cervejas sour ou juicy IPA.</segment>
    <segment id="79">Mas além das torneiras</segment>
    <segment id="80">, há muitas opções em lata</segment>
    <segment id="81">, é só consultar os simpáticos atendentes.</segment>
    <segment id="82">Ah, e tem ainda aquele outro passo: na mesma Barra Funda a Trilha abriu sua nova fábrica</segment>
    <segment id="83">, quase dobrando a capacidade de produção</segment>
    <segment id="84">, de 7.000 para 13 mil litros.</segment>
    <segment id="85">E o espaço em Perdizes?</segment>
    <segment id="86">Continua lá.</segment>
    <segment id="87">Mas agora deixa de ser um brewpub para ser um taproom</segment>
    <segment id="88">, ou seja</segment>
    <segment id="89">, oferece a cerveja própria</segment>
    <segment id="90">, masmas não produz mais ali.</segment>
    <segment id="91">E o que isso muda?</segment>
    <segment id="92">Nada.</segment>
    <segment id="93">Só mais uma alternativa para fazer a Trilha que preferir.  Trilha Fermentaria - Cônego Vicente Miguel Marino</segment>
    <segment id="94">, 390, Barra Funda</segment>
    <segment id="95">, região central.</segment>
    <segment id="96">Qua.</segment>
    <segment id="97">a sex.</segment>
    <segment id="98">:</segment>
    <segment id="99">18h às 24h.</segment>
    <segment id="100">Sáb.</segment>
    <segment id="101">:</segment>
    <segment id="102">12h às 24h.</segment>
    <segment id="103">Dom.</segment>
    <segment id="104">:</segment>
    <segment id="105">12h às 22h.</segment>
    <segment id="106">50 lugares.</segment>
    <segment id="107">Ecommerce: loja.trilhacervejaria.com.br/</segment>
  </rst>
</analysis>