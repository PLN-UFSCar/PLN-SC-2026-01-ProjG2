  <rst>
    <segment id="1">A modelo Cíntia Dicker chegou tão animada ao Nosso Camarote</segment>
    <segment id="2">, na Marquês de Sapucaí</segment>
    <segment id="3">, no Rio</segment>
    <segment id="4">, que em nada lembrava o início de ano turbulento que teve.</segment>
    <segment id="5">"Me sinto recuperada</segment>
    <segment id="6">, masmas ainda não estou.</segment>
    <segment id="7">Fazem só 50 dias.</segment>
    <segment id="8">É a primeira vez que saio sem a Aurora"</segment>
    <segment id="9">, conta</segment>
    <segment id="10">, em conversa com jornalistas na noite deste domingo (19).</segment>
    <segment id="11">A filha</segment>
    <segment id="12">, nascida a partir do relacionamento com Pedro Scooby</segment>
    <segment id="13">, passou por três cirurgias logo após o nascimento.</segment>
    <segment id="14">Cintia Dickerno</segment>
    <segment id="15">Nosso Camaroteno primeiro dia de desfile do Grupo Especial do Rio - Reginaldo Teixeira 19.fev.2023/DivulgaçãoA modelo diz que tenta voltar à rotina que tinha antes da gestação.</segment>
    <segment id="16">"Estou amamentando</segment>
    <segment id="17">, estou malhando e estou tentando fechar a boca</segment>
    <segment id="18">, porque</segment>
    <segment id="19">porque engordei 30 quilos.</segment>
    <segment id="20">Já perdi 15</segment>
    <segment id="21">, faltam mais 15"</segment>
    <segment id="22">, conta ela.</segment>
    <segment id="23">"</segment>
    <segment id="24">É meio cansativo</segment>
    <segment id="25">porque</segment>
    <segment id="26">porque estou sem babá</segment>
    <segment id="27">, então é a minha mãe que está comigo.</segment>
    <segment id="28">"</segment>
    <segment id="29">Apesar da energia com que chegou ao camarote</segment>
    <segment id="30">, Cíntia conta que não dormiu muito na noite anterior.</segment>
    <segment id="31">"</segment>
    <segment id="32">Hoje a Aurora acordou às quatro da manhã e só foi dormir às oito.</segment>
    <segment id="33">[Estou] 'viradaça'.</segment>
    <segment id="34">Às oito eu dei ela para a minha mãe e dormi duas horinhas.</segment>
    <segment id="35">Mãe salva.</segment>
    <segment id="36">"  Famosos e personalidades no Carnaval do Rio em 2023Mais    novamente         de   de  de  representando um    Cíntia diz que é muito parceira de Scooby e que</segment>
    <segment id="37">, mesmo distante —ele está em Portugal—</segment>
    <segment id="38">, o casal não deixa de</segment>
    <segment id="39">sese falar.</segment>
    <segment id="40">"</segment>
    <segment id="41">Ele está lá com as crianças"</segment>
    <segment id="42">, diz.</segment>
    <segment id="43">"</segment>
    <segment id="44">E fica o tempo inteiro [falando]:</segment>
    <segment id="45">'Me manda foto de você aí</segment>
    <segment id="46">, por favor'.</segment>
    <segment id="47">Mas a minha bateria acabou de acabar.</segment>
    <segment id="48">Eu estou bem</segment>
    <segment id="49">, amor!</segment>
    <segment id="50">Está tudo certo"</segment>
    <segment id="51">, fala</segment>
    <segment id="52">, aos risos</segment>
    <segment id="53">, enquanto envia o recado por meio dos jornalistas.</segment>
  </rst>
</analysis>