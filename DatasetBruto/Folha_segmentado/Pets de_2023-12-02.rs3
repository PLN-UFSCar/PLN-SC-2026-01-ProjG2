  <rst>
    <segment id="1">Animais idosos</segment>
    <segment id="2">, com deficiência ou de porte grande geralmente são os mais rejeitados na fila da adoção.</segment>
    <segment id="3">Ao lado deles</segment>
    <segment id="4">, cães e gatos de pelagem preta também aguardam mais tempo para ganhar um lar.</segment>
    <segment id="5">Dorinha</segment>
    <segment id="6">, que aguarda adoção - Divulgação</segment>
    <segment id="7">Em Minas</segment>
    <segment id="8">, animais com pelagem escura sob os cuidados da Vale desde a tragédia de Brumadinho demoram</segment>
    <segment id="9">, em média</segment>
    <segment id="10">, quatro vezes mais para serem adotados em comparação a pets de pelagem clara</segment>
    <segment id="11">, segundo a empresa.</segment>
    <segment id="12">São cães e gatos oriundos da cidade e de outras áreas esvaziadas para obras de reparação.</segment>
    <segment id="13">De 2019 a 2023</segment>
    <segment id="14">, 546 pets foram adotados</segment>
    <segment id="15">, 25 deles com pelagem preta.</segment>
    <segment id="16">Contando apenas gatos</segment>
    <segment id="17">, foram 150 adoções</segment>
    <segment id="18">, sendo 4 de pelagem preta.</segment>
    <segment id="19">Felinos dessa coloração são também vítimas da superstição e costumam sofrer perseguição e maus-tratos motivados por preconceito e ignorância</segment>
    <segment id="20">, como</segment>
    <segment id="21">como já mostrou o blog Gatices.</segment>
    <segment id="22">Colunas e BlogsReceba no seu email uma seleção de colunas e blogs da FolhaCarregando...</segment>
    <segment id="23">Atualmente</segment>
    <segment id="24">, 339 animais —235 cães e 54 gatos— estão disponíveis para adoção.</segment>
    <segment id="25">Eles são cuidados pela Vale</segment>
    <segment id="26">, que mantém estruturas para acolhimento temporário de animais domésticos e silvestres das áreas atingidas pelo rompimento da barragem</segment>
    <segment id="27">, como</segment>
    <segment id="28">como parte dos compromissos apresentados pela empresa aos órgãos públicos após a tragédia</segment>
    <segment id="29">, que deixou 270 pessoas mortas.</segment>
    <segment id="30">O processo de adoção pode ser feito online.</segment>
    <segment id="31">O candidato a tutor pode conhecer os pets na página Me Leva pra Casa</segment>
    <segment id="32">, que reúne fotos</segment>
    <segment id="33">, descrição de porte e perfil social dos animais.</segment>
    <segment id="34">Depois</segment>
    <segment id="35">, o interessado precisa preencher um formulário e aguardar o retorno da equipe.</segment>
    <segment id="36">O animal é acompanhado ao longo dos seis primeiros meses com a nova família.</segment>
    <segment id="37">Animais com pelagem escura aguardam mais tempo por adoção Mais    novamente         de   de  de  representando um  +</segment>
    <segment id="38">Bom</segment>
    <segment id="39">Pra CachorroPapai Noel e Árvore da Audoção</segment>
