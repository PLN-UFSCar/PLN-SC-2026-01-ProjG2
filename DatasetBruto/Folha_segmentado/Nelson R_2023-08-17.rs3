    <segment id="217">, Alcemar Vieira</segment>
    <segment id="218">, Alan Ribeiro</segment>
    <segment id="219">, Thiago MarinhoDireção Sérgio MódenaVestido de NoivaQuando</segment>
    <segment id="220">De 17/8 a 24/9</segment>
    <segment id="221">; qui.</segment>
    <segment id="222">e sex.</segment>
    <segment id="223">às 19h</segment>
    <segment id="224">; sáb.</segment>
    <segment id="225">e dom. às 17hOnde CCBB - r. Álvares Penteado</segment>
    <segment id="226">, 112, São PauloPreço R$ 30Classificação 14 anosAutoria Nelson RodriguesElenco Camila Felix</segment>
    <segment id="227">, Henrique Torres Mourão</segment>
    <segment id="228">, Jonnatha Horta Fortes</segment>
    <segment id="229">, Júnio de Carvalho</segment>
    <segment id="230">, Priscila Natany e Victor VellosoDireção Ione de Medeiros</segment>
  </rst>
</analysis>