    <segment id="211">às 20h</segment>
    <segment id="212">; dom. 18hOnde Sesc Santo Amaro - r. Amador Bueno</segment>
    <segment id="213">, 505, São PauloPreço R$ 40Classificação 16 anosAutoria Nelson RodriguesElenco Camila Morgado</segment>
    <segment id="214">, Thelmo Fernandes</segment>
    <segment id="215">, Stela Freitas</segment>
