  <rst>
    <segment id="1">Agricultores franceses</segment>
    <segment id="2">, temendo uma intensa entrada de carne proveniente da América do Sul</segment>
    <segment id="3">, fizeram manifestação nesta quarta-feira (21) em todo o país</segment>
    <segment id="4">, na véspera da recepção de mil representantes do setor no Palácio do Eliseu pelo presidente Emmanuel  Macron.</segment>
    <segment id="5">Enquanto as negociações para um acordo de livre-comércio entre a União Europeia e o Mercosul foram retomadas em Assunção</segment>
    <segment id="6">, agricultores franceses</segment>
    <segment id="7">, abalados por uma crise</segment>
    <segment id="8">, temem a concorrência gerada pela importação anual para a Europa de entre 70 mil e 99 mil toneladas de carne bovina sul-americana sem tarifas aduaneiras.  "</segment>
    <segment id="9">O governo francês está nos abandonando"</segment>
    <segment id="10">, disse Sebastien Poncet</segment>
    <segment id="11">, presidente da Jovens Agricultores de Isere</segment>
    <segment id="12">, na França.</segment>
    <segment id="13">Poncet afirma que foram feitas promessas em negociações encerradas em dezembro.</segment>
    <segment id="14">"</segment>
    <segment id="15">Por outro lado</segment>
    <segment id="16">, assinaram acordos para importar carne de países onde os padrões não são os mesmos"</segment>
    <segment id="17">, reclama.</segment>
    <segment id="18">Com cerca de 50 agricultores</segment>
    <segment id="19">, ele estava distribuindo folhetos em um pedágio aos motoristas.</segment>
    <segment id="20">"</segment>
    <segment id="21">No Mercosul (Brasil</segment>
    <segment id="22">, Argentina</segment>
    <segment id="23">, Paraguai e Uruguai)</segment>
    <segment id="24">, nós sempre lhe dissemos</segment>
    <segment id="25">, no que diz respeito ao setor de carne bovina</segment>
    <segment id="26">, a conta não fecha"</segment>
    <segment id="27">, afirmou terça-feira o ministro da Agropecuária Stéphane Travert</segment>
    <segment id="28">, em mensagem de apoio aos criadores.</segment>
    <segment id="29">A França quer "garantir que esta cota de 70 mil toneladas esteja bem separada entre carne fresca e carne congelada"</segment>
    <segment id="30">, disse o ministro</segment>
    <segment id="31">, que também expressou o desejo de que as condições sejam estabelecidas sobre os critérios de qualidade e regulamentos sanitários em vigor na França.</segment>
    <segment id="32">Apesar dessa mensagem</segment>
    <segment id="33">, as manifestações acompanhadas de tratores</segment>
    <segment id="34">, sese espalharam em diversas regiões do Centro</segment>
    <segment id="35">, do Oeste e do Sudoeste.</segment>
    <segment id="36">"Macron Traidor" e "Mercosul</segment>
    <segment id="37">, distorção com certeza" eram algumas das frases de cartazes em Bordeaux.</segment>
    <segment id="38">Em algumas cidades</segment>
    <segment id="39">, foram despejados estrume e palha nas vias.</segment>
  </rst>
</analysis>