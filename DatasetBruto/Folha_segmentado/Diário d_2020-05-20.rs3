    <segment id="338">039;Contemplemos</segment>
    <segment id="339">, meditemos</segment>
    <segment id="340">, recordemos&amp;#039</segment>
    <segment id="341">;Dia 76:</segment>
    <segment id="342">&amp;#</segment>
    <segment id="343">039;A fábula do terrorista e da marquesa&amp;#039</segment>
    <segment id="344">;</segment>
    <segment id="345">Dia 77:</segment>
    <segment id="346">&amp;#</segment>
    <segment id="347">039;O informe da discórdia&amp;#039</segment>
    <segment id="348">;Dia 78:</segment>
    <segment id="349">&amp;#039;Lições da cólera em tempos de coronavírus&amp;#039</segment>
    <segment id="350">;Dia 79:</segment>
    <segment id="351">&amp;#</segment>
    <segment id="352">039;Nos deram um pouco de liberdade e agimos</segment>
    <segment id="353">comocomo</segment>
    <segment id="354">sese o vírus não existisse&amp;#039</segment>
    <segment id="355">;Dia 80:&amp;#039</segment>
    <segment id="356">;Sem pressa</segment>
    <segment id="357">, masmas sem pausa&amp;#039</segment>
    <segment id="358">;Dia 81: &amp;#039</segment>
    <segment id="359">;Botellones</segment>
    <segment id="360">, a nova discoteca pós-Covid&amp;#039</segment>
    <segment id="361">;Dia 82:</segment>
    <segment id="362">&amp;#039;Pandemia</segment>
    <segment id="363">, crise e racismo&amp;#039</segment>
    <segment id="364">;Dia 83:</segment>
    <segment id="365">&amp;#039;Sair da UTI para ver o mar&amp;#039</segment>
    <segment id="366">;Dia 84:</segment>
    <segment id="367">&amp;#039;A senhora deu positivo e deve</segment>
    <segment id="368">sese isolar imediatamente&amp;#039</segment>
    <segment id="369">;Dia 85:</segment>
    <segment id="370">&amp;#</segment>
    <segment id="371">039;A verdade é que é uma incerteza para todos&amp;#039</segment>
    <segment id="372">;Dia 86:&amp;#039</segment>
    <segment id="373">;A cultura de bar na Espanha é expressiva&amp;#039</segment>
    <segment id="374">;Dia 87: &amp;</segment>
    <segment id="375">#039;Todo cuidado é pouco e</segment>
    <segment id="376">, inclusive</segment>
    <segment id="377">, pode não ser suficiente&amp;#039</segment>
    <segment id="378">;Dia 88:</segment>
    <segment id="379">&amp;#</segment>
    <segment id="380">039;O vírus segue sendo uma ameaça&amp;#039</segment>
    <segment id="381">;Dia 89:</segment>
    <segment id="382">&amp;#</segment>
    <segment id="383">039;O fogo que nunca</segment>
    <segment id="384">sese apaga&amp;#039</segment>
    <segment id="385">;Dia 90:</segment>
    <segment id="386">&amp;#</segment>
    <segment id="387">039;Uma bolha</segment>
    <segment id="388">, uma família&amp;#039</segment>
    <segment id="389">;Dia 91:</segment>
    <segment id="390">&amp;#039;Músicos do mundinho</segment>
    <segment id="391">, uni-vos&amp;#039</segment>
    <segment id="392">;</segment>
    <segment id="393">Dia 92:</segment>
    <segment id="394">&amp;#</segment>
    <segment id="395">039;Como um clube de jazz dos anos</segment>
    <segment id="396">1930&amp;#039</segment>
    <segment id="397">;Dia 93:</segment>
    <segment id="398">&amp;#</segment>
    <segment id="399">039;Dinheiro</segment>
    <segment id="400">pode estar com os dias contados no pós-pandemia espanhol&amp;#039</segment>
    <segment id="401">;Dia 94:</segment>
    <segment id="402">&amp;#</segment>
    <segment id="403">039;Uma vida de mil e uma regrinhas&amp;#039</segment>
    <segment id="404">;Dia 95:</segment>
    <segment id="405">&amp;#039;Cada dia</segment>
    <segment id="406">, ao chegar em casa</segment>
    <segment id="407">, me isolava da minha família&amp;#039</segment>
    <segment id="408">;Dia 96:</segment>
    <segment id="409">&amp;#</segment>
    <segment id="410">039;Abraços</segment>
    <segment id="411">, mesmo que de plástico&amp;#039</segment>
    <segment id="412">;Dia 97:</segment>
    <segment id="413">&amp;#</segment>
    <segment id="414">039;Em casa com o agressor&amp;#039</segment>
    <segment id="415">;Dia 98:</segment>
    <segment id="416">&amp;#</segment>
    <segment id="417">039;Já vivemos</segment>
    <segment id="418">comocomo podemos</segment>
    <segment id="419">, e não há mais&amp;#039</segment>
    <segment id="420">;Dia 99:</segment>
    <segment id="421">&amp;#039;O ídolo pop e as amêndoas&amp;#039</segment>
