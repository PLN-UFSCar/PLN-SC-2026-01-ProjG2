    <segment id="237">;Dia 39:</segment>
    <segment id="238">&amp;#</segment>
    <segment id="239">039;O elaborado ritual do passeio em família&amp;#039</segment>
    <segment id="240">;Dia 40:&amp;#039</segment>
    <segment id="241">;A cidade mascarada&amp;#039</segment>
    <segment id="242">;Dia 41: &amp;#039</segment>
    <segment id="243">;Um Dia dos Namorados diferente&amp;#039</segment>
    <segment id="244">;Dia 42:</segment>
    <segment id="245">&amp;#039;Sair</segment>
    <segment id="246">, sim,</segment>
    <segment id="247">masmas com separação de brinquedos&amp;#039</segment>
    <segment id="248">;Dia 43:</segment>
    <segment id="249">&amp;#</segment>
    <segment id="250">039;Tínhamos</segment>
    <segment id="251">que tomar decisões duras e rápidas&amp;#039</segment>
    <segment id="252">;Dia 44:</segment>
