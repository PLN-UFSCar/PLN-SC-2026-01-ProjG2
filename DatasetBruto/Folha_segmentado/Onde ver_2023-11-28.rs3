  <rst>
    <segment id="1">Agentes britânicos que fracassaram em suas missões são reunidos numa subdivisão chamada Slogh House</segment>
    <segment id="2">, e por isto recebem o apelido de "slow horses"</segment>
    <segment id="3">, ou cavalos lentos.</segment>
    <segment id="4">Gary Oldman</segment>
    <segment id="5">, Rosalind Eleazar e Dustin Demri-Burns em cena da série &amp;#039</segment>
    <segment id="6">;Slow Horses&amp;#039</segment>
    <segment id="7">;, do Apple TV+ - DivulgaçãoNa terceira temporada da série de espionagem "</segment>
    <segment id="8">Slow Horses"</segment>
    <segment id="9">, um contato em Istambul ameaça expor um segredo que põe em risco toda a organização.</segment>
    <segment id="10">Com Gary Oldman</segment>
    <segment id="11">, Kristin Scott Thomas e Sophie Okonedo e Jonathan Pryce.</segment>
    <segment id="12">Apple TV+</segment>
    <segment id="13">, 16 anos</segment>
    <segment id="14">Olóládé</segment>
    <segment id="15">Dois amigos ficam ricos de uma hora para a outra e embarcam na vida boa.</segment>
    <segment id="16">Mas, quando a origem da fortuna é relevada</segment>
    <segment id="17">, eles precisam recorrer à lavagem de dinheiro e até mesmo a assassinatos.</segment>
    <segment id="18">Série cômica da Nigéria.  Neftlix</segment>
    <segment id="19">, 14 anos</segment>
    <segment id="20">Ao Seu Lado  Dois jogadores de rúgbi</segment>
    <segment id="21">, Mark e Warren</segment>
    <segment id="22">, começam a namorar</segment>
    <segment id="23">, masmas têm medo que</segment>
    <segment id="24">, sese sua paixão for revelada</segment>
    <segment id="25">, o clube decadente pelo qual ambos jogam sofra um golpe fatal.</segment>
    <segment id="26">Prime Video</segment>
    <segment id="27">, 16 anos   Quitandas e Quitandeiras</segment>
    <segment id="28">A equipe da Record Minas percorreu várias cidades do estado para registrar quitutes</segment>
    <segment id="29">, guloseimas e biscoitos regionais feitas à base de frutas</segment>
    <segment id="30">, coco</segment>
    <segment id="31">, amendoim</segment>
    <segment id="32">, massa folhada e até mesmo amoníaco</segment>
    <segment id="33">, para esta série documental.</segment>
    <segment id="34">Play Plus</segment>
    <segment id="35">, livre   Santos Dumont</segment>
    <segment id="36">O canal passa a exibir a minissérie sobre Alberto Santos Dumont</segment>
    <segment id="37">, transmitida em 2019 pela HBO</segment>
    <segment id="38">, ao ritmo de dois episódios por dia</segment>
    <segment id="39">, até sexta.</segment>
    <segment id="40">João Pedro Zappa brilha no papel principal.</segment>
    <segment id="41">Conheça Santos Dumont</segment>
    <segment id="42">, o brasileiro que inventou o aviãoMais    novamente         de   de  de  representando um  Canal Brasil</segment>
    <segment id="43">, 18h35</segment>
    <segment id="44">, 14 anos</segment>
    <segment id="45">Infiltrado  Jason Statham faz um segurança de carro-forte que atrai suspeitas sobre si depois de exibir habilidades surpreendentes durante um assalto.</segment>
    <segment id="46">Direção de Guy Ritchie.</segment>
    <segment id="47">Confira cenas de &amp;#039</segment>
    <segment id="48">;Infiltrado&amp;#039</segment>
    <segment id="49">;, novo filme de Guy RitchieMais    novamente         de   de  de  representando um  Megapix</segment>
    <segment id="50">, 21h, 16 anos</segment>
    <segment id="51">Get On Up – A História de James Bown  Chadwick Boseman</segment>
    <segment id="52">, o Pantera Negra</segment>
    <segment id="53">, completaria 46 anos nesta quarta.</segment>
    <segment id="54">Para homenageá-lo</segment>
    <segment id="55">, o canal exibe outro de seus filmes de destaque</segment>
    <segment id="56">, uma cinebiografia de James Brown</segment>
    <segment id="57">, o rei da soul music.</segment>
