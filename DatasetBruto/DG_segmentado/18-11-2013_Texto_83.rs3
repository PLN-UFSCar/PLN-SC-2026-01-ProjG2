    <segment id="30">Mas a fase ГѓВ©</segment>
    <segment id="31">, inegavelmente</segment>
    <segment id="32">, muito ruim.</segment>
    <segment id="33">Agora, atГѓВ© o ГѓВЎrbitro puxa o Inter para baixo.</segment>
    <segment id="34">ГѓвЂ° difГѓВ­cil os colorados dormirem com esse pesadelo rondando seus travesseiros?</segment>
    <segment id="35">ContrataГѓВ§ГѓВЈo</segment>
    <segment id="36">Na medida em que o BrasileirГѓВЈo</segment>
    <segment id="37">sese aproxima do final</segment>
