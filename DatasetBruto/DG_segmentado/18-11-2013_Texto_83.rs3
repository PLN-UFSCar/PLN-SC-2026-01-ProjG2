    <segment id="21">, no segundo tempo</segment>
    <segment id="22">, o ГѓВЎrbitro expulsou o centroavante Rafael Moura</segment>
    <segment id="23">, por reclamaГѓВ§ГѓВЈo</segment>
    <segment id="24">, fragilizando ainda mais o Inter.</segment>
    <segment id="25">Com dez jogadores</segment>
    <segment id="26">, o Colorado levou mais dois gols</segment>
    <segment id="27">, marcados por Hugo e Roni.</segment>
    <segment id="28">Pelo que o Inter jogou no primeiro tempo</segment>
