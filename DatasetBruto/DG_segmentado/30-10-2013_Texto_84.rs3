    <segment id="69">O que doar
- Quem quiser fazer doa횄짠횄쨉es</segment>
    <segment id="70">, os itens necess횄징rios s횄짙o alimentos (principalmente arroz e a횄짠횄쨘car).</segment>
    <segment id="71">S횄짙o aceitos colch횄쨉es</segment>
    <segment id="72">, cobertores e produtos de higiene e limpeza.</segment>
    <segment id="73">As doa횄짠횄쨉es podem ser entregues no gin횄징sio (Rua 24 de Agosto</segment>
    <segment id="74">, 3079).</segment>
    <segment id="75">Como se</segment>
    <segment id="76">se cadastrar
- V횄짯timas devem ir at횄짤 a prefeitura.</segment>
    <segment id="77">FGTS
- Para as v횄짯timas de quarta-feira</segment>
    <segment id="78">, a prefeitura dever횄징 solicitar 횄혻 Caixa a permiss횄짙o para retirada de parte do fundo.</segment>
    <segment id="79">Esse processo deve demorar cerca de dois meses para ser liberado.
 Doa횄짠횄쨉es n횄짙o chegaram 
N횄징dia Pereira</segment>
    <segment id="80">, 59 anos</segment>
    <segment id="81">, presidente da Associa횄짠횄짙o de Moradores da Vila Nova</segment>
    <segment id="82">, contou que h횄징 moradores que ainda n횄짙o voltaram para casa pela falta de colch횄쨉es e alimentos.
- Aqui</segment>
    <segment id="83">, as pessoas n횄짙o receberam quase nada.</segment>
    <segment id="84">Estamos no maior sufoco.</segment>
    <segment id="85">M횄짙e de cinco crian횄짠as e gestante de oito meses</segment>
    <segment id="86">, a dona de casa Ana Cl횄징udia da Silva</segment>
    <segment id="87">, 26 anos</segment>
    <segment id="88">, ganhou tr횄짧s colch횄쨉es e outros itens de uma ong:
- O que as pessoas tinham para doar</segment>
    <segment id="89">, j횄징 doaram em agosto.</segment>
    <segment id="90">Na enchente de tr횄짧s meses atr횄징s</segment>
    <segment id="91">, o com횄짤rcio de Ad횄짙o Silva da Trindade</segment>
    <segment id="92">, 54 anos</segment>
    <segment id="93">, na Vila Nova</segment>
    <segment id="94">, ficou inundado</segment>
    <segment id="95">, masmas voltou a funcionar.</segment>
    <segment id="96">Na semana passada</segment>
    <segment id="97">, o preju횄짯zo foi tanto que ele desistiu:
- Aluguei para uma igreja.</segment>
    <segment id="98">Chega de com횄짤rcio.</segment>
    <segment id="99">Agora, perdi freezer</segment>
    <segment id="100">, geladeira</segment>
    <segment id="101">, televis횄짙o.</segment>
    <segment id="102">Ontem, por conta da umidade</segment>
    <segment id="103">, a casa dele ainda cheirava a mofo.</segment>
    <segment id="104">Os arm횄징rios est횄짙o inutilizados.</segment>
    <segment id="105">Colch횄쨉es foram perdidos:
