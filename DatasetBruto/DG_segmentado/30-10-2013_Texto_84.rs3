  <rst>
    <segment id="1">Espera na seca</segment>
    <segment id="2">Demora na ajuda a v횄짯timas da chuva em Esteio
Moradores reclamam da demora na entrega de donativos a v횄짯timas de alagamento</segment>
    <segment id="3">, ocorrido h횄징 uma semana.</segment>
    <segment id="4">Prefeitura cita a burocracia</segment>
    <segment id="5">comocomo entrave</segment>
    <segment id="6">Demora na ajuda a v횄짯timas da chuva em Esteio</segment>
    <segment id="7">Carmen ajuda na separa횄짠횄짙o de roupas no Gin횄징sio Edgar Piccioni
Roberta Schuler
roberta.schuler@diariogaucho.com.br</segment>
    <segment id="8">Uma semana depois</segment>
    <segment id="9">, boa parte das fam횄짯lias de Esteio que foram atingidas pela enxurrada ainda espera por doa횄짠횄쨉es.</segment>
    <segment id="10">As 횄징reas mais afetadas foram contempladas</segment>
    <segment id="11">, masmas a prefeitura alega que tr횄짖mites burocr횄징ticos impedem a agilidade sonhada por quem perdeu muito.</segment>
    <segment id="12">Ontem, foi dia de triagem para conferir os cadastros das v횄짯timas - 3 mil</segment>
    <segment id="13">, entre desabrigadas e desalojadas.
- As entregas foram interrompidas</segment>
    <segment id="14">porque</segment>
    <segment id="15">porque havia fam횄짯lias com cadastro em dois lugares - disse a secret횄징ria de cidadania e desenvolvimento social</segment>
    <segment id="16">, M횄징rcia Busatto.</segment>
    <segment id="17">A secret횄징ria garante que a entrega ser횄징 retomada hoje e conclu횄짯da at횄짤</segment>
    <segment id="18">o final de semana.</segment>
    <segment id="19">Al횄짤m dos donativos depositados no Gin횄징sio Edgar Piccioni (ponto central de arrecada횄짠횄쨉es)</segment>
    <segment id="20">, a prefeitura adquiriu cestas b횄징sicas</segment>
    <segment id="21">, colch횄쨉es</segment>
