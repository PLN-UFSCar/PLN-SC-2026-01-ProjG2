    <segment id="23">Volunt횄징rias d횄짙o exemplo
No gin횄징sio h횄징 roupas</segment>
    <segment id="24">, alimentos</segment>
    <segment id="25">, 횄징gua</segment>
    <segment id="26">, colch횄쨉es</segment>
    <segment id="27">, cobertores e m횄쨀veis.</segment>
    <segment id="28">Uma das volunt횄징rias foi a representante de vendas Sirlei Nunes</segment>
    <segment id="29">, 56 anos</segment>
    <segment id="30">, de Sapucaia:
- Tirei folga no trabalho e resolvi ajudar</segment>
    <segment id="31">, fazer a minha parte.</segment>
    <segment id="32">A dona de casa Carmen Machado</segment>
    <segment id="33">, 68 anos</segment>
    <segment id="34">, tamb횄짤m abra횄짠ou a causa:
- S횄쨀 saio daqui quando tudo estiver pronto.</segment>
    <segment id="35">Enquanto separo as roupas</segment>
    <segment id="36">, penso nas pessoas.</segment>
    <segment id="37">Manifesta횄짠횄쨉es na cidade e na 116
Um dos pontos para onde sacos cheios de roupas foram levados de caminh횄짙o foi o Centro de Conviv횄짧ncia do Territ횄쨀rio da Paz</segment>
    <segment id="38">, no Parque Primavera.</segment>
    <segment id="39">O pedreiro Jorge Ata횄짯des Borges</segment>
    <segment id="40">, 49 anos</segment>
    <segment id="41">, da Travessa Jorge Morais de Souza</segment>
    <segment id="42">, afirmou:
- Vamos viver a vida de doa횄짠횄쨉es?</segment>
    <segment id="43">Precisamos que resolvam o problema</segment>
    <segment id="44">, retirem os moradores desta 횄징rea.</segment>
    <segment id="45">Ontem ocorreu protesto na Vila Os횄쨀rio no final da tarde.</segment>
    <segment id="46">A BR-116 sofreu</segment>
    <segment id="47">interdi횄짠횄쨉es tamb횄짤</segment>
    <segment id="48">m. Nova manifesta횄짠횄짙o deve ocorrer 횄혻s 20h de hoje</segment>
    <segment id="49">, na Rua Coronel Serafim Pereira.</segment>
