    <segment id="32">, sigo acreditando</segment>
    <segment id="33">, inclusive</segment>
    <segment id="34">, numa queda dos dois l횄짯deres.</segment>
    <segment id="35">Assim, 횄짤 deveras importante que o povo tricolor compare횄짠a na Arena hoje</segment>
    <segment id="36">횄혻 noite</segment>
    <segment id="37">, num hor횄징rio cedo</segment>
    <segment id="38">, com tempo de retornar para casa ainda bem antes da madrugada.</segment>
