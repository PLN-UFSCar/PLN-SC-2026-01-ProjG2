  <rst>
    <segment id="1">Rumo ao recorde do cr횄짤dito imobili횄징rio no pa횄짯s</segment>
    <segment id="2">Os empr횄짤stimos para compra e constru횄짠횄짙o de im횄쨀veis no pa횄짯s alcan횄짠aram o valor de R$ 49</segment>
    <segment id="3">,6 bilh횄쨉es no primeiro semestre de 2013 - 34% a mais que os R$ 37 bilh횄쨉es do mesmo per횄짯odo de 2012 - de acordo com a Associa횄짠횄짙o Brasileira das Entidades de Cr횄짤dito Imobili횄징rio e Poupan횄짠a (Abecip).</segment>
    <segment id="4">O volume 횄짤 o maior j횄징 registrado em um 횄쨘nico semestre.</segment>
    <segment id="5">Os dados levam em conta apenas os financiamentos com recursos da poupan횄짠a.</segment>
    <segment id="6">Pelas regras do Banco Central</segment>
    <segment id="7">, 65% do saldo da caderneta devem ser direcionados para o cr횄짤dito imobili횄징rio.</segment>
    <segment id="8">Somente em junho</segment>
    <segment id="9">, foram concedidos R$ 11</segment>
    <segment id="10">,2 bilh횄쨉es</segment>
    <segment id="11">, alta de 51% sobre o volume do mesmo m횄짧s no ano passado e aumento de 15% em rela횄짠횄짙o a maio de 2013.</segment>
    <segment id="12">Em n횄쨘mero de unidades</segment>
    <segment id="13">, nos primeiros seis meses desse ano</segment>
    <segment id="14">, foram financiados 244</segment>
    <segment id="15">,7 mil im횄쨀veis</segment>
    <segment id="16">, 14% a mais que no mesmo per횄짯odo em 2012.</segment>
    <segment id="17">Consumidor deve manter a cautela</segment>
    <segment id="18">Com o resultado</segment>
    <segment id="19">, a Abecip mant횄짤m a proje횄짠횄짙o de crescimento do cr횄짤dito em</segment>
    <segment id="20">, pelo menos</segment>
    <segment id="21">, 15% neste ano</segment>
    <segment id="22">, chegando a R$ 95</segment>
    <segment id="23">,2 bilh횄쨉es.</segment>
    <segment id="24">A meta representa um novo recorde</segment>
    <segment id="25">, superando o j횄징 hist횄쨀rico desempenho do ano passado.</segment>
    <segment id="26">O motivo da alta no primeiro semestre foi o volume</segment>
    <segment id="27">"represado" no fim de 2012 e que acabou "desaguando" agora</segment>
    <segment id="28">, afirma o presidente da Abecip</segment>
    <segment id="29">, Octavio de Lazari Junior.</segment>
    <segment id="30">Para o executivo</segment>
    <segment id="31">, a proje횄짠횄짙o de alta 횄짤 "saud횄징vel" para o setor.</segment>
    <segment id="32">Na avalia횄짠횄짙o de Alexandra Almawi</segment>
    <segment id="33">, economista da Lerosa Investimentos</segment>
    <segment id="34">, por횄짤m</segment>
    <segment id="35">, a expans횄짙o do cr횄짤dito agora 횄짤 pontual:
- No cen횄징rio atual</segment>
    <segment id="36">, de economia crescendo pouco</segment>
    <segment id="37">, renda caindo e infla횄짠횄짙o preocupante</segment>
    <segment id="38">, o consumidor deve seguir conservador na tomada de empr횄짤stimos longos.</segment>
    <segment id="39">Em rela횄짠횄짙o aos pre횄짠os</segment>
    <segment id="40">, Alexandra projeta que n횄짙o deve ocorrer queda</segment>
    <segment id="41">, masmas os aumentos devem acompanhar a infla횄짠횄짙o</segment>
    <segment id="42">, sem subir muito acima dela</segment>
    <segment id="43">, como</segment>
    <segment id="44">como ocorreu em anos anteriores.
- FGTS - O valor m횄징ximo de im횄쨀veis para financiamento pelo Sistema</segment>
    <segment id="45">Financeiro da Habita횄짠횄짙o (SFH) - que possibilita uso de recursos do Fundo de Garantia do Tempo de Servi횄짠o (FGTS) e juro menor - pode subir de R$ 500 mil para R$ 750 mil ainda neste ano.</segment>
    <segment id="46">A proposta da Abecip est횄징 sob an횄징lise do governo federal.</segment>
  </rst>
