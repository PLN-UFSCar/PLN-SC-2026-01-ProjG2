    <segment id="7">Carolina Rocha
carolina.rocha@diariogaucho.com.br</segment>
    <segment id="8">O titular da 2횂짧 DP de Sapucaia</segment>
    <segment id="9">, delegado Eduardo Moraes</segment>
    <segment id="10">, pediu ontem ao Hospital Get횄쨘lio Vargas mais informa횄짠횄쨉es sobre o homic횄짯dio seguido de suic횄짯dio que chocou o Estado na manh횄짙 de quarta-feira.</segment>
    <segment id="11">O policial civil tem d횄쨘vidas em rela횄짠횄짙o ao estado e as condi횄짠횄쨉es</segment>
    <segment id="12">em que a dona de casa Rosimeri da Silva An횄쨀rio</segment>
    <segment id="13">, 51 anos</segment>
    <segment id="14">, e o ex-companheiro</segment>
    <segment id="15">, Jerri Eder Aguiar de Oliveira</segment>
    <segment id="16">, 41 anos</segment>
    <segment id="17">, chegaram 횄혻 institui횄짠횄짙o.</segment>
    <segment id="18">Ele tamb횄짤m encaminhou perguntas ao IGP sobre a cena do crime e sobre o exame dos corpos.</segment>
    <segment id="19">Por volta das 7h</segment>
    <segment id="20">, o Gate invadiu a casa da Rua S횄짙o Caetano ap횄쨀s mais de 21 horas de c횄징rcere privado.</segment>
    <segment id="21">Rosimeri</segment>
    <segment id="22">, resgatada inconsciente</segment>
    <segment id="23">, foi reanimada por socorristas do Samu</segment>
    <segment id="24">, masmas n횄짙o resistiu a uma nova parada card횄짯aca e faleceu 횄혻s 9h18min de ontem.</segment>
    <segment id="25">Desde que foi internada</segment>
    <segment id="26">, ela respirava apenas com a ajuda de aparelhos.</segment>
    <segment id="27">Ontem 횄혻 tarde</segment>
    <segment id="28">, legistas do DML de Canoas examinaram o corpo de Rosimeri.</segment>
    <segment id="29">O resultado do exame</segment>
    <segment id="30">, que tenta esclarecer o que aconteceu com a mulher durante o tempo em que ficou ref횄짤m</segment>
    <segment id="31">, ser횄징 enviado para a 2횂짧 DP.</segment>
    <segment id="32">O delegado pediu aos legistas mais informa횄짠횄쨉es sobre o tipo de agress횄쨉es que ela sofreu e sobre o modo</segment>
    <segment id="33">comocomo foi estrangulada por Jerri.</segment>
    <segment id="34">Ele quer saber ainda</segment>
    <segment id="35">sese ela sofreu abusos durante o per횄짯odo.
Respons횄징vel pela equipe m횄짤dica do hospital</segment>
    <segment id="36">, Marcelo Saldanha afirmou que a paciente j횄징 chegou em coma.</segment>
    <segment id="37">Segundo o m횄짤dico</segment>
