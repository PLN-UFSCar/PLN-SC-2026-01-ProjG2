    <segment id="190">, na qual dizia estar deprimido e decepcionado com a fam횄짯lia.</segment>
    <segment id="191">Devido 횄혻s brigas constantes</segment>
    <segment id="192">,</segment>
    <segment id="193">a mulher j횄징 tinha uma medida protetiva contra o ex-companheiro</segment>
