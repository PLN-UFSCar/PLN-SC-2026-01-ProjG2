    <segment id="143">O CASO
Por volta das 7h desta quarta-feira</segment>
    <segment id="144">, o homem que mantinha a ex-companheira por mais de 20 horas sob c횄징rcere privado foi encontrado morto na casa por policiais em Sapucaia do Sul.</segment>
    <segment id="145">O Grupo de A횄짠횄쨉es T횄징ticas Especiais (Gate) da Brigada Militar (BM) invadiu a casa na Rua S횄짙o Caetano</segment>
    <segment id="146">, bairro Vila Vargas</segment>
    <segment id="147">, utilizando bombas de efeito moral.</segment>
    <segment id="148">Cinco minutos antes da a횄짠횄짙o</segment>
    <segment id="149">, policiais militares movimentaram viaturas e cercaram a 횄징rea da resid횄짧ncia.</segment>
    <segment id="150">Uma ambul횄짖ncia do Servi횄짠o de Atendimento M횄쨀vel de Urg횄짧ncia (Samu) foi posta em frente</segment>
    <segment id="151">횄혻 moradia.</segment>
    <segment id="152">Jerry Eder Aguiar</segment>
    <segment id="153">, 41 anos</segment>
    <segment id="154">, sese enforcou dentro da casa e Rosemeri da Silva Anori</segment>
    <segment id="155">, 51 anos</segment>
    <segment id="156">, ferida em estado grav횄짯ssimo.
- Mantivemos contato de 30 em 30 minutos durante toda a madrugada.</segment>
    <segment id="157">Na 횄쨘ltima liga횄짠횄짙o</segment>
    <segment id="158">, ele pediu que o defensor e a imprensa estivessem presentes</segment>
    <segment id="159">, que iria</segment>
    <segment id="160">sese entregar.</segment>
    <segment id="161">Depois</segment>
    <segment id="162">, n횄짙o atendeu mais e a casa ficou silenciosa.</segment>
    <segment id="163">O negociador tentou</segment>
    <segment id="164">sese aproximar 횄혻 resid횄짧ncia e conversar</segment>
    <segment id="165">, masmas n횄짙o obteve resposta.</segment>
    <segment id="166">Da횄짯 determinamos a invas횄짙o t횄징tica - disse o subcomandante da BM</segment>
    <segment id="167">, coronel Silanus Melo</segment>
    <segment id="168">, ap횄쨀s a a횄짠횄짙o.</segment>
    <segment id="169">Conforme Silanus</segment>
    <segment id="170">, o sof횄징 trancava a porta e Rosemeri estava desacordada sobre o m횄쨀vel.</segment>
    <segment id="171">Aguiar foi encontrado enforcado por uma corda</segment>
    <segment id="172">, j횄징 morto.</segment>
    <segment id="173">Ele teria tentado asfixiar a ex-companheira</segment>
    <segment id="174">, de acordo com o coronel.</segment>
    <segment id="175">Ap횄쨀s atendimento na ambul횄짖ncia</segment>
    <segment id="176">, Rosemeri foi transferida para o Hospital Get횄쨘lio Vargas.
- A t횄짤cnica 횄짤 de que</segment>
    <segment id="177">, enquanto h횄징 negocia횄짠횄짙o</segment>
    <segment id="178">, n횄짙o invadimos - frisou Silanus.</segment>
    <segment id="179">Por volta das 23h</segment>
    <segment id="180">, a pol횄짯cia colocou Aguiar em contato com o defensor do munic횄짯pio M횄징rio Rheingantz.</segment>
    <segment id="181">Por telefone</segment>
    <segment id="182">, Rheingantz deu orienta횄짠횄쨉es jur횄짯dicas para Jerry.</segment>
    <segment id="183">O defensor prestou esclarecimentos e garantiu acompanhamento do</segment>
    <segment id="184">casocaso.
- Ele queria saber as consequ횄짧ncias deste ato - lembrou.</segment>
    <segment id="185">A rua segue isolada at횄짤 a conclus횄짙o dos trabalhos da per횄짯cia.</segment>
    <segment id="186">Aguiar invadiu a casa de Rosemeri por volta das 10h30min de ter횄짠a-feira.</segment>
    <segment id="187">Ele a amea횄짠ava com uma faca de cozinha.</segment>
    <segment id="188">Meia hora depois</segment>
