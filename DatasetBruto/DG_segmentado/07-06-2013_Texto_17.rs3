    <segment id="88">O negociador 횄짤 quem estabelece o que deve ser feito.
DG - Por que a BM n횄짙o tomou a casa quando ele entregou o beb횄짧</segment>
    <segment id="89">, ter횄짠a?</segment>
    <segment id="90">Coronel - Eu n횄짙o posso te responder em que situa횄짠횄짙o foi entregue o beb횄짧</segment>
    <segment id="91">porque</segment>
    <segment id="92">porque cheguei l횄징 somente</segment>
    <segment id="93">횄혻s 19h30min</segment>
    <segment id="94">, e isso j횄징 tinha ocorrido.</segment>
    <segment id="95">Pelo que me consta</segment>
    <segment id="96">, ele abriu a porta</segment>
    <segment id="97">, botou o beb횄짧 no carrinho e o empurrou para fora.
DG - O tempo entre o 횄쨘ltimo contato com o negociador e a invas횄짙o do Gate n횄짙o foi demasiado?</segment>
    <segment id="98">Coronel - N횄짙o.</segment>
    <segment id="99">Nem n횄쨀s temos certeza exata</segment>
    <segment id="100">, pois</segment>
    <segment id="101">pois as coisas s횄짙o t횄짙o din횄짖micas.</segment>
    <segment id="102">Mas, com certeza</segment>
    <segment id="103">, n횄짙o houve tanto tempo.</segment>
    <segment id="104">O m횄짤dico que recebeu ela disse que</segment>
    <segment id="105">sese n횄쨀s tiv횄짤ssemos demorado mais um ou dois minutos</segment>
    <segment id="106">, talvez nem tivessem conseguido recuper횄징-la.</segment>
    <segment id="107">Em torno de uns quatro minutos antes</segment>
