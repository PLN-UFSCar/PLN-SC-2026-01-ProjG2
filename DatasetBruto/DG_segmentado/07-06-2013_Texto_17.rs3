DG - Quem retirou Jerri do fio?</segment>
    <segment id="132">Ele ainda tinha sinais vitais?</segment>
    <segment id="133">Coronel - Somente quem entrou foi o Gate.</segment>
    <segment id="134">Assim que os PMs entraram</segment>
    <segment id="135">, apanharam ela e a levaram para a ambul횄짖ncia.</segment>
    <segment id="136">E, imediatamente</segment>
    <segment id="137">, levaram ele.</segment>
    <segment id="138">O m횄짤dico chegou e constatou que ele j횄징 estava em 횄쨀bito.</segment>
    <segment id="139">Ele foi levado at횄짤 pr횄쨀ximo a ambul횄짖ncia.</segment>
