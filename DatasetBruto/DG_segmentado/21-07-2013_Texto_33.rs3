    <segment id="57">sese tivesse abandonado o idoso.</segment>
    <segment id="58">NГѓВЈo hГѓВЎ prazo especГѓВ­fico</segment>
    <segment id="59">, masmas ГѓВ© questГѓВЈo de bom senso esperar alguns dias Гўв‚¬</segment>
    <segment id="60">вЂњ continuou.</segment>
    <segment id="61">O caso</segment>
    <segment id="62">caso veio ГѓВ  tona dia 12.</segment>
    <segment id="63">Um casal passava em frente ГѓВ  clГѓВ­nica e viu uma idosa</segment>
    <segment id="64">, na grade da frente</segment>
    <segment id="65">, gritando por socorro.</segment>
    <segment id="66">Em seguida</segment>
    <segment id="67">, uma funcionГѓВЎria veio de dentro da clГѓВ­nica para fazer com que a mulher</segment>
    <segment id="68">, de 83 anos</segment>
    <segment id="69">, voltasse para dentro.</segment>
    <segment id="70">A partir daГѓВ­</segment>
    <segment id="71">, as informaГѓВ§ГѓВµes sГѓВЈo conflitantes.</segment>
    <segment id="72">A mulher que passava em frente</segment>
    <segment id="73">, designer de interiores que mora no bairro</segment>
    <segment id="74">, divulgou no facebook que a idosa foi agredida com socos pela funcionГѓВЎria.</segment>
    <segment id="75">O post tinha quase 15 mil compartilhamentos atГѓВ© dia 18</segment>
    <segment id="76">, e diversos comentГѓВЎrios de pessoas indignadas.</segment>
    <segment id="77">O dono da clГѓВ­nica</segment>
    <segment id="78">, porГѓВ©m</segment>
    <segment id="79">, alega que nГѓВЈo houve agressГѓВЈo</segment>
    <segment id="80">, e que a funcionГѓВЎria</segment>
    <segment id="81">, que trabalha na casa hГѓВЎ quatro anos</segment>
    <segment id="82">, apenas a puxou para dentro.</segment>
    <segment id="83">Com a grande repercussГѓВЈo na internet</segment>
    <segment id="84">, o local recebeu "visitas" do poder pГѓВєblico.</segment>
    <segment id="85">Titular da Delegacia do Idoso</segment>
    <segment id="86">, o delegado Antonio Paulo Torres Machado esteve na casa e nГѓВЈo achou sinais de maus-tratos e irregularidades - ouvidas informalmente</segment>
    <segment id="87">, seis mulheres disseram ser bem tratadas.</segment>
    <segment id="88">A fiscalizaГѓВ§ГѓВЈo da VigilГѓВўncia SanitГѓВЎria tambГѓВ©m compareceu e</segment>
    <segment id="89">, em vistoria</segment>
    <segment id="90">, encontrou problemas</segment>
    <segment id="91">comocomo a falta de corrimГѓВЈo em dois corredores.</segment>
    <segment id="92">E na cozinha: alimentos mal acomodados e quatro iogurtes vencidos - os potes</segment>
    <segment id="93">, segundo o proprietГѓВЎrio da clГѓВ­nica</segment>
    <segment id="94">, foram levados pelos filhos da idosa que gritou na porta da frente</segment>
    <segment id="95">, e como</segment>
    <segment id="96">como ela nГѓВЈo quis comer</segment>
    <segment id="97">, acabaram vencendo</segment>
    <segment id="98">, masmas seriam jogados fora.</segment>
    <segment id="99">Na mesma tarde</segment>
    <segment id="100">, a clГѓВ­nica foi comunicada da interdiГѓВ§ГѓВЈo cautelar</segment>
    <segment id="101">, e adesivos com a palavra "Interditado" foram colados nos muros da geriatria.</segment>
    <segment id="102">Ontem ГѓВ  tarde</segment>
    <segment id="103">, Clovanir Rodrigues disse que espera</segment>
    <segment id="104">, "em poucos dias"</segment>
    <segment id="105">, terminar as reformas exigidas pela VigilГѓВўncia SanitГѓВЎria.</segment>
    <segment id="106">A Delegacia do Idoso pretende ouvir</segment>
    <segment id="107">, a partir de hoje</segment>
    <segment id="108">, pacientes e funcionГѓВЎrios da clГѓВ­nica para apurar</segment>
    <segment id="109">sese hГѓВЎ algum tipo de irregularidade.</segment>
