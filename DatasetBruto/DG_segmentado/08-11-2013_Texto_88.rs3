Aline Cust횄쨀dio
aline.custodio@diariogaucho.com.br</segment>
    <segment id="4">A dire횄짠횄짙o da Escola Municipal de Ensino Fundamental S횄짙o Francisco de Assis</segment>
    <segment id="5">, no Bairro Colina</segment>
    <segment id="6">, em Gua횄짯ba</segment>
    <segment id="7">,decidiu suspender as aulas desta sexta-feira para evitar novos transtornos com as abelhas.</segment>
