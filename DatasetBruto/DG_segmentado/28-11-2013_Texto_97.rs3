  <rst>
    <segment id="1">Dicas de quem sabe</segment>
    <segment id="2">Hoteleiros mandam recados para JosГѓВ© Dirceu</segment>
    <segment id="3">, novo colega da categoria</segment>
    <segment id="4">FuncionГѓВЎrios de hotГѓВ©is da Capital dГѓВЈo dicas para mensaleiro e novo colega JosГѓВ© Dirceu.</segment>
    <segment id="5">Ex-ministro receberГѓВЎ R$ 20 mil por mГѓВЄs</segment>
