    <segment id="99">Denigre a imagem do setor</segment>
    <segment id="100">, que ГѓВ© sГѓВ©rio.</segment>
    <segment id="101">ГѓвЂ° melhor ele ter cuidado</segment>
    <segment id="102">, porque</segment>
    <segment id="103">porque nos hotГѓВ©is e em redes sГѓВ©rias existem auditorias independentes e implacГѓВЎveis.</segment>
