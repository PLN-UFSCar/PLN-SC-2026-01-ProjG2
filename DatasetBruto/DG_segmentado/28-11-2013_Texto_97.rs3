    <segment id="8">Hoteleiros mandam recados para JosГѓВ© Dirceu</segment>
    <segment id="9">, novo colega da categoria
Eduardo Rodrigues
eduardo.rodrigues@diariogaucho.com.br</segment>
    <segment id="10">Nunca antes na histГѓВіria deste paГѓВ­s a reinserГѓВ§ГѓВЈo de um preso na sociedade foi tГѓВЈo rГѓВЎpida e com salГѓВЎrio tГѓВЈo alto.</segment>
    <segment id="11">Condenado no processo do MensalГѓВЈo e preso em regime semiaberto na penitenciГѓВЎria da Papuda</segment>
    <segment id="12">, em BrasГѓВ­lia</segment>
    <segment id="13">, o ex-ministro da Casa Civil JosГѓВ© Dirceu foi contratado pelo Hotel Saint Peter para trabalhar</segment>
    <segment id="14">comocomo gerente administrativo e ganhar R$ 20 mil mensais.</segment>
    <segment id="15">A carteira foi assinada na sexta-feira passada.</segment>
    <segment id="16">Se for autorizado pela Vara de ExecuГѓВ§ГѓВµes Penais</segment>
    <segment id="17">, Dirceu trabalharГѓВЎ</segment>
    <segment id="18">das 8h</segment>
    <segment id="19">ГѓВ s 17h.</segment>
    <segment id="20">Motivo de piada e deboche</segment>
    <segment id="21">A notГѓВ­cia foi encarada</segment>
    <segment id="22">comocomo deboche na rede hoteleira da Capital</segment>
    <segment id="23">, onde o salГѓВЎrio de um bom gerente</segment>
    <segment id="24">, com anos de experiГѓВЄncia na funГѓВ§ГѓВЈo</segment>
    <segment id="25">, varia de R$ 5 mil a R$ 12 mil.</segment>
    <segment id="26">AtГѓВ©</segment>
    <segment id="27">o presidente da AssociaГѓВ§ГѓВЈo Brasileira da IndГѓВєstria de HotГѓВ©is</segment>
    <segment id="28">, Enrico FГѓВ©rmi Torquato Fontes</segment>
    <segment id="29">, sese manifestou.
- SalГѓВЎrio de R$ 20 mil para profissional sem experiГѓВЄncia</segment>
    <segment id="30">comocomo gerente de hotel ГѓВ© incomum - disse.</segment>
    <segment id="31">Veja abaixo os conselhos de um gerente</segment>
    <segment id="32">, um recepcionista</segment>
    <segment id="33">, uma camareira</segment>
    <segment id="34">, uma copeira</segment>
    <segment id="35">, uma supervisora de recepГѓВ§ГѓВЈo e de uma coordenadora de reservas para o homem condenado a dez anos e dez meses de prisГѓВЈo.</segment>
    <segment id="36">Trabalho de dia</segment>
    <segment id="37">, prisГѓВЈo ГѓВ  noite</segment>
    <segment id="38">Pelo visto</segment>
    <segment id="39">, a Papuda sГѓВі verГѓВЎ o ex-ministro ГѓВ  noite.</segment>
    <segment id="40">Na ficha de solicitaГѓВ§ГѓВЈo de emprego</segment>
    <segment id="41">, assinada por Dirceu no dia 18 de novembro</segment>
    <segment id="42">, ele afirma que ГѓВ© formado em Direito</segment>
    <segment id="43">, ГѓВ© catГѓВіlico e pratica caminhada.</segment>
    <segment id="44">Ao ser perguntado sobre o motivo de procurar o trabalho</segment>
    <segment id="45">, ele respondeu:
- Necessidade e por apreciar hotelaria e ГѓВЎrea administrativa.</segment>
    <segment id="46">O documento foi entregue ao STF juntamente com pedido de autorizaГѓВ§ГѓВЈo para trabalho externo na segunda-feira.</segment>
    <segment id="47">Na terГѓВ§a</segment>
    <segment id="48">, foi encaminhado ГѓВ  Vara de ExecuГѓВ§ГѓВЈo Penal do Distrito Federal</segment>
    <segment id="49">, que tomarГѓВЎ a decisГѓВЈo.</segment>
    <segment id="50">RelaГѓВ§ГѓВµes suspeitas
Quando a esmola</segment>
    <segment id="51">ГѓВ© demais</segment>
    <segment id="52">, o santo desconfia.</segment>
    <segment id="53">Paulo Masci de Abreu</segment>
    <segment id="54">, um dos sГѓВіcios do Hotel Saint Peter</segment>
    <segment id="55">, ГѓВ© irmГѓВЈo do presidente do PTN</segment>
    <segment id="56">, JosГѓВ© Masci de Abreu.</segment>
    <segment id="57">A legenda integra a base aliada da presidente Dilma Rousseff (PT).</segment>
    <segment id="58">Na composiГѓВ§ГѓВЈo societГѓВЎria</segment>
    <segment id="59">, Paulo aparece apenas com um capital de R$ 1 - os R$ 499.999 restantes pertencem a empresa de companhias hipotecГѓВЎrias do PanamГѓВЎ</segment>
    <segment id="60">, a Truston International.</segment>
    <segment id="61">SГѓВіcios de emissoras</segment>
    <segment id="62">Tanto Paulo quanto JosГѓВ© sГѓВЈo</segment>
    <segment id="63">sГѓВіcios de emissoras de rГѓВЎdio em SP.</segment>
    <segment id="64">O sГѓВіcio do Saint Peter tem interesses diretos no governo federal: processos relacionados</segment>
    <segment id="65">ГѓВ s rГѓВЎdios</segment>
    <segment id="66">, inclusive concessГѓВЈo de outorga</segment>
    <segment id="67">, tramitam no MinistГѓВ©rio das ComunicaГѓВ§ГѓВµes.</segment>
    <segment id="68">Fala, hoteleiro!</segment>
    <segment id="69">No ramo da hotelaria</segment>
    <segment id="70">, a pessoa precisa ser correta</segment>
    <segment id="71">, muito correta</segment>
    <segment id="72">, e nГѓВЈo fazer o que ele fez.</segment>
    <segment id="73">A gente atende hГѓВіspedes que deixam pertences em cima da cama</segment>
    <segment id="74">, espalhado no quarto.</segment>
