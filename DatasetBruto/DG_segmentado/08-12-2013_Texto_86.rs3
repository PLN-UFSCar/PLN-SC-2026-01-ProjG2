  <rst>
    <segment id="1">Mist횄짤</segment>
    <segment id="2">rio</segment>
    <segment id="3">Homem</segment>
    <segment id="4">횄</segment>
    <segment id="5">짤 encontrado sem a cabe횄짠a e os bra횄짠os em Viam횄짙o</segment>
    <segment id="6">Corpo foi encontrado no s횄징bado e estava em avan횄짠ado estado de decomposi횄짠횄짙o</segment>
    <segment id="7">, pr횄쨀ximo a um c횄쨀rrego</segment>
    <segment id="8">, no Bairro Espig횄짙o</segment>
    <segment id="9">O corpo de um homem foi encontrado sem a cabe횄짠a e os dois bra횄짠os pr횄쨀ximo a um c횄쨀rrego na Estrada do Campo Aberto</segment>
    <segment id="10">, no Bairro Espig횄짙o</segment>
    <segment id="11">, em Viam횄짙o</segment>
    <segment id="12">, no in횄짯cio da tarde de s횄징bado.</segment>
    <segment id="13">Segundo a 2횂짧 DP de Viam횄짙o</segment>
    <segment id="14">, a v횄짯tima ainda apresentava uma perfura횄짠횄짙o no t횄쨀rax.</segment>
    <segment id="15">A pol횄짯cia suspeita que o corpo seja de um senhor de 62 anos que estava desaparecido desde 25 de novembro e morava numa ch횄징cara no bairro.</segment>
    <segment id="16">O registro do desaparecimento</segment>
    <segment id="17">, por횄짤m</segment>
    <segment id="18">, s횄쨀 foi realizado pelo filho da v횄짯tima na 1횂짧 DP de Viam횄짙o</segment>
    <segment id="19">, no dia 6 de dezembro.</segment>
    <segment id="20">Foram os pr횄쨀prios familiares os respons횄징veis por encontrarem o corpo</segment>
    <segment id="21">, que estava a 500 metros da casa da v횄짯tima</segment>
    <segment id="22">, preso a um cip횄쨀 dentro do c횄쨀rrego e ao lado de uma foice.</segment>
    <segment id="23">Peritos n횄짙o encontraram vest횄짯gios de sangue no instrumento agr횄짯cola.</segment>
    <segment id="24">A pol횄짯cia n횄짙o descarta a possibilidade de que o homem tenha sofrido um mal s횄쨘bito e morrido no local.</segment>
    <segment id="25">As partes do corpo que sumiram s횄짙o justamente aquelas que ficaram para fora do c횄쨀rrego.</segment>
    <segment id="26">A identifica횄짠횄짙o pr횄짤via foi feita a partir das roupas usadas pela v횄짯tima.</segment>
    <segment id="27">Como estava em avan횄짠ado estado de decomposi횄짠횄짙o</segment>
    <segment id="28">, ela passar횄징 por exame de DNA para confirmar a identidade.</segment>
    <segment id="29">Por enquanto</segment>
    <segment id="30">, o caso</segment>
    <segment id="31">caso ficar횄징 com a 2횂짧 Delegacia de Viam횄짙o</segment>
    <segment id="32">, respons횄징vel pelos homic횄짯dios na cidade.</segment>
