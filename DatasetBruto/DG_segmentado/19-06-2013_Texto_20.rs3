  <rst>
    <segment id="1">Fila do Sus</segment>
    <segment id="2">Alvorada vai enviar cartas para recuperar pacientes que n횄짙o foram inseridos no sistema informatizado
Secretaria da Sa횄쨘de tenta</segment>
    <segment id="3">sese comunicar com a popula횄짠횄짙o que ainda necessita de atendimento</segment>
    <segment id="4">A Secretaria da Sa횄쨘de de Alvorada decidiu investir em um m횄짤</segment>
    <segment id="5">todo bastante simples para</segment>
    <segment id="6">sese comunicar com a popula횄짠횄짙o: cartas.</segment>
    <segment id="7">A tentativa de contato 횄짤 com as 27 mil pessoas que n횄짙o foram inseridas no sistema informatizado do munic횄짯pio em 2011.</segment>
    <segment id="8">O assunto foi revelado pelo Di횄징rio Ga횄쨘cho no dia 14 de junho</segment>
    <segment id="9">, contando a hist횄쨀ria do vendedor Carlos Eduardo Martins Flores</segment>
    <segment id="10">, 32 anos</segment>
    <segment id="11">, que espera h횄징 oito anos por uma cirurgia no ouvido direito.</segment>
    <segment id="12">S횄짙o 300 correspond횄짧ncias que ser횄짙o enviadas via Correios at횄짤 a sexta-feira.</segment>
    <segment id="13">Um mutir횄짙o no s횄징bado produzir횄징 mais mil cartas</segment>
    <segment id="14">, endere횄짠adas aos pacientes ainda na segunda-feira.</segment>
    <segment id="15">A chefe da pasta</segment>
    <segment id="16">, Janete Conzatti de Souza</segment>
    <segment id="17">, explica que vai esperar de dez a 12 dias</segment>
    <segment id="18">para que</segment>
    <segment id="19">para que essas pessoas procurem a Central de Marca횄짠횄짙o de Consultas.</segment>
    <segment id="20">Depois de uma avalia횄짠횄짙o no fluxo</segment>
    <segment id="21">, ser횄징 decidido a quantidade da pr횄쨀xima remessa.</segment>
    <segment id="22">A inten횄짠횄짙o</segment>
    <segment id="23">횄짤 repassar do papel para o computador apenas os pacientes que ainda precisam do atendimento especializado.</segment>
    <segment id="24">A secretaria suspeita que muitos j횄징 procuraram outras alternativas de cura</segment>
    <segment id="25">, al횄짤m dos que j횄징 melhoraram ou morreram.</segment>
    <segment id="26">Entenda o</segment>
    <segment id="27">casocaso</segment>
    <segment id="28">Em 2011</segment>
    <segment id="29">, o sistema de consultas de Alvorada foi informatizado.</segment>
    <segment id="30">As fichas de todos os pacientes da rede p횄쨘blica de sa횄쨘de deveriam ter sa횄짯do do papel para o computador.</segment>
    <segment id="31">Na 횄짤poca</segment>
    <segment id="32">, ficou decidido que pessoas que tivessem ingressado anteriormente a 2008 estariam fora da migra횄짠횄짙o.</segment>
    <segment id="33">A partir daquele ano</segment>
    <segment id="34">, as consultas realizadas passaram a ser feitas somente com base nas informa횄짠횄쨉es abastecidas no computador.
Para acelerar o processo</segment>
    <segment id="35">, a Central de Marca횄짠횄짙o de Consultas</segment>
    <segment id="36">, que tem dez funcion횄징rios</segment>
    <segment id="37">, est횄징 fazendo contato com esses pacientes via telefone e cartas.
Se voc횄짧</segment>
    <segment id="38">sese encaixa no perfil desses pacientes</segment>
    <segment id="39">, procure o setor de Marca횄짠횄짙o de Consulta na Rua Roberto Souza Feij횄쨀</segment>
    <segment id="40">, na via do Pan 8</segment>
    <segment id="41">, na Parada 48</segment>
    <segment id="42">, no setor de Marca횄짠횄짙o de Consulta</segment>
    <segment id="43">, 횄혻 tarde.</segment>
