    <segment id="8">sese manter ainda entre os tr횄짧s primeiros colocados.</segment>
    <segment id="9">No futebol</segment>
    <segment id="10">, sempre privilegio o trabalho coletivo.</segment>
    <segment id="11">O que ocorre</segment>
    <segment id="12">, salvo melhor ju횄짯zo</segment>
    <segment id="13">, 횄짤 que as responsabilidades devem ser atribu횄짯das ao conceito futebol횄짯stico que o clube adotou para enfrentar eventuais dificuldades inerentes e comuns no dia a dia de um departamento de futebol.</segment>
    <segment id="14">Com isso n횄짙o fa횄짠o cr횄짯ticas pontuais a pessoas</segment>
