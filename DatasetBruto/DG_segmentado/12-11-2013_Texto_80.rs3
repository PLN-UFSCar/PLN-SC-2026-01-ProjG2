    <segment id="23">N횄짙o se</segment>
    <segment id="24">se trata de culpar jogadores</segment>
    <segment id="25">, masmas de buscar alternativas contra a mesmice</segment>
    <segment id="26">, provocando uma forte rea횄짠횄짙o coletiva interna diante da situa횄짠횄짙o vigente.</segment>
    <segment id="27">Se todos perdem</segment>
    <segment id="28">, todos devem tamb횄짤m ganhar.</segment>
    <segment id="29">Para tanto</segment>
    <segment id="30">, esgotou-</segment>
    <segment id="31">sese a toler횄짖ncia com a falta de vit횄쨀rias.</segment>
    <segment id="32">Um clube da grandeza do Gr횄짧mio e dos seus profissionais deve reagir com for횄짠a para retomar o caminho das vit횄쨀rias.</segment>
    <segment id="33">Para isso</segment>
    <segment id="34">, 횄짤 preciso criar fatos novos</segment>
    <segment id="35">, ultrapassando esse limite insuport횄징vel de tristezas para a comunidade tricolor.</segment>
