    <segment id="17">, masmas ao contexto existente no futebol do clube.</segment>
    <segment id="18">Reage!</segment>
    <segment id="19">No entanto</segment>
    <segment id="20">, mais do que chegou a hora de algu횄짤m chutar o balde.</segment>
    <segment id="21">Preferencialmente</segment>
