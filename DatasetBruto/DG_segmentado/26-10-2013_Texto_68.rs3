    <segment id="21">Questionadas</segment>
    <segment id="22">, as meninas contaram que o homem as teria levado para uma casa e chegou a toc횄징-las</segment>
    <segment id="23">, masmas n횄짙o houve penetra횄짠횄짙o.</segment>
    <segment id="24">A BM foi chamada.</segment>
    <segment id="25">Suspeito foi detido em casa</segment>
    <segment id="26">Um notebook do suspeito</segment>
    <segment id="27">, encontrado com uma das crian횄짠as</segment>
    <segment id="28">, foi recolhido pelos PMs.</segment>
