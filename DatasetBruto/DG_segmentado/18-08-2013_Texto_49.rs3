Aline Cust횄쨀dio
aline.custodio@diariogaucho.com.br</segment>
    <segment id="9">Um reencontro aguardado h횄징 quatro d횄짤cadas ocorreu na sexta-feira passada.</segment>
    <segment id="10">O pescador Hon횄쨀rio Gomes Zilli deixou a Ilha Grande dos Marinheiros</segment>
    <segment id="11">, em Porto Alegre</segment>
    <segment id="12">, e cruzou o Estado rumo 횄혻 terra natal: S횄짙o Nicolau</segment>
    <segment id="13">, nas Miss횄쨉es</segment>
    <segment id="14">, a 600km da Capital.</segment>
    <segment id="15">Em 29 de julho</segment>
    <segment id="16">, a solid횄짙o de Hon횄쨀rio na Ilha foi apresentada no DG.</segment>
    <segment id="17">Naquele dia</segment>
    <segment id="18">, uma leitora localizou a fam횄짯lia que ele n횄짙o via havia 40 anos.</segment>
    <segment id="19">A partir da횄짯</segment>
    <segment id="20">, uma rede formou-</segment>
    <segment id="21">sese para lev횄징-lo para casa.</segment>
    <segment id="22">E com os cachorros.</segment>
    <segment id="23">A vida solit횄징ria ganhou novo rumo.</segment>
    <segment id="24">O jornal acompanhou o emocionante desfecho da hist횄쨀ria.</segment>
    <segment id="25">Bastaram os olhos</segment>
    <segment id="26">sese cruzarem</segment>
    <segment id="27">para que</segment>
    <segment id="28">para que 40 anos de saudade ficassem para tr횄징s.</segment>
    <segment id="29">O pescador aposentado Hon횄쨀rio Gomes Zilli</segment>
    <segment id="30">, 70 anos</segment>
    <segment id="31">, e o pai adotivo</segment>
    <segment id="32">, Domingos Zilli</segment>
    <segment id="33">, 89 anos</segment>
    <segment id="34">, sese reencontraram na sexta-feira passada</segment>
    <segment id="35">, depois de Hon횄쨀rio viajar por dez horas da Ilha Grande dos Marinheiros</segment>
    <segment id="36">, em Porto Alegre</segment>
    <segment id="37">, at횄짤 o distrito de Santo Isidro</segment>
    <segment id="38">, em S횄짙o Nicolau.</segment>
    <segment id="39">De cabe횄짠a baixa</segment>
    <segment id="40">, o pescador desceu do carro</segment>
    <segment id="41">, ajeitou a boina</segment>
    <segment id="42">, colocou as m횄짙os na cintura</segment>
    <segment id="43">, respirou fundo e deu oito passos em sil횄짧ncio rumo ao abra횄짠o do pai.</segment>
    <segment id="44">O primeiro di횄징logo entre pai e filho
Domingos</segment>
    <segment id="45">, com os olhos marejados</segment>
    <segment id="46">, estendeu a m횄짙o:
- Oi</segment>
    <segment id="47">, filho</segment>
    <segment id="48">, Deus te aben횄짠oe.</segment>
    <segment id="49">Como 횄짤 que tu t횄징?</segment>
    <segment id="50">Acanhado</segment>
    <segment id="51">, Hon횄쨀rio apenas balbuciou:
- T횄쨈 bem</segment>
    <segment id="52">, pai.</segment>
    <segment id="53">Emocionado</segment>
    <segment id="54">, o anfitri횄짙o deu um abra횄짠o apertado diante de toda a fam횄짯lia. 
- Saiu do inferno</segment>
    <segment id="55">, meu filho.
- Gra횄짠as a Deus.</segment>
    <segment id="56">Aquilo l횄징 era um inferno mesmo - disse Hon횄쨀rio</segment>
    <segment id="57">, antes de</segment>
    <segment id="58">sese aconchegar no peito de Domingos.</segment>
    <segment id="59">Galinhada esperava os viajantes
Foram a ca횄짠ula de Domingos</segment>
    <segment id="60">, Cleonice Zilli</segment>
