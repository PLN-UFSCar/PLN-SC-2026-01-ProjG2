Ado횄짠횄짙o ocorreu na inf횄짖ncia</segment>
    <segment id="83">Ainda na mesa</segment>
    <segment id="84">, Domingos recordou a 횄짤poca em que Hon횄쨀rio foi adotado pela fam횄짯lia.</segment>
    <segment id="85">Ca횄짠ula e 횄쨀rf횄짙o de m횄짙e</segment>
    <segment id="86">, o pescador vivia em condi횄짠횄쨉es prec횄징rias com o pai e outros cinco irm횄짙os no distrito de Rinc횄짙o dos Potreiros.</segment>
    <segment id="87">Domingos contou que a decis횄짙o de adot횄징-lo foi para salvar a vida de Hon횄쨀rio.
- Ele tinha uns cinco anos</segment>
    <segment id="88">, e vivia pelado.</segment>
    <segment id="89">N횄짙o tinham roupas.</segment>
    <segment id="90">Dava para contar os ossinhos do corpo</segment>
    <segment id="91">, de t횄짙o magrinho que era.</segment>
    <segment id="92">Tinha uma cabelama cheia de piolhos.</segment>
    <segment id="93">Um irm횄짙o dele j횄징 tinha morrido de fome.</segment>
    <segment id="94">E ele ia morrer tamb횄짤m - recordou o pai</segment>
    <segment id="95">, com l횄징grimas nos olhos.</segment>
    <segment id="96">Em casa
No s횄징bado</segment>
    <segment id="97">, Hon횄쨀rio conheceu a casa onde passar횄징 a viver.</segment>
    <segment id="98">Enquanto circulava pela moradia de quatro pe횄짠as de madeira e banheiro de alvenaria</segment>
    <segment id="99">, com dois a횄짠udes e pomares</segment>
    <segment id="100">, foi surpreendido pelos latidos dos "amigos</segment>
    <segment id="101">"</segment>
    <segment id="102">no port횄짙o</segment>
    <segment id="103">.</segment>
    <segment id="104">Eram os c횄짙es Chupim e Barbudo</segment>
    <segment id="105">, levados pelo mec횄짖nico Valter Ribeiro e a mulher dele</segment>
    <segment id="106">, Sandra</segment>
    <segment id="107">, pais do veterin횄징rio Rodrigo Ribeiro</segment>
    <segment id="108">, de Alvorada.</segment>
    <segment id="109">Com os laudos de viagem expedidos pela veterin횄징ria Michele Panazzolo</segment>
    <segment id="110">, de Canoas</segment>
    <segment id="111">, os dois companheiros de Hon횄쨀rio puderam seguir rumo a S횄짙o Nicolau.</segment>
    <segment id="112">Macaco</segment>
    <segment id="113">, o outro guaipeca</segment>
    <segment id="114">, fugiu para o interior da Ilha pouco antes da viagem.</segment>
    <segment id="115">Quando deixaram as gaiolas</segment>
    <segment id="116">, os c횄짙es correram para o abra횄짠o de Hon횄쨀rio.</segment>
    <segment id="117">Familiares</segment>
    <segment id="118">sese emocionaram.</segment>
    <segment id="119">Em segundos</segment>
    <segment id="120">, o rosto sisudo do pescador deu lugar a um largo sorriso.</segment>
    <segment id="121">N횄짙o estava mais solit횄징rio.</segment>
    <segment id="122">E fez previs횄쨉es:
- Espero alguma coisa mais pra frente</segment>
    <segment id="123">, antes do fim da vida.</segment>
    <segment id="124">Criar bichinhos</segment>
    <segment id="125">, comprar umas galinhas</segment>
    <segment id="126">, uns porquinhos.</segment>
    <segment id="127">Pretendo ficar por aqui.</segment>
    <segment id="128">E quanto 횄혻 idade de Hon횄쨀rio</segment>
    <segment id="129">, cujos novos documentos - feitos por um ex-patr횄짙o de uma das fazendas onde trabalhou - constatam que ele teria 88 anos?</segment>
    <segment id="130">Domingos afirma que o filho</segment>
    <segment id="131">, na verdade</segment>
    <segment id="132">, tem 70 anos (nasceu em 1943).</segment>
    <segment id="133">Ali횄징s</segment>
    <segment id="134">, completar횄징 71 anos na pr횄쨀xima quinta-feira. 
- Esperei tanto por este momento.</segment>
    <segment id="135">H횄징 quase 20 anos</segment>
    <segment id="136">, descobri que ele estava em Porto Alegre e mandei dois dos meus filhos buscarem ele.</segment>
    <segment id="137">Mas n횄짙o quis vir sem os documentos.</segment>
