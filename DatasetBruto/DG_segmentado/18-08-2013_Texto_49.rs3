    <segment id="158">Rio Uruguai</segment>
    <segment id="159">Apesar do rosto sisudo</segment>
    <segment id="160">, Hon횄쨀rio conversou com a irm횄짙 durante quase toda a viagem.</segment>
    <segment id="161">Entre uma sorvida e outra de chimarr횄짙o</segment>
    <segment id="162">, deixou escapar que queria muito rever o Rio Uruguai</segment>
    <segment id="163">, masmas n횄짙o pretendia nadar.
- Papai tentou v횄징rias vezes me ensinar a nadar.</segment>
    <segment id="164">Mas eu fugia feito gato.</segment>
    <segment id="165">Apesar de ser pescador</segment>
    <segment id="166">, nunca aprendi - contou.</segment>
    <segment id="167">Energia el횄짤trica</segment>
    <segment id="168">J횄징 era noite quando o pescador avistou a primeira placa indicando S횄짙o Nicolau</segment>
    <segment id="169">, a cidade fronteiri횄짠a de 5.727 habitantes.</segment>
    <segment id="170">Ficou impressionado com a chegada da energia el횄짤trica 횄혻 regi횄짙o.</segment>
    <segment id="171">Na parte da Ilha onde morou pelos 횄쨘ltimos 40 anos</segment>
    <segment id="172">, at횄짤 hoje n횄짙o h횄징 luz e 횄징gua encanada.</segment>
