    <segment id="1">PaixГѓВЈo</segment>
    <segment id="2">Tricolor</segment>
    <segment id="3">A mesma dificuldade
Cacalo Silveira Martins
cacalo@diariogaucho.com.br</segment>
    <segment id="4">No jogo de ontem</segment>
    <segment id="5">, contra o Bahia</segment>
    <segment id="6">, houve a repetiГѓВ§ГѓВЈo daquele problema que vinha acontecendo nas partidas do GrГѓВЄmio.</segment>
    <segment id="7">O time demonstra imensa dificuldade em marcar um golzinho salvador</segment>
    <segment id="8">, que defina a partida.</segment>
    <segment id="9">AliГѓВЎs</segment>
    <segment id="10">, tem se</segment>
    <segment id="11">se dito reiteradas vezes que o time joga por uma bola.</segment>
    <segment id="12">Quando ela vem</segment>
    <segment id="13">, vence por 1 a 0.</segment>
    <segment id="14">Quando essa bola nГѓВЈo aparece</segment>
    <segment id="15">, repete-</segment>
    <segment id="16">sese a dificuldade</segment>
    <segment id="17">, como</segment>
    <segment id="18">como se</segment>
    <segment id="19">se viu ontem na Arena.</segment>
    <segment id="20">ГѓвЂ° verdade que o time teve algumas poucas chances de marcar.</segment>
    <segment id="21">Foi quando sobressaiu o goleiro do Bahia</segment>
    <segment id="22">, Marcelo Lomba.</segment>
    <segment id="23">Mas</segment>
    <segment id="24">ГѓВ© pouco para o Tricolor</segment>
    <segment id="25">, que precisa somar pontos e chegar ГѓВ  Libertadores.</segment>
    <segment id="26">Inegavelmente</segment>
    <segment id="27">, a equipe melhorou sua qualidade tГѓВ©cnica com a entrada de Elano e ZГѓВ© Roberto.</segment>
    <segment id="28">Mas tambГѓВ©m foram insuficientes para decidir o jogo</segment>
    <segment id="29">, pelo pouco tempo em que atuaram.</segment>
    <segment id="30">Copa do Brasil</segment>
    <segment id="31">A equipe vive espГѓВ©cie de crise tГѓВ©cnica</segment>
    <segment id="32">porque</segment>
    <segment id="33">porque sobra esforГѓВ§o</segment>
    <segment id="34">masmas nГѓВЈo consegue conclusГѓВµes de forma clara ao gol adversГѓВЎrio</segment>
    <segment id="35">, nem sequer cria situaГѓВ§ГѓВµes vivas de marcar os gols necessГѓВЎrios.</segment>
    <segment id="36">HГѓВЎ que</segment>
    <segment id="37">sese ressaltar</segment>
    <segment id="38">, por justiГѓВ§a</segment>
    <segment id="39">, a vontade de todos os jogadores em vencer e a forma fechada e defensiva</segment>
    <segment id="40">comocomo jogou o adversГѓВЎrio</segment>
    <segment id="41">, o Bahia.</segment>
    <segment id="42">Isso, de certa forma</segment>
    <segment id="43">, atenua eventuais problemas do GrГѓВЄmio.</segment>
    <segment id="44">Paralelamente</segment>
    <segment id="45">, o GoiГѓВЎs sobe na tabela</segment>
    <segment id="46">, e o Botafogo foi ultrapassado pelo GrГѓВЄmio.</segment>
    <segment id="47">Mas ГѓВ© preciso muita atenГѓВ§ГѓВЈo</segment>
    <segment id="48">, esforГѓВ§o e dedicaГѓВ§ГѓВЈo para manter o time na zona de Libertadores.</segment>
    <segment id="49">Agora, foco total na Copa do Brasil</segment>
    <segment id="50">, pois</segment>
    <segment id="51">pois a chance de buscar a classificaГѓВ§ГѓВЈo</segment>
    <segment id="52">ГѓВ  final</segment>
    <segment id="53">ГѓВ© bem razoГѓВЎvel.</segment>
