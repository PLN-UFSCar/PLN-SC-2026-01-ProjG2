  <rst>
    <segment id="1">Planeta Moto</segment>
    <segment id="2">Cuidados ao viajar de moto na chuva</segment>
    <segment id="3">Saiba os cuidados que o condutor precisa ter para aumentar a seguran횄짠a e o prazer na hora de andar em duas rodas</segment>
    <segment id="4">Extremamente gelado e 횄쨘mido.</segment>
    <segment id="5">Assim deve ser o 횄쨘ltimo m횄짧s do inverno no Estado - e em boa parte do Sul e Sudeste do Brasil.</segment>
    <segment id="6">Nada disso impede uma viagem de moto</segment>
    <segment id="7">, masmas 횄짤 preciso alguns cuidados.</segment>
    <segment id="8">Sob o chamado p횄짤-d'횄징gua</segment>
    <segment id="9">, o b횄징sico</segment>
    <segment id="10">횄짤 diminuir a velocidade em 20% e aumentar a dist횄짖ncia do ve횄짯culo da frente em 30%.</segment>
    <segment id="11">Nessas horas</segment>
    <segment id="12">, a falta de manuten횄짠횄짙o na moto pode causar uma grande dor de cabe횄짠a - quem anda com pneus carecas</segment>
    <segment id="13">, mais do que nunca est횄징 sujeito a um tombo.</segment>
    <segment id="14">O Planeta Moto mostra cuidados que o condutor precisa ter para aumentar a seguran횄짠a e o prazer na hora de andar em duas rodas:
Fique de olho
- No ba횄쨘 ou nos alforjes</segment>
    <segment id="15">, coloque pe횄짠as de roupas em v횄징rios sacos pl횄징sticos e</segment>
    <segment id="16">, depois</segment>
    <segment id="17">, tudo em um saco maior.</segment>
    <segment id="18">Assim, tudo ficar횄징 protegido da umidade em uma viagem.
- Roupas de cordura ou couro s횄짙o 횄쨀timas contra o frio</segment>
    <segment id="19">, masmas n횄짙o aguentam chuvas fortes e longas.</segment>
    <segment id="20">Nada melhor do que a capa de borracha</segment>
    <segment id="21">, que custa menos de R$ 100.
- Se sua bota n횄짙o for imperme횄징vel</segment>
    <segment id="22">, uma op횄짠횄짙o barata s횄짙o as prote횄짠횄쨉es de borracha para</segment>
    <segment id="23">sese colocar em volta.</segment>
    <segment id="24">Evite sacos pl횄징sticos (</segment>
    <segment id="25">comocomo os de mercado)</segment>
    <segment id="26">, pois</segment>
    <segment id="27">pois derrapam muito.
- O mesmo pode ser usado na luva: por cima da de couro</segment>
    <segment id="28">, uma de borracha.</segment>
    <segment id="29">Na condu횄짠횄짙o
- Freie com sutileza.</segment>
    <segment id="30">Apoie as pontas dos p횄짤</segment>
    <segment id="31">s nas pedaleiras para rebaixar o centro de gravidade e aumentar a estabilidade.</segment>
    <segment id="32">-</segment>
    <segment id="33">Na curva</segment>
    <segment id="34">, incline menos a moto e mais o corpo.
- Evite as faixas brancas e amarelas pintadas no asfalto e tampas met횄징licas.</segment>
    <segment id="35">S횄짙o escorregadias.
- Para n횄짙o acumular 횄징gua na parte de fora da viseira</segment>
    <segment id="36">, basta limp횄징-la com lustram횄쨀veis.</segment>
    <segment id="37">Na parte interna</segment>
    <segment id="38">, use antiemba횄짠antes vendidos em motope횄짠as.</segment>
    <segment id="39">Encontro ocorre em Cruz Alta</segment>
    <segment id="40">O motoclube Tribo do Vento realiza neste final de semana a sexta edi횄짠횄짙o do Hot Cruz Alta Motofest</segment>
    <segment id="41">, na cidade a 347km da Capital.</segment>
    <segment id="42">Bandas de rock</segment>
    <segment id="43">, desfile de modas e shows de pilotagem fazem parte da programa횄짠횄짙o do encontro</segment>
    <segment id="44">, que vai de sexta a domingo.</segment>
    <segment id="45">Informa횄짠횄쨉es: site motogrupotribodovento.blogspot.com</segment>
    <segment id="46">, e-mail mg-tribodovento@hotmail.com e pelo telefone (55)</segment>
    <segment id="47">9963-4666                                                      Passeio da Yamaha no s횄징bado</segment>
    <segment id="48">A Motoryama realiza neste s횄징bado um passeio destinado a donos de modelos</segment>
    <segment id="49">Yamaha acima de 250cc.</segment>
    <segment id="50">A partir das 8h</segment>
    <segment id="51">, haver횄징 caf횄짤 da manh횄짙 aos participantes</segment>
    <segment id="52">, e a largada ser횄징</segment>
    <segment id="53">횄혻s 9h</segment>
    <segment id="54">, na loja da concession횄징ria em Canoas (Avenida Get횄쨘lio Vargas</segment>
    <segment id="55">, 6676).</segment>
    <segment id="56">O evento consiste em uma viagem at횄짤 a regi횄짙o de Taquara</segment>
    <segment id="57">, com a maior parte do percurso no asfalto e cerca de 25km em estradas de ch횄짙o.</segment>
    <segment id="58">Segundo os organizadores</segment>
    <segment id="59">, o retorno deve come횄짠ar por volta das 14h.</segment>
    <segment id="60">As inscri횄짠횄쨉es s횄짙o gratuitas.</segment>
    <segment id="61">Informa횄짠횄쨉es na concession횄징ria</segment>
    <segment id="62">, pelo telefone 3406-4000 e no site www.motoryama.com.br.
  Motocross: Para횄짯 tem etapa do Centro-Serra 
Para횄짯</segment>
    <segment id="63">, a 204km da Capital</segment>
    <segment id="64">, no Norte do Estado</segment>
    <segment id="65">, recebe neste final de semana a s횄짤tima etapa do Campeonato Centro/Serra Ipiranga de Motocross.</segment>
    <segment id="66">Ser횄짙o mais de 200 pilotos em 13 categorias na pista do Parque Municipal de Eventos</segment>
    <segment id="67">, no Centro.</segment>
    <segment id="68">Os treinos acontecem no s횄징bado</segment>
    <segment id="69">횄혻 tarde</segment>
    <segment id="70">, com ingresso gratuito.</segment>
    <segment id="71">As baterias valendo pontos come횄짠am no domingo</segment>
    <segment id="72">, a partir das 13h.</segment>
    <segment id="73">Ingressos antecipados a R$ 5 - no dia</segment>
    <segment id="74">, custar횄짙o R$ 10.
Informa횄짠횄쨉es: 9995-4342 e 9358-1356 e sites</segment>
    <segment id="75">www.fielpromo coes.com.br e www.fgmcom.br.</segment>
    <segment id="76">Fen횄쨈meno na telinha</segment>
    <segment id="77">As mudan횄짠as feitas pela Honda na CG</segment>
    <segment id="78">, maior fen횄쨈meno do mercado de duas rodas do Brasil</segment>
    <segment id="79">, 횄짤 o destaque deste domingo no Carros &amp; Motos</segment>
    <segment id="80">, que mostra a nova roupagem e as mudan횄짠as feitas no modelo que vende perto de 1 milh횄짙o de unidades por ano.</segment>
    <segment id="81">O programa vai ao ar todos os domingos</segment>
    <segment id="82">, na TVCOM</segment>
    <segment id="83">, a partir das 20h30min - as reprises s횄짙o exibidas 횄혻s ter횄짠as e quintas</segment>
    <segment id="84">, a partir das 14h.</segment>
    <segment id="85">A MOTOCICLETA MAIS CARA DO MUNDO 
Milion횄징rio</segment>
    <segment id="86">, f횄짙 de duas rodas e propriet횄징rio da empresa de customiza횄짠횄짙o TT Custom Chopper</segment>
    <segment id="87">, o turco Tarhan Telli construiu uma moto que tem tudo para ser eleita a mais cara do mundo em todos os tempos.</segment>
    <segment id="88">O quadro</segment>
    <segment id="89">, feito em ouro</segment>
    <segment id="90">, tem valor estimado em US$ 1 milh횄짙o (R$ 2</segment>
    <segment id="91">,27 milh횄쨉es).</segment>
    <segment id="92">Segundo a ag횄짧ncia de not횄짯cias Infomoto</segment>
    <segment id="93">, o ve횄짯culo tem motor V2 de 1.800cc (125 cavalos) e c횄짖mbio de seis marchas.</segment>
    <segment id="94">Algumas pe횄짠as foram inspiradas na mitologia grega</segment>
    <segment id="95">, como</segment>
    <segment id="96">como a cabe횄짠a de medusa incrustada no tanque.</segment>
    <segment id="97">Um ano para ser constru횄짯da</segment>
    <segment id="98">O dono n횄짙o revela o pre횄짠o</segment>
    <segment id="99">, masmas conta que gastou um ano na constru횄짠횄짙o.</segment>
    <segment id="100">A apar횄짧ncia envelhecida</segment>
    <segment id="101">, segundo ele</segment>
    <segment id="102">, 횄짤 para evitar o excesso de brilho.</segment>
    <segment id="103">Atualmente</segment>
    <segment id="104">, segundo o Guinness Book (Livro dos Recordes</segment>
    <segment id="105">, feito na Inglaterra)</segment>
    <segment id="106">, a moto mais cara do mundo foi feita pela empresa TT Marine Superbike</segment>
    <segment id="107">, que usou uma turbina de helic횄쨀ptero.</segment>
    <segment id="108">Foi avaliada em US$ 185 mil (R$ 420 mil).</segment>
