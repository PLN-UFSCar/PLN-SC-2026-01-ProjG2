    <segment id="1">Paix횄짙o colorada</segment>
    <segment id="2">Egos inflados no vesti횄징rio colorado
Kenny Braga
kenny.braga@diariogaucho.com.br
Nem sempre dirigentes</segment>
    <segment id="3">, t횄짤cnicos e jogadores dizem</segment>
    <segment id="4">, em suas entrevistas</segment>
    <segment id="5">, tudo o que pensam.</segment>
    <segment id="6">Principalmente quando crises rondam os ambientes dos vesti횄징rios.</segment>
    <segment id="7">Mas algumas entrevistas</segment>
    <segment id="8">, quando ouvidas com aten횄짠횄짙o</segment>
    <segment id="9">, esclarecem e iluminam situa횄짠횄쨉es at횄짤 ent횄짙o incompreens횄짯veis para os torcedores que est횄짙o acompanhando.</segment>
    <segment id="10">Foi o caso</segment>
    <segment id="11">caso da 횄쨘ltima entrevista do Clemer na condi횄짠횄짙o de t횄짤cnico do Inter</segment>
    <segment id="12">, depois do jogo com a Ponte Preta</segment>
    <segment id="13">, domingo</segment>
    <segment id="14">, em Caxias do Sul.</segment>
    <segment id="15">A parte mais importante da entrevista foi quando o t횄짤cnico abordou o problema das vaidades</segment>
    <segment id="16">, que conspiram contra a necess횄징ria harmonia nos ambientes do vesti횄징rios.</segment>
    <segment id="17">Sem divis횄쨉es
Ele deixou claro</segment>
    <segment id="18">, para quem quis entender</segment>
    <segment id="19">, que as vaidades de alguns jogadores do Inter</segment>
    <segment id="20">, colocadas em atrito</segment>
    <segment id="21">, prejudicaram seu trabalho.</segment>
    <segment id="22">Clemer n횄짙o citou nomes</segment>
    <segment id="23">, nem poderia</segment>
    <segment id="24">, porque</segment>
    <segment id="25">porque os jogadores envolvidos nas brigas de ego conviviam com ele no cotidiano do clube.</segment>
    <segment id="26">Mas Clemer</segment>
    <segment id="27">, mesmo sem querer</segment>
    <segment id="28">, deixou contribui횄짠횄짙o para os novos respons횄징veis pelo futebol do Inter em 2014.</segment>
    <segment id="29">Antes de qualquer preocupa횄짠횄짙o com a forma횄짠횄짙o do novo time</segment>
    <segment id="30">, com a defini횄짠횄짙o do seu perfil</segment>
    <segment id="31">, eles devem erradicar qualquer resqu횄짯cio de divis횄쨉es no grupo de profissionais em raz횄짙o de egos inflados.</segment>
    <segment id="32">O novo comando do vesti횄징rio deve pregar mais futebol e menos vaidades</segment>
    <segment id="33">, mais disciplina</segment>
    <segment id="34">, mais respeito a hierarquia imposta a todos</segment>
    <segment id="35">, sem exce횄짠횄쨉es.</segment>
    <segment id="36">Se essas diretrizes n횄짙o forem seguidas</segment>
