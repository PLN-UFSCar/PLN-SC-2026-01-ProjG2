  <rst>
    <segment id="1">Latroc횄짯nio
Pol횄짯cia tem dois suspeitos para morte de homem esfaqueado em Port횄짙o
Vanderlei Ant횄쨈nio Trich dos Santos</segment>
    <segment id="2">, 36 anos</segment>
    <segment id="3">, foi morto com tr횄짧s facadas na madrugada de ter횄짠a-feira</segment>
    <segment id="4">A pol횄짯cia j횄징</segment>
    <segment id="5">tem dois suspeitos de terem assassinado Vanderlei Ant횄쨈nio Trich dos Santos</segment>
    <segment id="6">, 36 anos</segment>
    <segment id="7">, com tr횄짧s facadas na barriga</segment>
    <segment id="8">, na madrugada de ter횄짠a.</segment>
    <segment id="9">Os investigadores da DP de Port횄짙o chegaram a fazer buscas pelos dois homens</segment>
    <segment id="10">, de 21 e 30 anos</segment>
    <segment id="11">, sem sucesso.</segment>
    <segment id="12">Na casa de um deles</segment>
    <segment id="13">, os agentes encontraram roupas sujas</segment>
    <segment id="14">, aparentemente de sangue humano</segment>
    <segment id="15">, dentro da m횄징quina de lavar.</segment>
    <segment id="16">Os dois seriam usu횄징rios de crack e moradores da Vila Saibreira.</segment>
    <segment id="17">A convic횄짠횄짙o dos policiais</segment>
    <segment id="18">횄짤 de que</segment>
    <segment id="19">sese trata de um latroc횄짯nio (roubo com morte).</segment>
    <segment id="20">Vanderlei foi arrancado com a mulher de dentro de casa</segment>
    <segment id="21">, no Bairro Rinc횄짙o do Cascalho.</segment>
    <segment id="22">Os dois foram feitos ref횄짤ns no carro deles</segment>
    <segment id="23">, dirigido pelos bandidos.</segment>
    <segment id="24">O corpo do trabalhador aut횄쨈nomo foi encontrado na Estrada Bom Jardim</segment>
    <segment id="25">, Bairro Macaco Branco.</segment>
    <segment id="26">Neste local</segment>
    <segment id="27">, ele teria sido colocado fora do carro</segment>
    <segment id="28">, espancado e esfaqueado.</segment>
    <segment id="29">Conforme a investiga횄짠횄짙o</segment>
    <segment id="30">, a dupla estava armada com facas e roubou R$ 500 da casa.</segment>
    <segment id="31">Durante todo o percurso em que levaram o casal</segment>
    <segment id="32">, a mulher teria sido mantida no porta-malas.</segment>
    <segment id="33">Ela s횄쨀 foi libertada na cidade de S횄짙o Vendelino.</segment>
    <segment id="34">Oito horas depois</segment>
    <segment id="35">, o carro foi achado no Vale do Ca횄짯.</segment>
    <segment id="36">As buscas pelos suspeitos</segment>
    <segment id="37">, com o apoio da Brigada Militar</segment>
    <segment id="38">, prosseguem na 횄징rea rural de Port횄짙o.</segment>
