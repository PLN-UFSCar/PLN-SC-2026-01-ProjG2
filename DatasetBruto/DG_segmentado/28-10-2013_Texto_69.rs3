    <segment id="5">Eduardo Torres
eduardo.torres@diariogaucho.com.br</segment>
    <segment id="6">Pela sexta vez em sete anos</segment>
    <segment id="7">, Michele Oliveira de Moraes</segment>
    <segment id="8">, 29 anos</segment>
    <segment id="9">, est횄징 desaparecida.</segment>
    <segment id="10">Namorada do assaltante de carros-fortes Jos횄짤</segment>
    <segment id="11">Carlos dos Santos</segment>
    <segment id="12">, o Seco (preso desde 2006)</segment>
