    <segment id="16">, em Canoas</segment>
    <segment id="17">, por homens encapuzados e armados</segment>
    <segment id="18">, em um carro escuro</segment>
    <segment id="19">, no dia 16 de outubro.</segment>
    <segment id="20">Com ela</segment>
    <segment id="21">, foi sequestrado Maicon Bialva dos Santos</segment>
    <segment id="22">, 24 anos</segment>
    <segment id="23">, tamb횄짤m morador do bairro.</segment>
    <segment id="24">Os sumi횄짠os foram registrados na Pol횄짯cia Civil</segment>
    <segment id="25">, masmas a investiga횄짠횄짙o sequer foi iniciada.</segment>
    <segment id="26">Nos outros cinco ataques do qual foi v횄짯tima</segment>
    <segment id="27">, criminosos teriam levado Michele para tentar arrancar dela informa횄짠횄쨉es sobre o local onde estariam supostos milh횄쨉es roubados e guardados por Seco.</segment>
    <segment id="28">Rela횄짠횄짙o entre eles</segment>
    <segment id="29">횄짤 desconhecida
Mas</segment>
    <segment id="30">, agora</segment>
    <segment id="31">, a fam횄짯lia suspeita de que ela tenha</segment>
    <segment id="32">sese envolvido em uma perigosa negocia횄짠횄짙o com traficantes.</segment>
    <segment id="33">E, provavelmente</segment>
    <segment id="34">, executada</segment>
    <segment id="35">, assim</segment>
    <segment id="36">comocomo o rapaz levado com ela</segment>
    <segment id="37">, cujo tipo de envolvimento a pol횄짯cia desconhece.</segment>
    <segment id="38">Informa횄짠횄쨉es n횄짙o confirmadas pela pol횄짯cia d횄짙o conta de que a namorada do famoso assaltante teria tramado um golpe para ganhar mais de R$ 200 mil de traficantes da Regi횄짙o Metropolitana.</segment>
    <segment id="39">Prima dela j횄징</segment>
    <segment id="40">sofreu amea횄짠as</segment>
    <segment id="41">A suspeita dos parentes</segment>
    <segment id="42">횄짤 de que Maicon tenha sido envolvido no esquema.</segment>
    <segment id="43">Ele receberia mais de R$ 2 mil para</segment>
    <segment id="44">sese passar por um falso traficante do Interior.</segment>
    <segment id="45">H횄징 cerca de dois meses</segment>
    <segment id="46">, uma prima de Michele j횄징 teria sido obrigada a deixar a cidade.</segment>
    <segment id="47">As paredes da sua casa foram alvejadas por tiros.</segment>
    <segment id="48">Os criminosos cobravam uma d횄짯vida feita</segment>
    <segment id="49">, supostamente</segment>
    <segment id="50">, por Michele usando o nome da prima.</segment>
    <segment id="51">Ainda a investiga/subt횄짯tulo&gt;</segment>
    <segment id="52">No dia seguinte ao desaparecimento</segment>
    <segment id="53">, a fam횄짯lia de Michele registrou o</segment>
    <segment id="54">casocaso na Delegacia de Homic횄짯dios de Canoas.</segment>
    <segment id="55">Na ocorr횄짧ncia</segment>
    <segment id="56">, n횄짙o</segment>
    <segment id="57">횄짤 citado rapto nem a presen횄짠a de Maicon.</segment>
    <segment id="58">Somente na quinta</segment>
    <segment id="59">, oito dias ap횄쨀s o sumi횄짠o</segment>
    <segment id="60">, a fam횄짯lia do rapaz foi 횄혻 1횂짧 DP de Canoas.</segment>
    <segment id="61">A m횄짙e de Maicon relata que ele deveria ter ido jogar futebol na noite de 16 de outubro em Sapucaia do Sul</segment>
    <segment id="62">, masmas n횄짙o apareceu.</segment>
    <segment id="63">Foi para a casa de Michele e sumiu.</segment>
    <segment id="64">De acordo com o delegado Rafael Soares Pereira</segment>
    <segment id="65">, o caso</segment>
    <segment id="66">caso n횄짙o caracteriza um sequestro.</segment>
    <segment id="67">N횄짙o foram solicitados valores aos familiares</segment>
    <segment id="68">, por exemplo.</segment>
    <segment id="69">No entendimento do titular da 1횂짧 DP de Canoas</segment>
    <segment id="70">, h횄징 sinais de que houve duplo assassinato.</segment>
    <segment id="71">Por isso</segment>
    <segment id="72">, a ocorr횄짧ncia ser횄징 encaminhada 횄혻 Delegacia de Homic횄짯dios.</segment>
    <segment id="73">Quem 횄짤</segment>
    <segment id="74">Seco</segment>
    <segment id="75">Jos횄짤</segment>
    <segment id="76">Carlos dos Santos</segment>
    <segment id="77">, o Seco</segment>
    <segment id="78">, preso desde 2006</segment>
    <segment id="79">, foi considerado o foragido n횄쨘mero 1 e era suspeito dos principais roubos a carros-fortes desde 2002.</segment>
    <segment id="80">Pelos crimes que j횄징 foi condenado</segment>
    <segment id="81">, a pena soma mais de 200 anos de pris횄짙o.</segment>
