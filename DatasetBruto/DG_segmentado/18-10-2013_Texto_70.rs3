    <segment id="3">, quarta-feira</segment>
    <segment id="4">, na Arena.</segment>
    <segment id="5">Mas preciso renovar algumas manifesta횄짠횄쨉es ainda sobre o jogo.</segment>
    <segment id="6">Especialmente a atua횄짠횄짙o de Dida</segment>
    <segment id="7">, que foi muito boa</segment>
