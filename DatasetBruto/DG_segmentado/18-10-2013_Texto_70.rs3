    <segment id="18">At횄짤</segment>
    <segment id="19">porque</segment>
    <segment id="20">porque</segment>
    <segment id="21">, por conhecermos os dois times</segment>
    <segment id="22">, gostaria que prevalecesse novamente o fator local e a capacidade dos jogadores gremistas.</segment>
    <segment id="23">Desafio na Serra</segment>
    <segment id="24">Com certeza</segment>
    <segment id="25">, por desencontros acontecidos entre as dire횄짠횄쨉es dos dois clubes</segment>
    <segment id="26">, o Gr횄짧mio ter횄징 poucos torcedores no Centen횄징rio</segment>
    <segment id="27">, em Caxias do Sul</segment>
    <segment id="28">, para o cl횄징ssico Gre-Nal de domingo.</segment>
    <segment id="29">Gostaria que houvesse uma amistosa concilia횄짠횄짙o entre os dirigentes e que n횄짙o sobrevivesse esse clima de animosidade dos 횄쨘ltimos dias.</segment>
    <segment id="30">A partida ser횄징 decidida dentro do campo</segment>
    <segment id="31">, pois</segment>
