    <segment id="19">, como</segment>
    <segment id="20">como pode acontecer com uso de papel-toalha ou a barra de sua camiseta.
2 - Antes de limpar</segment>
    <segment id="21">, desligue o aparelho para melhor identificar os pontos com sujeira.</segment>
    <segment id="22">Com o pano em m횄짙os</segment>
    <segment id="23">, fa횄짠a leves movimentos circulares.</segment>
    <segment id="24">Eles facilitam a remo횄짠횄짙o de poeira e gordura da tela.
3 - De vez e quando</segment>
    <segment id="25">, at횄짤 o vapor da respira횄짠횄짙o pode ser o suficiente para limpar a tela usando uma flanela limpa. 
4 - Evite produtos de limpeza</segment>
    <segment id="26">, pois</segment>
    <segment id="27">pois eles podem danificar o aparelho.</segment>
    <segment id="28">Dispositivos</segment>
    <segment id="29">comocomo iPad ou o iPhone contam com uma subst횄짖ncia de prote횄짠횄짙o na tela conhecida</segment>
    <segment id="30">comocomo revestimento oleof횄쨀bico.</segment>
    <segment id="31">Ele repele o 횄쨀leo deixado pelos seus dedos no aparelho.
5 - Se a tela estiver 횄쨘mida</segment>
    <segment id="32">, deixe-a secar.</segment>
    <segment id="33">Depois</segment>
    <segment id="34">, passe o pano novamente.</segment>
