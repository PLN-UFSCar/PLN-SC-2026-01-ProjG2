  <rst>
    <segment id="1">Embaixo d'횄징gua</segment>
    <segment id="2">Setembro ter횄징 chuva acima da m횄짤dia no Estado</segment>
    <segment id="3">O m횄짧s que</segment>
    <segment id="4">sese inicia no domingo ser횄징 ainda pior</segment>
    <segment id="5">, segundo previs횄쨉es meteorol횄쨀gicas
Enchente hist횄쨀rica no Vale do Sinos faz com que moradores do Bairro Feitoria tenham de usar barco
Aline Cust횄쨀dio</segment>
    <segment id="6">; Denise Waskow
aline.custodio@diariogaucho.com.br</segment>
    <segment id="7">; denise.waskow@diariogaucho.com.br
Moradores das cidades do Vale do Sinos devem</segment>
    <segment id="8">sese preparar para setembro.</segment>
    <segment id="9">Se as previs횄쨉es climatol횄쨀gicas</segment>
    <segment id="10">sese confirmarem</segment>
    <segment id="11">, a regi횄짙o poder횄징 ter 26% a mais de chuva do que a m횄짤dia do m횄짧s</segment>
    <segment id="12">, de 140mm.</segment>
    <segment id="13">E depois de quatro dias de sol e temperaturas em eleva횄짠횄짙o</segment>
    <segment id="14">, as chuvas j횄징 retornam ao Estado neste domingo</segment>
    <segment id="15">, acompanhadas de vento e at횄짤 granizo</segment>
    <segment id="16">, segundo a meteorologista Tatiane Martins</segment>
    <segment id="17">, da Somar Meteorologia</segment>
    <segment id="18">, com sede em S횄짙o Paulo.
- A primeira quinzena de setembro ter횄징 chuva em grande quantidade</segment>
    <segment id="19">, masmas em dias mais espa횄짠ados.</segment>
    <segment id="20">A segunda</segment>
    <segment id="21">, por횄짤m</segment>
    <segment id="22">, ser횄징 ainda mais chuvosa</segment>
    <segment id="23">, mais fechada</segment>
    <segment id="24">, com at횄짤 quatro dias seguidos sem sol - prev횄짧.</segment>
    <segment id="25">A explica횄짠횄짙o para a precipita횄짠횄짙o acima do normal estaria no avan횄짠o lento das frentes frias sobre o Estado</segment>
    <segment id="26">, que acabam</segment>
    <segment id="27">sese chocando com as massas de ar quente vindas da Amaz횄쨈nia.</segment>
    <segment id="28">- Estamos num per횄짯odo de neutralidade clim횄징tica</segment>
    <segment id="29">, sem fen횄쨈menos</segment>
    <segment id="30">comocomo El Ni횄짹o (fen횄쨈meno de aquecimento das 횄징guas do Oceano Pac횄짯fico</segment>
    <segment id="31">, que aumenta a pluviosidade na Am횄짤rica).</segment>
    <segment id="32">Mas estes choques acabam formando chuvas e tempestades sobre o Sul - justifica.</segment>
    <segment id="33">Na Capital</segment>
    <segment id="34">, o volume acumulado de chuvas tamb횄짤m est횄징 previsto para ficar ligeiramente acima da m횄짤dia - de 139mm poder횄징 chegar a 145mm no m횄짧s.
- Quando para a chuva</segment>
    <segment id="35">, a횄짯 횄짤 que aumenta a 횄징gua.</segment>
    <segment id="36">O relato da auxiliar de produ횄짠횄짙o Iara Terezinha dos Santos da Silva</segment>
    <segment id="37">, 45 anos</segment>
    <segment id="38">, define bem a realidade enfrentada pelos moradores do Bairro Americana</segment>
    <segment id="39">, em Alvorada.</segment>
    <segment id="40">O dia de sol</segment>
    <segment id="41">, que poderia trazer al횄짯vio</segment>
    <segment id="42">, nem de perto</segment>
    <segment id="43">횄짤 o fim da tormenta.</segment>
    <segment id="44">Mesmo que a chuva</segment>
    <segment id="45">, respons횄징vel pelo aumento no n횄짯vel do Arroio Feij횄쨀</segment>
    <segment id="46">, j횄징 tenha parado</segment>
    <segment id="47">, a 횄징gua continua a descer de outros rios e c횄쨀rregos rumo ao Gua횄짯ba.</segment>
    <segment id="48">Por isso</segment>
    <segment id="49">, o volume tende a aumentar</segment>
    <segment id="50">, dando in횄짯cio ao sofrimento da comunidade. 
- Metade da minha casa est횄징 alagada</segment>
    <segment id="51">, desde ter횄짠a-feira.</segment>
    <segment id="52">E t횄징 subindo cada vez mais.</segment>
    <segment id="53">Eu tinha comprado material de constru횄짠횄짙o</segment>
    <segment id="54">, areia</segment>
    <segment id="55">, cimento</segment>
    <segment id="56">, foi tudo fora - lamenta Iara</segment>
    <segment id="57">, atravessando a Rua Itarar횄짤 com 횄징gua pelos joelhos</segment>
    <segment id="58">, com os filhos Rafael</segment>
    <segment id="59">, sete anos</segment>
    <segment id="60">, e Tamires</segment>
    <segment id="61">, 24 anos.</segment>
    <segment id="62">Sem creche</segment>
    <segment id="63">, sem trabalho
Ao lado dela</segment>
    <segment id="64">, a confeiteira Taiane Ma횄짯sa Lopes de Souza</segment>
    <segment id="65">, 31 anos</segment>
    <segment id="66">, levava os filhos Thales</segment>
    <segment id="67">, cinco anos</segment>
    <segment id="68">, e David</segment>
    <segment id="69">, quatro anos</segment>
    <segment id="70">, pelas m횄짙os.</segment>
    <segment id="71">As botas dos meninos n횄짙o davam conta de proteg횄짧-los da 횄징gua fria e suja.</segment>
    <segment id="72">Sem ter onde deix횄징-los</segment>
    <segment id="73">, porque</segment>
    <segment id="74">porque a 횄쨘nica creche do bairro est횄징 alagada</segment>
    <segment id="75">, Taiane</segment>
    <segment id="76">sese revolta com a situa횄짠횄짙o. 
- A gente n횄짙o pode trabalhar</segment>
    <segment id="77">, porque</segment>
    <segment id="78">porque n횄짙o tem onde deixar as crian횄짠as.</segment>
    <segment id="79">E isso n횄짙o 횄짤 de hoje.</segment>
    <segment id="80">Estamos s횄쨀 organizando as casas e vamos</segment>
    <segment id="81">embora</segment>
    <segment id="82">embora</segment>
    <segment id="83">, porque</segment>
    <segment id="84">porque n횄짙o d횄징 pra ficar aqui sem luz - desabafa.</segment>
    <segment id="85">Nos mais de 30 anos que mora na Rua Gaspar Martins</segment>
    <segment id="86">, no Bairro Sumar횄짤</segment>
    <segment id="87">, em Alvorada</segment>
    <segment id="88">, o graniteiro Jo횄짙o Ant횄쨈nio Deviti</segment>
    <segment id="89">, 56 anos</segment>
    <segment id="90">, j횄징 se</segment>
    <segment id="91">se acostumou a enfrentar alagamentos quase todos os anos. 
- Eu sempre peguei enchente</segment>
    <segment id="92">, toda a vida</segment>
    <segment id="93">횄짤 assim - relata.</segment>
    <segment id="94">Com mais de 40cm de 횄징gua dentro de casa</segment>
    <segment id="95">, ele ergueu os m횄쨀veis que conseguiu e saiu com a mulher para</segment>
    <segment id="96">sese abrigar na casa de amigos.</segment>
    <segment id="97">Mas n횄짙o ficou distante por muito tempo.</segment>
    <segment id="98">De bermudas e chinelos</segment>
    <segment id="99">, enfrentou o aguaceiro na manh횄짙 de ontem para ver</segment>
    <segment id="100">comocomo estava a situa횄짠횄짙o da moradia.
- Essa 횄짤 uma das enchentes mais fortes.</segment>
    <segment id="101">Mas vamos enfrentar a 횄징gua - conforma-</segment>
    <segment id="102">sese.</segment>
    <segment id="103">Plano foi montado</segment>
    <segment id="104">Um atendimento de emerg횄짧ncia foi montado pela prefeitura na Rua Itarar횄짤</segment>
    <segment id="105">, com servi횄짠os de cadastramento para distribui횄짠횄짙o de mantimentos e agasalhos</segment>
    <segment id="106">, unidade m횄쨀vel de sa횄쨘de</segment>
    <segment id="107">, utiliza횄짠횄짙o de m횄징quinas para retirada de m횄쨀veis e apoio dos bombeiros.</segment>
    <segment id="108">Na tarde de ontem</segment>
    <segment id="109">, em parceria com a Corsan e com o acompanhamento do Dep</segment>
    <segment id="110">, teve in횄짯cio o bombeamento de 횄징gua para o canal nas proximidades da Fiergs</segment>
    <segment id="111">, na Capital</segment>
    <segment id="112">, para minimizar os danos do alagamento no Bairro Americana.</segment>
    <segment id="113">O n횄쨘mero de desalojados (acolhidos em casas de parentes e amigos)</segment>
    <segment id="114">, chegou a 635 pessoas.</segment>
    <segment id="115">H횄징 necessidade de doa횄짠횄쨉es de cobertores</segment>
    <segment id="116">, colch횄쨉es e roupas para crian횄짠as de at횄짤 dez anos</segment>
    <segment id="117">, al횄짤m de itens de higiene e limpeza.</segment>
    <segment id="118">Situa횄짠횄짙o preocupante no Vale do Sinos*</segment>
    <segment id="119">A enchente que atingiu o Vale do Sinos deixou gente</segment>
    <segment id="120">, como</segment>
    <segment id="121">como Cleidiano Vitorino da Silva</segment>
    <segment id="122">, 30 anos</segment>
    <segment id="123">, em situa횄짠횄짙o dif횄짯cil.</segment>
    <segment id="124">Morador do Bairro Feitoria</segment>
    <segment id="125">, em S횄짙o Leopoldo</segment>
    <segment id="126">, desde domingo ele troca a guarda com o cunhado sobre o telhado da casa</segment>
    <segment id="127">, para evitar saques no local.
- N횄짙o arredo p횄짤.</segment>
    <segment id="128">Daqui d횄징 para vigiar a minha casa e a dos vizinhos.</segment>
    <segment id="129">Quando cai a noite</segment>
    <segment id="130">, os vagabundos passam de barco por aqui rondando para saquear as casas.</segment>
    <segment id="131">Aqui eles n횄짙o entram</segment>
    <segment id="132">porque</segment>
    <segment id="133">porque a gente foca - diz.</segment>
    <segment id="134">Ele integra um contingente de 17.754 pessoas afetadas pelas inunda횄짠횄쨉es em 36 munic횄짯pios</segment>
    <segment id="135">, conforme dados da Defesa Civil estadual.</segment>
    <segment id="136">Um n횄쨘mero que cresceu</segment>
    <segment id="137">, pois</segment>
    <segment id="138">pois estava em 9.986 atingidos no boletim das 18h de quarta-feira.</segment>
    <segment id="139">At횄짤 ontem</segment>
    <segment id="140">, tr횄짧s pessoas haviam morrido</segment>
    <segment id="141">, e uma</segment>
    <segment id="142">sese feriu.</segment>
    <segment id="143">Dos 14</segment>
    <segment id="144">,8 mil desalojados no Estado</segment>
    <segment id="145">, 8 mil est횄짙o em S횄짙o Leopoldo e 3 mil em Novo Hamburgo.</segment>
    <segment id="146">Mais tr횄짧s dias para baixar</segment>
    <segment id="147">O tenente-coronel Alexandre Teixeira dos Santos</segment>
    <segment id="148">, coordenador regional da Defesa Civil na 횄rea Metropolitana</segment>
    <segment id="149">, explica que o n횄짯vel do Rio dos Sinos tem baixado 10cm a cada 12 horas e que o vento continua soprando no sentido Norte</segment>
    <segment id="150">, o que ajuda a aumentar a vaz횄짙o das 횄징guas. 
- Acredito que</segment>
    <segment id="151">, em S횄짙o Leopoldo</segment>
    <segment id="152">, ainda leve 72 horas</segment>
    <segment id="153">para que</segment>
    <segment id="154">para que o n횄짯vel da 횄징gua baixe ao ponto de aliviar as casas.</segment>
    <segment id="155">Em Alvorada</segment>
    <segment id="156">, outra regi횄짙o bem cr횄짯tica (횄짤 uma plan횄짯cie)</segment>
    <segment id="157">, pode levar at횄짤 dez dias - arrisca.</segment>
    <segment id="158">Apesar do sol forte de ontem</segment>
    <segment id="159">, em bairros</segment>
    <segment id="160">comocomo Feitoria e Scharlau</segment>
    <segment id="161">, a 횄징gua passava de um metro de altura em diversas ruas.</segment>
    <segment id="162">Cheia do Sinos
Por que o fim da chuva n횄짙o diminuiu os alagamentos no Vale do Sinos?</segment>
    <segment id="163">Gra횄짠as a uma s횄짤rie de fontes naturais que influenciam na demora da vaz횄짙o da 횄징gua.</segment>
    <segment id="164">횄guas de afluentes - Como a Bacia do Rio dos Sinos tem a contribui횄짠횄짙o de v횄징rios rios e arroios localizados em 횄징reas altas</segment>
    <segment id="165">, muita 횄징gua continua escorrendo do que ficou reservado nelas.</segment>
    <segment id="166">Mesmo diminuindo a velocidade da vaz횄짙o dos afluentes</segment>
    <segment id="167">, a 
횄징gua que estava parada na parte baixa da bacia</segment>
    <segment id="168">, em uma plan횄짯cie</segment>
    <segment id="169">, fica parada.</segment>
    <segment id="170">H횄징 tamb횄짤m o acr횄짤scimo de 횄징gua acumulada no Rio Ca횄짯</segment>
    <segment id="171">, por meio da barragem hidrel횄짤trica da Ceee em S횄짙o Francisco de Paula</segment>
    <segment id="172">, ao Rio Paranhana</segment>
    <segment id="173">, integrante da bacia.</segment>
    <segment id="174">Al횄짤m disso</segment>
    <segment id="175">, quando chove muito</segment>
    <segment id="176">, v횄징rias barragens na parte baixa s횄짙o abertas para dar vaz횄짙o.</segment>
    <segment id="177">Acabam alimentando mais ainda o Rio dos Sinos.</segment>
    <segment id="178">Vento - De s횄징bado at횄짤 ter횄짠a-feira</segment>
    <segment id="179">, o vento soprou forte e constantemente de quadrante sul</segment>
    <segment id="180">, algo que represa a 횄징gua do rio.</segment>
    <segment id="181">Somente na quarta-feira</segment>
    <segment id="182">, o vento ficou mais fraco e come횄짠ou a mudar de sentido.</segment>
    <segment id="183">O ideal para uma r횄징pida vaz횄짙o</segment>
    <segment id="184">횄짤 de que n횄짙o haja vento.</segment>
    <segment id="185">Len횄짠ol fre횄징tico - O len횄짠ol fre횄징tico (reservat횄쨀rio de 횄징gua subterr횄짖nea decorrente da infiltra횄짠횄짙o da 횄징gua da chuva no solo) saturado continua ajudando no aumento do n횄짯vel do rio.</segment>
    <segment id="186">Mesmo com o fim da chuva</segment>
    <segment id="187">, a 횄징gua retida inicialmente come횄짠a a aflorar</segment>
    <segment id="188">, o que aumenta a quantidade na superf횄짯cie.</segment>
    <segment id="189">Temperatura - O solo com temperatura alta ajuda na evapora횄짠횄짙o da 횄징gua e na consequente diminui횄짠횄짙o no n횄짯vel dos rios.</segment>
    <segment id="190">Mas a temperatura do terreno est횄징 muito baixa em fun횄짠횄짙o das ondas de frio registradas desde julho no Estado.</segment>
    <segment id="191">* Por Kamila Almeida (kamila.almeida@zerohora.com.br)</segment>
