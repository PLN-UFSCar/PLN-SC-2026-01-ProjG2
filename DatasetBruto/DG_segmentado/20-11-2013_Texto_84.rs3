    <segment id="28">Maxi estar횄징 inclu횄짯do.</segment>
    <segment id="29">O que n횄짙o sei</segment>
    <segment id="30">, no entanto</segment>
    <segment id="31">, 횄짤 qual ser횄징 a op횄짠횄짙o de Renato.</segment>
