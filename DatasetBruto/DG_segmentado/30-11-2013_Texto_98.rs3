  <rst>
    <segment id="1">Corrente do bem
ConheГғВ§a a histГғВіria de quem faz do Natal uma data ainda mais especial</segment>
    <segment id="2">Durante todo o mГғВӘs de dezembro</segment>
    <segment id="3">, o DiГғВЎrio GaГғВәcho contarГғВЎ histГғВіrias de quem faz desta a data especial dos outros.</segment>
    <segment id="4">Seu Nadir Machado</segment>
    <segment id="5">, ao centro</segment>
    <segment id="6">, fazendo um Natal mais alegre em Alvorada
Aline CustГғВіdio
aline.custodio@diariogaucho.com.br
Eles jamais viram neve na vida</segment>
    <segment id="7">, nГғВЈo cuidam de renas e nГғВЈo moram na LapГғВҙnia.</segment>
    <segment id="8">Tampouco</segment>
    <segment id="9">, atendem pelo nome do bom velhinho.</segment>
    <segment id="10">Fazem parte</segment>
    <segment id="11">, porГғВ©m</segment>
    <segment id="12">, de uma parcela da populaГғВ§ГғВЈo que</segment>
    <segment id="13">sese transforma em papais e mamГғВЈes noГғВ©is voluntariamente</segment>
    <segment id="14">, dispostos a transformar o Natal daqueles que nГғВЈo o tem.</segment>
    <segment id="15">Durante todo o mГғВӘs de dezembro</segment>
    <segment id="16">, o DiГғВЎrio GaГғВәcho contarГғВЎ histГғВіrias de quem faz desta a data especial dos outros.</segment>
    <segment id="17">Hoje, trГғВӘs histГғВіrias que jГғВЎ passaram pelas pГғВЎginas do jornal serГғВЈo contadas pelos prГғВіprios entrevistados.</segment>
    <segment id="18">Para Dalva</segment>
    <segment id="19">, Nadir</segment>
    <segment id="20">, JoГғВЈo e Araci a data</segment>
    <segment id="21">sese torna sinГғВҙnimo de doaГғВ§ГғВЈo</segment>
    <segment id="22">, amor e persistГғВӘncia.</segment>
    <segment id="23">Dalva Terezinha da Costa</segment>
    <segment id="24">, 55 anos</segment>
    <segment id="25">, da Grande Cruzeiro</segment>
    <segment id="26">, em Porto Alegre - 14 anos de voluntariado.</segment>
    <segment id="27">Faz festa para 350 crianГғВ§as.</segment>
    <segment id="28">Aceita doaГғВ§ГғВөes de brinquedos</segment>
    <segment id="29">, refrigerantes e balas.</segment>
    <segment id="30">A festa serГғВЎ no dia 25 /12</segment>
    <segment id="31">, ГғВ  tarde.</segment>
    <segment id="32">Contato: 3232-5455 e 9352-0362</segment>
    <segment id="33">"</segment>
    <segment id="34">HГғ</segment>
    <segment id="35">ВЎ 14 anos</segment>
    <segment id="36">, meu marido foi assaltado e levou cinco tiros.</segment>
    <segment id="37">Ficou entre a vida e a morte.</segment>
    <segment id="38">Prometi que</segment>
    <segment id="39">sese ele ficasse bom</segment>
    <segment id="40">, eu faria uma festa no Natal com a gurizada da vila.</segment>
    <segment id="41">Ele melhorou</segment>
    <segment id="42">, masmas nГғВЈo tive dinheiro para dar presentes na data.</segment>
    <segment id="43">SГғВі enchi um saco de papel e saГғВӯ pelas ruas vestida de Papai Noel.</segment>
    <segment id="44">Com o tempo e a ajuda de vizinhos e voluntГғВЎrios anГғВҙnimos</segment>
    <segment id="45">, a festa cresceu.</segment>
    <segment id="46">Hoje, comemoramos a PГғВЎscoa</segment>
    <segment id="47">, o Dia das CrianГғВ§as e o Natal.</segment>
    <segment id="48">ГғвҖ° o Natal que mais me emociona</segment>
    <segment id="49">porque</segment>
    <segment id="50">porque eles passam o ano inteiro esperando por este momento.</segment>
    <segment id="51">Mas hГғВЎ dois anos</segment>
    <segment id="52">, diminuГғВӯram as doaГғВ§ГғВөes.</segment>
    <segment id="53">Hoje, confesso que ainda nГғВЈo ganhei nada.</segment>
    <segment id="54">Os doadores nГғВЈo apareceram.</segment>
    <segment id="55">Estou preocupada</segment>
    <segment id="56">, masmas nГғВЈo vou desistir.</segment>
    <segment id="57">Se for preciso sairei sГғВі com o saco vazio para animГғВЎ-los.</segment>
    <segment id="58">Quando a gente comeГғВ§a a fazer um trabalho</segment>
    <segment id="59">comocomo este</segment>
    <segment id="60">, nГғВЈo pode simplesmente parar.</segment>
    <segment id="61">JГғВЎ estou na segunda geraГғВ§ГғВЈo de crianГғВ§as.</segment>
    <segment id="62">E eles estГғВЈo esperando os presentes que sГғВі terГғВЈo a chance de ganhar aqui.</segment>
    <segment id="63">"</segment>
    <segment id="64">Nadir Machado Pereira</segment>
    <segment id="65">, 53 anos</segment>
    <segment id="66">, do Bairro Umbu</segment>
    <segment id="67">, em Alvorada - 10 anos de voluntariado.</segment>
    <segment id="68">Faz festa para 350 crianГғВ§as.</segment>
    <segment id="69">Aceita doaГғВ§ГғВөes de brinquedos</segment>
    <segment id="70">, roupas</segment>
    <segment id="71">, calГғВ§ados</segment>
    <segment id="72">, salsicha</segment>
    <segment id="73">, pГғВЈes</segment>
    <segment id="74">, bolos e brinquedos inflГғВЎveis.</segment>
    <segment id="75">A festa serГғВЎ no dia 25/12</segment>
    <segment id="76">, ГғВ s 14h.</segment>
    <segment id="77">Contato: 9886-1499.</segment>
    <segment id="78">"</segment>
    <segment id="79">Comecei distribuindo sacolinhas de presentes na vila onde moro.</segment>
    <segment id="80">Depois</segment>
    <segment id="81">, a festa de Natal foi parar no pГғВЎtio da minha casa.</segment>
    <segment id="82">HГғВЎ dois anos</segment>
    <segment id="83">, ganhamos um terreno e fundamos uma associaГғВ§ГғВЈo que</segment>
    <segment id="84">, entre as atividades</segment>
    <segment id="85">, organiza festas de PГғВЎscoa</segment>
    <segment id="86">, Dia das CrianГғВ§as e Natal sempre com a ajuda de doadores.</segment>
    <segment id="87">Durante o ano inteiro</segment>
    <segment id="88">, acompanho as 350 crianГғВ§as que participam do Natal.</segment>
    <segment id="89">ГғвҖ° preciso saber</segment>
    <segment id="90">sese seguem morando no mesmo endereГғВ§o.</segment>
    <segment id="91">Nosso sonho ГғВ© conseguir brinquedos inflГғВЎveis e um banheiro quГғВӯmico para serem usados na festa.</segment>
    <segment id="92">Mas este ano estГғВЎ muito difГғВӯcil.</segment>
    <segment id="93">HГғВЎ dois meses</segment>
    <segment id="94">, perdi um dos meus filhos que ajudava a organizar tudo.</segment>
    <segment id="95">Como sigo me recuperando do luto</segment>
    <segment id="96">, nГғВЈo consegui sair pedindo no comГғ</segment>
    <segment id="97">В©rcio da cidade.</segment>
    <segment id="98">EntГғВЈo</segment>
    <segment id="99">, sГғВі tenho duas sacolas de brinquedos.</segment>
    <segment id="100">Isso, nГғВЈo darГғВЎ nem para o comeГғВ§o.</segment>
    <segment id="101">Meu marido</segment>
    <segment id="102">, meus outros trГғВӘs filhos e meus ajudantes de MamГғВЈe Noel estГғВЈo me dando forГғВ§as para seguir.</segment>
    <segment id="103">Tenho alguns meninos que me auxiliam antes e no dia da festa.</segment>
    <segment id="104">Para isso</segment>
    <segment id="105">, precisam estar com boas notas na escola e ter bom comportamento na vila.</segment>
    <segment id="106">SГғВЈo eles que estГғВЈo me animando a voltar a sorrir.</segment>
    <segment id="107">Isso que fizemos ГғВ© de uma responsabilidade sem tamanho.</segment>
    <segment id="108">ГғвҖ° feito com carinho</segment>
    <segment id="109">, com amor.</segment>
    <segment id="110">As crianГғВ§as precisam disso.</segment>
    <segment id="111">E eu, ainda mais.</segment>
    <segment id="112">"
JoГғВЈo e Araci Rodrigues</segment>
    <segment id="113">, de 52 e 60 anos</segment>
    <segment id="114">, respectivamente</segment>
    <segment id="115">, do Jardim Estalagem</segment>
    <segment id="116">, em ViamГғВЈo - 25 anos de voluntariado.</segment>
    <segment id="117">Promovem festa para 550 crianГғВ§as.</segment>
    <segment id="118">Aceitam doaГғВ§ГғВөes de refrigerantes e brinquedos.</segment>
    <segment id="119">A festa serГғВЎ no dia 21/12</segment>
    <segment id="120">, ГғВ  tarde.</segment>
    <segment id="121">Contato: 8544-9789 e 8544-9799
"</segment>
    <segment id="122">Em 1989</segment>
    <segment id="123">, nossa filha</segment>
    <segment id="124">sese vestiu de Papai Noel e prometeu a um menino que ele ganharia um brinquedo naquela noite de Natal.</segment>
    <segment id="125">No outro dia</segment>
    <segment id="126">, o garoto veio chorando atГғВ© ela e disse que nГғВЈo havia recebido o presente e</segment>
    <segment id="127">, por este motivo</segment>
    <segment id="128">, deixaria de acreditar na data.</segment>
    <segment id="129">Aquilo nos cortou o coraГғВ§ГғВЈo.</segment>
    <segment id="130">No outro Natal</segment>
    <segment id="131">, juntamos brinquedos e distribuГғВӯmos pelo bairro.</segment>
    <segment id="132">Nunca mais paramos.</segment>
    <segment id="133">Hoje, a movimentaГғВ§ГғВЈo aqui em casa com as primeiras doaГғВ§ГғВөes comeГғВ§a em agosto.</segment>
    <segment id="134">ComeГғВ§amos a reformar os brinquedos doados ao longo do ano.</segment>
    <segment id="135">No final de novembro</segment>
    <segment id="136">, juntamos os nossos dois 13ГӮВә salГғВЎrios e saГғВӯmos a comprar brinquedos novos.</segment>
    <segment id="137">No dia da festa</segment>
    <segment id="138">, me visto de Papai Noel e minha cabeГғВ§a fica um turbilhГғВЈo.</segment>
    <segment id="139">ГғвҖ° muita emoГғВ§ГғВЈo a cada abraГғВ§o.</segment>
    <segment id="140">O presente pode ser simples</segment>
    <segment id="141">, masmas precisa ser dado de coraГғВ§ГғВЈo.</segment>
    <segment id="142">Tem que ser espontГғВўneo</segment>
    <segment id="143">, sem outros interesses.</segment>
    <segment id="144">Nunca visamos nada para si.</segment>
    <segment id="145">SГғВі queremos dar alegria a quem tem dificuldade.</segment>
    <segment id="146">" (JoГғВЈo) "</segment>
    <segment id="147">Numa ГғВ©poca em que todos estГғВЈo voltados para o seu prГғВіprio umbigo</segment>
    <segment id="148">, como</segment>
    <segment id="149">como ГғВ© bom olhar para o outro e vГғВӘ-lo sorrir.</segment>
    <segment id="150">Isso nos gratifica muito.</segment>
    <segment id="151">Eles me agradecem</segment>
    <segment id="152">, e eu agradeГғВ§o a eles por aquele momento.</segment>
    <segment id="153">O que mais importa na festa ГғВ© que as crianГғВ§as saibam que sГғВЈo importantes para alguГғВ©</segment>
    <segment id="154">m. ГғвҖ° esta a imagem que fica do Papai Noel" (Araci)</segment>
  </rst>
</analysis>