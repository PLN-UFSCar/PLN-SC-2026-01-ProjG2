    <segment id="26">O impacto da baixa</segment>
    <segment id="27">, no entanto</segment>
    <segment id="28">, n횄짙o foi t횄짙o forte</segment>
    <segment id="29">porque</segment>
    <segment id="30">porque o resultado j횄징 era esperado.</segment>
    <segment id="31">O desconto no Imposto sobre Produtos Industrializados (IPI) fez os 횄짯ndices da ind횄쨘stria automobil횄짯stica dispararem no in횄짯cio do segundo semestre de 2012 - julho alcan횄짠ou a marca de terceiro melhor da hist횄쨀ria.</segment>
    <segment id="32">Acumulado do ano segue positivo</segment>
    <segment id="33">A retra횄짠횄짙o aumenta o volume de ve횄짯culos nos p횄징tios das montadoras.</segment>
    <segment id="34">O cen횄징rio</segment>
    <segment id="35">, por횄짤m</segment>
    <segment id="36">, equilibra os estoques</segment>
    <segment id="37">, que haviam ca횄짯do em fun횄짠횄짙o da greve do caminhoneiros e das paradas em v횄징rias f횄징bricas   na greve geral do dia 11.</segment>
    <segment id="38">O resultado no in횄짯cio de julho reduz o crescimento acumulado de vendas em 2013</segment>
    <segment id="39">, na compara횄짠횄짙o com o ano passado.</segment>
    <segment id="40">Ainda assim</segment>
    <segment id="41">, o 횄짯ndice</segment>
    <segment id="42">, em 3</segment>
    <segment id="43">,14%, continua em super횄징vit.</segment>
    <segment id="44">Por enquanto</segment>
    <segment id="45">, as proje횄짠횄쨉es para o final de 2013 est횄짙o mantidas.</segment>
    <segment id="46">As previs횄쨉es apontam crescimento global de 1</segment>
    <segment id="47">,98% e de 3</segment>
