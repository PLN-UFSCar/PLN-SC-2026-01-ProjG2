    <segment id="77">O inverno chegou com toda for횄짠a.</segment>
    <segment id="78">A temperatura despencou com direito a sensa횄짠횄쨉es t횄짤rmicas abaixo de zero e neve em v횄징rias cidades ga횄쨘chas.</segment>
    <segment id="79">Nestas condi횄짠횄쨉es</segment>
    <segment id="80">횄짤 comum surgir a dificuldade em ligar o carro abastecido com etanol nas primeiras tentativas</segment>
    <segment id="81">, principalmente nas manh횄짙s mais frias.</segment>
    <segment id="82">Para evitar atrasos ao sair de casa e</segment>
    <segment id="83">, sobretudo</segment>
    <segment id="84">, agravamento de problemas no motor</segment>
    <segment id="85">, o motorista deve tomar alguns cuidados.</segment>
    <segment id="86">Velas de igni횄짠횄짙o excessivamente desgastadas ou com vida 횄쨘til ultrapassada podem prejudicar o desempenho do ve횄짯culo e dificultar a partida ap횄쨀s o motor ficar desligado por longos per횄짯odos</segment>
    <segment id="87">, como</segment>
    <segment id="88">como em noites com baixas temperaturas</segment>
    <segment id="89">, por exemplo.</segment>
    <segment id="90">A manuten횄짠횄짙o preventiva 횄짤 a melhor op횄짠횄짙o.</segment>
    <segment id="91">Velas em bom estado de conserva횄짠횄짙o garantem o funcionamento da igni횄짠횄짙o do ve횄짯culo</segment>
    <segment id="92">, facilitando a partida imediata do motor.</segment>
    <segment id="93">Mesmo em modelos mais modernos</segment>
    <segment id="94">, equipados com sistemas que dispensam a utiliza횄짠횄짙o do reservat횄쨀rio de gasolina para injetar o combust횄짯vel na partida a frio</segment>
    <segment id="95">, a vela de igni횄짠횄짙o tem papel fundamental no sucesso da opera횄짠횄짙o.</segment>
    <segment id="96">Por isso</segment>
    <segment id="97">, os ve횄짯culos com vela desgastada tamb횄짤</segment>
    <segment id="98">m ter횄짙o dificuldade na partida.
- Para que o etanol mude</segment>
    <segment id="99">seu estado f횄짯sico durante a queima e proporcione o funcionamento do motor</segment>
    <segment id="100">, s횄짙o necess횄징rias temperaturas mais elevadas que as exigidas pela gasolina</segment>
    <segment id="101">, que evapora rapidamente - explica Hiromori Mori</segment>
    <segment id="102">, t횄짤cnico da assist횄짧ncia NGK.</segment>
    <segment id="103">Ficar for횄짠ando pode piorar o problema</segment>
    <segment id="104">A insist횄짧ncia em ligar o motor tamb횄짤m pode causar o encharcamento das velas.</segment>
    <segment id="105">Caso ocorra</segment>
    <segment id="106">, 횄짤 preciso desligar o carro e aguardar que o combust횄짯vel evapore por completo.</segment>
    <segment id="107">O tempo varia de um ve횄짯culo para outro</segment>
    <segment id="108">, e pode levar at횄짤 30 minutos.</segment>
