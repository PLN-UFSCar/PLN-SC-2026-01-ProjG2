  <rst>
    <segment id="1">PMs estГѓВЈo nas ruas</segment>
    <segment id="2">, masmas cobertor ainda ГѓВ© curto
Falta de patrulhamento provoca inseguranГѓВ§a na Capital
Nos dias 8 e 9 de maio</segment>
    <segment id="3">, a reportagem do DiГѓВЎrio GaГѓВєcho completou 14 horas rodando por 126km entre as principais vias das zonas Sul</segment>
    <segment id="4">, Leste e Norte da Capital para conferir a presenГѓВ§a do policiamento nas ruas.</segment>
    <segment id="5">Com o ingresso de 483 novos soldados na Brigada Militar em Porto Alegre</segment>
    <segment id="6">, a garantia do governo estadual era retomar a ideia dos PMs "Pedro e Paulo"</segment>
    <segment id="7">, aqueles policiais que</segment>
    <segment id="8">, em dupla e a pГѓВ©</segment>
    <segment id="9">, ficam visГѓВ­veis e conhecidos da comunidade.</segment>
    <segment id="10">Eduardo Torres</segment>
    <segment id="11">;</segment>
    <segment id="12">Carolina Rocha
eduardo.torres@diariogaucho.com.br</segment>
    <segment id="13">; carolina.rocha@diariogaucho.com.br
AtГѓВ© certo ponto</segment>
    <segment id="14">, a promessa foi cumprida.</segment>
    <segment id="15">Mas, assim</segment>
    <segment id="16">comocomo jГѓВЎ havia acontecido em outras safras de reforГѓВ§os na Brigada</segment>
    <segment id="17">, a realidade do cobertor curto voltou a ocorrer.</segment>
    <segment id="18">Se a presenГѓВ§a de policiais em avenidas</segment>
    <segment id="19">comocomo a Bento GonГѓВ§alves e a Assis Brasil trouxe alГѓВ­vio aos comerciantes</segment>
    <segment id="20">, em vias nevrГѓВЎlgicas da Zona Sul isso nГѓВЈo</segment>
    <segment id="21">sese repetiu.</segment>
    <segment id="22">Durante o levantamento</segment>
    <segment id="23">, no primeiro dia foram vistos a pГѓ</segment>
    <segment id="24">В©</segment>
    <segment id="25">29 policiais e</segment>
    <segment id="26">, no segundo</segment>
    <segment id="27">, 24 - todos recГѓВ©m-integrados.</segment>
    <segment id="28">Circulando em viaturas</segment>
    <segment id="29">, foram 36 no primeiro dia e</segment>
    <segment id="30">, no segundo</segment>
    <segment id="31">, outros 59.</segment>
    <segment id="32">"</segment>
    <segment id="33">Eu tenho que ser realista"</segment>
    <segment id="34">De acordo com o responsГѓВЎvel pelo Comando de Policiamento da Capital (CPC)</segment>
    <segment id="35">, coronel JoГѓВЈo Diniz Prates GodГѓВіi</segment>
    <segment id="36">, a chegada das novas turmas reforГѓВ§ou o policiamento ostensivo.
- Melhorou bastante.</segment>
    <segment id="37">Quanto mais gente eu tiver</segment>
    <segment id="38">, melhor.</segment>
    <segment id="39">Tenho que ser realista</segment>
    <segment id="40">, fazer com aquilo que eu tenho e usar da melhor forma possГѓВ­vel - disse o comandante.</segment>
    <segment id="41">AlГѓВ©m dos 483 novos PMs</segment>
    <segment id="42">, Porto Alegre deve receber 95 do Interior</segment>
    <segment id="43">, cujas transferГѓВЄncias ainda nГѓВЈo foram finalizadas.</segment>
    <segment id="44">Com isso</segment>
    <segment id="45">, o efetivo da Capital chegaria a 3 mil PMs.</segment>
    <segment id="46">Segundo estudos</segment>
    <segment id="47">, o ideal seriam5 mil policiais militares.</segment>
    <segment id="48">Ainda assim</segment>
    <segment id="49">, o coronel comemora</segment>
    <segment id="50">, pois</segment>
    <segment id="51">pois garante que a populaГѓВ§ГѓВЈo tem dado retorno:
- Eu tenho recebido relatos de pessoas que tГѓВЄm visto policiamento montado</segment>
    <segment id="52">, a pГѓВ© e motorizado pelas ruas.</segment>
    <segment id="53">E isso jГѓВЎ</segment>
    <segment id="54">ГѓВ© um reflexo.</segment>
    <segment id="55">Algumas vezes</segment>
    <segment id="56">, a gente modifica o policiamento para poder atender determinado evento</segment>
    <segment id="57">, ou os PMs saem para levar um preso para a delegacia.</segment>
    <segment id="58">Isso sim</segment>
    <segment id="59">, pode variar - explicou.</segment>
    <segment id="60">Melhorou</segment>
    <segment id="61">, porГѓВ©m o medo ainda persiste
HГѓВЎ duas semanas</segment>
    <segment id="62">, desde que o PM Portela foi efetivado no 20Г‚Вє BPM</segment>
    <segment id="63">, funcionГѓВЎrios da farmГѓВЎcia na esquina da Avenida Assis Brasil com Rua AbaetГѓВ©</segment>
    <segment id="64">, Bairro Sarandi</segment>
    <segment id="65">, tГѓВЄm um novo vizinho.</segment>
    <segment id="66">A quadra</segment>
    <segment id="67">sese tornou atribuiГѓВ§ГѓВЈo dele</segment>
    <segment id="68">, que patrulha a regiГѓВЈo a pГѓВ©.</segment>
    <segment id="69">A presenГѓВ§a dele parece ter mudado o clima.
- ГѓвЂ° um alГѓВ­vio</segment>
    <segment id="70">, nГѓВ©?</segment>
    <segment id="71">A gente trabalha com muito mais tranquilidade sabendo que temos a quem recorrer.</segment>
    <segment id="72">Desde que entraram os novos policiais</segment>
    <segment id="73">, melhorou - destaca uma atendente.</segment>
    <segment id="74">Ela nГѓВЈo</segment>
    <segment id="75">sese identifica.</segment>
    <segment id="76">Ainda tem na lembranГѓВ§a cenas de uma semana antes da presenГѓВ§a do policiamento na avenida.</segment>
    <segment id="77">Em um domingo</segment>
    <segment id="78">, os funcionГѓВЎrios foram mantidos sob a mira de um revГѓВіlver durante assalto.</segment>
    <segment id="79">A Brigada sГѓВі chegou depois</segment>
    <segment id="80">, acionada pelas vГѓВ­timas.</segment>
    <segment id="81">Mas, se</segment>
    <segment id="82">se uma das principais vias da Zona Norte</segment>
    <segment id="83">sese tornou bom exemplo</segment>
    <segment id="84">, o mesmo nГѓВЈo</segment>
    <segment id="85">sese pode dizer da vizinhanГѓВ§a.</segment>
    <segment id="86">Na Avenida Bernardino Silveira Amorim</segment>
    <segment id="87">, que separa os bairros Rubem Berta e Sarandi e ГѓВ© uma das recordistas em homicГѓВ­dios</segment>
    <segment id="88">, a aposentada Joice Dias</segment>
    <segment id="89">, 57 anos</segment>
    <segment id="90">, nГѓВЈo notou diferenГѓВ§a.
- Continua a mesma coisa.</segment>
    <segment id="91">SГѓВі aparece polГѓВ­cia quando tem desgraГѓВ§a.</segment>
    <segment id="92">Brigadiano a pГѓВ©</segment>
    <segment id="93">, eu nunca vi - diz.</segment>
